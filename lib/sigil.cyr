    _sha_ni_pack_k_word(_sha_ni_K + 176, 0xd192e819);
    _sha_ni_pack_k_word(_sha_ni_K + 180, 0xd6990624);
    _sha_ni_pack_k_word(_sha_ni_K + 184, 0xf40e3585);
    _sha_ni_pack_k_word(_sha_ni_K + 188, 0x106aa070);
    _sha_ni_pack_k_word(_sha_ni_K + 192, 0x19a4c116);
    _sha_ni_pack_k_word(_sha_ni_K + 196, 0x1e376c08);
    _sha_ni_pack_k_word(_sha_ni_K + 200, 0x2748774c);
    _sha_ni_pack_k_word(_sha_ni_K + 204, 0x34b0bcb5);
    _sha_ni_pack_k_word(_sha_ni_K + 208, 0x391c0cb3);
    _sha_ni_pack_k_word(_sha_ni_K + 212, 0x4ed8aa4a);
    _sha_ni_pack_k_word(_sha_ni_K + 216, 0x5b9cca4f);
    _sha_ni_pack_k_word(_sha_ni_K + 220, 0x682e6ff3);
    _sha_ni_pack_k_word(_sha_ni_K + 224, 0x748f82ee);
    _sha_ni_pack_k_word(_sha_ni_K + 228, 0x78a5636f);
    _sha_ni_pack_k_word(_sha_ni_K + 232, 0x84c87814);
    _sha_ni_pack_k_word(_sha_ni_K + 236, 0x8cc70208);
    _sha_ni_pack_k_word(_sha_ni_K + 240, 0x90befffa);
    _sha_ni_pack_k_word(_sha_ni_K + 244, 0xa4506ceb);
    _sha_ni_pack_k_word(_sha_ni_K + 248, 0xbef9a3f7);
    _sha_ni_pack_k_word(_sha_ni_K + 252, 0xc67178f2);
    return 0;
}

# ================================================================
# _sha_ni_compress_one — single-block SHA-NI compress.
#
# Parameters arrive on the stack at:
#   [rbp-8]  ctx     — 144-byte SHA-256 context (h0..h7 at +0,
#                       block buffer at +64)
#   [rbp-16] buf     — 80-byte module global. Layout:
#                        +0..31  packed state in/out
#                        +32..47 ABEF_save
#                        +48..63 CDGH_save
#                        +64..79 PSHUFFLE_BYTE_FLIP_MASK
#   [rbp-24] kbuf    — 256-byte packed K table
#
# 3 params (rather than 4) so the [rbp-N] spill convention is the
# one cycc has used reliably for asm-block functions since 2.9.1
# (`aes_ni.cyr`'s 3-param `aes256_encrypt_block_ni`); cycc.5.30 may
# spill a 4th param into a register rather than the stack, which
# breaks the `mov ..., [rbp-32]` form.
#
# Register usage inside the asm block:
#   rdi = ctx, rsi = buf, rcx = kbuf, rdx = scalar tmp
#   xmm0 = MSG, xmm1 = STATE0 (ABEF), xmm2 = STATE1 (CDGH),
#   xmm3 = MSGTMP0, xmm4 = MSGTMP1, xmm5 = MSGTMP2, xmm6 = MSGTMP3,
#   xmm7 = MSGTMP4 (palignr scratch)
#
# All XMM registers are caller-saved in System V x86-64 — clobber
# is safe because the asm block is straight-line with no calls
# and Cyrius does not expect XMM state across the block.
# ================================================================
fn _sha_ni_compress_one(ctx, buf, kbuf): i64 {
    #ifdef CYRIUS_ARCH_X86
    asm {
        # ── Param loads ───────────────────────────────────────────
        0x48; 0x8B; 0x7D; 0xF8;    # mov rdi, [rbp-8]   (ctx)
        0x48; 0x8B; 0x75; 0xF0;    # mov rsi, [rbp-16]  (buf)
        0x48; 0x8B; 0x4D; 0xE8;    # mov rcx, [rbp-24]  (kbuf)

        # ── Pack ctx h0..h7 (8 sparse 64-bit slots, low 32 bits each)
        #    into scratch[0..31] (8 packed little-endian dwords).
        #    Each pair is `mov edx, [rdi+8i]` + `mov [rsi+4i], edx`.
        0x8B; 0x57; 0x00; 0x89; 0x56; 0x00;
        0x8B; 0x57; 0x08; 0x89; 0x56; 0x04;
        0x8B; 0x57; 0x10; 0x89; 0x56; 0x08;
        0x8B; 0x57; 0x18; 0x89; 0x56; 0x0C;
        0x8B; 0x57; 0x20; 0x89; 0x56; 0x10;
        0x8B; 0x57; 0x28; 0x89; 0x56; 0x14;
        0x8B; 0x57; 0x30; 0x89; 0x56; 0x18;
        0x8B; 0x57; 0x38; 0x89; 0x56; 0x1C;

        # ── State setup: load packed ABCD/EFGH, permute to ABEF/CDGH ─
        0xF3; 0x0F; 0x6F; 0x4E; 0x00;          # movdqu xmm1, [rsi+0]   STATE0=ABCD
        0xF3; 0x0F; 0x6F; 0x56; 0x10;          # movdqu xmm2, [rsi+16]  STATE1=EFGH
        0x66; 0x0F; 0x70; 0xC9; 0xB1;          # pshufd xmm1, xmm1, 0xB1   →[b,a,d,c]
        0x66; 0x0F; 0x70; 0xD2; 0x1B;          # pshufd xmm2, xmm2, 0x1B   →[h,g,f,e]
        0x66; 0x0F; 0x6F; 0xF9;                # movdqa xmm7, xmm1     save pre-palignr
        0x66; 0x0F; 0x3A; 0x0F; 0xCA; 0x08;    # palignr xmm1, xmm2, 8 STATE0=ABEF=[f,e,b,a]
        0x66; 0x0F; 0x3A; 0x0E; 0xD7; 0xF0;    # pblendw xmm2, xmm7,F0 STATE1=CDGH=[h,g,d,c]

        # ── Save ABEF/CDGH for the post-loop add ──────────────────
        0xF3; 0x0F; 0x7F; 0x4E; 0x20;          # movdqu [rsi+32], xmm1  (ABEF_save)
        0xF3; 0x0F; 0x7F; 0x56; 0x30;          # movdqu [rsi+48], xmm2  (CDGH_save)

        # ── Iter 0 — Rounds 0..3 — load MSGTMP0 = W[0..3] ─────────
        0xF3; 0x0F; 0x6F; 0x47; 0x40;          # movdqu xmm0, [rdi+64]
        0x66; 0x0F; 0x38; 0x00; 0x46; 0x40;    # pshufb xmm0, [rsi+64]
        0x66; 0x0F; 0x6F; 0xD8;                # movdqa xmm3, xmm0      MSGTMP0
        0x66; 0x0F; 0xFE; 0x41; 0x00;          # paddd  xmm0, [rcx+0]
        0x0F; 0x38; 0xCB; 0xD1;                # sha256rnds2 xmm2, xmm1
        0x66; 0x0F; 0x70; 0xC0; 0x0E;          # pshufd xmm0, xmm0, 0x0E
        0x0F; 0x38; 0xCB; 0xCA;                # sha256rnds2 xmm1, xmm2

        # ── Iter 1 — Rounds 4..7 — load MSGTMP1 = W[4..7] ─────────
        0xF3; 0x0F; 0x6F; 0x47; 0x50;          # movdqu xmm0, [rdi+80]
        0x66; 0x0F; 0x38; 0x00; 0x46; 0x40;    # pshufb xmm0, [rsi+64]
        0x66; 0x0F; 0x6F; 0xE0;                # movdqa xmm4, xmm0      MSGTMP1
        0x66; 0x0F; 0xFE; 0x41; 0x10;          # paddd  xmm0, [rcx+16]
        0x0F; 0x38; 0xCB; 0xD1;                # sha256rnds2 xmm2, xmm1
        0x66; 0x0F; 0x70; 0xC0; 0x0E;          # pshufd xmm0, xmm0, 0x0E
        0x0F; 0x38; 0xCB; 0xCA;                # sha256rnds2 xmm1, xmm2
        0x0F; 0x38; 0xCC; 0xDC;                # sha256msg1 xmm3, xmm4   MSGTMP0+=σ0

        # ── Iter 2 — Rounds 8..11 — load MSGTMP2 = W[8..11] ───────
        0xF3; 0x0F; 0x6F; 0x47; 0x60;          # movdqu xmm0, [rdi+96]
        0x66; 0x0F; 0x38; 0x00; 0x46; 0x40;    # pshufb xmm0, [rsi+64]
        0x66; 0x0F; 0x6F; 0xE8;                # movdqa xmm5, xmm0      MSGTMP2
        0x66; 0x0F; 0xFE; 0x41; 0x20;          # paddd  xmm0, [rcx+32]
        0x0F; 0x38; 0xCB; 0xD1;                # sha256rnds2 xmm2, xmm1
        0x66; 0x0F; 0x70; 0xC0; 0x0E;          # pshufd xmm0, xmm0, 0x0E
        0x0F; 0x38; 0xCB; 0xCA;                # sha256rnds2 xmm1, xmm2
        0x0F; 0x38; 0xCC; 0xE5;                # sha256msg1 xmm4, xmm5   MSGTMP1+=σ0

        # ── Iter 3 — Rounds 12..15 — load MSGTMP3 = W[12..15];
        #    also compute MSGTMP0 = W[16..19] for iter 4. ──────────
        0xF3; 0x0F; 0x6F; 0x47; 0x70;          # movdqu xmm0, [rdi+112]
        0x66; 0x0F; 0x38; 0x00; 0x46; 0x40;    # pshufb xmm0, [rsi+64]
        0x66; 0x0F; 0x6F; 0xF0;                # movdqa xmm6, xmm0      MSGTMP3
        0x66; 0x0F; 0xFE; 0x41; 0x30;          # paddd  xmm0, [rcx+48]
        0x0F; 0x38; 0xCB; 0xD1;                # sha256rnds2 xmm2, xmm1
        0x66; 0x0F; 0x6F; 0xFE;                # movdqa xmm7, xmm6      tmp ← MSGTMP3
        0x66; 0x0F; 0x3A; 0x0F; 0xFD; 0x04;    # palignr xmm7, xmm5, 4  W[9..12]
        0x66; 0x0F; 0xFE; 0xDF;                # paddd  xmm3, xmm7      MSGTMP0 += W[9..12]
        0x0F; 0x38; 0xCD; 0xDE;                # sha256msg2 xmm3, xmm6  MSGTMP0 = W[16..19]
        0x66; 0x0F; 0x70; 0xC0; 0x0E;          # pshufd xmm0, xmm0, 0x0E
        0x0F; 0x38; 0xCB; 0xCA;                # sha256rnds2 xmm1, xmm2
        0x0F; 0x38; 0xCC; 0xEE;                # sha256msg1 xmm5, xmm6   MSGTMP2+=σ0

        # ── Iter 4 — Rounds 16..19 — MSGTMP0 already W[16..19];
        #    compute MSGTMP1 = W[20..23] ────────────────────────────
        0x66; 0x0F; 0x6F; 0xC3;                # movdqa xmm0, xmm3
        0x66; 0x0F; 0xFE; 0x41; 0x40;          # paddd  xmm0, [rcx+64]
        0x0F; 0x38; 0xCB; 0xD1;                # sha256rnds2 xmm2, xmm1
        0x66; 0x0F; 0x6F; 0xFB;                # movdqa xmm7, xmm3
        0x66; 0x0F; 0x3A; 0x0F; 0xFE; 0x04;    # palignr xmm7, xmm6, 4
        0x66; 0x0F; 0xFE; 0xE7;                # paddd  xmm4, xmm7
        0x0F; 0x38; 0xCD; 0xE3;                # sha256msg2 xmm4, xmm3   MSGTMP1=W[20..23]
        0x66; 0x0F; 0x70; 0xC0; 0x0E;          # pshufd xmm0, xmm0, 0x0E
        0x0F; 0x38; 0xCB; 0xCA;                # sha256rnds2 xmm1, xmm2
        0x0F; 0x38; 0xCC; 0xF3;                # sha256msg1 xmm6, xmm3

        # ── Iter 5 — Rounds 20..23 — compute MSGTMP2 = W[24..27] ──
        0x66; 0x0F; 0x6F; 0xC4;                # movdqa xmm0, xmm4
        0x66; 0x0F; 0xFE; 0x41; 0x50;          # paddd  xmm0, [rcx+80]
        0x0F; 0x38; 0xCB; 0xD1;
        0x66; 0x0F; 0x6F; 0xFC;                # movdqa xmm7, xmm4
        0x66; 0x0F; 0x3A; 0x0F; 0xFB; 0x04;    # palignr xmm7, xmm3, 4
        0x66; 0x0F; 0xFE; 0xEF;                # paddd  xmm5, xmm7
        0x0F; 0x38; 0xCD; 0xEC;                # sha256msg2 xmm5, xmm4
        0x66; 0x0F; 0x70; 0xC0; 0x0E;
        0x0F; 0x38; 0xCB; 0xCA;
        0x0F; 0x38; 0xCC; 0xDC;                # sha256msg1 xmm3, xmm4

        # ── Iter 6 — Rounds 24..27 — compute MSGTMP3 = W[28..31] ──
        0x66; 0x0F; 0x6F; 0xC5;                # movdqa xmm0, xmm5
        0x66; 0x0F; 0xFE; 0x41; 0x60;          # paddd  xmm0, [rcx+96]
        0x0F; 0x38; 0xCB; 0xD1;
        0x66; 0x0F; 0x6F; 0xFD;                # movdqa xmm7, xmm5
        0x66; 0x0F; 0x3A; 0x0F; 0xFC; 0x04;    # palignr xmm7, xmm4, 4
        0x66; 0x0F; 0xFE; 0xF7;                # paddd  xmm6, xmm7
        0x0F; 0x38; 0xCD; 0xF5;                # sha256msg2 xmm6, xmm5
        0x66; 0x0F; 0x70; 0xC0; 0x0E;
        0x0F; 0x38; 0xCB; 0xCA;
        0x0F; 0x38; 0xCC; 0xE5;                # sha256msg1 xmm4, xmm5

        # ── Iter 7 — Rounds 28..31 — compute MSGTMP0 = W[32..35] ──
        0x66; 0x0F; 0x6F; 0xC6;                # movdqa xmm0, xmm6
        0x66; 0x0F; 0xFE; 0x41; 0x70;          # paddd  xmm0, [rcx+112]
        0x0F; 0x38; 0xCB; 0xD1;
        0x66; 0x0F; 0x6F; 0xFE;                # movdqa xmm7, xmm6
        0x66; 0x0F; 0x3A; 0x0F; 0xFD; 0x04;    # palignr xmm7, xmm5, 4
        0x66; 0x0F; 0xFE; 0xDF;                # paddd  xmm3, xmm7
        0x0F; 0x38; 0xCD; 0xDE;                # sha256msg2 xmm3, xmm6
        0x66; 0x0F; 0x70; 0xC0; 0x0E;
        0x0F; 0x38; 0xCB; 0xCA;
        0x0F; 0x38; 0xCC; 0xEE;                # sha256msg1 xmm5, xmm6

        # ── Iter 8 — Rounds 32..35 — disp32 K offset 128 onward ──
        0x66; 0x0F; 0x6F; 0xC3;                # movdqa xmm0, xmm3
        0x66; 0x0F; 0xFE; 0x81; 0x80; 0x00; 0x00; 0x00;  # paddd xmm0, [rcx+128]
        0x0F; 0x38; 0xCB; 0xD1;
        0x66; 0x0F; 0x6F; 0xFB;                # movdqa xmm7, xmm3
        0x66; 0x0F; 0x3A; 0x0F; 0xFE; 0x04;    # palignr xmm7, xmm6, 4
        0x66; 0x0F; 0xFE; 0xE7;                # paddd  xmm4, xmm7
        0x0F; 0x38; 0xCD; 0xE3;                # sha256msg2 xmm4, xmm3
        0x66; 0x0F; 0x70; 0xC0; 0x0E;
        0x0F; 0x38; 0xCB; 0xCA;
        0x0F; 0x38; 0xCC; 0xF3;                # sha256msg1 xmm6, xmm3

        # ── Iter 9 — Rounds 36..39 ──────────────────────────────
        0x66; 0x0F; 0x6F; 0xC4;
        0x66; 0x0F; 0xFE; 0x81; 0x90; 0x00; 0x00; 0x00;  # [rcx+144]
        0x0F; 0x38; 0xCB; 0xD1;
        0x66; 0x0F; 0x6F; 0xFC;
        0x66; 0x0F; 0x3A; 0x0F; 0xFB; 0x04;
        0x66; 0x0F; 0xFE; 0xEF;
        0x0F; 0x38; 0xCD; 0xEC;
        0x66; 0x0F; 0x70; 0xC0; 0x0E;
        0x0F; 0x38; 0xCB; 0xCA;
        0x0F; 0x38; 0xCC; 0xDC;

        # ── Iter 10 — Rounds 40..43 ─────────────────────────────
        0x66; 0x0F; 0x6F; 0xC5;
        0x66; 0x0F; 0xFE; 0x81; 0xA0; 0x00; 0x00; 0x00;  # [rcx+160]
        0x0F; 0x38; 0xCB; 0xD1;
        0x66; 0x0F; 0x6F; 0xFD;
        0x66; 0x0F; 0x3A; 0x0F; 0xFC; 0x04;
        0x66; 0x0F; 0xFE; 0xF7;
        0x0F; 0x38; 0xCD; 0xF5;
        0x66; 0x0F; 0x70; 0xC0; 0x0E;
        0x0F; 0x38; 0xCB; 0xCA;
        0x0F; 0x38; 0xCC; 0xE5;

        # ── Iter 11 — Rounds 44..47 ─────────────────────────────
        0x66; 0x0F; 0x6F; 0xC6;
        0x66; 0x0F; 0xFE; 0x81; 0xB0; 0x00; 0x00; 0x00;  # [rcx+176]
        0x0F; 0x38; 0xCB; 0xD1;
        0x66; 0x0F; 0x6F; 0xFE;
        0x66; 0x0F; 0x3A; 0x0F; 0xFD; 0x04;
        0x66; 0x0F; 0xFE; 0xDF;
        0x0F; 0x38; 0xCD; 0xDE;
        0x66; 0x0F; 0x70; 0xC0; 0x0E;
        0x0F; 0x38; 0xCB; 0xCA;
        0x0F; 0x38; 0xCC; 0xEE;

        # ── Iter 12 — Rounds 48..51 ─────────────────────────────
        0x66; 0x0F; 0x6F; 0xC3;
        0x66; 0x0F; 0xFE; 0x81; 0xC0; 0x00; 0x00; 0x00;  # [rcx+192]
        0x0F; 0x38; 0xCB; 0xD1;
        0x66; 0x0F; 0x6F; 0xFB;
        0x66; 0x0F; 0x3A; 0x0F; 0xFE; 0x04;
        0x66; 0x0F; 0xFE; 0xE7;
        0x0F; 0x38; 0xCD; 0xE3;
        0x66; 0x0F; 0x70; 0xC0; 0x0E;
        0x0F; 0x38; 0xCB; 0xCA;
        0x0F; 0x38; 0xCC; 0xF3;

        # ── Iter 13 — Rounds 52..55 — drop sha256msg1 (no longer
        #    needed: msg1 precomputes for iter+3 = 16, out of range) ─
        0x66; 0x0F; 0x6F; 0xC4;
        0x66; 0x0F; 0xFE; 0x81; 0xD0; 0x00; 0x00; 0x00;  # [rcx+208]
        0x0F; 0x38; 0xCB; 0xD1;
        0x66; 0x0F; 0x6F; 0xFC;
        0x66; 0x0F; 0x3A; 0x0F; 0xFB; 0x04;
        0x66; 0x0F; 0xFE; 0xEF;
        0x0F; 0x38; 0xCD; 0xEC;
        0x66; 0x0F; 0x70; 0xC0; 0x0E;
        0x0F; 0x38; 0xCB; 0xCA;

        # ── Iter 14 — Rounds 56..59 ─────────────────────────────
        0x66; 0x0F; 0x6F; 0xC5;
        0x66; 0x0F; 0xFE; 0x81; 0xE0; 0x00; 0x00; 0x00;  # [rcx+224]
        0x0F; 0x38; 0xCB; 0xD1;
        0x66; 0x0F; 0x6F; 0xFD;
        0x66; 0x0F; 0x3A; 0x0F; 0xFC; 0x04;
        0x66; 0x0F; 0xFE; 0xF7;
        0x0F; 0x38; 0xCD; 0xF5;
        0x66; 0x0F; 0x70; 0xC0; 0x0E;
        0x0F; 0x38; 0xCB; 0xCA;

        # ── Iter 15 — Rounds 60..63 — drop ALL schedule work ───
        0x66; 0x0F; 0x6F; 0xC6;
        0x66; 0x0F; 0xFE; 0x81; 0xF0; 0x00; 0x00; 0x00;  # [rcx+240]
        0x0F; 0x38; 0xCB; 0xD1;
        0x66; 0x0F; 0x70; 0xC0; 0x0E;
        0x0F; 0x38; 0xCB; 0xCA;

        # ── Final add: STATE0 += ABEF_save; STATE1 += CDGH_save ──
        0x66; 0x0F; 0xFE; 0x4E; 0x20;          # paddd xmm1, [rsi+32]
        0x66; 0x0F; 0xFE; 0x56; 0x30;          # paddd xmm2, [rsi+48]

        # ── Reverse state setup: ABEF/CDGH → ABCD/EFGH packed ───
        0x66; 0x0F; 0x70; 0xC9; 0x1B;          # pshufd xmm1, xmm1, 0x1B → [A,B,E,F]
        0x66; 0x0F; 0x70; 0xD2; 0xB1;          # pshufd xmm2, xmm2, 0xB1 → [G,H,C,D]
        0x66; 0x0F; 0x6F; 0xF9;                # movdqa xmm7, xmm1
        0x66; 0x0F; 0x3A; 0x0E; 0xCA; 0xF0;    # pblendw xmm1, xmm2, 0xF0 → [A,B,C,D]
        0x66; 0x0F; 0x3A; 0x0F; 0xD7; 0x08;    # palignr xmm2, xmm7, 8   → [E,F,G,H]
        0xF3; 0x0F; 0x7F; 0x4E; 0x00;          # movdqu [rsi+0],  xmm1
        0xF3; 0x0F; 0x7F; 0x56; 0x10;          # movdqu [rsi+16], xmm2

        # ── Unpack scratch packed dwords back to ctx h0..h7 with
        #    zero-extending 64-bit stores so the high 32 bits of
        #    each ctx slot stay zero (sha256.cyr's invariant). ────
        0x8B; 0x56; 0x00; 0x48; 0x89; 0x57; 0x00;
        0x8B; 0x56; 0x04; 0x48; 0x89; 0x57; 0x08;
        0x8B; 0x56; 0x08; 0x48; 0x89; 0x57; 0x10;
        0x8B; 0x56; 0x0C; 0x48; 0x89; 0x57; 0x18;
        0x8B; 0x56; 0x10; 0x48; 0x89; 0x57; 0x20;
        0x8B; 0x56; 0x14; 0x48; 0x89; 0x57; 0x28;
        0x8B; 0x56; 0x18; 0x48; 0x89; 0x57; 0x30;
        0x8B; 0x56; 0x1C; 0x48; 0x89; 0x57; 0x38;
    }
    #endif
    return 0;
}

# sha256_transform_ni — SHA-NI single-block compression (live in 2.9.3).
#
# Caller contract:
#   - ctx points to a 144-byte SHA-256 context (h0..h7 at +0,
#     buf at +64)
#   - returns 0 on success (compressed in hardware)
#
# `sha256_transform`'s dispatcher in src/sha256.cyr falls through
# to the FIPS 180-4 software path on hosts where the CPUID probe
# returns 0; this entry point is only invoked when SHA-NI is live.
fn sha256_transform_ni(ctx): i64 {
    if (_sha_ni_buf == 0) { _sha_ni_init(); }
    _sha_ni_compress_one(ctx, _sha_ni_buf, _sha_ni_K);
    return 0;
}

# --- sha256.cyr ---

# sha256.cyr — FIPS 180-4 SHA-256 implementation
# All arithmetic masked to 32 bits. Working state in globals
# to survive nested function calls (Cyrius compiler constraint).
#
# `sha256_transform` dispatches to the SHA-NI hardware path via
# `sha_ni_available()` / `sha256_transform_ni()`; pull the dispatch
# infrastructure in so single-file consumers (test harnesses that
# include only `src/sha256.cyr`) link cleanly.


var MASK32 = 0xFFFFFFFF;

# ================================================================
# Bitwise helpers (32-bit)
# ================================================================

fn rotr32(x, n): i64 {
    return ((x >> n) | ((x << (32 - n)) & MASK32)) & MASK32;
}

fn shr32(x, n): i64 {
    return (x >> n) & MASK32;
}

# ================================================================
# SHA-256 sub-functions
# ================================================================

fn sha256_ch(x, y, z): i64 {
    return ((x & y) ^ ((x ^ MASK32) & z)) & MASK32;
}

fn sha256_maj(x, y, z): i64 {
    return ((x & y) ^ (x & z) ^ (y & z)) & MASK32;
}

fn sha256_bsig0(x): i64 {
    return (rotr32(x, 2) ^ rotr32(x, 13) ^ rotr32(x, 22)) & MASK32;
}

fn sha256_bsig1(x): i64 {
    return (rotr32(x, 6) ^ rotr32(x, 11) ^ rotr32(x, 25)) & MASK32;
}

fn sha256_ssig0(x): i64 {
    return (rotr32(x, 7) ^ rotr32(x, 18) ^ shr32(x, 3)) & MASK32;
}

fn sha256_ssig1(x): i64 {
    return (rotr32(x, 17) ^ rotr32(x, 19) ^ shr32(x, 10)) & MASK32;
}

# ================================================================
# Round constants K[0..63] and initialization
# ================================================================

var _sha256_K = 0;
var _sha256_W = 0;
var _sha256_inited = 0;

fn sha256_global_init(): i64 {
    if (_sha256_inited == 1) { return 0; }

    _sha256_K = alloc(512);
    store64(_sha256_K + 0, 0x428a2f98);
    store64(_sha256_K + 8, 0x71374491);
    store64(_sha256_K + 16, 0xb5c0fbcf);
    store64(_sha256_K + 24, 0xe9b5dba5);
    store64(_sha256_K + 32, 0x3956c25b);
    store64(_sha256_K + 40, 0x59f111f1);
    store64(_sha256_K + 48, 0x923f82a4);
    store64(_sha256_K + 56, 0xab1c5ed5);
    store64(_sha256_K + 64, 0xd807aa98);
    store64(_sha256_K + 72, 0x12835b01);
    store64(_sha256_K + 80, 0x243185be);
    store64(_sha256_K + 88, 0x550c7dc3);
    store64(_sha256_K + 96, 0x72be5d74);
    store64(_sha256_K + 104, 0x80deb1fe);
    store64(_sha256_K + 112, 0x9bdc06a7);
    store64(_sha256_K + 120, 0xc19bf174);
    store64(_sha256_K + 128, 0xe49b69c1);
    store64(_sha256_K + 136, 0xefbe4786);
    store64(_sha256_K + 144, 0x0fc19dc6);
    store64(_sha256_K + 152, 0x240ca1cc);
    store64(_sha256_K + 160, 0x2de92c6f);
    store64(_sha256_K + 168, 0x4a7484aa);
    store64(_sha256_K + 176, 0x5cb0a9dc);
    store64(_sha256_K + 184, 0x76f988da);
    store64(_sha256_K + 192, 0x983e5152);
    store64(_sha256_K + 200, 0xa831c66d);
    store64(_sha256_K + 208, 0xb00327c8);
    store64(_sha256_K + 216, 0xbf597fc7);
    store64(_sha256_K + 224, 0xc6e00bf3);
    store64(_sha256_K + 232, 0xd5a79147);
    store64(_sha256_K + 240, 0x06ca6351);
    store64(_sha256_K + 248, 0x14292967);
    store64(_sha256_K + 256, 0x27b70a85);
    store64(_sha256_K + 264, 0x2e1b2138);
    store64(_sha256_K + 272, 0x4d2c6dfc);
    store64(_sha256_K + 280, 0x53380d13);
    store64(_sha256_K + 288, 0x650a7354);
    store64(_sha256_K + 296, 0x766a0abb);
    store64(_sha256_K + 304, 0x81c2c92e);
    store64(_sha256_K + 312, 0x92722c85);
    store64(_sha256_K + 320, 0xa2bfe8a1);
    store64(_sha256_K + 328, 0xa81a664b);
    store64(_sha256_K + 336, 0xc24b8b70);
    store64(_sha256_K + 344, 0xc76c51a3);
    store64(_sha256_K + 352, 0xd192e819);
    store64(_sha256_K + 360, 0xd6990624);
    store64(_sha256_K + 368, 0xf40e3585);
    store64(_sha256_K + 376, 0x106aa070);
    store64(_sha256_K + 384, 0x19a4c116);
    store64(_sha256_K + 392, 0x1e376c08);
    store64(_sha256_K + 400, 0x2748774c);
    store64(_sha256_K + 408, 0x34b0bcb5);
    store64(_sha256_K + 416, 0x391c0cb3);
    store64(_sha256_K + 424, 0x4ed8aa4a);
    store64(_sha256_K + 432, 0x5b9cca4f);
    store64(_sha256_K + 440, 0x682e6ff3);
    store64(_sha256_K + 448, 0x748f82ee);
    store64(_sha256_K + 456, 0x78a5636f);
    store64(_sha256_K + 464, 0x84c87814);
    store64(_sha256_K + 472, 0x8cc70208);
    store64(_sha256_K + 480, 0x90befffa);
    store64(_sha256_K + 488, 0xa4506ceb);
    store64(_sha256_K + 496, 0xbef9a3f7);
    store64(_sha256_K + 504, 0xc67178f2);

    _sha256_W = alloc(512);
    _sha256_inited = 1;
    return 0;
}

# ================================================================
# SHA-256 context
# ================================================================
# Layout (144 bytes):
#   +0   h0..h7   (8 x 8 = 64 bytes) hash state words
#   +64  buf      (64 bytes) partial block buffer
#   +128 buf_len  (8 bytes)
#   +136 total_len (8 bytes)

fn sha256_init(): i64 {
    sha256_global_init();
    var ctx = fl_alloc(144);
    store64(ctx, 0x6a09e667);
    store64(ctx + 8, 0xbb67ae85);
    store64(ctx + 16, 0x3c6ef372);
    store64(ctx + 24, 0xa54ff53a);
    store64(ctx + 32, 0x510e527f);
    store64(ctx + 40, 0x9b05688c);
    store64(ctx + 48, 0x1f83d9ab);
    store64(ctx + 56, 0x5be0cd19);
    memset(ctx + 64, 0, 64);
    store64(ctx + 128, 0);
    store64(ctx + 136, 0);
    return ctx;
}

# ================================================================
# Compression function — globals for working state
# ================================================================

var _sha_a = 0;
var _sha_b = 0;
var _sha_c = 0;
var _sha_d = 0;
var _sha_e = 0;
var _sha_f = 0;
var _sha_g = 0;
var _sha_hv = 0;
var _sha_t1 = 0;
var _sha_t2 = 0;
var _sha_ctx = 0;
var _sha_i = 0;

fn sha256_transform(ctx): i64 {
    # SHA-NI dispatch wire-point (2.9.2 foundation).
    # When sha256_transform_ni returns 0 it has fully transformed
    # the block and we return early. The 2.9.2 stub returns -1 so
    # this falls through to the software path on every host; 2.9.3
    # replaces the stub body with a byte-encoded SHA-NI compress.
    if (sha_ni_available() == 1) {
        if (sha256_transform_ni(ctx) == 0) { return 0; }
    }

    _sha_ctx = ctx;
    var buf = ctx + 64;

    # Prepare message schedule W[0..15] from block (big-endian)
    _sha_i = 0;
    while (_sha_i < 16) {
        var off = _sha_i * 4;
        var w = ((load8(buf + off) & 0xFF) << 24)
        | ((load8(buf + off + 1) & 0xFF) << 16)
        | ((load8(buf + off + 2) & 0xFF) << 8)
        | (load8(buf + off + 3) & 0xFF);
        store64(_sha256_W + _sha_i * 8, w & MASK32);
        _sha_i = _sha_i + 1;
    }

    # Extend W[16..63]
    _sha_i = 16;
    while (_sha_i < 64) {
        var w16 = load64(_sha256_W + (_sha_i - 16) * 8);
        var w15 = load64(_sha256_W + (_sha_i - 15) * 8);
        var w7 = load64(_sha256_W + (_sha_i - 7) * 8);
        var w2 = load64(_sha256_W + (_sha_i - 2) * 8);
        var s0 = sha256_ssig0(w15);
        # _sha_i may be clobbered — reload from W offsets computed before calls
        var s1 = sha256_ssig1(w2);
        store64(_sha256_W + _sha_i * 8, (w16 + s0 + w7 + s1) & MASK32);
        _sha_i = _sha_i + 1;
    }

    # Initialize working variables
    _sha_a = load64(_sha_ctx);
    _sha_b = load64(_sha_ctx + 8);
    _sha_c = load64(_sha_ctx + 16);
    _sha_d = load64(_sha_ctx + 24);
    _sha_e = load64(_sha_ctx + 32);
    _sha_f = load64(_sha_ctx + 40);
    _sha_g = load64(_sha_ctx + 48);
    _sha_hv = load64(_sha_ctx + 56);

    # 64 rounds — accumulate into globals between function calls
    _sha_i = 0;
    while (_sha_i < 64) {
        _sha_t1 = _sha_hv;
        _sha_t1 = (_sha_t1 + sha256_bsig1(_sha_e)) & MASK32;
        _sha_t1 = (_sha_t1 + sha256_ch(_sha_e, _sha_f, _sha_g)) & MASK32;
        _sha_t1 = (_sha_t1 + load64(_sha256_K + _sha_i * 8)) & MASK32;
        _sha_t1 = (_sha_t1 + load64(_sha256_W + _sha_i * 8)) & MASK32;

        _sha_t2 = sha256_bsig0(_sha_a);
        _sha_t2 = (_sha_t2 + sha256_maj(_sha_a, _sha_b, _sha_c)) & MASK32;

        _sha_hv = _sha_g;
        _sha_g = _sha_f;
        _sha_f = _sha_e;
        _sha_e = (_sha_d + _sha_t1) & MASK32;
        _sha_d = _sha_c;
        _sha_c = _sha_b;
        _sha_b = _sha_a;
        _sha_a = (_sha_t1 + _sha_t2) & MASK32;
        _sha_i = _sha_i + 1;
    }

    # Add compressed chunk to current hash value
    store64(_sha_ctx, (load64(_sha_ctx) + _sha_a) & MASK32);
    store64(_sha_ctx + 8, (load64(_sha_ctx + 8) + _sha_b) & MASK32);
    store64(_sha_ctx + 16, (load64(_sha_ctx + 16) + _sha_c) & MASK32);
    store64(_sha_ctx + 24, (load64(_sha_ctx + 24) + _sha_d) & MASK32);
    store64(_sha_ctx + 32, (load64(_sha_ctx + 32) + _sha_e) & MASK32);
    store64(_sha_ctx + 40, (load64(_sha_ctx + 40) + _sha_f) & MASK32);
    store64(_sha_ctx + 48, (load64(_sha_ctx + 48) + _sha_g) & MASK32);
    store64(_sha_ctx + 56, (load64(_sha_ctx + 56) + _sha_hv) & MASK32);
    return 0;
}

# ================================================================
# Update — feed data into the hash context
# ================================================================

fn sha256_update(ctx, data, len): i64 {
    var buf_len = load64(ctx + 128);
    var total = load64(ctx + 136);
    total = total + len;
    store64(ctx + 136, total);

    var pos = 0;

    # Fill partial buffer first
    if (buf_len > 0) {
        var need = 64 - buf_len;
        if (len < need) {
            memcpy(ctx + 64 + buf_len, data, len);
            store64(ctx + 128, buf_len + len);
            return 0;
        }
        memcpy(ctx + 64 + buf_len, data, need);
        sha256_transform(ctx);
        pos = need;
        buf_len = 0;
    }

    # Process full 64-byte blocks
    while (pos + 64 <= len) {
        memcpy(ctx + 64, data + pos, 64);
        sha256_transform(ctx);
        pos = pos + 64;
    }

    # Buffer remaining bytes
    var remaining = len - pos;
    if (remaining > 0) {
        memcpy(ctx + 64, data + pos, remaining);
    }
    store64(ctx + 128, remaining);
    return 0;
}

# ================================================================
# Finalize — pad and produce 32-byte digest
# ================================================================

fn sha256_finalize(ctx, out): i64 {
    var buf_len = load64(ctx + 128);
    var total_bits = load64(ctx + 136) * 8;

    # Append 0x80 byte
    store8(ctx + 64 + buf_len, 0x80);
    buf_len = buf_len + 1;

    # If buffer > 56 bytes, pad and process extra block
    if (buf_len > 56) {
        memset(ctx + 64 + buf_len, 0, 64 - buf_len);
        sha256_transform(ctx);
        buf_len = 0;
    }
    memset(ctx + 64 + buf_len, 0, 56 - buf_len);

    # Append total length as 64-bit big-endian at bytes 56-63
    store8(ctx + 64 + 56, (total_bits >> 56) & 0xFF);
    store8(ctx + 64 + 57, (total_bits >> 48) & 0xFF);
    store8(ctx + 64 + 58, (total_bits >> 40) & 0xFF);
    store8(ctx + 64 + 59, (total_bits >> 32) & 0xFF);
    store8(ctx + 64 + 60, (total_bits >> 24) & 0xFF);
    store8(ctx + 64 + 61, (total_bits >> 16) & 0xFF);
    store8(ctx + 64 + 62, (total_bits >> 8) & 0xFF);
    store8(ctx + 64 + 63, total_bits & 0xFF);

    sha256_transform(ctx);

    # Write 32-byte digest in big-endian from h0-h7
    var di = 0;
    while (di < 8) {
        var word = load64(ctx + di * 8);
        store8(out + di * 4, (word >> 24) & 0xFF);
        store8(out + di * 4 + 1, (word >> 16) & 0xFF);
        store8(out + di * 4 + 2, (word >> 8) & 0xFF);
        store8(out + di * 4 + 3, word & 0xFF);
        di = di + 1;
    }
    return 0;
}

# ================================================================
# Convenience — hash data in one shot
# ================================================================

fn sha256(data, len, out): i64 {
    var ctx = sha256_init();
    sha256_update(ctx, data, len);
    sha256_finalize(ctx, out);
    fl_free(ctx);
    return 0;
}

# --- hex.cyr ---

# hex.cyr — hex encoding and decoding

# ================================================================
# Hex encode: bytes -> lowercase hex C-string
# ================================================================

fn hex_encode(bytes, len): i64 {
    var out = alloc(len * 2 + 1);
    var i = 0;
    while (i < len) {
        var b = load8(bytes + i) & 0xFF;
        var hi = (b >> 4) & 0xF;
        var lo = b & 0xF;
        if (hi < 10) { store8(out + i * 2, 48 + hi); }
        else { store8(out + i * 2, 87 + hi); }
        if (lo < 10) { store8(out + i * 2 + 1, 48 + lo); }
        else { store8(out + i * 2 + 1, 87 + lo); }
        i = i + 1;
    }
    store8(out + len * 2, 0);
    return out;
}

# ================================================================
# Hex decode: hex C-string + length -> raw bytes
# ================================================================

fn _hex_nibble(c): i64 {
    if (c >= 48) { if (c <= 57) { return c - 48; } }
    if (c >= 97) { if (c <= 102) { return c - 87; } }
    if (c >= 65) { if (c <= 70) { return c - 55; } }
    return (0 - 1);
}

fn _hex_is_valid_char(c): i64 {
    if (c >= 48) { if (c <= 57) { return 1; } }
    if (c >= 97) { if (c <= 102) { return 1; } }
    if (c >= 65) { if (c <= 70) { return 1; } }
    return 0;
}

# Returns 1 if hex_str is a valid even-length hex C-string of hex_len chars.
fn hex_is_valid(hex_str, hex_len): i64 {
    if (hex_len == 0) { return 0; }
    if ((hex_len & 1) == 1) { return 0; }
    var i = 0;
    while (i < hex_len) {
        if (_hex_is_valid_char(load8(hex_str + i) & 0xFF) == 0) { return 0; }
        i = i + 1;
    }
    return 1;
}

# Decode hex to bytes. Returns 0 (null) on invalid input
# (odd length, non-hex char). Caller MUST null-check.
fn hex_decode(hex_str, hex_len): i64 {
    if ((hex_len & 1) == 1) { return 0; }
    var blen = hex_len / 2;
    if (blen == 0) { return 0; }
    var out = alloc(blen);
    var i = 0;
    while (i < blen) {
        var hi = _hex_nibble(load8(hex_str + i * 2) & 0xFF);
        var lo = _hex_nibble(load8(hex_str + i * 2 + 1) & 0xFF);
        if (hi < 0) { return 0; }
        if (lo < 0) { return 0; }
        store8(out + i, (hi << 4) | lo);
        i = i + 1;
    }
    return out;
}

# ================================================================
# Convenience: hash bytes to hex string
# ================================================================

fn sha256_hex(data, len): i64 {
    var digest[32];
    sha256(data, len, &digest);
    return hex_encode(&digest, 32);
}

fn sha512_hex(data, len): i64 {
    var digest[64];
    sha512(data, len, &digest);
    return hex_encode(&digest, 64);
}

# --- hmac.cyr ---

# hmac.cyr — HMAC-SHA256 (RFC 2104)
# Proper ipad/opad construction, not simplified SHA-256(key||msg).
#
# Status in 3.0: sigil-internal primitive. Public consumers should
# call `hkdf_*` (src/hkdf.cyr) rather than `hmac_sha256` directly
# — HMAC's hot-path role in sigil is as the HKDF extract/expand
# building block, and exposing it as a top-level API would
# encourage miscomposition (consumers rolling their own KDFs when
# HKDF already covers the use case correctly). The 2.x roadmap
# entry proposing a full drop of this module is retired: the
# 2.9.0 HKDF landing pulled `hmac_sha256` into sigil's internal
# call graph, so it stays. `tests/tcyr/crypto.tcyr` and
# `tests/tcyr/security.tcyr` retain hmac-level test vectors as
# unit coverage of the primitive.
#
# HMAC(K, m) = H((K' xor opad) || H((K' xor ipad) || m))
# where:
#   K' = H(K) if len(K) > 64, else K padded to 64 bytes
#   ipad = 0x36 repeated 64 times
#   opad = 0x5c repeated 64 times

# ================================================================
# HMAC-SHA256
# ================================================================

fn hmac_sha256(key, key_len, msg, msg_len, out): i64 {
    # Step 1: Derive K' (64 bytes). `secret var` guarantees the
    # buffer is zeroed on function exit (Cyrius 5.3.5+). The init
    # memset below is retained for program correctness — the
    # key_len < 64 branch relies on the upper bytes being zero.
    secret var kprime[64];
    memset(&kprime, 0, 64);

    if (key_len > 64) {
        # Key too long — hash it
        sha256(key, key_len, &kprime);
        # kprime is now 32 bytes of hash + 32 bytes of zeros
    } else {
        memcpy(&kprime, key, key_len);
        # Rest already zeroed
    }

    # Step 2: inner = SHA-256((K' xor ipad) || message)
    secret var ipad[64];
    var i = 0;
    while (i < 64) {
        store8(&ipad + i, (load8(&kprime + i) & 0xFF) ^ 0x36);
        i = i + 1;
    }

    var inner_ctx = sha256_init();
    sha256_update(inner_ctx, &ipad, 64);
    sha256_update(inner_ctx, msg, msg_len);
    var inner_hash[32];
    sha256_finalize(inner_ctx, &inner_hash);
    fl_free(inner_ctx);

    # Step 3: outer = SHA-256((K' xor opad) || inner)
    secret var opad[64];
    i = 0;
    while (i < 64) {
        store8(&opad + i, (load8(&kprime + i) & 0xFF) ^ 0x5c);
        i = i + 1;
    }

    var outer_ctx = sha256_init();
    sha256_update(outer_ctx, &opad, 64);
    sha256_update(outer_ctx, &inner_hash, 32);
    sha256_finalize(outer_ctx, out);
    fl_free(outer_ctx);

    # kprime / ipad / opad are `secret var` — zeroed on return by
    # the compiler. inner_hash is a public digest; left as a plain
    # var (no security need to clear).
    return 0;
}


# --- hkdf.cyr ---

# hkdf.cyr — HKDF (RFC 5869) on top of HMAC-SHA256
#
# HKDF is a two-stage key derivation function:
#   1. Extract: PRK = HMAC-SHA256(salt, IKM)       (32-byte PRK)
#   2. Expand: OKM = T(1) || T(2) || ... || T(N)
#      where T(0) = empty, T(i) = HMAC-SHA256(PRK, T(i-1) || info || i)
#
# HashLen = 32 (SHA-256), so max OKM length = 255 * 32 = 8160 bytes
# per RFC 5869 §2.3.
#
# Security hygiene (matches sigil's existing pattern):
#   - PRK (the pseudorandom key) is key material and is zeroized
#     before free when the extract+expand convenience function is
#     used. When callers drive extract+expand themselves, they own
#     the PRK buffer and are responsible for zeroization.
#   - T(i-1) and every HMAC intermediate is zeroized after the last
#     block is emitted.
#   - No branch on secret data: the loop count is derived from
#     out_len which is public.
#
# RFC 5869 §2.2: if salt is empty / not provided, use a string of
# HashLen zeros (32 zeros for SHA-256). Callers can pass
# (salt=0, salt_len=0) and this module handles the substitution.
#
# RFC 5869 §2.3: if info is empty / not provided, the concatenation
# "T(i-1) || info || i" collapses to "T(i-1) || i" (info contributes
# zero bytes). Callers can pass (info=0, info_len=0) and this module
# handles that cleanly.

# ================================================================
# hkdf_extract — PRK = HMAC-SHA256(salt, IKM)
# ================================================================
# salt    : pointer to salt bytes (may be 0 if salt_len == 0)
# salt_len: length of salt in bytes
# ikm     : pointer to input keying material
# ikm_len : length of IKM in bytes
# prk_out : caller-provided 32-byte output buffer; receives the PRK
# Returns 0 on success, non-zero on input-validation failure.

fn hkdf_extract(salt, salt_len, ikm, ikm_len, prk_out): i64 {
    if (salt_len < 0) { return (0 - 1); }
    if (ikm_len < 0) { return (0 - 1); }

    # RFC 5869 §2.2: a NULL/empty salt is treated as HashLen zero bytes.
    if (salt_len == 0) {
        var zero_salt[32];
        memset(&zero_salt, 0, 32);
        hmac_sha256(&zero_salt, 32, ikm, ikm_len, prk_out);
        memset(&zero_salt, 0, 32);
        return 0;
    }

    hmac_sha256(salt, salt_len, ikm, ikm_len, prk_out);
    return 0;
}

# ================================================================
# hkdf_expand — OKM = T(1) || T(2) || ... || T(N)
# ================================================================
# prk      : pointer to 32-byte pseudorandom key (output of extract)
# prk_len  : length of PRK (should be >= 32; SHA-256 always gives 32)
# info     : pointer to context/application info (may be 0 if info_len == 0)
# info_len : length of info in bytes
# out      : caller-provided buffer of size >= out_len
# out_len  : number of OKM bytes to produce
#
# Returns:
#   0   on success
#  -1   on negative-length input
#  -2   on out_len > 255*32 (RFC 5869 §2.3 cap)

# Globals: Cyrius single-pass compiler can clobber locals across
# nested call chains. hkdf_expand has a deep call chain (hmac_sha256
# itself calls sha256_init / update / finalize with memcpy/memset
# around them), so the round state lives in globals.
var _hkdf_scratch = 0;
var _hkdf_scratch_len = 0;
var _hkdf_prk = 0;
var _hkdf_prk_len = 0;
var _hkdf_info = 0;
var _hkdf_info_len = 0;
var _hkdf_out = 0;
var _hkdf_out_len = 0;
var _hkdf_produced = 0;
var _hkdf_counter = 0;

fn hkdf_expand(prk, prk_len, info, info_len, out, out_len): i64 {
    if (prk_len < 0) { return (0 - 1); }
    if (info_len < 0) { return (0 - 1); }
    if (out_len < 0) { return (0 - 1); }
    # HashLen = 32. Max OKM = 255 * 32 = 8160 bytes.
    if (out_len > 8160) { return (0 - 2); }
    if (out_len == 0) { return 0; }

    # Promote all parameters to globals so nested HMAC calls can't
    # clobber them via cycc's register allocator.
    _hkdf_prk = prk;
    _hkdf_prk_len = prk_len;
    _hkdf_info = info;
    _hkdf_info_len = info_len;
    _hkdf_out = out;
    _hkdf_out_len = out_len;

    # Scratch holds "T(i-1) || info || counter" — the HMAC input for
    # each round. Max size = 32 + info_len + 1. `alloc` via fl_alloc
    # because we want a proper free at the end + secret material.
    _hkdf_scratch_len = 32 + info_len + 1;
    _hkdf_scratch = fl_alloc(_hkdf_scratch_len);
    memset(_hkdf_scratch, 0, _hkdf_scratch_len);

    # T(i-1) and T(i) are HMAC outputs and therefore key material
    # per RFC 5869. `secret var` zeroes both on function exit
    # (covers the happy-path ret and any early errors); init
    # memsets retained because the counter==1 branch leaves t_prev
    # untouched and we memcpy out of it.
    secret var t_prev[32];
    memset(&t_prev, 0, 32);
    secret var t_current[32];
    memset(&t_current, 0, 32);

    _hkdf_produced = 0;
    _hkdf_counter = 1;   # RFC 5869: i starts at 1

    while (_hkdf_produced < _hkdf_out_len) {
        # Build input to HMAC: T(i-1) || info || counter
        # First round (counter=1): T(0) is empty, so skip the T_prev copy.
        var scratch_write = 0;
        if (_hkdf_counter > 1) {
            memcpy(_hkdf_scratch, &t_prev, 32);
            scratch_write = 32;
        }
        if (_hkdf_info_len > 0) {
            memcpy(_hkdf_scratch + scratch_write, _hkdf_info, _hkdf_info_len);
            scratch_write = scratch_write + _hkdf_info_len;
        }
        store8(_hkdf_scratch + scratch_write, _hkdf_counter & 0xFF);
        scratch_write = scratch_write + 1;

        # T(i) = HMAC-SHA256(PRK, scratch[0..scratch_write])
        hmac_sha256(_hkdf_prk, _hkdf_prk_len, _hkdf_scratch, scratch_write, &t_current);

        # Copy min(32, out_len - produced) bytes into the output.
        var take = 32;
        if (_hkdf_out_len - _hkdf_produced < 32) {
            take = _hkdf_out_len - _hkdf_produced;
        }
        memcpy(_hkdf_out + _hkdf_produced, &t_current, take);
        _hkdf_produced = _hkdf_produced + take;

        # Save T(i) for the next iteration.
        memcpy(&t_prev, &t_current, 32);

        _hkdf_counter = _hkdf_counter + 1;
    }

    # Zeroize the heap scratch before free. t_prev / t_current are
    # `secret var` — zeroed on function exit by the compiler.
    memset(_hkdf_scratch, 0, _hkdf_scratch_len);
    fl_free(_hkdf_scratch);
    # Wipe the global pointers so nothing leaks between calls.
    _hkdf_scratch = 0;
    _hkdf_prk = 0;
    _hkdf_info = 0;
    _hkdf_out = 0;
    return 0;
}

# ================================================================
# hkdf — extract + expand convenience wrapper
# ================================================================
# One-shot HKDF. Derives out_len bytes of OKM from (salt, IKM, info).
# The intermediate PRK is allocated on the stack, used, and zeroized
# before return — callers never see it.
#
# Returns:
#   0   on success
#  -1   on negative-length input
#  -2   on out_len > 255*32

fn hkdf(salt, salt_len, ikm, ikm_len, info, info_len, out, out_len): i64 {
    # PRK is key material. `secret var` handles zeroization on
    # every return path (both rc1 error and rc2 success/error).
    secret var prk[32];
    var rc1 = hkdf_extract(salt, salt_len, ikm, ikm_len, &prk);
    if (rc1 != 0) { return rc1; }
    return hkdf_expand(&prk, 32, info, info_len, out, out_len);
}

# --- aes_ni.cyr ---

# aes_ni.cyr — AES-NI hardware-acceleration dispatch (live since 2.9.1).
#
# Cyrius 5.5.21's array-global 16-byte alignment fix closed out the
# SSE m128-operand fault that had kept this path dormant through
# 2.9.0 and part of 2.9.x development. With `var rk[240]` reliably
# landing on a 16-aligned VA, PXOR / AESENC / AESENCLAST memory
# operands on the round-key table no longer trip #GP, and the
# inline-asm stores through caller-supplied output pointers reach
# memory cleanly. Verified against FIPS 197 §C.3 in
# tests/tcyr/aes_ni.tcyr.
#
# The module exposes two entry points:
#   - aes_ni_available()        — runtime CPUID probe, cached
#   - aes256_encrypt_block_ni(round_keys, in, out)
#                               — 14-round AES-256 block encrypt
# aes_gcm.cyr's aes256_encrypt_block dispatches here when the probe
# returns 1, falling back to the FIPS 197 §5.1 software path when
# the host lacks AES-NI. Downstream callers should call
# aes256_encrypt_block (the dispatcher), not aes256_encrypt_block_ni
# directly, unless they're writing their own fast path.
#
# AES-NI opcode reference (Intel SDM Vol 2A §3.2, §5):
#   AESENC xmm0, [rdi+disp]       66 0F 38 DC 47/87 <disp>
#   AESENCLAST xmm0, [rdi+disp]   66 0F 38 DD 47/87 <disp>
#   CPUID                          0F A2     (eax=1 → ECX bit 25 = AES-NI)
#   PXOR xmm0, [rdi]               66 0F EF 07
#   MOVDQU xmm0, [rsi]             F3 0F 6F 06
#   MOVDQU [rdx], xmm0             F3 0F 7F 02

# _aes_ni_cache: 2 = uncached, 0 = unavailable (software path), 1 = available.
# First call to aes_ni_available() runs the CPUID probe and caches
# the result; subsequent calls return the cached value. The probe
# is a serializing instruction so we want to pay it exactly once.
var _aes_ni_cache = 2;
var _aes_ni_probe_out = 0;      # 8-byte scratch for the probe's *out param

fn aes_ni_available(): i64 {
    if (_aes_ni_cache != 2) { return _aes_ni_cache; }
    if (_aes_ni_probe_out == 0) { _aes_ni_probe_out = alloc(8); }
    store64(_aes_ni_probe_out, 0);
    _aes_ni_cpuid_probe(_aes_ni_probe_out);
    var ecx = load64(_aes_ni_probe_out);
    # ECX bit 25 = AES-NI (Intel SDM Vol 2A §3.2 CPUID leaf 1).
    if ((ecx & (1 << 25)) != 0) {
        _aes_ni_cache = 1;
    } else {
        _aes_ni_cache = 0;
    }
    return _aes_ni_cache;
}

# _aes_ni_cpuid_probe — write CPUID leaf 1 ECX to *out.
# Takes a caller-supplied pointer to keep the CPUID-clobbered
# registers' lifetime confined to the inline-asm block; the caller
# reloads via load64 after the call returns.
fn _aes_ni_cpuid_probe(out): i64 {
    #ifdef CYRIUS_ARCH_X86
    asm {
        # Param out = [rbp-8]. Load into rdi.
        0x48; 0x8B; 0x7D; 0xF8;        # mov rdi, [rbp-8]
        0x53;                          # push rbx (callee-saved; CPUID clobbers it)
        0xB8; 0x01; 0x00; 0x00; 0x00;  # mov eax, 1
        0x31; 0xC9;                    # xor ecx, ecx (subleaf 0)
        0x0F; 0xA2;                    # cpuid
        0x48; 0x89; 0x0F;              # mov [rdi], rcx  ; *out = ecx
        0x5B;                          # pop rbx
    }
    #endif
    return 0;
}

# aes256_encrypt_block_ni — hardware AES-256 single-block encrypt.
#
# Byte-accurate AESENC + AESENCLAST sequence over round_keys
# (240-byte expanded schedule, same layout as the software
# encryptor). Consumes:
#   round_keys — rdi — 15 round keys of 16 bytes each
#   in_block   — rsi — 16-byte plaintext
#   out_block  — rdx — 16-byte ciphertext (caller-allocated)
#
# Status: reaches the CPU's AESENC machinery correctly when called
# directly inside a single-compilation-unit build. Not wired into
# aes_gcm_encrypt in 2.9.0 (see module header).
fn aes256_encrypt_block_ni(round_keys, in_block, out_block): i64 {
    #ifdef CYRIUS_ARCH_X86
    asm {
        # Params: round_keys=[rbp-8], in_block=[rbp-16], out_block=[rbp-24]
        0x48; 0x8B; 0x7D; 0xF8;        # mov rdi, [rbp-8]   (round_keys)
        0x48; 0x8B; 0x75; 0xF0;        # mov rsi, [rbp-16]  (in_block)
        0x48; 0x8B; 0x55; 0xE8;        # mov rdx, [rbp-24]  (out_block)

        # movdqu xmm0, [rsi]           ; state = in_block
        0xF3; 0x0F; 0x6F; 0x06;
        # pxor xmm0, [rdi]             ; state ^= round_key[0]
        0x66; 0x0F; 0xEF; 0x07;

        # Rounds 1..7: AESENC xmm0, [rdi + N*16]  (disp8 form)
        0x66; 0x0F; 0x38; 0xDC; 0x47; 0x10;
        0x66; 0x0F; 0x38; 0xDC; 0x47; 0x20;
        0x66; 0x0F; 0x38; 0xDC; 0x47; 0x30;
        0x66; 0x0F; 0x38; 0xDC; 0x47; 0x40;
        0x66; 0x0F; 0x38; 0xDC; 0x47; 0x50;
        0x66; 0x0F; 0x38; 0xDC; 0x47; 0x60;
        0x66; 0x0F; 0x38; 0xDC; 0x47; 0x70;
        # Rounds 8..13: AESENC xmm0, [rdi + N*16]  (disp32 form; 128..208 beyond disp8 range)
        0x66; 0x0F; 0x38; 0xDC; 0x87; 0x80; 0x00; 0x00; 0x00;
        0x66; 0x0F; 0x38; 0xDC; 0x87; 0x90; 0x00; 0x00; 0x00;
        0x66; 0x0F; 0x38; 0xDC; 0x87; 0xA0; 0x00; 0x00; 0x00;
        0x66; 0x0F; 0x38; 0xDC; 0x87; 0xB0; 0x00; 0x00; 0x00;
        0x66; 0x0F; 0x38; 0xDC; 0x87; 0xC0; 0x00; 0x00; 0x00;
        0x66; 0x0F; 0x38; 0xDC; 0x87; 0xD0; 0x00; 0x00; 0x00;
        # Round 14 (final): AESENCLAST xmm0, [rdi+224]
        0x66; 0x0F; 0x38; 0xDD; 0x87; 0xE0; 0x00; 0x00; 0x00;

        # movdqu [rdx], xmm0           ; out_block = state
        0xF3; 0x0F; 0x7F; 0x02;
    }
    #endif
    return 0;
}

# --- aes_gcm.cyr ---

# aes_gcm.cyr — AES-256-GCM (AEAD) implementation
# FIPS 197 (AES-256 block cipher, 14 rounds) + NIST SP 800-38D
# (Galois/Counter Mode) — the AEAD primitive for the AGNOS ecosystem.
#
# Scope:
#   - AES-256 block cipher, forward direction only (GCM never
#     invokes the inverse cipher). 14-round Rijndael, full key
#     schedule over 32-byte keys, 16-byte blocks.
#   - GHASH under GF(2^128) with reduction polynomial
#     x^128 + x^7 + x^2 + x + 1, bit-by-bit multiply (constant-time).
#   - GCM encrypt / decrypt over 12-byte (96-bit) IVs — the RFC
#     fast-path. Arbitrary-length IVs deferred to a follow-up.
#   - Tag: 128-bit, constant-time compared via cyrius stdlib's
#     `ct_eq_bytes_lens` (was sigil's hand-rolled `ct_eq` pre-3.0.2).
#
# Security floor (matches CLAUDE.md § Security Hardening):
#   - AES block encrypt dispatches to AES-NI when available
#     (runtime CPUID probe in src/aes_ni.cyr), otherwise runs the
#     constant-time software path in this file. Both paths produce
#     byte-identical output against FIPS 197 §C.3.
#   - Constant-time tag compare; no early exit on secret data.
#   - No branches on key bytes or plaintext.
#   - Round-key buffers and the GHASH subkey H are zeroized
#     before free after every encrypt / decrypt call.
#   - Input lengths validated at the GCM boundary.
#
# Globals: Cyrius single-pass compiler can clobber locals across
# nested calls; working state lives in globals where it must
# survive a nested call chain (same pattern as sha256.cyr).

# aes_ni.cyr supplies aes_ni_available() and aes256_encrypt_block_ni
# for the dispatcher in aes256_encrypt_block below. Including it
# here means any consumer of aes_gcm automatically pulls the
# hardware path in without having to list it separately.

# ================================================================
# AES S-box (forward direction, FIPS 197 Fig. 7)
# ================================================================
# 256 bytes. Allocated once at init and never mutated. Read-only
# in the cipher body.

var _aes_sbox = 0;
var _aes_rcon = 0;
var _aes_inited = 0;

# S-box as a hex string (512 chars → 256 bytes). Single literal
# keeps the fixup count tiny — we decode it in a small loop at
# init time rather than emitting 256 store8 calls.
# Canonical Rijndael S-box, FIPS 197 Figure 7, rows 0..F:
#   row 0: 63 7c 77 7b f2 6b 6f c5 30 01 67 2b fe d7 ab 76
#   row 1: ca 82 c9 7d fa 59 47 f0 ad d4 a2 af 9c a4 72 c0
#   row 2: b7 fd 93 26 36 3f f7 cc 34 a5 e5 f1 71 d8 31 15
#   row 3: 04 c7 23 c3 18 96 05 9a 07 12 80 e2 eb 27 b2 75
#   row 4: 09 83 2c 1a 1b 6e 5a a0 52 3b d6 b3 29 e3 2f 84
#   row 5: 53 d1 00 ed 20 fc b1 5b 6a cb be 39 4a 4c 58 cf
#   row 6: d0 ef aa fb 43 4d 33 85 45 f9 02 7f 50 3c 9f a8
#   row 7: 51 a3 40 8f 92 9d 38 f5 bc b6 da 21 10 ff f3 d2
#   row 8: cd 0c 13 ec 5f 97 44 17 c4 a7 7e 3d 64 5d 19 73
#   row 9: 60 81 4f dc 22 2a 90 88 46 ee b8 14 de 5e 0b db
#   row a: e0 32 3a 0a 49 06 24 5c c2 d3 ac 62 91 95 e4 79
#   row b: e7 c8 37 6d 8d d5 4e a9 6c 56 f4 ea 65 7a ae 08
#   row c: ba 78 25 2e 1c a6 b4 c6 e8 dd 74 1f 4b bd 8b 8a
#   row d: 70 3e b5 66 48 03 f6 0e 61 35 57 b9 86 c1 1d 9e
#   row e: e1 f8 98 11 69 d9 8e 94 9b 1e 87 e9 ce 55 28 df
#   row f: 8c a1 89 0d bf e6 42 68 41 99 2d 0f b0 54 bb 16
fn _aes_sbox_hex(): i64 {
    return "";
}

# rcon[0..10] as hex: rcon[0] is padding (8d), never used.
fn _aes_rcon_hex(): i64 {
    return "8d01020408102040801b36";
}

fn _aes_decode_nibble(c): i64 {
    if (c >= 48) { if (c <= 57) { return c - 48; } }
    if (c >= 97) { if (c <= 102) { return c - 87; } }
    return 0;
}

fn _aes_decode_hex(buf, hex_str, byte_len): i64 {
    var i = 0;
    while (i < byte_len) {
        var hi = _aes_decode_nibble(load8(hex_str + i * 2) & 0xFF);
        var lo = _aes_decode_nibble(load8(hex_str + i * 2 + 1) & 0xFF);
        store8(buf + i, ((hi << 4) | lo) & 0xFF);
        i = i + 1;
    }
    return 0;
}

fn aes_gcm_global_init(): i64 {
    if (_aes_inited == 1) { return 0; }
    _aes_sbox = alloc(256);
    _aes_rcon = alloc(16);
    _aes_decode_hex(_aes_sbox, _aes_sbox_hex(), 256);
    _aes_decode_hex(_aes_rcon, _aes_rcon_hex(), 11);
    _aes_inited = 1;
    return 0;
}

fn _aes_sub(b): i64 {
    return load8(_aes_sbox + (b & 0xFF)) & 0xFF;
}

# ================================================================
# xtime — multiply a byte by x in GF(2^8) with the AES polynomial
# (x^8 + x^4 + x^3 + x + 1). FIPS 197 § 4.2.1.
# ================================================================

fn _aes_xtime(b): i64 {
    var shifted = (b << 1) & 0xFF;
    if ((b & 0x80) != 0) {
        return (shifted ^ 0x1b) & 0xFF;
    }
    return shifted & 0xFF;
}

# ================================================================
# Key expansion — AES-256: 32-byte key → 240 bytes (15 round keys).
# FIPS 197 § 5.2 algorithm. Nk=8, Nr=14, total expanded size = 4*4*(Nr+1)=240.
# ================================================================

fn aes256_key_expand(key, round_keys): i64 {
    aes_gcm_global_init();
    # First 32 bytes of the expanded key = raw key material.
    memcpy(round_keys, key, 32);

    var i = 8;   # word index into the expanded key
    while (i < 60) {
        # temp = previous word (4 bytes)
        var base = (i - 1) * 4;
        var t0 = load8(round_keys + base + 0) & 0xFF;
        var t1 = load8(round_keys + base + 1) & 0xFF;
        var t2 = load8(round_keys + base + 2) & 0xFF;
        var t3 = load8(round_keys + base + 3) & 0xFF;

        if ((i & 7) == 0) {
            # RotWord
            var rot0 = t1;
            var rot1 = t2;
            var rot2 = t3;
            var rot3 = t0;
            # SubWord
            t0 = _aes_sub(rot0);
            t1 = _aes_sub(rot1);
            t2 = _aes_sub(rot2);
            t3 = _aes_sub(rot3);
            # XOR Rcon[i/8] into t0
            t0 = t0 ^ (load8(_aes_rcon + (i / 8)) & 0xFF);
        } else {
            if ((i & 3) == 0) {
                # Nk=8 path: SubWord only
                t0 = _aes_sub(t0);
                t1 = _aes_sub(t1);
                t2 = _aes_sub(t2);
                t3 = _aes_sub(t3);
            }
        }

        # W[i] = W[i-Nk] XOR temp
        var prev_base = (i - 8) * 4;
        var dst_base = i * 4;
        store8(round_keys + dst_base + 0, (load8(round_keys + prev_base + 0) ^ t0) & 0xFF);
        store8(round_keys + dst_base + 1, (load8(round_keys + prev_base + 1) ^ t1) & 0xFF);
        store8(round_keys + dst_base + 2, (load8(round_keys + prev_base + 2) ^ t2) & 0xFF);
        store8(round_keys + dst_base + 3, (load8(round_keys + prev_base + 3) ^ t3) & 0xFF);

        i = i + 1;
    }
    return 0;
}

# ================================================================
# AES single-block encrypt — forward direction, 14 rounds
# ================================================================
# state is laid out column-major in the spec, but since SubBytes
# and AddRoundKey are per-byte we keep it in native byte order
# and just transpose the ShiftRows / MixColumns accesses.
#
# Layout: state[r*4 + c] = byte at row r, column c.
# AES input is read column-major: in[0]=s[0,0], in[1]=s[1,0],
# in[2]=s[2,0], in[3]=s[3,0], in[4]=s[0,1], etc.
# We store state[col*4 + row] to match that wire order — so
# state[0..3] = column 0, state[4..7] = column 1, etc.

var _aes_state = 0;
var _aes_tmp = 0;
var _aes_state_inited = 0;

fn _aes_state_init(): i64 {
    if (_aes_state_inited == 1) { return 0; }
    _aes_state = alloc(16);
    _aes_tmp = alloc(16);
    _aes_state_inited = 1;
    return 0;
}

fn _aes_add_round_key(rk, round): i64 {
    var off = round * 16;
    var i = 0;
    while (i < 16) {
        store8(_aes_state + i,
        (load8(_aes_state + i) ^ load8(rk + off + i)) & 0xFF);
        i = i + 1;
    }
    return 0;
}

fn _aes_sub_bytes(): i64 {
    var i = 0;
    while (i < 16) {
        store8(_aes_state + i, _aes_sub(load8(_aes_state + i) & 0xFF));
        i = i + 1;
    }
    return 0;
}

fn _aes_shift_rows(): i64 {
    # State in column-major order: s[c,r] at _aes_state[c*4 + r].
    # ShiftRows rotates row r left by r columns: row 0 unchanged,
    # row 1 rotated by 1, row 2 by 2, row 3 by 3.
    # Read into _aes_tmp then write back permuted.
    memcpy(_aes_tmp, _aes_state, 16);

    # Row 0 (unchanged): columns 0,1,2,3
    # store8(_aes_state + 0*4 + 0, load8(_aes_tmp + 0*4 + 0));  (no-op)

    # Row 1 rotated left by 1:
    #   new s[0,1] = old s[1,1]    → state[0*4+1] = tmp[1*4+1]
    #   new s[1,1] = old s[2,1]    → state[1*4+1] = tmp[2*4+1]
    #   new s[2,1] = old s[3,1]    → state[2*4+1] = tmp[3*4+1]
    #   new s[3,1] = old s[0,1]    → state[3*4+1] = tmp[0*4+1]
    store8(_aes_state +  1, load8(_aes_tmp +  5));
    store8(_aes_state +  5, load8(_aes_tmp +  9));
    store8(_aes_state +  9, load8(_aes_tmp + 13));
    store8(_aes_state + 13, load8(_aes_tmp +  1));

    # Row 2 rotated left by 2:
    store8(_aes_state +  2, load8(_aes_tmp + 10));
    store8(_aes_state +  6, load8(_aes_tmp + 14));
    store8(_aes_state + 10, load8(_aes_tmp +  2));
    store8(_aes_state + 14, load8(_aes_tmp +  6));

    # Row 3 rotated left by 3 (equivalently: right by 1):
    store8(_aes_state +  3, load8(_aes_tmp + 15));
    store8(_aes_state +  7, load8(_aes_tmp +  3));
    store8(_aes_state + 11, load8(_aes_tmp +  7));
    store8(_aes_state + 15, load8(_aes_tmp + 11));
    return 0;
}

fn _aes_mix_columns(): i64 {
    # MixColumns transforms each column independently.
    # s'[0,c] = 2·s[0,c] ^ 3·s[1,c] ^ s[2,c] ^ s[3,c]
    # s'[1,c] = s[0,c] ^ 2·s[1,c] ^ 3·s[2,c] ^ s[3,c]
    # s'[2,c] = s[0,c] ^ s[1,c] ^ 2·s[2,c] ^ 3·s[3,c]
    # s'[3,c] = 3·s[0,c] ^ s[1,c] ^ s[2,c] ^ 2·s[3,c]
    # Where 2·x = xtime(x), 3·x = xtime(x) ^ x.
    var c = 0;
    while (c < 4) {
        var a0 = load8(_aes_state + c * 4 + 0) & 0xFF;
        var a1 = load8(_aes_state + c * 4 + 1) & 0xFF;
        var a2 = load8(_aes_state + c * 4 + 2) & 0xFF;
        var a3 = load8(_aes_state + c * 4 + 3) & 0xFF;

        var x0 = _aes_xtime(a0);
        var x1 = _aes_xtime(a1);
        var x2 = _aes_xtime(a2);
        var x3 = _aes_xtime(a3);

        var n0 = (x0 ^ (x1 ^ a1) ^ a2 ^ a3) & 0xFF;
        var n1 = (a0 ^ x1 ^ (x2 ^ a2) ^ a3) & 0xFF;
        var n2 = (a0 ^ a1 ^ x2 ^ (x3 ^ a3)) & 0xFF;
        var n3 = ((x0 ^ a0) ^ a1 ^ a2 ^ x3) & 0xFF;

        store8(_aes_state + c * 4 + 0, n0);
        store8(_aes_state + c * 4 + 1, n1);
        store8(_aes_state + c * 4 + 2, n2);
        store8(_aes_state + c * 4 + 3, n3);
        c = c + 1;
    }
    return 0;
}

fn aes256_encrypt_block(round_keys, in_block, out_block): i64 {
    # AES-NI dispatch. The PXOR / AESENC memory-operand forms used
    # by aes256_encrypt_block_ni require the round_keys pointer to
    # be 16-byte aligned (#GP otherwise). Cyrius 5.5.21 guarantees
    # 16-alignment for array globals `var rk[240]`, and
    # `fl_alloc(240)` returns 16-aligned pointers because the block
    # header is a multiple of 16. Bump-`alloc(240)` is only 8-byte
    # aligned, so callers using that path bypass the NI branch here
    # and run the software fallback — matches the CLAUDE.md
    # discipline ("fl_alloc for round keys") without requiring every
    # call site to know about the alignment invariant.
    if (aes_ni_available() == 1) {
        if ((round_keys & 15) == 0) {
            aes256_encrypt_block_ni(round_keys, in_block, out_block);
            return 0;
        }
    }

    # Software path (FIPS 197 §5.1).
    _aes_state_init();
    memcpy(_aes_state, in_block, 16);

    # Initial round key
    _aes_add_round_key(round_keys, 0);

    # 13 middle rounds
    var r = 1;
    while (r < 14) {
        _aes_sub_bytes();
        _aes_shift_rows();
        _aes_mix_columns();
        _aes_add_round_key(round_keys, r);
        r = r + 1;
    }

    # Final round (no MixColumns)
    _aes_sub_bytes();
    _aes_shift_rows();
    _aes_add_round_key(round_keys, 14);

    memcpy(out_block, _aes_state, 16);
    return 0;
}

# ================================================================
# GHASH — GF(2^128) multiplication with reduction polynomial
# R = x^128 + x^7 + x^2 + x + 1. NIST SP 800-38D § 6.3.
# ================================================================
# Inputs are 128-bit blocks laid out big-endian (bit 0 is the MSB
# of byte 0 by GCM convention).
#
# Bit-by-bit right-shift multiply (Algorithm in NIST SP 800-38D
# Appendix A — constant-time, no table):
#     Z = 0, V = Y
#     for i = 0..127:
#         if bit i of X (high-to-low) == 1: Z ^= V
#         if V's LSbit == 0: V >>= 1
#         else: V = (V >> 1) ^ R_reduced
#
# The reduction polynomial R in the bit-reversed GCM convention
# becomes 0xE1000...00 as the MSByte after a right-shift on V.

fn _ghash_shift_right_and_reduce(v): i64 {
    # v is a 16-byte little-endian-of-bytes / big-endian-of-bits
    # block. Shift the whole block right by 1 bit, with carry
    # propagating from byte 0 → byte 1 → ... → byte 15.
    # If the original v[15] LSbit was 1, after the shift XOR 0xE1
    # into v[0] (the GCM reduction R').
    var lsb_set = load8(v + 15) & 1;
    var i = 15;
    while (i > 0) {
        var hi = (load8(v + i - 1) & 1) << 7;
        var cur = ((load8(v + i) & 0xFF) >> 1) & 0x7F;
        store8(v + i, (cur | hi) & 0xFF);
        i = i - 1;
    }
    store8(v, ((load8(v) & 0xFF) >> 1) & 0x7F);
    if (lsb_set == 1) {
        store8(v, (load8(v) ^ 0xE1) & 0xFF);
    }
    return 0;
}

fn _ghash_xor_16(dst, src): i64 {
    var i = 0;
    while (i < 16) {
        store8(dst + i, (load8(dst + i) ^ load8(src + i)) & 0xFF);
        i = i + 1;
    }
    return 0;
}

# _ghash_mul: Z = X * H in GF(2^128).
# X: 16 bytes (input, read-only). H: 16 bytes (hash subkey, read-only).
# z: 16 bytes (output, caller-provided, will be overwritten).
# Uses a local 16-byte scratch for V that is zeroized on return.
fn _ghash_mul(z, x, h): i64 {
    var v[16];
    memcpy(&v, h, 16);
    memset(z, 0, 16);

    var byte = 0;
    while (byte < 16) {
        var b = load8(x + byte) & 0xFF;
        var bit = 0;
        while (bit < 8) {
            var mask = (b >> (7 - bit)) & 1;
            if (mask == 1) {
                _ghash_xor_16(z, &v);
            }
            _ghash_shift_right_and_reduce(&v);
            bit = bit + 1;
        }
        byte = byte + 1;
    }
    memset(&v, 0, 16);
    return 0;
}

# GHASH over an arbitrary-length buffer: splits into 16-byte
# blocks, zero-pads the tail, XOR-then-multiplies each block into
# the running tag. Caller supplies the 16-byte output buffer `y`
# initialized to zeros (for the outer GHASH call) or to the
# running accumulator.
fn _ghash_update(y, h, data, len): i64 {
    var block[16];
    var pos = 0;
    while (pos + 16 <= len) {
        memcpy(&block, data + pos, 16);
        _ghash_xor_16(y, &block);
        # Z = Y * H, stored back into Y via scratch.
        var scratch[16];
        _ghash_mul(&scratch, y, h);
        memcpy(y, &scratch, 16);
        pos = pos + 16;
    }
    var remaining = len - pos;
    if (remaining > 0) {
        memset(&block, 0, 16);
        memcpy(&block, data + pos, remaining);
        _ghash_xor_16(y, &block);
        var scratch2[16];
        _ghash_mul(&scratch2, y, h);
        memcpy(y, &scratch2, 16);
    }
    memset(&block, 0, 16);
    return 0;
}

# ================================================================
# Big-endian 64-bit store — used for GHASH length block
# ================================================================

fn _be64_store(buf, v): i64 {
    store8(buf + 0, (v >> 56) & 0xFF);
    store8(buf + 1, (v >> 48) & 0xFF);
    store8(buf + 2, (v >> 40) & 0xFF);
    store8(buf + 3, (v >> 32) & 0xFF);
    store8(buf + 4, (v >> 24) & 0xFF);
    store8(buf + 5, (v >> 16) & 0xFF);
    store8(buf + 6, (v >>  8) & 0xFF);
    store8(buf + 7,  v        & 0xFF);
    return 0;
}

fn _be32_store(buf, v): i64 {
    store8(buf + 0, (v >> 24) & 0xFF);
    store8(buf + 1, (v >> 16) & 0xFF);
    store8(buf + 2, (v >>  8) & 0xFF);
    store8(buf + 3,  v        & 0xFF);
    return 0;
}

fn _be32_load(buf): i64 {
    return ((load8(buf + 0) & 0xFF) << 24)
    | ((load8(buf + 1) & 0xFF) << 16)
    | ((load8(buf + 2) & 0xFF) <<  8)
    | ((load8(buf + 3) & 0xFF)      );
}

# ================================================================
# CTR-mode XOR: produce keystream block AES(K, counter) and XOR
# into data. The low 32 bits of the 16-byte counter increment
# between blocks (big-endian).
# ================================================================

fn _aes_gcm_ctr_xor(round_keys, counter, src, dst, len): i64 {
    var ks[16];
    var pos = 0;
    while (pos < len) {
        aes256_encrypt_block(round_keys, counter, &ks);
        var chunk = 16;
        if (len - pos < 16) { chunk = len - pos; }
        var i = 0;
        while (i < chunk) {
            store8(dst + pos + i,
            (load8(src + pos + i) ^ load8(&ks + i)) & 0xFF);
            i = i + 1;
        }
        # Increment low 32 bits, big-endian, in place.
        var ctr_val = _be32_load(counter + 12);
        ctr_val = (ctr_val + 1) & 0xFFFFFFFF;
        _be32_store(counter + 12, ctr_val);
        pos = pos + chunk;
    }
    memset(&ks, 0, 16);
    return 0;
}

# ================================================================
# aes_gcm_encrypt — AEAD encrypt
# ================================================================
# Inputs:
#   key      — 32 bytes (AES-256 key)
#   iv       — 12 bytes (96-bit IV; RFC fast path)
#   aad      — additional authenticated data, aad_len bytes (may be 0)
#   pt       — plaintext, pt_len bytes (may be 0)
# Outputs:
#   ct_out   — ciphertext buffer, pt_len bytes (caller-allocated)
#   tag_out  — 16-byte authentication tag (caller-allocated)
# Returns 0 on success, non-zero on input-validation failure.
#
# Security: round-key buffer and H are zeroized before free.

fn aes_gcm_encrypt(key, iv, aad, aad_len, pt, pt_len, ct_out, tag_out): i64 {
    if (aad_len < 0) { return (0 - 1); }
    if (pt_len < 0) { return (0 - 1); }

    aes_gcm_global_init();

    var round_keys = fl_alloc(240);
    aes256_key_expand(key, round_keys);

    # H = AES_K(0^128)
    var zero_block[16];
    memset(&zero_block, 0, 16);
    var h[16];
    aes256_encrypt_block(round_keys, &zero_block, &h);

    # J0 = IV || 0x00000001
    var j0[16];
    memcpy(&j0, iv, 12);
    store8(&j0 + 12, 0);
    store8(&j0 + 13, 0);
    store8(&j0 + 14, 0);
    store8(&j0 + 15, 1);

    # Counter starts at inc32(J0) — low 32 bits incremented.
    var counter[16];
    memcpy(&counter, &j0, 16);
    var ctr_val = _be32_load(&counter + 12);
    ctr_val = (ctr_val + 1) & 0xFFFFFFFF;
    _be32_store(&counter + 12, ctr_val);

    # Encrypt plaintext via CTR mode
    if (pt_len > 0) {
        _aes_gcm_ctr_xor(round_keys, &counter, pt, ct_out, pt_len);
    }

    # GHASH over AAD || pad || CT || pad || len(AAD)||len(CT) in bits BE
    var y[16];
    memset(&y, 0, 16);
    if (aad_len > 0) {
        _ghash_update(&y, &h, aad, aad_len);
    }
    if (pt_len > 0) {
        _ghash_update(&y, &h, ct_out, pt_len);
    }
    var len_block[16];
    memset(&len_block, 0, 16);
    _be64_store(&len_block + 0, aad_len * 8);
    _be64_store(&len_block + 8, pt_len * 8);
    _ghash_update(&y, &h, &len_block, 16);

    # Tag = Y XOR AES_K(J0)
    var s[16];
    aes256_encrypt_block(round_keys, &j0, &s);
    var i = 0;
    while (i < 16) {
        store8(tag_out + i, (load8(&y + i) ^ load8(&s + i)) & 0xFF);
        i = i + 1;
    }

    # Zeroize all secret-derived scratch before free.
    memset(round_keys, 0, 240);
    fl_free(round_keys);
    memset(&h, 0, 16);
    memset(&y, 0, 16);
    memset(&s, 0, 16);
    memset(&counter, 0, 16);
    memset(&j0, 0, 16);
    memset(&zero_block, 0, 16);
    memset(&len_block, 0, 16);
    return 0;
}

# ================================================================
# aes_gcm_decrypt — AEAD decrypt with tag verification
# ================================================================
# Inputs:
#   key      — 32 bytes
#   iv       — 12 bytes
#   aad      — aad_len bytes
#   ct       — ciphertext, ct_len bytes
#   tag      — 16-byte received tag
# Output:
#   pt_out   — plaintext, ct_len bytes (caller-allocated)
# Returns:
#   ERR_NONE on success
#   ERR_INTEGRITY_MISMATCH on tag mismatch (pt_out NOT populated
#       with real plaintext — it is zeroed on failure).
#   ERR_INVALID_INPUT on length validation failure.
#
# AEAD contract: plaintext MUST NOT be released until the tag is
# verified. We compute & verify the tag first, then derive pt.

fn aes_gcm_decrypt(key, iv, aad, aad_len, ct, ct_len, tag, pt_out): i64 {
    if (aad_len < 0) { return ERR_INVALID_INPUT; }
    if (ct_len < 0) { return ERR_INVALID_INPUT; }

    aes_gcm_global_init();

    var round_keys = fl_alloc(240);
    aes256_key_expand(key, round_keys);

    # H = AES_K(0)
    var zero_block[16];
    memset(&zero_block, 0, 16);
    var h[16];
    aes256_encrypt_block(round_keys, &zero_block, &h);

    # J0 = IV || 0x00000001
    var j0[16];
    memcpy(&j0, iv, 12);
    store8(&j0 + 12, 0);
    store8(&j0 + 13, 0);
    store8(&j0 + 14, 0);
    store8(&j0 + 15, 1);

    # Compute expected tag over received ciphertext BEFORE
    # touching pt_out.
    var y[16];
    memset(&y, 0, 16);
    if (aad_len > 0) {
        _ghash_update(&y, &h, aad, aad_len);
    }
    if (ct_len > 0) {
        _ghash_update(&y, &h, ct, ct_len);
    }
    var len_block[16];
    memset(&len_block, 0, 16);
    _be64_store(&len_block + 0, aad_len * 8);
    _be64_store(&len_block + 8, ct_len * 8);
    _ghash_update(&y, &h, &len_block, 16);

    var s[16];
    aes256_encrypt_block(round_keys, &j0, &s);
    var expected_tag[16];
    var i = 0;
    while (i < 16) {
        store8(&expected_tag + i, (load8(&y + i) ^ load8(&s + i)) & 0xFF);
        i = i + 1;
    }

    # Constant-time tag compare. ct_eq_bytes_lens loops the full
    # length even on first mismatch — no early exit on secret data.
    # Lengths equal-by-construction (both 16 = poly1305 tag); could
    # equivalently call ct_eq_bytes(_, _, 16) since the dual-length
    # form's mismatch-fast-path is unreachable here. Kept dual-length
    # for symmetry with the v5.9.20 sigil 3.0.2 migration shape.
    var ok = ct_eq_bytes_lens(&expected_tag, 16, tag, 16);

    # Decrypt via CTR starting at inc32(J0) — we perform the CTR
    # pass unconditionally to keep the work profile flat across
    # valid and forged tag paths. If the tag failed, pt_out is
    # zeroed *after* CTR so no real plaintext ever escapes.
    var counter[16];
    memcpy(&counter, &j0, 16);
    var ctr_val = _be32_load(&counter + 12);
    ctr_val = (ctr_val + 1) & 0xFFFFFFFF;
    _be32_store(&counter + 12, ctr_val);

    if (ct_len > 0) {
        _aes_gcm_ctr_xor(round_keys, &counter, ct, pt_out, ct_len);
    }

    var rc = ERR_NONE;
    if (ok != 1) {
        # Overwrite the computed plaintext so the caller never
        # observes pre-auth bytes. AEAD no-plaintext-leak contract.
        if (ct_len > 0) {
            memset(pt_out, 0, ct_len);
        }
        rc = ERR_INTEGRITY_MISMATCH;
    }

    memset(round_keys, 0, 240);
    fl_free(round_keys);
    memset(&h, 0, 16);
    memset(&y, 0, 16);
    memset(&s, 0, 16);
    memset(&expected_tag, 0, 16);
    memset(&counter, 0, 16);
    memset(&j0, 0, 16);
    memset(&zero_block, 0, 16);
    memset(&len_block, 0, 16);
    return rc;
}

# --- sha512.cyr ---

# sha512.cyr — FIPS 180-4 SHA-512 implementation
# Required by Ed25519 (RFC 8032) for key expansion and signing.
# All arithmetic uses 64-bit words (native Cyrius i64).

# ================================================================
# SHA-512 round constants K[0..79]
# ================================================================

var _sha512_K = 0;
var _sha512_W = 0;
var _sha512_inited = 0;

fn _sha512_rotr(x, n): i64 {
    return (x >> n) | (x << (64 - n));
}

fn sha512_ch(x, y, z): i64 {
    return (x & y) ^ ((x ^ 0xFFFFFFFFFFFFFFFF) & z);
}

fn sha512_maj(x, y, z): i64 {
    return (x & y) ^ (x & z) ^ (y & z);
}

fn sha512_bsig0(x): i64 {
    return _sha512_rotr(x, 28) ^ _sha512_rotr(x, 34) ^ _sha512_rotr(x, 39);
}

fn sha512_bsig1(x): i64 {
    return _sha512_rotr(x, 14) ^ _sha512_rotr(x, 18) ^ _sha512_rotr(x, 41);
}

fn sha512_ssig0(x): i64 {
    return _sha512_rotr(x, 1) ^ _sha512_rotr(x, 8) ^ (x >> 7);
}

fn sha512_ssig1(x): i64 {
    return _sha512_rotr(x, 19) ^ _sha512_rotr(x, 61) ^ (x >> 6);
}

fn sha512_global_init(): i64 {
    if (_sha512_inited == 1) { return 0; }

    _sha512_K = alloc(640);
    store64(_sha512_K + 0, 0x428a2f98d728ae22);
    store64(_sha512_K + 8, 0x7137449123ef65cd);
    store64(_sha512_K + 16, 0xb5c0fbcfec4d3b2f);
    store64(_sha512_K + 24, 0xe9b5dba58189dbbc);
    store64(_sha512_K + 32, 0x3956c25bf348b538);
    store64(_sha512_K + 40, 0x59f111f1b605d019);
    store64(_sha512_K + 48, 0x923f82a4af194f9b);
    store64(_sha512_K + 56, 0xab1c5ed5da6d8118);
    store64(_sha512_K + 64, 0xd807aa98a3030242);
    store64(_sha512_K + 72, 0x12835b0145706fbe);
    store64(_sha512_K + 80, 0x243185be4ee4b28c);
    store64(_sha512_K + 88, 0x550c7dc3d5ffb4e2);
    store64(_sha512_K + 96, 0x72be5d74f27b896f);
    store64(_sha512_K + 104, 0x80deb1fe3b1696b1);
    store64(_sha512_K + 112, 0x9bdc06a725c71235);
    store64(_sha512_K + 120, 0xc19bf174cf692694);
    store64(_sha512_K + 128, 0xe49b69c19ef14ad2);
    store64(_sha512_K + 136, 0xefbe4786384f25e3);
    store64(_sha512_K + 144, 0x0fc19dc68b8cd5b5);
    store64(_sha512_K + 152, 0x240ca1cc77ac9c65);
    store64(_sha512_K + 160, 0x2de92c6f592b0275);
    store64(_sha512_K + 168, 0x4a7484aa6ea6e483);
    store64(_sha512_K + 176, 0x5cb0a9dcbd41fbd4);
    store64(_sha512_K + 184, 0x76f988da831153b5);
    store64(_sha512_K + 192, 0x983e5152ee66dfab);
    store64(_sha512_K + 200, 0xa831c66d2db43210);
    store64(_sha512_K + 208, 0xb00327c898fb213f);
    store64(_sha512_K + 216, 0xbf597fc7beef0ee4);
    store64(_sha512_K + 224, 0xc6e00bf33da88fc2);
    store64(_sha512_K + 232, 0xd5a79147930aa725);
    store64(_sha512_K + 240, 0x06ca6351e003826f);
    store64(_sha512_K + 248, 0x142929670a0e6e70);
    store64(_sha512_K + 256, 0x27b70a8546d22ffc);
    store64(_sha512_K + 264, 0x2e1b21385c26c926);
    store64(_sha512_K + 272, 0x4d2c6dfc5ac42aed);
