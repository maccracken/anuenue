# --- telemetry.cyr ---

var TRACE_FLAG_SAMPLED = 1;
fn trace_id_new() { return agent_id_new(); }
fn trace_id_to_str(id): Str {
    # 32 hex chars (no dashes)
    var buf = alloc(33);
    var i = 0;
    while (i < 16) {
        _hex_byte(buf, i * 2, load8(id + i));
        i = i + 1;
    }
    store8(buf + 32, 0);
    return str_new(buf, 32);
}
fn trace_id_from_str(s: Str) {
    var data = s.data;
    var slen = s.len;
    if (slen != 32) { return err_invalid_argument(str_from("expected 32 hex digits")); }
    var id = alloc(16);
    var i = 0;
    while (i < 16) {
        var hi = _hex_nibble(load8(data + i * 2));
        var lo = _hex_nibble(load8(data + i * 2 + 1));
        if (hi < 0) { return err_invalid_argument(str_from("invalid hex in trace id")); }
        if (lo < 0) { return err_invalid_argument(str_from("invalid hex in trace id")); }
        store8(id + i, hi << 4 | lo);
        i = i + 1;
    }
    return Ok(id);
}
fn trace_id_eq(a, b) { return agent_id_eq(a, b); }
fn span_id_new() {
    var id = alloc(8);
    _fill_random(id, 8);
    return id;
}
fn span_id_to_str(id): Str {
    # 16 hex chars
    var buf = alloc(17);
    var val = load64(id);
    var i = 0;
    while (i < 8) {
        var byte = (val >> ((7 - i) * 8)) & 0xFF;
        _hex_byte(buf, i * 2, byte);
        i = i + 1;
    }
    store8(buf + 16, 0);
    return str_new(buf, 16);
}
fn span_id_from_str(s: Str) {
    var data = s.data;
    var slen = s.len;
    if (slen != 16) { return err_invalid_argument(str_from("expected 16 hex digits")); }
    var id = alloc(8);
    var val = 0;
    var i = 0;
    while (i < 16) {
        var nibble = _hex_nibble(load8(data + i));
        if (nibble < 0) { return err_invalid_argument(str_from("invalid hex in span id")); }
        val = (val << 4) | nibble;
        i = i + 1;
    }
    store64(id, val);
    return Ok(id);
}
fn span_id_eq(a, b) {
    if (load64(a) == load64(b)) { return 1; }
    return 0;
}
enum SpanStatus {
    SPAN_UNSET;
    SPAN_OK;
    SPAN_ERROR;
}
fn span_status_name(s) {
    if (s == SPAN_UNSET)       { return "Unset"; }
    elif (s == SPAN_OK)        { return "Ok"; }
    elif (s == SPAN_ERROR)     { return "Error"; }
    return "Unknown";
}
fn span_status_error(message: Str) {
    return tagged_new(SPAN_ERROR, message);
}
enum SpanKind {
    SPAN_INTERNAL;
    SPAN_SERVER;
    SPAN_CLIENT;
    SPAN_PRODUCER;
    SPAN_CONSUMER;
}
fn span_kind_name(k) {
    if (k == SPAN_INTERNAL)      { return "Internal"; }
    elif (k == SPAN_SERVER)      { return "Server"; }
    elif (k == SPAN_CLIENT)      { return "Client"; }
    elif (k == SPAN_PRODUCER)    { return "Producer"; }
    elif (k == SPAN_CONSUMER)    { return "Consumer"; }
    return "Unknown";
}
enum EventType {
    EVT_AGENT_STARTED;
    EVT_AGENT_STOPPED;
    EVT_AGENT_FAILED;
    EVT_INFERENCE_COMPLETE;
    EVT_AUDIT_EVENT;
    EVT_SECURITY_ALERT;
    EVT_CUSTOM;
}
enum MetricKind {
    METRIC_COUNTER;
    METRIC_UP_DOWN_COUNTER;
    METRIC_GAUGE;
    METRIC_HISTOGRAM;
}
enum AggregationTemporality {
    TEMPORALITY_CUMULATIVE;
    TEMPORALITY_DELTA;
}
enum LogSeverity {
    LOG_TRACE = 1;
    LOG_DEBUG = 5;
    LOG_INFO = 9;
    LOG_WARN = 13;
    LOG_ERROR = 17;
    LOG_FATAL = 21;
}
fn log_severity_name(s) {
    if (s == LOG_TRACE) { return "TRACE"; }
    elif (s == LOG_DEBUG) { return "DEBUG"; }
    elif (s == LOG_INFO)  { return "INFO"; }
    elif (s == LOG_WARN)  { return "WARN"; }
    elif (s == LOG_ERROR) { return "ERROR"; }
    elif (s == LOG_FATAL) { return "FATAL"; }
    return "UNKNOWN";
}
fn resource_new(name: Str, version: Str, instance_id: Str) {
    var r = alloc(40);
    store64(r, name);
    store64(r + 8, version);
    store64(r + 16, instance_id);
    store64(r + 24, map_new());
    store64(r + 32, 0);
    return r;
}
fn resource_default() {
    return resource_new(str_from(""), str_from(""), str_from(""));
}
fn res_service_name(r)    { return load64(r); }
fn res_service_version(r) { return load64(r + 8); }
fn res_instance_id(r)     { return load64(r + 16); }
fn res_attributes(r)      { return load64(r + 24); }
fn res_schema_url(r)      { return load64(r + 32); }
fn trace_context_new() {
    var ctx = alloc(40);
    store64(ctx, trace_id_new());
    store64(ctx + 8, span_id_new());
    store64(ctx + 16, 0);
    store64(ctx + 24, TRACE_FLAG_SAMPLED);
    store64(ctx + 32, str_from(""));
    return ctx;
}
fn tctx_trace_id(c)       { return load64(c); }
fn tctx_span_id(c)        { return load64(c + 8); }
fn tctx_parent_span_id(c) { return load64(c + 16); }
fn tctx_trace_flags(c)    { return load64(c + 24); }
fn tctx_trace_state(c)    { return load64(c + 32); }
fn tctx_is_sampled(c) {
    if ((load64(c + 24) & TRACE_FLAG_SAMPLED) != 0) { return 1; }
    return 0;
}
fn tctx_child(parent) {
    var child = alloc(40);
    store64(child, load64(parent));          # same trace_id
    store64(child + 8, span_id_new());       # new span_id
    store64(child + 16, load64(parent + 8)); # parent's span_id
    store64(child + 24, load64(parent + 24)); # propagate flags
    store64(child + 32, load64(parent + 32)); # propagate state
    return child;
}
fn tctx_to_traceparent(c): Str {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "00-");
    str_builder_add(sb, trace_id_to_str(tctx_trace_id(c)));
    str_builder_putc(sb, '-');
    str_builder_add(sb, span_id_to_str(tctx_span_id(c)));
    str_builder_putc(sb, '-');
    var flags = tctx_trace_flags(c);
    var fbuf = alloc(3);
    _hex_byte(fbuf, 0, flags & 0xFF);
    store8(fbuf + 2, 0);
    str_builder_add(sb, str_new(fbuf, 2));
    return str_builder_build(sb);
}
fn tctx_from_traceparent(s: Str) {
    # Format: "VV-TTTTTTTTTTTTTTTTTTTTTTTTTTTTTTTT-SSSSSSSSSSSSSSSS-FF"
    # Total: 55 chars
    var data = s.data;
    var slen = s.len;
    if (slen != 55) { return err_invalid_argument(str_from("traceparent must be 55 chars")); }
    if (load8(data + 2) != 45) { return err_invalid_argument(str_from("invalid traceparent format")); }
    if (load8(data + 35) != 45) { return err_invalid_argument(str_from("invalid traceparent format")); }
    if (load8(data + 52) != 45) { return err_invalid_argument(str_from("invalid traceparent format")); }
    # Parse trace_id (32 hex chars at offset 3)
    var tid = trace_id_from_str(str_new(data + 3, 32))?;
    # Parse span_id (16 hex chars at offset 36)
    var sid = span_id_from_str(str_new(data + 36, 16))?;
    # Parse flags (2 hex chars at offset 53)
    var fhi = _hex_nibble(load8(data + 53));
    var flo = _hex_nibble(load8(data + 54));
    if (fhi < 0) { return err_invalid_argument(str_from("invalid hex in traceparent flags")); }
    if (flo < 0) { return err_invalid_argument(str_from("invalid hex in traceparent flags")); }
    var flags = fhi << 4 | flo;
    var ctx = alloc(40);
    store64(ctx, tid);
    store64(ctx + 8, sid);
    store64(ctx + 16, 0);
    store64(ctx + 24, flags);
    store64(ctx + 32, str_from(""));
    return Ok(ctx);
}
fn span_new(name: Str, trace_id, span_id) {
    var s = alloc(112);
    store64(s, name);
    store64(s + 8, trace_id);
    store64(s + 16, span_id);
    store64(s + 24, 0);
    store64(s + 32, SPAN_UNSET);
    store64(s + 40, SPAN_INTERNAL);
    store64(s + 48, clock_now_ns());
    store64(s + 56, 0);
    store64(s + 64, map_new());
    store64(s + 72, vec_new());
    store64(s + 80, vec_new());
    store64(s + 88, 0);
    store64(s + 96, 0);
    store64(s + 104, 0);
    return s;
}
fn span_name(s)           { return load64(s); }
fn span_trace_id(s)       { return load64(s + 8); }
fn span_span_id(s)        { return load64(s + 16); }
fn span_parent_id(s)      { return load64(s + 24); }
fn span_status(s)         { return load64(s + 32); }
fn span_kind(s)           { return load64(s + 40); }
fn span_started_at(s)     { return load64(s + 48); }
fn span_duration_ms(s)    { return load64(s + 56); }
fn span_attributes(s)     { return load64(s + 64); }
fn span_events(s)         { return load64(s + 72); }
fn span_links(s)          { return load64(s + 80); }
fn span_set_status(s, v)      { store64(s + 32, v); return 0; }
fn span_set_kind(s, v)        { store64(s + 40, v); return 0; }
fn span_set_duration_ms(s, v) { store64(s + 56, v); return 0; }
fn span_set_parent(s, v)      { store64(s + 24, v); return 0; }
fn span_dropped_attrs(s)  { return load64(s + 88); }
fn span_dropped_events(s) { return load64(s + 96); }
fn span_dropped_links(s)  { return load64(s + 104); }
# v1.2.0 — OTLP wire-format encoder for Span. Maps to
# opentelemetry.proto.trace.v1.Span. Covers scalar fields:
# trace_id, span_id, parent_span_id, name, kind, start/end times,
# status, dropped-counts. Repeated nested-message fields
# (attributes, events, links) are skipped in this slot — they
# require nested KeyValue/Event/Link encoders pinned for v1.2.x
# when a consumer surfaces the need.
#
# OTLP field-number reference (proto/trace/v1/trace.proto §Span):
#   1: trace_id (bytes, 16)
#   2: span_id (bytes, 8)
#   3: trace_state (string)        — skipped (caller-set, often empty)
#   4: parent_span_id (bytes, 8)   — only emitted if non-zero
#   5: name (string)
#   6: kind (varint, SpanKind enum)
#   7: start_time_unix_nano (fixed64)
#   8: end_time_unix_nano (fixed64) — start + duration_ms*1e6
#   9: attributes (repeated KeyValue) — DEFERRED v1.2.x
#  10: dropped_attributes_count (varint)
#  11: events (repeated Event)        — DEFERRED v1.2.x
#  12: dropped_events_count (varint)
#  13: links (repeated Link)          — DEFERRED v1.2.x
#  14: dropped_links_count (varint)
#  15: status (Status sub-message: code, message)
#  16: flags (fixed32)              — skipped (rarely set)
#
# SpanKind enum values map agnostik → OTLP:
#   SPAN_INTERNAL=0 → SPAN_KIND_INTERNAL=1
#   SPAN_SERVER=1   → SPAN_KIND_SERVER=2
#   SPAN_CLIENT=2   → SPAN_KIND_CLIENT=3
#   SPAN_PRODUCER=3 → SPAN_KIND_PRODUCER=4
#   SPAN_CONSUMER=4 → SPAN_KIND_CONSUMER=5
fn _span_kind_to_otlp(k) {
    if (k == SPAN_INTERNAL) { return 1; }
    if (k == SPAN_SERVER)   { return 2; }
    if (k == SPAN_CLIENT)   { return 3; }
    if (k == SPAN_PRODUCER) { return 4; }
    if (k == SPAN_CONSUMER) { return 5; }
    return 0;
}
# SpanStatus.code: SPAN_UNSET=0 (default OTLP), SPAN_OK=1 → 1, SPAN_ERROR=2 → 2.
# Maps directly since both enums use the same numeric values.
fn Span_to_otlp_proto(ptr, sb) {
    var trace_id = load64(ptr + 8);
    var span_id  = load64(ptr + 16);
    var parent   = load64(ptr + 24);
    var name     = load64(ptr);
    var kind     = load64(ptr + 40);
    var start_ns = load64(ptr + 48);
    var dur_ms   = load64(ptr + 56);
    # field 1: trace_id (16 raw bytes — agent_id_new returns alloc(16))
    _proto_bytes(sb, 1, trace_id, 16);
    # field 2: span_id (8 raw bytes — span_id_new returns alloc(8))
    _proto_bytes(sb, 2, span_id, 8);
    # field 4: parent_span_id (only if set)
    if (parent != 0) { _proto_bytes(sb, 4, parent, 8); }
    # field 5: name
    _proto_string(sb, 5, name);
    # field 6: kind (default SPAN_INTERNAL → 1; emit only if non-default
    # to match canonical OTLP encoders that elide default-value scalars).
    if (kind != SPAN_INTERNAL) { _proto_int64(sb, 6, _span_kind_to_otlp(kind)); }
    # field 7: start_time_unix_nano
    _proto_fixed64(sb, 7, start_ns);
    # field 8: end_time_unix_nano = start + duration_ms × 1_000_000
    _proto_fixed64(sb, 8, start_ns + dur_ms * 1000000);
    # field 10: dropped_attributes_count (only if non-zero)
    var da = load64(ptr + 88);
    if (da != 0) { _proto_int64(sb, 10, da); }
    # field 12: dropped_events_count
    var de = load64(ptr + 96);
    if (de != 0) { _proto_int64(sb, 12, de); }
    # field 14: dropped_links_count
    var dl = load64(ptr + 104);
    if (dl != 0) { _proto_int64(sb, 14, dl); }
    # field 15: status — only emit if status code is set (non-UNSET)
    var status = load64(ptr + 32);
    if (status != SPAN_UNSET) {
        var status_sb = str_builder_new();
        _proto_int64(status_sb, 1, status);   # Status.code
        _proto_message(sb, 15, str_builder_build(status_sb));
    }
    return 0;
}
struct TelemetryConfig { enabled; sample_rate; export_endpoint; }
fn TelemetryConfig_to_json(ptr, sb) {
    # ADR-002: compact byte format for library uniformity. The Str
    # field with null-for-0 handling prevents derive adoption (cyrius
    # 5.10.14 derive on `: Str` field with value 0 → SIGSEGV via
    # str_data(0)). Hand-written stays.
    str_builder_add_cstr(sb, "{\"enabled\":");
    str_builder_add_int(sb, load64(ptr));
    str_builder_add_cstr(sb, ",\"sample_rate\":");
    str_builder_add_int(sb, load64(ptr + 8));
    str_builder_add_cstr(sb, ",\"export_endpoint\":");
    var ep = load64(ptr + 16);
    if (ep != 0) {
        str_builder_putc(sb, '"');
        str_builder_add(sb, ep);
        str_builder_putc(sb, '"');
    } else {
        str_builder_add_cstr(sb, "null");
    }
    str_builder_putc(sb, '}');
    return 0;
}
fn TelemetryConfig_from_json(src: Str) {
    var c = alloc(24);
    store64(c, _json_int(src, str_from("enabled")));
    store64(c + 8, _json_int(src, str_from("sample_rate")));
    store64(c + 16, _json_str(src, str_from("export_endpoint")));
    return c;
}
fn telemetry_config_new() {
    var c = alloc(24);
    store64(c, 1);       # enabled = true
    store64(c + 8, 1000); # sample_rate = 1.0
    store64(c + 16, 0);
    return c;
}
