# test.cyr — table-driven and framework-shaped testing helpers
# Usage: include "lib/test.cyr"
# Transitively pulls in lib/assert.cyr + lib/fnptr.cyr so consumers
# write one include and get the unit-test stack: primitives + dispatch.
#
# Pinned 2026-04-30 (v5.7.43). The decision to keep this stdlib-side
# (vs bundling into yantra) lives in
# `docs/development/roadmap.md §Testing framework split — lib/test.cyr +
# yantra-stays-narrow`. v1 is intentionally minimal:
#
#   - `test_each(cases_vec, fn)` — table-driven dispatch.
#
# Property-based testing (`test_property` on top of `lib/random.cyr`)
# and fixture register/teardown are pinned for v2 behind further
# consumer pressure. They're genuinely different shape and would
# inflate v1's surface without payoff for the in-tree pain that
# justified the slot (json_pointer §5 corpus, json_stream scalars,
# etc. — all of which are pure table-driven dispatch).

include "lib/assert.cyr"
include "lib/fnptr.cyr"

# test_each — apply `fp` to every element of `cases_vec` in order.
#
# Convention: each element of `cases_vec` is a pointer to a
# user-defined "case" struct (typically `alloc(N)` with the test's
# inputs and expected outputs stored at fixed offsets). `fp` is a
# fn pointer (obtained via `&my_check_fn`) that takes the case
# pointer as its single argument and is responsible for extracting
# fields, calling `test_group(case_label)` if it wants per-case
# grouping, and firing the appropriate `assert_*` calls.
#
# Returns 0. Failures are accounted via `lib/assert.cyr`'s globals
# (`_assert_fail` / `_assert_pass` / `_assert_total`); call
# `assert_summary()` once at the end of the test to print totals.
#
# Example:
#
#   fn _check_pointer(c) {
#       var path  = load64(c);          # case[0] = path Str
#       var want  = load64(c + 8);      # case[1] = expected int
#       var label = load64(c + 16);     # case[2] = label cstr
#       assert_eq(json_v_int(json_v_pointer(doc, path)), want, label);
#       return 0;
#   }
#
#   var cases = vec_new();
#   var c0 = alloc(24);
#   store64(c0,      str_from("/users/0/id"));
#   store64(c0 + 8,  1);
#   store64(c0 + 16, "/users/0/id = 1");
#   vec_push(cases, c0);
#   # ... more cases ...
#   test_each(cases, &_check_pointer);
fn test_each(cases_vec, fp): i64 {
    if (cases_vec == 0) { return 0; }
    if (fp == 0) { return 0; }
    var len = vec_len(cases_vec);
    var i = 0;
    while (i < len) {
        fncall1(fp, vec_get(cases_vec, i));
        i = i + 1;
    }
    return 0;
}
