# anuenue test suite. M1 coverage: hsv_rainbow geometry (canonical
# hues + sector ramps + phase normalization), the buf-targeting
# escape-emission primitive borrowed from darshana 0.5.1, and the
# byte-cost arithmetic the filter loop's force-flush threshold
# (ANUENUE_FLUSH_RESERVE) is sized against. The stdin→stdout filter
# loop itself is exercised end-to-end via `scripts/smoke.sh` (added
# alongside M1) — Cyrius can't trivially redirect fd 0/1 inside a
# unit test, so the integration smoke owns the I/O surface.
#
# Stdlib + darshana auto-included via cyrius.cyml.

include "src/filter.cyr"
include "src/animate.cyr"
include "src/version_str.cyr"

fn main(): i64 {
    alloc_init();

    # ---- smoke ------------------------------------------------------
    test_group("smoke");
    assert(1, "true is true");
    assert_eq(1 + 1, 2, "math works");

    # ---- hsv_rainbow: canonical pure-hue sector boundaries ----------
    # Six exact integer points the rainbow geometry MUST hit, one per
    # sector boundary. If any of these regress the entire color model
    # is wrong.
    test_group("hsv_rainbow — canonical hues");
    var rgb[24];

    hsv_rainbow(0, &rgb);
    assert_eq(load64(&rgb + 0),  255, "phase 0    → R=255 (red)");
    assert_eq(load64(&rgb + 8),  0,   "phase 0    → G=0");
    assert_eq(load64(&rgb + 16), 0,   "phase 0    → B=0");

    hsv_rainbow(255, &rgb);
    assert_eq(load64(&rgb + 0),  255, "phase 255  → R=255 (yellow)");
    assert_eq(load64(&rgb + 8),  255, "phase 255  → G=255");
    assert_eq(load64(&rgb + 16), 0,   "phase 255  → B=0");

    hsv_rainbow(510, &rgb);
    assert_eq(load64(&rgb + 0),  0,   "phase 510  → R=0 (green)");
    assert_eq(load64(&rgb + 8),  255, "phase 510  → G=255");
    assert_eq(load64(&rgb + 16), 0,   "phase 510  → B=0");

    hsv_rainbow(765, &rgb);
    assert_eq(load64(&rgb + 0),  0,   "phase 765  → R=0 (cyan)");
    assert_eq(load64(&rgb + 8),  255, "phase 765  → G=255");
    assert_eq(load64(&rgb + 16), 255, "phase 765  → B=255");

    hsv_rainbow(1020, &rgb);
    assert_eq(load64(&rgb + 0),  0,   "phase 1020 → R=0 (blue)");
    assert_eq(load64(&rgb + 8),  0,   "phase 1020 → G=0");
    assert_eq(load64(&rgb + 16), 255, "phase 1020 → B=255");

    hsv_rainbow(1275, &rgb);
    assert_eq(load64(&rgb + 0),  255, "phase 1275 → R=255 (magenta)");
    assert_eq(load64(&rgb + 8),  0,   "phase 1275 → G=0");
    assert_eq(load64(&rgb + 16), 255, "phase 1275 → B=255");

    # phase = 1530 wraps to 0 — proves the modulus normalization path
    hsv_rainbow(1530, &rgb);
    assert_eq(load64(&rgb + 0),  255, "phase 1530 wraps → R=255 (red)");
    assert_eq(load64(&rgb + 8),  0,   "phase 1530 wraps → G=0");
    assert_eq(load64(&rgb + 16), 0,   "phase 1530 wraps → B=0");

    # ---- hsv_rainbow: sub-sector linear ramps -----------------------
    # Each sector has one channel running 0→255 (rising) or 255→0
    # (falling) over its 255 sub-steps. Sample mid-sector to catch
    # off-by-one in the ramp direction.
    test_group("hsv_rainbow — sector ramps");
    # Sector 0 mid (phase 128): R fixed at 255, G rising from 0, B=0.
    hsv_rainbow(128, &rgb);
    assert_eq(load64(&rgb + 0),  255, "sector 0 mid: R=255");
    assert_eq(load64(&rgb + 8),  128, "sector 0 mid: G=128 (rising)");
    assert_eq(load64(&rgb + 16), 0,   "sector 0 mid: B=0");
    # Sector 1 mid (phase 383 = 255+128): R falling 255→0, G fixed, B=0.
    hsv_rainbow(383, &rgb);
    assert_eq(load64(&rgb + 0),  127, "sector 1 mid: R=127 (falling 255-128)");
    assert_eq(load64(&rgb + 8),  255, "sector 1 mid: G=255");
    assert_eq(load64(&rgb + 16), 0,   "sector 1 mid: B=0");
    # Sector 3 mid (phase 893 = 765+128): R=0, G falling, B fixed.
    hsv_rainbow(893, &rgb);
    assert_eq(load64(&rgb + 0),  0,   "sector 3 mid: R=0");
    assert_eq(load64(&rgb + 8),  127, "sector 3 mid: G=127 (falling)");
    assert_eq(load64(&rgb + 16), 255, "sector 3 mid: B=255");
    # Sector 5 mid (phase 1403 = 1275+128): R fixed, G=0, B falling.
    hsv_rainbow(1403, &rgb);
    assert_eq(load64(&rgb + 0),  255, "sector 5 mid: R=255");
    assert_eq(load64(&rgb + 8),  0,   "sector 5 mid: G=0");
    assert_eq(load64(&rgb + 16), 127, "sector 5 mid: B=127 (falling)");

    # ---- hsv_rainbow: phase normalization (large + negative) --------
    # The modulus must wrap any phase value back into [0, 1530). The
    # filter loop's per-byte phase advance will never go negative on
    # its own, but a future M2 -F flag may land negative offsets and
    # we want the model robust now.
    test_group("hsv_rainbow — phase normalization");
    hsv_rainbow(3060, &rgb);    # 2 * 1530 → wraps to 0
    assert_eq(load64(&rgb + 0),  255, "phase 3060 (2×mod) → red R");
    assert_eq(load64(&rgb + 8),  0,   "phase 3060 (2×mod) → red G");
    hsv_rainbow(0 - 255, &rgb); # -255 → wraps to 1275 (magenta start)
    assert_eq(load64(&rgb + 0),  255, "phase -255 → magenta R");
    assert_eq(load64(&rgb + 8),  0,   "phase -255 → magenta G");
    assert_eq(load64(&rgb + 16), 255, "phase -255 → magenta B");

    # ---- byte-cost arithmetic for the filter loop -------------------
    # The flush-reserve threshold ANUENUE_FLUSH_RESERVE = 22 must be
    # ≥ max(escape) + 1 (payload byte) + 4 (trailing reset). The
    # worst-case escape happens when all three channels encode as 3
    # digits each — emitted via tty_fg_rgb_buf below. If darshana
    # ever grows the escape envelope, this test catches it before
    # the filter loop can scribble past the line buffer.
    test_group("filter geometry — flush reserve sizing");
    var ebuf[32];
    var ei = 0;
    while (ei < 32) { store8(&ebuf + ei, 0); ei = ei + 1; }
    var ep = tty_fg_rgb_buf(&ebuf, 0, 255, 255, 255);
    assert_eq(ep, 19, "max fg escape = 19 bytes (ESC[38;2;255;255;255m)");
    # Round-trip the inequality the filter loop uses:
    # `pos + ANUENUE_FLUSH_RESERVE > ANUENUE_LINE_BUF` triggers flush,
    # so a buffer with pos == ANUENUE_LINE_BUF - ANUENUE_FLUSH_RESERVE
    # still has room for `max_escape + payload + reset` = 19 + 1 + 4
    # = 24 bytes... but reserve is 22. The filter doesn't append the
    # next char until AFTER this check fires, so the actual
    # invariant is: after the trigger, we flush, pos resets to 0,
    # then the next escape+byte writes from offset 0 — no overflow.
    # Reserve must only cover the LAST char + reset already in the
    # buffer at flush time, which is escape+byte+reset = 24, hmm.
    # Re-check: the loop appends escape+byte FIRST (consuming up to
    # 18 bytes), THEN tests whether to flush (with margin for the
    # NEXT iteration's escape+byte+reset). So at trigger time we
    # need: 18 (just-written) + 4 (reset on flush) ≤ reserve. 22 fits.
    # Below: enforce 22 >= 18 + 4.
    assert(ANUENUE_FLUSH_RESERVE >= 18 + 4, "reserve ≥ max escape + reset");

    # ---- filter constants are sane ---------------------------------
    test_group("filter constants — sanity");
    assert(ANUENUE_PHASE_MOD == 1530, "PHASE_MOD = 6 × 255 = 1530");
    assert(ANUENUE_PHASE_STEP > 0, "PHASE_STEP positive");
    assert(ANUENUE_PHASE_STEP < ANUENUE_PHASE_MOD, "PHASE_STEP < PHASE_MOD (no per-byte wrap)");
    # LINE_BUF need not hold a full read-chunk's worst-case output —
    # the force-flush inside the loop drains incrementally. The real
    # invariant is "the flush-reserve guard is meaningful": the buf
    # is large enough that flushes amortize the per-flush syscall
    # cost over ≥100 characters. With reserve=22, LINE_BUF=32768 ⇒
    # ~1700 chars between flushes — well over the floor.
    assert(ANUENUE_LINE_BUF > ANUENUE_FLUSH_RESERVE * 100, "LINE_BUF amortizes ≥100 chars per flush");
    assert(ANUENUE_LINE_BUF > ANUENUE_FLUSH_RESERVE, "LINE_BUF > FLUSH_RESERVE (no underflow in guard)");

    # ---- v0.3.0 — M2 flag-parser coverage ---------------------------
    # Exercises `flags_parse` over synthetic argv arrays. The
    # parser's own contract is asserted in cyrius's own
    # tests/flags.tcyr; here we verify anuenue's flag-set wiring:
    # short forms, long forms, integer extraction, the additive
    # `-s` + `-F` accumulator, the boolean -h / -V markers, and the
    # error-variant dispatch. The end-to-end stdin/stdout path
    # (`echo X | anuenue -s 42`) is exercised by the determinism
    # golden in `docs/benchmarks.md` (M5 may scriptize it).
    test_group("M2 flags — long/short bool flags");
    var fs1 = flags_new();
    var f_help    = flags_add_bool(fs1, 104, "help",    0, "h");
    var f_version = flags_add_bool(fs1, 86,  "version", 0, "v");
    var f_freq    = flags_add_int (fs1, 112, "freq",    7, "p");
    var f_seed    = flags_add_int (fs1, 115, "seed",    0, "s");
    var f_offset  = flags_add_int (fs1, 70,  "offset",  0, "F");
    # Argv: ["anuenue", "--help"]
    var argv1[8];
    store64(&argv1 + 0,  "anuenue");
    store64(&argv1 + 8,  "--help");
    assert_eq(flags_parse(fs1, 2, &argv1), 0, "long --help parses clean");
    assert_eq(flags_get_bool(fs1, f_help), 1, "--help → true");
    assert_eq(flags_get_bool(fs1, f_version), 0, "--version untouched");
    assert_eq(flags_get_int(fs1, f_freq), 7, "freq = default 7");

    test_group("M2 flags — short -V");
    var fs2 = flags_new();
    var f2_v = flags_add_bool(fs2, 86, "version", 0, "v");
    var argv2[8];
    store64(&argv2 + 0, "anuenue");
    store64(&argv2 + 8, "-V");
    assert_eq(flags_parse(fs2, 2, &argv2), 0, "-V parses clean");
    assert_eq(flags_get_bool(fs2, f2_v), 1, "-V → true");

    test_group("M2 flags — int -p / -s / -F");
    var fs3 = flags_new();
    var f3_p = flags_add_int(fs3, 112, "freq",   7, "p");
    var f3_s = flags_add_int(fs3, 115, "seed",   0, "s");
    var f3_F = flags_add_int(fs3, 70,  "offset", 0, "F");
    # Argv: ["anuenue", "-p", "13", "-s", "42", "-F", "100"]
    var argv3[64];
    store64(&argv3 + 0,  "anuenue");
    store64(&argv3 + 8,  "-p");
    store64(&argv3 + 16, "13");
    store64(&argv3 + 24, "-s");
    store64(&argv3 + 32, "42");
    store64(&argv3 + 40, "-F");
    store64(&argv3 + 48, "100");
    assert_eq(flags_parse(fs3, 7, &argv3), 0, "-p 13 -s 42 -F 100 parses clean");
    assert_eq(flags_get_int(fs3, f3_p), 13,  "-p value extracted");
    assert_eq(flags_get_int(fs3, f3_s), 42,  "-s value extracted");
    assert_eq(flags_get_int(fs3, f3_F), 100, "-F value extracted");

    test_group("M2 flags — long --freq=N attached syntax");
    var fs4 = flags_new();
    var f4_p = flags_add_int(fs4, 112, "freq", 7, "p");
    var argv4[16];
    store64(&argv4 + 0, "anuenue");
    store64(&argv4 + 8, "--freq=99");
    assert_eq(flags_parse(fs4, 2, &argv4), 0, "--freq=99 parses clean");
    assert_eq(flags_get_int(fs4, f4_p), 99, "--freq=99 value extracted");

    test_group("M2 flags — additive seed+offset semantics");
    # Verifies the main.cyr dispatch logic: PHASE_START = seed +
    # offset. -s 510 (green) + -F 510 (advance 2 sectors) = 1020 (blue).
    var fs5 = flags_new();
    var f5_s = flags_add_int(fs5, 115, "seed",   0, "s");
    var f5_F = flags_add_int(fs5, 70,  "offset", 0, "F");
    var argv5[32];
    store64(&argv5 + 0,  "anuenue");
    store64(&argv5 + 8,  "-s");
    store64(&argv5 + 16, "510");
    store64(&argv5 + 24, "-F");
    store64(&argv5 + 32, "510");
    assert_eq(flags_parse(fs5, 5, &argv5), 0, "-s 510 -F 510 parses clean");
    var combined = flags_get_int(fs5, f5_s) + flags_get_int(fs5, f5_F);
    assert_eq(combined, 1020, "seed + offset = 1020 (blue start)");
    # Confirm the resulting phase lands in sector 4 → blue at byte 0.
    var rgb5[24];
    hsv_rainbow(combined, &rgb5);
    assert_eq(load64(&rgb5 + 0),  0,   "combined phase 1020 → R=0");
    assert_eq(load64(&rgb5 + 16), 255, "combined phase 1020 → B=255 (blue)");

    test_group("M2 flags — error variants");
    # Unknown flag rejected.
    var fs6 = flags_new();
    flags_add_bool(fs6, 104, "help", 0, "h");
    var argv6[16];
    store64(&argv6 + 0, "anuenue");
    store64(&argv6 + 8, "--bogus");
    assert_eq(flags_parse(fs6, 2, &argv6), 0 - 1, "unknown flag rejected");
    assert_eq(flags_error(fs6), FLAG_ERR_UNKNOWN, "error variant = UNKNOWN");

    # Missing value for int flag rejected.
    var fs7 = flags_new();
    flags_add_int(fs7, 112, "freq", 7, "p");
    var argv7[16];
    store64(&argv7 + 0, "anuenue");
    store64(&argv7 + 8, "-p");                 # no value follows
    assert_eq(flags_parse(fs7, 2, &argv7), 0 - 1, "-p without value rejected");
    assert_eq(flags_error(fs7), FLAG_ERR_MISSING_VALUE, "error variant = MISSING_VALUE");

    # Bad integer value rejected.
    var fs8 = flags_new();
    flags_add_int(fs8, 112, "freq", 7, "p");
    var argv8[32];
    store64(&argv8 + 0,  "anuenue");
    store64(&argv8 + 8,  "-p");
    store64(&argv8 + 16, "notanumber");
    assert_eq(flags_parse(fs8, 3, &argv8), 0 - 1, "non-numeric -p value rejected");
    assert_eq(flags_error(fs8), FLAG_ERR_BAD_INT, "error variant = BAD_INT");

    # ---- v0.4.0 — M3 UTF-8 sequence detection ---------------------
    # Synthetic byte buffers cover each path through utf8_seq_len
    # without touching stdin. The decode round-trip ensures the
    # codepoints emerge as expected at canonical samples.

    test_group("M3 utf8_seq_len — 1/2/3/4-byte detection");
    var u1[4];
    store8(&u1 + 0, 0x41);        # 'A' — ASCII
    assert_eq(utf8_seq_len(&u1, 0, 1), 1, "ASCII 'A' → 1");

    var u2[4];
    store8(&u2 + 0, 0xC3);        # leading of é (U+00E9 → C3 A9)
    store8(&u2 + 1, 0xA9);
    assert_eq(utf8_seq_len(&u2, 0, 2), 2, "2-byte é → 2");

    var u3[4];
    store8(&u3 + 0, 0xE6);        # 日 (U+65E5 → E6 97 A5)
    store8(&u3 + 1, 0x97);
    store8(&u3 + 2, 0xA5);
    assert_eq(utf8_seq_len(&u3, 0, 3), 3, "3-byte 日 → 3");

    var u4[4];
    store8(&u4 + 0, 0xF0);        # 🌈 (U+1F308 → F0 9F 8C 88)
    store8(&u4 + 1, 0x9F);
    store8(&u4 + 2, 0x8C);
    store8(&u4 + 3, 0x88);
    assert_eq(utf8_seq_len(&u4, 0, 4), 4, "4-byte 🌈 → 4");

    test_group("M3 utf8_seq_len — invalid + truncated");
    # 0x80 bare continuation byte (not a valid leading byte).
    var bad1[2];
    store8(&bad1 + 0, 0x80);
    store8(&bad1 + 1, 0x41);
    assert_eq(utf8_seq_len(&bad1, 0, 2), 1, "bare continuation → 1 (graceful)");

    # 0xF8 — 5-byte leader, disallowed by RFC 3629.
    var bad2[1];
    store8(&bad2 + 0, 0xF8);
    assert_eq(utf8_seq_len(&bad2, 0, 1), 1, "0xF8 leader → 1");

    # 3-byte leader, but only 2 bytes available — truncated.
    var trunc[2];
    store8(&trunc + 0, 0xE6);
    store8(&trunc + 1, 0x97);
    assert_eq(utf8_seq_len(&trunc, 0, 2), 0, "truncated 3-byte → 0 (carry signal)");

    # 2-byte leader followed by ASCII byte — invalid continuation.
    var badcont[2];
    store8(&badcont + 0, 0xC3);
    store8(&badcont + 1, 0x41);   # 'A' is NOT a valid continuation byte
    assert_eq(utf8_seq_len(&badcont, 0, 2), 1, "invalid continuation → 1");

    test_group("M3 utf8_decode — canonical codepoints");
    # é → U+00E9
    assert_eq(utf8_decode(&u2, 0, 2), 0x00E9, "é decodes to U+00E9");
    # 日 → U+65E5
    assert_eq(utf8_decode(&u3, 0, 3), 0x65E5, "日 decodes to U+65E5");
    # 🌈 → U+1F308
    assert_eq(utf8_decode(&u4, 0, 4), 0x1F308, "🌈 decodes to U+1F308");
    # ASCII passthrough
    assert_eq(utf8_decode(&u1, 0, 1), 0x41, "'A' decodes to 0x41");

    test_group("M3 cp_is_extending — combining marks");
    assert_eq(cp_is_extending(0x0301), 1, "U+0301 combining acute → extending");
    assert_eq(cp_is_extending(0x036F), 1, "U+036F end of Latin combining → extending");
    assert_eq(cp_is_extending(0x200D), 1, "ZWJ → extending");
    assert_eq(cp_is_extending(0xFE0F), 1, "VS-16 → extending");
    assert_eq(cp_is_extending(0xFE20), 1, "U+FE20 combining half mark → extending");
    assert_eq(cp_is_extending(0x064B), 1, "Arabic fatḥatan → extending");
    assert_eq(cp_is_extending(0xE0100), 1, "Variation Selector Supplement → extending");
    # Non-extending: ASCII, regular emoji, regular CJK
    assert_eq(cp_is_extending(0x41),    0, "'A' → not extending");
    assert_eq(cp_is_extending(0x65E5),  0, "日 → not extending");
    assert_eq(cp_is_extending(0x1F308), 0, "🌈 → not extending");
    # Boundary: 0x2FF is just below the Latin combining range
    assert_eq(cp_is_extending(0x02FF), 0, "U+02FF (one before combining) → not extending");
    assert_eq(cp_is_extending(0x0370), 0, "U+0370 (one after combining) → not extending");

    test_group("M3 cp_is_regional_indicator");
    assert_eq(cp_is_regional_indicator(0x1F1E6), 1, "RI A → yes");
    assert_eq(cp_is_regional_indicator(0x1F1FF), 1, "RI Z → yes");
    assert_eq(cp_is_regional_indicator(0x1F1FA), 1, "RI U (🇺) → yes");
    assert_eq(cp_is_regional_indicator(0x1F1E5), 0, "U+1F1E5 → no");
    assert_eq(cp_is_regional_indicator(0x1F200), 0, "U+1F200 → no");
    assert_eq(cp_is_regional_indicator(0x1F308), 0, "🌈 → no");

    # ---- v0.6.0 — M5 perf pass --------------------------------------
    # Phase-cached escape buffer. The fast path replaces
    # `hsv_rainbow + tty_fg_rgb_buf` per cluster with a memcpy from
    # _PHASE_ESC_TABLE[phase % MOD]. The unit-test contract: every
    # entry in the table is byte-identical to what the runtime path
    # would have produced. Build the table, then for each canonical
    # phase compare the cached entry against a fresh runtime emit.
    test_group("M5 perf — phase-cached escape table");
    assert_eq(_phase_esc_init(), 0, "_phase_esc_init returns 0 on success");
    assert(_PHASE_ESC_TABLE != 0, "table pointer non-null after init");
    # Idempotent: second call is a no-op (table already built).
    assert_eq(_phase_esc_init(), 0, "_phase_esc_init idempotent");

    # Per-entry round-trip: for each canonical hue boundary, the
    # cached escape's bytes match a freshly-computed tty_fg_rgb_buf
    # emission. Six canonical hues + the wraparound corner cover
    # 1/2/3-digit channel encodings.
    var pe_rgb[24];
    var pe_fresh[32];
    var pe_dst[32];
    var pe_phases[8];
    store64(&pe_phases + 0 * 8, 0);     # red
    store64(&pe_phases + 1 * 8, 255);   # yellow
    store64(&pe_phases + 2 * 8, 510);   # green
    store64(&pe_phases + 3 * 8, 765);   # cyan
    store64(&pe_phases + 4 * 8, 1020);  # blue
    store64(&pe_phases + 5 * 8, 1275);  # magenta
    store64(&pe_phases + 6 * 8, 1529);  # last entry before wrap
    store64(&pe_phases + 7 * 8, 7);     # default -p step value

    var pi = 0;
    while (pi < 8) {
        var phase = load64(&pe_phases + pi * 8);
        # Runtime path for comparison.
        hsv_rainbow(phase, &pe_rgb);
        var fresh_len = tty_fg_rgb_buf(&pe_fresh, 0,
                                       load64(&pe_rgb + 0),
                                       load64(&pe_rgb + 8),
                                       load64(&pe_rgb + 16));
        # Cached path: _emit_phase_esc writes elen bytes starting at
        # `pos` into the buffer and returns `pos + elen`.
        var cached_pos = _emit_phase_esc(&pe_dst, 0, phase);
        assert_eq(cached_pos, fresh_len, "cached length matches runtime length");
        var bi = 0;
        var bytes_ok = 1;
        while (bi < fresh_len) {
            if (load8(&pe_dst + bi) != load8(&pe_fresh + bi)) { bytes_ok = 0; }
            bi = bi + 1;
        }
        assert_eq(bytes_ok, 1, "cached escape bytes byte-identical to runtime");
        pi = pi + 1;
    }

    # Phase normalization: negative and >MOD phases should hit the
    # same cached entries as their canonical [0, MOD) representatives.
    var n_pos = _emit_phase_esc(&pe_dst, 0, 0);
    var n_neg = _emit_phase_esc(&pe_fresh, 0, 0 - ANUENUE_PHASE_MOD);
    assert_eq(n_pos, n_neg, "phase = -MOD == phase = 0 (same length)");
    var nb = 0;
    var n_match = 1;
    while (nb < n_pos) {
        if (load8(&pe_dst + nb) != load8(&pe_fresh + nb)) { n_match = 0; }
        nb = nb + 1;
    }
    assert_eq(n_match, 1, "phase = -MOD byte-identical to phase = 0");

    var w_canon = _emit_phase_esc(&pe_dst, 0, 7);
    var w_over  = _emit_phase_esc(&pe_fresh, 0, 7 + ANUENUE_PHASE_MOD * 3);
    assert_eq(w_canon, w_over, "phase = 7 + 3*MOD == phase = 7 (same length)");
    var wb = 0;
    var w_match = 1;
    while (wb < w_canon) {
        if (load8(&pe_dst + wb) != load8(&pe_fresh + wb)) { w_match = 0; }
        wb = wb + 1;
    }
    assert_eq(w_match, 1, "phase = 7 + 3*MOD byte-identical to phase = 7");

    # Table layout sanity: 32-byte stride matches the documented
    # cache-line discipline; entry length is always 13..19 (the
    # truecolor SGR envelope).
    assert_eq(ANUENUE_ESC_TABLE_ENTRY_SIZE, 32, "entry size = 32 bytes (cache line stride)");
    var len_min = 99;
    var len_max = 0;
    var li = 0;
    while (li < ANUENUE_PHASE_MOD) {
        var elen = load64(_PHASE_ESC_TABLE + li * ANUENUE_ESC_TABLE_ENTRY_SIZE);
        if (elen < len_min) { len_min = elen; }
        if (elen > len_max) { len_max = elen; }
        li = li + 1;
    }
    assert(len_min >= 13, "min entry length ≥ 13 (truecolor SGR floor)");
    assert(len_max <= 19, "max entry length ≤ 19 (truecolor SGR ceiling)");

    # ---- v0.5.0 — M4 animation surface ------------------------------
    # Cluster pre-tagging and helper math. The frame loop, signalfd,
    # and sleep cadence resist unit-level testing — they go through
    # scripts/golden-check.sh (which gains an animation smoke at M4)
    # and the live SIGINT/duration smokes documented in the M4 cut
    # commit. What we *can* lock down here: the pure functions that
    # turn the buffered input into a cluster table the renderer
    # walks per frame.

    test_group("M4 animate — constants sanity");
    # Defaults the flag layer falls back to.
    assert(ANUENUE_DEFAULT_DURATION_S > 0, "default duration positive (0 reserved for 'until SIGINT')");
    assert(ANUENUE_DEFAULT_SPEED > 0, "default speed positive");
    assert(ANUENUE_FRAME_MS > 0, "frame interval positive");
    assert(ANUENUE_FRAME_MS <= 33, "frame interval ≤ 33ms (~30 fps floor)");
    # Buffer ceilings stay well clear of the cluster index sizing.
    assert(ANUENUE_ANIMATE_INPUT_MAX > 0, "input ceiling > 0");
    assert(ANUENUE_ANIMATE_CLUSTER_MAX > 0, "cluster ceiling > 0");
    # SFD_NONBLOCK is the Linux kernel ABI value (O_NONBLOCK = 04000
    # octal = 2048 decimal on every Linux arch anuenue targets).
    assert_eq(ANUENUE_SFD_NONBLOCK, 2048, "SFD_NONBLOCK = O_NONBLOCK = 2048");

    test_group("M4 animate — _pretag_clusters ASCII");
    # Pre-tag "AGNOS\n" — six clusters, one per byte. ctab[i] holds
    # start offset; ctab[6] holds the byte count sentinel.
    var ab[16];
    store8(&ab + 0, 65);  # A
    store8(&ab + 1, 71);  # G
    store8(&ab + 2, 78);  # N
    store8(&ab + 3, 79);  # O
    store8(&ab + 4, 83);  # S
    store8(&ab + 5, 10);  # LF
    var ac[64];           # 8 slots × 8 bytes
    var n_ac = _pretag_clusters(&ab, 6, &ac, 7);
    assert_eq(n_ac, 6, "AGNOS\\n → 6 clusters");
    assert_eq(load64(&ac + 0 * 8), 0, "cluster 0 starts at byte 0");
    assert_eq(load64(&ac + 1 * 8), 1, "cluster 1 starts at byte 1");
    assert_eq(load64(&ac + 5 * 8), 5, "cluster 5 (LF) starts at byte 5");
    assert_eq(load64(&ac + 6 * 8), 6, "sentinel = total byte count");

    test_group("M4 animate — _pretag_clusters combining diacritic");
    # "é" = e (1 byte) + U+0301 combining acute (2 bytes, 0xCC 0x81)
    # → one cluster covering all 3 bytes. The cluster table records
    # only the base codepoint's start offset.
    var cb[8];
    store8(&cb + 0, 101);   # 'e'
    store8(&cb + 1, 0xCC);  # U+0301 leading byte
    store8(&cb + 2, 0x81);  # U+0301 continuation
    var cc[32];
    var n_cc = _pretag_clusters(&cb, 3, &cc, 3);
    assert_eq(n_cc, 1, "e + combining acute → 1 cluster");
    assert_eq(load64(&cc + 0), 0, "cluster 0 starts at byte 0");
    assert_eq(load64(&cc + 8), 3, "sentinel = 3 (cluster spans all 3 bytes)");

    test_group("M4 animate — _pretag_clusters CJK");
    # "日" = U+65E5 = 0xE6 0x97 0xA5 (3 bytes, 1 cluster), then 'A'
    # = 1 byte = 1 cluster. Two clusters, sentinel = 4.
    var jb[8];
    store8(&jb + 0, 0xE6);
    store8(&jb + 1, 0x97);
    store8(&jb + 2, 0xA5);
    store8(&jb + 3, 65);   # 'A'
    var jc[32];
    var n_jc = _pretag_clusters(&jb, 4, &jc, 3);
    assert_eq(n_jc, 2, "日A → 2 clusters");
    assert_eq(load64(&jc + 0), 0, "cluster 0 (日) starts at byte 0");
    assert_eq(load64(&jc + 8), 3, "cluster 1 (A) starts at byte 3");
    assert_eq(load64(&jc + 16), 4, "sentinel = 4");

    test_group("M4 animate — _pretag_clusters truncated UTF-8");
    # 0xE6 0x97 alone (truncated 3-byte sequence). Pre-tag converts
    # truncation to per-byte clusters (graceful degradation; no
    # next-chunk to wait for in animation mode).
    var tb[4];
    store8(&tb + 0, 0xE6);
    store8(&tb + 1, 0x97);
    var tc[32];
    var n_tc = _pretag_clusters(&tb, 2, &tc, 3);
    assert_eq(n_tc, 2, "truncated 3-byte seq → 2 singleton clusters");
    assert_eq(load64(&tc + 0), 0, "cluster 0 starts at byte 0");
    assert_eq(load64(&tc + 8), 1, "cluster 1 starts at byte 1");
    assert_eq(load64(&tc + 16), 2, "sentinel = 2");

    test_group("M4 animate — _pretag_clusters overflow cap");
    # max_clusters = 2 means stop after 2 clusters are recorded; the
    # remaining input is silently dropped. Sentinel reflects how far
    # we actually advanced.
    var ob[8];
    store8(&ob + 0, 65);
    store8(&ob + 1, 66);
    store8(&ob + 2, 67);
    store8(&ob + 3, 68);
    var oc[32];
    var n_oc = _pretag_clusters(&ob, 4, &oc, 2);
    assert_eq(n_oc, 2, "cap = 2 → exactly 2 clusters tagged");
    assert_eq(load64(&oc + 16), 2, "sentinel = 2 (only first 2 bytes consumed)");

    test_group("M4 animate — _count_lf_clusters");
    # Re-use the ASCII "AGNOS\n" tagged above (ac, n_ac).
    assert_eq(_count_lf_clusters(&ab, &ac, n_ac), 1, "AGNOS\\n → 1 LF cluster");
    # Two-line input: "A\nB\n" → 2 LF clusters.
    var lb[8];
    store8(&lb + 0, 65);
    store8(&lb + 1, 10);
    store8(&lb + 2, 66);
    store8(&lb + 3, 10);
    var lc[64];
    var n_lc = _pretag_clusters(&lb, 4, &lc, 7);
    assert_eq(n_lc, 4, "A\\nB\\n → 4 clusters");
    assert_eq(_count_lf_clusters(&lb, &lc, n_lc), 2, "A\\nB\\n → 2 LFs");

    test_group("M4 animate — _input_ends_with_lf");
    # Re-use AGNOS\n (ends with LF) and a no-LF variant.
    assert_eq(_input_ends_with_lf(&ab, &ac, n_ac), 1, "AGNOS\\n ends with LF");
    var nb[4];
    store8(&nb + 0, 65);  # A
    store8(&nb + 1, 66);  # B
    var nc[32];
    var n_nc = _pretag_clusters(&nb, 2, &nc, 3);
    assert_eq(_input_ends_with_lf(&nb, &nc, n_nc), 0, "AB → no trailing LF");
    # Empty cluster table → false (animate driver short-circuits, but
    # the helper must not crash on the zero case).
    assert_eq(_input_ends_with_lf(&nb, &nc, 0), 0, "0 clusters → false");

    test_group("M4 flags — -a / -d / -S parse");
    var fs_a = flags_new();
    var f_a_animate  = flags_add_bool(fs_a, 97,  "animate",  0, "a");
    var f_a_duration = flags_add_int (fs_a, 100, "duration", ANUENUE_DEFAULT_DURATION_S, "d");
    var f_a_speed    = flags_add_int (fs_a, 83,  "speed",    ANUENUE_DEFAULT_SPEED, "S");
    var argv_a[40];
    store64(&argv_a + 0,  "anuenue");
    store64(&argv_a + 8,  "-a");
    store64(&argv_a + 16, "-d");
    store64(&argv_a + 24, "3");
    store64(&argv_a + 32, "-S");
    var argv_a_2[16];
    store64(&argv_a_2 + 0, "anuenue");
    store64(&argv_a_2 + 8, "-a");
    assert_eq(flags_parse(fs_a, 2, &argv_a_2), 0, "-a alone parses clean");
    assert_eq(flags_get_bool(fs_a, f_a_animate), 1, "-a → animate true");
    assert_eq(flags_get_int(fs_a, f_a_duration), ANUENUE_DEFAULT_DURATION_S, "duration = default");
    assert_eq(flags_get_int(fs_a, f_a_speed), ANUENUE_DEFAULT_SPEED, "speed = default");

    var fs_b = flags_new();
    var f_b_animate  = flags_add_bool(fs_b, 97,  "animate",  0, "a");
    var f_b_duration = flags_add_int (fs_b, 100, "duration", ANUENUE_DEFAULT_DURATION_S, "d");
    var f_b_speed    = flags_add_int (fs_b, 83,  "speed",    ANUENUE_DEFAULT_SPEED, "S");
    var argv_b[48];
    store64(&argv_b + 0,  "anuenue");
    store64(&argv_b + 8,  "-a");
    store64(&argv_b + 16, "-d");
    store64(&argv_b + 24, "12");
    store64(&argv_b + 32, "-S");
    store64(&argv_b + 40, "4");
    assert_eq(flags_parse(fs_b, 6, &argv_b), 0, "-a -d 12 -S 4 parses clean");
    assert_eq(flags_get_bool(fs_b, f_b_animate), 1, "-a → animate true");
    assert_eq(flags_get_int(fs_b, f_b_duration), 12, "duration = 12");
    assert_eq(flags_get_int(fs_b, f_b_speed), 4, "speed = 4");

    # Long-form: --duration=N attached syntax (mirrors M2 --freq=N test).
    var fs_c = flags_new();
    var f_c_animate  = flags_add_bool(fs_c, 97,  "animate",  0, "a");
    var f_c_duration = flags_add_int (fs_c, 100, "duration", ANUENUE_DEFAULT_DURATION_S, "d");
    var argv_c[24];
    store64(&argv_c + 0,  "anuenue");
    store64(&argv_c + 8,  "--animate");
    store64(&argv_c + 16, "--duration=0");
    assert_eq(flags_parse(fs_c, 3, &argv_c), 0, "--animate --duration=0 parses clean");
    assert_eq(flags_get_bool(fs_c, f_c_animate), 1, "--animate → true");
    assert_eq(flags_get_int(fs_c, f_c_duration), 0, "duration = 0 ('until SIGINT' sentinel)");

    test_group("M2 — version literal consistency");
    # _VERSION_STR_ANUENUE is auto-generated by scripts/version-
    # bump.sh; assert the literal format so a hand-edit (or a stale
    # version_str.cyr) trips the test before it can ship in a
    # release. Bytes: "anuenue " (8) + "X.Y.Z" + "\n".
    assert_eq(load8(_VERSION_STR_ANUENUE + 0), 97,  "byte 0 = 'a'");
    assert_eq(load8(_VERSION_STR_ANUENUE + 1), 110, "byte 1 = 'n'");
    assert_eq(load8(_VERSION_STR_ANUENUE + 7), 32,  "byte 7 = ' '");
    assert_eq(load8(_VERSION_STR_ANUENUE + _VERSION_LEN_ANUENUE - 1), 10, "last byte = LF");
    # Length matches strlen — guards against version-bump.sh writing
    # a mismatched LEN constant.
    assert_eq(strlen(_VERSION_STR_ANUENUE), _VERSION_LEN_ANUENUE, "strlen matches _VERSION_LEN_ANUENUE");

    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
