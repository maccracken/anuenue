# file.cyr — .patra file format constants, header, flock locking

# ── Constants ────────────────────

enum PageConst { PAGE_SIZE = 4096; MAX_TABLES = 63; MAX_COLS = 32; }

# Magic: "PTRA" as little-endian u32 (P=0x50 T=0x54 R=0x52 A=0x41)
enum PatraFmt { PATRA_MAGIC = 0x41525450; PATRA_VER = 1; }

enum PageType  { PAGE_FREE = 0; PAGE_DATA = 1; PAGE_SCHEMA = 2; PAGE_BTREE = 3; PAGE_BYTES = 4; }
enum ColType   { COL_INT = 0; COL_STR = 1; COL_BYTES = 2; COL_INT_SZ = 8; COL_STR_SZ = 256; COL_BYTES_SZ = 16; }

# Blob page layout (4096 bytes; chained). Stores up to BY_DATA_MAX bytes;
# `BY_NEXT` points at the next blob page (0 = last). Chain is one-way.
# A row's BLOB field is 16 bytes: (first_page i64, length i64). length is
# the *total* payload in the chain — not per-page. A zero first_page means
# an empty blob (no pages allocated).
enum ByOff {
    BY_TYPE = 0;
    BY_LEN = 8;
    BY_NEXT = 16;
    BY_DATA = 24;
    BY_DATA_MAX = 4072;
}

# Row blob ref layout (16 bytes at a BLOB column's row offset).
enum BRefOff { BR_PAGE = 0; BR_LEN = 8; }

enum PatraErr {
    PATRA_OK = 0;
    PATRA_ERR_IO = 1;
    PATRA_ERR_MAGIC = 2;
    PATRA_ERR_FULL = 3;
    PATRA_ERR_EXISTS = 4;
    PATRA_ERR_NOTFOUND = 5;
    PATRA_ERR_SYNTAX = 6;
    PATRA_ERR_PAGE = 7;
    PATRA_ERR_ROWSZ = 8;
    PATRA_ERR_TYPE = 9;
    PATRA_ERR_COLCOUNT = 10;
}

# Header layout (4096 bytes total — page 0)
enum HdrOff {
    HDR_MAGIC = 0;
    HDR_VER = 4;
    HDR_PGCOUNT = 8;
    HDR_FREEHEAD = 16;
    HDR_TBLCOUNT = 24;
    HDR_TBLDIR = 64;
}

# Table directory entry (64 bytes each, max 63 entries)
enum TblOff {
    TBL_NAME = 0;
    TBL_NAME_MAX = 32;
    TBL_NCOLS = 32;
    TBL_ROOT = 40;
    TBL_NROWS = 48;
    TBL_SCHEMA = 56;
    TBL_ENTRY_SZ = 64;
}

# Schema page column layout (40 bytes per column)
enum SchOff {
    SCH_NCOLS = 0;
    SCH_START = 8;
    SCH_CNAME = 0;
    SCH_CNAME_MAX = 32;
    SCH_CTYPE = 32;
    SCH_ENTRY_SZ = 40;
}

# Data page layout
enum DPOff {
    DP_TYPE = 0;
    DP_NROWS = 8;
    DP_NEXT = 16;
    DP_DATA = 24;
}

# Free page layout
enum FPOff { FP_TYPE = 0; FP_NEXT = 8; }

# flock + fsync syscalls
enum Flock { LOCK_SH = 1; LOCK_EX = 2; LOCK_UN = 8; SYS_FLOCK = 73; }
enum Sync { SYS_FDATASYNC = 75; }

# ── Low-level operations ────────────────────

# Seek to byte offset in file
fn _pt_seek(fd, off): i64 {
    return syscall(SYS_LSEEK, fd, off, 0);
}

# Apply flock operation to fd
fn _pt_flock(fd, op): i64 {
    return syscall(SYS_FLOCK, fd, op);
}

# Acquire exclusive (write) lock
fn patra_lock_ex(fd): i64 { return _pt_flock(fd, LOCK_EX); }
# Acquire shared (read) lock
fn patra_lock_sh(fd): i64 { return _pt_flock(fd, LOCK_SH); }
# Release lock
fn patra_unlock(fd): i64 { return _pt_flock(fd, LOCK_UN); }

# ── Header management ────────────────────

# Initialize header buffer with magic and defaults
fn patra_hdr_init(buf): i64 {
    memset(buf, 0, PAGE_SIZE);
    store32(buf + HDR_MAGIC, PATRA_MAGIC);
    store32(buf + HDR_VER, PATRA_VER);
    store64(buf + HDR_PGCOUNT, 1);
}

# Read header page from file into buffer
fn patra_hdr_read(fd, buf): i64 {
    if (_pt_seek(fd, 0) < 0) { return PATRA_ERR_IO; }
    if (sys_read(fd, buf, PAGE_SIZE) != PAGE_SIZE) { return PATRA_ERR_IO; }
    return PATRA_OK;
}

# Write header page from buffer to file without fdatasync. Used by the
# group-commit path (1.8.0) — caller is responsible for syncing later.
# Write the header page without fdatasync (group-commit path).
fn patra_hdr_write_nosync(fd, buf): i64 {
    if (_pt_seek(fd, 0) < 0) { return PATRA_ERR_IO; }
    if (sys_write(fd, buf, PAGE_SIZE) != PAGE_SIZE) { return PATRA_ERR_IO; }
    return PATRA_OK;
}

# Write header page from buffer to file with fdatasync
fn patra_hdr_write(fd, buf): i64 {
    var r = patra_hdr_write_nosync(fd, buf);
    if (r != PATRA_OK) { return r; }
    syscall(SYS_FDATASYNC, fd);
    return PATRA_OK;
}

# Verify header magic + version + internal bounds. Audit 2026-04-21 §3.7
# rejects a malformed header that would let `tbl_find` walk past the 63-entry
# table directory or let `page_alloc` dereference a bogus free-list head.
# Verify header magic, version, and internal bounds.
fn patra_hdr_verify(buf): i64 {
    if (load32(buf + HDR_MAGIC) != PATRA_MAGIC) { return PATRA_ERR_MAGIC; }
    if (load32(buf + HDR_VER) != PATRA_VER) { return PATRA_ERR_MAGIC; }
    var pgc = load64(buf + HDR_PGCOUNT);
    if (pgc < 1) { return PATRA_ERR_PAGE; }
    var fh = load64(buf + HDR_FREEHEAD);
    if (fh != 0) {
        if (fh >= pgc) { return PATRA_ERR_PAGE; }
        if (fh < 1) { return PATRA_ERR_PAGE; }
    }
    var tc = load64(buf + HDR_TBLCOUNT);
    if (tc < 0) { return PATRA_ERR_PAGE; }
    if (tc > MAX_TABLES) { return PATRA_ERR_PAGE; }
    return PATRA_OK;
}

# Log error message via sakshi
fn _pt_err(msg): i64 {
    sakshi_error(msg, strlen(msg));
}

# ── File create / open ────────────────────

# O_NOFOLLOW on Linux x86_64 = 0x20000 (131072). Prevents `open(2)` from
# following a symbolic link at the final path component. Audit 2026-04-21
# §2.8: closes the TOCTOU/symlink plant described in CVE-2025-68146.
enum OpenFlag { O_NOFOLLOW = 131072; }

# Create new .patra file (O_RDWR | O_CREAT | O_EXCL | O_NOFOLLOW,
# mode 0644 = 420). O_EXCL already refuses an existing target; O_NOFOLLOW
# additionally refuses a symlink pointed at the target path.
fn _pt_file_create(path): i64 {
    var fd = sys_open(path, 194 + O_NOFOLLOW, 420);
    if (fd < 0) { return 0 - 1; }
    var buf = pg_alloc();
    patra_hdr_init(buf);
    _pt_seek(fd, 0);
    var r = sys_write(fd, buf, PAGE_SIZE);
    pg_free(buf);
    if (r != PAGE_SIZE) { sys_close(fd); return 0 - 1; }
    return fd;
}

# Open existing .patra file (O_RDWR | O_NOFOLLOW). Refuses symlinked targets.
fn _pt_file_open(path): i64 {
    return sys_open(path, 2 + O_NOFOLLOW, 0);
}

# ── Page slab (4KB buffer pool) ───────────
#
# Hot paths (page_read/_write callers, btree node walks, schema reads,
# bytes-chain walks) allocate and free PAGE_SIZE-sized scratch buffers
# tens of times per `patra_exec`. fl_alloc/fl_free goes through size-class
# lookup + freelist bookkeeping; a small LIFO stack of pre-allocated
# 4KB buffers skips both. Cap at PG_SLAB_MAX so a long-running consumer
# can't accumulate unbounded retained memory; overflows fall back to
# freelist transparently. Callers must pair pg_alloc / pg_free — slab
# correctness depends on every pushed buffer being PAGE_SIZE.
enum SlabConst { PG_SLAB_MAX = 32; }
var _pg_slab_stack = 0;
var _pg_slab_top = 0;

fn _pg_slab_init(): i64 {
    if (_pg_slab_stack == 0) {
        _pg_slab_stack = alloc(PG_SLAB_MAX * 8);
    }
    return 0;
}

# Allocate a 4KB buffer from the page slab, falling back to fl_alloc on miss.
fn pg_alloc(): i64 {
    _pg_slab_init();
    if (_pg_slab_top > 0) {
        _pg_slab_top = _pg_slab_top - 1;
        return load64(_pg_slab_stack + _pg_slab_top * 8);
    }
    return fl_alloc(PAGE_SIZE);
}

# Return a 4KB buffer to the page slab, or to fl_free if the slab is full.
fn pg_free(buf): i64 {
    if (buf == 0) { return 0; }
    _pg_slab_init();
    if (_pg_slab_top < PG_SLAB_MAX) {
        store64(_pg_slab_stack + _pg_slab_top * 8, buf);
        _pg_slab_top = _pg_slab_top + 1;
        return 0;
    }
    fl_free(buf);
    return 0;
}

# --- wal.cyr ---

# wal.cyr — Write-ahead logging for crash recovery
#
# Before modifying a page, the current (before) content is saved to a .wal file.
# On commit: WAL is deleted. On crash recovery: WAL is replayed (undo).
# Integrates with page_write via globals — no call-site changes needed.
#
# File format (1.5.3+, v2):
#   [0..3]       magic "PTWA" (0x41575450 little-endian)
#   [4..7]       version (2)
#   [8..15]      salt1 (i64, fresh per transaction)
#   [16..23]     salt2 (i64, fresh per transaction)
#   [24..]       records, each 4112 bytes:
#                  [0..7]       page_num (i64)
#                  [8..4103]    before-image page (4096 bytes)
#                  [4104..4111] djb2-derived hash of (salt1, pg, data, salt2)
#
# Salts are drawn from SYS_GETRANDOM with a time+counter fallback, and are
# re-generated on every wal_start so a WAL from one transaction is useless
# to inject into another. Records whose hash does not match the header's
# salts abort replay at that point; earlier records still apply. Bare or
# old-version WAL files are refused outright and left in place so an
# operator can inspect them.

var _wal_fd = 0 - 1;
var _wal_db_fd = 0 - 1;
var _wal_pages = 0;
var _wal_nlog = 0;
var _wal_overflow = 0;
var _wal_salt1 = 0;
var _wal_salt2 = 0;
var _wal_tx_counter = 0;

enum WalConst {
    WAL_MAX_PAGES = 64;
    WAL_REC_SZ = 4112;
    WAL_HDR_SZ = 24;
    WAL_MAGIC = 0x41575450;
    WAL_VER = 2;
    SYS_GETRANDOM = 318;
}

# Draw 16 bytes of randomness into (salt1, salt2). Prefers SYS_GETRANDOM;
# if unavailable (very old kernel / restricted container), falls back to
# a time + tx-counter mix — weaker but still unique per transaction.
fn _wal_gen_salts(): i64 {
    var buf = fl_alloc(16);
    var nr = syscall(SYS_GETRANDOM, buf, 16, 0);
    if (nr == 16) {
        _wal_salt1 = load64(buf);
        _wal_salt2 = load64(buf + 8);
    } else {
        var t = syscall(201, 0);
        _wal_tx_counter = _wal_tx_counter + 1;
        _wal_salt1 = t * 2654435761 + _wal_tx_counter;
        _wal_salt2 = t + _wal_tx_counter * 1099511628211;
    }
    fl_free(buf);
    return 0;
}

# djb2-derivative hash seeded with salt1 and mixed with salt2 at the end.
# Non-cryptographic — defeats accidental corruption, stale-WAL replay, and
# cross-WAL replay. Does not defeat an attacker who can read .wal and the
# algorithm simultaneously (same-host read gives them the salts). Any
# stronger guarantee requires a secret outside the filesystem.
fn _wal_hash(pg, page_data, salt1, salt2): i64 {
    var h = salt1 * 2654435761 + pg;
    h = h + 5381;
    for (var i = 0; i < PAGE_SIZE; i = i + 1) {
        h = h * 33 + (load8(page_data + i) & 0xff);
    }
    return h ^ salt2;
}

# Begin WAL logging for a transaction
fn wal_start(db_fd, wal_path): i64 {
    _wal_fd = sys_open(wal_path, 578, 420);
    # O_RDWR | O_CREAT | O_TRUNC = 2 + 64 + 512 = 578
    if (_wal_fd < 0) { _wal_fd = 0 - 1; return PATRA_ERR_IO; }
    _wal_db_fd = db_fd;
    if (_wal_pages == 0) { _wal_pages = alloc(WAL_MAX_PAGES * 8); }
    _wal_nlog = 0;
    _wal_overflow = 0;

    _wal_gen_salts();

    # Write WAL header: magic + version + salt1 + salt2
    var hdr = fl_alloc(WAL_HDR_SZ);
    memset(hdr, 0, WAL_HDR_SZ);
    store32(hdr, WAL_MAGIC);
    store32(hdr + 4, WAL_VER);
    store64(hdr + 8, _wal_salt1);
    store64(hdr + 16, _wal_salt2);
    sys_write(_wal_fd, hdr, WAL_HDR_SZ);
    fl_free(hdr);
    return PATRA_OK;
}

# Returns 1 if WAL logging is active
fn wal_is_active(): i64 {
    if (_wal_fd >= 0) { return 1; }
    return 0;
}

# Returns 1 if WAL overflowed (more than 64 pages in transaction)
fn wal_overflowed(): i64 { return _wal_overflow; }

# Log before-image of a page (called from page_write)
fn wal_log_page(page_num): i64 {
    if (_wal_fd < 0) { return 0; }
    # Check if already logged
    for (var i = 0; i < _wal_nlog; i = i + 1) {
        if (load64(_wal_pages + i * 8) == page_num) { return 0; }
    }
    if (_wal_nlog >= WAL_MAX_PAGES) { _wal_overflow = 1; return 0; }
    store64(_wal_pages + _wal_nlog * 8, page_num);
    _wal_nlog = _wal_nlog + 1;

    # Read current page from disk
    var buf = fl_alloc(WAL_REC_SZ);
    memset(buf, 0, WAL_REC_SZ);
    store64(buf, page_num);
    _pt_seek(_wal_db_fd, page_offset(page_num));
    var nr = sys_read(_wal_db_fd, buf + 8, PAGE_SIZE);
    if (nr < 0) { nr = 0; }
    # Trailing checksum (salted)
    store64(buf + 8 + PAGE_SIZE, _wal_hash(page_num, buf + 8, _wal_salt1, _wal_salt2));
    # Write record to WAL
    sys_write(_wal_fd, buf, WAL_REC_SZ);
    fl_free(buf);
    return 0;
}

# Commit transaction: sync WAL, flush in-place data pages, then delete WAL.
# Audit 2026-04-21 §2.9: pre-1.5.2 the WAL was unlinked before the data-page
# writes were durable. A crash in that window lost committed data. Now we
# fdatasync the DB fd before unlink, guaranteeing that by the time the WAL
# disappears, the committed pages have reached disk.
fn wal_commit(wal_path): i64 {
    if (_wal_fd >= 0) {
        syscall(SYS_FDATASYNC, _wal_fd);
        sys_close(_wal_fd);
    }
    if (_wal_db_fd >= 0) {
        syscall(SYS_FDATASYNC, _wal_db_fd);
    }
    _wal_fd = 0 - 1;
    _wal_nlog = 0;
    sys_unlink(wal_path);
    return 0;
}

# Verify WAL header and load its salts into the module globals. Returns
# PATRA_OK, or PATRA_ERR_MAGIC on bad magic / unsupported version / short read.
fn _wal_hdr_verify(fd): i64 {
    if (syscall(SYS_LSEEK, fd, 0, 0) < 0) { return PATRA_ERR_IO; }
    var hdr = fl_alloc(WAL_HDR_SZ);
    var nr = sys_read(fd, hdr, WAL_HDR_SZ);
    if (nr != WAL_HDR_SZ) { fl_free(hdr); return PATRA_ERR_MAGIC; }
    if (load32(hdr) != WAL_MAGIC) { fl_free(hdr); return PATRA_ERR_MAGIC; }
    if (load32(hdr + 4) != WAL_VER) { fl_free(hdr); return PATRA_ERR_MAGIC; }
    _wal_salt1 = load64(hdr + 8);
    _wal_salt2 = load64(hdr + 16);
    fl_free(hdr);
    return PATRA_OK;
}

# Rollback: restore before-images from WAL, delete it. Stops replay on a
# checksum mismatch — earlier records still apply, the record with the bad
# hash and everything after it is skipped.
fn wal_rollback(wal_path): i64 {
    if (_wal_fd < 0) { return 0; }
    if (_wal_hdr_verify(_wal_fd) != PATRA_OK) {
        sys_close(_wal_fd);
        _wal_fd = 0 - 1;
        _wal_nlog = 0;
        sys_unlink(wal_path);
        return PATRA_ERR_MAGIC;
    }
    var buf = fl_alloc(WAL_REC_SZ);
    var done = 0;
    while (done == 0) {
        var nr = sys_read(_wal_fd, buf, WAL_REC_SZ);
        if (nr != WAL_REC_SZ) { done = 1; continue; }
        var pg = load64(buf);
        var want = load64(buf + 8 + PAGE_SIZE);
        var got = _wal_hash(pg, buf + 8, _wal_salt1, _wal_salt2);
        if (want != got) { done = 1; continue; }
        _pt_seek(_wal_db_fd, page_offset(pg));
        sys_write(_wal_db_fd, buf + 8, PAGE_SIZE);
    }
    fl_free(buf);
    syscall(SYS_FDATASYNC, _wal_db_fd);
    sys_close(_wal_fd);
    _wal_fd = 0 - 1;
    _wal_nlog = 0;
    sys_unlink(wal_path);
    return 0;
}

# Recover from crash: if WAL file exists, replay it. Returns 1 on replay
# attempt (even if bad magic — the file is then left for inspection).
fn wal_recover(db_fd, wal_path): i64 {
    var wfd = sys_open(wal_path, 0, 0);
    if (wfd < 0) { return 0; }
    if (_wal_hdr_verify(wfd) != PATRA_OK) {
        # Bad magic / stale format: refuse to replay. Leave the file on disk
        # so an operator can inspect it; we will not silently corrupt the DB.
        sys_close(wfd);
        return 1;
    }
    var buf = fl_alloc(WAL_REC_SZ);
    var done = 0;
    while (done == 0) {
        var nr = sys_read(wfd, buf, WAL_REC_SZ);
        if (nr != WAL_REC_SZ) { done = 1; continue; }
        var pg = load64(buf);
        var want = load64(buf + 8 + PAGE_SIZE);
        var got = _wal_hash(pg, buf + 8, _wal_salt1, _wal_salt2);
        if (want != got) { done = 1; continue; }
        _pt_seek(db_fd, page_offset(pg));
        sys_write(db_fd, buf + 8, PAGE_SIZE);
    }
    fl_free(buf);
    syscall(SYS_FDATASYNC, db_fd);
    sys_close(wfd);
    sys_unlink(wal_path);
    return 1;
}

# --- page.cyr ---

# page.cyr — 4KB page management (alloc, read, write, free list)

# Compute byte offset for page number. Returns a negative value on
# overflow so callers' `_pt_seek` check catches it. Audit 2026-04-21 §2.4:
# i64 `num * PAGE_SIZE` wraps for num ≥ 2^51; we cap at num ≤ 2^50 to leave
# headroom.
fn page_offset(num): i64 {
    if (num < 0) { return 0 - 1; }
    if (num > 1125899906842624) { return 0 - 1; }
    return PAGE_SIZE + num * PAGE_SIZE;
}

# Read a page from file into buffer
fn page_read(fd, num, buf): i64 {
    if (_pt_seek(fd, page_offset(num)) < 0) { return PATRA_ERR_IO; }
    if (sys_read(fd, buf, PAGE_SIZE) != PAGE_SIZE) { return PATRA_ERR_IO; }
    return PATRA_OK;
}

# Bounds-checked page read: rejects num == 0 (header) and num >= HDR_PGCOUNT
# (past end of file). Used on any page number read from on-disk data —
# closes the Magellan-class OOB-read vector where a malformed .patra file
# can point a B-tree child at arbitrary page numbers.
fn page_read_checked(fd, hdr, num, buf): i64 {
    if (num <= 0) { return PATRA_ERR_PAGE; }
    if (num >= load64(hdr + HDR_PGCOUNT)) { return PATRA_ERR_PAGE; }
    return page_read(fd, num, buf);
}

# Write a page from buffer to file (WAL-logged)
fn page_write(fd, num, buf): i64 {
    wal_log_page(num);
    if (_pt_seek(fd, page_offset(num)) < 0) { return PATRA_ERR_IO; }
    if (sys_write(fd, buf, PAGE_SIZE) != PAGE_SIZE) { return PATRA_ERR_IO; }
    return PATRA_OK;
}

# Allocate a new page (from free list or extend file)
fn page_alloc(fd, hdr): i64 {
    var fh = load64(hdr + HDR_FREEHEAD);
    if (fh != 0) {
        var buf = fl_alloc(PAGE_SIZE);
        var rr = page_read(fd, fh, buf);
        if (rr != PATRA_OK) { fl_free(buf); return 0; }
        var next = load64(buf + FP_NEXT);
        store64(hdr + HDR_FREEHEAD, next);
        fl_free(buf);
        return fh;
    }
    var num = load64(hdr + HDR_PGCOUNT);
    store64(hdr + HDR_PGCOUNT, num + 1);
    var buf = fl_alloc(PAGE_SIZE);
    memset(buf, 0, PAGE_SIZE);
    page_write(fd, num, buf);
    fl_free(buf);
    return num;
}

# Free a page (add to free list)
fn page_free(fd, hdr, num): i64 {
    var buf = fl_alloc(PAGE_SIZE);
    memset(buf, 0, PAGE_SIZE);
    store64(buf + FP_TYPE, PAGE_FREE);
    store64(buf + FP_NEXT, load64(hdr + HDR_FREEHEAD));
    page_write(fd, num, buf);
    store64(hdr + HDR_FREEHEAD, num);
    fl_free(buf);
}

# Initialize buffer as empty data page
fn page_init_data(buf): i64 {
    memset(buf, 0, PAGE_SIZE);
    store64(buf + DP_TYPE, PAGE_DATA);
}

# --- row.cyr ---

# row.cyr — row encoding/decoding (i64 + fixed-length strings)

# Size in bytes for a column type (INT=8, STR=256, BLOB=16)
fn row_col_size(ctype): i64 {
    if (ctype == COL_INT)  { return COL_INT_SZ; }
    if (ctype == COL_BYTES) { return COL_BYTES_SZ; }
    return COL_STR_SZ;
}

# Compute total row size from a schema page buffer
# Total row size from schema page
fn row_compute_size(schema, ncols): i64 {
    var sz = 0;
    for (var i = 0; i < ncols; i = i + 1) {
        var ct = load64(schema + SCH_START + i * SCH_ENTRY_SZ + SCH_CTYPE);
        sz = sz + row_col_size(ct);
    }
    return sz;
}

# Byte offset of column col_idx within a row
# Byte offset of column within a row
fn row_field_offset(schema, ncols, col): i64 {
    var off = 0;
    for (var i = 0; i < col; i = i + 1) {
        var ct = load64(schema + SCH_START + i * SCH_ENTRY_SZ + SCH_CTYPE);
        off = off + row_col_size(ct);
    }
    return off;
}

# Write i64 value to row at offset
fn row_write_int(row, off, val): i64 {
    store64(row + off, val);
}

# Write string value padded to COL_STR_SZ (256 bytes), null-terminated
# Write string value to row at offset (padded to 64 bytes)
fn row_write_str(row, off, ptr, len): i64 {
    memset(row + off, 0, COL_STR_SZ);
    var n = len;
    if (n > COL_STR_SZ - 1) { n = COL_STR_SZ - 1; }
    memcpy(row + off, ptr, n);
}

# Read i64 value from row at offset
fn row_read_int(row, off): i64 {
    return load64(row + off);
}

# Returns pointer to the 256-byte string field (null-terminated)
# Read string pointer from row at offset
fn row_read_str(row, off): i64 {
    return row + off;
}

# Write blob ref (first_page, length) into the 16-byte BLOB field
fn row_write_bytes_ref(row, off, first_page, blen): i64 {
    store64(row + off + BR_PAGE, first_page);
    store64(row + off + BR_LEN,  blen);
}

# Read blob ref first page from row at offset
fn row_read_bytes_page(row, off): i64 {
    return load64(row + off + BR_PAGE);
}

# Read blob ref length from row at offset
fn row_read_bytes_len(row, off): i64 {
    return load64(row + off + BR_LEN);
}

# Compare two COL_STR_SZ-byte slots word-at-a-time. STR-slot compare is
# the hot inner loop of the INSERT OR IGNORE STR conflict probe; both
# slots are guaranteed COL_STR_SZ-aligned (256 / 8 = 32 word loads).
# Returns 1 if equal, 0 otherwise.
fn _memeq256(a, b): i64 {
    var i = 0;
    while (i < COL_STR_SZ) {
        if (load64(a + i) != load64(b + i)) { return 0; }
        i = i + 8;
    }
    return 1;
}

# 64-bit string hash for STR-keyed B-tree indexes. djb2 over the input
# bytes followed by zero-padding to COL_STR_SZ — so a query-time literal
# "alice" (len 5) hashes identically to the 256-byte zero-padded slot
# row_write_str produced. WHERE-indexed-eq verifies hits with where_eval,
# so collisions are correctness-neutral; djb2 is enough.
fn _str_hash64(ptr, len): i64 {
    var h = 5381;
    var n = len;
    if (n > COL_STR_SZ - 1) { n = COL_STR_SZ - 1; }
    var i = 0;
    while (i < n) {
        h = h * 33 + load8(ptr + i);
        i = i + 1;
    }
    while (i < COL_STR_SZ) {
        h = h * 33;
        i = i + 1;
    }
    return h;
}

# Index key for the indexed column `ic` of `row`. INT cols return the
# raw i64; STR cols return _str_hash64 of the 256-byte slot.
fn _idx_key_from_row(schema, ncols, ic, row): i64 {
    var ct = load64(schema + SCH_START + ic * SCH_ENTRY_SZ + SCH_CTYPE);
    var off = row_field_offset(schema, ncols, ic);
    if (ct == COL_INT) { return row_read_int(row, off); }
    return _str_hash64(row + off, COL_STR_SZ);
}

# --- bytes.cyr ---

# blob.cyr — variable-length binary column storage
#
# A BLOB value is written as a chain of PAGE_BYTES pages:
#   [BY_TYPE=PAGE_BYTES : 8][BY_LEN : 8][BY_NEXT : 8][BY_DATA : 4072]
# BY_LEN is the payload byte count *in this page* (not total). The total
# length lives in the row's 16-byte blob ref as (first_page, length).
# Chain pages are allocated through page_alloc (so WAL & free list apply).

# Write `len` bytes from `ptr` as a chain of blob pages. Returns the first
# page number (0 for an empty blob). Allocates bottom-up so the final page
# is written first, and the returned page is the head of the chain.
fn _bytes_write_chain(fd, hdr, ptr, len): i64 {
    if (len <= 0) { return 0; }
    if (ptr == 0) { return 0; }

    # Count pages needed, ceiling-div
    var full = len / BY_DATA_MAX;
    var rem  = len - full * BY_DATA_MAX;
    var npages = full;
    if (rem > 0) { npages = npages + 1; }

    var buf = pg_alloc();
    var next_pg = 0;

    # Emit the tail page first; walk backward to the head
    for (var i = npages - 1; i >= 0; i = i - 1) {
        memset(buf, 0, PAGE_SIZE);
        store64(buf + BY_TYPE, PAGE_BYTES);

        var off = i * BY_DATA_MAX;
        var chunk = BY_DATA_MAX;
        var tail = len - off;
        if (tail < chunk) { chunk = tail; }

        store64(buf + BY_LEN, chunk);
        store64(buf + BY_NEXT, next_pg);
        memcpy(buf + BY_DATA, ptr + off, chunk);

        var this_pg = page_alloc(fd, hdr);
        page_write(fd, this_pg, buf);
        next_pg = this_pg;
    }
    pg_free(buf);
    return next_pg;
}

# Read `len` bytes of blob from the chain starting at `first_page` into
# `out`. Returns PATRA_OK on success, PATRA_ERR_PAGE on a malformed chain.
fn _bytes_read_chain(fd, hdr, first_page, len, out): i64 {
    if (len <= 0) { return PATRA_OK; }
    if (first_page == 0) { return PATRA_ERR_PAGE; }

    var buf = pg_alloc();
    var cur = first_page;
    var copied = 0;

    while (cur != 0) {
        if (page_read_checked(fd, hdr, cur, buf) != PATRA_OK) {
            pg_free(buf);
            return PATRA_ERR_PAGE;
        }
        if (load64(buf + BY_TYPE) != PAGE_BYTES) {
            pg_free(buf);
            return PATRA_ERR_PAGE;
        }
        var chunk = load64(buf + BY_LEN);
        if (chunk < 0) { pg_free(buf); return PATRA_ERR_PAGE; }
        if (chunk > BY_DATA_MAX) { pg_free(buf); return PATRA_ERR_PAGE; }
        if (copied + chunk > len) { chunk = len - copied; }
        memcpy(out + copied, buf + BY_DATA, chunk);
        copied = copied + chunk;
        if (copied >= len) { cur = 0; }
        else { cur = load64(buf + BY_NEXT); }
    }

    pg_free(buf);
    if (copied != len) { return PATRA_ERR_PAGE; }
    return PATRA_OK;
}

# Free every page in the blob chain starting at `first_page`. Safe on a
# zero head (no-op). On a malformed chain it stops at the first bad hop
# and leaks the remainder — matches page_free_all's fail-safe behavior.
fn _bytes_free_chain(fd, hdr, first_page): i64 {
    if (first_page == 0) { return 0; }

    var buf = pg_alloc();
    var cur = first_page;

    while (cur != 0) {
        if (page_read_checked(fd, hdr, cur, buf) != PATRA_OK) {
            pg_free(buf);
            return PATRA_ERR_PAGE;
        }
        if (load64(buf + BY_TYPE) != PAGE_BYTES) {
            pg_free(buf);
            return PATRA_ERR_PAGE;
        }
        var nx = load64(buf + BY_NEXT);
        page_free(fd, hdr, cur);
        cur = nx;
    }

    pg_free(buf);
    return PATRA_OK;
}

# --- sql.cyr ---

# sql.cyr — SQL tokenizer and parser (v0.2: WHERE, ORDER BY, LIMIT, UPDATE, DELETE)

# ── Token types ────────────────────

enum TokType {
    TK_EOF = 0;
    TK_ERR = 1;
    TK_IDENT = 2;
    TK_INT_LIT = 3;
    TK_STR_LIT = 4;
    TK_LPAREN = 5;
    TK_RPAREN = 6;
    TK_COMMA = 7;
    TK_STAR = 8;
    TK_SEMI = 9;
    TK_CREATE = 10;
    TK_TABLE = 11;
    TK_INSERT = 12;
    TK_INTO = 13;
    TK_VALUES = 14;
    TK_SELECT = 15;
    TK_FROM = 16;
    TK_KW_INT = 17;
    TK_KW_STR = 18;
    TK_WHERE = 19;
    TK_AND = 20;
    TK_OR = 21;
    TK_UPDATE = 22;
    TK_SET = 23;
    TK_DELETE = 24;
    TK_ORDER = 25;
    TK_BY = 26;
    TK_LIMIT = 27;
    TK_ASC = 28;
    TK_DESC = 29;
    TK_EQ = 30;
    TK_NEQ = 31;
    TK_LT = 32;
    TK_GT = 33;
    TK_LTE = 34;
    TK_GTE = 35;
    TK_COUNT = 36;
    TK_SUM = 37;
    TK_MINF = 38;
    TK_MAXF = 39;
    TK_INDEX = 40;
    TK_ON = 41;
    TK_DROP = 42;
    TK_LIKE = 43;
    TK_VACUUM = 44;
    TK_ALTER = 45;
    TK_ADD = 46;
    TK_COLUMN = 47;
    TK_RENAME = 48;
    TK_TO = 49;
    TK_KW_BYTES = 50;
    TK_IGNORE = 51;
}

enum StmtType {
    STMT_NONE = 0;
    STMT_CREATE = 1;
    STMT_INSERT = 2;
    STMT_SELECT = 3;
    STMT_UPDATE = 4;
    STMT_DELETE = 5;
    STMT_CREATE_INDEX = 6;
    STMT_DROP = 7;
    STMT_VACUUM = 8;
    STMT_ALTER_ADD = 9;
    STMT_ALTER_RENAME_TBL = 10;
    STMT_ALTER_RENAME_COL = 11;
    STMT_ALTER_DROP_COL = 12;
}

enum AggType { AGG_NONE = 0; AGG_COUNT = 1; AGG_SUM = 2; AGG_MIN = 3; AGG_MAX = 4; }
enum AggOff { PR_AGG_TYPE = 768; PR_AGG_COL_PTR = 776; PR_AGG_COL_LEN = 784; }

# SELECT column-list projection item: 16 bytes (ptr, len). Stored in PR_ITEMS.
# PR_PROJ_N = 0 means SELECT * (or aggregate query).
enum SelOff { SEL_PTR = 0; SEL_LEN = 8; SEL_SZ = 16; PR_PROJ_N = 792; }

# Token layout: 24 bytes (type, ptr, len)
enum TokOff { TOK_TYPE = 0; TOK_PTR = 8; TOK_LEN = 16; TOK_SZ = 24; }
enum TokLim { MAX_TOKENS = 128; }

# ── Parse result layout ────────────────────

enum PROff {
    PR_STMT = 0;
    PR_TNAME = 8;
    PR_TNLEN = 16;
    PR_COUNT = 24;
    PR_WHERE_N = 32;
    PR_WHERE_JOIN = 40;
    PR_ORDERBY_N = 48;
    PR_LIMIT = 56;
    PR_INSERT_IGNORE = 64;
    PR_ITEMS = 72;
    PR_ORDERBY_COLS = 800;
    PR_WHERE = 1024;
}

# CREATE column item: 24 bytes
enum CROff { CR_NPTR = 0; CR_NLEN = 8; CR_TYPE = 16; CR_SZ = 24; }

# ORDER BY column: 24 bytes (ptr, len, dir)
enum ObOff { OB_PTR = 0; OB_LEN = 8; OB_DIR = 16; OB_SZ = 24; }
enum ObLim { OB_MAX = 8; }

# INSERT value item: 32 bytes
enum IROff { IR_TYPE = 0; IR_IVAL = 8; IR_SPTR = 16; IR_SLEN = 24; IR_SZ = 32; }

# UPDATE SET pair: 48 bytes
enum SetOff {
    SET_CPTR = 0;
    SET_CLEN = 8;
    SET_VTYPE = 16;
    SET_IVAL = 24;
    SET_SPTR = 32;
    SET_SLEN = 40;
    SET_SZ = 48;
}

# WHERE condition: 56 bytes
enum WhOff {
    WH_COL_PTR = 0;
    WH_COL_LEN = 8;
    WH_CMP_OP = 16;
    WH_VAL_TYPE = 24;
    WH_INT_VAL = 32;
    WH_STR_PTR = 40;
    WH_STR_LEN = 48;
    WH_ENTRY_SZ = 56;
}

# Comparison operators
enum CmpOp {
    CMP_EQ = 0;
    CMP_NEQ = 1;
    CMP_LT = 2;
    CMP_GT = 3;
    CMP_LTE = 4;
    CMP_GTE = 5;
    CMP_LIKE = 6;
}

# WHERE join type
enum WhJoin { WH_AND = 0; WH_OR = 1; }

# Hard cap on WHERE conditions per statement. `_sql_pr` is 4096 bytes;
# PR_WHERE starts at 1024 and entries are 56 bytes, so 32 conditions fit
# with headroom. Audit 2026-04-21 §2.10 — prevents heap corruption from
# attacker-supplied `WHERE a=1 AND a=1 AND ...` storms.
enum WhLim { WH_MAX = 32; }

# ── State ────────────────────

var _sql_toks = 0;
var _sql_ntoks = 0;
var _sql_pr = 0;

fn _sql_init(): i64 {
    _sql_toks = fl_alloc(MAX_TOKENS * TOK_SZ);
    _sql_pr = fl_alloc(4096);
}

# ── Token access ────────────────────

fn _tok_set(i, typ, ptr, len): i64 {
    var base = _sql_toks + i * TOK_SZ;
    store64(base + TOK_TYPE, typ);
    store64(base + TOK_PTR, ptr);
    store64(base + TOK_LEN, len);
}

fn _tok_type(i): i64 { return load64(_sql_toks + i * TOK_SZ + TOK_TYPE); }
fn _tok_ptr(i): i64 { return load64(_sql_toks + i * TOK_SZ + TOK_PTR); }
fn _tok_len(i): i64 { return load64(_sql_toks + i * TOK_SZ + TOK_LEN); }

# ── Character classification ────────────────────

fn _to_upper(c): i64 {
    if (c >= 97) { if (c <= 122) { return c - 32; } }
    return c;
}

fn _is_alpha(c): i64 {
    if (c >= 65) { if (c <= 90)  { return 1; } }
    if (c >= 97) { if (c <= 122) { return 1; } }
    if (c == 95) { return 1; }
    return 0;
}

fn _is_digit(c): i64 {
    if (c >= 48) { if (c <= 57) { return 1; } }
    return 0;
}

fn _is_alnum(c): i64 {
    if (_is_alpha(c)) { return 1; }
    return _is_digit(c);
}

fn _is_ws(c): i64 {
    if (c == 32) { return 1; }
    if (c == 9)  { return 1; }
    if (c == 10) { return 1; }
    if (c == 13) { return 1; }
    return 0;
}

# ── Keyword matching ───────────────────────

fn _kw_eq(ptr, len, kw): i64 {
    var kl = strlen(kw);
    if (len != kl) { return 0; }
    for (var i = 0; i < len; i = i + 1) {
        if (_to_upper(load8(ptr + i)) != load8(kw + i)) { return 0; }
    }
    return 1;
}

fn _classify_ident(ptr, len): i64 {
    if (_kw_eq(ptr, len, "CREATE")) { return TK_CREATE; }
    if (_kw_eq(ptr, len, "TABLE"))  { return TK_TABLE; }
    if (_kw_eq(ptr, len, "INSERT")) { return TK_INSERT; }
    if (_kw_eq(ptr, len, "INTO"))   { return TK_INTO; }
    if (_kw_eq(ptr, len, "VALUES")) { return TK_VALUES; }
    if (_kw_eq(ptr, len, "SELECT")) { return TK_SELECT; }
    if (_kw_eq(ptr, len, "FROM"))   { return TK_FROM; }
    if (_kw_eq(ptr, len, "INT"))    { return TK_KW_INT; }
    if (_kw_eq(ptr, len, "STR"))    { return TK_KW_STR; }
    # BYTES is the canonical column-type keyword. BLOB is accepted as a
    # case-insensitive alias so habitual "BLOB" spellings still parse.
    if (_kw_eq(ptr, len, "BYTES"))  { return TK_KW_BYTES; }
    if (_kw_eq(ptr, len, "BLOB"))   { return TK_KW_BYTES; }
    if (_kw_eq(ptr, len, "WHERE"))  { return TK_WHERE; }
    if (_kw_eq(ptr, len, "AND"))    { return TK_AND; }
    if (_kw_eq(ptr, len, "OR"))     { return TK_OR; }
    if (_kw_eq(ptr, len, "UPDATE")) { return TK_UPDATE; }
    if (_kw_eq(ptr, len, "SET"))    { return TK_SET; }
    if (_kw_eq(ptr, len, "DELETE")) { return TK_DELETE; }
    if (_kw_eq(ptr, len, "ORDER"))  { return TK_ORDER; }
    if (_kw_eq(ptr, len, "BY"))     { return TK_BY; }
    if (_kw_eq(ptr, len, "LIMIT"))  { return TK_LIMIT; }
    if (_kw_eq(ptr, len, "ASC"))    { return TK_ASC; }
    if (_kw_eq(ptr, len, "DESC"))   { return TK_DESC; }
    if (_kw_eq(ptr, len, "COUNT")) { return TK_COUNT; }
    if (_kw_eq(ptr, len, "SUM"))   { return TK_SUM; }
    if (_kw_eq(ptr, len, "MIN"))   { return TK_MINF; }
    if (_kw_eq(ptr, len, "MAX"))   { return TK_MAXF; }
    if (_kw_eq(ptr, len, "INDEX")) { return TK_INDEX; }
    if (_kw_eq(ptr, len, "ON"))    { return TK_ON; }
    if (_kw_eq(ptr, len, "DROP"))  { return TK_DROP; }
    if (_kw_eq(ptr, len, "LIKE"))  { return TK_LIKE; }
    if (_kw_eq(ptr, len, "VACUUM")) { return TK_VACUUM; }
    if (_kw_eq(ptr, len, "ALTER"))  { return TK_ALTER; }
    if (_kw_eq(ptr, len, "ADD"))    { return TK_ADD; }
    if (_kw_eq(ptr, len, "COLUMN")) { return TK_COLUMN; }
    if (_kw_eq(ptr, len, "RENAME")) { return TK_RENAME; }
    if (_kw_eq(ptr, len, "TO"))     { return TK_TO; }
    if (_kw_eq(ptr, len, "IGNORE")) { return TK_IGNORE; }
    return TK_IDENT;
}

# ── Tokenizer ────────────────────

# Tokenize SQL string into token array
fn sql_tokenize(input): i64 {
    var pos = 0;
    var n = 0;
    var slen = strlen(input);

    while (pos < slen) {
        if (n >= MAX_TOKENS - 1) { break; }
        var c = load8(input + pos);

        if (_is_ws(c)) { pos = pos + 1; continue; }

        # Identifier or keyword
        if (_is_alpha(c)) {
            var start = pos;
            while (pos < slen) {
                if (_is_alnum(load8(input + pos)) == 0) { break; }
                pos = pos + 1;
            }
            var len = pos - start;
            _tok_set(n, _classify_ident(input + start, len), input + start, len);
            n = n + 1;
            continue;
        }

        # Integer literal
        if (_is_digit(c)) {
            var start = pos;
            while (pos < slen) {
                if (_is_digit(load8(input + pos)) == 0) { break; }
                pos = pos + 1;
            }
            _tok_set(n, TK_INT_LIT, input + start, pos - start);
            n = n + 1;
            continue;
        }

        # String literal: 'content'
        if (c == 39) {
            pos = pos + 1;
            var start = pos;
            while (pos < slen) {
                if (load8(input + pos) == 39) { break; }
                pos = pos + 1;
            }
            _tok_set(n, TK_STR_LIT, input + start, pos - start);
            if (pos < slen) { pos = pos + 1; }
            n = n + 1;
            continue;
        }

        # Multi-char operators: != <= >=
        if (c == 33) {
            if (pos + 1 < slen) {
                if (load8(input + pos + 1) == 61) {
                    _tok_set(n, TK_NEQ, input + pos, 2);
                    n = n + 1;
                    pos = pos + 2;
                    continue;
                }
            }
            _tok_set(n, TK_ERR, input + pos, 1);
            n = n + 1;
            pos = pos + 1;
            continue;
        }

        if (c == 60) {
            if (pos + 1 < slen) {
                if (load8(input + pos + 1) == 61) {
                    _tok_set(n, TK_LTE, input + pos, 2);
                    n = n + 1;
                    pos = pos + 2;
                    continue;
                }
            }
            _tok_set(n, TK_LT, input + pos, 1);
            n = n + 1;
            pos = pos + 1;
            continue;
        }

        if (c == 62) {
            if (pos + 1 < slen) {
                if (load8(input + pos + 1) == 61) {
                    _tok_set(n, TK_GTE, input + pos, 2);
                    n = n + 1;
                    pos = pos + 2;
                    continue;
                }
            }
            _tok_set(n, TK_GT, input + pos, 1);
            n = n + 1;
            pos = pos + 1;
            continue;
        }

        # Single-char tokens
        if (c == 61) { _tok_set(n, TK_EQ, input + pos, 1); }
        elif (c == 40) { _tok_set(n, TK_LPAREN, input + pos, 1); }
        elif (c == 41) { _tok_set(n, TK_RPAREN, input + pos, 1); }
        elif (c == 44) { _tok_set(n, TK_COMMA, input + pos, 1); }
        elif (c == 42) { _tok_set(n, TK_STAR, input + pos, 1); }
        elif (c == 59) { _tok_set(n, TK_SEMI, input + pos, 1); }
        else { _tok_set(n, TK_ERR, input + pos, 1); }
        n = n + 1;
        pos = pos + 1;
    }

    _tok_set(n, TK_EOF, 0, 0);
    _sql_ntoks = n;
    return n;
}

# ── Helpers ────────────────────

fn _pt_atoi(ptr, len): i64 {
    var r = 0;
    for (var i = 0; i < len; i = i + 1) {
        r = r * 10 + (load8(ptr + i) - 48);
    }
    return r;
}

fn _tok_to_cmpop(pos): i64 {
    var tt = _tok_type(pos);
    if (tt == TK_EQ)  { return CMP_EQ; }
    if (tt == TK_NEQ) { return CMP_NEQ; }
    if (tt == TK_LT)  { return CMP_LT; }
    if (tt == TK_GT)  { return CMP_GT; }
    if (tt == TK_LTE) { return CMP_LTE; }
    if (tt == TK_GTE) { return CMP_GTE; }
    if (tt == TK_LIKE) { return CMP_LIKE; }
    return 0 - 1;
}

# ── WHERE parser (shared by SELECT, UPDATE, DELETE) ─────────

fn _parse_where(pos): i64 {
    if (_tok_type(pos) != TK_WHERE) { return pos; }
    pos = pos + 1;

    var count = 0;
    var join = 0 - 1;

    while (pos <= _sql_ntoks) {
        var tt = _tok_type(pos);
        if (tt == TK_EOF)   { break; }
        if (tt == TK_ORDER) { break; }
        if (tt == TK_LIMIT) { break; }
        if (tt == TK_SEMI)  { break; }

        # col
        if (tt != TK_IDENT) { return 0 - 1; }
        # Audit 2026-04-21 §2.10: cap condition count before writing
        if (count >= WH_MAX) { return 0 - 1; }
        var cond = _sql_pr + PR_WHERE + count * WH_ENTRY_SZ;
        store64(cond + WH_COL_PTR, _tok_ptr(pos));
        store64(cond + WH_COL_LEN, _tok_len(pos));
        pos = pos + 1;

        # operator
        var op = _tok_to_cmpop(pos);
        if (op < 0) { return 0 - 1; }
        store64(cond + WH_CMP_OP, op);
        pos = pos + 1;

        # value
        tt = _tok_type(pos);
        if (tt == TK_INT_LIT) {
            store64(cond + WH_VAL_TYPE, COL_INT);
            store64(cond + WH_INT_VAL, _pt_atoi(_tok_ptr(pos), _tok_len(pos)));
        } elif (tt == TK_STR_LIT) {
            store64(cond + WH_VAL_TYPE, COL_STR);
            store64(cond + WH_STR_PTR, _tok_ptr(pos));
            store64(cond + WH_STR_LEN, _tok_len(pos));
        } else {
            return 0 - 1;
        }
        pos = pos + 1;
        count = count + 1;

        # AND / OR
        tt = _tok_type(pos);
        if (tt == TK_AND) {
            if (join == (0 - 1)) { join = WH_AND; }
            elif (join != WH_AND) { return 0 - 1; }
            pos = pos + 1;
        } elif (tt == TK_OR) {
            if (join == (0 - 1)) { join = WH_OR; }
            elif (join != WH_OR) { return 0 - 1; }
            pos = pos + 1;
        } else {
            break;
        }
    }

    # WHERE with no conditions is malformed
    if (count == 0) { return 0 - 1; }
    store64(_sql_pr + PR_WHERE_N, count);
    if (join == (0 - 1)) { join = WH_AND; }
    store64(_sql_pr + PR_WHERE_JOIN, join);
    return pos;
}

# ── Parsers ────────────────────

fn _parse_create(): i64 {
    var pos = 0;
    if (_tok_type(pos) != TK_CREATE) { return PATRA_ERR_SYNTAX; }
    pos = pos + 1;
    if (_tok_type(pos) != TK_TABLE)  { return PATRA_ERR_SYNTAX; }
    pos = pos + 1;
    if (_tok_type(pos) != TK_IDENT)  { return PATRA_ERR_SYNTAX; }

    store64(_sql_pr + PR_STMT, STMT_CREATE);
    store64(_sql_pr + PR_TNAME, _tok_ptr(pos));
    store64(_sql_pr + PR_TNLEN, _tok_len(pos));
    pos = pos + 1;

    if (_tok_type(pos) != TK_LPAREN) { return PATRA_ERR_SYNTAX; }
    pos = pos + 1;

    var ncols = 0;
    while (pos <= _sql_ntoks) {
        var tt = _tok_type(pos);
        if (tt == TK_EOF)    { return PATRA_ERR_SYNTAX; }
        if (tt == TK_RPAREN) { pos = pos + 1; break; }
        if (ncols >= MAX_COLS) { return PATRA_ERR_COLCOUNT; }

        if (_tok_type(pos) != TK_IDENT) { return PATRA_ERR_SYNTAX; }
        var item = _sql_pr + PR_ITEMS + ncols * CR_SZ;
        store64(item + CR_NPTR, _tok_ptr(pos));
        store64(item + CR_NLEN, _tok_len(pos));
        pos = pos + 1;

        tt = _tok_type(pos);
        if (tt == TK_KW_INT)       { store64(item + CR_TYPE, COL_INT); }
        elif (tt == TK_KW_STR)     { store64(item + CR_TYPE, COL_STR); }
        elif (tt == TK_KW_BYTES)    { store64(item + CR_TYPE, COL_BYTES); }
        else { return PATRA_ERR_SYNTAX; }
        pos = pos + 1;

        if (_tok_type(pos) == TK_COMMA) { pos = pos + 1; }
        ncols = ncols + 1;
    }

    store64(_sql_pr + PR_COUNT, ncols);
    return PATRA_OK;
}

fn _parse_insert(): i64 {
    var pos = 0;
    if (_tok_type(pos) != TK_INSERT) { return PATRA_ERR_SYNTAX; }
    pos = pos + 1;
    # Optional `OR IGNORE` between INSERT and INTO. Skip the conflicting row
    # silently if the indexed column already holds the inserted key.
    if (_tok_type(pos) == TK_OR) {
        pos = pos + 1;
        if (_tok_type(pos) != TK_IGNORE) { return PATRA_ERR_SYNTAX; }
        pos = pos + 1;
        store64(_sql_pr + PR_INSERT_IGNORE, 1);
    }
    if (_tok_type(pos) != TK_INTO)   { return PATRA_ERR_SYNTAX; }
    pos = pos + 1;
    if (_tok_type(pos) != TK_IDENT)  { return PATRA_ERR_SYNTAX; }

    store64(_sql_pr + PR_STMT, STMT_INSERT);
    store64(_sql_pr + PR_TNAME, _tok_ptr(pos));
    store64(_sql_pr + PR_TNLEN, _tok_len(pos));
    pos = pos + 1;

    if (_tok_type(pos) != TK_VALUES) { return PATRA_ERR_SYNTAX; }
    pos = pos + 1;
    if (_tok_type(pos) != TK_LPAREN) { return PATRA_ERR_SYNTAX; }
    pos = pos + 1;

    var nvals = 0;
    while (pos <= _sql_ntoks) {
        var tt = _tok_type(pos);
        if (tt == TK_EOF)    { return PATRA_ERR_SYNTAX; }
        if (tt == TK_RPAREN) { pos = pos + 1; break; }
        # Audit 2026-04-21 §2.5: cap before writing to PR_ITEMS slot
        if (nvals >= MAX_COLS) { return PATRA_ERR_COLCOUNT; }

        var item = _sql_pr + PR_ITEMS + nvals * IR_SZ;

        if (tt == TK_INT_LIT) {
            store64(item + IR_TYPE, COL_INT);
            store64(item + IR_IVAL, _pt_atoi(_tok_ptr(pos), _tok_len(pos)));
        } elif (tt == TK_STR_LIT) {
            store64(item + IR_TYPE, COL_STR);
            store64(item + IR_SPTR, _tok_ptr(pos));
            store64(item + IR_SLEN, _tok_len(pos));
        } else {
            return PATRA_ERR_SYNTAX;
        }
        pos = pos + 1;

        if (_tok_type(pos) == TK_COMMA) { pos = pos + 1; }
        nvals = nvals + 1;
    }

    store64(_sql_pr + PR_COUNT, nvals);
    return PATRA_OK;
}

fn _parse_select(): i64 {
    # SELECT * | agg(col) FROM tbl [WHERE] [ORDER BY] [LIMIT]
    var pos = 0;
    if (_tok_type(pos) != TK_SELECT) { return PATRA_ERR_SYNTAX; }
    pos = pos + 1;

    # Check for aggregate function or *
    var tt = _tok_type(pos);
    if (tt == TK_COUNT) {
        store64(_sql_pr + PR_AGG_TYPE, AGG_COUNT);
        pos = pos + 1;
        if (_tok_type(pos) != TK_LPAREN) { return PATRA_ERR_SYNTAX; }
        pos = pos + 1;
        if (_tok_type(pos) != TK_STAR) { return PATRA_ERR_SYNTAX; }
        pos = pos + 1;
        if (_tok_type(pos) != TK_RPAREN) { return PATRA_ERR_SYNTAX; }
        pos = pos + 1;
    } elif (tt == TK_SUM) {
        store64(_sql_pr + PR_AGG_TYPE, AGG_SUM);
        pos = pos + 1;
        if (_tok_type(pos) != TK_LPAREN) { return PATRA_ERR_SYNTAX; }
        pos = pos + 1;
        if (_tok_type(pos) != TK_IDENT) { return PATRA_ERR_SYNTAX; }
        store64(_sql_pr + PR_AGG_COL_PTR, _tok_ptr(pos));
        store64(_sql_pr + PR_AGG_COL_LEN, _tok_len(pos));
        pos = pos + 1;
        if (_tok_type(pos) != TK_RPAREN) { return PATRA_ERR_SYNTAX; }
        pos = pos + 1;
    } elif (tt == TK_MINF) {
        store64(_sql_pr + PR_AGG_TYPE, AGG_MIN);
        pos = pos + 1;
        if (_tok_type(pos) != TK_LPAREN) { return PATRA_ERR_SYNTAX; }
        pos = pos + 1;
        if (_tok_type(pos) != TK_IDENT) { return PATRA_ERR_SYNTAX; }
        store64(_sql_pr + PR_AGG_COL_PTR, _tok_ptr(pos));
        store64(_sql_pr + PR_AGG_COL_LEN, _tok_len(pos));
        pos = pos + 1;
        if (_tok_type(pos) != TK_RPAREN) { return PATRA_ERR_SYNTAX; }
        pos = pos + 1;
    } elif (tt == TK_MAXF) {
        store64(_sql_pr + PR_AGG_TYPE, AGG_MAX);
        pos = pos + 1;
        if (_tok_type(pos) != TK_LPAREN) { return PATRA_ERR_SYNTAX; }
        pos = pos + 1;
        if (_tok_type(pos) != TK_IDENT) { return PATRA_ERR_SYNTAX; }
        store64(_sql_pr + PR_AGG_COL_PTR, _tok_ptr(pos));
        store64(_sql_pr + PR_AGG_COL_LEN, _tok_len(pos));
        pos = pos + 1;
        if (_tok_type(pos) != TK_RPAREN) { return PATRA_ERR_SYNTAX; }
        pos = pos + 1;
    } elif (tt == TK_STAR) {
        pos = pos + 1;
    } elif (tt == TK_IDENT) {
        # Column-list projection: col1 [, col2 ...]
        var pn = 0;
        var pdone = 0;
        while (pdone == 0) {
            if (_tok_type(pos) != TK_IDENT) { return PATRA_ERR_SYNTAX; }
            if (pn >= MAX_COLS) { return PATRA_ERR_COLCOUNT; }
            var pitem = _sql_pr + PR_ITEMS + pn * SEL_SZ;
            store64(pitem + SEL_PTR, _tok_ptr(pos));
            store64(pitem + SEL_LEN, _tok_len(pos));
            pos = pos + 1;
            pn = pn + 1;
            if (_tok_type(pos) == TK_COMMA) { pos = pos + 1; }
            else { pdone = 1; }
        }
        store64(_sql_pr + PR_PROJ_N, pn);
    } else {
        return PATRA_ERR_SYNTAX;
    }

    if (_tok_type(pos) != TK_FROM)   { return PATRA_ERR_SYNTAX; }
    pos = pos + 1;
    if (_tok_type(pos) != TK_IDENT)  { return PATRA_ERR_SYNTAX; }

    store64(_sql_pr + PR_STMT, STMT_SELECT);
    store64(_sql_pr + PR_TNAME, _tok_ptr(pos));
    store64(_sql_pr + PR_TNLEN, _tok_len(pos));
    pos = pos + 1;

    # Optional WHERE
    pos = _parse_where(pos);
    if (pos < 0) { return PATRA_ERR_SYNTAX; }

    # Optional ORDER BY col [ASC|DESC] [, col [ASC|DESC] ...]
    if (_tok_type(pos) == TK_ORDER) {
        pos = pos + 1;
        if (_tok_type(pos) != TK_BY) { return PATRA_ERR_SYNTAX; }
        pos = pos + 1;
        var obn = 0;
        var ob_done = 0;
        while (ob_done == 0) {
            if (_tok_type(pos) != TK_IDENT) { return PATRA_ERR_SYNTAX; }
            if (obn >= OB_MAX) { return PATRA_ERR_SYNTAX; }
            var ob = _sql_pr + PR_ORDERBY_COLS + obn * OB_SZ;
            store64(ob + OB_PTR, _tok_ptr(pos));
            store64(ob + OB_LEN, _tok_len(pos));
            pos = pos + 1;
            if (_tok_type(pos) == TK_DESC) {
                store64(ob + OB_DIR, 1);
                pos = pos + 1;
            } elif (_tok_type(pos) == TK_ASC) {
                pos = pos + 1;
            }
            obn = obn + 1;
            if (_tok_type(pos) == TK_COMMA) { pos = pos + 1; }
            else { ob_done = 1; }
        }
        store64(_sql_pr + PR_ORDERBY_N, obn);
    }

    # Optional LIMIT
    if (_tok_type(pos) == TK_LIMIT) {
        pos = pos + 1;
        if (_tok_type(pos) != TK_INT_LIT) { return PATRA_ERR_SYNTAX; }
        store64(_sql_pr + PR_LIMIT, _pt_atoi(_tok_ptr(pos), _tok_len(pos)));
        pos = pos + 1;
    }

    return PATRA_OK;
}

fn _parse_update(): i64 {
    # UPDATE table SET col = val [, ...] [WHERE ...]
    var pos = 0;
    if (_tok_type(pos) != TK_UPDATE) { return PATRA_ERR_SYNTAX; }
    pos = pos + 1;
    if (_tok_type(pos) != TK_IDENT)  { return PATRA_ERR_SYNTAX; }

    store64(_sql_pr + PR_STMT, STMT_UPDATE);
    store64(_sql_pr + PR_TNAME, _tok_ptr(pos));
    store64(_sql_pr + PR_TNLEN, _tok_len(pos));
    pos = pos + 1;

    if (_tok_type(pos) != TK_SET) { return PATRA_ERR_SYNTAX; }
    pos = pos + 1;

    var nsets = 0;
    var sdone = 0;
    while (sdone == 0) {
        if (pos > _sql_ntoks) { sdone = 1; continue; }
        var stt = _tok_type(pos);
        if (stt == TK_EOF)   { sdone = 1; continue; }
        if (stt == TK_WHERE) { sdone = 1; continue; }
        if (stt == TK_SEMI)  { sdone = 1; continue; }

        if (stt != TK_IDENT) { return PATRA_ERR_SYNTAX; }
        var item = _sql_pr + PR_ITEMS + nsets * SET_SZ;
        store64(item + SET_CPTR, _tok_ptr(pos));
        store64(item + SET_CLEN, _tok_len(pos));
        pos = pos + 1;

        if (_tok_type(pos) != TK_EQ) { return PATRA_ERR_SYNTAX; }
        pos = pos + 1;

        stt = _tok_type(pos);
        if (stt == TK_INT_LIT) {
            store64(item + SET_VTYPE, COL_INT);
            store64(item + SET_IVAL, _pt_atoi(_tok_ptr(pos), _tok_len(pos)));
        } elif (stt == TK_STR_LIT) {
            store64(item + SET_VTYPE, COL_STR);
            store64(item + SET_SPTR, _tok_ptr(pos));
            store64(item + SET_SLEN, _tok_len(pos));
        } else {
            return PATRA_ERR_SYNTAX;
        }
        pos = pos + 1;
        nsets = nsets + 1;

        if (_tok_type(pos) == TK_COMMA) { pos = pos + 1; }
    }

    if (nsets == 0) { return PATRA_ERR_SYNTAX; }
    store64(_sql_pr + PR_COUNT, nsets);

    pos = _parse_where(pos);
    if (pos < 0) { return PATRA_ERR_SYNTAX; }
    return PATRA_OK;
}

fn _parse_delete(): i64 {
    # DELETE FROM table [WHERE ...]
    var pos = 0;
    if (_tok_type(pos) != TK_DELETE) { return PATRA_ERR_SYNTAX; }
    pos = pos + 1;
    if (_tok_type(pos) != TK_FROM)   { return PATRA_ERR_SYNTAX; }
    pos = pos + 1;
    if (_tok_type(pos) != TK_IDENT)  { return PATRA_ERR_SYNTAX; }

    store64(_sql_pr + PR_STMT, STMT_DELETE);
    store64(_sql_pr + PR_TNAME, _tok_ptr(pos));
    store64(_sql_pr + PR_TNLEN, _tok_len(pos));
    pos = pos + 1;

    pos = _parse_where(pos);
    if (pos < 0) { return PATRA_ERR_SYNTAX; }
    return PATRA_OK;
}

fn _parse_create_index(): i64 {
    # CREATE INDEX ON table (col)
    var pos = 0;
    if (_tok_type(pos) != TK_CREATE) { return PATRA_ERR_SYNTAX; }
    pos = pos + 1;
    if (_tok_type(pos) != TK_INDEX) { return PATRA_ERR_SYNTAX; }
    pos = pos + 1;
    if (_tok_type(pos) != TK_ON) { return PATRA_ERR_SYNTAX; }
    pos = pos + 1;
    if (_tok_type(pos) != TK_IDENT) { return PATRA_ERR_SYNTAX; }
    store64(_sql_pr + PR_STMT, STMT_CREATE_INDEX);
    store64(_sql_pr + PR_TNAME, _tok_ptr(pos));
    store64(_sql_pr + PR_TNLEN, _tok_len(pos));
    pos = pos + 1;
    if (_tok_type(pos) != TK_LPAREN) { return PATRA_ERR_SYNTAX; }
    pos = pos + 1;
    if (_tok_type(pos) != TK_IDENT) { return PATRA_ERR_SYNTAX; }
    # Store column name in first item slot
    store64(_sql_pr + PR_ITEMS, _tok_ptr(pos));
    store64(_sql_pr + PR_ITEMS + 8, _tok_len(pos));
    pos = pos + 1;
    if (_tok_type(pos) != TK_RPAREN) { return PATRA_ERR_SYNTAX; }
    return PATRA_OK;
}

fn _parse_drop(): i64 {
    # DROP TABLE name
    var pos = 0;
    if (_tok_type(pos) != TK_DROP) { return PATRA_ERR_SYNTAX; }
    pos = pos + 1;
    if (_tok_type(pos) != TK_TABLE) { return PATRA_ERR_SYNTAX; }
    pos = pos + 1;
    if (_tok_type(pos) != TK_IDENT) { return PATRA_ERR_SYNTAX; }
    store64(_sql_pr + PR_STMT, STMT_DROP);
    store64(_sql_pr + PR_TNAME, _tok_ptr(pos));
    store64(_sql_pr + PR_TNLEN, _tok_len(pos));
    return PATRA_OK;
}

fn _parse_alter(): i64 {
    # ALTER TABLE t ADD COLUMN name INT|STR
    # ALTER TABLE t RENAME TO new_name
    # ALTER TABLE t RENAME COLUMN old TO new
    var pos = 0;
    if (_tok_type(pos) != TK_ALTER) { return PATRA_ERR_SYNTAX; }
    pos = pos + 1;
    if (_tok_type(pos) != TK_TABLE) { return PATRA_ERR_SYNTAX; }
    pos = pos + 1;
    if (_tok_type(pos) != TK_IDENT) { return PATRA_ERR_SYNTAX; }
    store64(_sql_pr + PR_TNAME, _tok_ptr(pos));
    store64(_sql_pr + PR_TNLEN, _tok_len(pos));
    pos = pos + 1;

    var nxt = _tok_type(pos);
    if (nxt == TK_ADD) {
        pos = pos + 1;
        if (_tok_type(pos) != TK_COLUMN) { return PATRA_ERR_SYNTAX; }
        pos = pos + 1;
        if (_tok_type(pos) != TK_IDENT) { return PATRA_ERR_SYNTAX; }
        var item = _sql_pr + PR_ITEMS;
        store64(item + CR_NPTR, _tok_ptr(pos));
        store64(item + CR_NLEN, _tok_len(pos));
        pos = pos + 1;
        var tt = _tok_type(pos);
        if (tt == TK_KW_INT)    { store64(item + CR_TYPE, COL_INT); }
        elif (tt == TK_KW_STR)  { store64(item + CR_TYPE, COL_STR); }
        elif (tt == TK_KW_BYTES) { store64(item + CR_TYPE, COL_BYTES); }
        else { return PATRA_ERR_SYNTAX; }
        store64(_sql_pr + PR_STMT, STMT_ALTER_ADD);
        return PATRA_OK;
    }
    if (nxt == TK_DROP) {
        pos = pos + 1;
        if (_tok_type(pos) != TK_COLUMN) { return PATRA_ERR_SYNTAX; }
        pos = pos + 1;
        if (_tok_type(pos) != TK_IDENT) { return PATRA_ERR_SYNTAX; }
        var itemd = _sql_pr + PR_ITEMS;
        store64(itemd + CR_NPTR, _tok_ptr(pos));
        store64(itemd + CR_NLEN, _tok_len(pos));
        store64(_sql_pr + PR_STMT, STMT_ALTER_DROP_COL);
        return PATRA_OK;
    }
    if (nxt == TK_RENAME) {
        pos = pos + 1;
        var rt = _tok_type(pos);
        if (rt == TK_TO) {
            pos = pos + 1;
            if (_tok_type(pos) != TK_IDENT) { return PATRA_ERR_SYNTAX; }
            var item2 = _sql_pr + PR_ITEMS;
            store64(item2 + CR_NPTR, _tok_ptr(pos));
            store64(item2 + CR_NLEN, _tok_len(pos));
            store64(_sql_pr + PR_STMT, STMT_ALTER_RENAME_TBL);
            return PATRA_OK;
        }
        if (rt == TK_COLUMN) {
            pos = pos + 1;
            if (_tok_type(pos) != TK_IDENT) { return PATRA_ERR_SYNTAX; }
            var item3 = _sql_pr + PR_ITEMS;
            store64(item3 + CR_NPTR, _tok_ptr(pos));
            store64(item3 + CR_NLEN, _tok_len(pos));
            pos = pos + 1;
            if (_tok_type(pos) != TK_TO) { return PATRA_ERR_SYNTAX; }
            pos = pos + 1;
            if (_tok_type(pos) != TK_IDENT) { return PATRA_ERR_SYNTAX; }
            var item4 = _sql_pr + PR_ITEMS + CR_SZ;
            store64(item4 + CR_NPTR, _tok_ptr(pos));
            store64(item4 + CR_NLEN, _tok_len(pos));
            store64(_sql_pr + PR_STMT, STMT_ALTER_RENAME_COL);
            return PATRA_OK;
        }
        return PATRA_ERR_SYNTAX;
    }
    return PATRA_ERR_SYNTAX;
}

fn _parse_vacuum(): i64 {
    # VACUUM tblname — reclaim B-tree tombstones for a table
    var pos = 0;
    if (_tok_type(pos) != TK_VACUUM) { return PATRA_ERR_SYNTAX; }
    pos = pos + 1;
    if (_tok_type(pos) != TK_IDENT) { return PATRA_ERR_SYNTAX; }
    store64(_sql_pr + PR_STMT, STMT_VACUUM);
    store64(_sql_pr + PR_TNAME, _tok_ptr(pos));
    store64(_sql_pr + PR_TNLEN, _tok_len(pos));
    return PATRA_OK;
}

# Parse tokenized SQL into parse result
fn sql_parse(): i64 {
    memset(_sql_pr, 0, 4096);
    var tt = _tok_type(0);
    if (tt == TK_CREATE) {
        if (_tok_type(1) == TK_INDEX) { return _parse_create_index(); }
        return _parse_create();
    }
    if (tt == TK_INSERT) { return _parse_insert(); }
    if (tt == TK_SELECT) { return _parse_select(); }
    if (tt == TK_UPDATE) { return _parse_update(); }
    if (tt == TK_DELETE) { return _parse_delete(); }
    if (tt == TK_DROP)   { return _parse_drop(); }
    if (tt == TK_VACUUM) { return _parse_vacuum(); }
    if (tt == TK_ALTER)  { return _parse_alter(); }
    return PATRA_ERR_SYNTAX;
}

# --- where.cyr ---

# where.cyr — WHERE clause evaluation

# Resolve column name to index in schema. Returns -1 if not found.
fn _wh_resolve_col(schema, ncols, name, nlen): i64 {
    for (var i = 0; i < ncols; i = i + 1) {
        var cname = schema + SCH_START + i * SCH_ENTRY_SZ + SCH_CNAME;
        if (strlen(cname) == nlen) {
            if (memeq(cname, name, nlen)) { return i; }
        }
    }
    return 0 - 1;
}

# Compare two integers with given operator
fn _cmp_int(a, b, op): i64 {
    if (op == CMP_EQ)  { if (a == b) { return 1; } return 0; }
    if (op == CMP_NEQ) { if (a != b) { return 1; } return 0; }
    if (op == CMP_LT)  { if (a < b)  { return 1; } return 0; }
    if (op == CMP_GT)  { if (a > b)  { return 1; } return 0; }
    if (op == CMP_LTE) { if (a <= b) { return 1; } return 0; }
    if (op == CMP_GTE) { if (a >= b) { return 1; } return 0; }
    return 0;
}

# Compare null-terminated string against ptr+len for equality
fn _streq_pl(ns, ptr, len): i64 {
    if (strlen(ns) != len) { return 0; }
    return memeq(ns, ptr, len);
}

# Lexicographic compare: null-terminated vs ptr+len. Returns <0, 0, >0.
fn _strcmp_pl(ns, ptr, len): i64 {
    var slen = strlen(ns);
    var min = slen;
    if (len < min) { min = len; }
    for (var i = 0; i < min; i = i + 1) {
        var a = load8(ns + i);
        var b = load8(ptr + i);
        if (a != b) { return a - b; }
    }
    return slen - len;
}

# SQL LIKE: `%` matches zero or more chars, `_` matches exactly one.
# Iterative backtracking on the last `%` seen. row_str is null-terminated;
# pat is ptr+len (from a SQL string literal, not null-terminated).
fn _like_match(row_str, pat_ptr, pat_len): i64 {
    var slen = strlen(row_str);
    var si = 0;
    var pi = 0;
    var star_s = 0 - 1;
    var star_p = 0 - 1;
    var done = 0;
    var matched = 0;

    while (done == 0) {
        if (si >= slen) {
            # String consumed — pattern must be only trailing %'s
            var tail_ok = 1;
            var ti = pi;
            while (ti < pat_len) {
                if (load8(pat_ptr + ti) != 37) { tail_ok = 0; ti = pat_len; continue; }
                ti = ti + 1;
            }
            matched = tail_ok;
            done = 1;
            continue;
        }
        if (pi < pat_len) {
            var pc = load8(pat_ptr + pi);
            if (pc == 37) {
                # '%' — record backtrack point, advance pattern
                star_p = pi;
                star_s = si;
                pi = pi + 1;
                continue;
            }
            if (pc == 95) {
                # '_' — match any single char
                si = si + 1;
                pi = pi + 1;
                continue;
            }
            if (pc == load8(row_str + si)) {
                si = si + 1;
                pi = pi + 1;
                continue;
            }
        }
        # Mismatch or pattern exhausted with string remaining — backtrack
        if (star_p >= 0) {
            star_s = star_s + 1;
            si = star_s;
            pi = star_p + 1;
            continue;
        }
        matched = 0;
        done = 1;
    }
    return matched;
}

# Compare string column value against WHERE condition value
fn _cmp_str(row_str, cmp_ptr, cmp_len, op): i64 {
    if (op == CMP_EQ)  { return _streq_pl(row_str, cmp_ptr, cmp_len); }
    if (op == CMP_NEQ) { if (_streq_pl(row_str, cmp_ptr, cmp_len)) { return 0; } return 1; }
    if (op == CMP_LIKE) { return _like_match(row_str, cmp_ptr, cmp_len); }
    var c = _strcmp_pl(row_str, cmp_ptr, cmp_len);
    if (op == CMP_LT)  { if (c < 0)  { return 1; } return 0; }
    if (op == CMP_GT)  { if (c > 0)  { return 1; } return 0; }
    if (op == CMP_LTE) { if (c <= 0) { return 1; } return 0; }
    if (op == CMP_GTE) { if (c >= 0) { return 1; } return 0; }
    return 0;
}

# Evaluate WHERE conditions against a single row.
# Returns 1 if row matches, 0 if not.
# pr = parse result buffer (_sql_pr).
# Evaluate WHERE conditions against a row (1=match, 0=no)
fn where_eval(row, schema, ncols, pr): i64 {
    var wcount = load64(pr + PR_WHERE_N);
    if (wcount == 0) { return 1; }

    var join = load64(pr + PR_WHERE_JOIN);
    # AND: start true, any false → false
    # OR:  start false, any true → true
    var result = 0;
    if (join == WH_AND) { result = 1; }

    for (var i = 0; i < wcount; i = i + 1) {
        var cond = pr + PR_WHERE + i * WH_ENTRY_SZ;
        var col_idx = _wh_resolve_col(schema, ncols,
        load64(cond + WH_COL_PTR), load64(cond + WH_COL_LEN));
        if (col_idx < 0) {
            if (join == WH_AND) { result = 0; }
            continue;
        }

        var col_type = load64(schema + SCH_START + col_idx * SCH_ENTRY_SZ + SCH_CTYPE);
        var val_type = load64(cond + WH_VAL_TYPE);
        var off = row_field_offset(schema, ncols, col_idx);
        var cmp = load64(cond + WH_CMP_OP);
        var hit = 0;

        if (col_type == COL_INT) {
            if (val_type == COL_INT) {
                hit = _cmp_int(row_read_int(row, off), load64(cond + WH_INT_VAL), cmp);
            }
        } elif (col_type == COL_STR) {
            if (val_type == COL_STR) {
                hit = _cmp_str(row_read_str(row, off),
                load64(cond + WH_STR_PTR), load64(cond + WH_STR_LEN), cmp);
            }
        }
        # COL_BYTES: WHERE never matches — variable-length binary isn't
        # comparable via = / LIKE / ordered ops. Filter in application code.

        if (join == WH_AND) {
            if (hit == 0) { result = 0; }
        } else {
            if (hit != 0) { result = 1; }
        }
    }

    return result;
}

# --- btree.cyr ---

# btree.cyr — B+ tree index (order 64, keys are i64)

enum BtConst {
    BTREE_ORDER = 64;
    BT_MAX_KEYS = 63;
    BT_MAX_DEPTH = 10;
}

enum BtOff {
    BT_TYPE = 0;
    BT_LEAF = 8;
    BT_NKEYS = 16;
    BT_KEYS = 24;
    BT_VALS = 528;
}
# Keys: 63 × 8 = 504 bytes at offset 24–527
# Vals:  leaf: 63 × 8 = 504 bytes at 528–1031
#        int:  64 × 8 = 512 bytes at 528–1039

# Schema page index info
enum SchIdx {
    SCH_IDX_COL = 4080;
    SCH_IDX_ROOT = 4088;
}

# Row reference encoding: page * 65536 + slot
fn _bt_mkref(pg, slot): i64 { return pg * 65536 + slot; }
fn _bt_ref_pg(ref): i64 { return ref / 65536; }
fn _bt_ref_slot(ref): i64 { return ref % 65536; }

# Path stack for insert (max depth BT_MAX_DEPTH = 10)
var _bt_path[80];
var _bt_pdepth = 0;

# ── Create ────────────────────

# Create empty B-tree (single leaf root), returns page number
fn btree_create(fd, hdr): i64 {
    var pg = page_alloc(fd, hdr);
    var buf = pg_alloc();
    memset(buf, 0, PAGE_SIZE);
    store64(buf + BT_TYPE, PAGE_BTREE);
    store64(buf + BT_LEAF, 1);
    page_write(fd, pg, buf);
    pg_free(buf);
    return pg;
}

# ── Find leaf (records path) ────────────────────

fn _bt_find_leaf(fd, hdr, root, key): i64 {
    _bt_pdepth = 0;
    var pg = root;
    var buf = pg_alloc();
    page_read(fd, pg, buf);

    while (load64(buf + BT_LEAF) == 0) {
        if (_bt_pdepth >= BT_MAX_DEPTH) {
            # Depth cap reached: malformed tree / cycle → return current page
            # as if it were a leaf. Caller's key-match logic will find nothing.
            pg_free(buf);
            return pg;
        }
        store64(&_bt_path + _bt_pdepth * 8, pg);
        _bt_pdepth = _bt_pdepth + 1;
        var nk = load64(buf + BT_NKEYS);
        if (nk > BT_MAX_KEYS) { nk = BT_MAX_KEYS; }
        var ci = nk;
        var ff = 0;
        for (var i = 0; i < nk; i = i + 1) {
            if (ff == 0) {
                if (key < load64(buf + BT_KEYS + i * 8)) {
                    ci = i;
                    ff = 1;
                }
            }
        }
        pg = load64(buf + BT_VALS + ci * 8);
        if (page_read_checked(fd, hdr, pg, buf) != PATRA_OK) {
            pg_free(buf);
            return root;
        }
    }
    store64(&_bt_path + _bt_pdepth * 8, pg);
    _bt_pdepth = _bt_pdepth + 1;
    pg_free(buf);
    return pg;
}

# ── Insert into non-full leaf ────────────────────

fn _bt_leaf_ins(buf, key, val): i64 {
    var nk = load64(buf + BT_NKEYS);
    var pos = nk;
    var ff = 0;
    for (var i = 0; i < nk; i = i + 1) {
        if (ff == 0) {
            if (key <= load64(buf + BT_KEYS + i * 8)) {
                pos = i;
                ff = 1;
            }
        }
    }
    var j = nk - 1;
    while (j >= pos) {
        store64(buf + BT_KEYS + (j + 1) * 8, load64(buf + BT_KEYS + j * 8));
        store64(buf + BT_VALS + (j + 1) * 8, load64(buf + BT_VALS + j * 8));
        j = j - 1;
    }
    store64(buf + BT_KEYS + pos * 8, key);
    store64(buf + BT_VALS + pos * 8, val);
    store64(buf + BT_NKEYS, nk + 1);
}

# ── Insert into non-full internal ──────────

fn _bt_int_ins(buf, key, rchild): i64 {
    var nk = load64(buf + BT_NKEYS);
    var pos = nk;
    var ff = 0;
    for (var i = 0; i < nk; i = i + 1) {
        if (ff == 0) {
            if (key < load64(buf + BT_KEYS + i * 8)) {
                pos = i;
                ff = 1;
            }
        }
    }
    var j = nk - 1;
    while (j >= pos) {
        store64(buf + BT_KEYS + (j + 1) * 8, load64(buf + BT_KEYS + j * 8));
        j = j - 1;
    }
    store64(buf + BT_KEYS + pos * 8, key);
    j = nk;
    while (j >= pos + 1) {
        store64(buf + BT_VALS + (j + 1) * 8, load64(buf + BT_VALS + j * 8));
        j = j - 1;
    }
    store64(buf + BT_VALS + (pos + 1) * 8, rchild);
    store64(buf + BT_NKEYS, nk + 1);
}

# ── Push separator to parent ───────────────

fn _bt_push_up(fd, hdr, root, left_pg, sep, right_pg): i64 {
    if (_bt_pdepth <= 1) {
        # left_pg is the root — create new root
        var nr = page_alloc(fd, hdr);
        var nb = pg_alloc();
        memset(nb, 0, PAGE_SIZE);
        store64(nb + BT_TYPE, PAGE_BTREE);
        store64(nb + BT_LEAF, 0);
        store64(nb + BT_NKEYS, 1);
        store64(nb + BT_KEYS, sep);
        store64(nb + BT_VALS, left_pg);
        store64(nb + BT_VALS + 8, right_pg);
        page_write(fd, nr, nb);
        pg_free(nb);
        return nr;
    }

    var par_pg = load64(&_bt_path + (_bt_pdepth - 2) * 8);
    var pb = pg_alloc();
    page_read(fd, par_pg, pb);
    var nk = load64(pb + BT_NKEYS);

    if (nk < BT_MAX_KEYS) {
        _bt_int_ins(pb, sep, right_pg);
        page_write(fd, par_pg, pb);
        pg_free(pb);
        return root;
    }

    # Parent full — split internal node
    var tk = fl_alloc(520);
    var tc = fl_alloc(528);

    # Find position for sep
    var pos = nk;
    var ff = 0;
    for (var i = 0; i < nk; i = i + 1) {
        if (ff == 0) {
            if (sep < load64(pb + BT_KEYS + i * 8)) {
                pos = i;
                ff = 1;
            }
        }
    }

    # Build temp keys (64)
    var ti = 0;
    for (var i = 0; i < nk; i = i + 1) {
        if (i == pos) {
            store64(tk + ti * 8, sep);
            ti = ti + 1;
        }
        store64(tk + ti * 8, load64(pb + BT_KEYS + i * 8));
        ti = ti + 1;
    }
    if (pos == nk) { store64(tk + ti * 8, sep); ti = ti + 1; }

    # Build temp children (65)
    ti = 0;
    for (var i = 0; i <= nk; i = i + 1) {
        store64(tc + ti * 8, load64(pb + BT_VALS + i * 8));
        ti = ti + 1;
        if (i == pos) {
            store64(tc + ti * 8, right_pg);
            ti = ti + 1;
        }
    }

    # Split: left [0..30] (31 keys, 32 children), mid=31, right [32..63] (32 keys, 33 children)
    var mid = 31;
    var mid_key = load64(tk + mid * 8);

    # Left stays in par_pg
    store64(pb + BT_NKEYS, mid);
    for (var i = 0; i < mid; i = i + 1) {
        store64(pb + BT_KEYS + i * 8, load64(tk + i * 8));
    }
    for (var i = 0; i <= mid; i = i + 1) {
        store64(pb + BT_VALS + i * 8, load64(tc + i * 8));
    }
    page_write(fd, par_pg, pb);

    # Right in new page
    var rpg = page_alloc(fd, hdr);
    var rnk = 64 - mid - 1;
    memset(pb, 0, PAGE_SIZE);
    store64(pb + BT_TYPE, PAGE_BTREE);
    store64(pb + BT_LEAF, 0);
    store64(pb + BT_NKEYS, rnk);
    for (var i = 0; i < rnk; i = i + 1) {
        store64(pb + BT_KEYS + i * 8, load64(tk + (mid + 1 + i) * 8));
    }
    for (var i = 0; i <= rnk; i = i + 1) {
        store64(pb + BT_VALS + i * 8, load64(tc + (mid + 1 + i) * 8));
    }
    page_write(fd, rpg, pb);

    fl_free(tk);
    fl_free(tc);
    pg_free(pb);

    _bt_pdepth = _bt_pdepth - 1;
    return _bt_push_up(fd, hdr, root, par_pg, mid_key, rpg);
}

# ── Insert ────────────────────

# Insert key-value into B-tree, returns (possibly new) root
fn btree_insert(fd, hdr, root, key, val): i64 {
    var leaf_pg = _bt_find_leaf(fd, hdr, root, key);
    var buf = pg_alloc();
    page_read(fd, leaf_pg, buf);
    var nk = load64(buf + BT_NKEYS);

    if (nk < BT_MAX_KEYS) {
        _bt_leaf_ins(buf, key, val);
        page_write(fd, leaf_pg, buf);
        pg_free(buf);
        return root;
    }

    # Leaf full — build sorted temp (64 entries)
    var tk = fl_alloc(520);
    var tv = fl_alloc(520);
    var ins = 0;
    var ff = 0;
    for (var i = 0; i < nk; i = i + 1) {
        if (ff == 0) {
            if (key <= load64(buf + BT_KEYS + i * 8)) {
                store64(tk + ins * 8, key);
                store64(tv + ins * 8, val);
                ins = ins + 1;
                ff = 1;
            }
        }
        store64(tk + ins * 8, load64(buf + BT_KEYS + i * 8));
        store64(tv + ins * 8, load64(buf + BT_VALS + i * 8));
        ins = ins + 1;
    }
    if (ff == 0) {
        store64(tk + ins * 8, key);
        store64(tv + ins * 8, val);
        ins = ins + 1;
    }

    var split = 32;
    var sep = load64(tk + split * 8);

    # Left half stays in leaf_pg
    store64(buf + BT_NKEYS, split);
    for (var i = 0; i < split; i = i + 1) {
        store64(buf + BT_KEYS + i * 8, load64(tk + i * 8));
        store64(buf + BT_VALS + i * 8, load64(tv + i * 8));
    }
    page_write(fd, leaf_pg, buf);

    # Right half in new page
    var rpg = page_alloc(fd, hdr);
    memset(buf, 0, PAGE_SIZE);
    store64(buf + BT_TYPE, PAGE_BTREE);
    store64(buf + BT_LEAF, 1);
    var rn = 64 - split;
    store64(buf + BT_NKEYS, rn);
    for (var i = 0; i < rn; i = i + 1) {
        store64(buf + BT_KEYS + i * 8, load64(tk + (split + i) * 8));
        store64(buf + BT_VALS + i * 8, load64(tv + (split + i) * 8));
    }
    page_write(fd, rpg, buf);

    fl_free(tk);
    fl_free(tv);
    pg_free(buf);

    return _bt_push_up(fd, hdr, root, leaf_pg, sep, rpg);
}

# ── Search (all refs for key) ──────────────

# Search for all refs matching key
fn btree_search(fd, hdr, root, key, out, max): i64 {
    return _bt_range(fd, hdr, root, key, key, out, max);
}

# ── Range scan [lo, hi] — collects refs into out ────────────

fn _bt_range(fd, hdr, root, lo, hi, out, max): i64 {
    var cnt = 0;
    _bt_rwalk(fd, hdr, root, lo, hi, out, max, &cnt, 0);
    return cnt;
}

fn _bt_rwalk(fd, hdr, pg, lo, hi, out, max, cp, depth): i64 {
    if (depth >= BT_MAX_DEPTH) { return 0; }
    var buf = pg_alloc();
    if (page_read_checked(fd, hdr, pg, buf) != PATRA_OK) {
        pg_free(buf);
        return 0;
    }
    var nk = load64(buf + BT_NKEYS);
    if (nk > BT_MAX_KEYS) { nk = BT_MAX_KEYS; }
    var leaf = load64(buf + BT_LEAF);

    if (leaf != 0) {
        for (var i = 0; i < nk; i = i + 1) {
            var c = load64(cp);
            if (c < max) {
                var k = load64(buf + BT_KEYS + i * 8);
                if (k >= lo) {
                    if (k <= hi) {
                        store64(out + c * 8, load64(buf + BT_VALS + i * 8));
                        store64(cp, c + 1);
                    }
                }
            }
        }
    } else {
        # Find first relevant child
        var first = 0;
        for (var i = 0; i < nk; i = i + 1) {
            if (load64(buf + BT_KEYS + i * 8) < lo) {
                first = i + 1;
            }
        }
        var stop = 0;
        for (var i = first; i <= nk; i = i + 1) {
            if (stop == 0) {
                if (load64(cp) < max) {
                    _bt_rwalk(fd, hdr, load64(buf + BT_VALS + i * 8),
                    lo, hi, out, max, cp, depth + 1);
                    if (i < nk) {
                        if (load64(buf + BT_KEYS + i * 8) > hi) {
                            stop = 1;
                        }
                    }
                }
            }
        }
    }
    pg_free(buf);
    return 0;
}

# ── Remove ref (lazy delete — set value to 0) ──────────────

# Lazy-delete: invalidate a specific ref for a key
fn btree_remove_ref(fd, hdr, root, key, ref): i64 {
    var leaf_pg = _bt_find_leaf(fd, hdr, root, key);
    var buf = pg_alloc();
    page_read(fd, leaf_pg, buf);
    var nk = load64(buf + BT_NKEYS);
    var modified = 0;
    for (var i = 0; i < nk; i = i + 1) {
        if (load64(buf + BT_KEYS + i * 8) == key) {
            if (load64(buf + BT_VALS + i * 8) == ref) {
                store64(buf + BT_VALS + i * 8, 0 - 1);
                modified = 1;
            }
        }
    }
    if (modified != 0) { page_write(fd, leaf_pg, buf); }
    pg_free(buf);
    return 0;
}

# ── Whole-tree free (depth-first page reclaim) ─────────────

# Free every page in the B-tree rooted at `root` via depth-first recursion:
# leaves get freed directly; internal nodes recurse into children before
# freeing themselves. Prior to 1.5.0 only the root was freed, leaving all
# internal and leaf pages unreachable on DROP TABLE / ALTER ADD / ALTER DROP.
fn btree_free_all(fd, hdr, root): i64 {
    return _bt_free_walk(fd, hdr, root, 0);
}

fn _bt_free_walk(fd, hdr, root, depth): i64 {
    if (root == 0) { return 0; }
    if (depth >= BT_MAX_DEPTH) { return 0; }
    var buf = pg_alloc();
    if (page_read_checked(fd, hdr, root, buf) != PATRA_OK) {
        pg_free(buf);
        return 0;
    }
    var leaf = load64(buf + BT_LEAF);
    if (leaf != 0) {
        pg_free(buf);
        page_free(fd, hdr, root);
        return 0;
    }
    var nk = load64(buf + BT_NKEYS);
    if (nk > BT_MAX_KEYS) { nk = BT_MAX_KEYS; }
    for (var i = 0; i <= nk; i = i + 1) {
        _bt_free_walk(fd, hdr, load64(buf + BT_VALS + i * 8), depth + 1);
    }
    pg_free(buf);
    page_free(fd, hdr, root);
    return 0;
}

# ── Compaction: reclaim lazy-deleted entries ──────────────

# Compact a single leaf in place: keep only entries with valid refs (val != -1).
# Shifts survivors forward, updates BT_NKEYS. Returns reclaimed count.
# Structural rebalancing (empty-leaf removal) is intentionally out of scope —
# future inserts into the leaf's key range will refill the slots.
fn _bt_leaf_compact(fd, pg): i64 {
    var buf = pg_alloc();
    page_read(fd, pg, buf);
    var nk = load64(buf + BT_NKEYS);
    var kept = 0;
    for (var i = 0; i < nk; i = i + 1) {
        var v = load64(buf + BT_VALS + i * 8);
        if (v != (0 - 1)) {
            if (kept != i) {
                store64(buf + BT_KEYS + kept * 8, load64(buf + BT_KEYS + i * 8));
                store64(buf + BT_VALS + kept * 8, v);
            }
            kept = kept + 1;
        }
    }
    var reclaimed = nk - kept;
    if (reclaimed > 0) {
        store64(buf + BT_NKEYS, kept);
        page_write(fd, pg, buf);
    }
    pg_free(buf);
    return reclaimed;
}

# Depth-first walk: recurse into internal children, compact every leaf.
# Returns total reclaimed across all leaves.
fn _bt_compact_walk(fd, hdr, pg, depth): i64 {
    if (depth >= BT_MAX_DEPTH) { return 0; }
    var buf = pg_alloc();
    if (page_read_checked(fd, hdr, pg, buf) != PATRA_OK) {
        pg_free(buf);
        return 0;
    }
    var leaf = load64(buf + BT_LEAF);
    if (leaf != 0) {
        pg_free(buf);
        return _bt_leaf_compact(fd, pg);
    }
    var nk = load64(buf + BT_NKEYS);
    if (nk > BT_MAX_KEYS) { nk = BT_MAX_KEYS; }
    var total = 0;
    for (var i = 0; i <= nk; i = i + 1) {
        total = total + _bt_compact_walk(fd, hdr,
        load64(buf + BT_VALS + i * 8),
        depth + 1);
    }
    pg_free(buf);
    return total;
}

# Reclaim all tombstoned (lazy-deleted) entries in the tree. Safe to call
# concurrently with nothing (caller holds write lock). Returns count reclaimed.
fn btree_compact(fd, hdr, root): i64 {
    return _bt_compact_walk(fd, hdr, root, 0);
}

# --- table.cyr ---

# table.cyr — table metadata, create, insert, scan, update, delete

var _tbl_last_ref = 0;
var _tbl_lp_idx = 0 - 1;
var _tbl_lp_page = 0;

fn _tbl_entry(hdr, idx): i64 {
    return hdr + HDR_TBLDIR + idx * TBL_ENTRY_SZ;
}

fn _tbl_name_eq(entry, name, nlen): i64 {
    var elen = strlen(entry + TBL_NAME);
    if (elen != nlen) { return 0; }
    return memeq(entry + TBL_NAME, name, nlen);
}

# Free any BLOB chains referenced by this row. Called before a row's
# storage is reclaimed (DROP TABLE, DELETE, ALTER DROP). No-op if the
# schema has no BLOB columns. Also used during ALTER DROP COLUMN on a
# BLOB column, where the dropped column's chain must be freed; in that
# case the caller skips the row-wide sweep and targets the one column.
fn _tbl_free_row_bytes(fd, hdr, row, schema, ncols): i64 {
    for (var i = 0; i < ncols; i = i + 1) {
        var ctype = load64(schema + SCH_START + i * SCH_ENTRY_SZ + SCH_CTYPE);
        if (ctype == COL_BYTES) {
            var off = row_field_offset(schema, ncols, i);
            var first_pg = row_read_bytes_page(row, off);
            if (first_pg != 0) {
                _bytes_free_chain(fd, hdr, first_pg);
            }
        }
    }
    return 0;
}

# True (1) if the schema has at least one BLOB column. Cheap guard so
# non-BLOB tables skip the per-row chain scan on DROP/DELETE.
fn _tbl_has_bytes(schema, ncols): i64 {
    for (var i = 0; i < ncols; i = i + 1) {
        var ctype = load64(schema + SCH_START + i * SCH_ENTRY_SZ + SCH_CTYPE);
        if (ctype == COL_BYTES) { return 1; }
    }
    return 0;
}

# Find table by name, returns index or -1
fn tbl_find(hdr, name, nlen): i64 {
    var count = load64(hdr + HDR_TBLCOUNT);
    for (var i = 0; i < count; i = i + 1) {
        if (_tbl_name_eq(_tbl_entry(hdr, i), name, nlen)) {
            return i;
        }
    }
    return 0 - 1;
}

# col_names: array of (ptr, len) pairs — 16 bytes each
# col_types: array of i64 — 8 bytes each
# Create table with schema and data pages
fn tbl_create(fd, hdr, name, nlen, col_names, col_types, ncols): i64 {
    if (load64(hdr + HDR_TBLCOUNT) >= MAX_TABLES) { return PATRA_ERR_FULL; }
    if (ncols > MAX_COLS) { return PATRA_ERR_COLCOUNT; }
    if (tbl_find(hdr, name, nlen) >= 0) { return PATRA_ERR_EXISTS; }

    var spg = page_alloc(fd, hdr);
    var sbuf = pg_alloc();
    memset(sbuf, 0, PAGE_SIZE);
    store64(sbuf + SCH_NCOLS, ncols);

    for (var i = 0; i < ncols; i = i + 1) {
        var soff = SCH_START + i * SCH_ENTRY_SZ;
        var np = load64(col_names + i * 16);
        var nl = load64(col_names + i * 16 + 8);
        var cn = nl;
        if (cn > SCH_CNAME_MAX - 1) { cn = SCH_CNAME_MAX - 1; }
        memcpy(sbuf + soff + SCH_CNAME, np, cn);
        store8(sbuf + soff + SCH_CNAME + cn, 0);
        store64(sbuf + soff + SCH_CTYPE, load64(col_types + i * 8));
    }
    # Auto-index on first INT column
    store64(sbuf + SCH_IDX_COL, 0 - 1);
    if (ncols > 0) {
        if (load64(col_types) == COL_INT) {
            var bt = btree_create(fd, hdr);
            store64(sbuf + SCH_IDX_COL, 0);
            store64(sbuf + SCH_IDX_ROOT, bt);
        }
    }
    page_write(fd, spg, sbuf);
    pg_free(sbuf);

    var dpg = page_alloc(fd, hdr);
    var dbuf = pg_alloc();
    page_init_data(dbuf);
    page_write(fd, dpg, dbuf);
    pg_free(dbuf);

    var idx = load64(hdr + HDR_TBLCOUNT);
    var entry = _tbl_entry(hdr, idx);
    memset(entry, 0, TBL_ENTRY_SZ);
    var nn = nlen;
    if (nn > TBL_NAME_MAX - 1) { nn = TBL_NAME_MAX - 1; }
    memcpy(entry + TBL_NAME, name, nn);
    store8(entry + TBL_NAME + nn, 0);
    store64(entry + TBL_NCOLS, ncols);
    store64(entry + TBL_ROOT, dpg);
    store64(entry + TBL_NROWS, 0);
    store64(entry + TBL_SCHEMA, spg);
    store64(hdr + HDR_TBLCOUNT, idx + 1);

    return PATRA_OK;
}

# Drop table: free data pages, schema page, compact directory
fn tbl_drop(fd, hdr, idx): i64 {
    _tbl_lp_idx = 0 - 1;
    var entry = _tbl_entry(hdr, idx);
    var spg = load64(entry + TBL_SCHEMA);

    # Read schema to learn the row layout (for BLOB cleanup)
    var schema = pg_alloc();
    page_read(fd, spg, schema);
    var ncols = load64(schema + SCH_NCOLS);
    var has_blob = _tbl_has_bytes(schema, ncols);
    var row_sz = row_compute_size(schema, ncols);

    # Free BLOB chains referenced by every row, then free the data pages.
    # If there are no BLOB columns the row walk is skipped entirely.
    var cur = load64(entry + TBL_ROOT);
    var buf = pg_alloc();
    while (cur != 0) {
        page_read(fd, cur, buf);
        if (has_blob != 0) {
            var nr = load64(buf + DP_NROWS);
            for (var ri = 0; ri < nr; ri = ri + 1) {
                _tbl_free_row_bytes(fd, hdr, buf + DP_DATA + ri * row_sz, schema, ncols);
            }
        }
        var next = load64(buf + DP_NEXT);
        page_free(fd, hdr, cur);
        cur = next;
    }
    pg_free(schema);

    # Free B-tree pages (walk from schema index root)
    var sbuf = pg_alloc();
    page_read(fd, spg, sbuf);
    var ic = load64(sbuf + SCH_IDX_COL);
    if (ic >= 0) {
        var ir = load64(sbuf + SCH_IDX_ROOT);
        if (ir != 0) {
            btree_free_all(fd, hdr, ir);
        }
    }
    pg_free(sbuf);

    # Free schema page
    page_free(fd, hdr, spg);

    # Compact table directory: shift entries after idx left by one
    var count = load64(hdr + HDR_TBLCOUNT);
    var i = idx;
    while (i < count - 1) {
        var dst = _tbl_entry(hdr, i);
        var src = _tbl_entry(hdr, i + 1);
        memcpy(dst, src, TBL_ENTRY_SZ);
        i = i + 1;
    }
    store64(hdr + HDR_TBLCOUNT, count - 1);

    pg_free(buf);
    return PATRA_OK;
}

# Insert a row into table
fn tbl_insert(fd, hdr, idx, row_data, row_sz): i64 {
    var entry = _tbl_entry(hdr, idx);
    var buf = pg_alloc();

    # Use cached last page if available for this table
    var cur = 0;
    if (_tbl_lp_idx == idx) {
        cur = _tbl_lp_page;
        page_read(fd, cur, buf);
    } else {
        cur = load64(entry + TBL_ROOT);
        page_read(fd, cur, buf);
        while (load64(buf + DP_NEXT)) {
            cur = load64(buf + DP_NEXT);
            page_read(fd, cur, buf);
        }
    }

    var nrows = load64(buf + DP_NROWS);
    var used = DP_DATA + nrows * row_sz;

    if (used + row_sz <= PAGE_SIZE) {
        _tbl_last_ref = _bt_mkref(cur, nrows);
        memcpy(buf + used, row_data, row_sz);
        store64(buf + DP_NROWS, nrows + 1);
        page_write(fd, cur, buf);
        _tbl_lp_idx = idx;
        _tbl_lp_page = cur;
    } else {
        var npg = page_alloc(fd, hdr);
        store64(buf + DP_NEXT, npg);
        page_write(fd, cur, buf);

        _tbl_last_ref = _bt_mkref(npg, 0);
        page_init_data(buf);
        memcpy(buf + DP_DATA, row_data, row_sz);
        store64(buf + DP_NROWS, 1);
        page_write(fd, npg, buf);
        _tbl_lp_idx = idx;
        _tbl_lp_page = npg;
    }

    var rc = load64(entry + TBL_NROWS);
    store64(entry + TBL_NROWS, rc + 1);

    pg_free(buf);
    return PATRA_OK;
}

# Scan all rows (no filter). Returns rows copied.
# Scan all rows into output buffer, returns count
fn tbl_scan(fd, hdr, idx, out, row_sz): i64 {
    var entry = _tbl_entry(hdr, idx);
    var cur = load64(entry + TBL_ROOT);
    var buf = pg_alloc();
    var written = 0;

    while (cur != 0) {
        page_read(fd, cur, buf);
        var nrows = load64(buf + DP_NROWS);
        var bytes = nrows * row_sz;
        memcpy(out + written, buf + DP_DATA, bytes);
        written = written + bytes;
        cur = load64(buf + DP_NEXT);
    }

    pg_free(buf);
    return written / row_sz;
}

# Filtered scan — copies matching rows into out. Returns count.
# Scan rows matching WHERE into output, returns count
fn tbl_scan_where(fd, hdr, idx, out, row_sz, schema, ncols, pr): i64 {
    var entry = _tbl_entry(hdr, idx);
    var cur = load64(entry + TBL_ROOT);
    var buf = pg_alloc();
    var kept = 0;

    while (cur != 0) {
        page_read(fd, cur, buf);
        var nrows = load64(buf + DP_NROWS);
        for (var i = 0; i < nrows; i = i + 1) {
            var rptr = buf + DP_DATA + i * row_sz;
            if (where_eval(rptr, schema, ncols, pr)) {
                memcpy(out + kept * row_sz, rptr, row_sz);
                kept = kept + 1;
            }
        }
        cur = load64(buf + DP_NEXT);
    }

    pg_free(buf);
    return kept;
}

# Update matching rows in-place. Returns PATRA_OK or error.
# Update matching rows in-place
fn tbl_update(fd, hdr, idx, row_sz, schema, ncols, pr): i64 {
    var entry = _tbl_entry(hdr, idx);
    var cur = load64(entry + TBL_ROOT);
    var buf = pg_alloc();
    var nsets = load64(pr + PR_COUNT);

    # Check if indexed column is being updated
    var uic = load64(schema + SCH_IDX_COL);
    var uir = load64(schema + SCH_IDX_ROOT);
    var uioff = 0;
    var ui_updating = 0;
    if (uic >= 0) {
        if (uic < ncols) {
            uioff = row_field_offset(schema, ncols, uic);
            var icn = schema + SCH_START + uic * SCH_ENTRY_SZ + SCH_CNAME;
            var icnl = strlen(icn);
            for (var s = 0; s < nsets; s = s + 1) {
                var set = pr + PR_ITEMS + s * SET_SZ;
                if (load64(set + SET_CLEN) == icnl) {
                    if (memeq(load64(set + SET_CPTR), icn, icnl)) {
                        ui_updating = 1;
                    }
                }
            }
        } else { uic = 0 - 1; }
    }

    while (cur != 0) {
        page_read(fd, cur, buf);
        var nrows = load64(buf + DP_NROWS);
        var modified = 0;

        for (var i = 0; i < nrows; i = i + 1) {
            var rptr = buf + DP_DATA + i * row_sz;
            if (where_eval(rptr, schema, ncols, pr)) {
                # Remove old index entry if indexed col is being updated
                if (ui_updating != 0) {
                    if (uir != 0) {
                        var old_key = _idx_key_from_row(schema, ncols, uic, rptr);
                        btree_remove_ref(fd, hdr, uir, old_key, _bt_mkref(cur, i));
                    }
                }
                for (var s = 0; s < nsets; s = s + 1) {
                    var set = pr + PR_ITEMS + s * SET_SZ;
                    var cidx = _wh_resolve_col(schema, ncols,
                    load64(set + SET_CPTR), load64(set + SET_CLEN));
                    if (cidx < 0) {
                        pg_free(buf);
                        return PATRA_ERR_NOTFOUND;
                    }
                    var ctype = load64(schema + SCH_START + cidx * SCH_ENTRY_SZ + SCH_CTYPE);
                    if (ctype == COL_BYTES) {
                        pg_free(buf);
                        return PATRA_ERR_TYPE;
                    }
                    var coff = row_field_offset(schema, ncols, cidx);
                    if (load64(set + SET_VTYPE) == COL_INT) {
                        row_write_int(rptr, coff, load64(set + SET_IVAL));
                    } else {
                        row_write_str(rptr, coff, load64(set + SET_SPTR), load64(set + SET_SLEN));
                    }
                }
                # Insert new index entry if indexed col was updated
                if (ui_updating != 0) {
                    if (uir != 0) {
                        var new_key = _idx_key_from_row(schema, ncols, uic, rptr);
                        uir = btree_insert(fd, hdr, uir, new_key, _bt_mkref(cur, i));
                        store64(schema + SCH_IDX_ROOT, uir);
                    }
                }
                modified = 1;
            }
        }

        if (modified != 0) { page_write(fd, cur, buf); }
        cur = load64(buf + DP_NEXT);
    }

    pg_free(buf);
    return PATRA_OK;
}

# Delete matching rows with page compaction. Returns PATRA_OK.
# Delete matching rows with page compaction
fn tbl_delete(fd, hdr, idx, row_sz, schema, ncols, pr): i64 {
    _tbl_lp_idx = 0 - 1;
    var entry = _tbl_entry(hdr, idx);
    var cur = load64(entry + TBL_ROOT);
    var buf = pg_alloc();
    var deleted = 0;

    # Check for B-tree index
    var dic = load64(schema + SCH_IDX_COL);
    var dir = load64(schema + SCH_IDX_ROOT);
    var doff = 0;
    if (dic >= 0) {
        if (dic < ncols) {
            doff = row_field_offset(schema, ncols, dic);
        } else {
            dic = 0 - 1;
        }
    }

    while (cur != 0) {
        page_read(fd, cur, buf);
        var nrows = load64(buf + DP_NROWS);
        var kept = 0;

        for (var i = 0; i < nrows; i = i + 1) {
            var rptr = buf + DP_DATA + i * row_sz;
            if (where_eval(rptr, schema, ncols, pr)) {
                # Free any BLOB chains this row owned before the row slot
                # gets reclaimed or overwritten by the compaction below.
                _tbl_free_row_bytes(fd, hdr, rptr, schema, ncols);
                # Invalidate B-tree entry
                if (dic >= 0) {
                    if (dir != 0) {
                        var dkey = _idx_key_from_row(schema, ncols, dic, rptr);
                        var dref = _bt_mkref(cur, i);
                        btree_remove_ref(fd, hdr, dir, dkey, dref);
                    }
                }
                deleted = deleted + 1;
            } else {
                if (kept != i) {
                    memcpy(buf + DP_DATA + kept * row_sz, rptr, row_sz);
                }
                kept = kept + 1;
            }
        }

        if (kept != nrows) {
            store64(buf + DP_NROWS, kept);
            page_write(fd, cur, buf);
        }
        cur = load64(buf + DP_NEXT);
    }

    var rc = load64(entry + TBL_NROWS);
    store64(entry + TBL_NROWS, rc - deleted);

    pg_free(buf);
    return PATRA_OK;
}

# --- jsonl.cyr ---

# jsonl.cyr — JSON Lines append-only mode (libro compatibility)
#
# JSONL files: one JSON object per line, newline-delimited.
# flock for concurrent access, O_APPEND for atomic appends.

# ── Open / Close ────────────────────

# O_RDWR | O_CREAT | O_APPEND | O_NOFOLLOW = 2 + 64 + 1024 + 131072 = 132162
# O_NOFOLLOW added in 1.5.2 (audit §2.8).
fn jsonl_open(path): i64 {
    return sys_open(path, 132162, 420);
}

# Close JSONL file
fn jsonl_close(fd): i64 {
    sys_close(fd);
    return 0;
}

# ── Append ────────────────────

# Append raw data + newline with exclusive lock
fn jsonl_append(fd, data, len): i64 {
    patra_lock_ex(fd);
    var w = sys_write(fd, data, len);
    if (w < 0) { patra_unlock(fd); return PATRA_ERR_IO; }
    sys_write(fd, "\n", 1);
    syscall(SYS_FDATASYNC, fd);
    patra_unlock(fd);
    return PATRA_OK;
}

# ── JSON string escaping ────────────────────

fn _hex_digit(v): i64 {
    if (v < 10) { return 48 + v; }
    return 87 + v;
}

# Escape src[0..slen) into JSON per RFC 8259 §7. All control bytes 0x00–0x1F
# are escaped (named shortcuts for \b/\t/\n/\f/\r; \u00XX for the rest).
# Returns bytes written. Worst-case expansion is 6× (all \u00XX), so callers
# must size dst accordingly — `patra_json_build`'s 4096B buffer covers any single
# 256-byte Patra string (max 1536B expanded) plus framing.
#
# Audit 2026-04-21 §2.6, §3.6: strict JSON readers (`json.loads`, `jq`,
# `simdjson` in strict mode) reject raw control bytes. Pre-1.5.2 Patra could
# emit invalid JSON whenever a STR column contained a byte outside the five
# originally-escaped chars.
fn _json_escape(dst, src, slen): i64 {
    var w = 0;
    var cap = slen * 6 + 8;
    for (var i = 0; i < slen; i = i + 1) {
        if (w + 6 > cap) { return w; }
        var c = load8(src + i) & 0xff;
        if (c == 34) {
            store8(dst + w, 92); store8(dst + w + 1, 34); w = w + 2;
        } elif (c == 92) {
            store8(dst + w, 92); store8(dst + w + 1, 92); w = w + 2;
        } elif (c == 8) {
            store8(dst + w, 92); store8(dst + w + 1, 98); w = w + 2;
        } elif (c == 9) {
            store8(dst + w, 92); store8(dst + w + 1, 116); w = w + 2;
        } elif (c == 10) {
            store8(dst + w, 92); store8(dst + w + 1, 110); w = w + 2;
        } elif (c == 12) {
            store8(dst + w, 92); store8(dst + w + 1, 102); w = w + 2;
        } elif (c == 13) {
            store8(dst + w, 92); store8(dst + w + 1, 114); w = w + 2;
        } elif (c < 32) {
            store8(dst + w, 92);
            store8(dst + w + 1, 117);
            store8(dst + w + 2, 48);
            store8(dst + w + 3, 48);
            store8(dst + w + 4, _hex_digit((c / 16) & 0xf));
            store8(dst + w + 5, _hex_digit(c & 0xf));
            w = w + 6;
        } else {
            store8(dst + w, c); w = w + 1;
        }
    }
    return w;
}

# ── JSON object builder ────────────────────

# Length-aware builder. `vlens` gives explicit byte length for each STR value
# (entries for COL_INT are ignored). A STR value may therefore contain embedded
# NUL bytes without being silently truncated by strlen — audit 2026-04-21 §2.6
# log-forging case. Emits `[NUL]` for any NUL, producing valid JSON in all cases.
# Pass `vlens = 0` to fall back to strlen on every STR value (legacy behavior).
fn json_build_lens(buf, max, keys, vals, vlens, types, n): i64 {
    var pos = 0;
    store8(buf + pos, 123); pos = pos + 1;

    for (var i = 0; i < n; i = i + 1) {
        if (i > 0) {
            store8(buf + pos, 44); pos = pos + 1;
            store8(buf + pos, 32); pos = pos + 1;
        }
        # Key
        store8(buf + pos, 34); pos = pos + 1;
        var kp = load64(keys + i * 8);
        var kl = strlen(kp);
        memcpy(buf + pos, kp, kl); pos = pos + kl;
        store8(buf + pos, 34); pos = pos + 1;
        store8(buf + pos, 58); pos = pos + 1;
        store8(buf + pos, 32); pos = pos + 1;

        # Value
        var vt = load64(types + i * 8);
        if (vt == COL_INT) {
            pos = pos + fmt_int_buf(load64(vals + i * 8), buf + pos);
        } else {
            store8(buf + pos, 34); pos = pos + 1;
            var sp = load64(vals + i * 8);
            var sl = 0;
            if (vlens != 0) { sl = load64(vlens + i * 8); }
            else { sl = strlen(sp); }
            pos = pos + _json_escape(buf + pos, sp, sl);
            store8(buf + pos, 34); pos = pos + 1;
        }
    }

    store8(buf + pos, 125); pos = pos + 1;
    store8(buf + pos, 0);
    return pos;
}

# Legacy strlen-based builder. Prefer `json_build_lens` when inputs
# may contain embedded NUL bytes (audit §2.6).
#
# v1.9.0: renamed from `json_build` → `patra_json_build` to clear a
# silent collision with `lib/json.cyr::json_build/1` (the general
# pairs-vec utility). Last-include wins under cyrius v5.7.8 and
# earlier; cyrius v5.7.9 emits a `warning: duplicate fn` at this
# kind of registration. The `patra_*` namespace prefix matches
# the convention used elsewhere in patra (`patra_open`, `patra_close`,
# etc.). See cyrius `docs/audit/2026-04-26-stdlib-fn-collisions.md`.
fn patra_json_build(buf, max, keys, vals, types, n): i64 {
    return json_build_lens(buf, max, keys, vals, 0, types, n);
}

# Length-aware JSONL append. vlens is an array of explicit lengths for STR
# values (ignored for INT). Added in 1.5.3 to close the embedded-NUL
# truncation in `jsonl_append_obj` without breaking existing callers.
fn jsonl_append_obj_lens(fd, keys, vals, vlens, types, n): i64 {
    var buf = fl_alloc(4096);
    var len = json_build_lens(buf, 4096, keys, vals, vlens, types, n);
    jsonl_append(fd, buf, len);
    fl_free(buf);
    return 0;
}

# Legacy append — strlen-based. Kept for backward compatibility.
fn jsonl_append_obj(fd, keys, vals, types, n): i64 {
    return jsonl_append_obj_lens(fd, keys, vals, 0, types, n);
}

# ── Read ────────────────────

# Read result layout: { count(8), data_ptr(8), lines_ptr(8) }
# lines: array of (ptr, len) pairs — 16 bytes each
enum JlrOff { JLR_COUNT = 0; JLR_DATA = 8; JLR_LINES = 16; JLR_SZ = 24; }

# Read all lines from JSONL file into indexed result
fn jsonl_read(fd): i64 {
    patra_lock_sh(fd);
    var size = syscall(SYS_LSEEK, fd, 0, 2);
    syscall(SYS_LSEEK, fd, 0, 0);

    if (size <= 0) {
        patra_unlock(fd);
        var lr = fl_alloc(JLR_SZ);
        memset(lr, 0, JLR_SZ);
        return lr;
    }

    var data = fl_alloc(size + 1);
    var rd = 0;
    var eof = 0;
    while (eof == 0) {
        if (rd >= size) { eof = 1; continue; }
        var n = sys_read(fd, data + rd, size - rd);
        if (n <= 0) { eof = 1; continue; }
        rd = rd + n;
    }
    store8(data + size, 0);
    patra_unlock(fd);

    # Count newlines
    var nlc = 0;
    for (var i = 0; i < size; i = i + 1) {
        if (load8(data + i) == 10) { nlc = nlc + 1; }
    }
    # Handle last line without trailing newline
    if (size > 0) {
        if (load8(data + size - 1) != 10) { nlc = nlc + 1; }
    }

    var lines = fl_alloc(nlc * 16 + 16);
    var li = 0;
    var start = 0;
    for (var i = 0; i <= size; i = i + 1) {
        var at_end = 0;
        if (i == size) { at_end = 1; }
        elif (load8(data + i) == 10) { at_end = 1; }

        if (at_end != 0) {
            var llen = i - start;
            if (llen > 0) {
                store64(lines + li * 16, data + start);
                store64(lines + li * 16 + 8, llen);
                li = li + 1;
            }
            start = i + 1;
        }
    }

    var lr = fl_alloc(JLR_SZ);
    store64(lr + JLR_COUNT, li);
    store64(lr + JLR_DATA, data);
    store64(lr + JLR_LINES, lines);
    return lr;
}

# Get number of lines in read result
fn jsonl_lines_count(lr): i64 { return load64(lr + JLR_COUNT); }

# Get pointer to line data at index
fn jsonl_lines_get(lr, idx): i64 {
    var lines = load64(lr + JLR_LINES);
    return load64(lines + idx * 16);
}

# Get length of line at index
fn jsonl_lines_len(lr, idx): i64 {
    var lines = load64(lr + JLR_LINES);
    return load64(lines + idx * 16 + 8);
}

# Free read result and all buffers
fn jsonl_lines_free(lr): i64 {
    if (lr == 0) { return 0; }
    var d = load64(lr + JLR_DATA);
    var l = load64(lr + JLR_LINES);
    if (d != 0) { fl_free(d); }
    if (l != 0) { fl_free(l); }
    fl_free(lr);
    return 0;
}

# ── Field extraction ────────────────────

# Find "key": in a JSON line. Returns offset past the colon+space, or -1.
fn _jl_find_key(line, llen, key, klen): i64 {
    var i = 0;
    var result = 0 - 1;
    var done = 0;
    while (done == 0) {
        if (i >= llen) { done = 1; continue; }
        if (load8(line + i) != 34) { i = i + 1; continue; }
        # Found opening quote — check if key matches
        i = i + 1;
        if (i + klen >= llen) { done = 1; continue; }
        var eq = memeq(line + i, key, klen);
        if (eq != 0) {
            if (load8(line + i + klen) == 34) {
                # Matched "key" — skip to colon
                i = i + klen + 1;
                var fdone = 0;
                while (fdone == 0) {
                    if (i >= llen) { fdone = 1; continue; }
                    if (load8(line + i) == 58) { fdone = 1; continue; }
                    i = i + 1;
                }
                i = i + 1;
                # Skip whitespace
                var sdone = 0;
                while (sdone == 0) {
                    if (i >= llen) { sdone = 1; continue; }
                    if (load8(line + i) != 32) { sdone = 1; continue; }
                    i = i + 1;
                }
                result = i;
                done = 1;
                continue;
            }
        }
        # Skip past this string value
        var qdone = 0;
        while (qdone == 0) {
            if (i >= llen) { qdone = 1; continue; }
            if (load8(line + i) == 34) { qdone = 1; continue; }
            i = i + 1;
        }
        if (i < llen) { i = i + 1; }
    }
    return result;
}

# Get string value for key from JSON line. Returns ptr to content (inside quotes), sets len.
# out_len: pointer to store length. Returns pointer or 0.
# Extract string field from JSON line by key
fn jsonl_get_str(line, llen, key, klen, out_len): i64 {
    var off = _jl_find_key(line, llen, key, klen);
    if (off < 0) { return 0; }
    if (off >= llen) { return 0; }
    if (load8(line + off) != 34) { return 0; }
    off = off + 1;
    var start = off;
    var edone = 0;
    while (edone == 0) {
        if (off >= llen) { edone = 1; continue; }
        if (load8(line + off) == 34) { edone = 1; continue; }
        off = off + 1;
    }
    store64(out_len, off - start);
    return line + start;
}

# Get integer value for key from JSON line. Returns the value, 0 if not
# found, or 0 on i64 overflow. Audit 2026-04-21 §2.7: pre-1.5.2 a 25-digit
# input silently wrapped to an attacker-chosen i64 — flag it and refuse.
fn jsonl_get_int(line, llen, key, klen): i64 {
    var off = _jl_find_key(line, llen, key, klen);
    if (off < 0) { return 0; }
    if (off >= llen) { return 0; }
    var neg = 0;
    if (load8(line + off) == 45) { neg = 1; off = off + 1; }
    var val = 0;
    var ovf = 0;
    var pdone = 0;
    # 9223372036854775807 / 10 = 922337203685477580 — any val above this
    # overflows on the next `*10`. Strictly-greater is correct: val=cutoff
    # leaves room for up to +7, which a single digit can't exceed.
    var limit = 922337203685477580;
    while (pdone == 0) {
        if (off >= llen) { pdone = 1; continue; }
        var c = load8(line + off);
        if (c < 48) { pdone = 1; continue; }
        if (c > 57) { pdone = 1; continue; }
        if (val > limit) { ovf = 1; pdone = 1; continue; }
        val = val * 10 + (c - 48);
        off = off + 1;
    }
    if (ovf != 0) { return 0; }
    if (neg != 0) { val = 0 - val; }
    return val;
}

# ── Count lines ────────────────────

# Count lines in JSONL file
fn jsonl_count(fd): i64 {
    patra_lock_sh(fd);
    syscall(SYS_LSEEK, fd, 0, 0);
    var buf = fl_alloc(4096);
    var count = 0;
    var eof = 0;
    while (eof == 0) {
        var n = sys_read(fd, buf, 4096);
        if (n <= 0) { eof = 1; continue; }
        for (var i = 0; i < n; i = i + 1) {
            if (load8(buf + i) == 10) { count = count + 1; }
        }
    }
    fl_free(buf);
    patra_unlock(fd);
    return count;
}

# --- lib.cyr ---

# lib.cyr — Patra public API
#
# Structured storage and SQL queries for Cyrius.
# Usage: include "src/lib.cyr", call patra_init(), then use the API.

# ── Stdlib ────────────────────


# ── Modules (order matters: sql before where before table) ──


# ── DB handle (16 bytes) ────────────────────

enum DbOff {
    DB_FD = 0; DB_HDR = 8; DB_PATH = 16; DB_TX = 24;
    DB_SYNC_MODE = 32; DB_BATCH_PENDING = 40;
    DB_SZ = 48;
}

# 1.8.0 group-commit modes. FULL = fdatasync after every mutating exec
# (default; current behavior, durable on every call). BATCH = defer fdatasync
# and accumulate up to PATRA_BATCH_FLUSH_N pending writes; auto-flush on
# threshold, on patra_flush(db), or on patra_close(db). Explicit transactions
# (patra_begin/patra_commit) keep their own durability contract regardless
# of the mode — commit always fsyncs.
enum SyncMode { PATRA_SYNC_FULL = 0; PATRA_SYNC_BATCH = 1; }
enum SyncConst { PATRA_BATCH_FLUSH_N = 64; }

# ── Result set (48 bytes header + inline data) ──────────────

enum RsOff {
    RS_NCOLS = 0;
    RS_NROWS = 8;
    RS_TYPES = 16;
    RS_NAMES = 24;
    RS_ROWSZ = 32;
    RS_DATA = 40;
    RS_HDR_SZ = 48;
}

# ── Init ────────────────────

# Initialize patra (call once before use)
fn patra_init(): i64 {
    _sql_init();
    sakshi_set_level(SK_WARN);
}

# ── Open / Close ────────────────────

# Open or create a .patra database file
fn patra_open(path): i64 {
    _tbl_lp_idx = 0 - 1;
    var fd = _pt_file_open(path);
    if (fd < 0) {
        fd = _pt_file_create(path);
        if (fd < 0) {
            _pt_err("patra: cannot open or create file");
            return 0;
        }
    } else {
        var tmp = pg_alloc();
        var ok = patra_hdr_read(fd, tmp);
        if (ok != PATRA_OK) {
            pg_free(tmp);
            sys_close(fd);
            _pt_err("patra: cannot read header");
            return 0;
        }
        if (patra_hdr_verify(tmp) != PATRA_OK) {
            pg_free(tmp);
            sys_close(fd);
            _pt_err("patra: invalid magic");
            return 0;
        }
        pg_free(tmp);
    }

    # Build WAL path
    var plen = strlen(path);
    var wpath = alloc(plen + 5);
    memcpy(wpath, path, plen);
    memcpy(wpath + plen, ".wal", 4);
    store8(wpath + plen + 4, 0);

    # WAL recovery
    wal_recover(fd, wpath);

    var db = fl_alloc(DB_SZ);
    var hdr = pg_alloc();
    patra_hdr_read(fd, hdr);
    store64(db + DB_FD, fd);
    store64(db + DB_HDR, hdr);
    store64(db + DB_PATH, wpath);
    store64(db + DB_TX, 0);
    store64(db + DB_SYNC_MODE, PATRA_SYNC_FULL);
    store64(db + DB_BATCH_PENDING, 0);
    return db;
}

# Close the database, flushing any pending BATCH-mode writes first.
fn patra_close(db): i64 {
    if (db == 0) { return 0; }
    var fd = load64(db + DB_FD);
    if (load64(db + DB_BATCH_PENDING) != 0) {
        syscall(SYS_FDATASYNC, fd);
    }
    pg_free(load64(db + DB_HDR));
    sys_close(fd);
    fl_free(db);
    return 0;
}

fn _db_fd(db): i64 { return load64(db + DB_FD); }
fn _db_hdr(db): i64 { return load64(db + DB_HDR); }

# Set group-commit mode (PATRA_SYNC_FULL or PATRA_SYNC_BATCH); flushes first.
fn patra_set_sync_mode(db, mode): i64 {
    if (load64(db + DB_BATCH_PENDING) != 0) {
        syscall(SYS_FDATASYNC, load64(db + DB_FD));
        store64(db + DB_BATCH_PENDING, 0);
    }
    store64(db + DB_SYNC_MODE, mode);
    return PATRA_OK;
}

# Return the current group-commit mode for this DB handle.
fn patra_get_sync_mode(db): i64 { return load64(db + DB_SYNC_MODE); }

# Force durability of any pending BATCH-mode writes. No-op in FULL mode.
fn patra_flush(db): i64 {
    if (load64(db + DB_BATCH_PENDING) != 0) {
        syscall(SYS_FDATASYNC, load64(db + DB_FD));
        store64(db + DB_BATCH_PENDING, 0);
    }
    return PATRA_OK;
}

# Internal: commit the post-mutation header write. FULL mode does the
# legacy synchronous header-write-with-fdatasync. BATCH mode writes the
# header without syncing, increments the pending counter, and triggers
# an auto-flush every PATRA_BATCH_FLUSH_N writes to bound the crash window.
fn _db_hdr_commit(db, fd, hdr): i64 {
    if (load64(db + DB_SYNC_MODE) == PATRA_SYNC_BATCH) {
        var r = patra_hdr_write_nosync(fd, hdr);
        if (r != PATRA_OK) { return r; }
        var pending = load64(db + DB_BATCH_PENDING) + 1;
        if (pending >= PATRA_BATCH_FLUSH_N) {
            syscall(SYS_FDATASYNC, fd);
            pending = 0;
        }
        store64(db + DB_BATCH_PENDING, pending);
        return PATRA_OK;
    }
    return patra_hdr_write(fd, hdr);
}

# ── Exec: CREATE TABLE ────────────────────

fn _exec_create(db): i64 {
    var fd = _db_fd(db);
    var hdr = _db_hdr(db);

    patra_lock_ex(fd);
    patra_hdr_read(fd, hdr);

    var ncols = load64(_sql_pr + PR_COUNT);
    var names = fl_alloc(ncols * 16);
    var types = fl_alloc(ncols * 8);

    for (var i = 0; i < ncols; i = i + 1) {
        var item = _sql_pr + PR_ITEMS + i * CR_SZ;
        store64(names + i * 16, load64(item + CR_NPTR));
        store64(names + i * 16 + 8, load64(item + CR_NLEN));
        store64(types + i * 8, load64(item + CR_TYPE));
    }

    var r = tbl_create(fd, hdr, load64(_sql_pr + PR_TNAME),
    load64(_sql_pr + PR_TNLEN), names, types, ncols);
    fl_free(names);
    fl_free(types);

    if (r == PATRA_OK) { _db_hdr_commit(db, fd, hdr); }
    patra_unlock(fd);
    return r;
}

# ── Exec: INSERT ────────────────────

fn _exec_insert(db): i64 {
    var fd = _db_fd(db);
    var hdr = _db_hdr(db);

    patra_lock_ex(fd);
    patra_hdr_read(fd, hdr);

    var tname = load64(_sql_pr + PR_TNAME);
    var tnlen = load64(_sql_pr + PR_TNLEN);
    var idx = tbl_find(hdr, tname, tnlen);
    if (idx < 0) {
        patra_unlock(fd);
        return PATRA_ERR_NOTFOUND;
    }

    var entry = _tbl_entry(hdr, idx);
    var spg = load64(entry + TBL_SCHEMA);
    var schema = pg_alloc();
    page_read(fd, spg, schema);

    var ncols = load64(schema + SCH_NCOLS);
    var nvals = load64(_sql_pr + PR_COUNT);
    if (nvals != ncols) {
        pg_free(schema);
        patra_unlock(fd);
        return PATRA_ERR_COLCOUNT;
    }

    var rsz = row_compute_size(schema, ncols);
    var row = fl_alloc(rsz);
    memset(row, 0, rsz);

    for (var i = 0; i < ncols; i = i + 1) {
        var item = _sql_pr + PR_ITEMS + i * IR_SZ;
        var vtype = load64(item + IR_TYPE);
        var ctype = load64(schema + SCH_START + i * SCH_ENTRY_SZ + SCH_CTYPE);
        var off = row_field_offset(schema, ncols, i);

        if (vtype == COL_INT) {
            if (ctype != COL_INT) {
                fl_free(row);
                pg_free(schema);
                patra_unlock(fd);
                return PATRA_ERR_TYPE;
            }
            row_write_int(row, off, load64(item + IR_IVAL));
        } else {
            if (ctype != COL_STR) {
                fl_free(row);
                pg_free(schema);
                patra_unlock(fd);
                return PATRA_ERR_TYPE;
            }
            row_write_str(row, off, load64(item + IR_SPTR), load64(item + IR_SLEN));
        }
    }

    # INSERT OR IGNORE: probe the indexed column for an existing row with
    # the same key. On hit, return PATRA_OK without inserting. Only fires
    # when the table has an index — without one there's no conflict to detect.
    # STR-indexed cols are hash-keyed: btree_search returns candidates, then
    # we byte-compare the 256-byte slot in each candidate row to filter false
    # positives from hash collisions.
    if (load64(_sql_pr + PR_INSERT_IGNORE) != 0) {
        var iic = load64(schema + SCH_IDX_COL);
        if (iic >= 0) {
            if (iic < ncols) {
                var iir = load64(schema + SCH_IDX_ROOT);
                if (iir != 0) {
                    var pkey = _idx_key_from_row(schema, ncols, iic, row);
                    var ictype = load64(schema + SCH_START + iic * SCH_ENTRY_SZ + SCH_CTYPE);
                    var ihit = 0;
                    if (ictype == COL_INT) {
                        var probe = fl_alloc(8);
                        if (btree_search(fd, hdr, iir, pkey, probe, 1) > 0) { ihit = 1; }
                        fl_free(probe);
                    } else {
                        var refs = fl_alloc(256 * 8);
                        var nrefs = btree_search(fd, hdr, iir, pkey, refs, 256);
                        var icoff = row_field_offset(schema, ncols, iic);
                        var pbuf = pg_alloc();
                        var lpg = 0 - 1;
                        for (var ri = 0; ri < nrefs; ri = ri + 1) {
                            if (ihit == 0) {
                                var iref = load64(refs + ri * 8);
                                if (iref != (0 - 1)) {
                                    var rpg = _bt_ref_pg(iref);
                                    var rsl = _bt_ref_slot(iref);
                                    if (rpg != lpg) { page_read(fd, rpg, pbuf); lpg = rpg; }
                                    if (_memeq256(pbuf + DP_DATA + rsl * rsz + icoff, row + icoff)) {
                                        ihit = 1;
                                    }
                                }
                            }
                        }
                        pg_free(pbuf);
                        fl_free(refs);
                    }
                    if (ihit != 0) {
                        fl_free(row);
                        pg_free(schema);
                        patra_unlock(fd);
                        return PATRA_OK;
                    }
                }
            }
        }
    }

    var r = tbl_insert(fd, hdr, idx, row, rsz);

    # Maintain B-tree index
    if (r == PATRA_OK) {
        var ic = load64(schema + SCH_IDX_COL);
        if (ic >= 0) {
            if (ic < ncols) {
                var ir = load64(schema + SCH_IDX_ROOT);
                if (ir != 0) {
                    var ikey = _idx_key_from_row(schema, ncols, ic, row);
                    var nr = btree_insert(fd, hdr, ir, ikey, _tbl_last_ref);
                    if (nr != ir) {
                        store64(schema + SCH_IDX_ROOT, nr);
                        page_write(fd, spg, schema);
                    }
                }
            }
        }
    }

    fl_free(row);
    pg_free(schema);

    if (r == PATRA_OK) { _db_hdr_commit(db, fd, hdr); }
    patra_unlock(fd);
    return r;
}

# ── Exec: UPDATE ────────────────────

fn _exec_update(db): i64 {
    var fd = _db_fd(db);
    var hdr = _db_hdr(db);

    patra_lock_ex(fd);
    patra_hdr_read(fd, hdr);

    var tname = load64(_sql_pr + PR_TNAME);
    var tnlen = load64(_sql_pr + PR_TNLEN);
    var idx = tbl_find(hdr, tname, tnlen);
    if (idx < 0) {
        patra_unlock(fd);
        return PATRA_ERR_NOTFOUND;
    }

    var entry = _tbl_entry(hdr, idx);
    var spg = load64(entry + TBL_SCHEMA);
    var schema = pg_alloc();
    page_read(fd, spg, schema);
    var ncols = load64(schema + SCH_NCOLS);
    var rsz = row_compute_size(schema, ncols);

    var r = tbl_update(fd, hdr, idx, rsz, schema, ncols, _sql_pr);

    # Write schema page if index root may have changed
    if (r == PATRA_OK) {
        page_write(fd, spg, schema);
        _db_hdr_commit(db, fd, hdr);
    }
    pg_free(schema);
    patra_unlock(fd);
    return r;
}

# ── Exec: DELETE ────────────────────

fn _exec_delete(db): i64 {
    var fd = _db_fd(db);
    var hdr = _db_hdr(db);

    patra_lock_ex(fd);
    patra_hdr_read(fd, hdr);

    var tname = load64(_sql_pr + PR_TNAME);
    var tnlen = load64(_sql_pr + PR_TNLEN);
    var idx = tbl_find(hdr, tname, tnlen);
    if (idx < 0) {
        patra_unlock(fd);
        return PATRA_ERR_NOTFOUND;
    }

    var entry = _tbl_entry(hdr, idx);
    var spg = load64(entry + TBL_SCHEMA);
    var schema = pg_alloc();
    page_read(fd, spg, schema);
    var ncols = load64(schema + SCH_NCOLS);
    var rsz = row_compute_size(schema, ncols);

    var r = tbl_delete(fd, hdr, idx, rsz, schema, ncols, _sql_pr);
    pg_free(schema);

    _db_hdr_commit(db, fd, hdr);
    patra_unlock(fd);
    return r;
}

# ── Exec: DROP TABLE ────────────────────

fn _exec_drop(db): i64 {
    var fd = _db_fd(db);
    var hdr = _db_hdr(db);

    patra_lock_ex(fd);
    patra_hdr_read(fd, hdr);

    var tname = load64(_sql_pr + PR_TNAME);
    var tnlen = load64(_sql_pr + PR_TNLEN);
    var idx = tbl_find(hdr, tname, tnlen);
    if (idx < 0) {
        patra_unlock(fd);
        return PATRA_ERR_NOTFOUND;
    }

    var r = tbl_drop(fd, hdr, idx);
    if (r == PATRA_OK) { _db_hdr_commit(db, fd, hdr); }
    patra_unlock(fd);
    return r;
}

# ── Exec: ALTER TABLE ────────────────────

# ALTER TABLE t RENAME TO new
fn _exec_alter_rename_tbl(db): i64 {
    var fd = _db_fd(db);
    var hdr = _db_hdr(db);

    patra_lock_ex(fd);
    patra_hdr_read(fd, hdr);

    var tname = load64(_sql_pr + PR_TNAME);
    var tnlen = load64(_sql_pr + PR_TNLEN);
    var idx = tbl_find(hdr, tname, tnlen);
    if (idx < 0) { patra_unlock(fd); return PATRA_ERR_NOTFOUND; }

    var it = _sql_pr + PR_ITEMS;
    var new_ptr = load64(it + CR_NPTR);
    var new_len = load64(it + CR_NLEN);

    # Reject if new name collides with any existing table
    if (tbl_find(hdr, new_ptr, new_len) >= 0) {
        patra_unlock(fd);
        return PATRA_ERR_EXISTS;
    }

    var entry = _tbl_entry(hdr, idx);
    var nn = new_len;
    if (nn > TBL_NAME_MAX - 1) { nn = TBL_NAME_MAX - 1; }
    memset(entry + TBL_NAME, 0, TBL_NAME_MAX);
    memcpy(entry + TBL_NAME, new_ptr, nn);
    store8(entry + TBL_NAME + nn, 0);

    _db_hdr_commit(db, fd, hdr);
    patra_unlock(fd);
    return PATRA_OK;
}

# ALTER TABLE t RENAME COLUMN old TO new
fn _exec_alter_rename_col(db): i64 {
    var fd = _db_fd(db);
    var hdr = _db_hdr(db);

    patra_lock_ex(fd);
    patra_hdr_read(fd, hdr);

    var tname = load64(_sql_pr + PR_TNAME);
    var tnlen = load64(_sql_pr + PR_TNLEN);
    var idx = tbl_find(hdr, tname, tnlen);
    if (idx < 0) { patra_unlock(fd); return PATRA_ERR_NOTFOUND; }

    var entry = _tbl_entry(hdr, idx);
    var spg = load64(entry + TBL_SCHEMA);
    var schema = pg_alloc();
    page_read(fd, spg, schema);
    var ncols = load64(schema + SCH_NCOLS);

    var it_old = _sql_pr + PR_ITEMS;
    var it_new = _sql_pr + PR_ITEMS + CR_SZ;
    var old_ptr = load64(it_old + CR_NPTR);
    var old_len = load64(it_old + CR_NLEN);
    var new_ptr = load64(it_new + CR_NPTR);
    var new_len = load64(it_new + CR_NLEN);

    var ci = _wh_resolve_col(schema, ncols, old_ptr, old_len);
    if (ci < 0) { pg_free(schema); patra_unlock(fd); return PATRA_ERR_NOTFOUND; }

    # Reject if new name collides with another existing column
    var collide = _wh_resolve_col(schema, ncols, new_ptr, new_len);
    if (collide >= 0) {
        if (collide != ci) {
            pg_free(schema);
            patra_unlock(fd);
            return PATRA_ERR_EXISTS;
        }
    }

    var cn = new_len;
    if (cn > SCH_CNAME_MAX - 1) { cn = SCH_CNAME_MAX - 1; }
    var coff = SCH_START + ci * SCH_ENTRY_SZ + SCH_CNAME;
    memset(schema + coff, 0, SCH_CNAME_MAX);
    memcpy(schema + coff, new_ptr, cn);
    store8(schema + coff + cn, 0);

    page_write(fd, spg, schema);
    pg_free(schema);
    patra_unlock(fd);
    return PATRA_OK;
}

# ALTER TABLE t ADD COLUMN name INT|STR
# Gathers all rows, frees old data+btree pages, rewrites schema, re-inserts rows
# with the default value (0 / empty string) in the new trailing column. The B-tree
# is rebuilt when the table had an index.
fn _exec_alter_add(db): i64 {
    var fd = _db_fd(db);
    var hdr = _db_hdr(db);

    patra_lock_ex(fd);
    patra_hdr_read(fd, hdr);

    var tname = load64(_sql_pr + PR_TNAME);
    var tnlen = load64(_sql_pr + PR_TNLEN);
    var idx = tbl_find(hdr, tname, tnlen);
    if (idx < 0) { patra_unlock(fd); return PATRA_ERR_NOTFOUND; }

    var entry = _tbl_entry(hdr, idx);
    var spg = load64(entry + TBL_SCHEMA);
    var schema = pg_alloc();
    page_read(fd, spg, schema);
    var ncols_old = load64(schema + SCH_NCOLS);
    if (ncols_old >= MAX_COLS) {
        pg_free(schema);
        patra_unlock(fd);
        return PATRA_ERR_COLCOUNT;
    }

    var it = _sql_pr + PR_ITEMS;
    var nc_ptr = load64(it + CR_NPTR);
    var nc_len = load64(it + CR_NLEN);
    var nc_type = load64(it + CR_TYPE);

    # Reject if the new column name already exists
    if (_wh_resolve_col(schema, ncols_old, nc_ptr, nc_len) >= 0) {
        pg_free(schema);
        patra_unlock(fd);
        return PATRA_ERR_EXISTS;
    }

    var rsz_old = row_compute_size(schema, ncols_old);
    var rsz_new = rsz_old + row_col_size(nc_type);
    var nrows = load64(entry + TBL_NROWS);

    # Stage rows into a scratch buffer with the default (zero) trailing field
    var scratch = 0;
    if (nrows > 0) {
        scratch = fl_alloc(nrows * rsz_new);
        memset(scratch, 0, nrows * rsz_new);
    }
    var buf = pg_alloc();
    var cur = load64(entry + TBL_ROOT);
    var written = 0;
    while (cur != 0) {
        page_read(fd, cur, buf);
        var pn = load64(buf + DP_NROWS);
        for (var i = 0; i < pn; i = i + 1) {
            memcpy(scratch + written * rsz_new,
            buf + DP_DATA + i * rsz_old, rsz_old);
            written = written + 1;
        }
        cur = load64(buf + DP_NEXT);
    }

    # Release old data pages
    _tbl_lp_idx = 0 - 1;
    cur = load64(entry + TBL_ROOT);
    while (cur != 0) {
        page_read(fd, cur, buf);
        var nx = load64(buf + DP_NEXT);
        page_free(fd, hdr, cur);
        cur = nx;
    }
    pg_free(buf);

    # Release B-tree root (internal/leaf pages leak — matches tbl_drop behavior)
    var ic = load64(schema + SCH_IDX_COL);
    var ir_old = load64(schema + SCH_IDX_ROOT);
    if (ic >= 0) {
        if (ir_old != 0) { btree_free_all(fd, hdr, ir_old); }
    }

    # Append new column entry to schema
    var soff = SCH_START + ncols_old * SCH_ENTRY_SZ;
    memset(schema + soff, 0, SCH_ENTRY_SZ);
    var cn = nc_len;
    if (cn > SCH_CNAME_MAX - 1) { cn = SCH_CNAME_MAX - 1; }
    memcpy(schema + soff + SCH_CNAME, nc_ptr, cn);
    store8(schema + soff + SCH_CNAME + cn, 0);
    store64(schema + soff + SCH_CTYPE, nc_type);
    var ncols_new = ncols_old + 1;
    store64(schema + SCH_NCOLS, ncols_new);

    # Fresh empty data page as root, fresh B-tree if originally indexed
    var new_root = page_alloc(fd, hdr);
    var nbuf = pg_alloc();
    page_init_data(nbuf);
    page_write(fd, new_root, nbuf);
    pg_free(nbuf);
    if (ic >= 0) {
        var bt_new = btree_create(fd, hdr);
        store64(schema + SCH_IDX_ROOT, bt_new);
    }

    store64(entry + TBL_NCOLS, ncols_new);
    store64(entry + TBL_ROOT, new_root);
    store64(entry + TBL_NROWS, 0);

    # Re-insert rows; each insert updates TBL_NROWS and the B-tree
    for (var ri = 0; ri < nrows; ri = ri + 1) {
        var rp = scratch + ri * rsz_new;
        tbl_insert(fd, hdr, idx, rp, rsz_new);
        if (ic >= 0) {
            var ir_now = load64(schema + SCH_IDX_ROOT);
            if (ir_now != 0) {
                var ikey = _idx_key_from_row(schema, ncols_new, ic, rp);
                var nr = btree_insert(fd, hdr, ir_now, ikey, _tbl_last_ref);
                if (nr != ir_now) { store64(schema + SCH_IDX_ROOT, nr); }
            }
        }
    }

    page_write(fd, spg, schema);
    if (nrows > 0) { fl_free(scratch); }
    pg_free(schema);
    _db_hdr_commit(db, fd, hdr);
    patra_unlock(fd);
    return PATRA_OK;
}

# ALTER TABLE t DROP COLUMN name
# Mirrors _exec_alter_add but skips the dropped column's bytes and adjusts
# the index. If the dropped column WAS the indexed column, the index is
# torn down. If the dropped column PRECEDES the indexed column in schema
# order, SCH_IDX_COL shifts left by one. In all surviving-index cases the
# B-tree is rebuilt because refs change with row rewriting.
fn _exec_alter_drop_col(db): i64 {
    var fd = _db_fd(db);
    var hdr = _db_hdr(db);

    patra_lock_ex(fd);
    patra_hdr_read(fd, hdr);

    var tname = load64(_sql_pr + PR_TNAME);
    var tnlen = load64(_sql_pr + PR_TNLEN);
    var idx = tbl_find(hdr, tname, tnlen);
    if (idx < 0) { patra_unlock(fd); return PATRA_ERR_NOTFOUND; }

    var entry = _tbl_entry(hdr, idx);
    var spg = load64(entry + TBL_SCHEMA);
    var schema = pg_alloc();
    page_read(fd, spg, schema);
    var ncols_old = load64(schema + SCH_NCOLS);
    if (ncols_old <= 1) {
        pg_free(schema);
        patra_unlock(fd);
        return PATRA_ERR_COLCOUNT;
    }

    var it = _sql_pr + PR_ITEMS;
    var dc_ptr = load64(it + CR_NPTR);
    var dc_len = load64(it + CR_NLEN);
    var di = _wh_resolve_col(schema, ncols_old, dc_ptr, dc_len);
    if (di < 0) {
        pg_free(schema);
        patra_unlock(fd);
        return PATRA_ERR_NOTFOUND;
    }

    var dctype = load64(schema + SCH_START + di * SCH_ENTRY_SZ + SCH_CTYPE);
    var rsz_old = row_compute_size(schema, ncols_old);
    var drop_off = row_field_offset(schema, ncols_old, di);
    var drop_sz = row_col_size(dctype);
    var rsz_new = rsz_old - drop_sz;
    var post_sz = rsz_old - drop_off - drop_sz;
    var nrows = load64(entry + TBL_NROWS);

    # Stage rows: copy pre-drop bytes then post-drop bytes. If the dropped
    # column is a BLOB, free each row's chain first — those pages become
    # orphans otherwise. Surviving BLOB columns keep their chains untouched;
    # the ref bytes (page, length) are preserved by the memcpy-around-drop.
    var scratch = 0;
    if (nrows > 0) {
        scratch = fl_alloc(nrows * rsz_new);
        memset(scratch, 0, nrows * rsz_new);
    }
    var buf = pg_alloc();
    var cur = load64(entry + TBL_ROOT);
    var written = 0;
    while (cur != 0) {
        page_read(fd, cur, buf);
        var pn = load64(buf + DP_NROWS);
        for (var i = 0; i < pn; i = i + 1) {
            var src = buf + DP_DATA + i * rsz_old;
            if (dctype == COL_BYTES) {
                var dr_pg = row_read_bytes_page(src, drop_off);
                if (dr_pg != 0) { _bytes_free_chain(fd, hdr, dr_pg); }
            }
            var dst = scratch + written * rsz_new;
            if (drop_off > 0) { memcpy(dst, src, drop_off); }
            if (post_sz > 0) {
                memcpy(dst + drop_off, src + drop_off + drop_sz, post_sz);
            }
            written = written + 1;
        }
        cur = load64(buf + DP_NEXT);
    }

    # Release old data pages
    _tbl_lp_idx = 0 - 1;
    cur = load64(entry + TBL_ROOT);
    while (cur != 0) {
        page_read(fd, cur, buf);
        var nx = load64(buf + DP_NEXT);
        page_free(fd, hdr, cur);
        cur = nx;
    }
    pg_free(buf);

    # Release B-tree root (pre-existing tbl_drop pattern: internal/leaf pages leak)
    var ic_old = load64(schema + SCH_IDX_COL);
    var ir_old = load64(schema + SCH_IDX_ROOT);
    if (ic_old >= 0) {
        if (ir_old != 0) { btree_free_all(fd, hdr, ir_old); }
    }

    # Shift schema column entries left and zero the tail
    var ncols_new = ncols_old - 1;
    for (var i = di; i < ncols_new; i = i + 1) {
        var dsoff = SCH_START + i * SCH_ENTRY_SZ;
        var ssoff = SCH_START + (i + 1) * SCH_ENTRY_SZ;
        memcpy(schema + dsoff, schema + ssoff, SCH_ENTRY_SZ);
    }
    memset(schema + SCH_START + ncols_new * SCH_ENTRY_SZ, 0, SCH_ENTRY_SZ);
    store64(schema + SCH_NCOLS, ncols_new);

    # Recompute index column: tear down if dropped, shift if it followed
    var ic_new = 0 - 1;
    if (ic_old >= 0) {
        if (ic_old == di) { ic_new = 0 - 1; }
        elif (ic_old > di) { ic_new = ic_old - 1; }
        else { ic_new = ic_old; }
    }
    store64(schema + SCH_IDX_COL, ic_new);
    store64(schema + SCH_IDX_ROOT, 0);

    # Fresh empty data page + fresh B-tree if still indexed
    var new_root = page_alloc(fd, hdr);
    var nbuf = pg_alloc();
    page_init_data(nbuf);
    page_write(fd, new_root, nbuf);
    pg_free(nbuf);
    if (ic_new >= 0) {
        var bt_new = btree_create(fd, hdr);
        store64(schema + SCH_IDX_ROOT, bt_new);
    }

    store64(entry + TBL_NCOLS, ncols_new);
    store64(entry + TBL_ROOT, new_root);
    store64(entry + TBL_NROWS, 0);

    # Re-insert rows; each insert updates TBL_NROWS and the B-tree
    for (var ri = 0; ri < nrows; ri = ri + 1) {
        var rp = scratch + ri * rsz_new;
        tbl_insert(fd, hdr, idx, rp, rsz_new);
        if (ic_new >= 0) {
            var ir_now = load64(schema + SCH_IDX_ROOT);
            if (ir_now != 0) {
                var ikey = _idx_key_from_row(schema, ncols_new, ic_new, rp);
                var nr = btree_insert(fd, hdr, ir_now, ikey, _tbl_last_ref);
                if (nr != ir_now) { store64(schema + SCH_IDX_ROOT, nr); }
            }
        }
    }

    page_write(fd, spg, schema);
    if (nrows > 0) { fl_free(scratch); }
    pg_free(schema);
    _db_hdr_commit(db, fd, hdr);
    patra_unlock(fd);
    return PATRA_OK;
}

# ── Exec: VACUUM ────────────────────

fn _exec_vacuum(db): i64 {
    var fd = _db_fd(db);
    var hdr = _db_hdr(db);

    patra_lock_ex(fd);
    patra_hdr_read(fd, hdr);

    var tname = load64(_sql_pr + PR_TNAME);
    var tnlen = load64(_sql_pr + PR_TNLEN);
    var idx = tbl_find(hdr, tname, tnlen);
    if (idx < 0) { patra_unlock(fd); return PATRA_ERR_NOTFOUND; }

    var entry = _tbl_entry(hdr, idx);
    var spg = load64(entry + TBL_SCHEMA);
    var schema = pg_alloc();
    page_read(fd, spg, schema);
    var ic = load64(schema + SCH_IDX_COL);
    var ir = load64(schema + SCH_IDX_ROOT);
    pg_free(schema);

    if (ic >= 0) {
        if (ir != 0) {
            btree_compact(fd, hdr, ir);
        }
    }
    patra_unlock(fd);
    return PATRA_OK;
}

# ── Exec: CREATE INDEX ────────────────────

fn _exec_create_index(db): i64 {
    var fd = _db_fd(db);
    var hdr = _db_hdr(db);

    patra_lock_ex(fd);
    patra_hdr_read(fd, hdr);

    var tname = load64(_sql_pr + PR_TNAME);
    var tnlen = load64(_sql_pr + PR_TNLEN);
    var idx = tbl_find(hdr, tname, tnlen);
    if (idx < 0) { patra_unlock(fd); return PATRA_ERR_NOTFOUND; }

    var entry = _tbl_entry(hdr, idx);
    var spg = load64(entry + TBL_SCHEMA);
    var schema = pg_alloc();
    page_read(fd, spg, schema);
    var ncols = load64(schema + SCH_NCOLS);

    # Resolve column name
    var cn_ptr = load64(_sql_pr + PR_ITEMS);
    var cn_len = load64(_sql_pr + PR_ITEMS + 8);
    var ci = _wh_resolve_col(schema, ncols, cn_ptr, cn_len);
    if (ci < 0) { pg_free(schema); patra_unlock(fd); return PATRA_ERR_NOTFOUND; }

    # INT columns index by raw i64; STR columns index by hash of the
    # 256-byte slot (collisions verified at lookup via where_eval / byte
    # compare). BYTES columns can't be indexed.
    var ct = load64(schema + SCH_START + ci * SCH_ENTRY_SZ + SCH_CTYPE);
    if (ct == COL_BYTES) { pg_free(schema); patra_unlock(fd); return PATRA_ERR_TYPE; }

    # Create B-tree and populate with existing rows
    var bt = btree_create(fd, hdr);
    var rsz = row_compute_size(schema, ncols);
    var cur = load64(entry + TBL_ROOT);
    var pbuf = pg_alloc();

    while (cur != 0) {
        page_read(fd, cur, pbuf);
        var nrows = load64(pbuf + DP_NROWS);
        for (var i = 0; i < nrows; i = i + 1) {
            var rp = pbuf + DP_DATA + i * rsz;
            var key = _idx_key_from_row(schema, ncols, ci, rp);
            bt = btree_insert(fd, hdr, bt, key, _bt_mkref(cur, i));
        }
        cur = load64(pbuf + DP_NEXT);
    }
    pg_free(pbuf);

    # Store index in schema page
    store64(schema + SCH_IDX_COL, ci);
    store64(schema + SCH_IDX_ROOT, bt);
    page_write(fd, spg, schema);
    pg_free(schema);

    _db_hdr_commit(db, fd, hdr);
    patra_unlock(fd);
    return PATRA_OK;
}

# ── Transactions ────────────────────

# Begin an explicit transaction (lock + WAL)
fn patra_begin(db): i64 {
    if (load64(db + DB_TX)) { return PATRA_OK; }
    var fd = _db_fd(db);
    var wpath = load64(db + DB_PATH);
    patra_lock_ex(fd);
    patra_hdr_read(fd, _db_hdr(db));
    wal_start(fd, wpath);
    store64(db + DB_TX, 1);
    return PATRA_OK;
}

# Commit transaction (sync + unlock)
fn patra_commit(db): i64 {
    if (load64(db + DB_TX) == 0) { return PATRA_OK; }
    var fd = _db_fd(db);
    var wpath = load64(db + DB_PATH);
    var overflow = wal_overflowed();
    patra_hdr_write(fd, _db_hdr(db));
    wal_commit(wpath);
    patra_unlock(fd);
    store64(db + DB_TX, 0);
    if (overflow != 0) { return PATRA_ERR_FULL; }
    return PATRA_OK;
}

# Rollback transaction (restore pages + unlock)
fn patra_rollback(db): i64 {
    if (load64(db + DB_TX) == 0) { return PATRA_OK; }
    var wpath = load64(db + DB_PATH);
    wal_rollback(wpath);
    patra_hdr_read(_db_fd(db), _db_hdr(db));
    patra_unlock(_db_fd(db));
    store64(db + DB_TX, 0);
    return PATRA_OK;
}

# ── patra_exec ────────────────────

# Execute a DDL/DML SQL statement
fn patra_exec(db, sql): i64 {
    if (db == 0) { return PATRA_ERR_IO; }
    sql_tokenize(sql);
    var r = sql_parse();
    if (r != PATRA_OK) { return r; }

    var stmt = load64(_sql_pr + PR_STMT);
    if (stmt == STMT_CREATE) { return _exec_create(db); }
    if (stmt == STMT_INSERT) { return _exec_insert(db); }
    if (stmt == STMT_UPDATE) { return _exec_update(db); }
    if (stmt == STMT_DELETE) { return _exec_delete(db); }
    if (stmt == STMT_CREATE_INDEX) { return _exec_create_index(db); }
    if (stmt == STMT_DROP) { return _exec_drop(db); }
    if (stmt == STMT_VACUUM) { return _exec_vacuum(db); }
    if (stmt == STMT_ALTER_ADD) { return _exec_alter_add(db); }
    if (stmt == STMT_ALTER_RENAME_TBL) { return _exec_alter_rename_tbl(db); }
    if (stmt == STMT_ALTER_RENAME_COL) { return _exec_alter_rename_col(db); }
    if (stmt == STMT_ALTER_DROP_COL) { return _exec_alter_drop_col(db); }
    return PATRA_ERR_SYNTAX;
}

# ── Sorting for ORDER BY ────────────────────

fn _strcmp_nn(a, b): i64 {
    var i = 0;
    while (1) {
        var ca = load8(a + i);
        var cb = load8(b + i);
        if (ca != cb) { return ca - cb; }
        if (ca == 0) { return 0; }
        i = i + 1;
    }
    return 0;
}

fn _rs_field_off(rs, col): i64 {
    var types = load64(rs + RS_TYPES);
    var off = 0;
    for (var i = 0; i < col; i = i + 1) {
        var t = load64(types + i * 8);
        if (t == COL_INT)       { off = off + COL_INT_SZ; }
        elif (t == COL_BYTES)    { off = off + COL_BYTES_SZ; }
        else                    { off = off + COL_STR_SZ; }
    }
    return off;
}

# Compare two rows on multiple ORDER BY columns. Returns >0 if a should come after b.
fn _cmp_rows(rs, ra, rb, ob_idxs, ob_types, ob_dirs, obn): i64 {
    for (var k = 0; k < obn; k = k + 1) {
        var ci = load64(ob_idxs + k * 8);
        var ct = load64(ob_types + k * 8);
        var dr = load64(ob_dirs + k * 8);
        var off = _rs_field_off(rs, ci);
        var c = 0;
        if (ct == COL_INT) {
            var a = load64(ra + off);
            var b = load64(rb + off);
            if (a > b) { c = 1; }
            elif (a < b) { c = 0 - 1; }
        } else {
            c = _strcmp_nn(ra + off, rb + off);
        }
        if (dr != 0) { c = 0 - c; }
        if (c != 0) { return c; }
    }
    return 0;
}

fn _sort_result_multi(rs, ob_idxs, ob_types, ob_dirs, obn): i64 {
    var data = load64(rs + RS_DATA);
    var rsz = load64(rs + RS_ROWSZ);
    var nrows = load64(rs + RS_NROWS);
    if (nrows <= 1) { return 0; }

    var tmp = fl_alloc(rsz);
    for (var i = 1; i < nrows; i = i + 1) {
        memcpy(tmp, data + i * rsz, rsz);
        var j = i - 1;
        while (j >= 0) {
            var c = _cmp_rows(rs, data + j * rsz, tmp, ob_idxs, ob_types, ob_dirs, obn);
            if (c <= 0) { break; }
            memcpy(data + (j + 1) * rsz, data + j * rsz, rsz);
            j = j - 1;
        }
        memcpy(data + (j + 1) * rsz, tmp, rsz);
    }
    fl_free(tmp);
    return 0;
}

# ── patra_query (SELECT with WHERE, ORDER BY, LIMIT) ────────

# Execute a SELECT query, returns result set
fn patra_query(db, sql): i64 {
    if (db == 0) { return 0; }
    sql_tokenize(sql);
    var r = sql_parse();
    if (r != PATRA_OK) { return 0; }
    if (load64(_sql_pr + PR_STMT) != STMT_SELECT) { return 0; }
    return _patra_query_exec(db);
}

fn _patra_query_exec(db): i64 {
    var fd = _db_fd(db);
    var hdr = _db_hdr(db);

    patra_lock_sh(fd);
    patra_hdr_read(fd, hdr);

    var tname = load64(_sql_pr + PR_TNAME);
    var tnlen = load64(_sql_pr + PR_TNLEN);
    var idx = tbl_find(hdr, tname, tnlen);
    if (idx < 0) {
        patra_unlock(fd);
        return 0;
    }

    var entry = _tbl_entry(hdr, idx);
    var ncols = load64(entry + TBL_NCOLS);
    var nrows = load64(entry + TBL_NROWS);
    var spg = load64(entry + TBL_SCHEMA);

    var schema = pg_alloc();
    page_read(fd, spg, schema);
    var rsz = row_compute_size(schema, ncols);

    # Check for aggregate query
    var agg = load64(_sql_pr + PR_AGG_TYPE);
    if (agg != AGG_NONE) {
        # Compute aggregate over matching rows
        var agg_val = 0;
        var agg_count = 0;
        var agg_init = 0;
        var agg_off = 0;
        if (agg != AGG_COUNT) {
            var aci = _wh_resolve_col(schema, ncols,
            load64(_sql_pr + PR_AGG_COL_PTR), load64(_sql_pr + PR_AGG_COL_LEN));
            if (aci < 0) { pg_free(schema); patra_unlock(fd); return 0; }
            agg_off = row_field_offset(schema, ncols, aci);
        }

        var acur = load64(entry + TBL_ROOT);
        var abuf = pg_alloc();
        while (acur != 0) {
            page_read(fd, acur, abuf);
            var anr = load64(abuf + DP_NROWS);
            for (var ai = 0; ai < anr; ai = ai + 1) {
                var arp = abuf + DP_DATA + ai * rsz;
                if (where_eval(arp, schema, ncols, _sql_pr)) {
                    agg_count = agg_count + 1;
                    if (agg != AGG_COUNT) {
                        var av = row_read_int(arp, agg_off);
                        if (agg == AGG_SUM) { agg_val = agg_val + av; }
                        elif (agg_init == 0) { agg_val = av; agg_init = 1; }
                        elif (agg == AGG_MIN) { if (av < agg_val) { agg_val = av; } }
                        elif (agg == AGG_MAX) { if (av > agg_val) { agg_val = av; } }
                    }
                }
            }
            acur = load64(abuf + DP_NEXT);
        }
        pg_free(abuf);
        pg_free(schema);
        patra_unlock(fd);

        if (agg == AGG_COUNT) { agg_val = agg_count; }

        # Build 1-row, 1-column result
        var ars = fl_alloc(RS_HDR_SZ + 8 + 32 + 8);
        memset(ars, 0, RS_HDR_SZ + 8 + 32 + 8);
        store64(ars + RS_NCOLS, 1);
        store64(ars + RS_NROWS, 1);
        store64(ars + RS_TYPES, ars + RS_HDR_SZ);
        store64(ars + RS_NAMES, ars + RS_HDR_SZ + 8);
        store64(ars + RS_ROWSZ, 8);
        store64(ars + RS_DATA, ars + RS_HDR_SZ + 8 + 32);
        store64(ars + RS_HDR_SZ, COL_INT);
        # Column name based on aggregate type
        var aname = ars + RS_HDR_SZ + 8;
        if (agg == AGG_COUNT) { memcpy(aname, "count", 5); }
        elif (agg == AGG_SUM) { memcpy(aname, "sum", 3); }
        elif (agg == AGG_MIN) { memcpy(aname, "min", 3); }
        elif (agg == AGG_MAX) { memcpy(aname, "max", 3); }
        store64(ars + RS_HDR_SZ + 8 + 32, agg_val);
        return ars;
    }

    # Allocate result for worst case (all rows)
    var total = RS_HDR_SZ + ncols * 8 + ncols * SCH_CNAME_MAX + nrows * rsz;
    if (total < RS_HDR_SZ + 64) { total = RS_HDR_SZ + 64; }
    var rs = fl_alloc(total);
    memset(rs, 0, total);

    var types_ptr = rs + RS_HDR_SZ;
    var names_ptr = types_ptr + ncols * 8;
    var data_ptr  = names_ptr + ncols * SCH_CNAME_MAX;

    store64(rs + RS_NCOLS, ncols);
    store64(rs + RS_TYPES, types_ptr);
    store64(rs + RS_NAMES, names_ptr);
    store64(rs + RS_ROWSZ, rsz);
    store64(rs + RS_DATA, data_ptr);

    # Copy schema info
    for (var i = 0; i < ncols; i = i + 1) {
        var soff = SCH_START + i * SCH_ENTRY_SZ;
        store64(types_ptr + i * 8, load64(schema + soff + SCH_CTYPE));
        memcpy(names_ptr + i * SCH_CNAME_MAX, schema + soff + SCH_CNAME, SCH_CNAME_MAX);
    }

    # Try B-tree index for WHERE on indexed column
    var actual = 0;
    var used_index = 0;
    var ic = load64(schema + SCH_IDX_COL);
    if (ic >= ncols) { ic = 0 - 1; }
    if (ic >= 0) {
        var ir = load64(schema + SCH_IDX_ROOT);
        if (ir != 0) {
            var wn = load64(_sql_pr + PR_WHERE_N);
            var wjoin_ok = 0;
            if (wn == 1) { wjoin_ok = 1; }
            elif (load64(_sql_pr + PR_WHERE_JOIN) == WH_AND) { wjoin_ok = 1; }
            if (wjoin_ok != 0) {
                # Scan WHERE conditions for indexed column — build range [lo, hi]
                var icn = schema + SCH_START + ic * SCH_ENTRY_SZ + SCH_CNAME;
                var icnl = strlen(icn);
                var idx_lo = 0 - (1 << 62);
                var idx_hi = 1 << 62;
                var idx_found = 0;
                # Indexed col is INT or STR (post-1.7.1). STR keys are
                # hashed, so only equality narrows the range; range ops
                # over hashed keys would be meaningless. INT keys keep the
                # full equality + range range. The where_eval re-check
                # downstream byte-compares STR values, filtering any hash
                # collisions correctly.
                var ictype_eq = load64(schema + SCH_START + ic * SCH_ENTRY_SZ + SCH_CTYPE);
                for (var wi = 0; wi < wn; wi = wi + 1) {
                    var cond = _sql_pr + PR_WHERE + wi * WH_ENTRY_SZ;
                    var cptr = load64(cond + WH_COL_PTR);
                    var clen = load64(cond + WH_COL_LEN);
                    if (clen == icnl) {
                        if (memeq(cptr, icn, clen)) {
                            if (load64(cond + WH_VAL_TYPE) == COL_INT) {
                                if (ictype_eq == COL_INT) {
                                    var op = load64(cond + WH_CMP_OP);
                                    var v = load64(cond + WH_INT_VAL);
                                    idx_found = 1;
                                    if (op == CMP_EQ)  { idx_lo = v; idx_hi = v; }
                                    elif (op == CMP_GT)  { if (v + 1 > idx_lo) { idx_lo = v + 1; } }
                                    elif (op == CMP_GTE) { if (v > idx_lo) { idx_lo = v; } }
                                    elif (op == CMP_LT)  { if (v - 1 < idx_hi) { idx_hi = v - 1; } }
                                    elif (op == CMP_LTE) { if (v < idx_hi) { idx_hi = v; } }
                                }
                            } elif (load64(cond + WH_VAL_TYPE) == COL_STR) {
                                if (ictype_eq == COL_STR) {
                                    if (load64(cond + WH_CMP_OP) == CMP_EQ) {
                                        var hk = _str_hash64(load64(cond + WH_STR_PTR),
                                        load64(cond + WH_STR_LEN));
                                        idx_lo = hk;
                                        idx_hi = hk;
                                        idx_found = 1;
                                    }
                                }
                            }
                        }
                    }
                }
                if (idx_found != 0) {
                    if (idx_lo <= idx_hi) {
                        # 1024 refs * 8 bytes = 8KB ref buffer
                        var refs = fl_alloc(8192);
                        var nrefs = _bt_range(fd, hdr, ir, idx_lo, idx_hi, refs, 1024);

                        # Selectivity-based planner: when the index returns
                        # most of the rows in the table, a full scan reads
                        # the same pages without the B-tree walk overhead.
                        # Only triggers for nrefs >= 128 so small result
                        # sets always take the index. `nrows` comes from
                        # the table directory and is maintained on every
                        # insert/delete.
                        var low_selectivity = 0;
                        if (nrefs >= 128) {
                            if (nrefs * 2 >= nrows) { low_selectivity = 1; }
                        }

                        if (nrefs >= 1024) {
                            # Index returned max refs — may be truncated, fall back to scan
                            fl_free(refs);
                        } elif (low_selectivity != 0) {
                            # Index would return >=50% of rows — scan is cheaper
                            fl_free(refs);
                        } else {
                            used_index = 1;
                            var rbuf = pg_alloc();
                            var lpg = 0 - 1;
                            for (var ri = 0; ri < nrefs; ri = ri + 1) {
                                var ref = load64(refs + ri * 8);
                                if (ref == (0 - 1)) { continue; }
                                var rpg = _bt_ref_pg(ref);
                                var rsl = _bt_ref_slot(ref);
                                if (rpg != lpg) {
                                    page_read(fd, rpg, rbuf);
                                    lpg = rpg;
                                }
                                var rp = rbuf + DP_DATA + rsl * rsz;
                                if (where_eval(rp, schema, ncols, _sql_pr)) {
                                    memcpy(data_ptr + actual * rsz, rp, rsz);
                                    actual = actual + 1;
                                }
                            }
                            pg_free(rbuf);
                            fl_free(refs);
                        }
                    }
                }
            }
        }
    }

    if (used_index == 0) {
        actual = tbl_scan_where(fd, hdr, idx, data_ptr, rsz, schema, ncols, _sql_pr);
    }
    store64(rs + RS_NROWS, actual);

    pg_free(schema);
    patra_unlock(fd);

    # ORDER BY (multi-column)
    var obn = load64(_sql_pr + PR_ORDERBY_N);
    if (obn > 0) {
        var ob_idxs = fl_alloc(obn * 8);
        var ob_types = fl_alloc(obn * 8);
        var ob_dirs = fl_alloc(obn * 8);
        var np = load64(rs + RS_NAMES);
        var ob_valid = 1;
        for (var oi = 0; oi < obn; oi = oi + 1) {
            var ob = _sql_pr + PR_ORDERBY_COLS + oi * OB_SZ;
            var ob_p = load64(ob + OB_PTR);
            var ob_l = load64(ob + OB_LEN);
            var ob_d = load64(ob + OB_DIR);
            var ci = 0 - 1;
            for (var c = 0; c < ncols; c = c + 1) {
                var cn = np + c * SCH_CNAME_MAX;
                if (strlen(cn) == ob_l) {
                    if (memeq(cn, ob_p, ob_l)) { ci = c; }
                }
            }
            if (ci < 0) { ob_valid = 0; }
            store64(ob_idxs + oi * 8, ci);
            store64(ob_types + oi * 8, load64(types_ptr + ci * 8));
            store64(ob_dirs + oi * 8, ob_d);
        }
        if (ob_valid != 0) {
            _sort_result_multi(rs, ob_idxs, ob_types, ob_dirs, obn);
        }
        fl_free(ob_idxs);
        fl_free(ob_types);
        fl_free(ob_dirs);
    }

    # LIMIT
    var lim = load64(_sql_pr + PR_LIMIT);
    if (lim > 0) {
        if (actual > lim) {
            store64(rs + RS_NROWS, lim);
        }
    }

    # Projection (SELECT col1, col2, ...). PR_PROJ_N = 0 is SELECT *, returned as-is.
    # Runs after ORDER BY / LIMIT so sort can reference columns not in the projection.
    var pjn = load64(_sql_pr + PR_PROJ_N);
    if (pjn > 0) {
        var pj_idxs = fl_alloc(pjn * 8);
        var pj_types = fl_alloc(pjn * 8);
        var pj_offs = fl_alloc(pjn * 8);
        var pj_names_src = load64(rs + RS_NAMES);
        var pj_types_src = load64(rs + RS_TYPES);
        var pj_valid = 1;
        for (var pji = 0; pji < pjn; pji = pji + 1) {
            var pj_item = _sql_pr + PR_ITEMS + pji * SEL_SZ;
            var pj_p = load64(pj_item + SEL_PTR);
            var pj_l = load64(pj_item + SEL_LEN);
            var pj_ci = 0 - 1;
            for (var pj_c = 0; pj_c < ncols; pj_c = pj_c + 1) {
                var pj_cn = pj_names_src + pj_c * SCH_CNAME_MAX;
                if (strlen(pj_cn) == pj_l) {
                    if (memeq(pj_cn, pj_p, pj_l)) { pj_ci = pj_c; }
                }
            }
            if (pj_ci < 0) { pj_valid = 0; }
            store64(pj_idxs + pji * 8, pj_ci);
            if (pj_ci >= 0) {
                store64(pj_types + pji * 8, load64(pj_types_src + pj_ci * 8));
                store64(pj_offs + pji * 8, _rs_field_off(rs, pj_ci));
            }
        }
        if (pj_valid == 0) {
            fl_free(pj_idxs);
            fl_free(pj_types);
            fl_free(pj_offs);
            fl_free(rs);
            return 0;
        }

        var pj_new_rsz = 0;
        for (var pji2 = 0; pji2 < pjn; pji2 = pji2 + 1) {
            pj_new_rsz = pj_new_rsz + row_col_size(load64(pj_types + pji2 * 8));
        }

        var pj_out_n = load64(rs + RS_NROWS);
        var pj_total = RS_HDR_SZ + pjn * 8 + pjn * SCH_CNAME_MAX + pj_out_n * pj_new_rsz;
        if (pj_total < RS_HDR_SZ + 64) { pj_total = RS_HDR_SZ + 64; }
        var rs2 = fl_alloc(pj_total);
        memset(rs2, 0, pj_total);
        var pj_t = rs2 + RS_HDR_SZ;
        var pj_nm = pj_t + pjn * 8;
        var pj_d = pj_nm + pjn * SCH_CNAME_MAX;
        store64(rs2 + RS_NCOLS, pjn);
        store64(rs2 + RS_NROWS, pj_out_n);
        store64(rs2 + RS_TYPES, pj_t);
        store64(rs2 + RS_NAMES, pj_nm);
        store64(rs2 + RS_ROWSZ, pj_new_rsz);
        store64(rs2 + RS_DATA, pj_d);

        for (var pji3 = 0; pji3 < pjn; pji3 = pji3 + 1) {
            var pj_ci3 = load64(pj_idxs + pji3 * 8);
            store64(pj_t + pji3 * 8, load64(pj_types + pji3 * 8));
            memcpy(pj_nm + pji3 * SCH_CNAME_MAX,
            pj_names_src + pj_ci3 * SCH_CNAME_MAX, SCH_CNAME_MAX);
        }

        var pj_old_data = load64(rs + RS_DATA);
        var pj_old_rsz = load64(rs + RS_ROWSZ);
        for (var pj_ri = 0; pj_ri < pj_out_n; pj_ri = pj_ri + 1) {
            var pj_src = pj_old_data + pj_ri * pj_old_rsz;
            var pj_dst = pj_d + pj_ri * pj_new_rsz;
            var pj_dst_off = 0;
            for (var pji4 = 0; pji4 < pjn; pji4 = pji4 + 1) {
                var pj_so = load64(pj_offs + pji4 * 8);
                var pj_fsz = row_col_size(load64(pj_types + pji4 * 8));
                memcpy(pj_dst + pj_dst_off, pj_src + pj_so, pj_fsz);
                pj_dst_off = pj_dst_off + pj_fsz;
            }
        }

        fl_free(pj_idxs);
        fl_free(pj_types);
        fl_free(pj_offs);
        fl_free(rs);
        return rs2;
    }

    return rs;
}

# ── Prepared statements (1.8.2) ────────────
#
# patra_exec / patra_query re-tokenize + re-parse on every call (~8-10µs
# per invocation). For consumers that run the same SQL many times — sit's
# write_typed_object loop, libro's append-events flow — patra_prepare
# parses once and patra_exec_prepared / patra_query_prepared dispatch
# directly from the cached parse result.
#
# Layout (4112 bytes per stmt): 8-byte SQL ptr + 8-byte SQL len + 4096-byte
# parse-result snapshot (mirrors `_sql_pr`). The owned SQL buffer keeps the
# pointers in the parse result valid; finalize releases both.
enum StmtOff {
    STMT_SQL = 0;
    STMT_SQL_LEN = 8;
    STMT_PR_BUF = 16;
    STMT_TOTAL_SZ = 4112;
}

# Parse `sql` once and return an opaque stmt handle, or 0 on parse error.
# The handle owns a copy of the SQL string; safe to free the input
# immediately after this call. Caller must patra_finalize when done.
# Tokenize + parse SQL once and return an opaque, reusable stmt handle.
fn patra_prepare(db, sql): i64 {
    if (db == 0) { return 0; }
    if (sql == 0) { return 0; }
    var slen = strlen(sql);
    var stmt = fl_alloc(STMT_TOTAL_SZ);
    var sbuf = fl_alloc(slen + 1);
    memcpy(sbuf, sql, slen);
    store8(sbuf + slen, 0);
    store64(stmt + STMT_SQL, sbuf);
    store64(stmt + STMT_SQL_LEN, slen);

    sql_tokenize(sbuf);
    if (sql_parse() != PATRA_OK) {
        fl_free(sbuf);
        fl_free(stmt);
        return 0;
    }
    memcpy(stmt + STMT_PR_BUF, _sql_pr, 4096);
    return stmt;
}

# Free a prepared statement and its owned SQL buffer.
fn patra_finalize(stmt): i64 {
    if (stmt == 0) { return 0; }
    var sbuf = load64(stmt + STMT_SQL);
    if (sbuf != 0) { fl_free(sbuf); }
    fl_free(stmt);
    return 0;
}

# Internal: copy the cached parse result into _sql_pr so the existing
# _exec_* / _patra_query_exec dispatch sees the prepared statement's
# tables/values. Single-threaded; the global is overwritten per call.
# Word-at-a-time copy because stdlib memcpy is byte-by-byte and 4KB
# per call would eat most of the prepare win.
fn _stmt_restore(stmt): i64 {
    var src = stmt + STMT_PR_BUF;
    var i = 0;
    while (i < 4096) {
        store64(_sql_pr + i, load64(src + i));
        i = i + 8;
    }
    return 0;
}

# Execute a prepared DDL/DML statement, skipping tokenize + parse.
fn patra_exec_prepared(db, stmt): i64 {
    if (db == 0) { return PATRA_ERR_IO; }
    if (stmt == 0) { return PATRA_ERR_SYNTAX; }
    _stmt_restore(stmt);
    var st = load64(_sql_pr + PR_STMT);
    if (st == STMT_CREATE) { return _exec_create(db); }
    if (st == STMT_INSERT) { return _exec_insert(db); }
    if (st == STMT_UPDATE) { return _exec_update(db); }
    if (st == STMT_DELETE) { return _exec_delete(db); }
    if (st == STMT_CREATE_INDEX) { return _exec_create_index(db); }
    if (st == STMT_DROP) { return _exec_drop(db); }
    if (st == STMT_VACUUM) { return _exec_vacuum(db); }
    if (st == STMT_ALTER_ADD) { return _exec_alter_add(db); }
    if (st == STMT_ALTER_RENAME_TBL) { return _exec_alter_rename_tbl(db); }
    if (st == STMT_ALTER_RENAME_COL) { return _exec_alter_rename_col(db); }
    if (st == STMT_ALTER_DROP_COL) { return _exec_alter_drop_col(db); }
    return PATRA_ERR_SYNTAX;
}

# Execute a prepared SELECT, returning a result set or 0.
fn patra_query_prepared(db, stmt): i64 {
    if (db == 0) { return 0; }
    if (stmt == 0) { return 0; }
    _stmt_restore(stmt);
    if (load64(_sql_pr + PR_STMT) != STMT_SELECT) { return 0; }
    return _patra_query_exec(db);
}

# ── Result set accessors ────────────────────

# Get number of rows in result set
fn patra_result_count(rs): i64 { return load64(rs + RS_NROWS); }
# Get number of columns in result set
fn patra_result_cols(rs): i64 { return load64(rs + RS_NCOLS); }

# Get integer value at (row, col)
fn patra_result_get_int(rs, row, col): i64 {
    var data = load64(rs + RS_DATA);
    var rsz = load64(rs + RS_ROWSZ);
    return load64(data + row * rsz + _rs_field_off(rs, col));
}

# Get string pointer at (row, col)
fn patra_result_get_str(rs, row, col): i64 {
    var data = load64(rs + RS_DATA);
    var rsz = load64(rs + RS_ROWSZ);
    return data + row * rsz + _rs_field_off(rs, col);
}

# Length of a STR value at (row, col): bounded scan over the COL_STR_SZ slot,
# stopping at the first NUL or COL_STR_SZ. Returns -1 if the column isn't STR.
# Mirrors patra_result_get_bytes_len so consumers can drop ad-hoc strnlen.
# Byte length of a STR value at (row, col), or -1 if the column isn't STR.
fn patra_result_get_str_len(rs, row, col): i64 {
    var types = load64(rs + RS_TYPES);
    if (load64(types + col * 8) != COL_STR) { return 0 - 1; }
    var data = load64(rs + RS_DATA);
    var rsz = load64(rs + RS_ROWSZ);
    var ptr = data + row * rsz + _rs_field_off(rs, col);
    var n = 0;
    while (n < COL_STR_SZ) {
        if (load8(ptr + n) == 0) { return n; }
        n = n + 1;
    }
    return COL_STR_SZ;
}

# Get column name at index
fn patra_result_col_name(rs, col): i64 {
    var names = load64(rs + RS_NAMES);
    return names + col * SCH_CNAME_MAX;
}

# Get column type at index (COL_INT or COL_STR)
fn patra_result_col_type(rs, col): i64 {
    var types = load64(rs + RS_TYPES);
    return load64(types + col * 8);
}

# Get column type at index (COL_INT or COL_STR)
# Length of a BLOB value at (row, col). Returns -1 if the column isn't BLOB.
fn patra_result_get_bytes_len(rs, row, col): i64 {
    var types = load64(rs + RS_TYPES);
    if (load64(types + col * 8) != COL_BYTES) { return 0 - 1; }
    var data = load64(rs + RS_DATA);
    var rsz = load64(rs + RS_ROWSZ);
    return load64(data + row * rsz + _rs_field_off(rs, col) + BR_LEN);
}

# Read a BLOB column's payload into `out` (caller-allocated, must be at
# least `patra_result_get_bytes_len(rs, row, col)` bytes). Returns PATRA_OK,
# PATRA_ERR_TYPE for non-BLOB columns, or PATRA_ERR_PAGE on a malformed
# chain. The empty blob (length 0) returns PATRA_OK with no bytes read.
# Read a BYTES column's payload into a caller-allocated `out` buffer.
fn patra_result_read_bytes(db, rs, row, col, out): i64 {
    var types = load64(rs + RS_TYPES);
    if (load64(types + col * 8) != COL_BYTES) { return PATRA_ERR_TYPE; }
    var data = load64(rs + RS_DATA);
    var rsz = load64(rs + RS_ROWSZ);
    var ref = data + row * rsz + _rs_field_off(rs, col);
    var first_pg = load64(ref + BR_PAGE);
    var blen = load64(ref + BR_LEN);
    if (blen <= 0) { return PATRA_OK; }
    if (first_pg == 0) { return PATRA_ERR_PAGE; }
    return _bytes_read_chain(_db_fd(db), _db_hdr(db), first_pg, blen, out);
}

# Free result set and all buffers
fn patra_result_free(rs): i64 {
    if (rs != 0) { fl_free(rs); }
    return 0;
}

# ── Programmatic insert with BLOB support ───────────────────
#
# patra_insert_row is the only way to write rows containing BLOB columns;
# SQL INSERT/UPDATE can't carry binary payloads. For a schema with N
# columns, pass type-specific values via parallel arrays, each indexed
# 0..N-1. For column `i`, the populated slot depends on `types[i]`:
#   COL_INT  → ivals[i]
#   COL_STR  → sptrs[i] + slens[i] (byte buffer + length)
#   COL_BYTES → bptrs[i] + blens[i] (binary buffer + length; empty if 0)
# Arrays whose slots aren't consulted can be 0 (null). Returns PATRA_OK,
# PATRA_ERR_NOTFOUND, PATRA_ERR_COLCOUNT, or PATRA_ERR_TYPE.
# Programmatic row insert; the only path that can write BYTES columns.
fn patra_insert_row(db, tname, tnlen, ncols, types, ivals, sptrs, slens, bptrs, blens): i64 {
    var fd = _db_fd(db);
    var hdr = _db_hdr(db);

    patra_lock_ex(fd);
    patra_hdr_read(fd, hdr);

    var idx = tbl_find(hdr, tname, tnlen);
    if (idx < 0) { patra_unlock(fd); return PATRA_ERR_NOTFOUND; }

    var entry = _tbl_entry(hdr, idx);
    var spg = load64(entry + TBL_SCHEMA);
    var schema = pg_alloc();
    page_read(fd, spg, schema);

    var scols = load64(schema + SCH_NCOLS);
    if (ncols != scols) {
        pg_free(schema); patra_unlock(fd); return PATRA_ERR_COLCOUNT;
    }

    # Type-match every column before we write anything on disk
    for (var i = 0; i < ncols; i = i + 1) {
        var ctype = load64(schema + SCH_START + i * SCH_ENTRY_SZ + SCH_CTYPE);
        var vtype = load64(types + i * 8);
        if (vtype != ctype) {
            pg_free(schema); patra_unlock(fd); return PATRA_ERR_TYPE;
        }
    }

    var rsz = row_compute_size(schema, scols);
    var row = fl_alloc(rsz);
    memset(row, 0, rsz);

    # Write the row. BLOB payloads write their chains here; if the insert
    # fails after any chain has been laid down, those pages will orphan.
    # Consumers should treat patra_insert_row as atomic at the row level
    # only — failure after the first BLOB chain leaks pages until the next
    # VACUUM-ish cleanup lands.
    for (var j = 0; j < ncols; j = j + 1) {
        var ctj = load64(schema + SCH_START + j * SCH_ENTRY_SZ + SCH_CTYPE);
        var off = row_field_offset(schema, scols, j);
        if (ctj == COL_INT) {
            row_write_int(row, off, load64(ivals + j * 8));
        } elif (ctj == COL_STR) {
            row_write_str(row, off, load64(sptrs + j * 8), load64(slens + j * 8));
        } else {
            var bp = load64(bptrs + j * 8);
            var bl = load64(blens + j * 8);
            var head = _bytes_write_chain(fd, hdr, bp, bl);
            row_write_bytes_ref(row, off, head, bl);
        }
    }

    var r = tbl_insert(fd, hdr, idx, row, rsz);

    if (r == PATRA_OK) {
        var ic = load64(schema + SCH_IDX_COL);
        if (ic >= 0) {
            if (ic < scols) {
                var ir = load64(schema + SCH_IDX_ROOT);
                if (ir != 0) {
                    var ikey = _idx_key_from_row(schema, scols, ic, row);
                    var nr = btree_insert(fd, hdr, ir, ikey, _tbl_last_ref);
                    if (nr != ir) {
                        store64(schema + SCH_IDX_ROOT, nr);
                        page_write(fd, spg, schema);
                    }
                }
            }
        }
    }

    fl_free(row);
    pg_free(schema);

    if (r == PATRA_OK) { _db_hdr_commit(db, fd, hdr); }
    patra_unlock(fd);
    return r;
}
