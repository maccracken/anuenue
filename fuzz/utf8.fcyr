# anuenue fuzz — M3 UTF-8 surface.
#
# Targets:
#   utf8_seq_len(read_buf, i, n)       — UTF-8 sequence length (or 0 truncated, 1 invalid)
#   utf8_decode(read_buf, i, seqlen)   — codepoint from validated sequence
#   cp_is_extending(cp)                — practical-subset combining classifier
#   cp_is_regional_indicator(cp)       — RI flag predicate
#
# Invariants the M8 audit (2026-05-22 § Finding 4) trusted:
#   - utf8_seq_len returns ∈ {0, 1, 2, 3, 4}; never larger, never negative
#   - utf8_seq_len(buf, i, n) only reads bytes in [i, n)
#   - cp_is_extending returns 0 or 1 for any i64 input (binary search safe)
#   - cp_is_regional_indicator returns 0 or 1 for any i64 input
#
# Roadmap rule (CLAUDE.md § anuenue-specific minimum):
# "UTF-8 robustness: invalid byte sequences must not panic, must not over-read".

include "src/hsv.cyr"
include "src/color.cyr"
include "src/filter.cyr"
include "src/animate.cyr"

var _fuzz_state = 0;

fn _fuzz_seed(s) {
    _fuzz_state = s;
    return 0;
}

fn _fuzz_next() {
    _fuzz_state = _fuzz_state * 6364136223846793005 + 1442695040888963407;
    return (_fuzz_state >> 33) & 255;
}

fn _fuzz_next_i64() {
    _fuzz_state = _fuzz_state * 6364136223846793005 + 1442695040888963407;
    return _fuzz_state;
}

fn _fuzz_fill(buf, len) {
    var i = 0;
    while (i < len) {
        store8(buf + i, _fuzz_next());
        i = i + 1;
    }
    return 0;
}

# Random bytes through utf8_seq_len. Every result must be one of
# {0, 1, 2, 3, 4}. Anything outside that set is a contract violation —
# the filter and pretag loops both assume seqlen ∈ those values.
fn fuzz_utf8_seq_len_random(seed) {
    _fuzz_seed(seed);
    var buf = alloc(4096);
    if (buf == 0) { return 1; }
    _fuzz_fill(buf, 4096);

    var iters = 0;
    while (iters < 4096) {
        var seqlen = utf8_seq_len(buf, iters, 4096);
        assert(seqlen >= 0, "utf8_seq_len returned negative");
        assert(seqlen <= 4, "utf8_seq_len returned > 4");
        iters = iters + 1;
    }
    return 0;
}

# Truncation behaviour: every (i, n) pair with n > i must produce a
# defined result. The critical invariant: if seqlen > 0, the function
# claims that many bytes — and must not have read past `n - i` of them.
fn fuzz_utf8_seq_len_short_buffer(seed) {
    _fuzz_seed(seed);
    var buf = alloc(1024);
    if (buf == 0) { return 1; }
    _fuzz_fill(buf, 1024);

    var i = 0;
    while (i < 1020) {
        var probe = 1;
        while (probe <= 4) {
            var n = i + probe;
            var seqlen = utf8_seq_len(buf, i, n);
            assert(seqlen >= 0, "short-buf seqlen negative");
            assert(seqlen <= 4, "short-buf seqlen > 4");
            if (seqlen > 0) {
                assert(seqlen <= n - i, "seqlen claims to span past buffer end");
            }
            probe = probe + 1;
        }
        i = i + 1;
    }
    return 0;
}

# Round-trip: any byte sequence that `utf8_seq_len` declares valid
# (seqlen in 1..4) must decode without going OOB. We walk the buffer,
# call seq_len then decode, and assert the codepoint is in the i32
# range. Malformed sequences (overlong / surrogate / above U+10FFFF)
# may still decode to garbage — graceful per the M3 contract — but
# the value is bounded by the leading byte mask.
fn fuzz_utf8_decode_validated(seed) {
    _fuzz_seed(seed);
    var buf = alloc(4096);
    if (buf == 0) { return 1; }
    _fuzz_fill(buf, 4096);

    var i = 0;
    while (i < 4096) {
        var seqlen = utf8_seq_len(buf, i, 4096);
        if (seqlen >= 1) {
            if (seqlen <= 4) {
                var cp = utf8_decode(buf, i, seqlen);
                # 4-byte UTF-8 can encode up to 0x1FFFFF; valid Unicode
                # caps at U+10FFFF. Our decoder doesn't enforce the
                # cap — graceful degradation per ADR 0003. Either way
                # the value is non-negative and below 2^21.
                assert(cp >= 0, "utf8_decode returned negative codepoint");
                assert(cp <= 0x1FFFFF, "utf8_decode returned out-of-range codepoint");
                i = i + seqlen;
            } else {
                i = i + 1;       # unreachable, loop termination guard
            }
        } else {
            i = i + 1;           # seqlen == 0 (truncated at end); skip
        }
    }
    return 0;
}

# cp_is_extending uses a binary search over a 21-entry (lo, hi) table.
# Random i64 inputs must produce a clean 0 or 1 — never a panic, never
# an OOB into the table. We don't check the *correctness* of the
# classification here (that's owned by the M3 unit tests); only that
# the function is total.
fn fuzz_cp_is_extending(seed) {
    _fuzz_seed(seed);
    var iters = 0;
    while (iters < 2000) {
        var cp = _fuzz_next_i64();
        var result = cp_is_extending(cp);
        assert(result >= 0, "cp_is_extending returned < 0");
        assert(result <= 1, "cp_is_extending returned > 1");
        iters = iters + 1;
    }
    return 0;
}

fn fuzz_cp_is_regional_indicator(seed) {
    _fuzz_seed(seed);
    var iters = 0;
    while (iters < 2000) {
        var cp = _fuzz_next_i64();
        var result = cp_is_regional_indicator(cp);
        assert(result >= 0, "cp_is_regional_indicator returned < 0");
        assert(result <= 1, "cp_is_regional_indicator returned > 1");
        iters = iters + 1;
    }
    return 0;
}

fn main(): i64 {
    alloc_init();

    var seed = 1;
    while (seed <= 5) {
        fuzz_utf8_seq_len_random(seed * 7919);
        fuzz_utf8_seq_len_short_buffer(seed * 6271);
        fuzz_utf8_decode_validated(seed * 5417);
        fuzz_cp_is_extending(seed * 4729);
        fuzz_cp_is_regional_indicator(seed * 3919);
        seed = seed + 1;
    }
    println("fuzz_utf8: invariants held across all UTF-8 surfaces");
    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
