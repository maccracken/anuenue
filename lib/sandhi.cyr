}


# --- appium.cyr ---

# sandhi/rpc/appium — Appium dialect on top of W3C WebDriver.
#
# Reference: https://appium.io/docs/en/commands/
#
# Appium extends the WebDriver wire protocol with mobile-platform
# commands (UiAutomator2 on Android, XCUITest on iOS). The base
# session / navigation / element-interaction verbs from webdriver.cyr
# apply directly; this file adds the mobile-only extensions that
# yantra's Android + iOS backends need.
#
# Kept small per CLAUDE.md "one dialect per file" guidance. When a
# consumer needs more surface, add verbs here rather than splitting.

# ================================================================
# Mobile session setup
# ================================================================

# Start a new Appium session. `platform_name` is "Android" or "iOS".
# `automation_name` is "UiAutomator2" / "XCUITest" / etc. Extra caps
# may be passed via `extra_caps_json` (a pre-built JSON object fragment
# including its braces, or 0 for none).
#
# The body shape is the W3C-compatible one Appium 2.x expects:
#   {"capabilities":{"alwaysMatch":{"platformName":"Android",
#    "appium:automationName":"UiAutomator2", ...}}}
# 1.2.4 Batch F: each verb gains an `_a` variant; bare versions
# stay as back-compat wrappers passing `default_alloc()`. Each
# `_a` threads `a` through URL build, JSON envelope build, and
# `sandhi_rpc_call_a` (paired since 1.1.0).
fn sandhi_ap_new_session_a(a, base_url, platform_name, automation_name, extra_caps_json): i64 {
    var always = sandhi_json_obj_new_a(a);
    if (always == 0) { return _sandhi_rpc_resp_new_a(a, 0, 0, 0, SANDHI_ERR_INTERNAL, 0); }
    sandhi_json_add_string_a(a, always, "platformName", platform_name);
    sandhi_json_add_string_a(a, always, "appium:automationName", automation_name);
    if (extra_caps_json != 0) {
        sandhi_json_add_raw_a(a, always, "appium:extras", extra_caps_json);
    }
    var caps = sandhi_json_obj_new_a(a);
    if (caps == 0) { return _sandhi_rpc_resp_new_a(a, 0, 0, 0, SANDHI_ERR_INTERNAL, 0); }
    sandhi_json_add_object_a(a, caps, "alwaysMatch", always);
    var root = sandhi_json_obj_new_a(a);
    if (root == 0) { return _sandhi_rpc_resp_new_a(a, 0, 0, 0, SANDHI_ERR_INTERNAL, 0); }
    sandhi_json_add_object_a(a, root, "capabilities", caps);
    return sandhi_wd_new_session_a(a, base_url, sandhi_json_build_a(a, root));
}

fn sandhi_ap_new_session(base_url, platform_name, automation_name, extra_caps_json): i64 {
    return sandhi_ap_new_session_a(default_alloc(), base_url, platform_name, automation_name, extra_caps_json);
}

