# Reboot magic
var LINUX_REBOOT_MAGIC1 = 0xFEE1DEAD;
var LINUX_REBOOT_MAGIC2 = 672274793;

# ================================================================
# struct stat layout — x86_64 layout
# (arch/x86/include/uapi/asm/stat.h, 144 bytes)
# ================================================================
# st_dev    @ 0   (8 bytes)
# st_ino    @ 8   (8 bytes)
# st_nlink  @ 16  (8 bytes)   <-- 8-byte field on x86_64; 4-byte on aarch64 generic
# st_mode   @ 24  (4 bytes)
# st_uid    @ 28  (4 bytes)
# st_gid    @ 32  (4 bytes)
# (pad)     @ 36  (4 bytes)
# st_rdev   @ 40
# st_size   @ 48  (8 bytes)
# ...
# Total = 144 bytes.
# Companion peer (aarch64) uses different offsets — consumers
# must use the Stat enum to stay arch-clean. See v5.4.11 chunk-A
# audit findings.
enum Stat {
    STAT_MODE = 24;
    STAT_NLINK = 16;
    STAT_UID = 28;
    STAT_GID = 32;
    STAT_SIZE = 48;
    STAT_MTIME = 88;
    STAT_MTIME_NSEC = 96;
    STAT_BUFSZ = 144;
}

# ================================================================
# Syscall wrappers
# ================================================================
# Body-identical wrappers shared with the aarch64 peer live in
# lib/syscalls_linux_common.cyr (~46 wrappers extracted v5.11.20).
# This peer keeps only x86_64-specific wrappers below.

include "lib/syscalls_linux_common.cyr"

# File operations — sys_open uses x86_64's bare SYS_OPEN; aarch64
# routes through openat(AT_FDCWD).
#io
fn sys_open(path, flags, mode): i64 {
    return syscall(SYS_OPEN, path, flags, mode);
}

# v5.8.6: phylax #2 backfill — sys_stat / sys_fstat to match the
# aarch64 wrapper surface (lib/syscalls_aarch64_linux.cyr:346-353).
# Pre-v5.8.6, x86_64's stdlib defined the SYS_STAT (4) / SYS_FSTAT
# (5) enum slots but exposed no wrapper fns; consumers calling
# sys_stat(path, buf) portably (relying on aarch64's wrapper to
# dispatch through the at-family) hit `undefined function 'sys_stat'`
# warnings on x86 builds. Phylax + agnosys's src/fuse.cyr both
# carried local backfills; v5.8.6 lets them drop those.
#
# x86_64 has direct stat/fstat syscalls (the aarch64 wrapper goes
# through newfstatat with AT_FDCWD because aarch64 dropped the
# direct stat in favor of the at-family). Both arches' wrappers
# now have the same (path, buf) / (fd, buf) signatures — consumer
# code is portable.
fn sys_stat(path, buf): i64 {
    return syscall(SYS_STAT, path, buf);
}

# Duplicate fd oldfd to newfd.
fn sys_dup2(oldfd, newfd): i64 {
    return syscall(SYS_DUP2, oldfd, newfd);
}

# Create a directory at path with given mode.
fn sys_mkdir(path, mode): i64 {
    return syscall(SYS_MKDIR, path, mode);
}

# Remove an empty directory.
fn sys_rmdir(path): i64 {
    return syscall(SYS_RMDIR, path);
}

# Delete a file.
fn sys_unlink(path): i64 {
    return syscall(SYS_UNLINK, path);
}

# Create a symbolic link at `linkpath` pointing to `target`.
# Returns 0 on success, negative errno on failure.
fn sys_symlink(target, linkpath): i64 {
    return syscall(SYS_SYMLINK, target, linkpath);
}

# v6.1.3 — bare-name fs peers (x86_64 has the direct syscalls; the
# aarch64 peer routes these through the at-family). Hard-link, stat
# that does NOT follow symlinks, and rename.
fn sys_link(oldpath, newpath): i64 {
    return syscall(SYS_LINK, oldpath, newpath);
}
# lstat(path, buf) — stat that does NOT follow a trailing symlink.
fn sys_lstat(path, buf): i64 {
    return syscall(SYS_LSTAT, path, buf);
}
# rename(oldpath, newpath) — single-filesystem rename/move.
fn sys_rename(oldpath, newpath): i64 {
    return syscall(SYS_RENAME, oldpath, newpath);
}

# Read the target of a symbolic link into `buf` (cap `bufsize`).
# Returns the number of bytes placed in buf (no null terminator),
# or negative errno on failure. Buf is NOT null-terminated by the
# kernel — caller must store0 if used as a cstring.
fn sys_readlink(path, buf, bufsize): i64 {
    return syscall(SYS_READLINK, path, buf, bufsize);
}

# Change file permissions.
fn sys_chmod(path, mode): i64 {
    return syscall(SYS_CHMOD, path, mode);
}

# Check file access permissions.
fn sys_access(path, mode): i64 {
    return syscall(SYS_ACCESS, path, mode);
}

# Process operations
fn sys_fork(): i64 {
    return syscall(SYS_FORK);
}

# pipe: create pipe, fds[0]=read end, fds[1]=write end
fn sys_pipe(fds): i64 {
    return syscall(SYS_PIPE, fds);
}

# Wait for a signal.
fn sys_pause(): i64 {
    return syscall(SYS_PAUSE);
}

# sys_setsid / sys_waitpid / WIFEXITED / WEXITSTATUS / WIFSIGNALED /
# WTERMSIG / sys_getuid / sys_getgid / sys_geteuid / sys_getegid /
# sys_setuid / sys_setgid / sys_setgroups / sys_setresuid /
# sys_setresgid all moved to lib/syscalls_linux_common.cyr at v5.11.20.

# sys_prctl / sys_seccomp / sys_execveat / sys_mount / sys_umount2 /
# sys_sync / sys_reboot moved to lib/syscalls_linux_common.cyr at v5.11.20.

# Signal operations
fn sigset_new(): i64 {
    var set = alloc(8);
    store64(set, 0);
    return set;
}

# sigset_add syscall wrapper.
fn sigset_add(set, signum): i64 {
    var mask = load64(set);
    mask = mask | (1 << (signum - 1));
    store64(set, mask);
    return 0;
}

# sigset_has syscall wrapper.
fn sigset_has(set, signum): i64 {
    var mask = load64(set);
    if ((mask & (1 << (signum - 1))) != 0) { return 1; }
    return 0;
}

# sys_sigprocmask / sys_signalfd / sys_epoll_create moved to
# lib/syscalls_linux_common.cyr at v5.11.20.

# epoll_event: { u32 events, u64 data } = 12 bytes
fn epoll_event_new(events, data): i64 {
    var ev = alloc(16);
    store32(ev, events);
    store64(ev + 4, data);
    return ev;
}

# sys_epoll_ctl moved to lib/syscalls_linux_common.cyr at v5.11.20.

# Wait for epoll events.
fn sys_epoll_wait(epfd, events, maxevents, timeout): i64 {
    return syscall(SYS_EPOLL_WAIT, epfd, events, maxevents, timeout);
}

# sys_timerfd_create moved to lib/syscalls_linux_common.cyr at v5.11.20.

# itimerspec: { interval: {sec, nsec}, value: {sec, nsec} } = 32 bytes
fn timerspec_new(interval_sec, initial_sec): i64 {
    var ts = alloc(32);
    store64(ts, interval_sec);
    store64(ts + 8, 0);
    store64(ts + 16, initial_sec);
    store64(ts + 24, 0);
    return ts;
}

# sys_timerfd_settime moved to lib/syscalls_linux_common.cyr at v5.11.20.

# timerfd_drain syscall wrapper.
fn timerfd_drain(fd): i64 {
    var buf[1];
    var n = sys_read(fd, &buf, 8);
    if (n == 8) { return load64(&buf); }
    return 0;
}

# Utility
fn is_err(ret): i64 {
    if (ret < 0) { return 1; }
    return 0;
}

# err_code syscall wrapper.
fn err_code(ret): i64 {
    return 0 - ret;
}

# Inotify — file system event monitoring
enum InotifyEvent {
    IN_MODIFY = 2;
    IN_CREATE = 256;
    IN_DELETE = 512;
    IN_MOVED_FROM = 64;
    IN_MOVED_TO = 128;
    IN_CLOSE_WRITE = 8;
}

# SYS_INOTIFY_INIT1 = 294, SYS_INOTIFY_ADD_WATCH = 254, SYS_INOTIFY_RM_WATCH = 255
fn sys_inotify_init(): i64 { return syscall(294, 0); }
# Add a watch on a path for inotify events
fn sys_inotify_add_watch(fd, path, mask): i64 { return syscall(254, fd, path, mask); }
# Remove an inotify watch
fn sys_inotify_rm_watch(fd, wd): i64 { return syscall(255, fd, wd); }

# sys_getdents64 / sys_getrandom / sys_landlock_create_ruleset /
# sys_landlock_add_rule / sys_landlock_restrict_self / sys_socket /
# sys_connect / sys_recvfrom / sys_recvmsg / sys_bind moved to
# lib/syscalls_linux_common.cyr at v5.11.20.

# sys_listen / sys_accept4 also moved to syscalls_linux_common.cyr at v5.11.20.
