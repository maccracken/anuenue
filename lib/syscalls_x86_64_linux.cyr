# syscalls_x86_64_linux.cyr — Linux x86_64 syscall wrappers
# Usage: include "lib/syscalls.cyr" (selector picks this peer
#        when CYRIUS_ARCH_X86 is defined; do NOT include this
#        file directly — go through the selector so cross-arch
#        builds work).
#
# Companion peer: lib/syscalls_aarch64_linux.cyr (v5.4.11+).
# Layout-affecting constants (e.g. struct stat offsets) are
# arch-dispatched; offsets in this file are the x86_64
# `arch/x86/include/uapi/asm/stat.h` values.
#
# Cyrius re-implementation of agnosys syscall bindings.
# Constants use enums to avoid gvar_toks overflow (64 slot limit).

# ================================================================
# Syscall numbers (x86_64)
# ================================================================
enum SysNr {
    SYS_READ = 0;
    SYS_WRITE = 1;
    SYS_OPEN = 2;
    SYS_CLOSE = 3;
    SYS_STAT = 4;
    SYS_FSTAT = 5;
    SYS_LSEEK = 8;
    SYS_MMAP = 9;
    SYS_BRK = 12;
    SYS_RT_SIGPROCMASK = 14;
    SYS_IOCTL = 16;
    SYS_ACCESS = 21;
    SYS_PIPE = 22;
    SYS_DUP = 32;
    SYS_DUP2 = 33;
    SYS_PAUSE = 34;
    SYS_GETPID = 39;
    SYS_FORK = 57;
    SYS_EXECVE = 59;
    SYS_EXIT = 60;
    SYS_WAIT4 = 61;
    SYS_KILL = 62;
    SYS_UNAME = 63;
    SYS_FCNTL = 72;
    SYS_GETCWD = 79;
    SYS_CHDIR = 80;
    SYS_MKDIR = 83;
    SYS_RMDIR = 84;
    SYS_UNLINK = 87;
    SYS_SYMLINK = 88;
    SYS_READLINK = 89;
    SYS_CHMOD = 90;
    SYS_FCHMOD = 91;
    SYS_GETUID = 102;
    SYS_GETGID = 104;
    SYS_SETUID = 105;
    SYS_SETGID = 106;
    SYS_GETEUID = 107;
    SYS_GETEGID = 108;
    SYS_GETPPID = 110;
    SYS_SETSID = 112;
    SYS_SETGROUPS = 116;
    SYS_SETRESUID = 117;
    SYS_SETRESGID = 119;
    SYS_PRCTL = 157;
    SYS_SYNC = 162;
    SYS_MOUNT = 165;
    SYS_UMOUNT2 = 166;
    SYS_REBOOT = 169;
    SYS_EPOLL_WAIT = 232;
    SYS_EPOLL_CTL = 233;
    SYS_WAITID = 247;
    SYS_TIMERFD_CREATE = 283;
    SYS_TIMERFD_SETTIME = 286;
    SYS_SIGNALFD4 = 289;
    SYS_EPOLL_CREATE1 = 291;
    SYS_CLONE = 56;
    SYS_MUNMAP = 11;
    SYS_FUTEX = 202;
    SYS_GETTID = 186;
    SYS_SET_TID_ADDRESS = 218;
    SYS_EXIT_GROUP = 231;
    # v5.7.35 (agnosys-surfaced — drm/luks/security)
    SYS_GETDENTS64 = 217;
    # v5.11.0 (kavach-surfaced — sandbox post-fork hardening)
    SYS_SECCOMP = 317;
    SYS_GETRANDOM = 318;
    SYS_EXECVEAT = 322;
    SYS_LANDLOCK_CREATE_RULESET = 444;
    SYS_LANDLOCK_ADD_RULE = 445;
    SYS_LANDLOCK_RESTRICT_SELF = 446;
    # v5.11.18 (kybernet 1.1.5-surfaced — sd_notify dgram + supervisor IPC).
    # See aarch64 peer + CHANGELOG [5.11.18].
    SYS_SOCKET = 41;
    SYS_SOCKETPAIR = 53;
    SYS_SETSOCKOPT = 54;
    SYS_CONNECT = 42;
    SYS_RECVFROM = 45;
    SYS_RECVMSG = 47;
    SYS_BIND = 49;
    SYS_LISTEN = 50;
    SYS_ACCEPT4 = 288;
    # v6.1.3 — bare-name fs syscalls + POSIX *at() family (kriya M2 surfaced).
    SYS_LSTAT = 6;
    SYS_RENAME = 82;
    SYS_LINK = 86;
    SYS_OPENAT = 257;
    SYS_MKDIRAT = 258;
    SYS_NEWFSTATAT = 262;
    SYS_UNLINKAT = 263;
    SYS_RENAMEAT = 264;
    SYS_LINKAT = 265;
    SYS_FCHMODAT = 268;
    SYS_UTIMENSAT = 280;
}

