# --- error.cyr ---

# sandhi/error — unified error kinds across sandhi's submodules.
#
# Convention: every public sandhi function that can fail returns a
# `sandhi_result*` with status_code + body ptr (http-response-shaped
# at the library boundary). Internal call chains can use sakshi
# structured error logging plus the codes below.

enum SandhiErrorKind {
    SANDHI_OK              = 0;
    SANDHI_ERR_PARSE       = 1;
    SANDHI_ERR_CONNECT     = 2;
    SANDHI_ERR_TLS         = 3;
    SANDHI_ERR_TIMEOUT     = 4;
    SANDHI_ERR_REMOTE      = 5;
    SANDHI_ERR_PROTOCOL    = 6;
    SANDHI_ERR_AUTH        = 7;
    SANDHI_ERR_DISCOVERY   = 8;
    SANDHI_ERR_INTERNAL    = 99;
}

fn sandhi_err_kind_name(kind): i64 {
    if (kind == SANDHI_OK)             { return "OK";         }
    if (kind == SANDHI_ERR_PARSE)      { return "PARSE";      }
    if (kind == SANDHI_ERR_CONNECT)    { return "CONNECT";    }
    if (kind == SANDHI_ERR_TLS)        { return "TLS";        }
    if (kind == SANDHI_ERR_TIMEOUT)    { return "TIMEOUT";    }
    if (kind == SANDHI_ERR_REMOTE)     { return "REMOTE";     }
    if (kind == SANDHI_ERR_PROTOCOL)   { return "PROTOCOL";   }
    if (kind == SANDHI_ERR_AUTH)       { return "AUTH";       }
    if (kind == SANDHI_ERR_DISCOVERY)  { return "DISCOVERY";  }
    if (kind == SANDHI_ERR_INTERNAL)   { return "INTERNAL";   }
    return "UNKNOWN";
}

# --- trace.cyr ---

# sandhi/obs/trace — thin wrapper around stdlib sakshi's span API.
#
# sandhi wraps `sakshi_span_enter` / `_exit` so that all sandhi-emitted
# spans share a naming convention ("sandhi.<subsystem>.<verb>") and
# so that the call-site code reads at the sandhi layer, not as stdlib
# internals. Keeps the fold-into-stdlib public surface clean of direct
# sakshi coupling beyond the one `lib/sakshi.cyr` include.
#
# Span model:
#   sandhi_trace_begin(name) — pushes a span onto sakshi's stack
#   sandhi_trace_end()       — pops + emits elapsed-ns on exit
#
# Stack max-depth = 16 (per sakshi). sandhi's nesting is shallow
# (HTTP call → DNS resolve + RPC dispatch → HTTP call), so the 16-
# slot budget is comfortable.
#
# Span-name-only by design — sakshi's public API has no key/value
# attribute surface (no `sakshi_span_attr` ships). Span names carry
# the context callers need (e.g. `sandhi.http.GET.example.com`).
# This is an upstream API shape, not a sandhi stub.

# Opt-in flag. Default 0 = every span call is a no-op; sandhi stays
# silent. Consumers that want spans call sandhi_trace_enable(1) once
# at process start (typically right after configuring sakshi's output
# target). We default off rather than inherit from sakshi so an
# application that uses sakshi for its own app-level events isn't
# flooded with sandhi-internal ENTER/EXIT noise it didn't ask for.
var _sandhi_trace_enabled = 0;

fn sandhi_trace_enable(on): i64 {
    _sandhi_trace_enabled = on;
    return 0;
}

fn sandhi_trace_enabled(): i64 {
    return _sandhi_trace_enabled;
}

fn sandhi_trace_begin(name): i64 {
    if (_sandhi_trace_enabled == 0) { return 0; }
    sakshi_span_enter(name, strlen(name));
    return 0;
}

fn sandhi_trace_end(): i64 {
    if (_sandhi_trace_enabled == 0) { return 0; }
    sakshi_span_exit();
    return 0;
}

fn sandhi_trace_depth(): i64 {
    return sakshi_span_depth();
}


# --- prof.cyr ---

# sandhi/obs/prof — runtime per-request profile instrumentation.
#
# Mirrors the cyrius v5.10.0 `_prof_*_end` capture pattern but
# adapted for runtime (sandhi is called many times per process, so
# captures reset per request rather than printing once at exit).
#
# Off by default — every capture is a single global-load comparison
# against `_sandhi_prof_enabled` and an early return; production
# overhead is one branch per phase boundary. Consumers that want
# numbers call `sandhi_prof_enable(1)` once at process start (or
# selectively around requests they care about) and then read back
# the per-phase elapsed-ns via `sandhi_prof_get(SANDHI_PROF_PHASE_*)`
# after the request completes.
#
# Phase model — captures during `_sandhi_http_do_impl_a`:
#   PHASE_REQUEST_START   = 0  (reset at request entry)
#   PHASE_URL_PARSE_END   = 1  (after sandhi_url_parse_a)
#   PHASE_DNS_END         = 2  (after _sandhi_client_resolve(_v6)?_a)
#   PHASE_CONN_OPEN_END   = 3  (after pool take or open_fully_timed_a)
#   PHASE_REQ_BUILD_END   = 4  (after _sandhi_client_build_request_va)
#   PHASE_EXCHANGE_END    = 5  (after _sandhi_http_exchange*_a)
#
# Each capture records a ns timestamp; `sandhi_prof_get(phase)`
# returns elapsed ns from PHASE_REQUEST_START to that phase. The
# pool-take fast path doesn't reach the connect step, so
# PHASE_CONN_OPEN_END equals the prior phase's timestamp on a pool
# hit (zero elapsed). Same for IPv6 fallback inside DNS — the v6
# resolution is captured under the unified DNS phase.
#
# Plus recv-buffer waste tracking: `sandhi_prof_recv_cap()` is the
# bytes allocated for the recv buffer; `sandhi_prof_recv_used()` is
# the bytes actually received. The ratio is the over-allocation
# factor, useful for tuning the default 256 KB cap.
#
# This module is the first slot of a future optimization arc — the
# captures stay constant across slots, but the analysis driving the
# next optimization picks lands as separate work using these numbers.

enum SandhiProfPhase {
    SANDHI_PROF_PHASE_REQUEST_START   = 0;
    SANDHI_PROF_PHASE_URL_PARSE_END   = 1;
    SANDHI_PROF_PHASE_DNS_END         = 2;
    SANDHI_PROF_PHASE_CONN_OPEN_END   = 3;
    SANDHI_PROF_PHASE_REQ_BUILD_END   = 4;
    SANDHI_PROF_PHASE_EXCHANGE_END    = 5;
}

var SANDHI_PROF_PHASE_COUNT = 6;

# Module-level state. Six slot per-phase timestamps + the cap/used
# pair. All zero at process start; reset at every request entry
# when profiling is enabled.
var _sandhi_prof_enabled = 0;
var _sandhi_prof_ts_0 = 0;
var _sandhi_prof_ts_1 = 0;
var _sandhi_prof_ts_2 = 0;
var _sandhi_prof_ts_3 = 0;
var _sandhi_prof_ts_4 = 0;
var _sandhi_prof_ts_5 = 0;
var _sandhi_prof_recv_cap_v = 0;
var _sandhi_prof_recv_used_v = 0;

# ================================================================
# Public surface
# ================================================================

# Toggle profiling on/off. Default 0 = every capture is a no-op.
fn sandhi_prof_enable(on): i64 {
    _sandhi_prof_enabled = on;
    return 0;
}

fn sandhi_prof_enabled(): i64 {
    return _sandhi_prof_enabled;
}

# Reset per-request state at request entry. Records PHASE_REQUEST_START.
# No-op when profiling is disabled.
fn sandhi_prof_reset(): i64 {
    if (_sandhi_prof_enabled == 0) { return 0; }
    var now = clock_now_ns();
    _sandhi_prof_ts_0 = now;
    _sandhi_prof_ts_1 = now;
    _sandhi_prof_ts_2 = now;
    _sandhi_prof_ts_3 = now;
    _sandhi_prof_ts_4 = now;
    _sandhi_prof_ts_5 = now;
    _sandhi_prof_recv_cap_v = 0;
    _sandhi_prof_recv_used_v = 0;
    return 0;
}

# Capture timestamp for `phase`. No-op when profiling is disabled.
# Phase ordering matters — capture in the order phases complete.
fn sandhi_prof_capture(phase): i64 {
    if (_sandhi_prof_enabled == 0) { return 0; }
    var now = clock_now_ns();
    if (phase == SANDHI_PROF_PHASE_URL_PARSE_END) { _sandhi_prof_ts_1 = now; }
    if (phase == SANDHI_PROF_PHASE_DNS_END)       { _sandhi_prof_ts_2 = now; }
    if (phase == SANDHI_PROF_PHASE_CONN_OPEN_END) { _sandhi_prof_ts_3 = now; }
    if (phase == SANDHI_PROF_PHASE_REQ_BUILD_END) { _sandhi_prof_ts_4 = now; }
    if (phase == SANDHI_PROF_PHASE_EXCHANGE_END)  { _sandhi_prof_ts_5 = now; }
    return 0;
}

# Record the recv-buffer cap (allocated) and used (actually received).
# Called once per exchange, just before `sandhi_conn_close`. No-op
# when profiling is disabled.
fn sandhi_prof_record_recv(cap, used): i64 {
    if (_sandhi_prof_enabled == 0) { return 0; }
    _sandhi_prof_recv_cap_v = cap;
    _sandhi_prof_recv_used_v = used;
    return 0;
}

# Read elapsed ns from PHASE_REQUEST_START to `phase`. Returns 0
# when profiling is disabled or for PHASE_REQUEST_START itself.
fn sandhi_prof_get(phase): i64 {
    if (_sandhi_prof_enabled == 0) { return 0; }
    if (phase == SANDHI_PROF_PHASE_REQUEST_START) { return 0; }
    var start = _sandhi_prof_ts_0;
    if (phase == SANDHI_PROF_PHASE_URL_PARSE_END) { return _sandhi_prof_ts_1 - start; }
    if (phase == SANDHI_PROF_PHASE_DNS_END)       { return _sandhi_prof_ts_2 - start; }
    if (phase == SANDHI_PROF_PHASE_CONN_OPEN_END) { return _sandhi_prof_ts_3 - start; }
    if (phase == SANDHI_PROF_PHASE_REQ_BUILD_END) { return _sandhi_prof_ts_4 - start; }
    if (phase == SANDHI_PROF_PHASE_EXCHANGE_END)  { return _sandhi_prof_ts_5 - start; }
    return 0;
}

# Bytes allocated for the recv buffer in the most-recent exchange.
fn sandhi_prof_recv_cap(): i64 {
    return _sandhi_prof_recv_cap_v;
}

# Bytes actually received in the most-recent exchange. The ratio
# `recv_used / recv_cap` is the over-allocation factor — values
# near 1.0 mean the cap is well-tuned, near 0 means we allocated
# 100KB+ for a 200-byte response.
fn sandhi_prof_recv_used(): i64 {
    return _sandhi_prof_recv_used_v;
}

# --- headers.cyr ---

# sandhi/http/headers — HTTP request/response header management.
#
# Wraps stdlib str/vec/alloc with a proper key-value store:
# case-insensitive lookup, multi-valued fields (Set-Cookie etc.),
# CRLF-terminated wire-format serialize + parse. Order is preserved
# across set/add so downstream tests don't race on iteration shape.
#
# Storage model — a vec of entry pointers. Each entry is a 16-byte
# alloc: { name_cstr, value_cstr }. Header blocks are small (< 30
# entries in practice); linear scan beats a hashmap here on both
# code size and constant factor, and matters for serialization
# ordering (multi-value fields render in the order they were added).

# ================================================================
# Entry layout + helpers
# ================================================================

# Internal entry constructor — `_a` variant takes the Allocator first.
# Returns 0 on OOM. Callers MUST null-check (existing call sites in
# sandhi_headers_add_a do).
fn _sandhi_hdr_entry_new_a(a, name, value): i64 {
    var e = alloc_via(a, 16);
    if (e == 0) { return 0; }
    store64(e, name);
    store64(e + 8, value);
    return e;
}

fn _sandhi_hdr_entry_new(name, value): i64 {
    return _sandhi_hdr_entry_new_a(default_alloc(), name, value);
}

fn _sandhi_hdr_entry_name(e): i64 {
    return load64(e);
}

fn _sandhi_hdr_entry_value(e): i64 {
    return load64(e + 8);
}

# ASCII lowercase — header names are ASCII-only per RFC 7230.
fn _sandhi_hdr_to_lower(c): i64 {
    if (c >= 65) { if (c <= 90) { return c + 32; } }
    return c;
}

# Case-insensitive cstr equality. Returns 1 if equal, 0 otherwise.
fn _sandhi_hdr_ieq(a, b): i64 {
    var i = 0;
    while (1 == 1) {
        var ca = _sandhi_hdr_to_lower(load8(a + i));
        var cb = _sandhi_hdr_to_lower(load8(b + i));
        if (ca != cb) { return 0; }
        if (ca == 0) { return 1; }
        i = i + 1;
    }
    return 0;
}

# Trim ASCII SP / HTAB from both ends of a cstr range and copy into
# `a`. Returns 0 on OOM.
fn _sandhi_hdr_trim_copy_a(a, ptr, start, end): i64 {
    var s = start;
    var e = end;
    while (s < e && (load8(ptr + s) == 32 || load8(ptr + s) == 9)) { s = s + 1; }
    while (e > s && (load8(ptr + e - 1) == 32 || load8(ptr + e - 1) == 9)) { e = e - 1; }
    var n = e - s;
    var out = alloc_via(a, n + 1);
    if (out == 0) { return 0; }
    memcpy(out, ptr + s, n);
    store8(out + n, 0);
    return out;
}

fn _sandhi_hdr_trim_copy(ptr, start, end): i64 {
    return _sandhi_hdr_trim_copy_a(default_alloc(), ptr, start, end);
}

# Duplicate a cstr into a fresh null-terminated alloc owned by `a`.
# Returns 0 on null input OR on OOM (caller distinguishes via the
# input-null pre-check that lives in the public verbs).
fn _sandhi_hdr_cstr_dup_a(a, s): i64 {
    if (s == 0) { return 0; }
    var n = strlen(s);
    var out = alloc_via(a, n + 1);
    if (out == 0) { return 0; }
    memcpy(out, s, n);
    store8(out + n, 0);
    return out;
}

fn _sandhi_hdr_cstr_dup(s): i64 {
    return _sandhi_hdr_cstr_dup_a(default_alloc(), s);
}

# ================================================================
# Public API — block creation + mutation
# ================================================================

# Allocate an empty header block from `a`. Returns a vec of entry
# pointers; 0 on OOM.
fn sandhi_headers_new_a(a): i64 {
    return vec_new_a(a);
}

fn sandhi_headers_new(): i64 {
    return sandhi_headers_new_a(default_alloc());
}

# Total entry count (includes duplicate-name entries).
fn sandhi_headers_count(h): i64 {
    return vec_len(h);
}

# 0.9.1 P1 — 1 if `s` contains any of CR (0x0D), LF (0x0A), or NUL
# embedded mid-string (NUL is the cstr terminator, so embedded NUL
# is the only failure mode; CR/LF are header smuggling vectors).
# Returns 1 = unsafe, 0 = safe. Used by add / set to refuse caller-
# injected smuggled-header bytes.
fn _sandhi_hdr_has_unsafe_byte(s): i64 {
    if (s == 0) { return 0; }
    var i = 0;
    while (load8(s + i) != 0) {
        var c = load8(s + i);
        if (c == 13 || c == 10) { return 1; }
        i = i + 1;
    }
    return 0;
}

# Append an entry into `a`. Multi-value-friendly — `add` never
# replaces; use `set` when you want single-value semantics.
#
# 0.9.1 P1 — refuses caller-supplied name/value containing CR / LF.
# Returns 0 on success, `0 - 1` on byte-rejection, `0 - 2` on OOM.
fn sandhi_headers_add_a(a, h, name, value): i64 {
    if (_sandhi_hdr_has_unsafe_byte(name) == 1)  { return 0 - 1; }
    if (_sandhi_hdr_has_unsafe_byte(value) == 1) { return 0 - 1; }
    var name_dup = _sandhi_hdr_cstr_dup_a(a, name);
    if (name_dup == 0) { return 0 - 2; }
    var value_dup = _sandhi_hdr_cstr_dup_a(a, value);
    if (value_dup == 0) { return 0 - 2; }
    var e = _sandhi_hdr_entry_new_a(a, name_dup, value_dup);
    if (e == 0) { return 0 - 2; }
    vec_push_a(a, h, e);
    return 0;
}

fn sandhi_headers_add(h, name, value): i64 {
    return sandhi_headers_add_a(default_alloc(), h, name, value);
}

# Replace all entries with the given name, then append one new entry,
# allocating any new storage in `a`. Use for single-value headers.
fn sandhi_headers_set_a(a, h, name, value): i64 {
    if (_sandhi_hdr_has_unsafe_byte(name) == 1)  { return 0 - 1; }
    if (_sandhi_hdr_has_unsafe_byte(value) == 1) { return 0 - 1; }
    sandhi_headers_remove(h, name);
    return sandhi_headers_add_a(a, h, name, value);
}

fn sandhi_headers_set(h, name, value): i64 {
    return sandhi_headers_set_a(default_alloc(), h, name, value);
}

# Remove all entries with the given name. Returns number removed.
# Order-preserving for surviving entries.
fn sandhi_headers_remove(h, name): i64 {
    var i = 0;
    var w = 0;
    var removed = 0;
    var n = vec_len(h);
    while (i < n) {
        var e = vec_get(h, i);
        if (_sandhi_hdr_ieq(_sandhi_hdr_entry_name(e), name) == 1) {
            removed = removed + 1;
        } else {
            vec_set(h, w, e);
            w = w + 1;
        }
        i = i + 1;
    }
    # Shrink the vec — store64 the new length into the len slot (vec
    # layout: {data, len, cap} per lib/vec.cyr). No public vec_truncate,
    # so we reach in. Safe because w <= old_len.
    store64(h + 8, w);
    return removed;
}

# First value for the given name, case-insensitive. Returns 0 if absent.
# For multi-value headers (Set-Cookie), iterate via the _at() verbs.
fn sandhi_headers_get(h, name): i64 {
    var i = 0;
    var n = vec_len(h);
    while (i < n) {
        var e = vec_get(h, i);
        if (_sandhi_hdr_ieq(_sandhi_hdr_entry_name(e), name) == 1) {
            return _sandhi_hdr_entry_value(e);
        }
        i = i + 1;
    }
    return 0;
}

# Indexed name access (iteration). Returns 0 if out of range.
fn sandhi_headers_name_at(h, idx): i64 {
    if (idx < 0) { return 0; }
    if (idx >= vec_len(h)) { return 0; }
    return _sandhi_hdr_entry_name(vec_get(h, idx));
}

# Indexed value access (iteration). Returns 0 if out of range.
fn sandhi_headers_value_at(h, idx): i64 {
    if (idx < 0) { return 0; }
    if (idx >= vec_len(h)) { return 0; }
    return _sandhi_hdr_entry_value(vec_get(h, idx));
}

# 1 if any entry matches the given name (case-insensitive).
fn sandhi_headers_has(h, name): i64 {
    if (sandhi_headers_get(h, name) == 0) { return 0; }
    return 1;
}

# ================================================================
# Serialization
# ================================================================

# Append each entry to the str_builder as "Name: Value\r\n".
# Does NOT append the terminating blank line — caller emits that
# after any request-line / status-line framing so the builder can
# be shared with method-specific prefixes.
fn sandhi_headers_serialize(h, sb): i64 {
    var i = 0;
    var n = vec_len(h);
    while (i < n) {
        var e = vec_get(h, i);
        str_builder_add_cstr(sb, _sandhi_hdr_entry_name(e));
        str_builder_add_cstr(sb, ": ");
        str_builder_add_cstr(sb, _sandhi_hdr_entry_value(e));
        str_builder_add_cstr(sb, "\r\n");
        i = i + 1;
    }
    return 0;
}

# ================================================================
# Parsing
# ================================================================

# Parse a raw HTTP header block into a new sandhi_headers block.
# Expects the request-line OR status-line to already be stripped —
# start the buffer at the first header line. Stops at the first
# empty (CRLF-only) line or at blen, whichever comes first.
#
# Parse a raw HTTP header block into a fresh block allocated from `a`.
# Returns 0 on OOM (block allocation failure); otherwise returns a
# block that may be empty if every line was malformed. Per-line
# allocation failures bail out of the loop with the partial block —
# arena callers reset on failure anyway, default-alloc callers get a
# best-effort partial parse (matches pre-migration behavior where
# alloc-fail aborted, since the global bump can't fail in practice
# until the heap is exhausted).
fn sandhi_headers_parse_a(a, buf, blen): i64 {
    var h = sandhi_headers_new_a(a);
    if (h == 0) { return 0; }
    var i = 0;
    while (i < blen) {
        # End-of-headers marker — empty line.
        if (i + 1 < blen && load8(buf + i) == 13 && load8(buf + i + 1) == 10) {
            return h;
        }
        if (load8(buf + i) == 10) { return h; }

        # Find end of line (next LF).
        var line_start = i;
        var line_end = i;
        while (line_end < blen && load8(buf + line_end) != 10) {
            line_end = line_end + 1;
        }
        # Strip trailing CR.
        var trim_end = line_end;
        if (trim_end > line_start && load8(buf + trim_end - 1) == 13) {
            trim_end = trim_end - 1;
        }

        # Find colon. If absent, skip the line.
        var colon = line_start;
        while (colon < trim_end && load8(buf + colon) != 58) {
            colon = colon + 1;
        }
        if (colon < trim_end) {
            # Name: [line_start, colon) — trim trailing whitespace.
            var name_end = colon;
            while (name_end > line_start && (load8(buf + name_end - 1) == 32 || load8(buf + name_end - 1) == 9)) {
                name_end = name_end - 1;
            }
            var name_len = name_end - line_start;
            if (name_len > 0) {
                var name = alloc_via(a, name_len + 1);
                if (name == 0) { return h; }
                memcpy(name, buf + line_start, name_len);
                store8(name + name_len, 0);

                # Value: [colon+1, trim_end) — trim leading + trailing whitespace.
                var val = _sandhi_hdr_trim_copy_a(a, buf, colon + 1, trim_end);
                if (val == 0) { return h; }
                sandhi_headers_add_a(a, h, name, val);
            }
        }

        i = line_end + 1;
    }
    return h;
}

fn sandhi_headers_parse(buf, blen): i64 {
    return sandhi_headers_parse_a(default_alloc(), buf, blen);
}

# ================================================================
# Smuggling-vector dup detection (0.9.1 P1)
# ================================================================
#
# Per RFC 7230 §3.3.2 and §5.4, multiple `Content-Length` / multiple
# `Host` / multiple `Transfer-Encoding` headers in a single message
# is a malformed-message condition. Different intermediaries pick
# different ones to honor — the classic CL.CL / Host.Host
# disagreement vectors. We can't repair these; the only safe move
# is to refuse the message entirely.
#
# `sandhi_headers_smuggle_dup` returns 1 if any of those three
# header names appears more than once (case-insensitive). The
# response parser + server-side accept loop call it after parse
# and reject on truthy.

fn _sandhi_hdr_count_ci(h, name): i64 {
    var count = 0;
    var n = sandhi_headers_count(h);
    var i = 0;
    while (i < n) {
        var entry = vec_get(h, i);
        if (_sandhi_hdr_ieq(_sandhi_hdr_entry_name(entry), name) == 1) {
            count = count + 1;
        }
        i = i + 1;
    }
    return count;
}

fn sandhi_headers_smuggle_dup(h): i64 {
    if (h == 0) { return 0; }
    if (_sandhi_hdr_count_ci(h, "Host") > 1)              { return 1; }
    if (_sandhi_hdr_count_ci(h, "Content-Length") > 1)    { return 1; }
    if (_sandhi_hdr_count_ci(h, "Transfer-Encoding") > 1) { return 1; }
    return 0;
}

