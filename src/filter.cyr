# filter.cyr — M1 library surface. Contains everything `src/main.cyr`
# needs at runtime and `tests/anuenue.tcyr` needs at test time: the
# HSV phase model, the stdin→stdout filter loop, and the module-level
# constants the filter is sized against.
#
# Split out from `src/main.cyr` at M1 (per state.md "Module split
# planned at M1 — defer until the code earns it"): the test suite
# needs to `include` the filter without triggering the top-level
# `main()` invocation that reads stdin. main.cyr now is the
# entrypoint shell — includes this file, defines `fn main()`, and
# fires the top-level syscall(SYS_EXIT).
#
# Stdlib + darshana auto-included via cyrius.cyml — this file
# doesn't restate them; the consumer (main.cyr / test) is responsible
# for that.

# ---- Module-level constants (durable; the M2 -p flag will override the
# default phase step but not the underlying integer-rainbow geometry).

# Phase space is `[0, 1530)` — 6 hue sectors × 255 sub-steps each. The
# 1530-unit choice avoids floating-point: at sector boundaries the
# canonical pure hues fall exactly on integer (R,G,B) without a
# round-to-255 step. See `hsv_rainbow` below.
var ANUENUE_PHASE_MOD = 1530;

# Per-byte phase advance. With 1530 / 7 ≈ 219 chars per full cycle,
# a typical 80-col line spans roughly one-third of the rainbow —
# enough visual progression to read as "tinted" rather than
# monochrome, without compressing ROYGBIV into a few characters.
# v0.3.0 (M2) made this a CLI override: `anuenue -p <freq>` writes
# this var before anuenue_filter() runs. 7 is the default for
# back-compat with the v0.2.0 visual cadence.
var ANUENUE_PHASE_STEP = 7;

# Starting phase (mod ANUENUE_PHASE_MOD). v0.3.0 added — the `-s
# <seed>` and `-F <offset>` flags both write here (last one wins;
# semantically equivalent, `-s` being the AGNOS-native test-hook
# name and `-F` the Ruby-lolcat compat name). Default 0 produces
# the canonical "start at pure red" output. anuenue_filter() reads
# this as the initial phase value once at loop entry.
var ANUENUE_PHASE_START = 0;

# Heap-allocated line buffer size (bytes). Sized so a single-write
# flush per line holds ~1700 bytes of fg-escape + payload (each char
# costs ≤19 bytes worst case; the `_ansi_emit_u8` digit packing means
# most run 13–17). 32KB covers a generous terminal-line width without
# bloating the binary; explicit heap allocation per CLAUDE.md
# "Heap-allocate large buffers" rule.
var ANUENUE_LINE_BUF = 32768;

# Per-syscall read chunk. Independent of the line buffer — we read
# 4096 input bytes per `read(2)`, then walk those bytes through the
# line buffer with flush-on-LF / flush-on-near-full. 4096 matches a
# typical page; no advantage to larger here since the kernel pipe
# buffer caps at 64KB and we drain it iteratively.
var ANUENUE_READ_CHUNK = 4096;

# Reserve threshold inside the line buffer. The check fires AFTER
# the latest character has been appended. At M3 a "character" can be
# a 4-byte UTF-8 sequence prefixed by one fg escape (19 worst case),
# so the worst-case append is 19 (escape) + 4 (sequence bytes) = 23
# bytes per codepoint; flush then adds 4 (reset). RESERVE must
# cover the last-appended codepoint + reset = 23 + 4 = 27, and is
# rounded to 32 for headroom against future grapheme-cluster code-
# point chains (a base-codepoint + a few combining marks emit as
# escape + base + combiners, all under one fg). v0.2.0/v0.3.0
# byte-loop used 22; v0.4.0 bumped to 32 for the 4-byte codepoint.
var ANUENUE_FLUSH_RESERVE = 32;

# ---- hsv_rainbow ---------------------------------------------------
#
# Integer-only HSV → RGB for full-saturation full-value (S=V=1) rainbow.
# This is the entire color model anuenue ships at v1.0 — no palettes,
# no themes; the brand IS the rainbow. See `docs/adr/` (planned at
# M7) for the why; CLAUDE.md flags this as "Own the HSV phase model".
#
# Geometry: hue space is split into 6 sectors of 255 sub-steps each.
# Within a sector one channel is at 255, one is at 0, and one is the
# linear ramp `t` (rising) or `255 - t` (falling). At sector
# boundaries the canonical pure hues are exact integers:
#
#   phase=   0 → ( 255,   0,   0 )   red
#   phase= 255 → ( 255, 255,   0 )   yellow
#   phase= 510 → (   0, 255,   0 )   green
#   phase= 765 → (   0, 255, 255 )   cyan
#   phase=1020 → (   0,   0, 255 )   blue
#   phase=1275 → ( 255,   0, 255 )   magenta
#   phase=1530 = 0 (mod 1530), wraps back to red.
#
# `out_rgb` is a 24-byte buffer (3 × i64 slots) the caller has
# stack-allocated. We write r at offset 0, g at offset 8, b at
# offset 16. i64 slots (not u8) match Cyrius's "every struct field
# is 8 bytes, accessed via load64 / store64" convention from
# CLAUDE.md, and lets the downstream `tty_fg_rgb_buf` consume them
# directly without a widening load.
fn hsv_rainbow(phase, out_rgb): i64 {
    # Normalize phase into `[0, ANUENUE_PHASE_MOD)`. Negative inputs
    # wrap once — the caller's phase walks forward in
    # ANUENUE_PHASE_STEP increments, so a wraparound is rare unless a
    # future flag (e.g. M2 -F starting offset) lands negative.
    phase = phase % ANUENUE_PHASE_MOD;
    if (phase < 0) { phase = phase + ANUENUE_PHASE_MOD; }
    var sector = phase / 255;
    var t = phase % 255;
    if (sector == 0) {
        store64(out_rgb + 0,  255);
        store64(out_rgb + 8,  t);
        store64(out_rgb + 16, 0);
    } else { if (sector == 1) {
        store64(out_rgb + 0,  255 - t);
        store64(out_rgb + 8,  255);
        store64(out_rgb + 16, 0);
    } else { if (sector == 2) {
        store64(out_rgb + 0,  0);
        store64(out_rgb + 8,  255);
        store64(out_rgb + 16, t);
    } else { if (sector == 3) {
        store64(out_rgb + 0,  0);
        store64(out_rgb + 8,  255 - t);
        store64(out_rgb + 16, 255);
    } else { if (sector == 4) {
        store64(out_rgb + 0,  t);
        store64(out_rgb + 8,  0);
        store64(out_rgb + 16, 255);
    } else {
        # sector 5 — the only remaining case (phase / 255 in [0, 5])
        store64(out_rgb + 0,  255);
        store64(out_rgb + 8,  0);
        store64(out_rgb + 16, 255 - t);
    } } } } }
    return 0;
}

# ---- UTF-8 sequence detection + codepoint decode ------------------
#
# anuenue at M3 (v0.4.0) cycles by Unicode codepoint, not byte —
# multi-byte UTF-8 characters get one phase advance, not N. This is
# the layer that recognises sequence boundaries and decodes them.
#
# Roadmap explicitly evaluated vyakarana (siblings registry) vs
# stdlib + inline; vyakarana is a source-code TOKENIZER (token-kind
# spans for syntax highlighting) — wrong domain. Stdlib ships
# `_utf8_encode` (codepoint → bytes) only. So: implemented inline,
# right next to anuenue_filter where it's used.
#
# Invalid bytes (overlong leaders, missing continuations, etc) get
# the "graceful degradation" treatment from the roadmap:
# `utf8_seq_len` returns 1, the filter emits the offender as a
# single-byte cluster, advances phase, and keeps going. Never panic,
# never over-read.

# Number of bytes in the UTF-8 sequence beginning at `read_buf + i`,
# given `n` bytes are available in `read_buf` total.
# Returns:
#   1..4  — valid sequence of that length
#   1     — invalid leading byte / invalid continuation (graceful
#           degradation: emit the offender as a 1-byte cluster)
#   0     — leading byte expects N more bytes, but only M<N are
#           present in the buffer (truncated at chunk boundary).
#           Caller carries those bytes to the next read.
fn utf8_seq_len(read_buf, i, n) {
    var b0 = load8(read_buf + i);
    # ASCII fast path — most MOTD / shell input.
    if (b0 < 0x80) { return 1; }
    # 0x80-0xC1: bare continuation or overlong-encoded ASCII —
    # always invalid as a leading byte.
    if (b0 < 0xC2) { return 1; }
    var needed = 2;
    if (b0 >= 0xE0) { needed = 3; }
    if (b0 >= 0xF0) { needed = 4; }
    # 0xF5-0xFF: 5+ byte leaders disallowed by RFC 3629 (limited to
    # Unicode U+10FFFF max).
    if (b0 >= 0xF5) { return 1; }
    # Truncated at chunk boundary — defer.
    if (i + needed > n) { return 0; }
    # Continuation bytes must be 10xxxxxx (0x80-0xBF). Cyrius
    # `break`-with-var is unreliable per CLAUDE.md, so we use a
    # validity flag instead.
    var valid = 1;
    var k = 1;
    while (k < needed) {
        var bk = load8(read_buf + i + k);
        if ((bk & 0xC0) != 0x80) { valid = 0; }
        k = k + 1;
    }
    if (valid == 0) { return 1; }
    return needed;
}

# Decode the UTF-8 sequence at `read_buf + i` of length `seqlen`
# (1..4) into a Unicode codepoint. Caller must have validated via
# `utf8_seq_len` first; this fn does NO validation (any bit pattern
# outside the documented continuation form yields garbage). The
# `& 0x1F / 0x0F / 0x07` masks strip the leading-byte type bits;
# `& 0x3F` strips each continuation byte's `10xxxxxx` marker.
fn utf8_decode(read_buf, i, seqlen) {
    if (seqlen == 1) { return load8(read_buf + i); }
    if (seqlen == 2) {
        return ((load8(read_buf + i) & 0x1F) << 6)
             |  (load8(read_buf + i + 1) & 0x3F);
    }
    if (seqlen == 3) {
        return ((load8(read_buf + i) & 0x0F) << 12)
             | ((load8(read_buf + i + 1) & 0x3F) << 6)
             |  (load8(read_buf + i + 2) & 0x3F);
    }
    # seqlen == 4 (the only remaining valid case)
    return ((load8(read_buf + i) & 0x07) << 18)
         | ((load8(read_buf + i + 1) & 0x3F) << 12)
         | ((load8(read_buf + i + 2) & 0x3F) << 6)
         |  (load8(read_buf + i + 3) & 0x3F);
}

# ---- grapheme cluster classification ------------------------------
#
# A grapheme cluster is what a human reads as "one character" — `é`
# (e + combining acute), `🏳️‍🌈` (rainbow flag = white flag + VS-16
# + ZWJ + rainbow), `🇺🇸` (US flag = two regional indicators). The
# rainbow phase should advance ONCE per cluster, not per codepoint.
#
# Full UAX #29 needs a several-thousand-entry codepoint database
# (Mn / Mc / Me categories, GraphemeBreakProperty tables). For
# anuenue's domain (MOTD pipelines, banner output, shell prompts)
# we ship a **practical subset**:
#
#   - Combining Diacritical Marks (Latin/Greek) — U+0300..036F
#   - Cyrillic combining — U+0483..0489
#   - Hebrew points + cantillation — U+0591..05BD, 05BF, 05C1-C2,
#     05C4-C5, 05C7
#   - Arabic — U+0610-061A, 064B-065F, 0670, 06D6-DC, 06DF-E4,
#     06E7-E8, 06EA-ED
#   - ZWJ (U+200D) — emoji-sequence joiner; treat as extending so
#     a base + ZWJ + extension renders as one cluster (e.g. 👨‍👩‍👧).
#   - Variation Selectors — U+FE00..FE0F (incl. VS-15 = text, VS-16
#     = emoji)
#   - Combining Half Marks — U+FE20..FE2F
#   - Math-zone combiners — U+1AB0..1ACE, 1DC0..1DFF, 20D0..20F0
#   - Variation Selectors Supplement — U+E0100..E01EF
#
# Things this DOESN'T fully model:
#   - Hangul L/V/T/LV/LVT syllable composition (Korean)
#   - Devanagari + other Brahmic vowel-mark sequences (the spacing
#     marks need extra rules — we treat them as advancing for now)
#   - Tag sequences (subdivision flags)
#
# Misclassifying these errs on the side of "advance more often than
# strictly correct" — never under-advances, so the rainbow stays
# visible. ADR 0003 (M7) will record this trade-off; the doc rule
# in CLAUDE.md is "UTF-8 robustness: invalid byte sequences must
# not panic, must not over-read" — both honoured by this subset.
fn cp_is_extending(cp) {
    # Combining Diacritical Marks — Latin/Greek/Cyrillic accents
    if (cp >= 0x0300 && cp <= 0x036F) { return 1; }
    # Cyrillic combining
    if (cp >= 0x0483 && cp <= 0x0489) { return 1; }
    # Hebrew points + cantillation
    if (cp >= 0x0591 && cp <= 0x05BD) { return 1; }
    if (cp == 0x05BF) { return 1; }
    if (cp >= 0x05C1 && cp <= 0x05C2) { return 1; }
    if (cp >= 0x05C4 && cp <= 0x05C5) { return 1; }
    if (cp == 0x05C7) { return 1; }
    # Arabic
    if (cp >= 0x0610 && cp <= 0x061A) { return 1; }
    if (cp >= 0x064B && cp <= 0x065F) { return 1; }
    if (cp == 0x0670) { return 1; }
    if (cp >= 0x06D6 && cp <= 0x06DC) { return 1; }
    if (cp >= 0x06DF && cp <= 0x06E4) { return 1; }
    if (cp >= 0x06E7 && cp <= 0x06E8) { return 1; }
    if (cp >= 0x06EA && cp <= 0x06ED) { return 1; }
    # ZWJ — emoji sequence joiner
    if (cp == 0x200D) { return 1; }
    # Combining Diacritical Marks for Symbols
    if (cp >= 0x20D0 && cp <= 0x20F0) { return 1; }
    # Math-zone combiners (Combining Diacritical Marks Extended)
    if (cp >= 0x1AB0 && cp <= 0x1ACE) { return 1; }
    if (cp >= 0x1DC0 && cp <= 0x1DFF) { return 1; }
    # Variation Selectors (VS-1..VS-16; VS-16 enables emoji form)
    if (cp >= 0xFE00 && cp <= 0xFE0F) { return 1; }
    # Combining Half Marks
    if (cp >= 0xFE20 && cp <= 0xFE2F) { return 1; }
    # Variation Selectors Supplement (VS-17..VS-256)
    if (cp >= 0xE0100 && cp <= 0xE01EF) { return 1; }
    return 0;
}

# Regional Indicator codepoints (U+1F1E6..U+1F1FF, A..Z). Two
# consecutive RIs form a country-flag emoji as a single cluster
# (🇺🇸 = US-EN regional indicator A + S). The filter loop tracks
# state to pair them.
fn cp_is_regional_indicator(cp) {
    if (cp >= 0x1F1E6 && cp <= 0x1F1FF) { return 1; }
    return 0;
}

# ---- anuenue_filter ------------------------------------------------
#
# The pipe-purity proof. Reads stdin in ANUENUE_READ_CHUNK chunks,
# emits each byte prefixed by a 24-bit fg escape derived from a
# monotonically-advancing phase counter, flushes on LF or buffer-near-
# full, resets SGR before each LF so the terminal returns clean.
#
# Capability surface: read(0), write(1), and the brk(2) that
# `alloc()` already invoked for the heap. No open, connect, fork,
# exec, signal, ioctl. Auditable by `strace -e trace=!read,!write -p
# <pid>` returning empty after `alloc_init()`.
#
# Return value: 0 on clean EOF, non-zero on a read(2) error. Per
# CLAUDE.md the only failure path we care about is the kernel-side
# one; we treat partial reads and short writes as normal.
fn anuenue_filter(): i64 {
    var line_buf = alloc(ANUENUE_LINE_BUF);
    var read_buf = alloc(ANUENUE_READ_CHUNK);
    if (line_buf == 0 || read_buf == 0) {
        # alloc returns 0 on OOM. Surface a non-zero exit so callers
        # can detect the failure — silently truncating output would
        # be worse than a clean error code.
        return 1;
    }

    var pos = 0;                            # current write offset into line_buf
    var phase = ANUENUE_PHASE_START;        # current hue phase (= phase of current cluster)
    var rgb[24];                            # 3 × i64 slots — hsv_rainbow output

    # Bytes carried over from the prior chunk because they formed
    # the start of a UTF-8 sequence whose tail hadn't arrived yet.
    # 0..3 — utf8_seq_len returns 0 only for sequences expecting up
    # to 4 bytes, so at most 3 of those would be carry-bytes (the
    # leading byte plus up to 2 continuations seen). Stored at the
    # head of read_buf; the next file_read appends to read_buf +
    # carry_len with a correspondingly shorter length.
    var carry_len = 0;

    # Regional-indicator pair state. When we see the first of two
    # consecutive RI codepoints we open this latch; the second RI
    # closes it and gets folded into the cluster (single phase
    # advance for the flag). Any non-RI advance resets it.
    var prev_unpaired_ri = 0;

    # "Previous codepoint was ZWJ" latch. ZWJ (U+200D) makes the
    # codepoint AFTER it part of the current cluster — UAX #29's
    # emoji-ZWJ-sequence rule: family emoji 👨‍👩‍👧 = ONE cluster
    # composed of 👨 + ZWJ + 👩 + ZWJ + 👧. Without this latch the
    # post-ZWJ emoji would start a new cluster. Set right after
    # emitting a ZWJ codepoint; consumed (cleared) on the next.
    var prev_was_zwj = 0;

    # Whether any prior cluster has been emitted. The phase advances
    # *before* a new cluster, not after — so the first cluster sits
    # at PHASE_START exactly, and each subsequent non-extending
    # cluster bumps by STEP. saw_any = 0 suppresses the bump on the
    # very first emit (which otherwise would over-advance by one).
    var saw_any = 0;

    var go = 1;
    while (go == 1) {
        var n_read = file_read(STDIN, read_buf + carry_len, ANUENUE_READ_CHUNK - carry_len);
        if (n_read < 0) {
            # Read error. Flush whatever's queued so partial output
            # isn't lost; exit non-zero.
            if (pos > 0) {
                pos = tty_sgr_reset_buf(line_buf, pos);
                file_write(STDOUT, line_buf, pos);
            }
            return 1;
        }
        if (n_read == 0) {
            # Clean EOF. Any carry_len bytes are a truncated multi-
            # byte sequence that will never complete — emit them as
            # single-byte clusters (graceful degradation per the M3
            # roadmap rule "invalid UTF-8 bytes get cycled-byte-at-
            # a-time, never panic").
            var ci = 0;
            while (ci < carry_len) {
                if (saw_any == 1) { phase = phase + ANUENUE_PHASE_STEP; }
                hsv_rainbow(phase, &rgb);
                pos = tty_fg_rgb_buf(line_buf, pos,
                                     load64(&rgb + 0),
                                     load64(&rgb + 8),
                                     load64(&rgb + 16));
                store8(line_buf + pos, load8(read_buf + ci));
                pos = pos + 1;
                saw_any = 1;
                if (pos + ANUENUE_FLUSH_RESERVE > ANUENUE_LINE_BUF) {
                    pos = tty_sgr_reset_buf(line_buf, pos);
                    file_write(STDOUT, line_buf, pos);
                    pos = 0;
                }
                ci = ci + 1;
            }
            if (pos > 0) {
                pos = tty_sgr_reset_buf(line_buf, pos);
                file_write(STDOUT, line_buf, pos);
                pos = 0;
            }
            go = 0;
            continue;
        }

        # Total valid bytes in read_buf this iteration: carry from
        # last chunk + what we just read.
        var n = n_read + carry_len;
        carry_len = 0;

        # Inner walk. `in_chunk` flag pattern instead of `break` per
        # the CLAUDE.md no-break-with-var rule.
        var i = 0;
        var in_chunk = 1;
        while (in_chunk == 1 && i < n) {
            var b = load8(read_buf + i);

            if (b == 10) {
                # LF — its own non-extending cluster. Pre-advance
                # if any prior cluster exists (same rule as for any
                # other non-extending codepoint), then reset SGR,
                # emit the LF, flush the line, drop RI candidacy
                # and the ZWJ latch (newline breaks any open
                # ZWJ sequence).
                if (saw_any == 1) { phase = phase + ANUENUE_PHASE_STEP; }
                pos = tty_sgr_reset_buf(line_buf, pos);
                store8(line_buf + pos, 10);
                pos = pos + 1;
                file_write(STDOUT, line_buf, pos);
                pos = 0;
                saw_any = 1;
                prev_unpaired_ri = 0;
                prev_was_zwj = 0;
                i = i + 1;
                continue;
            }

            var seqlen = utf8_seq_len(read_buf, i, n);
            if (seqlen == 0) {
                # Multi-byte sequence truncated at chunk boundary.
                # Defer remaining bytes to next read.
                in_chunk = 0;
                continue;
            }

            var cp = utf8_decode(read_buf, i, seqlen);

            # Decide if this codepoint extends the previous cluster:
            #   - Combining mark / ZWJ / VS (via cp_is_extending)
            #   - First codepoint after a ZWJ (joins forward through
            #     the ZWJ — the emoji-ZWJ-sequence rule)
            #   - Second-half of a regional-indicator pair (flag)
            var extending = 0;
            if (cp_is_extending(cp) == 1) { extending = 1; }
            if (prev_was_zwj == 1) { extending = 1; }
            if (cp_is_regional_indicator(cp) == 1) {
                if (prev_unpaired_ri == 1) { extending = 1; }
            }

            # Phase advance BEFORE emitting — applies to every non-
            # extending cluster after the first. Result: cluster N
            # always renders at PHASE_START + N*STEP, exactly the
            # M1/M2 semantics for the ASCII-only case (one cluster
            # per byte).
            if (saw_any == 1) {
                if (extending == 0) { phase = phase + ANUENUE_PHASE_STEP; }
            }

            # Emit the fg escape + all sequence bytes under one
            # color. A multi-byte codepoint always renders as a
            # contiguous run; the next escape is laid down at the
            # next cluster boundary.
            hsv_rainbow(phase, &rgb);
            pos = tty_fg_rgb_buf(line_buf, pos,
                                 load64(&rgb + 0),
                                 load64(&rgb + 8),
                                 load64(&rgb + 16));
            var k = 0;
            while (k < seqlen) {
                store8(line_buf + pos, load8(read_buf + i + k));
                pos = pos + 1;
                k = k + 1;
            }

            saw_any = 1;

            # Update ZWJ latch: cleared by default (consumed by
            # this codepoint), then re-set if THIS codepoint is
            # itself ZWJ.
            prev_was_zwj = 0;
            if (cp == 0x200D) { prev_was_zwj = 1; }

            # Update RI-pair latch. RI codepoints toggle the latch
            # in pairs; any non-extending, non-RI codepoint resets it.
            if (cp_is_regional_indicator(cp) == 1) {
                if (prev_unpaired_ri == 1) {
                    prev_unpaired_ri = 0;     # pair closed
                } else {
                    prev_unpaired_ri = 1;     # pair opened
                }
            } else {
                if (extending == 0) { prev_unpaired_ri = 0; }
            }

            # Force-flush if the next cluster's worst-case write
            # wouldn't fit (escape + 4-byte sequence + reset).
            if (pos + ANUENUE_FLUSH_RESERVE > ANUENUE_LINE_BUF) {
                pos = tty_sgr_reset_buf(line_buf, pos);
                file_write(STDOUT, line_buf, pos);
                pos = 0;
            }

            i = i + seqlen;
        }

        # If the inner loop exited early on a truncated sequence,
        # `i` points at its leading byte. Copy the trailing 1..3
        # partial bytes to the head of read_buf so the next
        # file_read appends after them.
        if (i < n) {
            carry_len = n - i;
            var ji = 0;
            while (ji < carry_len) {
                store8(read_buf + ji, load8(read_buf + i + ji));
                ji = ji + 1;
            }
        }
    }
    return 0;
}
