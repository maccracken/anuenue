    # opening /dev/urandom because it works in sandboxed envs that
    # block file IO and never returns short reads for buffers <= 256 B.
    var got = syscall(318, buf, n, 0);
    if (got == n) { return 0; }
    # Fallback: /dev/urandom for older kernels / restricted seccomp.
    var fd = syscall(2, "/dev/urandom", 0, 0);
    if (fd >= 0) {
        # Loop in case the kernel returns a short read (rare for small n
        # but legal per read(2)).
        var off = 0;
        while (off < n) {
            var r = syscall(0, fd, buf + off, n - off);
            if (r <= 0) { off = 0 - 1; }
            else { off = off + r; }
        }
        syscall(3, fd);
        if (off == n) { return 0; }
    }
    # Both sources failed. Identifier generation is security-critical
    # (agent_id, session_id, trace_id back authorisation in aegis/sigil)
    # so we fail loudly rather than degrade to a deterministic seed.
    # F-012 (audit 2026-05-10): the byte-count was hardcoded 67 for a
    # 68-byte literal; the trailing newline silently dropped. Use
    # strlen() so the count tracks the literal.
    var msg = "agnostik: CSPRNG unavailable (getrandom + /dev/urandom both failed)\n";
    syscall(1, 2, msg, strlen(msg));
    syscall(60, 70);
    return 0 - 1;
}
