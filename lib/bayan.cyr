fn json_v_arr_push_a(a, arr, val): i64 { return bayan_json_v_arr_push_a(a, arr, val); }
fn json_v_arr_push(arr, val): i64 { return bayan_json_v_arr_push(arr, val); }
fn json_v_obj_set(obj, key, val): i64 { return bayan_json_v_obj_set(obj, key, val); }
fn json_v_tag(v): i64 { return bayan_json_v_tag(v); }
fn json_v_is_null(v): i64 { return bayan_json_v_is_null(v); }
fn json_v_is_bool(v): i64 { return bayan_json_v_is_bool(v); }
fn json_v_is_int(v): i64 { return bayan_json_v_is_int(v); }
fn json_v_is_float(v): i64 { return bayan_json_v_is_float(v); }
