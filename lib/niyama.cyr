# --- posix_classes.cyr ---

# posix_classes.cyr — shared POSIX bracket-class implementation.
#
# Provides ASCII fillers for the 12 POSIX bracket classes
# (`[:alpha:]`, `[:digit:]`, ..., `[:xdigit:]`) plus a name-recognizer.
# All functions are state-free — they take a `class_base` pointer
# (engine-specific class table) and a `ci` index and operate on
# 32-byte bitmaps in that table. The recognizer is also state-free:
# it takes `(pat, pos, pat_len)` and returns a packed result without
# touching any engine-specific globals.
#
# Used by niyama_bre and niyama_pcre starting at v0.7.0. niyama_vim
# still carries an in-engine copy from M4 (its dispatch is
# mode-aware and intermingled with vim's bracket parser); folding
# vim onto this module is a v0.9.0 cleanup, not a v0.7.0 commitment.
#
# Bitmap layout (matches bre/re2/pcre): each class is 32 bytes,
# bit `c` of byte `c >> 3` set means the class includes byte `c`.
#
# All globals/functions are `_posix_*`-prefixed for collision-free
# coexistence with engine-internal `_bre_*` / `_pcre_*` / `_vim_*`
# helpers.

# --- Bit ops on a generic class table -------------------------------

fn _posix_class_set(class_base, ci, c): i64 {
    if (c < 0)   { return 0; }
    if (c > 255) { return 0; }
    var off = class_base + ci * 32 + (c >> 3);
    store8(off, load8(off) | (1 << (c & 7)));
    return 0;
}

fn _posix_class_range(class_base, ci, lo, hi): i64 {
    var c = lo;
    while (c <= hi) {
        _posix_class_set(class_base, ci, c);
        c = c + 1;
    }
    return 0;
}

# --- The 12 POSIX bracket classes (ASCII) ---------------------------

fn _posix_fill_alpha(class_base, ci): i64 {
    _posix_class_range(class_base, ci, 65, 90);
    _posix_class_range(class_base, ci, 97, 122);
    return 0;
}

fn _posix_fill_digit(class_base, ci): i64 {
    _posix_class_range(class_base, ci, 48, 57);
    return 0;
}

fn _posix_fill_alnum(class_base, ci): i64 {
    _posix_fill_alpha(class_base, ci);
    _posix_fill_digit(class_base, ci);
    return 0;
}

fn _posix_fill_upper(class_base, ci): i64 {
    _posix_class_range(class_base, ci, 65, 90);
    return 0;
}

fn _posix_fill_lower(class_base, ci): i64 {
    _posix_class_range(class_base, ci, 97, 122);
    return 0;
}

fn _posix_fill_space(class_base, ci): i64 {
    # POSIX [:space:] is HT(9), LF(10), VT(11), FF(12), CR(13), SP(32).
    _posix_class_set(class_base, ci, 9);
    _posix_class_set(class_base, ci, 10);
    _posix_class_set(class_base, ci, 11);
    _posix_class_set(class_base, ci, 12);
    _posix_class_set(class_base, ci, 13);
    _posix_class_set(class_base, ci, 32);
    return 0;
}

fn _posix_fill_blank(class_base, ci): i64 {
    _posix_class_set(class_base, ci, 9);
    _posix_class_set(class_base, ci, 32);
    return 0;
}

fn _posix_fill_cntrl(class_base, ci): i64 {
    _posix_class_range(class_base, ci, 0, 31);
    _posix_class_set(class_base, ci, 127);
    return 0;
}

fn _posix_fill_print(class_base, ci): i64 {
    _posix_class_range(class_base, ci, 32, 126);
    return 0;
}

fn _posix_fill_graph(class_base, ci): i64 {
    _posix_class_range(class_base, ci, 33, 126);
    return 0;
}

fn _posix_fill_punct(class_base, ci): i64 {
    # ASCII punctuation: !"#$%&'()*+,-./ :;<=>?@ [\]^_` {|}~
    _posix_class_range(class_base, ci, 33, 47);
    _posix_class_range(class_base, ci, 58, 64);
    _posix_class_range(class_base, ci, 91, 96);
    _posix_class_range(class_base, ci, 123, 126);
    return 0;
}

fn _posix_fill_xdigit(class_base, ci): i64 {
    _posix_class_range(class_base, ci, 48, 57);
    _posix_class_range(class_base, ci, 65, 70);
    _posix_class_range(class_base, ci, 97, 102);
    return 0;
}

# --- Class name recognizer ------------------------------------------

# Globals so callers can read end-position after a successful match
# without an out-pointer convention. Set by _posix_match_class_name.
var _posix_match_end_pos = 0;

# Match a POSIX class header `[:name:]` starting at position `pos` in
# `pat` (which is `pat_len` bytes long). `pos` MUST point at the first
# byte AFTER the leading `[:` (i.e. caller has already consumed those
# two bytes). On success returns one of:
#   1 = alpha   2 = digit   3 = space   4 = upper   5 = lower
#   6 = alnum   7 = blank   8 = cntrl   9 = graph  10 = print
#  11 = punct  12 = xdigit
# and writes the position immediately after the trailing `:]` to
# `_posix_match_end_pos`.
# On no-match returns 0 and leaves `_posix_match_end_pos` unset.
fn _posix_match_class_name(pat, pos, pat_len): i64 {
    var name_start = pos;
    var p = pos;
    var scanning = 1;
    while (scanning == 1) {
        if (p >= pat_len) {
            scanning = 0;
        } else {
            var c = load8(pat + p);
            if (c < 97 || c > 122) { scanning = 0; }
            else                    { p = p + 1; }
        }
    }
    var name_len = p - name_start;
    if (p + 1 >= pat_len)               { return 0; }
    if (load8(pat + p) != 58)           { return 0; }
    if (load8(pat + p + 1) != 93)       { return 0; }

    var category = 0;
    if (name_len == 5) {
        var c0 = load8(pat + name_start);
        var c1 = load8(pat + name_start + 1);
        var c2 = load8(pat + name_start + 2);
        var c3 = load8(pat + name_start + 3);
        var c4 = load8(pat + name_start + 4);
        if      (c0 == 97  && c1 == 108 && c2 == 112 && c3 == 104 && c4 == 97)  { category = 1; }   # alpha
        elif    (c0 == 100 && c1 == 105 && c2 == 103 && c3 == 105 && c4 == 116) { category = 2; }   # digit
        elif    (c0 == 115 && c1 == 112 && c2 == 97  && c3 == 99  && c4 == 101) { category = 3; }   # space
        elif    (c0 == 117 && c1 == 112 && c2 == 112 && c3 == 101 && c4 == 114) { category = 4; }   # upper
        elif    (c0 == 108 && c1 == 111 && c2 == 119 && c3 == 101 && c4 == 114) { category = 5; }   # lower
        elif    (c0 == 97  && c1 == 108 && c2 == 110 && c3 == 117 && c4 == 109) { category = 6; }   # alnum
        elif    (c0 == 98  && c1 == 108 && c2 == 97  && c3 == 110 && c4 == 107) { category = 7; }   # blank
        elif    (c0 == 99  && c1 == 110 && c2 == 116 && c3 == 114 && c4 == 108) { category = 8; }   # cntrl
        elif    (c0 == 103 && c1 == 114 && c2 == 97  && c3 == 112 && c4 == 104) { category = 9; }   # graph
        elif    (c0 == 112 && c1 == 114 && c2 == 105 && c3 == 110 && c4 == 116) { category = 10; }  # print
        elif    (c0 == 112 && c1 == 117 && c2 == 110 && c3 == 99  && c4 == 116) { category = 11; }  # punct
    }
    elif (name_len == 6) {
        var d0 = load8(pat + name_start);
        var d1 = load8(pat + name_start + 1);
        var d2 = load8(pat + name_start + 2);
        var d3 = load8(pat + name_start + 3);
        var d4 = load8(pat + name_start + 4);
        var d5 = load8(pat + name_start + 5);
        if (d0 == 120 && d1 == 100 && d2 == 105 && d3 == 103 && d4 == 105 && d5 == 116) { category = 12; }  # xdigit
    }
    if (category == 0) { return 0; }
    _posix_match_end_pos = p + 2;
    return category;
}

# Apply category (1..12) to class `ci` in `class_base`. Caller is
# responsible for having allocated `ci` already. Unknown category is
# a no-op (caller's check should have rejected before calling).
fn _posix_apply_filler(class_base, ci, category): i64 {
    if      (category == 1)  { _posix_fill_alpha(class_base, ci); }
    elif    (category == 2)  { _posix_fill_digit(class_base, ci); }
    elif    (category == 3)  { _posix_fill_space(class_base, ci); }
    elif    (category == 4)  { _posix_fill_upper(class_base, ci); }
    elif    (category == 5)  { _posix_fill_lower(class_base, ci); }
    elif    (category == 6)  { _posix_fill_alnum(class_base, ci); }
    elif    (category == 7)  { _posix_fill_blank(class_base, ci); }
    elif    (category == 8)  { _posix_fill_cntrl(class_base, ci); }
    elif    (category == 9)  { _posix_fill_graph(class_base, ci); }
    elif    (category == 10) { _posix_fill_print(class_base, ci); }
    elif    (category == 11) { _posix_fill_punct(class_base, ci); }
    elif    (category == 12) { _posix_fill_xdigit(class_base, ci); }
    return 0;
}

# --- unicode_props.cyr ---

# unicode_props.cyr — shared `\p{NAME}` / `\P{NAME}` parser helper.
#
# Provides syntax recognition + GeneralCategory bitmask computation for
# Unicode property classes. Used by niyama_re2, niyama_pcre, and
# niyama_vim starting at v0.8.0 (per ADR 0008).
#
# Scope: short Unicode property names only — single-letter aggregates
# (L, M, N, P, S, Z, C) and 2-letter leaves (Lu, Ll, Lt, Lm, Lo, Mn,
# Mc, Me, Nd, Nl, No, Pc, Pd, Ps, Pe, Pi, Pf, Po, Sm, Sc, Sk, So, Zs,
# Zl, Zp, Cc, Cf, Cs, Co, Cn). Long names (`\p{Letter}`,
# `\p{Uppercase_Letter}`), Script properties (`\p{Greek}`), Block
# properties — all out of scope. If the user wants any of these,
# pinned at v0.8.x per the ladder rule.
#
# Design: parser returns a 30-bit positive bitmask over the 30
# GeneralCategory leaves (Lu=bit 0 ... Cn=bit 29). Negation (`\P` vs
# `\p`) is handled by the caller — the parser doesn't know which form
# it was invoked from. Callers store the bitmask + a negate flag in
# their engine-specific opcode encoding.
#
# Matching at runtime: caller decodes a UTF-8 codepoint at the input
# position, calls `unicode_category(cp)` (from lib/unicode/categories.cyr)
# to get the leaf index 0..29, then tests `(mask >> leaf) & 1`. If the
# opcode was the negated form, invert the result.
#
# All globals and functions are `_uprops_*`-prefixed. Consumers of
# this module must ALSO include `lib/unicode/categories.cyr` for
# `unicode_category(cp)` (called from `_uprops_test`). The lib include
# is left to the consumer rather than nested here so consumer .tcyr
# files retain the explicit dep declaration.

# Caller reads this after a successful _uprops_parse_class call to
# know where to advance the parser cursor (just past the closing `}`).
var _uprops_match_end_pos = 0;

# Aggregate masks — pre-computed for the seven Unicode top-level
# categories. Defined as `var` rather than `const` to match the
# existing engine style; treat as read-only.
var _UPROPS_MASK_L = 0x0000001F;     # Lu Ll Lt Lm Lo (cats 0..4)
var _UPROPS_MASK_M = 0x000000E0;     # Mn Mc Me       (cats 5..7)
var _UPROPS_MASK_N = 0x00000700;     # Nd Nl No       (cats 8..10)
var _UPROPS_MASK_P = 0x0003F800;     # Pc Pd Ps Pe Pi Pf Po (cats 11..17)
var _UPROPS_MASK_S = 0x003C0000;     # Sm Sc Sk So    (cats 18..21)
var _UPROPS_MASK_Z = 0x01C00000;     # Zs Zl Zp       (cats 22..24)
var _UPROPS_MASK_C = 0x3E000000;     # Cc Cf Cs Co Cn (cats 25..29)

# Look up the GC bitmask for a 1- or 2-character property name.
# Returns 0 if name is unrecognized.
fn _uprops_lookup_name(pat, name_start, name_len): i64 {
    if (name_len == 1) {
        var c = load8(pat + name_start);
        if (c == 76) { return _UPROPS_MASK_L; }   # L
        if (c == 77) { return _UPROPS_MASK_M; }   # M
        if (c == 78) { return _UPROPS_MASK_N; }   # N
        if (c == 80) { return _UPROPS_MASK_P; }   # P
        if (c == 83) { return _UPROPS_MASK_S; }   # S
        if (c == 90) { return _UPROPS_MASK_Z; }   # Z
        if (c == 67) { return _UPROPS_MASK_C; }   # C
        return 0;
    }
    if (name_len == 2) {
        var c0 = load8(pat + name_start);
        var c1 = load8(pat + name_start + 1);
        if (c0 == 76) {                           # L_
            if (c1 == 117) { return 1 << 0; }     # u
            if (c1 == 108) { return 1 << 1; }     # l
            if (c1 == 116) { return 1 << 2; }     # t
            if (c1 == 109) { return 1 << 3; }     # m
            if (c1 == 111) { return 1 << 4; }     # o
            return 0;
        }
        if (c0 == 77) {                           # M_
            if (c1 == 110) { return 1 << 5; }     # n
            if (c1 == 99)  { return 1 << 6; }     # c
            if (c1 == 101) { return 1 << 7; }     # e
            return 0;
        }
        if (c0 == 78) {                           # N_
            if (c1 == 100) { return 1 << 8; }     # d
            if (c1 == 108) { return 1 << 9; }     # l
            if (c1 == 111) { return 1 << 10; }    # o
            return 0;
        }
        if (c0 == 80) {                           # P_
            if (c1 == 99)  { return 1 << 11; }    # c
            if (c1 == 100) { return 1 << 12; }    # d
            if (c1 == 115) { return 1 << 13; }    # s
            if (c1 == 101) { return 1 << 14; }    # e
            if (c1 == 105) { return 1 << 15; }    # i
            if (c1 == 102) { return 1 << 16; }    # f
            if (c1 == 111) { return 1 << 17; }    # o
            return 0;
        }
        if (c0 == 83) {                           # S_
            if (c1 == 109) { return 1 << 18; }    # m
            if (c1 == 99)  { return 1 << 19; }    # c
            if (c1 == 107) { return 1 << 20; }    # k
            if (c1 == 111) { return 1 << 21; }    # o
            return 0;
        }
        if (c0 == 90) {                           # Z_
            if (c1 == 115) { return 1 << 22; }    # s
            if (c1 == 108) { return 1 << 23; }    # l
            if (c1 == 112) { return 1 << 24; }    # p
            return 0;
        }
        if (c0 == 67) {                           # C_
            if (c1 == 99)  { return 1 << 25; }    # c
            if (c1 == 102) { return 1 << 26; }    # f
            if (c1 == 115) { return 1 << 27; }    # s
            if (c1 == 111) { return 1 << 28; }    # o
            if (c1 == 110) { return 1 << 29; }    # n
            return 0;
        }
        return 0;
    }
    return 0;
}

# Parse `{NAME}` starting at `pos` (caller has already consumed the
# leading `\p` or `\P`). Returns a 30-bit GC bitmask on success, 0 on
# any failure (missing `{`, unknown name, missing `}`). On success
# sets `_uprops_match_end_pos` to the position immediately after `}`.
fn _uprops_parse_class(pat, pos, pat_len): i64 {
    if (pos >= pat_len)             { return 0; }
    if (load8(pat + pos) != 123)    { return 0; }   # require '{'
    var name_start = pos + 1;
    var p = name_start;
    var close_pos = 0 - 1;
    while (p < pat_len) {
        if (load8(pat + p) == 125) {                 # '}'
            close_pos = p;
            p = pat_len;                              # break
        } else {
            p = p + 1;
        }
    }
    if (close_pos < 0) { return 0; }
    var name_len = close_pos - name_start;
    if (name_len < 1) { return 0; }
    if (name_len > 2) { return 0; }
    var mask = _uprops_lookup_name(pat, name_start, name_len);
    if (mask == 0) { return 0; }
    _uprops_match_end_pos = close_pos + 1;
    return mask;
}

# Test whether `cp` is a member of the property class encoded by
# `mask`. Decodes via stdlib unicode_category(); returns 1 / 0.
# Negation (`\P{...}`) is the caller's responsibility — invert as
# needed when the matcher decoded the negated opcode form.
fn _uprops_test(cp, mask): i64 {
    var cat = unicode_category(cp);
    return (mask >> cat) & 1;
}

# --- bre.cyr ---

# bre.cyr — niyama POSIX BRE engine.
#
# Implements POSIX.1-2017 § 9.3 Basic Regular Expressions, exposed via
# the niyama_bre_* ABI defined in docs/adr/0002-bre-engine-abi-and-scope.md.
#
# Architecture: forked from the cyrius stdlib lib/regex.cyr Pike NFA
# (instruction model, class bitmap, matcher) — reuse what's well-tested,
# swap the parser for BRE-flavor syntax.
#
# Public API (mirrors stdlib regex_*):
#   niyama_bre_compile(pat)       -> opaque NFA pointer or 0 on error
#   niyama_bre_match(nfa, s)      -> 1 if anchored match, else 0
#   niyama_bre_search(nfa, s)     -> first match offset, or -1
#   niyama_bre_search_at(...)     -> first match offset starting at `from`
#   niyama_bre_group_start(nfa,n) -> group n start or -1
#   niyama_bre_group_end(nfa,n)   -> group n end or -1
#   niyama_bre_last_error()       -> error code from most recent compile
#
# POSIX BRE flavor highlights:
#   - `*`, `+`, `?`, `(`, `)`, `{`, `}` literal-by-default; `*` is special
#     ONLY after a previously-emitted atom (not at start of pattern).
#   - `\(...\)` capturing groups (1..9), `\{n,m\}` quantifiers.
#   - `^` anchor only at byte 0 of the pattern; literal elsewhere.
#   - `$` anchor only at end of pattern; literal elsewhere.
#   - `[...]` / `[^...]` POSIX bracket expressions, ranges.
#   - `\1`..`\9` backreferences are REJECTED at compile time
#     (BRE_E_BACKREF_UNSUPPORTED); use niyama_pcre at M3 for backref-using
#     patterns.
#
# Out of scope for M1:
#   - `\d` `\w` `\s` `\b` (ERE-style; not POSIX BRE — treated as literal
#     `d`/`w`/`s`/`b` per POSIX undefined-escape rule).
#   - GNU `\<` / `\>` word boundaries (deferred to M4 vim, which inherits
#     the same semantics — implement once in vim.cyr).
#   - `[:alpha:]` POSIX bracket character classes (deferred to M4 vim).
#
# All globals are `_bre_*`-prefixed to avoid collision with stdlib
# regex.cyr if both are linked into the same program.
#
# Precondition: `alloc_init()` must have been called before
# niyama_bre_compile (mirrors the rest of the AGNOS-lineage stdlib —
# every consumer's main() calls alloc_init() once at startup).

# === Constants ========================================================

var BRE_OP_MATCH     = 0;
var BRE_OP_CHAR      = 1;
var BRE_OP_ANY       = 2;
var BRE_OP_CLASS     = 3;
var BRE_OP_NCLASS    = 4;
var BRE_OP_JMP       = 5;
var BRE_OP_SPLIT     = 6;
var BRE_OP_SAVE      = 7;
var BRE_OP_BOL       = 8;
var BRE_OP_EOL       = 9;
# v0.7.0 — GNU BRE word boundaries. Strict semantics distinct from
# `\b`: WORDBEGIN fires only at non-word -> word transitions,
# WORDEND only at word -> non-word transitions. (vim conflates the
# two onto its single BOUNDARY op; bre tracks `grep -G` which keeps
# them distinct.)
var BRE_OP_WORDBEGIN = 10;
var BRE_OP_WORDEND   = 11;

var BRE_NFA_HEADER_SIZE = 216;
var BRE_OFF_INSTR_COUNT = 0;
var BRE_OFF_INSTRS_OFF  = 8;
var BRE_OFF_CLASS_COUNT = 16;
var BRE_OFF_CLASSES_OFF = 24;
var BRE_OFF_CAPTURES    = 32;
var BRE_OFF_MATCH_START = 40;
var BRE_OFF_MATCH_END   = 48;
var BRE_OFF_SAVES       = 56;

var BRE_MAX_INSTRS  = 4096;
var BRE_MAX_CLASSES = 64;
var BRE_MAX_SAVES   = 20;

# Error codes — frozen-at-M1 ABI. Adding new codes is fine; renumbering
# existing ones is not. See docs/adr/0002-bre-engine-abi-and-scope.md.
var BRE_E_OK                   = 0;
var BRE_E_SYNTAX               = 1;
var BRE_E_BACKREF_UNSUPPORTED  = 2;
var BRE_E_TOO_LARGE            = 3;
var BRE_E_BAD_ANCHOR           = 4;

# === Compile-time globals ============================================

var _bre_pat = 0;
var _bre_pat_len = 0;
var _bre_pos = 0;
var _bre_nfa = 0;
var _bre_instr_base = 0;
var _bre_class_base = 0;
var _bre_instr_n = 0;
var _bre_class_n = 0;
var _bre_capture_n = 0;
var _bre_err = 0;
var _bre_last_err = 0;

# Process-lifetime scratch buffers for the matcher (lazy-init), plus
# a quantifier-unroll splits scratch for the compiler.
var _bre_m_init = 0;
var _bre_m_cur = 0;
var _bre_m_next = 0;
var _bre_m_lastgen = 0;
var _bre_m_gen = 0;
var _bre_q_splits = 0;       # 64 slots × 8 bytes — quantifier unrolling

fn _bre_lazy_init(): i64 {
    if (_bre_m_init == 1) { return 0; }
    _bre_m_cur     = alloc(8 + BRE_MAX_INSTRS * 168);
    _bre_m_next    = alloc(8 + BRE_MAX_INSTRS * 168);
    _bre_m_lastgen = alloc(BRE_MAX_INSTRS * 8);
    _bre_q_splits  = alloc(64 * 8);
    var i = 0;
    while (i < BRE_MAX_INSTRS) {
        store64(_bre_m_lastgen + i * 8, 0);
        i = i + 1;
    }
    _bre_m_init = 1;
    _bre_m_gen = 1;
    return 0;
}

# === Instruction emit / patch helpers ================================

fn _bre_w0(op, small, arg1): i64 {
    return op | (small << 8) | (arg1 << 32);
}

fn _bre_emit_raw(w0, w1): i64 {
    var i = _bre_instr_n;
    if (i >= BRE_MAX_INSTRS) { _bre_err = BRE_E_TOO_LARGE; return i; }
    store64(_bre_instr_base + i * 16, w0);
    store64(_bre_instr_base + i * 16 + 8, w1);
    _bre_instr_n = i + 1;
    return i;
}

fn _bre_emit_op(op): i64 { return _bre_emit_raw(op, 0); }
fn _bre_emit_char(c): i64 { return _bre_emit_raw(BRE_OP_CHAR | (c << 8), 0); }
fn _bre_emit_class(neg, ci): i64 {
    var op = BRE_OP_CLASS;
    if (neg == 1) { op = BRE_OP_NCLASS; }
    return _bre_emit_raw(op | (ci << 8), 0);
}
fn _bre_emit_save(idx): i64 { return _bre_emit_raw(BRE_OP_SAVE | (idx << 8), 0); }
fn _bre_emit_jmp(target): i64 { return _bre_emit_raw(BRE_OP_JMP | (target << 32), 0); }
fn _bre_emit_split(a, b): i64 { return _bre_emit_raw(BRE_OP_SPLIT | (a << 32), b); }

fn _bre_patch_arg1(idx, arg1): i64 {
    var off = _bre_instr_base + idx * 16;
    var w0 = load64(off);
    store64(off, (w0 & 0xFFFFFFFF) | (arg1 << 32));
    return 0;
}

fn _bre_patch_arg2(idx, arg2): i64 {
    store64(_bre_instr_base + idx * 16 + 8, arg2);
    return 0;
}

# Shift instructions [lo, hi) right by 1 slot (overlap-safe backward copy).
fn _bre_shift_right(lo, hi): i64 {
    var k = (hi - lo) * 16 - 1;
    while (k >= 0) {
        var src = _bre_instr_base + lo * 16 + k;
        store8(src + 16, load8(src));
        k = k - 1;
    }
    return 0;
}

# After shifting [lo, hi) right by 1, fix branch targets that pointed
# back into the OLD range. Inclusive upper bound — a target == hi means
# "first position past the fragment" (where a JMP-to-end was patched at
# iter end with the then-current _bre_instr_n == hi); after shift, that
# position is hi+1, so the target needs the same bump as targets strictly
# inside.
fn _bre_shift_targets_one(lo, hi): i64 {
    var i = lo + 1;
    var end = hi + 1;
    while (i < end) {
        var off = _bre_instr_base + i * 16;
        var w0 = load64(off);
        var op = w0 & 0xFF;
        var is_branch = 0;
        if (op == BRE_OP_JMP)   { is_branch = 1; }
        if (op == BRE_OP_SPLIT) { is_branch = 1; }
        if (is_branch == 1) {
            var arg1 = (w0 >> 32) & 0xFFFFFFFF;
            if (arg1 >= lo && arg1 <= hi) {
                _bre_patch_arg1(i, arg1 + 1);
            }
            if (op == BRE_OP_SPLIT) {
                var arg2 = load64(off + 8);
                if (arg2 >= lo && arg2 <= hi) {
                    _bre_patch_arg2(i, arg2 + 1);
                }
            }
        }
        i = i + 1;
    }
    return 0;
}

# === Class bitmap helpers ============================================

fn _bre_alloc_class(): i64 {
    var ci = _bre_class_n;
    if (ci >= BRE_MAX_CLASSES) { _bre_err = BRE_E_TOO_LARGE; return ci; }
    var z = 0;
    while (z < 32) {
        store8(_bre_class_base + ci * 32 + z, 0);
        z = z + 1;
    }
    _bre_class_n = ci + 1;
    return ci;
}

fn _bre_class_set(ci, c): i64 {
    if (c < 0)   { return 0; }
    if (c > 255) { return 0; }
    var off = _bre_class_base + ci * 32 + (c >> 3);
    store8(off, load8(off) | (1 << (c & 7)));
    return 0;
}

fn _bre_class_range(ci, lo, hi): i64 {
    var c = lo;
    while (c <= hi) {
        _bre_class_set(ci, c);
        c = c + 1;
    }
    return 0;
}

# === Pattern decoder =================================================

# Decode a literal byte at _bre_pos and advance. Sets _bre_err on EOF.
# Backslash handling for IN-PATTERN bytes: \n \r \t \0 \a \f \v expand
# to control bytes (matches stdlib precedent + common consumer expectation);
# any other backslashed byte is the literal byte (`\.` -> `.`, `\\` -> `\`,
# etc.). Numeric backslash (`\1`..`\9`) is REJECTED upstream by
# _bre_check_backref before this is called.
fn _bre_lit_byte(): i64 {
    if (_bre_pos >= _bre_pat_len) { _bre_err = BRE_E_SYNTAX; return 0; }
    var c = load8(_bre_pat + _bre_pos);
    _bre_pos = _bre_pos + 1;
    if (c != 92) { return c; }
    if (_bre_pos >= _bre_pat_len) { _bre_err = BRE_E_SYNTAX; return 0; }
    var e = load8(_bre_pat + _bre_pos);
    _bre_pos = _bre_pos + 1;
    if (e == 110) { return 10; }
    if (e == 114) { return 13; }
    if (e == 116) { return 9; }
    if (e == 48)  { return 0; }
    if (e == 97)  { return 7; }
    if (e == 102) { return 12; }
    if (e == 118) { return 11; }
    return e;
}

# Parse a `[...]` POSIX bracket-expression body (caller already consumed
# `[`). Returns the class index. Sets _bre_err on syntax error. Negation
# is encoded by returning -(ci+1).
#
# Scope: ranges (`a-z`), literal characters, `^` for negation as first
# char, and POSIX bracket character classes `[:alpha:]` etc. (added in
# v0.7.0 via the shared posix_classes module).
fn _bre_parse_class(): i64 {
    var ci = _bre_alloc_class();
    if (_bre_err != BRE_E_OK) { return ci; }
    var neg = 0;
    if (_bre_pos < _bre_pat_len && load8(_bre_pat + _bre_pos) == 94) {
        neg = 1;
        _bre_pos = _bre_pos + 1;
    }
    # POSIX: `]` as first char (after optional `^`) is literal `]`, not
    # the close. Honor that.
    var first = 1;
    var done = 0;
    while (done == 0) {
        if (_bre_pos >= _bre_pat_len) { _bre_err = BRE_E_SYNTAX; return 0 - 1; }
        var pc = load8(_bre_pat + _bre_pos);
        if (pc == 93 && first == 0) {
            _bre_pos = _bre_pos + 1;
            done = 1;
        }
        # POSIX bracket class: `[:name:]` — only valid inside a `[...]`.
        elif (pc == 91 && _bre_pos + 1 < _bre_pat_len && load8(_bre_pat + _bre_pos + 1) == 58) {
            var category = _posix_match_class_name(_bre_pat, _bre_pos + 2, _bre_pat_len);
            if (category == 0) { _bre_err = BRE_E_SYNTAX; return 0 - 1; }
            _posix_apply_filler(_bre_class_base, ci, category);
            _bre_pos = _posix_match_end_pos;
            first = 0;
        }
        elif (pc == 92 && _bre_pos + 1 < _bre_pat_len) {
            # In bracket context, only literal-byte escapes apply.
            var lc = _bre_lit_byte();
            if (_bre_err != BRE_E_OK) { return 0 - 1; }
            if (_bre_pos + 1 < _bre_pat_len && load8(_bre_pat + _bre_pos) == 45 && load8(_bre_pat + _bre_pos + 1) != 93) {
                _bre_pos = _bre_pos + 1;
                var hi = _bre_lit_byte();
                if (_bre_err != BRE_E_OK) { return 0 - 1; }
                _bre_class_range(ci, lc, hi);
            } else {
                _bre_class_set(ci, lc);
            }
            first = 0;
        }
        else {
            var lc2 = _bre_lit_byte();
            if (_bre_err != BRE_E_OK) { return 0 - 1; }
            if (_bre_pos + 1 < _bre_pat_len && load8(_bre_pat + _bre_pos) == 45 && load8(_bre_pat + _bre_pos + 1) != 93) {
                _bre_pos = _bre_pos + 1;
                var hi2 = _bre_lit_byte();
                if (_bre_err != BRE_E_OK) { return 0 - 1; }
                _bre_class_range(ci, lc2, hi2);
            } else {
                _bre_class_set(ci, lc2);
            }
            first = 0;
        }
    }
    if (neg == 1) { return 0 - (ci + 1); }
    return ci;
}

# === Recursive-descent BRE compiler ==================================

# Parse a primary (atom body, no quantifier yet). Returns 0 always; sets
# _bre_err on failure. `at_start` is 1 when this primary is the first
# atom in the entire pattern (used for ^ anchor placement).
fn _bre_parse_primary(at_start): i64 {
    if (_bre_pos >= _bre_pat_len) { _bre_err = BRE_E_SYNTAX; return 0; }
    var c = load8(_bre_pat + _bre_pos);

    # `^` anchor — special only at byte 0 of the pattern. Literal elsewhere.
    if (c == 94) {
        _bre_pos = _bre_pos + 1;
        if (at_start == 1) {
            _bre_emit_op(BRE_OP_BOL);
        } else {
            _bre_emit_char(94);
        }
        return 0;
    }

    # `$` anchor — special only at end of pattern. Literal elsewhere.
    if (c == 36) {
        _bre_pos = _bre_pos + 1;
        if (_bre_pos == _bre_pat_len) {
            _bre_emit_op(BRE_OP_EOL);
        } else {
            _bre_emit_char(36);
        }
        return 0;
    }

    # `.` any byte
    if (c == 46) {
        _bre_pos = _bre_pos + 1;
        _bre_emit_op(BRE_OP_ANY);
        return 0;
    }

    # `[...]` bracket expression
    if (c == 91) {
        _bre_pos = _bre_pos + 1;
        var ci = _bre_parse_class();
        if (_bre_err != BRE_E_OK) { return 0; }
        var neg = 0;
        if (ci < 0) { neg = 1; ci = 0 - (ci + 1); }
        _bre_emit_class(neg, ci);
        return 0;
    }

    # Backslash — group delim, quantifier delim, or literal escape.
    if (c == 92) {
        if (_bre_pos + 1 >= _bre_pat_len) { _bre_err = BRE_E_SYNTAX; return 0; }
        var e = load8(_bre_pat + _bre_pos + 1);

        # `\(` open group
        if (e == 40) {
            _bre_pos = _bre_pos + 2;
            _bre_capture_n = _bre_capture_n + 1;
            var capture_idx = _bre_capture_n;
            if (capture_idx > 9) { _bre_err = BRE_E_SYNTAX; return 0; }
            _bre_emit_save(capture_idx * 2);
            # Inside a group, `^` is literal (POSIX BRE: `^` is anchor
            # only at byte 0 of the entire pattern). We propagate
            # at_start = 0.
            _bre_parse_concat(0);
            if (_bre_err != BRE_E_OK) { return 0; }
            # Expect `\)`
            if (_bre_pos + 1 >= _bre_pat_len) { _bre_err = BRE_E_SYNTAX; return 0; }
            if (load8(_bre_pat + _bre_pos) != 92 || load8(_bre_pat + _bre_pos + 1) != 41) {
                _bre_err = BRE_E_SYNTAX; return 0;
            }
            _bre_pos = _bre_pos + 2;
            _bre_emit_save(capture_idx * 2 + 1);
            return 0;
        }

        # `\)` outside a group — syntax error.
        if (e == 41) {
            _bre_err = BRE_E_SYNTAX; return 0;
        }

        # `\1`..`\9` backreference — REJECT explicitly per ADR 0002.
        if (e >= 49 && e <= 57) {
            _bre_err = BRE_E_BACKREF_UNSUPPORTED;
            return 0;
        }

        # GNU BRE word boundaries (v0.7.0): `\<` start-of-word,
        # `\>` end-of-word. Strict semantics (distinct from `\b`).
        if (e == 60) {
            _bre_pos = _bre_pos + 2;
            _bre_emit_op(BRE_OP_WORDBEGIN);
            return 0;
        }
        if (e == 62) {
            _bre_pos = _bre_pos + 2;
            _bre_emit_op(BRE_OP_WORDEND);
            return 0;
        }

        # `\{` quantifier — only valid AFTER an atom (handled in _bre_parse_atom).
        # Hitting it here means it's at start of concat with no preceding
        # atom; that's a syntax error.
        if (e == 123) {
            _bre_err = BRE_E_SYNTAX; return 0;
        }

        # Otherwise: plain escape -> literal byte.
        var lc = _bre_lit_byte();
        if (_bre_err == BRE_E_OK) { _bre_emit_char(lc); }
        return 0;
    }

    # Bare `*` at start of concat — POSIX says undefined; we err on
    # syntax (matches `grep -G '^*'` rejecting via "Unmatched [ or [^").
    # Actually GNU grep -G treats leading * as literal. We follow GNU
    # for compat: at_start = 1 means * is literal.
    if (c == 42) {
        _bre_pos = _bre_pos + 1;
        if (at_start == 1) {
            _bre_emit_char(42);
        } else {
            # Should never reach here; quantifier handling is in _bre_parse_atom.
            _bre_err = BRE_E_SYNTAX;
        }
        return 0;
    }

    # Everything else: literal byte. Note `+`, `?`, `(`, `)`, `{`, `}`,
    # `|` are literal in POSIX BRE.
    _bre_pos = _bre_pos + 1;
    _bre_emit_char(c);
    return 0;
}

# Apply `*` to the just-emitted atom at [atom_start, _bre_instr_n).
# POSIX BRE has no `+`, `?`, lazy quantifiers, or alternation.
fn _bre_apply_star(atom_start): i64 {
    var atom_end = _bre_instr_n;
    if (atom_end == atom_start) { _bre_err = BRE_E_SYNTAX; return 0; }
    _bre_pos = _bre_pos + 1;
    # SPLIT body, exit ; body ; JMP back ; exit
    _bre_shift_right(atom_start, atom_end);
    _bre_shift_targets_one(atom_start, atom_end);
    _bre_instr_n = _bre_instr_n + 1;
    var body_pc = atom_start + 1;
    store64(_bre_instr_base + atom_start * 16, _bre_w0(BRE_OP_SPLIT, 0, body_pc));
    store64(_bre_instr_base + atom_start * 16 + 8, 0);
    _bre_emit_jmp(atom_start);
    var exit_pc = _bre_instr_n;
    _bre_patch_arg2(atom_start, exit_pc);
    return 0;
}

# Apply `*` (greedy) to a body at [body_start, _bre_instr_n) — used by
# {n,} unrolling for the unbounded tail.
fn _bre_apply_star_inline(body_start): i64 {
    var body_end = _bre_instr_n;
    _bre_shift_right(body_start, body_end);
    _bre_shift_targets_one(body_start, body_end);
    _bre_instr_n = _bre_instr_n + 1;
    var body_pc = body_start + 1;
    store64(_bre_instr_base + body_start * 16, _bre_w0(BRE_OP_SPLIT, 0, body_pc));
    store64(_bre_instr_base + body_start * 16 + 8, 0);
    _bre_emit_jmp(body_start);
    var exit_pc = _bre_instr_n;
    _bre_patch_arg2(body_start, exit_pc);
    return 0;
}

# Apply `\{n,m\}` / `\{n,\}` / `\{n\}` to the atom at [atom_start, _bre_instr_n).
# `save_primary_start` is the source position before the FIRST primary —
# used to re-parse for additional copies.
fn _bre_apply_brace_q(save_primary_start, atom_start): i64 {
    if (_bre_instr_n == atom_start) { _bre_err = BRE_E_SYNTAX; return 0; }
    # caller positioned _bre_pos at the `\` of `\{` — consume `\{`.
    _bre_pos = _bre_pos + 2;
    var n_min = 0;
    var have_min = 0;
    while (_bre_pos < _bre_pat_len && load8(_bre_pat + _bre_pos) >= 48 && load8(_bre_pat + _bre_pos) <= 57) {
        n_min = n_min * 10 + (load8(_bre_pat + _bre_pos) - 48);
        _bre_pos = _bre_pos + 1;
        have_min = 1;
    }
    if (have_min == 0) { _bre_err = BRE_E_SYNTAX; return 0; }
    var n_max = n_min;
    var open_ended = 0;
    if (_bre_pos < _bre_pat_len && load8(_bre_pat + _bre_pos) == 44) {
        _bre_pos = _bre_pos + 1;
        n_max = 0;
        var have_max = 0;
        while (_bre_pos < _bre_pat_len && load8(_bre_pat + _bre_pos) >= 48 && load8(_bre_pat + _bre_pos) <= 57) {
            n_max = n_max * 10 + (load8(_bre_pat + _bre_pos) - 48);
            _bre_pos = _bre_pos + 1;
            have_max = 1;
        }
        if (have_max == 0) { open_ended = 1; n_max = 0; }
    }
    # Expect `\}`
    if (_bre_pos + 1 >= _bre_pat_len) { _bre_err = BRE_E_SYNTAX; return 0; }
    if (load8(_bre_pat + _bre_pos) != 92 || load8(_bre_pat + _bre_pos + 1) != 125) {
        _bre_err = BRE_E_SYNTAX; return 0;
    }
    _bre_pos = _bre_pos + 2;
    var pos_after_q = _bre_pos;
    if (open_ended == 0 && n_max < n_min) { _bre_err = BRE_E_SYNTAX; return 0; }
    if (n_max > 1000) { _bre_err = BRE_E_TOO_LARGE; return 0; }
    if (n_min == 0) {
        _bre_instr_n = atom_start;
        if (open_ended == 1) {
            # {0,} ≡ *
            var ts = _bre_instr_n;
            _bre_pos = save_primary_start;
            _bre_parse_primary(0);
            if (_bre_err != BRE_E_OK) { return 0; }
            _bre_apply_star_inline(ts);
        } else {
            var sn = 0;
            var k = 0;
            while (k < n_max) {
                if (sn >= 64) { _bre_err = BRE_E_TOO_LARGE; return 0; }
                var sx = _bre_emit_split(0, 0);
                store64(_bre_q_splits + sn * 8, sx);
                sn = sn + 1;
                _bre_pos = save_primary_start;
                _bre_parse_primary(0);
                if (_bre_err != BRE_E_OK) { return 0; }
                k = k + 1;
            }
            var exit_pc = _bre_instr_n;
            var ti = 0;
            while (ti < sn) {
                var sxi = load64(_bre_q_splits + ti * 8);
                _bre_patch_arg1(sxi, sxi + 1);
                _bre_patch_arg2(sxi, exit_pc);
                ti = ti + 1;
            }
        }
    } else {
        var k1 = 1;
        while (k1 < n_min) {
            _bre_pos = save_primary_start;
            _bre_parse_primary(0);
            if (_bre_err != BRE_E_OK) { return 0; }
            k1 = k1 + 1;
        }
        if (open_ended == 1) {
            var ts2 = _bre_instr_n;
            _bre_pos = save_primary_start;
            _bre_parse_primary(0);
            if (_bre_err != BRE_E_OK) { return 0; }
            _bre_apply_star_inline(ts2);
        } elif (n_max > n_min) {
            var sn2 = 0;
            var k2 = n_min;
            while (k2 < n_max) {
                if (sn2 >= 64) { _bre_err = BRE_E_TOO_LARGE; return 0; }
                var sy = _bre_emit_split(0, 0);
                store64(_bre_q_splits + sn2 * 8, sy);
                sn2 = sn2 + 1;
                _bre_pos = save_primary_start;
                _bre_parse_primary(0);
                if (_bre_err != BRE_E_OK) { return 0; }
                k2 = k2 + 1;
            }
            var exit_pc2 = _bre_instr_n;
            var tj = 0;
            while (tj < sn2) {
                var syi = load64(_bre_q_splits + tj * 8);
                _bre_patch_arg1(syi, syi + 1);
                _bre_patch_arg2(syi, exit_pc2);
                tj = tj + 1;
            }
        }
    }
    _bre_pos = pos_after_q;
    return 0;
}

fn _bre_parse_atom(at_start): i64 {
    var save_primary_start = _bre_pos;
    var atom_start = _bre_instr_n;
    _bre_parse_primary(at_start);
    if (_bre_err != BRE_E_OK) { return 0; }
    if (_bre_pos >= _bre_pat_len) { return 0; }
    var c = load8(_bre_pat + _bre_pos);
    if (c == 42) {
        _bre_apply_star(atom_start);
    }
    elif (c == 92 && _bre_pos + 1 < _bre_pat_len && load8(_bre_pat + _bre_pos + 1) == 123) {
        _bre_apply_brace_q(save_primary_start, atom_start);
    }
    return 0;
}

# Parse a concat — a sequence of atoms terminated by end-of-pattern or
# `\)`. `at_start` is 1 only for the first call (top-level pattern start);
# nested calls (inside a group) pass 0.
fn _bre_parse_concat(at_start): i64 {
    var first = at_start;
    while (_bre_pos < _bre_pat_len) {
        # Stop at `\)` (close-group).
        if (load8(_bre_pat + _bre_pos) == 92 && _bre_pos + 1 < _bre_pat_len && load8(_bre_pat + _bre_pos + 1) == 41) {
            return 0;
        }
        _bre_parse_atom(first);
        first = 0;
        if (_bre_err != BRE_E_OK) { return 0; }
    }
    return 0;
}

# === Compiler entry ==================================================

# Compile a null-terminated POSIX BRE pattern. Returns an opaque NFA
# pointer (heap-allocated) or 0 on error. Use niyama_bre_last_error()
# to get the error code.
# Consumer: cyim (src/cli.cyr). niyama's own src/bre.cyr is the
# reference implementation that got folded byte-identical at v5.9.0.
fn niyama_bre_compile(pat): i64 {
    _bre_lazy_init();
    var n = strlen(pat);
    var instr_bytes = BRE_MAX_INSTRS * 16;
    var class_bytes = BRE_MAX_CLASSES * 32;
    var nfa = alloc(BRE_NFA_HEADER_SIZE + instr_bytes + class_bytes);
    var instrs = nfa + BRE_NFA_HEADER_SIZE;
    var classes = instrs + instr_bytes;
    store64(nfa + BRE_OFF_INSTRS_OFF,  BRE_NFA_HEADER_SIZE);
    store64(nfa + BRE_OFF_CLASSES_OFF, BRE_NFA_HEADER_SIZE + instr_bytes);
    store64(nfa + BRE_OFF_MATCH_START, 0 - 1);
    store64(nfa + BRE_OFF_MATCH_END,   0 - 1);
    var sv = 0;
    while (sv < BRE_MAX_SAVES) {
        store64(nfa + BRE_OFF_SAVES + sv * 8, 0 - 1);
        sv = sv + 1;
    }
    _bre_pat = pat;
    _bre_pat_len = n;
    _bre_pos = 0;
    _bre_nfa = nfa;
    _bre_instr_base = instrs;
    _bre_class_base = classes;
    _bre_instr_n = 0;
    _bre_class_n = 0;
    _bre_capture_n = 0;
    _bre_err = BRE_E_OK;
    _bre_emit_save(0);
    _bre_parse_concat(1);
    if (_bre_err != BRE_E_OK || _bre_pos != _bre_pat_len) {
        if (_bre_err == BRE_E_OK) { _bre_err = BRE_E_SYNTAX; }
        _bre_last_err = _bre_err;
        return 0;
    }
    _bre_emit_save(1);
    _bre_emit_op(BRE_OP_MATCH);
    if (_bre_err != BRE_E_OK) {
        _bre_last_err = _bre_err;
        return 0;
    }
    store64(nfa + BRE_OFF_INSTR_COUNT, _bre_instr_n);
    store64(nfa + BRE_OFF_CLASS_COUNT, _bre_class_n);
    store64(nfa + BRE_OFF_CAPTURES,    _bre_capture_n);
    _bre_last_err = BRE_E_OK;
    return nfa;
}

fn niyama_bre_last_error(): i64 {
    return _bre_last_err;
}

# === Pike's NFA matcher (forked from stdlib) =========================

fn _bre_at_word_char(input, input_len, pos): i64 {
    if (pos < 0)         { return 0; }
    if (pos >= input_len){ return 0; }
    var c = load8(input + pos);
    if (c >= 48 && c <= 57)   { return 1; }
    if (c >= 65 && c <= 90)   { return 1; }
    if (c >= 97 && c <= 122)  { return 1; }
    if (c == 95)              { return 1; }
    return 0;
}

fn _bre_class_get_at(class_base, ci, c): i64 {
    if (c < 0)   { return 0; }
    if (c > 255) { return 0; }
    var off = class_base + ci * 32 + (c >> 3);
    var b = load8(off);
    if ((b >> (c & 7)) & 1) { return 1; }
    return 0;
}

fn _bre_add_thread(list_base, pc, input, input_len, pos, saves, instrs): i64 {
    if (pc < 0)                 { return 0; }
    if (load64(_bre_m_lastgen + pc * 8) == _bre_m_gen) { return 0; }
    store64(_bre_m_lastgen + pc * 8, _bre_m_gen);
    var off = instrs + pc * 16;
    var w0 = load64(off);
    var op = w0 & 0xFF;
    if (op == BRE_OP_JMP) {
        var t = (w0 >> 32) & 0xFFFFFFFF;
        _bre_add_thread(list_base, t, input, input_len, pos, saves, instrs);
    }
    elif (op == BRE_OP_SPLIT) {
        var a = (w0 >> 32) & 0xFFFFFFFF;
        var b = load64(off + 8);
        _bre_add_thread(list_base, a, input, input_len, pos, saves, instrs);
        _bre_add_thread(list_base, b, input, input_len, pos, saves, instrs);
    }
    elif (op == BRE_OP_SAVE) {
        var idx = (w0 >> 8) & 0xFF;
        var prev = load64(saves + idx * 8);
        store64(saves + idx * 8, pos);
        _bre_add_thread(list_base, pc + 1, input, input_len, pos, saves, instrs);
        store64(saves + idx * 8, prev);
    }
    elif (op == BRE_OP_BOL) {
        var ok = 0;
        if (pos == 0) { ok = 1; }
        else {
            if (load8(input + pos - 1) == 10) { ok = 1; }
        }
        if (ok == 1) { _bre_add_thread(list_base, pc + 1, input, input_len, pos, saves, instrs); }
    }
    elif (op == BRE_OP_EOL) {
        var ok2 = 0;
        if (pos == input_len) { ok2 = 1; }
        elif (load8(input + pos) == 10) { ok2 = 1; }
        if (ok2 == 1) { _bre_add_thread(list_base, pc + 1, input, input_len, pos, saves, instrs); }
    }
    elif (op == BRE_OP_WORDBEGIN) {
        var lw = _bre_at_word_char(input, input_len, pos - 1);
        var rw = _bre_at_word_char(input, input_len, pos);
        if (lw == 0 && rw == 1) {
            _bre_add_thread(list_base, pc + 1, input, input_len, pos, saves, instrs);
        }
    }
    elif (op == BRE_OP_WORDEND) {
        var lw2 = _bre_at_word_char(input, input_len, pos - 1);
        var rw2 = _bre_at_word_char(input, input_len, pos);
        if (lw2 == 1 && rw2 == 0) {
            _bre_add_thread(list_base, pc + 1, input, input_len, pos, saves, instrs);
        }
    }
    else {
        var n = load64(list_base);
        store64(list_base + 8 + n * 168, pc);
        var k = 0;
        while (k < BRE_MAX_SAVES) {
            var v = load64(saves + k * 8);
            store64(list_base + 8 + n * 168 + 8 + k * 8, v);
            k = k + 1;
        }
        store64(list_base, n + 1);
    }
    return 0;
}

fn _bre_pike_run(nfa, input, input_len, start_pos): i64 {
    _bre_lazy_init();
    var instrs = nfa + load64(nfa + BRE_OFF_INSTRS_OFF);
    var class_base = nfa + load64(nfa + BRE_OFF_CLASSES_OFF);
    var matched = 0 - 1;
    var saves_scratch = alloc(BRE_MAX_SAVES * 8);
    var k = 0;
    while (k < BRE_MAX_SAVES) {
        store64(saves_scratch + k * 8, 0 - 1);
        k = k + 1;
    }
    var match_saves = alloc(BRE_MAX_SAVES * 8);
    var k2 = 0;
    while (k2 < BRE_MAX_SAVES) {
        store64(match_saves + k2 * 8, 0 - 1);
        k2 = k2 + 1;
    }
    var cur = _bre_m_cur;
    var nxt = _bre_m_next;
    store64(cur, 0);
    store64(nxt, 0);
    _bre_m_gen = _bre_m_gen + 1;
    _bre_add_thread(cur, 0, input, input_len, start_pos, saves_scratch, instrs);
    var pos = start_pos;
    var done = 0;
    while (done == 0) {
        var c = 0 - 1;
        if (pos < input_len) { c = load8(input + pos); }
        _bre_m_gen = _bre_m_gen + 1;
        var n_cur = load64(cur);
        var ti = 0;
        while (ti < n_cur) {
            var pc = load64(cur + 8 + ti * 168);
            var iw0 = load64(instrs + pc * 16);
            var iop = iw0 & 0xFF;
            if (iop == BRE_OP_MATCH) {
                matched = pos;
                var ks = 0;
                while (ks < BRE_MAX_SAVES) {
                    store64(match_saves + ks * 8, load64(cur + 8 + ti * 168 + 8 + ks * 8));
                    ks = ks + 1;
                }
                ti = n_cur;
            }
            elif (iop == BRE_OP_CHAR) {
                var want = (iw0 >> 8) & 0xFF;
                if (c >= 0 && c == want) {
                    var ks2 = 0;
                    while (ks2 < BRE_MAX_SAVES) {
                        store64(saves_scratch + ks2 * 8, load64(cur + 8 + ti * 168 + 8 + ks2 * 8));
                        ks2 = ks2 + 1;
                    }
                    _bre_add_thread(nxt, pc + 1, input, input_len, pos + 1, saves_scratch, instrs);
                }
            }
            elif (iop == BRE_OP_ANY) {
                if (c >= 0) {
                    var ks3 = 0;
                    while (ks3 < BRE_MAX_SAVES) {
                        store64(saves_scratch + ks3 * 8, load64(cur + 8 + ti * 168 + 8 + ks3 * 8));
                        ks3 = ks3 + 1;
                    }
                    _bre_add_thread(nxt, pc + 1, input, input_len, pos + 1, saves_scratch, instrs);
                }
            }
            elif (iop == BRE_OP_CLASS || iop == BRE_OP_NCLASS) {
                if (c >= 0) {
                    var ci = (iw0 >> 8) & 0xFF;
                    var hit = _bre_class_get_at(class_base, ci, c);
                    if (iop == BRE_OP_NCLASS) {
                        if (hit == 1) { hit = 0; } else { hit = 1; }
                    }
                    if (hit == 1) {
                        var ks4 = 0;
                        while (ks4 < BRE_MAX_SAVES) {
                            store64(saves_scratch + ks4 * 8, load64(cur + 8 + ti * 168 + 8 + ks4 * 8));
                            ks4 = ks4 + 1;
                        }
                        _bre_add_thread(nxt, pc + 1, input, input_len, pos + 1, saves_scratch, instrs);
                    }
                }
            }
            ti = ti + 1;
        }
        var swap = cur;
        cur = nxt;
        nxt = swap;
        store64(nxt, 0);
        if (pos > input_len) { done = 1; }
        elif (load64(cur) == 0) { done = 1; }
        else { pos = pos + 1; }
    }
    if (matched >= 0) {
        var ks5 = 0;
        while (ks5 < BRE_MAX_SAVES) {
            store64(nfa + BRE_OFF_SAVES + ks5 * 8, load64(match_saves + ks5 * 8));
            ks5 = ks5 + 1;
        }
        store64(nfa + BRE_OFF_MATCH_START, load64(match_saves));
        store64(nfa + BRE_OFF_MATCH_END,   matched);
    } else {
        store64(nfa + BRE_OFF_MATCH_START, 0 - 1);
        store64(nfa + BRE_OFF_MATCH_END,   0 - 1);
    }
    return matched;
}

# === Public API ======================================================

fn niyama_bre_match(nfa, s): i64 {
    if (nfa == 0) { return 0; }
    var len = strlen(s);
    var r = _bre_pike_run(nfa, s, len, 0);
    if (r >= 0) { return 1; }
    return 0;
}

fn niyama_bre_search(nfa, s): i64 {
    if (nfa == 0) { return 0 - 1; }
    var len = strlen(s);
    return niyama_bre_search_at(nfa, s, len, 0);
}

fn niyama_bre_search_at(nfa, s, len, from): i64 {
    if (nfa == 0) { return 0 - 1; }
    var i = from;
    while (i <= len) {
        var r = _bre_pike_run(nfa, s, len, i);
        if (r >= 0) { return i; }
        i = i + 1;
    }
    return 0 - 1;
}

fn niyama_bre_group_start(nfa, n): i64 {
    if (nfa == 0)        { return 0 - 1; }
    if (n < 0 || n > 9)  { return 0 - 1; }
    return load64(nfa + BRE_OFF_SAVES + n * 16);
}

fn niyama_bre_group_end(nfa, n): i64 {
    if (nfa == 0)        { return 0 - 1; }
    if (n < 0 || n > 9)  { return 0 - 1; }
    return load64(nfa + BRE_OFF_SAVES + n * 16 + 8);
}

# --- re2.cyr ---

# re2.cyr — niyama RE2-flavor engine.
#
# Linear-time Pike NFA matcher with ERE-flavor parser, exposed via the
# niyama_re2_* ABI defined in docs/adr/0003-re2-engine-abi-and-scope.md.
#
# What re2 adds over stdlib lib/regex.cyr's already-present Pike NFA:
#   - Compile-time rejection of features that BREAK linear-time matching
#     (backref, lookaround, atomic groups, recursion). Each gets a
#     distinct error code so consumers know exactly which engine to fall
#     back to (niyama_pcre at M3).
#   - The advertised guarantee at the API level: any pattern that
#     niyama_re2_compile accepts is matchable in O(N × M) time
#     regardless of pattern shape. Catastrophic-backtracking inputs
#     terminate in linear time.
#
# Architecture: forked from src/bre.cyr (which itself forks the cyrius
# stdlib lib/regex.cyr Pike NFA). Same instruction model, same matcher
# kernel; the parser is ERE-flavor instead of POSIX BRE.
#
# Public API (mirrors niyama_bre_* per ADR 0002):
#   niyama_re2_compile(pat)       -> opaque NFA pointer or 0 on error
#   niyama_re2_match(nfa, s)      -> 1 if anchored match, else 0
#   niyama_re2_search(nfa, s)     -> first match offset, or -1
#   niyama_re2_search_at(...)     -> first match offset starting at `from`
#   niyama_re2_group_start(nfa,n) -> group n start or -1
#   niyama_re2_group_end(nfa,n)   -> group n end or -1
#   niyama_re2_last_error()       -> error code from most recent compile
#
# Out of scope for M2 (deferred per ADR 0003):
#   - Named captures (?P<name>...) — landed in v0.7.0 (ADR 0007).
#   - Unicode property classes \p{L} — landed in v0.8.0 (ADR 0008).
#   - Inline flags (?i) (?m) (?s) — landed in v0.7.0 (ADR 0007).
#
# v0.7.0 behavior change: niyama_re2's `^`, `$`, and `.` are now
# **strict-by-default** (matching the RE2/PCRE spec) — `^`/`$` only
# at string boundaries, `.` does not match `\n`. Multi-line semantics
# require `(?m)`; dot-matches-newline requires `(?s)`. Pre-v0.7.0
# implementations were silently loose; this is a documented change
# pre-surface-freeze (M5).
#
# Precondition: alloc_init() must have been called.
#
# All globals are `_re2_*`-prefixed for collision-free coexistence with
# niyama_bre and stdlib regex.cyr in the same program.

# === Constants ========================================================

var RE2_OP_MATCH     = 0;
var RE2_OP_CHAR      = 1;
var RE2_OP_ANY       = 2;
var RE2_OP_CLASS     = 3;
var RE2_OP_NCLASS    = 4;
var RE2_OP_JMP       = 5;
var RE2_OP_SPLIT     = 6;
var RE2_OP_SAVE      = 7;
var RE2_OP_BOL       = 8;       # multiline ^ — fires at pos 0 OR after \n
var RE2_OP_EOL       = 9;       # multiline $ — fires at pos len OR at \n
var RE2_OP_BOUNDARY  = 10;
var RE2_OP_NBOUNDARY = 11;
# v0.7.0 — opcodes added for PCRE-spec strict default of ^/$/. and
# the case-insensitive CHAR_CI used by `(?i)` flag emission.
var RE2_OP_CHAR_CI   = 12;      # case-insensitive char (ASCII fold)
var RE2_OP_BOS       = 13;      # strict ^ — pos == 0 only
var RE2_OP_EOS       = 14;      # strict $ — pos == len only
var RE2_OP_ANY_NONL  = 15;      # . excluding \n
# v0.8.0 — Unicode property class \p{L} / \P{L} via stdlib lib/unicode.
# 30-bit GeneralCategory mask packed into upper 32 bits of word0.
var RE2_OP_UPROP     = 16;      # \p{NAME} — cp_category(cp) ∈ mask
var RE2_OP_NUPROP    = 17;      # \P{NAME} — cp_category(cp) ∉ mask
# v0.8.0 — multi-byte literal char in pattern. Codepoint stored in
# upper 32 bits of word0. Emitted instead of byte-wise CHAR when the
# parser sees a non-ASCII literal, so that codepoint-stepped matching
# treats the multi-byte pattern char as a single unit (else the
# successor pos lands past the trailing UTF-8 continuation bytes and
# they never match).
var RE2_OP_UCHAR     = 18;      # codepoint literal — match cp == stored
# v0.8.0 — (?i) Unicode case-fold upgrade. Stores unicode_to_lower(cp).
# Matcher folds input cp via unicode_to_lower and compares. Handles
# Greek/Cyrillic/accented Latin 1:1 case pairs. Full case folding
# (e.g. ß↔SS — 1:many) is NOT in scope for v0.8.0; if a consumer
# asks, it goes onto the v0.8.x ladder.
var RE2_OP_UCHAR_CI  = 19;      # case-insensitive codepoint literal

var RE2_NFA_HEADER_SIZE = 256;  # extended for name table (was 216)
var RE2_OFF_INSTR_COUNT = 0;
var RE2_OFF_INSTRS_OFF  = 8;
var RE2_OFF_CLASS_COUNT = 16;
var RE2_OFF_CLASSES_OFF = 24;
var RE2_OFF_CAPTURES    = 32;
var RE2_OFF_MATCH_START = 40;
var RE2_OFF_MATCH_END   = 48;
var RE2_OFF_SAVES       = 56;   # 20 × 8 = 160 bytes (covers up to 215)
var RE2_OFF_NAMES_OFF   = 216;
var RE2_OFF_NAME_COUNT  = 224;

var RE2_MAX_INSTRS  = 4096;
var RE2_MAX_CLASSES = 64;
var RE2_MAX_SAVES   = 20;
var RE2_MAX_NAMES   = 9;
var RE2_NAME_SLOT_SIZE = 40;    # 32 bytes name (NUL-padded) + 8 bytes group_idx
var RE2_NAME_MAX_LEN   = 31;

# Error codes — frozen-at-M2 ABI per ADR 0003. v0.7.0 adds error 7
# (RE2_E_DUPLICATE_NAME) per ADR 0007; existing codes unchanged.
var RE2_E_OK                    = 0;
var RE2_E_SYNTAX                = 1;
var RE2_E_BACKREF_UNSUPPORTED   = 2;  # \1-\9 — non-regular
var RE2_E_LOOKAROUND_UNSUPPORTED = 3; # (?=...) (?!...) (?<=...) (?<!...)
var RE2_E_ATOMIC_UNSUPPORTED    = 4;  # (?>...) — backtracking-only
var RE2_E_RECURSION_UNSUPPORTED = 5;  # (?R) (?P>name) — non-regular
var RE2_E_TOO_LARGE             = 6;
var RE2_E_DUPLICATE_NAME        = 7;  # v0.7.0: (?<x>...)(?<x>...)
var RE2_E_BAD_PROPERTY          = 8;  # v0.8.0: \p{Xy} unrecognized name

# === Compile-time globals ============================================

var _re2_pat = 0;
var _re2_pat_len = 0;
var _re2_pos = 0;
var _re2_nfa = 0;
var _re2_instr_base = 0;
var _re2_class_base = 0;
var _re2_name_base = 0;
var _re2_instr_n = 0;
var _re2_class_n = 0;
var _re2_capture_n = 0;
var _re2_name_n = 0;
var _re2_err = 0;
var _re2_last_err = 0;
# v0.7.0 — inline-flag compile-time state (?i)/(?m)/(?s).
var _re2_flag_i = 0;
var _re2_flag_m = 0;
var _re2_flag_s = 0;

# Process-lifetime scratch (lazy-init).
var _re2_m_init = 0;
var _re2_m_cur = 0;
var _re2_m_next = 0;
var _re2_m_lastgen = 0;
var _re2_m_gen = 0;
var _re2_q_splits = 0;
# v0.8.0 — scratch slot for stdlib _uc_decode_utf8 codepoint output.
var _re2_m_cp_slot = 0;

fn _re2_lazy_init(): i64 {
    if (_re2_m_init == 1) { return 0; }
    _re2_m_cur     = alloc(8 + RE2_MAX_INSTRS * 168);
    _re2_m_next    = alloc(8 + RE2_MAX_INSTRS * 168);
    _re2_m_lastgen = alloc(RE2_MAX_INSTRS * 8);
    _re2_q_splits  = alloc(64 * 8);
    _re2_m_cp_slot = alloc(8);
    var i = 0;
    while (i < RE2_MAX_INSTRS) {
        store64(_re2_m_lastgen + i * 8, 0);
        i = i + 1;
    }
    _re2_m_init = 1;
    _re2_m_gen = 1;
    return 0;
}

# === Instruction emit / patch helpers ================================

fn _re2_w0(op, small, arg1): i64 {
    return op | (small << 8) | (arg1 << 32);
}

fn _re2_emit_raw(w0, w1): i64 {
    var i = _re2_instr_n;
    if (i >= RE2_MAX_INSTRS) { _re2_err = RE2_E_TOO_LARGE; return i; }
    store64(_re2_instr_base + i * 16, w0);
    store64(_re2_instr_base + i * 16 + 8, w1);
    _re2_instr_n = i + 1;
    return i;
}

fn _re2_emit_op(op): i64 { return _re2_emit_raw(op, 0); }
fn _re2_emit_char(c): i64 {
    # v0.7.0 — under (?i) emit CHAR_CI; the matcher does case-fold.
    var op = RE2_OP_CHAR;
    if (_re2_flag_i == 1) { op = RE2_OP_CHAR_CI; }
    # CHAR_CI stores the lower-case form to make the runtime check
    # cheap (single fold of the input byte, compare to lowered want).
    var stored = c;
    if (_re2_flag_i == 1 && c >= 65 && c <= 90) { stored = c + 32; }
    return _re2_emit_raw(op | (stored << 8), 0);
}
fn _re2_emit_class(neg, ci): i64 {
    var op = RE2_OP_CLASS;
    if (neg == 1) { op = RE2_OP_NCLASS; }
    return _re2_emit_raw(op | (ci << 8), 0);
}
fn _re2_emit_save(idx): i64 { return _re2_emit_raw(RE2_OP_SAVE | (idx << 8), 0); }
fn _re2_emit_jmp(target): i64 { return _re2_emit_raw(RE2_OP_JMP | (target << 32), 0); }
fn _re2_emit_split(a, b): i64 { return _re2_emit_raw(RE2_OP_SPLIT | (a << 32), b); }
fn _re2_emit_uprop(neg, mask): i64 {
    var op = RE2_OP_UPROP;
    if (neg == 1) { op = RE2_OP_NUPROP; }
    return _re2_emit_raw(op | (mask << 32), 0);
}
fn _re2_emit_uchar(cp): i64 {
    return _re2_emit_raw(RE2_OP_UCHAR | (cp << 32), 0);
}
fn _re2_emit_uchar_ci(cp): i64 {
    return _re2_emit_raw(RE2_OP_UCHAR_CI | (cp << 32), 0);
}

fn _re2_patch_arg1(idx, arg1): i64 {
    var off = _re2_instr_base + idx * 16;
    var w0 = load64(off);
    store64(off, (w0 & 0xFFFFFFFF) | (arg1 << 32));
    return 0;
}

fn _re2_patch_arg2(idx, arg2): i64 {
    store64(_re2_instr_base + idx * 16 + 8, arg2);
    return 0;
}

fn _re2_shift_right(lo, hi): i64 {
    var k = (hi - lo) * 16 - 1;
    while (k >= 0) {
        var src = _re2_instr_base + lo * 16 + k;
        store8(src + 16, load8(src));
        k = k - 1;
    }
    return 0;
}

fn _re2_shift_targets_one(lo, hi): i64 {
    var i = lo + 1;
    var end = hi + 1;
    while (i < end) {
        var off = _re2_instr_base + i * 16;
        var w0 = load64(off);
        var op = w0 & 0xFF;
        var is_branch = 0;
        if (op == RE2_OP_JMP)   { is_branch = 1; }
        if (op == RE2_OP_SPLIT) { is_branch = 1; }
        if (is_branch == 1) {
            var arg1 = (w0 >> 32) & 0xFFFFFFFF;
            if (arg1 >= lo && arg1 <= hi) {
                _re2_patch_arg1(i, arg1 + 1);
            }
            if (op == RE2_OP_SPLIT) {
                var arg2 = load64(off + 8);
                if (arg2 >= lo && arg2 <= hi) {
                    _re2_patch_arg2(i, arg2 + 1);
                }
            }
        }
        i = i + 1;
    }
    return 0;
}

# === Class bitmap helpers ============================================

fn _re2_alloc_class(): i64 {
    var ci = _re2_class_n;
    if (ci >= RE2_MAX_CLASSES) { _re2_err = RE2_E_TOO_LARGE; return ci; }
    var z = 0;
    while (z < 32) {
        store8(_re2_class_base + ci * 32 + z, 0);
        z = z + 1;
    }
    _re2_class_n = ci + 1;
    return ci;
}

fn _re2_class_set(ci, c): i64 {
    if (c < 0)   { return 0; }
    if (c > 255) { return 0; }
    var off = _re2_class_base + ci * 32 + (c >> 3);
    store8(off, load8(off) | (1 << (c & 7)));
    return 0;
}

fn _re2_class_range(ci, lo, hi): i64 {
    var c = lo;
    while (c <= hi) {
        _re2_class_set(ci, c);
        c = c + 1;
    }
    return 0;
}

fn _re2_class_invert(ci): i64 {
    var z = 0;
    while (z < 32) {
        var off = _re2_class_base + ci * 32 + z;
        store8(off, 255 ^ load8(off));
        z = z + 1;
    }
    return 0;
}

fn _re2_class_fill_digit(ci): i64 { _re2_class_range(ci, 48, 57); return 0; }

fn _re2_class_fill_word(ci): i64 {
    _re2_class_range(ci, 48, 57);
    _re2_class_range(ci, 65, 90);
    _re2_class_range(ci, 97, 122);
    _re2_class_set(ci, 95);
    return 0;
}

fn _re2_class_fill_space(ci): i64 {
    _re2_class_set(ci, 32);
    _re2_class_set(ci, 9);
    _re2_class_set(ci, 10);
    _re2_class_set(ci, 11);
    _re2_class_set(ci, 12);
    _re2_class_set(ci, 13);
    return 0;
}

# v0.7.0 — set `c` and (under (?i)) also its opposite-case ASCII letter.
fn _re2_class_set_folded(ci, c): i64 {
    _re2_class_set(ci, c);
    if (_re2_flag_i == 1) {
        if (c >= 65 && c <= 90)   { _re2_class_set(ci, c + 32); }
        elif (c >= 97 && c <= 122) { _re2_class_set(ci, c - 32); }
    }
    return 0;
}

fn _re2_class_range_folded(ci, lo, hi): i64 {
    var c = lo;
    while (c <= hi) {
        _re2_class_set_folded(ci, c);
        c = c + 1;
    }
    return 0;
}

# === Named-capture name table (v0.7.0) ===============================
# Mirrors niyama_pcre's scheme — same slot layout, same lookup ABI
# shape so the cross-engine surface stays uniform.

fn _re2_is_name_first(c): i64 {
    if (c >= 65 && c <= 90)  { return 1; }
    if (c >= 97 && c <= 122) { return 1; }
    if (c == 95)             { return 1; }
    return 0;
}
fn _re2_is_name_rest(c): i64 {
    if (_re2_is_name_first(c) == 1) { return 1; }
    if (c >= 48 && c <= 57)         { return 1; }
    return 0;
}

fn _re2_add_name(group_idx, terminator): i64 {
    if (_re2_pos >= _re2_pat_len) { _re2_err = RE2_E_SYNTAX; return 0 - 1; }
    var first = load8(_re2_pat + _re2_pos);
    if (_re2_is_name_first(first) == 0) { _re2_err = RE2_E_SYNTAX; return 0 - 1; }
    var name_start = _re2_pos;
    _re2_pos = _re2_pos + 1;
    while (_re2_pos < _re2_pat_len && _re2_is_name_rest(load8(_re2_pat + _re2_pos)) == 1) {
        _re2_pos = _re2_pos + 1;
    }
    var name_len = _re2_pos - name_start;
    if (name_len > RE2_NAME_MAX_LEN) { _re2_err = RE2_E_TOO_LARGE; return 0 - 1; }
    if (_re2_pos >= _re2_pat_len || load8(_re2_pat + _re2_pos) != terminator) {
        _re2_err = RE2_E_SYNTAX; return 0 - 1;
    }
    _re2_pos = _re2_pos + 1;  # consume terminator (`>`)

    # Duplicate-name detection.
    var i = 0;
    while (i < _re2_name_n) {
        var slot = _re2_name_base + i * RE2_NAME_SLOT_SIZE;
        var slot_len = 0;
        while (slot_len < RE2_NAME_MAX_LEN && load8(slot + slot_len) != 0) {
            slot_len = slot_len + 1;
        }
        if (slot_len == name_len) {
            var k = 0;
            var same = 1;
            while (k < name_len) {
                if (load8(slot + k) != load8(_re2_pat + name_start + k)) {
                    same = 0;
                    k = name_len;
                }
                k = k + 1;
            }
            if (same == 1) { _re2_err = RE2_E_DUPLICATE_NAME; return 0 - 1; }
        }
        i = i + 1;
    }

    if (_re2_name_n >= RE2_MAX_NAMES) { _re2_err = RE2_E_TOO_LARGE; return 0 - 1; }
    var dst = _re2_name_base + _re2_name_n * RE2_NAME_SLOT_SIZE;
    var k2 = 0;
    while (k2 < name_len) {
        store8(dst + k2, load8(_re2_pat + name_start + k2));
        k2 = k2 + 1;
    }
    while (k2 < RE2_NAME_MAX_LEN + 1) {
        store8(dst + k2, 0);
        k2 = k2 + 1;
    }
    store64(dst + 32, group_idx);
    _re2_name_n = _re2_name_n + 1;
    return 0;
}

# === Pattern decoder =================================================

# v0.7.0 — parse `(?...)` body when `...` is one or more of i/m/s.
# Caller has consumed `(?` and `_re2_pos` is at the first flag char.
# Returns 1 on success (flags applied + `)` consumed); 0 if the body
# is not pure-flag (caller should treat as a different (?...) form).
# Sets _re2_err on syntax error inside a recognized flag run.
fn _re2_try_inline_flags(): i64 {
    var p = _re2_pos;
    # Quick check — first byte must be i/m/s for the entire form to be
    # "(?<flags>)". Caller has already discriminated for `(?<`, `(?=`,
    # `(?!`, `(?:`, `(?>`, `(?P`, `(?R`, so this is fine.
    var first = load8(_re2_pat + p);
    if (first != 105 && first != 109 && first != 115) { return 0; }
    var fi = 0; var fm = 0; var fs = 0;
    var scanning = 1;
    while (scanning == 1) {
        if (p >= _re2_pat_len) { _re2_err = RE2_E_SYNTAX; return 0; }
        var c = load8(_re2_pat + p);
        if      (c == 105) { fi = 1; p = p + 1; }
        elif    (c == 109) { fm = 1; p = p + 1; }
        elif    (c == 115) { fs = 1; p = p + 1; }
        elif    (c == 41)  { scanning = 0; }
        else               { _re2_err = RE2_E_SYNTAX; return 0; }
    }
    _re2_pos = p + 1;  # consume `)`
    if (fi == 1) { _re2_flag_i = 1; }
    if (fm == 1) { _re2_flag_m = 1; }
    if (fs == 1) { _re2_flag_s = 1; }
    return 1;
}

fn _re2_lit_byte(): i64 {
    if (_re2_pos >= _re2_pat_len) { _re2_err = RE2_E_SYNTAX; return 0; }
    var c = load8(_re2_pat + _re2_pos);
    _re2_pos = _re2_pos + 1;
    if (c != 92) { return c; }
    if (_re2_pos >= _re2_pat_len) { _re2_err = RE2_E_SYNTAX; return 0; }
    var e = load8(_re2_pat + _re2_pos);
    _re2_pos = _re2_pos + 1;
    if (e == 110) { return 10; }
    if (e == 114) { return 13; }
    if (e == 116) { return 9; }
    if (e == 48)  { return 0; }
    if (e == 97)  { return 7; }
    if (e == 102) { return 12; }
    if (e == 118) { return 11; }
    return e;
}

# Parse a `[...]` bracket-expression body. Returns the class index;
# negation encoded as -(ci+1).
fn _re2_parse_class(): i64 {
    var ci = _re2_alloc_class();
    if (_re2_err != RE2_E_OK) { return ci; }
    var neg = 0;
    if (_re2_pos < _re2_pat_len && load8(_re2_pat + _re2_pos) == 94) {
        neg = 1;
        _re2_pos = _re2_pos + 1;
    }
    var first = 1;
    var done = 0;
    while (done == 0) {
        if (_re2_pos >= _re2_pat_len) { _re2_err = RE2_E_SYNTAX; return 0 - 1; }
        var pc = load8(_re2_pat + _re2_pos);
        if (pc == 93 && first == 0) {
            _re2_pos = _re2_pos + 1;
            done = 1;
        }
        elif (pc == 91 && _re2_pos + 1 < _re2_pat_len && load8(_re2_pat + _re2_pos + 1) == 58) {
            # v0.9.0 — POSIX bracket class [:name:] inside char class.
            # Fixes ADR 0007 oversight: bre/pcre/vim got POSIX classes,
            # re2 was missed. Hook into shared posix_classes.cyr.
            var category = _posix_match_class_name(_re2_pat, _re2_pos + 2, _re2_pat_len);
            if (category == 0) {
                _re2_err = RE2_E_SYNTAX;
                return 0 - 1;
            }
            _posix_apply_filler(_re2_class_base, ci, category);
            _re2_pos = _posix_match_end_pos;
            first = 0;
        }
        elif (pc == 92 && _re2_pos + 1 < _re2_pat_len) {
            var nx = load8(_re2_pat + _re2_pos + 1);
            if (nx == 100)      { _re2_class_fill_digit(ci); _re2_pos = _re2_pos + 2; }
            elif (nx == 119)    { _re2_class_fill_word(ci);  _re2_pos = _re2_pos + 2; }
            elif (nx == 115)    { _re2_class_fill_space(ci); _re2_pos = _re2_pos + 2; }
            elif (nx == 68) {
                # \D inside [...]: union the negation of digits.
                var tmp = _re2_alloc_class();
                if (_re2_err != RE2_E_OK) { return 0 - 1; }
                _re2_class_fill_digit(tmp);
                _re2_class_invert(tmp);
                var z = 0;
                while (z < 32) {
                    var d = _re2_class_base + ci * 32 + z;
                    var s = _re2_class_base + tmp * 32 + z;
                    store8(d, load8(d) | load8(s));
                    z = z + 1;
                }
                _re2_class_n = _re2_class_n - 1;
                _re2_pos = _re2_pos + 2;
            }
            elif (nx == 87) {
                var tmp2 = _re2_alloc_class();
                if (_re2_err != RE2_E_OK) { return 0 - 1; }
                _re2_class_fill_word(tmp2);
                _re2_class_invert(tmp2);
                var z2 = 0;
                while (z2 < 32) {
                    var d2 = _re2_class_base + ci * 32 + z2;
                    var s2 = _re2_class_base + tmp2 * 32 + z2;
                    store8(d2, load8(d2) | load8(s2));
                    z2 = z2 + 1;
                }
                _re2_class_n = _re2_class_n - 1;
                _re2_pos = _re2_pos + 2;
            }
            elif (nx == 83) {
                var tmp3 = _re2_alloc_class();
                if (_re2_err != RE2_E_OK) { return 0 - 1; }
                _re2_class_fill_space(tmp3);
                _re2_class_invert(tmp3);
                var z3 = 0;
                while (z3 < 32) {
                    var d3 = _re2_class_base + ci * 32 + z3;
                    var s3 = _re2_class_base + tmp3 * 32 + z3;
                    store8(d3, load8(d3) | load8(s3));
                    z3 = z3 + 1;
                }
                _re2_class_n = _re2_class_n - 1;
                _re2_pos = _re2_pos + 2;
            }
            else {
                var lc = _re2_lit_byte();
                if (_re2_err != RE2_E_OK) { return 0 - 1; }
                if (_re2_pos + 1 < _re2_pat_len && load8(_re2_pat + _re2_pos) == 45 && load8(_re2_pat + _re2_pos + 1) != 93) {
                    _re2_pos = _re2_pos + 1;
                    var hi = _re2_lit_byte();
                    if (_re2_err != RE2_E_OK) { return 0 - 1; }
                    _re2_class_range_folded(ci, lc, hi);
                } else {
                    _re2_class_set_folded(ci, lc);
                }
            }
            first = 0;
        }
        else {
            var lc2 = _re2_lit_byte();
            if (_re2_err != RE2_E_OK) { return 0 - 1; }
            if (_re2_pos + 1 < _re2_pat_len && load8(_re2_pat + _re2_pos) == 45 && load8(_re2_pat + _re2_pos + 1) != 93) {
                _re2_pos = _re2_pos + 1;
                var hi2 = _re2_lit_byte();
                if (_re2_err != RE2_E_OK) { return 0 - 1; }
                _re2_class_range_folded(ci, lc2, hi2);
            } else {
                _re2_class_set_folded(ci, lc2);
            }
            first = 0;
        }
    }
    if (neg == 1) { return 0 - (ci + 1); }
    return ci;
}

# === Recursive-descent ERE compiler ==================================
#
# The non-regular-feature rejection lives here. After consuming `(`, we
# inspect the next bytes to detect:
#   `(?:` -> non-capturing group (allowed)
#   `(?=` `(?!` -> lookahead (REJECT: RE2_E_LOOKAROUND_UNSUPPORTED)
#   `(?<=` `(?<!` -> lookbehind (REJECT)
#   `(?<...>` -> named capture (REJECT for now: RE2_E_SYNTAX, deferred)
#   `(?>` -> atomic group (REJECT: RE2_E_ATOMIC_UNSUPPORTED)
#   `(?P<...>` -> named capture (REJECT for now)
#   `(?P>` -> recursion (REJECT: RE2_E_RECURSION_UNSUPPORTED)
#   `(?R)` -> recursion (REJECT)
#   `(?...)` (anything else) -> RE2_E_SYNTAX

fn _re2_parse_primary(): i64 {
    if (_re2_pos >= _re2_pat_len) { _re2_err = RE2_E_SYNTAX; return 0; }
    var c = load8(_re2_pat + _re2_pos);
    if (c == 46) {
        # v0.7.0 — strict default: `.` excludes \n. `(?s)` flips to ANY.
        _re2_pos = _re2_pos + 1;
        if (_re2_flag_s == 1) { _re2_emit_op(RE2_OP_ANY); }
        else                   { _re2_emit_op(RE2_OP_ANY_NONL); }
    }
    elif (c == 94) {
        # v0.7.0 — strict default: `^` only at pos 0. `(?m)` flips to BOL.
        _re2_pos = _re2_pos + 1;
        if (_re2_flag_m == 1) { _re2_emit_op(RE2_OP_BOL); }
        else                   { _re2_emit_op(RE2_OP_BOS); }
    }
    elif (c == 36) {
        # v0.7.0 — strict default: `$` only at pos len. `(?m)` flips to EOL.
        _re2_pos = _re2_pos + 1;
        if (_re2_flag_m == 1) { _re2_emit_op(RE2_OP_EOL); }
        else                   { _re2_emit_op(RE2_OP_EOS); }
    }
    elif (c == 40) {
        # `(` — group. Inspect for `(?...)` sub-syntax.
        _re2_pos = _re2_pos + 1;
        var capture_idx = 0 - 1;
        if (_re2_pos < _re2_pat_len && load8(_re2_pat + _re2_pos) == 63) {
            # `(?` — must be one of: `(?:` `(?=` `(?!` `(?<=` `(?<!` `(?<NAME>` `(?>` `(?P<NAME>` `(?P>NAME` `(?R)` `(?ims)` ...
            if (_re2_pos + 1 >= _re2_pat_len) { _re2_err = RE2_E_SYNTAX; return 0; }
            var n1 = load8(_re2_pat + _re2_pos + 1);
            # `(?:` non-capturing — allowed.
            if (n1 == 58) {
                _re2_pos = _re2_pos + 2;
                # fall through to body parse below (no save emitted)
            }
            elif (n1 == 61 || n1 == 33) {
                # (?=...) lookahead, (?!...) negative lookahead
                _re2_err = RE2_E_LOOKAROUND_UNSUPPORTED;
                return 0;
            }
            elif (n1 == 60) {
                # (?<=...) lookbehind, (?<!...) negative lookbehind, OR
                # (?<NAME>...) named capture (v0.7.0).
                if (_re2_pos + 2 >= _re2_pat_len) { _re2_err = RE2_E_SYNTAX; return 0; }
                var n2 = load8(_re2_pat + _re2_pos + 2);
                if (n2 == 61 || n2 == 33) {
                    _re2_err = RE2_E_LOOKAROUND_UNSUPPORTED;
                    return 0;
                }
                # (?<NAME>...) named capture.
                _re2_pos = _re2_pos + 2;  # past `(?<`
                _re2_capture_n = _re2_capture_n + 1;
                if (_re2_capture_n > 9) { _re2_err = RE2_E_SYNTAX; return 0; }
                _re2_add_name(_re2_capture_n, 62);  # terminator `>`
                if (_re2_err != RE2_E_OK) { return 0; }
                capture_idx = _re2_capture_n;
                _re2_emit_save(capture_idx * 2);
            }
            elif (n1 == 62) {
                # (?>...) atomic group
                _re2_err = RE2_E_ATOMIC_UNSUPPORTED;
                return 0;
            }
            elif (n1 == 80) {
                # `(?P<NAME>` named capture (v0.7.0) or `(?P>NAME)` recursion.
                if (_re2_pos + 2 >= _re2_pat_len) { _re2_err = RE2_E_SYNTAX; return 0; }
                var p2 = load8(_re2_pat + _re2_pos + 2);
                if (p2 == 62) {
                    # (?P>NAME) — subroutine call / recursion.
                    _re2_err = RE2_E_RECURSION_UNSUPPORTED;
                    return 0;
                }
                if (p2 == 60) {
                    # (?P<NAME>...) named capture.
                    _re2_pos = _re2_pos + 3;  # past `(?P<`
                    _re2_capture_n = _re2_capture_n + 1;
                    if (_re2_capture_n > 9) { _re2_err = RE2_E_SYNTAX; return 0; }
                    _re2_add_name(_re2_capture_n, 62);
                    if (_re2_err != RE2_E_OK) { return 0; }
                    capture_idx = _re2_capture_n;
                    _re2_emit_save(capture_idx * 2);
                } else {
                    _re2_err = RE2_E_SYNTAX;
                    return 0;
                }
            }
            elif (n1 == 82) {
                # (?R) — recursion
                _re2_err = RE2_E_RECURSION_UNSUPPORTED;
                return 0;
            }
            elif (n1 == 105 || n1 == 109 || n1 == 115) {
                # v0.7.0 — `(?i)` `(?m)` `(?s)` (and combinations).
                _re2_pos = _re2_pos + 1;  # past `?`
                _re2_try_inline_flags();
                if (_re2_err != RE2_E_OK) { return 0; }
                # Flags-only (?...) emits no instructions; do NOT fall
                # through into alt parsing.
                return 0;
            }
            else {
                _re2_err = RE2_E_SYNTAX;
                return 0;
            }
        }
        else {
            # Plain `(` — capturing group.
            _re2_capture_n = _re2_capture_n + 1;
            capture_idx = _re2_capture_n;
            if (capture_idx > 9) { _re2_err = RE2_E_SYNTAX; return 0; }
            _re2_emit_save(capture_idx * 2);
        }
        _re2_parse_alt();
        if (_re2_err != RE2_E_OK) { return 0; }
        if (_re2_pos >= _re2_pat_len || load8(_re2_pat + _re2_pos) != 41) { _re2_err = RE2_E_SYNTAX; return 0; }
        _re2_pos = _re2_pos + 1;
        if (capture_idx >= 0) { _re2_emit_save(capture_idx * 2 + 1); }
    }
    elif (c == 91) {
        _re2_pos = _re2_pos + 1;
        var ci = _re2_parse_class();
        if (_re2_err != RE2_E_OK) { return 0; }
        var neg = 0;
        if (ci < 0) { neg = 1; ci = 0 - (ci + 1); }
        _re2_emit_class(neg, ci);
    }
    elif (c == 92) {
        if (_re2_pos + 1 >= _re2_pat_len) { _re2_err = RE2_E_SYNTAX; return 0; }
        var e = load8(_re2_pat + _re2_pos + 1);
        # `\1`-`\9` backref — REJECT explicitly per ADR 0003.
        if (e >= 49 && e <= 57) {
            _re2_err = RE2_E_BACKREF_UNSUPPORTED;
            return 0;
        }
        if (e == 100) {
            _re2_pos = _re2_pos + 2;
            var ci2 = _re2_alloc_class(); if (_re2_err != RE2_E_OK) { return 0; }
            _re2_class_fill_digit(ci2);
            _re2_emit_class(0, ci2);
        }
        elif (e == 68) {
            _re2_pos = _re2_pos + 2;
            var ci3 = _re2_alloc_class(); if (_re2_err != RE2_E_OK) { return 0; }
            _re2_class_fill_digit(ci3);
            _re2_emit_class(1, ci3);
        }
        elif (e == 119) {
            _re2_pos = _re2_pos + 2;
            var ci4 = _re2_alloc_class(); if (_re2_err != RE2_E_OK) { return 0; }
            _re2_class_fill_word(ci4);
            _re2_emit_class(0, ci4);
        }
        elif (e == 87) {
            _re2_pos = _re2_pos + 2;
            var ci5 = _re2_alloc_class(); if (_re2_err != RE2_E_OK) { return 0; }
            _re2_class_fill_word(ci5);
            _re2_emit_class(1, ci5);
        }
        elif (e == 115) {
            _re2_pos = _re2_pos + 2;
            var ci6 = _re2_alloc_class(); if (_re2_err != RE2_E_OK) { return 0; }
            _re2_class_fill_space(ci6);
            _re2_emit_class(0, ci6);
        }
        elif (e == 83) {
            _re2_pos = _re2_pos + 2;
            var ci7 = _re2_alloc_class(); if (_re2_err != RE2_E_OK) { return 0; }
            _re2_class_fill_space(ci7);
            _re2_emit_class(1, ci7);
        }
        elif (e == 98) {
            _re2_pos = _re2_pos + 2;
            _re2_emit_op(RE2_OP_BOUNDARY);
        }
        elif (e == 66) {
            _re2_pos = _re2_pos + 2;
            _re2_emit_op(RE2_OP_NBOUNDARY);
        }
        elif (e == 112 || e == 80) {
            # \p{NAME} or \P{NAME} — Unicode property class (v0.8.0).
            var neg_p = 0;
            if (e == 80) { neg_p = 1; }
            var mask = _uprops_parse_class(_re2_pat, _re2_pos + 2, _re2_pat_len);
            if (mask == 0) {
                _re2_err = RE2_E_BAD_PROPERTY;
                return 0;
            }
            _re2_pos = _uprops_match_end_pos;
            _re2_emit_uprop(neg_p, mask);
        }
        else {
            var lc = _re2_lit_byte();
            if (_re2_err == RE2_E_OK) { _re2_emit_char(lc); }
        }
    }
    elif (c == 124 || c == 41 || c == 42 || c == 43 || c == 63 || c == 123 || c == 125 || c == 93) {
        _re2_err = RE2_E_SYNTAX; return 0;
    }
    else {
        if (c >= 128) {
            # v0.8.0 — multi-byte literal: decode cp, emit single UCHAR
            # so codepoint-stepped matcher treats it as one unit. Under
            # (?i) emit UCHAR_CI with the folded codepoint so the
            # matcher's input-cp fold lands on a comparable value.
            var u_step = _uc_decode_utf8(_re2_pat, _re2_pos, _re2_pat_len, _re2_m_cp_slot);
            var u_cp = load64(_re2_m_cp_slot);
            _re2_pos = _re2_pos + u_step;
            if (_re2_flag_i == 1) {
                _re2_emit_uchar_ci(unicode_to_lower(u_cp));
            } else {
                _re2_emit_uchar(u_cp);
            }
        } else {
            _re2_pos = _re2_pos + 1;
            _re2_emit_char(c);
        }
    }
    return 0;
}

fn _re2_apply_simple_q(atom_start, op_char): i64 {
    var atom_end = _re2_instr_n;
    if (atom_end == atom_start) { _re2_err = RE2_E_SYNTAX; return 0; }
    _re2_pos = _re2_pos + 1;
    var lazy = 0;
    if (_re2_pos < _re2_pat_len && load8(_re2_pat + _re2_pos) == 63) {
        lazy = 1;
        _re2_pos = _re2_pos + 1;
    }
    if (op_char == 42) {
        # a* -> SPLIT body, exit ; body ; JMP back ; exit
        _re2_shift_right(atom_start, atom_end);
        _re2_shift_targets_one(atom_start, atom_end);
        _re2_instr_n = _re2_instr_n + 1;
        var body_pc = atom_start + 1;
        if (lazy == 1) {
            store64(_re2_instr_base + atom_start * 16, _re2_w0(RE2_OP_SPLIT, 0, 0));
            store64(_re2_instr_base + atom_start * 16 + 8, body_pc);
        } else {
            store64(_re2_instr_base + atom_start * 16, _re2_w0(RE2_OP_SPLIT, 0, body_pc));
            store64(_re2_instr_base + atom_start * 16 + 8, 0);
        }
        _re2_emit_jmp(atom_start);
        var exit_pc = _re2_instr_n;
        if (lazy == 1) { _re2_patch_arg1(atom_start, exit_pc); }
        else            { _re2_patch_arg2(atom_start, exit_pc); }
    }
    elif (op_char == 43) {
        # a+ -> body ; SPLIT body, exit (greedy) | SPLIT exit, body (lazy)
        if (lazy == 1) {
            var s = _re2_emit_split(0, atom_start);
            _re2_patch_arg1(s, _re2_instr_n);
        } else {
            var s2 = _re2_emit_split(atom_start, 0);
            _re2_patch_arg2(s2, _re2_instr_n);
        }
    }
    elif (op_char == 63) {
        # a? -> SPLIT body, exit (greedy) | SPLIT exit, body (lazy)
        _re2_shift_right(atom_start, atom_end);
        _re2_shift_targets_one(atom_start, atom_end);
        _re2_instr_n = _re2_instr_n + 1;
        var body = atom_start + 1;
        if (lazy == 1) {
            store64(_re2_instr_base + atom_start * 16, _re2_w0(RE2_OP_SPLIT, 0, 0));
            store64(_re2_instr_base + atom_start * 16 + 8, body);
            _re2_patch_arg1(atom_start, _re2_instr_n);
        } else {
            store64(_re2_instr_base + atom_start * 16, _re2_w0(RE2_OP_SPLIT, 0, body));
            store64(_re2_instr_base + atom_start * 16 + 8, _re2_instr_n);
        }
    }
    return 0;
}

fn _re2_apply_star_inline(body_start, lazy): i64 {
    var body_end = _re2_instr_n;
    _re2_shift_right(body_start, body_end);
    _re2_shift_targets_one(body_start, body_end);
    _re2_instr_n = _re2_instr_n + 1;
    var body_pc = body_start + 1;
    if (lazy == 1) {
        store64(_re2_instr_base + body_start * 16, _re2_w0(RE2_OP_SPLIT, 0, 0));
        store64(_re2_instr_base + body_start * 16 + 8, body_pc);
    } else {
        store64(_re2_instr_base + body_start * 16, _re2_w0(RE2_OP_SPLIT, 0, body_pc));
        store64(_re2_instr_base + body_start * 16 + 8, 0);
    }
    _re2_emit_jmp(body_start);
    var exit_pc = _re2_instr_n;
    if (lazy == 1) { _re2_patch_arg1(body_start, exit_pc); }
    else            { _re2_patch_arg2(body_start, exit_pc); }
    return 0;
}

fn _re2_apply_brace_q(save_primary_start, atom_start): i64 {
    if (_re2_instr_n == atom_start) { _re2_err = RE2_E_SYNTAX; return 0; }
    _re2_pos = _re2_pos + 1;
    var n_min = 0;
    var have_min = 0;
    while (_re2_pos < _re2_pat_len && load8(_re2_pat + _re2_pos) >= 48 && load8(_re2_pat + _re2_pos) <= 57) {
        n_min = n_min * 10 + (load8(_re2_pat + _re2_pos) - 48);
        _re2_pos = _re2_pos + 1;
        have_min = 1;
    }
    if (have_min == 0) { _re2_err = RE2_E_SYNTAX; return 0; }
    var n_max = n_min;
    var open_ended = 0;
    if (_re2_pos < _re2_pat_len && load8(_re2_pat + _re2_pos) == 44) {
        _re2_pos = _re2_pos + 1;
        n_max = 0;
        var have_max = 0;
        while (_re2_pos < _re2_pat_len && load8(_re2_pat + _re2_pos) >= 48 && load8(_re2_pat + _re2_pos) <= 57) {
            n_max = n_max * 10 + (load8(_re2_pat + _re2_pos) - 48);
            _re2_pos = _re2_pos + 1;
            have_max = 1;
        }
        if (have_max == 0) { open_ended = 1; n_max = 0; }
    }
    if (_re2_pos >= _re2_pat_len || load8(_re2_pat + _re2_pos) != 125) { _re2_err = RE2_E_SYNTAX; return 0; }
    _re2_pos = _re2_pos + 1;
    var lazy = 0;
    if (_re2_pos < _re2_pat_len && load8(_re2_pat + _re2_pos) == 63) {
        lazy = 1;
        _re2_pos = _re2_pos + 1;
    }
    var pos_after_q = _re2_pos;
    if (open_ended == 0 && n_max < n_min) { _re2_err = RE2_E_SYNTAX; return 0; }
    if (n_max > 1000) { _re2_err = RE2_E_TOO_LARGE; return 0; }
    if (n_min == 0) {
        _re2_instr_n = atom_start;
        if (open_ended == 1) {
            var ts = _re2_instr_n;
            _re2_pos = save_primary_start;
            _re2_parse_primary();
            if (_re2_err != RE2_E_OK) { return 0; }
            _re2_apply_star_inline(ts, lazy);
        } else {
            var sn = 0;
            var k = 0;
            while (k < n_max) {
                if (sn >= 64) { _re2_err = RE2_E_TOO_LARGE; return 0; }
                var sx = _re2_emit_split(0, 0);
                store64(_re2_q_splits + sn * 8, sx);
                sn = sn + 1;
                _re2_pos = save_primary_start;
                _re2_parse_primary();
                if (_re2_err != RE2_E_OK) { return 0; }
                k = k + 1;
            }
            var exit_pc = _re2_instr_n;
            var ti = 0;
            while (ti < sn) {
                var sxi = load64(_re2_q_splits + ti * 8);
                if (lazy == 1) { _re2_patch_arg1(sxi, exit_pc); _re2_patch_arg2(sxi, sxi + 1); }
                else            { _re2_patch_arg1(sxi, sxi + 1); _re2_patch_arg2(sxi, exit_pc); }
                ti = ti + 1;
            }
        }
    } else {
        var k1 = 1;
        while (k1 < n_min) {
            _re2_pos = save_primary_start;
            _re2_parse_primary();
            if (_re2_err != RE2_E_OK) { return 0; }
            k1 = k1 + 1;
        }
        if (open_ended == 1) {
            var ts2 = _re2_instr_n;
            _re2_pos = save_primary_start;
            _re2_parse_primary();
            if (_re2_err != RE2_E_OK) { return 0; }
            _re2_apply_star_inline(ts2, lazy);
        } elif (n_max > n_min) {
            var sn2 = 0;
            var k2 = n_min;
            while (k2 < n_max) {
                if (sn2 >= 64) { _re2_err = RE2_E_TOO_LARGE; return 0; }
                var sy = _re2_emit_split(0, 0);
                store64(_re2_q_splits + sn2 * 8, sy);
                sn2 = sn2 + 1;
                _re2_pos = save_primary_start;
                _re2_parse_primary();
                if (_re2_err != RE2_E_OK) { return 0; }
                k2 = k2 + 1;
            }
            var exit_pc2 = _re2_instr_n;
            var tj = 0;
            while (tj < sn2) {
                var syi = load64(_re2_q_splits + tj * 8);
                if (lazy == 1) { _re2_patch_arg1(syi, exit_pc2); _re2_patch_arg2(syi, syi + 1); }
                else            { _re2_patch_arg1(syi, syi + 1); _re2_patch_arg2(syi, exit_pc2); }
                tj = tj + 1;
            }
        }
    }
    _re2_pos = pos_after_q;
    return 0;
}

fn _re2_parse_atom(): i64 {
    var save_primary_start = _re2_pos;
    var atom_start = _re2_instr_n;
    _re2_parse_primary();
    if (_re2_err != RE2_E_OK) { return 0; }
    if (_re2_pos >= _re2_pat_len) { return 0; }
    var c = load8(_re2_pat + _re2_pos);
    if (c == 42 || c == 43 || c == 63) {
        _re2_apply_simple_q(atom_start, c);
    }
    elif (c == 123) {
        _re2_apply_brace_q(save_primary_start, atom_start);
    }
    return 0;
}

fn _re2_parse_concat(): i64 {
    while (_re2_pos < _re2_pat_len) {
        var c = load8(_re2_pat + _re2_pos);
        if (c == 124 || c == 41) { return 0; }
        _re2_parse_atom();
        if (_re2_err != RE2_E_OK) { return 0; }
    }
    return 0;
}

fn _re2_parse_alt(): i64 {
    var left_start = _re2_instr_n;
    _re2_parse_concat();
    if (_re2_err != RE2_E_OK) { return 0; }
    while (_re2_pos < _re2_pat_len && load8(_re2_pat + _re2_pos) == 124) {
        _re2_pos = _re2_pos + 1;
        var left_end = _re2_instr_n;
        _re2_shift_right(left_start, left_end);
        _re2_shift_targets_one(left_start, left_end);
        _re2_instr_n = _re2_instr_n + 1;
        store64(_re2_instr_base + left_start * 16, _re2_w0(RE2_OP_SPLIT, 0, left_start + 1));
        store64(_re2_instr_base + left_start * 16 + 8, 0);
        var jmp_idx = _re2_emit_jmp(0);
        var right_start = _re2_instr_n;
        _re2_patch_arg2(left_start, right_start);
        _re2_parse_concat();
        if (_re2_err != RE2_E_OK) { return 0; }
        _re2_patch_arg1(jmp_idx, _re2_instr_n);
    }
    return 0;
}

# === Compiler entry ==================================================

fn niyama_re2_compile(pat): i64 {
    _re2_lazy_init();
    var n = strlen(pat);
    var instr_bytes = RE2_MAX_INSTRS * 16;
    var class_bytes = RE2_MAX_CLASSES * 32;
    var name_bytes  = RE2_MAX_NAMES * RE2_NAME_SLOT_SIZE;
    var nfa = alloc(RE2_NFA_HEADER_SIZE + instr_bytes + class_bytes + name_bytes);
    var instrs = nfa + RE2_NFA_HEADER_SIZE;
    var classes = instrs + instr_bytes;
    var names = classes + class_bytes;
    store64(nfa + RE2_OFF_INSTRS_OFF,  RE2_NFA_HEADER_SIZE);
    store64(nfa + RE2_OFF_CLASSES_OFF, RE2_NFA_HEADER_SIZE + instr_bytes);
    store64(nfa + RE2_OFF_NAMES_OFF,   RE2_NFA_HEADER_SIZE + instr_bytes + class_bytes);
    store64(nfa + RE2_OFF_MATCH_START, 0 - 1);
    store64(nfa + RE2_OFF_MATCH_END,   0 - 1);
    var sv = 0;
    while (sv < RE2_MAX_SAVES) {
        store64(nfa + RE2_OFF_SAVES + sv * 8, 0 - 1);
        sv = sv + 1;
    }
    var nb = 0;
    while (nb < name_bytes) {
        store8(names + nb, 0);
        nb = nb + 1;
    }
    _re2_pat = pat;
    _re2_pat_len = n;
    _re2_pos = 0;
    _re2_nfa = nfa;
    _re2_instr_base = instrs;
    _re2_class_base = classes;
    _re2_name_base = names;
    _re2_instr_n = 0;
    _re2_class_n = 0;
    _re2_capture_n = 0;
    _re2_name_n = 0;
    _re2_flag_i = 0;
    _re2_flag_m = 0;
    _re2_flag_s = 0;
    _re2_err = RE2_E_OK;
    _re2_emit_save(0);
    _re2_parse_alt();
    if (_re2_err != RE2_E_OK || _re2_pos != _re2_pat_len) {
        if (_re2_err == RE2_E_OK) { _re2_err = RE2_E_SYNTAX; }
        _re2_last_err = _re2_err;
        return 0;
    }
    _re2_emit_save(1);
    _re2_emit_op(RE2_OP_MATCH);
    if (_re2_err != RE2_E_OK) {
        _re2_last_err = _re2_err;
        return 0;
    }
    store64(nfa + RE2_OFF_INSTR_COUNT, _re2_instr_n);
    store64(nfa + RE2_OFF_CLASS_COUNT, _re2_class_n);
    store64(nfa + RE2_OFF_CAPTURES,    _re2_capture_n);
    store64(nfa + RE2_OFF_NAME_COUNT,  _re2_name_n);
    _re2_last_err = RE2_E_OK;
    return nfa;
}

fn niyama_re2_last_error(): i64 {
    return _re2_last_err;
}

# === Pike NFA matcher ================================================

fn _re2_at_word_char(input, input_len, pos): i64 {
    if (pos < 0)         { return 0; }
    if (pos >= input_len){ return 0; }
    var c = load8(input + pos);
    if (c >= 48 && c <= 57)   { return 1; }
    if (c >= 65 && c <= 90)   { return 1; }
    if (c >= 97 && c <= 122)  { return 1; }
    if (c == 95)              { return 1; }
    return 0;
}

fn _re2_is_boundary(input, input_len, pos): i64 {
    var l = _re2_at_word_char(input, input_len, pos - 1);
    var r = _re2_at_word_char(input, input_len, pos);
    if (l != r) { return 1; }
    return 0;
}

fn _re2_class_get_at(class_base, ci, c): i64 {
    if (c < 0)   { return 0; }
    if (c > 255) { return 0; }
    var off = class_base + ci * 32 + (c >> 3);
    var b = load8(off);
    if ((b >> (c & 7)) & 1) { return 1; }
    return 0;
}

fn _re2_add_thread(list_base, pc, input, input_len, pos, saves, instrs): i64 {
    if (pc < 0)                 { return 0; }
    if (load64(_re2_m_lastgen + pc * 8) == _re2_m_gen) { return 0; }
    store64(_re2_m_lastgen + pc * 8, _re2_m_gen);
    var off = instrs + pc * 16;
    var w0 = load64(off);
    var op = w0 & 0xFF;
    if (op == RE2_OP_JMP) {
        var t = (w0 >> 32) & 0xFFFFFFFF;
        _re2_add_thread(list_base, t, input, input_len, pos, saves, instrs);
    }
    elif (op == RE2_OP_SPLIT) {
        var a = (w0 >> 32) & 0xFFFFFFFF;
        var b = load64(off + 8);
        _re2_add_thread(list_base, a, input, input_len, pos, saves, instrs);
        _re2_add_thread(list_base, b, input, input_len, pos, saves, instrs);
    }
    elif (op == RE2_OP_SAVE) {
        var idx = (w0 >> 8) & 0xFF;
        var prev = load64(saves + idx * 8);
        store64(saves + idx * 8, pos);
        _re2_add_thread(list_base, pc + 1, input, input_len, pos, saves, instrs);
        store64(saves + idx * 8, prev);
    }
    elif (op == RE2_OP_BOL) {
        var ok = 0;
        if (pos == 0) { ok = 1; }
        else {
            if (load8(input + pos - 1) == 10) { ok = 1; }
        }
        if (ok == 1) { _re2_add_thread(list_base, pc + 1, input, input_len, pos, saves, instrs); }
    }
    elif (op == RE2_OP_EOL) {
        var ok2 = 0;
        if (pos == input_len) { ok2 = 1; }
        elif (load8(input + pos) == 10) { ok2 = 1; }
        if (ok2 == 1) { _re2_add_thread(list_base, pc + 1, input, input_len, pos, saves, instrs); }
    }
    elif (op == RE2_OP_BOS) {
        if (pos == 0) {
            _re2_add_thread(list_base, pc + 1, input, input_len, pos, saves, instrs);
        }
    }
    elif (op == RE2_OP_EOS) {
        if (pos == input_len) {
            _re2_add_thread(list_base, pc + 1, input, input_len, pos, saves, instrs);
        }
    }
    elif (op == RE2_OP_BOUNDARY) {
        if (_re2_is_boundary(input, input_len, pos) == 1) {
            _re2_add_thread(list_base, pc + 1, input, input_len, pos, saves, instrs);
        }
    }
    elif (op == RE2_OP_NBOUNDARY) {
        if (_re2_is_boundary(input, input_len, pos) == 0) {
            _re2_add_thread(list_base, pc + 1, input, input_len, pos, saves, instrs);
        }
    }
    else {
        var n = load64(list_base);
        store64(list_base + 8 + n * 168, pc);
        var k = 0;
        while (k < RE2_MAX_SAVES) {
            var v = load64(saves + k * 8);
            store64(list_base + 8 + n * 168 + 8 + k * 8, v);
            k = k + 1;
        }
        store64(list_base, n + 1);
    }
    return 0;
}

fn _re2_pike_run(nfa, input, input_len, start_pos): i64 {
    _re2_lazy_init();
    var instrs = nfa + load64(nfa + RE2_OFF_INSTRS_OFF);
    var class_base = nfa + load64(nfa + RE2_OFF_CLASSES_OFF);
    var matched = 0 - 1;
    var saves_scratch = alloc(RE2_MAX_SAVES * 8);
    var k = 0;
    while (k < RE2_MAX_SAVES) {
        store64(saves_scratch + k * 8, 0 - 1);
        k = k + 1;
    }
    var match_saves = alloc(RE2_MAX_SAVES * 8);
    var k2 = 0;
    while (k2 < RE2_MAX_SAVES) {
        store64(match_saves + k2 * 8, 0 - 1);
        k2 = k2 + 1;
    }
    var cur = _re2_m_cur;
    var nxt = _re2_m_next;
    store64(cur, 0);
    store64(nxt, 0);
    _re2_m_gen = _re2_m_gen + 1;
    _re2_add_thread(cur, 0, input, input_len, start_pos, saves_scratch, instrs);
    var pos = start_pos;
    var done = 0;
    while (done == 0) {
        # v0.8.0 — codepoint-stepped: decode UTF-8 cp + step here so
        # all consumers schedule successors at pos + step (not pos + 1).
        # ASCII inputs give step = 1, behavior identical to byte-stepping.
        # Multi-byte sequences advance by their full UTF-8 length so
        # `.`/CHAR/CLASS treat a codepoint as a unit.
        var c = 0 - 1;
        var cp = 0 - 1;
        var step = 1;
        if (pos < input_len) {
            c = load8(input + pos);
            if (c < 128) {
                cp = c;
            } else {
                step = _uc_decode_utf8(input, pos, input_len, _re2_m_cp_slot);
                cp = load64(_re2_m_cp_slot);
            }
        }
        _re2_m_gen = _re2_m_gen + 1;
        var n_cur = load64(cur);
        var ti = 0;
        while (ti < n_cur) {
            var pc = load64(cur + 8 + ti * 168);
            var iw0 = load64(instrs + pc * 16);
            var iop = iw0 & 0xFF;
            if (iop == RE2_OP_MATCH) {
                matched = pos;
                var ks = 0;
                while (ks < RE2_MAX_SAVES) {
                    store64(match_saves + ks * 8, load64(cur + 8 + ti * 168 + 8 + ks * 8));
                    ks = ks + 1;
                }
                ti = n_cur;
            }
            elif (iop == RE2_OP_CHAR) {
                var want = (iw0 >> 8) & 0xFF;
                if (c >= 0 && c == want) {
                    var ks2 = 0;
                    while (ks2 < RE2_MAX_SAVES) {
                        store64(saves_scratch + ks2 * 8, load64(cur + 8 + ti * 168 + 8 + ks2 * 8));
                        ks2 = ks2 + 1;
                    }
                    _re2_add_thread(nxt, pc + 1, input, input_len, pos + step, saves_scratch, instrs);
                }
            }
            elif (iop == RE2_OP_UCHAR) {
                # v0.8.0 — codepoint literal match.
                var u_want = (iw0 >> 32) & 0x1FFFFF;
                if (cp >= 0 && cp == u_want) {
                    var ks_uc = 0;
                    while (ks_uc < RE2_MAX_SAVES) {
                        store64(saves_scratch + ks_uc * 8, load64(cur + 8 + ti * 168 + 8 + ks_uc * 8));
                        ks_uc = ks_uc + 1;
                    }
                    _re2_add_thread(nxt, pc + 1, input, input_len, pos + step, saves_scratch, instrs);
                }
            }
            elif (iop == RE2_OP_UCHAR_CI) {
                # v0.8.0 — case-insensitive codepoint literal via stdlib
                # unicode_to_lower. Stored cp is already folded.
                var uci_want = (iw0 >> 32) & 0x1FFFFF;
                if (cp >= 0) {
                    var cp_fold = unicode_to_lower(cp);
                    if (cp_fold == uci_want) {
                        var ks_uci = 0;
                        while (ks_uci < RE2_MAX_SAVES) {
                            store64(saves_scratch + ks_uci * 8, load64(cur + 8 + ti * 168 + 8 + ks_uci * 8));
                            ks_uci = ks_uci + 1;
                        }
                        _re2_add_thread(nxt, pc + 1, input, input_len, pos + step, saves_scratch, instrs);
                    }
                }
            }
            elif (iop == RE2_OP_CHAR_CI) {
                # v0.7.0 — case-insensitive char compare (ASCII fold).
                # The stored byte is already lower-cased; fold the input.
                var want_ci = (iw0 >> 8) & 0xFF;
                if (c >= 0) {
                    var c_fold = c;
                    if (c >= 65 && c <= 90) { c_fold = c + 32; }
                    if (c_fold == want_ci) {
                        var ks_ci = 0;
                        while (ks_ci < RE2_MAX_SAVES) {
                            store64(saves_scratch + ks_ci * 8, load64(cur + 8 + ti * 168 + 8 + ks_ci * 8));
                            ks_ci = ks_ci + 1;
                        }
                        _re2_add_thread(nxt, pc + 1, input, input_len, pos + step, saves_scratch, instrs);
                    }
                }
            }
            elif (iop == RE2_OP_ANY) {
                if (c >= 0) {
                    var ks3 = 0;
                    while (ks3 < RE2_MAX_SAVES) {
                        store64(saves_scratch + ks3 * 8, load64(cur + 8 + ti * 168 + 8 + ks3 * 8));
                        ks3 = ks3 + 1;
                    }
                    _re2_add_thread(nxt, pc + 1, input, input_len, pos + step, saves_scratch, instrs);
                }
            }
            elif (iop == RE2_OP_ANY_NONL) {
                # v0.7.0 — strict default `.` excludes \n.
                if (c >= 0 && c != 10) {
                    var ks_nn = 0;
                    while (ks_nn < RE2_MAX_SAVES) {
                        store64(saves_scratch + ks_nn * 8, load64(cur + 8 + ti * 168 + 8 + ks_nn * 8));
                        ks_nn = ks_nn + 1;
                    }
                    _re2_add_thread(nxt, pc + 1, input, input_len, pos + step, saves_scratch, instrs);
                }
            }
            elif (iop == RE2_OP_CLASS || iop == RE2_OP_NCLASS) {
                if (c >= 0) {
                    var ci = (iw0 >> 8) & 0xFF;
                    var hit = _re2_class_get_at(class_base, ci, c);
                    if (iop == RE2_OP_NCLASS) {
                        if (hit == 1) { hit = 0; } else { hit = 1; }
                    }
                    if (hit == 1) {
                        var ks4 = 0;
                        while (ks4 < RE2_MAX_SAVES) {
                            store64(saves_scratch + ks4 * 8, load64(cur + 8 + ti * 168 + 8 + ks4 * 8));
                            ks4 = ks4 + 1;
                        }
                        _re2_add_thread(nxt, pc + 1, input, input_len, pos + step, saves_scratch, instrs);
                    }
                }
            }
            elif (iop == RE2_OP_UPROP || iop == RE2_OP_NUPROP) {
                # v0.8.0 — \p{NAME} / \P{NAME} via stdlib unicode_category.
                if (cp >= 0) {
                    var u_mask = (iw0 >> 32) & 0x3FFFFFFF;
                    var u_hit = _uprops_test(cp, u_mask);
                    if (iop == RE2_OP_NUPROP) {
                        if (u_hit == 1) { u_hit = 0; } else { u_hit = 1; }
                    }
                    if (u_hit == 1) {
                        var ks_u = 0;
                        while (ks_u < RE2_MAX_SAVES) {
                            store64(saves_scratch + ks_u * 8, load64(cur + 8 + ti * 168 + 8 + ks_u * 8));
                            ks_u = ks_u + 1;
                        }
                        _re2_add_thread(nxt, pc + 1, input, input_len, pos + step, saves_scratch, instrs);
                    }
                }
            }
            ti = ti + 1;
        }
        var swap = cur;
        cur = nxt;
        nxt = swap;
        store64(nxt, 0);
        if (pos > input_len) { done = 1; }
        elif (load64(cur) == 0) { done = 1; }
        else { pos = pos + step; }
    }
    if (matched >= 0) {
        var ks5 = 0;
        while (ks5 < RE2_MAX_SAVES) {
            store64(nfa + RE2_OFF_SAVES + ks5 * 8, load64(match_saves + ks5 * 8));
            ks5 = ks5 + 1;
        }
        store64(nfa + RE2_OFF_MATCH_START, load64(match_saves));
        store64(nfa + RE2_OFF_MATCH_END,   matched);
    } else {
        store64(nfa + RE2_OFF_MATCH_START, 0 - 1);
        store64(nfa + RE2_OFF_MATCH_END,   0 - 1);
    }
    return matched;
}

# === Public API ======================================================

fn niyama_re2_match(nfa, s): i64 {
    if (nfa == 0) { return 0; }
    var len = strlen(s);
    var r = _re2_pike_run(nfa, s, len, 0);
    if (r >= 0) { return 1; }
    return 0;
}

fn niyama_re2_search(nfa, s): i64 {
    if (nfa == 0) { return 0 - 1; }
    var len = strlen(s);
    return niyama_re2_search_at(nfa, s, len, 0);
}

fn niyama_re2_search_at(nfa, s, len, from): i64 {
    if (nfa == 0) { return 0 - 1; }
    var i = from;
    while (i <= len) {
        var r = _re2_pike_run(nfa, s, len, i);
        if (r >= 0) { return i; }
        i = i + 1;
    }
    return 0 - 1;
}

fn niyama_re2_group_start(nfa, n): i64 {
    if (nfa == 0)        { return 0 - 1; }
    if (n < 0 || n > 9)  { return 0 - 1; }
    return load64(nfa + RE2_OFF_SAVES + n * 16);
}

fn niyama_re2_group_end(nfa, n): i64 {
    if (nfa == 0)        { return 0 - 1; }
    if (n < 0 || n > 9)  { return 0 - 1; }
    return load64(nfa + RE2_OFF_SAVES + n * 16 + 8);
}

# v0.7.0 — look up a named-capture group index by name. Returns -1 if
# not found. Same shape as niyama_pcre_group_by_name for cross-engine
# uniformity.
fn niyama_re2_group_by_name(nfa, name): i64 {
    if (nfa == 0) { return 0 - 1; }
    var name_count = load64(nfa + RE2_OFF_NAME_COUNT);
    var names_base = nfa + load64(nfa + RE2_OFF_NAMES_OFF);
    var name_len = strlen(name);
    var i = 0;
    while (i < name_count) {
        var slot = names_base + i * RE2_NAME_SLOT_SIZE;
        var slot_len = 0;
        while (slot_len < RE2_NAME_MAX_LEN && load8(slot + slot_len) != 0) {
            slot_len = slot_len + 1;
        }
        if (slot_len == name_len) {
            var k = 0;
            var matched = 1;
            while (k < name_len) {
                if (load8(slot + k) != load8(name + k)) {
                    matched = 0;
                    k = name_len;
                }
                k = k + 1;
            }
            if (matched == 1) { return load64(slot + 32); }
        }
        i = i + 1;
    }
    return 0 - 1;
}

# --- pcre.cyr ---

# pcre.cyr — niyama PCRE-light engine.
#
# Backtracking matcher with PCRE-flavor parser, exposed via the
# niyama_pcre_* ABI defined in docs/adr/0004-pcre-engine-abi-and-scope.md.
#
# Architecture: this is NOT a Pike NFA fork (unlike niyama_bre and
# niyama_re2). PCRE features — backreferences, lookaround, atomic
# groups — fundamentally need a backtracking matcher. The instruction
# model is similar to bre/re2 but the matcher is recursive
# backtracking with new opcodes (BACKREF, LOOKAHEAD_*, ATOMIC_*).
#
# CATASTROPHIC BACKTRACKING is mitigated by an explicit step-limit
# guard: every matcher step increments _pcre_step_count, and matching
# aborts if the count exceeds _pcre_step_limit. Default 1M steps.
# Configurable via niyama_pcre_set_step_limit().
#
# Public API:
#   niyama_pcre_compile(pat)         -> opaque NFA pointer or 0 on error
#   niyama_pcre_match(nfa, s)        -> 1 if anchored match, else 0
#   niyama_pcre_search(nfa, s)       -> first match offset, or -1
#   niyama_pcre_search_at(...)       -> match starting at `from`
#   niyama_pcre_group_start(nfa,n)   -> group n start or -1
#   niyama_pcre_group_end(nfa,n)     -> group n end or -1
#   niyama_pcre_group_by_name(nfa,name) -> group index or -1
#   niyama_pcre_last_error()         -> error code from most recent compile
#   niyama_pcre_set_step_limit(n)    -> set process-wide step budget
#   niyama_pcre_last_step_count()    -> step count of most recent match
#
# Out of scope for M3 (per ADR 0004):
#   - Lookbehind (?<=...) (?<!...) — deferred to v0.8.0 (needs
#     fixed-width compile-time analysis).
#   - Unicode property classes \p{L} — deferred to v0.9.0 (Unicode
#     table is shared across re2/pcre/fuzzy and lands together).
#   - Recursion (?R) (?P>name) — deferred to v0.8.0.
#
# v0.7.0 (per ADR 0007) lands the no-Unicode-dep pcre catch-up:
#   - POSIX bracket classes [:alpha:] etc. via shared posix_classes module
#   - Inline flags (?i) (?m) (?s) — and combinations
#   - \K reset-match-start
#   - Branch-reset groups (?|...)
#   - Conditional patterns (?(cond)yes|no)
#   - Callouts (?C) and (?C123) — observability only, no callback API
#
# v0.7.0 behavior change: niyama_pcre's `^`, `$`, and `.` are now
# **strict-by-default** (matching the PCRE spec) — `^`/`$` only at
# string boundaries, `.` does not match `\n`. Multi-line semantics
# require `(?m)`; dot-matches-newline requires `(?s)`. Pre-v0.7.0
# implementations were silently loose; this is a documented change
# pre-surface-freeze (M5).
#
# Precondition: alloc_init() must have been called.
#
# All globals are `_pcre_*`-prefixed for collision-free coexistence.

# === Opcodes =========================================================
# First 12 mirror bre/re2 (same instruction layout, same semantics).
# Remaining are pcre-only (backtracking-required).

var PCRE_OP_MATCH      = 0;
var PCRE_OP_CHAR       = 1;
var PCRE_OP_ANY        = 2;
var PCRE_OP_CLASS      = 3;
var PCRE_OP_NCLASS     = 4;
var PCRE_OP_JMP        = 5;
var PCRE_OP_SPLIT      = 6;
var PCRE_OP_SAVE       = 7;
var PCRE_OP_BOL        = 8;
var PCRE_OP_EOL        = 9;
var PCRE_OP_BOUNDARY   = 10;
var PCRE_OP_NBOUNDARY  = 11;
# pcre-only:
var PCRE_OP_BACKREF    = 12;  # arg: group index 1..9
var PCRE_OP_LOOKAHEAD  = 13;  # arg1: end_pc (positive lookahead)
var PCRE_OP_NLOOKAHEAD = 14;  # arg1: end_pc (negative lookahead)
var PCRE_OP_LOOKAHEAD_END = 15;  # marker: sub-match returns success
var PCRE_OP_ATOMIC     = 16;  # arg1: end_pc
var PCRE_OP_ATOMIC_END = 17;  # marker: sub-match returns success-with-pos
# v0.7.0 — additions for inline flags + new spec-strict defaults +
# conditional patterns + callouts.
var PCRE_OP_CHAR_CI    = 18;  # case-insensitive char (ASCII fold)
var PCRE_OP_BOS        = 19;  # strict ^ — pos == 0 only
var PCRE_OP_EOS        = 20;  # strict $ — pos == len only
var PCRE_OP_ANY_NONL   = 21;  # . excluding \n
var PCRE_OP_COND       = 22;  # arg1: group_idx, arg2: no_pc
var PCRE_OP_CALLOUT    = 23;  # arg1: callout number (zero-width no-op)
# v0.8.0 — Unicode property class \p{L} / \P{L} via stdlib lib/unicode.
# 30-bit GeneralCategory mask packed into upper 32 bits of word0. Mixed
# with byte-stepping ops; multi-byte input flows through UPROP cleanly,
# but combining `.` with UPROP across multi-byte boundaries can give
# surprising results (`.` advances 1 byte regardless of utf8 length).
var PCRE_OP_UPROP      = 24;  # \p{NAME} — cp_category(cp) ∈ mask
var PCRE_OP_NUPROP     = 25;  # \P{NAME} — cp_category(cp) ∉ mask
# v0.8.0 — (?i) Unicode case-fold upgrade for multi-byte literal chars.
# Stores unicode_to_lower(cp) in upper 32 bits. Decodes input UTF-8
# inline (no codepoint-stepping refactor — pcre is byte-stepped, each
# opcode picks its own advance). 1:1 case mappings only; full case
# folding (ß↔SS, etc.) deferred to v0.8.x ladder.
var PCRE_OP_UCHAR_CI   = 26;
# v0.8.0 — lookbehind (?<=...) (?<!...). Fixed-width compile-time
# analysis (PCRE2 10.43 model). Variable-width lookbehind is rejected
# at compile with PCRE_E_LOOKBEHIND_VARWIDTH (out of scope unless asked
# — pinned at v0.8.x ladder if a consumer wants it). Width packed
# into upper 32 bits of word0; end_pc reuses LOOKAHEAD_END (matcher
# treats LOOKAHEAD_END identically: return pos at success). Body must
# consume exactly `width` bytes ending at the current pos.
var PCRE_OP_LOOKBEHIND  = 28;  # arg1 (32:48): width, arg1 (48:): end_pc
var PCRE_OP_NLOOKBEHIND = 29;
# v0.8.0 — recursion `(?R)` (whole pattern), `(?P>NAME)` (named group).
# Stores target group_idx in low 16 bits of arg1. Matcher walks the
# compiled program to find SAVE 2*idx (open) and SAVE 2*idx+1 (close),
# runs sub-match from open+1, terminates at close+1. Saves are
# snapshot/restored around the recursive call so inner captures don't
# leak into the outer match. Numeric `(?N)` syntax NOT supported in
# v0.8.0; (?R) and (?P>name) only.
var PCRE_OP_RECURSE     = 30;  # arg1 (low 16): target group_idx (0..9)

# === NFA layout ======================================================

var PCRE_NFA_HEADER_SIZE = 256;  # extra slack vs bre/re2 (216) for names
var PCRE_OFF_INSTR_COUNT = 0;
var PCRE_OFF_INSTRS_OFF  = 8;
var PCRE_OFF_CLASS_COUNT = 16;
var PCRE_OFF_CLASSES_OFF = 24;
var PCRE_OFF_CAPTURES    = 32;
var PCRE_OFF_MATCH_START = 40;
var PCRE_OFF_MATCH_END   = 48;
var PCRE_OFF_SAVES       = 56;   # 20 × 8 = 160 bytes (covers up to offset 215)
var PCRE_OFF_NAMES_OFF   = 216;
var PCRE_OFF_NAME_COUNT  = 224;

var PCRE_MAX_INSTRS  = 4096;
var PCRE_MAX_CLASSES = 64;
var PCRE_MAX_SAVES   = 20;
var PCRE_MAX_NAMES   = 9;
var PCRE_NAME_SLOT_SIZE = 40;   # 32 bytes name (NUL-padded) + 8 bytes group_idx
var PCRE_NAME_MAX_LEN = 31;

# === Error codes (frozen ABI from M3 onward) =========================

var PCRE_E_OK                      = 0;
var PCRE_E_SYNTAX                  = 1;
var PCRE_E_LOOKBEHIND_UNSUPPORTED  = 2;
var PCRE_E_UNICODE_PROP_UNSUPPORTED = 3;
var PCRE_E_RECURSION_UNSUPPORTED   = 4;
# Slot 5 was PCRE_E_CONDITIONAL_UNSUPPORTED in M3. Conditionals
# landed in v0.7.0 (ADR 0007); the slot is reserved (frozen ABI)
# but no longer emitted.
var PCRE_E_CONDITIONAL_UNSUPPORTED = 5;
var PCRE_E_TOO_LARGE               = 6;
var PCRE_E_DUPLICATE_NAME          = 7;
# v0.7.0 — new error code (next-available; preserves M3 numbering).
var PCRE_E_BAD_CONDITION           = 8;
# v0.8.0 — \p{...} support landed at top-level (ADR 0008).
# PCRE_E_UNICODE_PROP_UNSUPPORTED (= 3) narrows: still emitted when
# \p{...} appears INSIDE a character class `[\p{L}]` — char classes
# are byte-bitmaps, and folding a codepoint-property in is not in
# scope for v0.8.0.
var PCRE_E_BAD_PROPERTY            = 9;
# v0.8.0 — lookbehind landed (ADR 0008), but body must be fixed-width.
# Variable-width bodies (alternation with mismatched arm widths,
# quantifiers, backref, codepoint-property classes) get this code.
# PCRE_E_LOOKBEHIND_UNSUPPORTED (= 2) is reserved (frozen ABI) but
# no longer emitted at top level — ABI-stability slot.
var PCRE_E_LOOKBEHIND_VARWIDTH     = 10;
# v0.8.0 — recursion landed (ADR 0008). Slot 4 PCRE_E_RECURSION_UNSUPPORTED
# is reserved (frozen ABI) but no longer emitted. New error for an
# (?P>name) ref that doesn't resolve to any defined group.
var PCRE_E_BAD_RECURSION_REF       = 11;

# === Compile-time globals ============================================

var _pcre_pat = 0;
var _pcre_pat_len = 0;
var _pcre_pos = 0;
var _pcre_nfa = 0;
var _pcre_instr_base = 0;
var _pcre_class_base = 0;
var _pcre_name_base = 0;
var _pcre_instr_n = 0;
var _pcre_class_n = 0;
var _pcre_capture_n = 0;
var _pcre_name_n = 0;
var _pcre_err = 0;
var _pcre_last_err = 0;

# Process-lifetime scratch.
var _pcre_init = 0;
var _pcre_q_splits = 0;
# v0.8.0 — UTF-8 codepoint scratch slot for UPROP / NUPROP.
var _pcre_m_cp_slot = 0;
var _pcre_step_limit = 1000000;
var _pcre_step_count = 0;
# v0.8.0 — recursion: when (?R) / (?P>NAME) makes a recursive call,
# this global is set to the pc immediately AFTER the target group's
# close SAVE. The matcher checks at the top of each iteration; if pc
# == _pcre_recurse_stop_pc, it returns pos (recursion body completed).
# Reset to -1 on entry to LOOKAHEAD/LOOKBEHIND/ATOMIC recursive calls
# so those sub-matches don't get prematurely truncated. Saved/restored
# around RECURSE itself so nested recursions stack properly.
var _pcre_recurse_stop_pc = 0 - 1;
# Scratch globals for _pcre_find_group_pcs return values (Cyrius lacks
# tuple returns).
var _pcre_grp_open_pc  = 0 - 1;
var _pcre_grp_close_pc = 0 - 1;
var _pcre_last_step_count = 0;

# v0.7.0 — inline-flag compile-time state. (?i)/(?m)/(?s).
var _pcre_flag_i = 0;
var _pcre_flag_m = 0;
var _pcre_flag_s = 0;
# v0.7.0 — branch-reset state. -1 outside (?|...); the saved
# `_pcre_capture_n` value at the start of the (?|...) when inside.
var _pcre_branch_reset_base = 0 - 1;
# v0.7.0 — last-callout-number observability. Reset per match.
var _pcre_last_callout = 0 - 1;

# Recursion-depth bound for the backtracking matcher. Cyrius has no
# native stack-depth limit, so deep adversarial patterns would SIGSEGV
# without this. 256 is comfortably above any legitimate pattern's
# recursive call depth (saves + nested groups + lookaround + atomic
# all stack additively; real patterns peak around 50).
var _pcre_depth_limit = 256;

fn _pcre_lazy_init(): i64 {
    if (_pcre_init == 1) { return 0; }
    _pcre_q_splits  = alloc(64 * 8);
    _pcre_m_cp_slot = alloc(8);
    _pcre_init = 1;
    return 0;
}

# === Instruction emit / patch helpers ================================

fn _pcre_w0(op, small, arg1): i64 {
    return op | (small << 8) | (arg1 << 32);
}

fn _pcre_emit_raw(w0, w1): i64 {
    var i = _pcre_instr_n;
    if (i >= PCRE_MAX_INSTRS) { _pcre_err = PCRE_E_TOO_LARGE; return i; }
    store64(_pcre_instr_base + i * 16, w0);
    store64(_pcre_instr_base + i * 16 + 8, w1);
    _pcre_instr_n = i + 1;
    return i;
}

fn _pcre_emit_op(op): i64 { return _pcre_emit_raw(op, 0); }
fn _pcre_emit_char(c): i64 {
    # v0.7.0 — under (?i) emit CHAR_CI; the matcher does case-fold.
    var op = PCRE_OP_CHAR;
    if (_pcre_flag_i == 1) { op = PCRE_OP_CHAR_CI; }
    var stored = c;
    if (_pcre_flag_i == 1 && c >= 65 && c <= 90) { stored = c + 32; }
    return _pcre_emit_raw(op | (stored << 8), 0);
}
fn _pcre_emit_class(neg, ci): i64 {
    var op = PCRE_OP_CLASS;
    if (neg == 1) { op = PCRE_OP_NCLASS; }
    return _pcre_emit_raw(op | (ci << 8), 0);
}
fn _pcre_emit_save(idx): i64 { return _pcre_emit_raw(PCRE_OP_SAVE | (idx << 8), 0); }
fn _pcre_emit_jmp(target): i64 { return _pcre_emit_raw(PCRE_OP_JMP | (target << 32), 0); }
fn _pcre_emit_split(a, b): i64 { return _pcre_emit_raw(PCRE_OP_SPLIT | (a << 32), b); }
fn _pcre_emit_backref(n): i64 { return _pcre_emit_raw(PCRE_OP_BACKREF | (n << 8), 0); }
fn _pcre_emit_uprop(neg, mask): i64 {
    var op = PCRE_OP_UPROP;
    if (neg == 1) { op = PCRE_OP_NUPROP; }
    return _pcre_emit_raw(op | (mask << 32), 0);
}
fn _pcre_emit_uchar_ci(cp): i64 {
    return _pcre_emit_raw(PCRE_OP_UCHAR_CI | (cp << 32), 0);
}
fn _pcre_emit_lookahead(neg): i64 {
    var op = PCRE_OP_LOOKAHEAD;
    if (neg == 1) { op = PCRE_OP_NLOOKAHEAD; }
    return _pcre_emit_raw(op, 0);
}

fn _pcre_emit_lookbehind(neg): i64 {
    var op = PCRE_OP_LOOKBEHIND;
    if (neg == 1) { op = PCRE_OP_NLOOKBEHIND; }
    # arg1 (upper 32 of word0): end_pc, patched after body. arg2 (word1):
    # fixed-width, patched after compile-time width analysis.
    return _pcre_emit_raw(op, 0);
}

fn _pcre_emit_recurse(group_idx): i64 {
    return _pcre_emit_raw(PCRE_OP_RECURSE | (group_idx << 8), 0);
}

# v0.8.0 — fixed-width compile-time analysis for lookbehind body.
# Walks compiled instructions in [body_start, body_end) and returns
# the total bytes consumed if every path is fixed-width, else -1.
# Conservative: rejects alternation (SPLIT/JMP), backrefs, codepoint-
# property classes (UPROP/UCHAR_CI — variable UTF-8 length), and any
# nested zero-width assertion (lookahead inside lookbehind body, etc.).
# Same fixed-byte-width model as PCRE2 10.43; no codepoint-aware
# width yet.
fn _pcre_compute_width(body_start, body_end): i64 {
    var width = 0;
    var pc = body_start;
    while (pc < body_end) {
        var w0 = load64(_pcre_instr_base + pc * 16);
        var op = w0 & 0xFF;
        if (op == PCRE_OP_CHAR)         { width = width + 1; }
        elif (op == PCRE_OP_CHAR_CI)    { width = width + 1; }
        elif (op == PCRE_OP_ANY)        { width = width + 1; }
        elif (op == PCRE_OP_ANY_NONL)   { width = width + 1; }
        elif (op == PCRE_OP_CLASS)      { width = width + 1; }
        elif (op == PCRE_OP_NCLASS)     { width = width + 1; }
        elif (op == PCRE_OP_SAVE)       { width = width + 0; }
        elif (op == PCRE_OP_BOL)        { width = width + 0; }
        elif (op == PCRE_OP_EOL)        { width = width + 0; }
        elif (op == PCRE_OP_BOS)        { width = width + 0; }
        elif (op == PCRE_OP_EOS)        { width = width + 0; }
        elif (op == PCRE_OP_BOUNDARY)   { width = width + 0; }
        elif (op == PCRE_OP_NBOUNDARY)  { width = width + 0; }
        elif (op == PCRE_OP_CALLOUT)    { width = width + 0; }
        else { return 0 - 1; }
        pc = pc + 1;
    }
    return width;
}

fn _pcre_patch_arg1(idx, arg1): i64 {
    var off = _pcre_instr_base + idx * 16;
    var w0 = load64(off);
    store64(off, (w0 & 0xFFFFFFFF) | (arg1 << 32));
    return 0;
}

fn _pcre_patch_arg2(idx, arg2): i64 {
    store64(_pcre_instr_base + idx * 16 + 8, arg2);
    return 0;
}

fn _pcre_shift_right(lo, hi): i64 {
    var k = (hi - lo) * 16 - 1;
    while (k >= 0) {
        var src = _pcre_instr_base + lo * 16 + k;
        store8(src + 16, load8(src));
        k = k - 1;
    }
    return 0;
}

fn _pcre_shift_targets_one(lo, hi): i64 {
    var i = lo + 1;
    var end = hi + 1;
    while (i < end) {
        var off = _pcre_instr_base + i * 16;
        var w0 = load64(off);
        var op = w0 & 0xFF;
        var is_branch = 0;
        if (op == PCRE_OP_JMP)   { is_branch = 1; }
        if (op == PCRE_OP_SPLIT) { is_branch = 1; }
        if (op == PCRE_OP_LOOKAHEAD)  { is_branch = 1; }
        if (op == PCRE_OP_NLOOKAHEAD) { is_branch = 1; }
        if (op == PCRE_OP_ATOMIC)     { is_branch = 1; }
        if (op == PCRE_OP_LOOKBEHIND)  { is_branch = 1; }
        if (op == PCRE_OP_NLOOKBEHIND) { is_branch = 1; }
        if (is_branch == 1) {
            var arg1 = (w0 >> 32) & 0xFFFFFFFF;
            if (arg1 >= lo && arg1 <= hi) {
                _pcre_patch_arg1(i, arg1 + 1);
            }
            if (op == PCRE_OP_SPLIT) {
                var arg2 = load64(off + 8);
                if (arg2 >= lo && arg2 <= hi) {
                    _pcre_patch_arg2(i, arg2 + 1);
                }
            }
        }
        # v0.7.0 — COND has arg1 = group_idx (NOT a PC, do not shift)
        # and arg2 = no_pc (a PC, shift if it falls inside the moved
        # range). Handled separately to keep the arg1 logic above
        # unconditional.
        if (op == PCRE_OP_COND) {
            var c_arg2 = load64(off + 8);
            if (c_arg2 >= lo && c_arg2 <= hi) {
                _pcre_patch_arg2(i, c_arg2 + 1);
            }
        }
        i = i + 1;
    }
    return 0;
}

# === Class bitmap helpers (mirrors re2) ==============================

fn _pcre_alloc_class(): i64 {
    var ci = _pcre_class_n;
    if (ci >= PCRE_MAX_CLASSES) { _pcre_err = PCRE_E_TOO_LARGE; return ci; }
    var z = 0;
    while (z < 32) {
        store8(_pcre_class_base + ci * 32 + z, 0);
        z = z + 1;
    }
    _pcre_class_n = ci + 1;
    return ci;
}

fn _pcre_class_set(ci, c): i64 {
    if (c < 0)   { return 0; }
    if (c > 255) { return 0; }
    var off = _pcre_class_base + ci * 32 + (c >> 3);
    store8(off, load8(off) | (1 << (c & 7)));
    return 0;
}

fn _pcre_class_range(ci, lo, hi): i64 {
    var c = lo;
    while (c <= hi) {
        _pcre_class_set(ci, c);
        c = c + 1;
    }
    return 0;
}

fn _pcre_class_invert(ci): i64 {
    var z = 0;
    while (z < 32) {
        var off = _pcre_class_base + ci * 32 + z;
        store8(off, 255 ^ load8(off));
        z = z + 1;
    }
    return 0;
}

fn _pcre_class_fill_digit(ci): i64 { _pcre_class_range(ci, 48, 57); return 0; }

fn _pcre_class_fill_word(ci): i64 {
    _pcre_class_range(ci, 48, 57);
    _pcre_class_range(ci, 65, 90);
    _pcre_class_range(ci, 97, 122);
    _pcre_class_set(ci, 95);
    return 0;
}

fn _pcre_class_fill_space(ci): i64 {
    _pcre_class_set(ci, 32);
    _pcre_class_set(ci, 9);
    _pcre_class_set(ci, 10);
    _pcre_class_set(ci, 11);
    _pcre_class_set(ci, 12);
    _pcre_class_set(ci, 13);
    return 0;
}

# v0.7.0 — under (?i) also set the opposite-case ASCII letter.
fn _pcre_class_set_folded(ci, c): i64 {
    _pcre_class_set(ci, c);
    if (_pcre_flag_i == 1) {
        if (c >= 65 && c <= 90)    { _pcre_class_set(ci, c + 32); }
        elif (c >= 97 && c <= 122) { _pcre_class_set(ci, c - 32); }
    }
    return 0;
}

fn _pcre_class_range_folded(ci, lo, hi): i64 {
    var c = lo;
    while (c <= hi) {
        _pcre_class_set_folded(ci, c);
        c = c + 1;
    }
    return 0;
}

# v0.7.0 — try to parse `(?<flags>)` where <flags> is one or more of
# i/m/s. Caller has consumed `(?`; `_pcre_pos` is at the first byte
# after `(?`. Returns 1 on success (flags set, `)` consumed); 0 if
# the body is not pure-flag (caller falls through). Sets _pcre_err on
# malformed flag run.
fn _pcre_try_inline_flags(): i64 {
    var p = _pcre_pos;
    var first = load8(_pcre_pat + p);
    if (first != 105 && first != 109 && first != 115) { return 0; }
    var fi = 0; var fm = 0; var fs = 0;
    var scanning = 1;
    while (scanning == 1) {
        if (p >= _pcre_pat_len) { _pcre_err = PCRE_E_SYNTAX; return 0; }
        var c = load8(_pcre_pat + p);
        if      (c == 105) { fi = 1; p = p + 1; }
        elif    (c == 109) { fm = 1; p = p + 1; }
        elif    (c == 115) { fs = 1; p = p + 1; }
        elif    (c == 41)  { scanning = 0; }
        else               { _pcre_err = PCRE_E_SYNTAX; return 0; }
    }
    _pcre_pos = p + 1;  # consume `)`
    if (fi == 1) { _pcre_flag_i = 1; }
    if (fm == 1) { _pcre_flag_m = 1; }
    if (fs == 1) { _pcre_flag_s = 1; }
    return 1;
}

# === Named-capture name table =======================================

# Validate a name char: [A-Za-z0-9_]; first must be [A-Za-z_].
fn _pcre_is_name_first(c): i64 {
    if (c >= 65 && c <= 90)  { return 1; }
    if (c >= 97 && c <= 122) { return 1; }
    if (c == 95)             { return 1; }
    return 0;
}
fn _pcre_is_name_rest(c): i64 {
    if (_pcre_is_name_first(c) == 1) { return 1; }
    if (c >= 48 && c <= 57)          { return 1; }
    return 0;
}

# Add a name → group index mapping. Caller positions _pcre_pos at the
# start of the name; this consumes the name. Validates duplicates.
# Returns 0 on success; sets _pcre_err on failure.
fn _pcre_add_name(group_idx, terminator): i64 {
    if (_pcre_pos >= _pcre_pat_len) { _pcre_err = PCRE_E_SYNTAX; return 0 - 1; }
    var first = load8(_pcre_pat + _pcre_pos);
    if (_pcre_is_name_first(first) == 0) { _pcre_err = PCRE_E_SYNTAX; return 0 - 1; }
    var name_start = _pcre_pos;
    _pcre_pos = _pcre_pos + 1;
    while (_pcre_pos < _pcre_pat_len && _pcre_is_name_rest(load8(_pcre_pat + _pcre_pos)) == 1) {
        _pcre_pos = _pcre_pos + 1;
    }
    var name_len = _pcre_pos - name_start;
    if (name_len > PCRE_NAME_MAX_LEN) { _pcre_err = PCRE_E_TOO_LARGE; return 0 - 1; }
    if (_pcre_pos >= _pcre_pat_len || load8(_pcre_pat + _pcre_pos) != terminator) {
        _pcre_err = PCRE_E_SYNTAX; return 0 - 1;
    }
    _pcre_pos = _pcre_pos + 1;  # consume terminator (`>`)

    # Check for duplicates.
    var i = 0;
    while (i < _pcre_name_n) {
        var slot = _pcre_name_base + i * PCRE_NAME_SLOT_SIZE;
        var slot_len = 0;
        while (slot_len < PCRE_NAME_MAX_LEN && load8(slot + slot_len) != 0) {
            slot_len = slot_len + 1;
        }
        if (slot_len == name_len) {
            var k = 0;
            var same = 1;
            while (k < name_len) {
                if (load8(slot + k) != load8(_pcre_pat + name_start + k)) {
                    same = 0;
                    k = name_len;
                }
                k = k + 1;
            }
            if (same == 1) { _pcre_err = PCRE_E_DUPLICATE_NAME; return 0 - 1; }
        }
        i = i + 1;
    }

    # Append.
    if (_pcre_name_n >= PCRE_MAX_NAMES) { _pcre_err = PCRE_E_TOO_LARGE; return 0 - 1; }
    var dst = _pcre_name_base + _pcre_name_n * PCRE_NAME_SLOT_SIZE;
    var k2 = 0;
    while (k2 < name_len) {
        store8(dst + k2, load8(_pcre_pat + name_start + k2));
        k2 = k2 + 1;
    }
    while (k2 < PCRE_NAME_MAX_LEN + 1) {
        store8(dst + k2, 0);
        k2 = k2 + 1;
    }
    store64(dst + 32, group_idx);
    _pcre_name_n = _pcre_name_n + 1;
    return 0;
}

# v0.8.0 — compile-time lookup for (?P>NAME) recursion. Walks the
# name table and returns the group_idx for `name_buf[0..name_len]`,
# or -1 if not found.
fn _pcre_lookup_name(name_buf, name_len): i64 {
    var i = 0;
    while (i < _pcre_name_n) {
        var slot = _pcre_name_base + i * PCRE_NAME_SLOT_SIZE;
        var slot_len = 0;
        while (slot_len < PCRE_NAME_MAX_LEN && load8(slot + slot_len) != 0) {
            slot_len = slot_len + 1;
        }
        if (slot_len == name_len) {
            var k = 0;
            var same = 1;
            while (k < name_len) {
                if (load8(slot + k) != load8(name_buf + k)) {
                    same = 0;
                    k = name_len;
                } else {
                    k = k + 1;
                }
            }
            if (same == 1) { return load64(slot + 32); }
        }
        i = i + 1;
    }
    return 0 - 1;
}

# === Pattern decoder =================================================

fn _pcre_lit_byte(): i64 {
    if (_pcre_pos >= _pcre_pat_len) { _pcre_err = PCRE_E_SYNTAX; return 0; }
    var c = load8(_pcre_pat + _pcre_pos);
    _pcre_pos = _pcre_pos + 1;
    if (c != 92) { return c; }
    if (_pcre_pos >= _pcre_pat_len) { _pcre_err = PCRE_E_SYNTAX; return 0; }
    var e = load8(_pcre_pat + _pcre_pos);
    _pcre_pos = _pcre_pos + 1;
    if (e == 110) { return 10; }
    if (e == 114) { return 13; }
    if (e == 116) { return 9; }
    if (e == 48)  { return 0; }
    if (e == 97)  { return 7; }
    if (e == 102) { return 12; }
    if (e == 118) { return 11; }
    return e;
}

fn _pcre_parse_class(): i64 {
    var ci = _pcre_alloc_class();
    if (_pcre_err != PCRE_E_OK) { return ci; }
    var neg = 0;
    if (_pcre_pos < _pcre_pat_len && load8(_pcre_pat + _pcre_pos) == 94) {
        neg = 1;
        _pcre_pos = _pcre_pos + 1;
    }
    var first = 1;
    var done = 0;
    while (done == 0) {
        if (_pcre_pos >= _pcre_pat_len) { _pcre_err = PCRE_E_SYNTAX; return 0 - 1; }
        var pc = load8(_pcre_pat + _pcre_pos);
        if (pc == 93 && first == 0) {
            _pcre_pos = _pcre_pos + 1;
            done = 1;
        }
        elif (pc == 92 && _pcre_pos + 1 < _pcre_pat_len) {
            var nx = load8(_pcre_pat + _pcre_pos + 1);
            if (nx == 100)      { _pcre_class_fill_digit(ci); _pcre_pos = _pcre_pos + 2; }
            elif (nx == 119)    { _pcre_class_fill_word(ci);  _pcre_pos = _pcre_pos + 2; }
            elif (nx == 115)    { _pcre_class_fill_space(ci); _pcre_pos = _pcre_pos + 2; }
            elif (nx == 68) {
                var tmp = _pcre_alloc_class();
                if (_pcre_err != PCRE_E_OK) { return 0 - 1; }
                _pcre_class_fill_digit(tmp);
                _pcre_class_invert(tmp);
                var z = 0;
                while (z < 32) {
                    var d = _pcre_class_base + ci * 32 + z;
                    var s = _pcre_class_base + tmp * 32 + z;
                    store8(d, load8(d) | load8(s));
                    z = z + 1;
                }
                _pcre_class_n = _pcre_class_n - 1;
                _pcre_pos = _pcre_pos + 2;
            }
            elif (nx == 87) {
                var tmp2 = _pcre_alloc_class();
                if (_pcre_err != PCRE_E_OK) { return 0 - 1; }
                _pcre_class_fill_word(tmp2);
                _pcre_class_invert(tmp2);
                var z2 = 0;
                while (z2 < 32) {
                    var d2 = _pcre_class_base + ci * 32 + z2;
                    var s2 = _pcre_class_base + tmp2 * 32 + z2;
                    store8(d2, load8(d2) | load8(s2));
                    z2 = z2 + 1;
                }
                _pcre_class_n = _pcre_class_n - 1;
                _pcre_pos = _pcre_pos + 2;
            }
            elif (nx == 83) {
                var tmp3 = _pcre_alloc_class();
                if (_pcre_err != PCRE_E_OK) { return 0 - 1; }
                _pcre_class_fill_space(tmp3);
                _pcre_class_invert(tmp3);
                var z3 = 0;
                while (z3 < 32) {
                    var d3 = _pcre_class_base + ci * 32 + z3;
                    var s3 = _pcre_class_base + tmp3 * 32 + z3;
                    store8(d3, load8(d3) | load8(s3));
                    z3 = z3 + 1;
                }
                _pcre_class_n = _pcre_class_n - 1;
                _pcre_pos = _pcre_pos + 2;
            }
            elif (nx == 112 || nx == 80) {
                # \p{...} \P{...} inside a char class. Top-level
                # \p{NAME} works (v0.8.0); inside `[...]` requires
                # folding Unicode props into a byte bitmap, out of
                # scope for v0.8.0. Reserved error code (ADR 0008).
                _pcre_err = PCRE_E_UNICODE_PROP_UNSUPPORTED;
                return 0 - 1;
            }
            else {
                var lc = _pcre_lit_byte();
                if (_pcre_err != PCRE_E_OK) { return 0 - 1; }
                if (_pcre_pos + 1 < _pcre_pat_len && load8(_pcre_pat + _pcre_pos) == 45 && load8(_pcre_pat + _pcre_pos + 1) != 93) {
                    _pcre_pos = _pcre_pos + 1;
                    var hi = _pcre_lit_byte();
                    if (_pcre_err != PCRE_E_OK) { return 0 - 1; }
                    _pcre_class_range_folded(ci, lc, hi);
                } else {
                    _pcre_class_set_folded(ci, lc);
                }
            }
            first = 0;
        }
        elif (pc == 91 && _pcre_pos + 1 < _pcre_pat_len && load8(_pcre_pat + _pcre_pos + 1) == 58) {
            # v0.7.0 — POSIX bracket class via shared posix_classes module.
            var category = _posix_match_class_name(_pcre_pat, _pcre_pos + 2, _pcre_pat_len);
            if (category == 0) { _pcre_err = PCRE_E_SYNTAX; return 0 - 1; }
            _posix_apply_filler(_pcre_class_base, ci, category);
            _pcre_pos = _posix_match_end_pos;
            first = 0;
        }
        else {
            var lc2 = _pcre_lit_byte();
            if (_pcre_err != PCRE_E_OK) { return 0 - 1; }
            if (_pcre_pos + 1 < _pcre_pat_len && load8(_pcre_pat + _pcre_pos) == 45 && load8(_pcre_pat + _pcre_pos + 1) != 93) {
                _pcre_pos = _pcre_pos + 1;
                var hi2 = _pcre_lit_byte();
                if (_pcre_err != PCRE_E_OK) { return 0 - 1; }
                _pcre_class_range_folded(ci, lc2, hi2);
            } else {
                _pcre_class_set_folded(ci, lc2);
            }
            first = 0;
        }
    }
    if (neg == 1) { return 0 - (ci + 1); }
    return ci;
}

# Parse a `(?...)` introducer following the opening `(`.
# `_pcre_pos` is at the `?` byte. Returns one of:
#   capture_idx >= 1: capturing group (named or positional fall-through)
#   capture_idx == 0: non-capturing group
#   capture_idx == -2: lookahead positive (caller emits LOOKAHEAD start/end)
#   capture_idx == -3: lookahead negative
#   capture_idx == -4: atomic group
# v0.7.0:
#   capture_idx == -5: branch-reset group `(?|...)` — caller still
#                      parses body but with branch-reset semantics.
#   capture_idx == -6: conditional `(?(cond)yes|no)` — caller is
#                      told to skip body parsing; this fn already
#                      emitted the COND/JMP/no_body and consumed `)`.
#   capture_idx == -7: fully-consumed form (inline flag, callout) —
#                      caller emits nothing, body already eaten.
# Sets _pcre_err on rejection / syntax / deferred-feature.
fn _pcre_parse_group_intro(): i64 {
    # _pcre_pos at `?`; advance past `?`
    _pcre_pos = _pcre_pos + 1;
    if (_pcre_pos >= _pcre_pat_len) { _pcre_err = PCRE_E_SYNTAX; return 0; }
    var n1 = load8(_pcre_pat + _pcre_pos);
    if (n1 == 58) {
        # (?:...) non-capturing
        _pcre_pos = _pcre_pos + 1;
        return 0;
    }
    if (n1 == 61) {
        # (?=...) positive lookahead
        _pcre_pos = _pcre_pos + 1;
        return 0 - 2;
    }
    if (n1 == 33) {
        # (?!...) negative lookahead
        _pcre_pos = _pcre_pos + 1;
        return 0 - 3;
    }
    if (n1 == 60) {
        # (?<=...) (?<!...) lookbehind, OR (?<NAME>...) named capture.
        if (_pcre_pos + 1 >= _pcre_pat_len) { _pcre_err = PCRE_E_SYNTAX; return 0; }
        var n2 = load8(_pcre_pat + _pcre_pos + 1);
        if (n2 == 61) {
            # v0.8.0 — (?<=...) positive lookbehind. Skip `<=`.
            _pcre_pos = _pcre_pos + 2;
            return 0 - 8;
        }
        if (n2 == 33) {
            # v0.8.0 — (?<!...) negative lookbehind. Skip `<!`.
            _pcre_pos = _pcre_pos + 2;
            return 0 - 9;
        }
        # Named capture (?<NAME>...).
        _pcre_pos = _pcre_pos + 1;  # skip `<`
        _pcre_capture_n = _pcre_capture_n + 1;
        if (_pcre_capture_n > 9) { _pcre_err = PCRE_E_SYNTAX; return 0; }
        _pcre_add_name(_pcre_capture_n, 62);  # terminator `>`
        if (_pcre_err != PCRE_E_OK) { return 0; }
        return _pcre_capture_n;
    }
    if (n1 == 62) {
        # (?>...) atomic
        _pcre_pos = _pcre_pos + 1;
        return 0 - 4;
    }
    if (n1 == 80) {
        # (?P<NAME>...) named capture, or (?P>NAME) recursion.
        if (_pcre_pos + 1 >= _pcre_pat_len) { _pcre_err = PCRE_E_SYNTAX; return 0; }
        var p2 = load8(_pcre_pat + _pcre_pos + 1);
        if (p2 == 60) {
            # (?P<NAME>...)
            _pcre_pos = _pcre_pos + 2;
            _pcre_capture_n = _pcre_capture_n + 1;
            if (_pcre_capture_n > 9) { _pcre_err = PCRE_E_SYNTAX; return 0; }
            _pcre_add_name(_pcre_capture_n, 62);
            if (_pcre_err != PCRE_E_OK) { return 0; }
            return _pcre_capture_n;
        }
        if (p2 == 62) {
            # v0.8.0 — (?P>NAME) recursion. Look up name, emit RECURSE,
            # consume `)`, return -7 (fully consumed).
            _pcre_pos = _pcre_pos + 2;  # skip `P>`
            var rname_start = _pcre_pos;
            var rname_p = _pcre_pos;
            while (rname_p < _pcre_pat_len) {
                var rc = load8(_pcre_pat + rname_p);
                if (rc == 41) { rname_p = _pcre_pat_len; }       # break on `)`
                else          { rname_p = rname_p + 1; }
            }
            # Re-find the close paren.
            var rclose = rname_start;
            while (rclose < _pcre_pat_len && load8(_pcre_pat + rclose) != 41) {
                rclose = rclose + 1;
            }
            if (rclose >= _pcre_pat_len) { _pcre_err = PCRE_E_SYNTAX; return 0; }
            var rname_len = rclose - rname_start;
            if (rname_len < 1) { _pcre_err = PCRE_E_SYNTAX; return 0; }
            # Look up name in name table.
            var rgroup = _pcre_lookup_name(_pcre_pat + rname_start, rname_len);
            if (rgroup < 0) {
                _pcre_err = PCRE_E_BAD_RECURSION_REF;
                return 0;
            }
            _pcre_pos = rclose + 1;  # consume `)`
            _pcre_emit_recurse(rgroup);
            return 0 - 7;
        }
        _pcre_err = PCRE_E_SYNTAX;
        return 0;
    }
    if (n1 == 82) {
        # v0.8.0 — (?R) recursion. Target = group 0 (whole pattern).
        # Consume `R`, expect `)`, emit RECURSE, return -7.
        _pcre_pos = _pcre_pos + 1;  # skip `R`
        if (_pcre_pos >= _pcre_pat_len || load8(_pcre_pat + _pcre_pos) != 41) {
            _pcre_err = PCRE_E_SYNTAX;
            return 0;
        }
        _pcre_pos = _pcre_pos + 1;  # consume `)`
        _pcre_emit_recurse(0);
        return 0 - 7;
    }
    if (n1 == 124) {
        # v0.7.0 — (?|...) branch-reset group.
        _pcre_pos = _pcre_pos + 1;
        return 0 - 5;
    }
    if (n1 == 40) {
        # v0.7.0 — (?(cond)yes|no) conditional. cond may be a group
        # number or a name. Compiles to:
        #   COND group_idx, no_pc
        #   <yes_body>
        #   JMP end_pc
        # no_pc:
        #   <no_body>
        # end_pc:
        # If there is no `|`, no_pc == end_pc and the JMP is omitted.
        _pcre_pos = _pcre_pos + 1;  # past `(`
        if (_pcre_pos >= _pcre_pat_len) { _pcre_err = PCRE_E_SYNTAX; return 0; }
        var group_idx = 0;
        var cb = load8(_pcre_pat + _pcre_pos);
        if (cb >= 49 && cb <= 57) {
            # Numeric reference (?(N)
            group_idx = cb - 48;
            _pcre_pos = _pcre_pos + 1;
        }
        elif (cb == 60) {
            # (?(<NAME>) named-group reference.
            _pcre_pos = _pcre_pos + 1;
            var nm_start = _pcre_pos;
            while (_pcre_pos < _pcre_pat_len && _pcre_is_name_rest(load8(_pcre_pat + _pcre_pos)) == 1) {
                _pcre_pos = _pcre_pos + 1;
            }
            if (_pcre_pos >= _pcre_pat_len || load8(_pcre_pat + _pcre_pos) != 62) {
                _pcre_err = PCRE_E_SYNTAX; return 0;
            }
            var nm_len = _pcre_pos - nm_start;
            # Look up the name in the in-progress name table.
            var i = 0;
            var found = 0 - 1;
            while (i < _pcre_name_n) {
                var slot = _pcre_name_base + i * PCRE_NAME_SLOT_SIZE;
                var slot_len = 0;
                while (slot_len < PCRE_NAME_MAX_LEN && load8(slot + slot_len) != 0) {
                    slot_len = slot_len + 1;
                }
                if (slot_len == nm_len) {
                    var k = 0;
                    var same = 1;
                    while (k < nm_len) {
                        if (load8(slot + k) != load8(_pcre_pat + nm_start + k)) {
                            same = 0;
                            k = nm_len;
                        }
                        k = k + 1;
                    }
                    if (same == 1) { found = load64(slot + 32); }
                }
                i = i + 1;
            }
            if (found < 1) { _pcre_err = PCRE_E_BAD_CONDITION; return 0; }
            group_idx = found;
            _pcre_pos = _pcre_pos + 1;  # past `>`
        }
        else {
            # Other condition forms (lookarounds-as-cond, DEFINE, etc.) — not v0.7.0.
            _pcre_err = PCRE_E_BAD_CONDITION; return 0;
        }
        # Expect `)` closing the condition.
        if (_pcre_pos >= _pcre_pat_len || load8(_pcre_pat + _pcre_pos) != 41) {
            _pcre_err = PCRE_E_SYNTAX; return 0;
        }
        _pcre_pos = _pcre_pos + 1;  # past `)` of condition
        # Emit COND with placeholder no_pc.
        var cond_pc = _pcre_emit_raw(PCRE_OP_COND | (group_idx << 32), 0);
        # Parse YES body.
        _pcre_parse_concat();
        if (_pcre_err != PCRE_E_OK) { return 0; }
        var jmp_pc = 0 - 1;
        if (_pcre_pos < _pcre_pat_len && load8(_pcre_pat + _pcre_pos) == 124) {
            # `|` — there's a NO branch.
            _pcre_pos = _pcre_pos + 1;
            jmp_pc = _pcre_emit_jmp(0);
            var no_pc = _pcre_instr_n;
            _pcre_patch_arg2(cond_pc, no_pc);
            _pcre_parse_concat();
            if (_pcre_err != PCRE_E_OK) { return 0; }
        }
        # Expect `)` closing the conditional group.
        if (_pcre_pos >= _pcre_pat_len || load8(_pcre_pat + _pcre_pos) != 41) {
            _pcre_err = PCRE_E_SYNTAX; return 0;
        }
        _pcre_pos = _pcre_pos + 1;  # past final `)`
        var end_pc = _pcre_instr_n;
        if (jmp_pc >= 0) { _pcre_patch_arg1(jmp_pc, end_pc); }
        else              { _pcre_patch_arg2(cond_pc, end_pc); }
        return 0 - 7;  # fully consumed
    }
    if (n1 == 67) {
        # v0.7.0 — (?C) or (?C<num>) callout. Numbered observability hook.
        _pcre_pos = _pcre_pos + 1;  # past `C`
        var num = 0;
        var have_digits = 0;
        while (_pcre_pos < _pcre_pat_len && load8(_pcre_pat + _pcre_pos) >= 48 && load8(_pcre_pat + _pcre_pos) <= 57) {
            num = num * 10 + (load8(_pcre_pat + _pcre_pos) - 48);
            _pcre_pos = _pcre_pos + 1;
            have_digits = 1;
        }
        if (have_digits == 0) { num = 0; }
        if (num > 255)        { _pcre_err = PCRE_E_SYNTAX; return 0; }
        if (_pcre_pos >= _pcre_pat_len || load8(_pcre_pat + _pcre_pos) != 41) {
            _pcre_err = PCRE_E_SYNTAX; return 0;
        }
        _pcre_pos = _pcre_pos + 1;  # past `)`
        _pcre_emit_raw(PCRE_OP_CALLOUT | (num << 8), 0);
        return 0 - 7;  # fully consumed
    }
    if (n1 == 105 || n1 == 109 || n1 == 115) {
        # v0.7.0 — inline flags `(?i)` `(?m)` `(?s)` and combinations.
        _pcre_try_inline_flags();
        if (_pcre_err != PCRE_E_OK) { return 0; }
        return 0 - 7;  # fully consumed
    }
    _pcre_err = PCRE_E_SYNTAX;
    return 0;
}

fn _pcre_parse_primary(): i64 {
    if (_pcre_pos >= _pcre_pat_len) { _pcre_err = PCRE_E_SYNTAX; return 0; }
    var c = load8(_pcre_pat + _pcre_pos);
    if (c == 46) {
        _pcre_pos = _pcre_pos + 1;
        if (_pcre_flag_s == 1) { _pcre_emit_op(PCRE_OP_ANY); }
        else                    { _pcre_emit_op(PCRE_OP_ANY_NONL); }
    }
    elif (c == 94) {
        _pcre_pos = _pcre_pos + 1;
        if (_pcre_flag_m == 1) { _pcre_emit_op(PCRE_OP_BOL); }
        else                    { _pcre_emit_op(PCRE_OP_BOS); }
    }
    elif (c == 36) {
        _pcre_pos = _pcre_pos + 1;
        if (_pcre_flag_m == 1) { _pcre_emit_op(PCRE_OP_EOL); }
        else                    { _pcre_emit_op(PCRE_OP_EOS); }
    }
    elif (c == 40) {
        # `(` — group. Inspect for `(?...)` sub-syntax.
        _pcre_pos = _pcre_pos + 1;
        var capture_idx = 0 - 1;
        var lookahead_kind = 0;     # 1 = positive, 2 = negative
        var atomic_flag = 0;
        var branch_reset_flag = 0;  # v0.7.0 — (?|...)
        var lookbehind_kind = 0;    # v0.8.0: 1 = positive, 2 = negative
        if (_pcre_pos < _pcre_pat_len && load8(_pcre_pat + _pcre_pos) == 63) {
            var introducer = _pcre_parse_group_intro();
            if (_pcre_err != PCRE_E_OK) { return 0; }
            if (introducer == 0 - 7) { return 0; }   # fully consumed (flags / callout / conditional)
            if (introducer == 0 - 2) { lookahead_kind = 1; }
            elif (introducer == 0 - 3) { lookahead_kind = 2; }
            elif (introducer == 0 - 4) { atomic_flag = 1; }
            elif (introducer == 0 - 5) { branch_reset_flag = 1; }
            elif (introducer == 0 - 8) { lookbehind_kind = 1; }
            elif (introducer == 0 - 9) { lookbehind_kind = 2; }
            elif (introducer >= 1) { capture_idx = introducer; }
            # introducer == 0 means non-capturing — fall through
        }
        else {
            # Plain `(` — capturing group.
            _pcre_capture_n = _pcre_capture_n + 1;
            capture_idx = _pcre_capture_n;
            if (capture_idx > 9) { _pcre_err = PCRE_E_SYNTAX; return 0; }
        }
        if (capture_idx >= 1) {
            _pcre_emit_save(capture_idx * 2);
        }
        var lookahead_pc = 0 - 1;
        var atomic_pc = 0 - 1;
        var lookbehind_pc = 0 - 1;
        if (lookahead_kind > 0) {
            var neg = 0;
            if (lookahead_kind == 2) { neg = 1; }
            lookahead_pc = _pcre_emit_lookahead(neg);
        }
        if (lookbehind_kind > 0) {
            var lb_neg = 0;
            if (lookbehind_kind == 2) { lb_neg = 1; }
            lookbehind_pc = _pcre_emit_lookbehind(lb_neg);
        }
        if (atomic_flag == 1) {
            atomic_pc = _pcre_emit_raw(PCRE_OP_ATOMIC, 0);
        }
        # v0.7.0 — branch-reset save/restore around the body. Always
        # save+clear: nested groups inside a (?|...) get their own
        # alternation semantics back. Branch-reset itself sets a fresh
        # base for its body.
        var saved_br = _pcre_branch_reset_base;
        if (branch_reset_flag == 1) {
            _pcre_branch_reset_base = _pcre_capture_n;
        } else {
            _pcre_branch_reset_base = 0 - 1;
        }
        _pcre_parse_alt();
        _pcre_branch_reset_base = saved_br;
        if (_pcre_err != PCRE_E_OK) { return 0; }
        if (_pcre_pos >= _pcre_pat_len || load8(_pcre_pat + _pcre_pos) != 41) { _pcre_err = PCRE_E_SYNTAX; return 0; }
        _pcre_pos = _pcre_pos + 1;
        if (lookahead_pc >= 0) {
            var end_pc = _pcre_emit_op(PCRE_OP_LOOKAHEAD_END);
            _pcre_patch_arg1(lookahead_pc, end_pc);
        }
        if (lookbehind_pc >= 0) {
            # Width analysis on the body that just got compiled.
            var lb_body_start = lookbehind_pc + 1;
            var lb_body_end = _pcre_instr_n;
            var lb_width = _pcre_compute_width(lb_body_start, lb_body_end);
            if (lb_width < 0) {
                _pcre_err = PCRE_E_LOOKBEHIND_VARWIDTH;
                return 0;
            }
            var lb_end_pc = _pcre_emit_op(PCRE_OP_LOOKAHEAD_END);
            _pcre_patch_arg1(lookbehind_pc, lb_end_pc);
            _pcre_patch_arg2(lookbehind_pc, lb_width);
        }
        if (atomic_pc >= 0) {
            var end_pc2 = _pcre_emit_op(PCRE_OP_ATOMIC_END);
            _pcre_patch_arg1(atomic_pc, end_pc2);
        }
        if (capture_idx >= 1) {
            _pcre_emit_save(capture_idx * 2 + 1);
        }
    }
    elif (c == 91) {
        _pcre_pos = _pcre_pos + 1;
        var ci = _pcre_parse_class();
        if (_pcre_err != PCRE_E_OK) { return 0; }
        var neg = 0;
        if (ci < 0) { neg = 1; ci = 0 - (ci + 1); }
        _pcre_emit_class(neg, ci);
    }
    elif (c == 92) {
        if (_pcre_pos + 1 >= _pcre_pat_len) { _pcre_err = PCRE_E_SYNTAX; return 0; }
        var e = load8(_pcre_pat + _pcre_pos + 1);
        # \1-\9 backreference (PCRE supports them — emit BACKREF op).
        if (e >= 49 && e <= 57) {
            var n = e - 48;
            if (n > _pcre_capture_n) { _pcre_err = PCRE_E_SYNTAX; return 0; }
            _pcre_pos = _pcre_pos + 2;
            _pcre_emit_backref(n);
            return 0;
        }
        if (e == 100) {
            _pcre_pos = _pcre_pos + 2;
            var ci2 = _pcre_alloc_class(); if (_pcre_err != PCRE_E_OK) { return 0; }
            _pcre_class_fill_digit(ci2);
            _pcre_emit_class(0, ci2);
        }
        elif (e == 68) {
            _pcre_pos = _pcre_pos + 2;
            var ci3 = _pcre_alloc_class(); if (_pcre_err != PCRE_E_OK) { return 0; }
            _pcre_class_fill_digit(ci3);
            _pcre_emit_class(1, ci3);
        }
        elif (e == 119) {
            _pcre_pos = _pcre_pos + 2;
            var ci4 = _pcre_alloc_class(); if (_pcre_err != PCRE_E_OK) { return 0; }
            _pcre_class_fill_word(ci4);
            _pcre_emit_class(0, ci4);
        }
        elif (e == 87) {
            _pcre_pos = _pcre_pos + 2;
            var ci5 = _pcre_alloc_class(); if (_pcre_err != PCRE_E_OK) { return 0; }
            _pcre_class_fill_word(ci5);
            _pcre_emit_class(1, ci5);
        }
        elif (e == 115) {
            _pcre_pos = _pcre_pos + 2;
            var ci6 = _pcre_alloc_class(); if (_pcre_err != PCRE_E_OK) { return 0; }
            _pcre_class_fill_space(ci6);
            _pcre_emit_class(0, ci6);
        }
        elif (e == 83) {
            _pcre_pos = _pcre_pos + 2;
            var ci7 = _pcre_alloc_class(); if (_pcre_err != PCRE_E_OK) { return 0; }
            _pcre_class_fill_space(ci7);
            _pcre_emit_class(1, ci7);
        }
        elif (e == 98) {
            _pcre_pos = _pcre_pos + 2;
            _pcre_emit_op(PCRE_OP_BOUNDARY);
        }
        elif (e == 66) {
            _pcre_pos = _pcre_pos + 2;
            _pcre_emit_op(PCRE_OP_NBOUNDARY);
        }
        elif (e == 75) {
            # v0.7.0 — \K reset-match-start. Emit SAVE 0 to overwrite
            # the implicit start-of-match save with the current pos.
            _pcre_pos = _pcre_pos + 2;
            _pcre_emit_save(0);
        }
        elif (e == 112 || e == 80) {
            # v0.8.0 — \p{NAME} / \P{NAME} via stdlib lib/unicode.
            var neg_p = 0;
            if (e == 80) { neg_p = 1; }
            var u_mask = _uprops_parse_class(_pcre_pat, _pcre_pos + 2, _pcre_pat_len);
            if (u_mask == 0) {
                _pcre_err = PCRE_E_BAD_PROPERTY;
                return 0;
            }
            _pcre_pos = _uprops_match_end_pos;
            _pcre_emit_uprop(neg_p, u_mask);
        }
        else {
            var lc = _pcre_lit_byte();
            if (_pcre_err == PCRE_E_OK) { _pcre_emit_char(lc); }
        }
    }
    elif (c == 124 || c == 41 || c == 42 || c == 43 || c == 63 || c == 123 || c == 125 || c == 93) {
        _pcre_err = PCRE_E_SYNTAX; return 0;
    }
    else {
        if (c >= 128 && _pcre_flag_i == 1) {
            # v0.8.0 — multi-byte literal under (?i): decode cp, fold via
            # stdlib unicode_to_lower, emit UCHAR_CI. Single opcode that
            # internally consumes the full multi-byte cp at match time.
            var u_step = _uc_decode_utf8(_pcre_pat, _pcre_pos, _pcre_pat_len, _pcre_m_cp_slot);
            var u_cp = load64(_pcre_m_cp_slot);
            _pcre_pos = _pcre_pos + u_step;
            _pcre_emit_uchar_ci(unicode_to_lower(u_cp));
        } else {
            _pcre_pos = _pcre_pos + 1;
            _pcre_emit_char(c);
        }
    }
    return 0;
}

# Wrap [atom_start, _pcre_instr_n) inside an ATOMIC block.
fn _pcre_wrap_atomic(atom_start): i64 {
    var atom_end = _pcre_instr_n;
    _pcre_shift_right(atom_start, atom_end);
    _pcre_shift_targets_one(atom_start, atom_end);
    _pcre_instr_n = _pcre_instr_n + 1;
    store64(_pcre_instr_base + atom_start * 16, _pcre_w0(PCRE_OP_ATOMIC, 0, 0));
    store64(_pcre_instr_base + atom_start * 16 + 8, 0);
    var end_pc = _pcre_emit_op(PCRE_OP_ATOMIC_END);
    _pcre_patch_arg1(atom_start, end_pc);
    return 0;
}

fn _pcre_apply_simple_q(atom_start, op_char): i64 {
    var atom_end = _pcre_instr_n;
    if (atom_end == atom_start) { _pcre_err = PCRE_E_SYNTAX; return 0; }
    _pcre_pos = _pcre_pos + 1;
    var lazy = 0;
    var possessive = 0;
    if (_pcre_pos < _pcre_pat_len) {
        var nx = load8(_pcre_pat + _pcre_pos);
        if (nx == 63) {
            lazy = 1;
            _pcre_pos = _pcre_pos + 1;
        }
        elif (nx == 43) {
            # Possessive quantifier (`*+`, `++`, `?+`) — equivalent to atomic
            # wrapping of the greedy quantifier per ADR 0004.
            possessive = 1;
            _pcre_pos = _pcre_pos + 1;
        }
    }
    if (op_char == 42) {
        _pcre_shift_right(atom_start, atom_end);
        _pcre_shift_targets_one(atom_start, atom_end);
        _pcre_instr_n = _pcre_instr_n + 1;
        var body_pc = atom_start + 1;
        if (lazy == 1) {
            store64(_pcre_instr_base + atom_start * 16, _pcre_w0(PCRE_OP_SPLIT, 0, 0));
            store64(_pcre_instr_base + atom_start * 16 + 8, body_pc);
        } else {
            store64(_pcre_instr_base + atom_start * 16, _pcre_w0(PCRE_OP_SPLIT, 0, body_pc));
            store64(_pcre_instr_base + atom_start * 16 + 8, 0);
        }
        _pcre_emit_jmp(atom_start);
        var exit_pc = _pcre_instr_n;
        if (lazy == 1) { _pcre_patch_arg1(atom_start, exit_pc); }
        else            { _pcre_patch_arg2(atom_start, exit_pc); }
    }
    elif (op_char == 43) {
        if (lazy == 1) {
            var s = _pcre_emit_split(0, atom_start);
            _pcre_patch_arg1(s, _pcre_instr_n);
        } else {
            var s2 = _pcre_emit_split(atom_start, 0);
            _pcre_patch_arg2(s2, _pcre_instr_n);
        }
    }
    elif (op_char == 63) {
        _pcre_shift_right(atom_start, atom_end);
        _pcre_shift_targets_one(atom_start, atom_end);
        _pcre_instr_n = _pcre_instr_n + 1;
        var body = atom_start + 1;
        if (lazy == 1) {
            store64(_pcre_instr_base + atom_start * 16, _pcre_w0(PCRE_OP_SPLIT, 0, 0));
            store64(_pcre_instr_base + atom_start * 16 + 8, body);
            _pcre_patch_arg1(atom_start, _pcre_instr_n);
        } else {
            store64(_pcre_instr_base + atom_start * 16, _pcre_w0(PCRE_OP_SPLIT, 0, body));
            store64(_pcre_instr_base + atom_start * 16 + 8, _pcre_instr_n);
        }
    }
    if (possessive == 1) {
        _pcre_wrap_atomic(atom_start);
    }
    return 0;
}

fn _pcre_apply_star_inline(body_start, lazy): i64 {
    var body_end = _pcre_instr_n;
    _pcre_shift_right(body_start, body_end);
    _pcre_shift_targets_one(body_start, body_end);
    _pcre_instr_n = _pcre_instr_n + 1;
    var body_pc = body_start + 1;
    if (lazy == 1) {
        store64(_pcre_instr_base + body_start * 16, _pcre_w0(PCRE_OP_SPLIT, 0, 0));
        store64(_pcre_instr_base + body_start * 16 + 8, body_pc);
    } else {
        store64(_pcre_instr_base + body_start * 16, _pcre_w0(PCRE_OP_SPLIT, 0, body_pc));
        store64(_pcre_instr_base + body_start * 16 + 8, 0);
    }
    _pcre_emit_jmp(body_start);
    var exit_pc = _pcre_instr_n;
    if (lazy == 1) { _pcre_patch_arg1(body_start, exit_pc); }
    else            { _pcre_patch_arg2(body_start, exit_pc); }
    return 0;
}

fn _pcre_apply_brace_q(save_primary_start, atom_start): i64 {
    if (_pcre_instr_n == atom_start) { _pcre_err = PCRE_E_SYNTAX; return 0; }
    _pcre_pos = _pcre_pos + 1;
    var n_min = 0;
    var have_min = 0;
    while (_pcre_pos < _pcre_pat_len && load8(_pcre_pat + _pcre_pos) >= 48 && load8(_pcre_pat + _pcre_pos) <= 57) {
        n_min = n_min * 10 + (load8(_pcre_pat + _pcre_pos) - 48);
        _pcre_pos = _pcre_pos + 1;
        have_min = 1;
    }
    if (have_min == 0) { _pcre_err = PCRE_E_SYNTAX; return 0; }
    var n_max = n_min;
    var open_ended = 0;
    if (_pcre_pos < _pcre_pat_len && load8(_pcre_pat + _pcre_pos) == 44) {
        _pcre_pos = _pcre_pos + 1;
        n_max = 0;
        var have_max = 0;
        while (_pcre_pos < _pcre_pat_len && load8(_pcre_pat + _pcre_pos) >= 48 && load8(_pcre_pat + _pcre_pos) <= 57) {
            n_max = n_max * 10 + (load8(_pcre_pat + _pcre_pos) - 48);
            _pcre_pos = _pcre_pos + 1;
            have_max = 1;
        }
        if (have_max == 0) { open_ended = 1; n_max = 0; }
    }
    if (_pcre_pos >= _pcre_pat_len || load8(_pcre_pat + _pcre_pos) != 125) { _pcre_err = PCRE_E_SYNTAX; return 0; }
    _pcre_pos = _pcre_pos + 1;
    var lazy = 0;
    var possessive = 0;
    if (_pcre_pos < _pcre_pat_len) {
        var qx = load8(_pcre_pat + _pcre_pos);
        if (qx == 63) { lazy = 1; _pcre_pos = _pcre_pos + 1; }
        elif (qx == 43) { possessive = 1; _pcre_pos = _pcre_pos + 1; }
    }
    var pos_after_q = _pcre_pos;
    if (open_ended == 0 && n_max < n_min) { _pcre_err = PCRE_E_SYNTAX; return 0; }
    if (n_max > 1000) { _pcre_err = PCRE_E_TOO_LARGE; return 0; }
    if (n_min == 0) {
        _pcre_instr_n = atom_start;
        if (open_ended == 1) {
            var ts = _pcre_instr_n;
            _pcre_pos = save_primary_start;
            _pcre_parse_primary();
            if (_pcre_err != PCRE_E_OK) { return 0; }
            _pcre_apply_star_inline(ts, lazy);
        } else {
            var sn = 0;
            var k = 0;
            while (k < n_max) {
                if (sn >= 64) { _pcre_err = PCRE_E_TOO_LARGE; return 0; }
                var sx = _pcre_emit_split(0, 0);
                store64(_pcre_q_splits + sn * 8, sx);
                sn = sn + 1;
                _pcre_pos = save_primary_start;
                _pcre_parse_primary();
                if (_pcre_err != PCRE_E_OK) { return 0; }
                k = k + 1;
            }
            var exit_pc = _pcre_instr_n;
            var ti = 0;
            while (ti < sn) {
                var sxi = load64(_pcre_q_splits + ti * 8);
                if (lazy == 1) { _pcre_patch_arg1(sxi, exit_pc); _pcre_patch_arg2(sxi, sxi + 1); }
                else            { _pcre_patch_arg1(sxi, sxi + 1); _pcre_patch_arg2(sxi, exit_pc); }
                ti = ti + 1;
            }
        }
    } else {
        var k1 = 1;
        while (k1 < n_min) {
            _pcre_pos = save_primary_start;
            _pcre_parse_primary();
            if (_pcre_err != PCRE_E_OK) { return 0; }
            k1 = k1 + 1;
        }
        if (open_ended == 1) {
            var ts2 = _pcre_instr_n;
            _pcre_pos = save_primary_start;
            _pcre_parse_primary();
            if (_pcre_err != PCRE_E_OK) { return 0; }
            _pcre_apply_star_inline(ts2, lazy);
        } elif (n_max > n_min) {
            var sn2 = 0;
            var k2 = n_min;
            while (k2 < n_max) {
                if (sn2 >= 64) { _pcre_err = PCRE_E_TOO_LARGE; return 0; }
                var sy = _pcre_emit_split(0, 0);
                store64(_pcre_q_splits + sn2 * 8, sy);
                sn2 = sn2 + 1;
                _pcre_pos = save_primary_start;
                _pcre_parse_primary();
                if (_pcre_err != PCRE_E_OK) { return 0; }
                k2 = k2 + 1;
            }
            var exit_pc2 = _pcre_instr_n;
            var tj = 0;
            while (tj < sn2) {
                var syi = load64(_pcre_q_splits + tj * 8);
                if (lazy == 1) { _pcre_patch_arg1(syi, exit_pc2); _pcre_patch_arg2(syi, syi + 1); }
                else            { _pcre_patch_arg1(syi, syi + 1); _pcre_patch_arg2(syi, exit_pc2); }
                tj = tj + 1;
            }
        }
    }
    if (possessive == 1) {
        _pcre_wrap_atomic(atom_start);
    }
    _pcre_pos = pos_after_q;
    return 0;
}

fn _pcre_parse_atom(): i64 {
    var save_primary_start = _pcre_pos;
    var atom_start = _pcre_instr_n;
    _pcre_parse_primary();
    if (_pcre_err != PCRE_E_OK) { return 0; }
    if (_pcre_pos >= _pcre_pat_len) { return 0; }
    var c = load8(_pcre_pat + _pcre_pos);
    if (c == 42 || c == 43 || c == 63) {
        _pcre_apply_simple_q(atom_start, c);
    }
    elif (c == 123) {
        _pcre_apply_brace_q(save_primary_start, atom_start);
    }
    return 0;
}

fn _pcre_parse_concat(): i64 {
    while (_pcre_pos < _pcre_pat_len) {
        var c = load8(_pcre_pat + _pcre_pos);
        if (c == 124 || c == 41) { return 0; }
        _pcre_parse_atom();
        if (_pcre_err != PCRE_E_OK) { return 0; }
    }
    return 0;
}

fn _pcre_parse_alt(): i64 {
    # v0.7.0 — branch-reset (?|...) tracking. When _pcre_branch_reset_base
    # is set (>= 0), each `|` resets _pcre_capture_n back to that base so
    # alternatives reuse group numbers; the post-group max-seen value is
    # tracked in `max_after_branches` and restored when we return.
    var br_base = _pcre_branch_reset_base;
    var max_after_branches = _pcre_capture_n;

    var left_start = _pcre_instr_n;
    _pcre_parse_concat();
    if (_pcre_err != PCRE_E_OK) { return 0; }
    if (_pcre_capture_n > max_after_branches) { max_after_branches = _pcre_capture_n; }
    while (_pcre_pos < _pcre_pat_len && load8(_pcre_pat + _pcre_pos) == 124) {
        _pcre_pos = _pcre_pos + 1;
        var left_end = _pcre_instr_n;
        _pcre_shift_right(left_start, left_end);
        _pcre_shift_targets_one(left_start, left_end);
        _pcre_instr_n = _pcre_instr_n + 1;
        store64(_pcre_instr_base + left_start * 16, _pcre_w0(PCRE_OP_SPLIT, 0, left_start + 1));
        store64(_pcre_instr_base + left_start * 16 + 8, 0);
        var jmp_idx = _pcre_emit_jmp(0);
        var right_start = _pcre_instr_n;
        _pcre_patch_arg2(left_start, right_start);
        if (br_base >= 0) {
            # Reset capture count for this new branch.
            _pcre_capture_n = br_base;
        }
        _pcre_parse_concat();
        if (_pcre_err != PCRE_E_OK) { return 0; }
        if (_pcre_capture_n > max_after_branches) { max_after_branches = _pcre_capture_n; }
        _pcre_patch_arg1(jmp_idx, _pcre_instr_n);
    }
    if (br_base >= 0) { _pcre_capture_n = max_after_branches; }
    return 0;
}

# === Compiler entry ==================================================

fn niyama_pcre_compile(pat): i64 {
    _pcre_lazy_init();
    var n = strlen(pat);
    var instr_bytes = PCRE_MAX_INSTRS * 16;
    var class_bytes = PCRE_MAX_CLASSES * 32;
    var name_bytes  = PCRE_MAX_NAMES * PCRE_NAME_SLOT_SIZE;
    var nfa = alloc(PCRE_NFA_HEADER_SIZE + instr_bytes + class_bytes + name_bytes);
    var instrs = nfa + PCRE_NFA_HEADER_SIZE;
    var classes = instrs + instr_bytes;
    var names = classes + class_bytes;
    store64(nfa + PCRE_OFF_INSTRS_OFF,  PCRE_NFA_HEADER_SIZE);
    store64(nfa + PCRE_OFF_CLASSES_OFF, PCRE_NFA_HEADER_SIZE + instr_bytes);
    store64(nfa + PCRE_OFF_NAMES_OFF,   PCRE_NFA_HEADER_SIZE + instr_bytes + class_bytes);
    store64(nfa + PCRE_OFF_MATCH_START, 0 - 1);
    store64(nfa + PCRE_OFF_MATCH_END,   0 - 1);
    var sv = 0;
    while (sv < PCRE_MAX_SAVES) {
        store64(nfa + PCRE_OFF_SAVES + sv * 8, 0 - 1);
        sv = sv + 1;
    }
    # Zero name table.
    var nb = 0;
    while (nb < name_bytes) {
        store8(names + nb, 0);
        nb = nb + 1;
    }
    _pcre_pat = pat;
    _pcre_pat_len = n;
    _pcre_pos = 0;
    _pcre_nfa = nfa;
    _pcre_instr_base = instrs;
    _pcre_class_base = classes;
    _pcre_name_base = names;
    _pcre_instr_n = 0;
    _pcre_class_n = 0;
    _pcre_capture_n = 0;
    _pcre_name_n = 0;
    # v0.7.0 — reset inline-flag + branch-reset state per compile.
    _pcre_flag_i = 0;
    _pcre_flag_m = 0;
    _pcre_flag_s = 0;
    _pcre_branch_reset_base = 0 - 1;
    _pcre_err = PCRE_E_OK;
    _pcre_emit_save(0);
    _pcre_parse_alt();
    if (_pcre_err != PCRE_E_OK || _pcre_pos != _pcre_pat_len) {
        if (_pcre_err == PCRE_E_OK) { _pcre_err = PCRE_E_SYNTAX; }
        _pcre_last_err = _pcre_err;
        return 0;
    }
    _pcre_emit_save(1);
    _pcre_emit_op(PCRE_OP_MATCH);
    if (_pcre_err != PCRE_E_OK) {
        _pcre_last_err = _pcre_err;
        return 0;
    }
    store64(nfa + PCRE_OFF_INSTR_COUNT, _pcre_instr_n);
    store64(nfa + PCRE_OFF_CLASS_COUNT, _pcre_class_n);
    store64(nfa + PCRE_OFF_CAPTURES,    _pcre_capture_n);
    store64(nfa + PCRE_OFF_NAME_COUNT,  _pcre_name_n);
    _pcre_last_err = PCRE_E_OK;
    return nfa;
}

fn niyama_pcre_last_error(): i64 {
    return _pcre_last_err;
}

fn niyama_pcre_set_step_limit(n): i64 {
    _pcre_step_limit = n;
    return 0;
}

fn niyama_pcre_last_step_count(): i64 {
    return _pcre_last_step_count;
}

# v0.7.0 — last callout number reached during the most recent match.
# -1 if no callout was hit (or no match was attempted).
fn niyama_pcre_last_callout(): i64 {
    return _pcre_last_callout;
}

# === Backtracking matcher ============================================
#
# Recursive: each call returns either the end-pos on match, or -1 on
# fail. The caller's saves[] is mutated during execution; on backtrack
# the caller is responsible for restoring any fields it cares about
# (the matcher does this at SAVE / SPLIT / lookahead branch points
# inline).
#
# Catastrophic backtracking is bounded by _pcre_step_count incrementing
# per step. Hits over _pcre_step_limit return -1 immediately. The "no
# match" answer this produces is intentional per ADR 0004 — the
# observable behavior matches an honest mismatch.

# v0.8.0 — locate a group's open/close SAVE pcs by scanning compiled
# instructions. Used at match time by RECURSE. Group 0 (whole pattern)
# uses the FIRST SAVE 0 (pc 0) and the LAST SAVE 1 (right before
# MATCH) because `\K` may emit additional SAVE 0 mid-pattern. Groups
# 1-9 each have a unique open/close pair. Returns 0 on success and
# stores results in _pcre_grp_open_pc / _pcre_grp_close_pc, -1 on
# missing-group.
fn _pcre_find_group_pcs(instrs, instr_count, group_idx): i64 {
    var open_save_idx = group_idx * 2;
    var close_save_idx = group_idx * 2 + 1;
    _pcre_grp_open_pc  = 0 - 1;
    _pcre_grp_close_pc = 0 - 1;
    var i = 0;
    while (i < instr_count) {
        var w0 = load64(instrs + i * 16);
        var op = w0 & 0xFF;
        if (op == PCRE_OP_SAVE) {
            var save_idx = (w0 >> 8) & 0xFF;
            if (save_idx == open_save_idx) {
                if (_pcre_grp_open_pc < 0) { _pcre_grp_open_pc = i; }
            }
            if (save_idx == close_save_idx) {
                _pcre_grp_close_pc = i;
            }
        }
        i = i + 1;
    }
    if (_pcre_grp_open_pc < 0)  { return 0 - 1; }
    if (_pcre_grp_close_pc < 0) { return 0 - 1; }
    return 0;
}

fn _pcre_at_word_char(input, input_len, pos): i64 {
    if (pos < 0)         { return 0; }
    if (pos >= input_len){ return 0; }
    var c = load8(input + pos);
    if (c >= 48 && c <= 57)   { return 1; }
    if (c >= 65 && c <= 90)   { return 1; }
    if (c >= 97 && c <= 122)  { return 1; }
    if (c == 95)              { return 1; }
    return 0;
}

fn _pcre_is_boundary(input, input_len, pos): i64 {
    var l = _pcre_at_word_char(input, input_len, pos - 1);
    var r = _pcre_at_word_char(input, input_len, pos);
    if (l != r) { return 1; }
    return 0;
}

fn _pcre_class_get_at(class_base, ci, c): i64 {
    if (c < 0)   { return 0; }
    if (c > 255) { return 0; }
    var off = class_base + ci * 32 + (c >> 3);
    var b = load8(off);
    if ((b >> (c & 7)) & 1) { return 1; }
    return 0;
}

# Save a 20-i64 saves[] snapshot to dst. Used at every backtrack point.
fn _pcre_saves_snapshot(saves, dst): i64 {
    var k = 0;
    while (k < PCRE_MAX_SAVES) {
        store64(dst + k * 8, load64(saves + k * 8));
        k = k + 1;
    }
    return 0;
}

fn _pcre_saves_restore(saves, src): i64 {
    var k = 0;
    while (k < PCRE_MAX_SAVES) {
        store64(saves + k * 8, load64(src + k * 8));
        k = k + 1;
    }
    return 0;
}

fn _pcre_match_run(instrs, instr_count, class_base, input, input_len, start_pc, start_pos, saves, depth): i64 {
    if (depth > _pcre_depth_limit) { return 0 - 1; }
    var pc = start_pc;
    var pos = start_pos;
    while (pc >= 0) {
        # v0.8.0 — recursion stop check. If the active recursion frame
        # set a stop_pc and we've reached it, the body completed
        # successfully — return pos to the recursive caller.
        if (_pcre_recurse_stop_pc >= 0 && pc == _pcre_recurse_stop_pc) {
            return pos;
        }
        _pcre_step_count = _pcre_step_count + 1;
        if (_pcre_step_count > _pcre_step_limit) { return 0 - 1; }
        if (pc >= instr_count) { return 0 - 1; }
        var w0 = load64(instrs + pc * 16);
        var op = w0 & 0xFF;
        if (op == PCRE_OP_MATCH) {
            return pos;
        }
        elif (op == PCRE_OP_LOOKAHEAD_END) {
            return pos;
        }
        elif (op == PCRE_OP_ATOMIC_END) {
            return pos;
        }
        elif (op == PCRE_OP_CHAR) {
            if (pos >= input_len) { return 0 - 1; }
            var want = (w0 >> 8) & 0xFF;
            if (load8(input + pos) != want) { return 0 - 1; }
            pos = pos + 1;
            pc = pc + 1;
        }
        elif (op == PCRE_OP_CHAR_CI) {
            if (pos >= input_len) { return 0 - 1; }
            var want_ci = (w0 >> 8) & 0xFF;
            var ic = load8(input + pos);
            if (ic >= 65 && ic <= 90) { ic = ic + 32; }
            if (ic != want_ci) { return 0 - 1; }
            pos = pos + 1;
            pc = pc + 1;
        }
        elif (op == PCRE_OP_ANY) {
            if (pos >= input_len) { return 0 - 1; }
            pos = pos + 1;
            pc = pc + 1;
        }
        elif (op == PCRE_OP_ANY_NONL) {
            if (pos >= input_len) { return 0 - 1; }
            if (load8(input + pos) == 10) { return 0 - 1; }
            pos = pos + 1;
            pc = pc + 1;
        }
        elif (op == PCRE_OP_CLASS) {
            if (pos >= input_len) { return 0 - 1; }
            var ci = (w0 >> 8) & 0xFF;
            var c = load8(input + pos);
            if (_pcre_class_get_at(class_base, ci, c) == 0) { return 0 - 1; }
            pos = pos + 1;
            pc = pc + 1;
        }
        elif (op == PCRE_OP_NCLASS) {
            if (pos >= input_len) { return 0 - 1; }
            var ci2 = (w0 >> 8) & 0xFF;
            var c2 = load8(input + pos);
            if (_pcre_class_get_at(class_base, ci2, c2) == 1) { return 0 - 1; }
            pos = pos + 1;
            pc = pc + 1;
        }
        elif (op == PCRE_OP_UCHAR_CI) {
            # v0.8.0 — case-insensitive multi-byte literal. Stored cp
            # is unicode_to_lower(pattern_cp); fold input cp the same
            # way and compare. Internal multi-byte advance.
            if (pos >= input_len) { return 0 - 1; }
            var uci_b = load8(input + pos);
            var uci_cp = uci_b;
            var uci_step = 1;
            if (uci_b >= 128) {
                uci_step = _uc_decode_utf8(input, pos, input_len, _pcre_m_cp_slot);
                uci_cp = load64(_pcre_m_cp_slot);
            }
            var uci_want = (w0 >> 32) & 0x1FFFFF;
            if (unicode_to_lower(uci_cp) != uci_want) { return 0 - 1; }
            pos = pos + uci_step;
            pc = pc + 1;
        }
        elif (op == PCRE_OP_UPROP || op == PCRE_OP_NUPROP) {
            # v0.8.0 — \p{NAME} / \P{NAME} via stdlib unicode_category.
            # Decodes UTF-8 cp at pos and advances by full codepoint
            # length (1..4). Mixed with byte-stepped CHAR/CLASS — see
            # opcode-decl comment for caveats.
            if (pos >= input_len) { return 0 - 1; }
            var cu = load8(input + pos);
            var cp = cu;
            var step = 1;
            if (cu >= 128) {
                step = _uc_decode_utf8(input, pos, input_len, _pcre_m_cp_slot);
                cp = load64(_pcre_m_cp_slot);
            }
            var u_mask = (w0 >> 32) & 0x3FFFFFFF;
            var u_hit = _uprops_test(cp, u_mask);
            if (op == PCRE_OP_NUPROP) {
                if (u_hit == 1) { u_hit = 0; } else { u_hit = 1; }
            }
            if (u_hit == 0) { return 0 - 1; }
            pos = pos + step;
            pc = pc + 1;
        }
        elif (op == PCRE_OP_BOL) {
            var ok = 0;
            if (pos == 0) { ok = 1; }
            elif (load8(input + pos - 1) == 10) { ok = 1; }
            if (ok == 0) { return 0 - 1; }
            pc = pc + 1;
        }
        elif (op == PCRE_OP_EOL) {
            var ok2 = 0;
            if (pos == input_len) { ok2 = 1; }
            elif (load8(input + pos) == 10) { ok2 = 1; }
            if (ok2 == 0) { return 0 - 1; }
            pc = pc + 1;
        }
        elif (op == PCRE_OP_BOS) {
            if (pos != 0) { return 0 - 1; }
            pc = pc + 1;
        }
        elif (op == PCRE_OP_EOS) {
            if (pos != input_len) { return 0 - 1; }
            pc = pc + 1;
        }
        elif (op == PCRE_OP_BOUNDARY) {
            if (_pcre_is_boundary(input, input_len, pos) == 0) { return 0 - 1; }
            pc = pc + 1;
        }
        elif (op == PCRE_OP_NBOUNDARY) {
            if (_pcre_is_boundary(input, input_len, pos) == 1) { return 0 - 1; }
            pc = pc + 1;
        }
        elif (op == PCRE_OP_JMP) {
            pc = (w0 >> 32) & 0xFFFFFFFF;
        }
        elif (op == PCRE_OP_SPLIT) {
            var a = (w0 >> 32) & 0xFFFFFFFF;
            var b = load64(instrs + pc * 16 + 8);
            var snap = alloc(PCRE_MAX_SAVES * 8);
            _pcre_saves_snapshot(saves, snap);
            var r = _pcre_match_run(instrs, instr_count, class_base, input, input_len, a, pos, saves, depth + 1);
            if (r >= 0) { return r; }
            _pcre_saves_restore(saves, snap);
            pc = b;
        }
        elif (op == PCRE_OP_SAVE) {
            var idx = (w0 >> 8) & 0xFF;
            var prev = load64(saves + idx * 8);
            store64(saves + idx * 8, pos);
            var r2 = _pcre_match_run(instrs, instr_count, class_base, input, input_len, pc + 1, pos, saves, depth + 1);
            if (r2 >= 0) { return r2; }
            store64(saves + idx * 8, prev);
            return 0 - 1;
        }
        elif (op == PCRE_OP_BACKREF) {
            var n = (w0 >> 8) & 0xFF;
            var gs = load64(saves + n * 16);
            var ge = load64(saves + n * 16 + 8);
            if (gs < 0) { return 0 - 1; }
            if (ge < 0) { return 0 - 1; }
            var glen = ge - gs;
            if (pos + glen > input_len) { return 0 - 1; }
            var k = 0;
            while (k < glen) {
                if (load8(input + pos + k) != load8(input + gs + k)) { return 0 - 1; }
                k = k + 1;
            }
            pos = pos + glen;
            pc = pc + 1;
        }
        elif (op == PCRE_OP_LOOKAHEAD) {
            var end_pc3 = (w0 >> 32) & 0xFFFFFFFF;
            var snap2 = alloc(PCRE_MAX_SAVES * 8);
            _pcre_saves_snapshot(saves, snap2);
            # v0.8.0 — clear recursion stop for the sub-match (lookahead
            # is its own scope; outer recursion's stop_pc shouldn't fire
            # mid-lookahead).
            var prev_stop_la = _pcre_recurse_stop_pc;
            _pcre_recurse_stop_pc = 0 - 1;
            var r3 = _pcre_match_run(instrs, instr_count, class_base, input, input_len, pc + 1, pos, saves, depth + 1);
            _pcre_recurse_stop_pc = prev_stop_la;
            if (r3 < 0) {
                _pcre_saves_restore(saves, snap2);
                return 0 - 1;
            }
            # Positive lookahead succeeded. Captures from sub stay (PCRE2
            # semantics). Don't advance pos. Skip past the END marker.
            pc = end_pc3 + 1;
        }
        elif (op == PCRE_OP_NLOOKAHEAD) {
            var end_pc4 = (w0 >> 32) & 0xFFFFFFFF;
            var snap3 = alloc(PCRE_MAX_SAVES * 8);
            _pcre_saves_snapshot(saves, snap3);
            var prev_stop_nla = _pcre_recurse_stop_pc;
            _pcre_recurse_stop_pc = 0 - 1;
            var r4 = _pcre_match_run(instrs, instr_count, class_base, input, input_len, pc + 1, pos, saves, depth + 1);
            _pcre_recurse_stop_pc = prev_stop_nla;
            # Negative lookahead — sub captures discarded regardless.
            _pcre_saves_restore(saves, snap3);
            if (r4 >= 0) { return 0 - 1; }
            pc = end_pc4 + 1;
        }
        elif (op == PCRE_OP_LOOKBEHIND || op == PCRE_OP_NLOOKBEHIND) {
            # v0.8.0 — fixed-width lookbehind. Body consumes exactly
            # `lb_width` bytes; succeed if running it from pos-lb_width
            # ends at pos. Sub captures stay (positive) or discarded
            # (negative), mirroring lookahead semantics.
            var lb_end_pc = (w0 >> 32) & 0xFFFFFFFF;
            var lb_width  = load64(instrs + pc * 16 + 8);
            var lb_neg = 0;
            if (op == PCRE_OP_NLOOKBEHIND) { lb_neg = 1; }
            if (pos < lb_width) {
                # Not enough preceding input. Positive: fail. Negative:
                # vacuously succeed (no `lb_width` chars to match against).
                if (lb_neg == 1) { pc = lb_end_pc + 1; }
                else             { return 0 - 1; }
            }
            else {
                var snap_lb = alloc(PCRE_MAX_SAVES * 8);
                _pcre_saves_snapshot(saves, snap_lb);
                var prev_stop_lb = _pcre_recurse_stop_pc;
                _pcre_recurse_stop_pc = 0 - 1;
                var rb = _pcre_match_run(instrs, instr_count, class_base, input, input_len, pc + 1, pos - lb_width, saves, depth + 1);
                _pcre_recurse_stop_pc = prev_stop_lb;
                # Body succeeded only if it landed exactly at pos
                # (consumed lb_width bytes). rb == pos means success.
                if (rb == pos) {
                    if (lb_neg == 1) {
                        _pcre_saves_restore(saves, snap_lb);
                        return 0 - 1;
                    }
                    pc = lb_end_pc + 1;
                }
                else {
                    _pcre_saves_restore(saves, snap_lb);
                    if (lb_neg == 1) { pc = lb_end_pc + 1; }
                    else             { return 0 - 1; }
                }
            }
        }
        elif (op == PCRE_OP_ATOMIC) {
            var end_pc5 = (w0 >> 32) & 0xFFFFFFFF;
            var prev_stop_at = _pcre_recurse_stop_pc;
            _pcre_recurse_stop_pc = 0 - 1;
            var r5 = _pcre_match_run(instrs, instr_count, class_base, input, input_len, pc + 1, pos, saves, depth + 1);
            _pcre_recurse_stop_pc = prev_stop_at;
            if (r5 < 0) { return 0 - 1; }
            pos = r5;
            pc = end_pc5 + 1;
        }
        elif (op == PCRE_OP_RECURSE) {
            # v0.8.0 — (?R) / (?P>NAME) recursion. Walk instructions to
            # find target group's open SAVE pc and close SAVE pc; run
            # sub-match from open_pc with stop_pc = close_pc + 1.
            # Saves snapshot/restored so recursion's captures don't
            # propagate; this matches PCRE2's recursion semantics
            # (recursion is for matching only, not capture).
            var rec_target = (w0 >> 8) & 0xFFFF;
            if (_pcre_find_group_pcs(instrs, instr_count, rec_target) < 0) {
                return 0 - 1;
            }
            var rec_open  = _pcre_grp_open_pc;
            var rec_close = _pcre_grp_close_pc;
            var rec_snap = alloc(PCRE_MAX_SAVES * 8);
            _pcre_saves_snapshot(saves, rec_snap);
            var prev_stop_rec = _pcre_recurse_stop_pc;
            _pcre_recurse_stop_pc = rec_close + 1;
            var rec_r = _pcre_match_run(instrs, instr_count, class_base, input, input_len, rec_open, pos, saves, depth + 1);
            _pcre_recurse_stop_pc = prev_stop_rec;
            _pcre_saves_restore(saves, rec_snap);
            if (rec_r < 0) { return 0 - 1; }
            pos = rec_r;
            pc = pc + 1;
        }
        elif (op == PCRE_OP_COND) {
            # v0.7.0 — conditional. arg1 = group_idx, arg2 = no_pc.
            # If the referenced group has participated (start >= 0),
            # fall through into the YES body; else jump to no_pc.
            var cg_idx = (w0 >> 32) & 0xFFFFFFFF;
            var no_pc  = load64(instrs + pc * 16 + 8);
            var gs_c = load64(saves + cg_idx * 16);
            if (gs_c >= 0) {
                pc = pc + 1;
            } else {
                pc = no_pc;
            }
        }
        elif (op == PCRE_OP_CALLOUT) {
            # v0.7.0 — observability hook. Records the callout number;
            # consumers query niyama_pcre_last_callout(). Zero-width.
            _pcre_last_callout = (w0 >> 8) & 0xFF;
            pc = pc + 1;
        }
        else {
            return 0 - 1;
        }
    }
    return 0 - 1;
}

# === Public API ======================================================

fn _pcre_run_at(nfa, input, input_len, from): i64 {
    _pcre_step_count = 0;
    _pcre_last_callout = 0 - 1;
    var instrs = nfa + load64(nfa + PCRE_OFF_INSTRS_OFF);
    var instr_count = load64(nfa + PCRE_OFF_INSTR_COUNT);
    var class_base = nfa + load64(nfa + PCRE_OFF_CLASSES_OFF);
    var saves = alloc(PCRE_MAX_SAVES * 8);
    var k = 0;
    while (k < PCRE_MAX_SAVES) {
        store64(saves + k * 8, 0 - 1);
        k = k + 1;
    }
    var r = _pcre_match_run(instrs, instr_count, class_base, input, input_len, 0, from, saves, 0);
    _pcre_last_step_count = _pcre_step_count;
    if (r >= 0) {
        var ks = 0;
        while (ks < PCRE_MAX_SAVES) {
            store64(nfa + PCRE_OFF_SAVES + ks * 8, load64(saves + ks * 8));
            ks = ks + 1;
        }
        store64(nfa + PCRE_OFF_MATCH_START, load64(saves));
        store64(nfa + PCRE_OFF_MATCH_END,   r);
    } else {
        store64(nfa + PCRE_OFF_MATCH_START, 0 - 1);
        store64(nfa + PCRE_OFF_MATCH_END,   0 - 1);
    }
    return r;
}

fn niyama_pcre_match(nfa, s): i64 {
    if (nfa == 0) { return 0; }
    var len = strlen(s);
    var r = _pcre_run_at(nfa, s, len, 0);
    if (r >= 0) { return 1; }
    return 0;
}

fn niyama_pcre_search(nfa, s): i64 {
    if (nfa == 0) { return 0 - 1; }
    var len = strlen(s);
    return niyama_pcre_search_at(nfa, s, len, 0);
}

fn niyama_pcre_search_at(nfa, s, len, from): i64 {
    if (nfa == 0) { return 0 - 1; }
    var i = from;
    while (i <= len) {
        var r = _pcre_run_at(nfa, s, len, i);
        if (r >= 0) { return i; }
        i = i + 1;
    }
    return 0 - 1;
}

fn niyama_pcre_group_start(nfa, n): i64 {
    if (nfa == 0)        { return 0 - 1; }
    if (n < 0 || n > 9)  { return 0 - 1; }
    return load64(nfa + PCRE_OFF_SAVES + n * 16);
}

fn niyama_pcre_group_end(nfa, n): i64 {
    if (nfa == 0)        { return 0 - 1; }
    if (n < 0 || n > 9)  { return 0 - 1; }
    return load64(nfa + PCRE_OFF_SAVES + n * 16 + 8);
}

# Look up a named-capture group index by name. Returns -1 if not found.
fn niyama_pcre_group_by_name(nfa, name): i64 {
    if (nfa == 0) { return 0 - 1; }
    var name_count = load64(nfa + PCRE_OFF_NAME_COUNT);
    var names_base = nfa + load64(nfa + PCRE_OFF_NAMES_OFF);
    var name_len = strlen(name);
    var i = 0;
    while (i < name_count) {
        var slot = names_base + i * PCRE_NAME_SLOT_SIZE;
        var slot_len = 0;
        while (slot_len < PCRE_NAME_MAX_LEN && load8(slot + slot_len) != 0) {
            slot_len = slot_len + 1;
        }
        if (slot_len == name_len) {
            var k = 0;
            var matched = 1;
            while (k < name_len) {
                if (load8(slot + k) != load8(name + k)) {
                    matched = 0;
                    k = name_len;
                }
                k = k + 1;
            }
            if (matched == 1) { return load64(slot + 32); }
        }
        i = i + 1;
    }
    return 0 - 1;
}

# --- fuzzy.cyr ---

# fuzzy.cyr — niyama Levenshtein edit-distance engine.
#
# The one engine in niyama that ISN'T regex — fuzzy matching for the
# pattern-matching neighborhood that owns shell completion, fuzzy file
# finders, typo-tolerant command lookup. Per ADR 0005.
#
# Algorithm: standard Levenshtein DP with two-row optimization
# (Wagner–Fischer). O(n × m) time, O(m+1) memory per row.
#
# Public API (mirrors niyama_bre / niyama_re2 / niyama_pcre per ADR 0002):
#   niyama_fuzzy_compile(pat)              -> handle (default opts)
#   niyama_fuzzy_compile_opts(pat,k,flags) -> handle (full opts)
#   niyama_fuzzy_match(h, s)               -> 1 if dist(pat,s) ≤ k
#   niyama_fuzzy_search(h, s)              -> start offset of best fuzzy
#                                             substring match, else -1
#   niyama_fuzzy_search_prefix(h, s)       -> 1 if some prefix of s
#                                             within k edits of pat
#   niyama_fuzzy_distance(h, s)            -> Levenshtein distance
#   niyama_fuzzy_last_distance()           -> distance from last call
#   niyama_fuzzy_last_error()              -> error code
#
# Match modes are explicit (three named functions, not one with a mode
# flag) per ADR 0005.
#
# Out of scope for M3.5 (per ADR 0005):
#   - Unicode NFD normalization — landed in v0.8.0 (ADR 0008) via stdlib
#     `lib/unicode/normalize.cyr` (no longer needs niyama-side ~25KB DB).
#     Opt in with FUZZY_FLAG_UNICODE_NFD.
#   - Exact start-position recovery in `_search` — landed v0.8.0
#     (ADR 0008) via reverse-DP pass; previously a heuristic.
#
# Precondition: alloc_init() must have been called.

# === Constants =======================================================

var FUZZY_MAX_PAT_LEN  = 256;
var FUZZY_MAX_TEXT_LEN = 4096;
var FUZZY_DEFAULT_K    = 2;

var FUZZY_FLAG_CASE_INSENSITIVE = 1;
# v0.8.0 — NFD-normalize pattern + input via stdlib str_normalize before
# the Levenshtein DP runs. Composed vs. decomposed forms (café NFC vs.
# NFD) become equivalence-classed at distance 0. ASCII-only inputs
# trivially round-trip; cost is paid only when the flag is set.
var FUZZY_FLAG_UNICODE_NFD      = 2;

# Handle layout:
#   +0   pat_len:   u64
#   +8   max_edits: i64
#   +16  flags:     u64
#   +24  pat:       FUZZY_MAX_PAT_LEN bytes (NUL-padded)
var FUZZY_OFF_PAT_LEN   = 0;
var FUZZY_OFF_MAX_EDITS = 8;
var FUZZY_OFF_FLAGS     = 16;
var FUZZY_OFF_PAT       = 24;
var FUZZY_HANDLE_SIZE   = 280;  # 24 + 256

# Error codes (frozen ABI from M3.5 onward).
var FUZZY_E_OK                 = 0;
var FUZZY_E_PATTERN_TOO_LONG   = 1;
var FUZZY_E_INVALID_THRESHOLD  = 2;
# v0.8.0 — NFD normalization may expand pattern bytes (max 3x for
# Hangul LVT). If the normalized pattern overflows FUZZY_MAX_PAT_LEN,
# reject at compile time rather than silently truncate.
var FUZZY_E_NFD_OVERFLOW       = 3;

# Process-lifetime scratch.
var _fuzzy_init = 0;
var _fuzzy_row_a = 0;
var _fuzzy_row_b = 0;
var _fuzzy_last_err = 0;
var _fuzzy_last_dist = 0;

fn _fuzzy_lazy_init(): i64 {
    if (_fuzzy_init == 1) { return 0; }
    _fuzzy_row_a = alloc((FUZZY_MAX_TEXT_LEN + 1) * 8);
    _fuzzy_row_b = alloc((FUZZY_MAX_TEXT_LEN + 1) * 8);
    _fuzzy_init = 1;
    return 0;
}

# === Helpers =========================================================

fn _fuzzy_min3(a, b, c): i64 {
    var m = a;
    if (b < m) { m = b; }
    if (c < m) { m = c; }
    return m;
}

fn _fuzzy_fold(c, casefold): i64 {
    if (casefold == 1 && c >= 65 && c <= 90) { return c + 32; }
    return c;
}

# === Compile entries =================================================

fn niyama_fuzzy_compile_opts(pat, max_edits, flags): i64 {
    _fuzzy_lazy_init();
    if (max_edits < 0) {
        _fuzzy_last_err = FUZZY_E_INVALID_THRESHOLD;
        return 0;
    }
    var n = strlen(pat);
    if (n > FUZZY_MAX_PAT_LEN) {
        _fuzzy_last_err = FUZZY_E_PATTERN_TOO_LONG;
        return 0;
    }
    # v0.8.0 — under FUZZY_FLAG_UNICODE_NFD, normalize pattern at compile
    # time so the matcher only pays the per-input normalize cost. Stored
    # form fits FUZZY_MAX_PAT_LEN or compile fails with NFD_OVERFLOW.
    var pat_buf = pat;
    var pat_len = n;
    if ((flags & FUZZY_FLAG_UNICODE_NFD) != 0) {
        var src_str = str_new(pat, n);
        var nfd_str = str_normalize(src_str, NFD);
        pat_buf = str_data(nfd_str);
        pat_len = str_len(nfd_str);
        if (pat_len > FUZZY_MAX_PAT_LEN) {
            _fuzzy_last_err = FUZZY_E_NFD_OVERFLOW;
            return 0;
        }
    }
    var h = alloc(FUZZY_HANDLE_SIZE);
    store64(h + FUZZY_OFF_PAT_LEN,   pat_len);
    store64(h + FUZZY_OFF_MAX_EDITS, max_edits);
    store64(h + FUZZY_OFF_FLAGS,     flags);
    var i = 0;
    while (i < pat_len) {
        store8(h + FUZZY_OFF_PAT + i, load8(pat_buf + i));
        i = i + 1;
    }
    while (i < FUZZY_MAX_PAT_LEN) {
        store8(h + FUZZY_OFF_PAT + i, 0);
        i = i + 1;
    }
    _fuzzy_last_err = FUZZY_E_OK;
    return h;
}

fn niyama_fuzzy_compile(pat): i64 {
    return niyama_fuzzy_compile_opts(pat, FUZZY_DEFAULT_K, 0);
}

fn niyama_fuzzy_last_error(): i64 {
    return _fuzzy_last_err;
}

fn niyama_fuzzy_last_distance(): i64 {
    return _fuzzy_last_dist;
}

# === Levenshtein DP variants =========================================

# Full-string Levenshtein distance between pat (length plen) and s
# (length slen). Returns the distance.
#
# Base case: prev[j] = j (empty pattern → j insertions to match s[0..j]).
fn _fuzzy_dp_full(pat, plen, s, slen, casefold): i64 {
    if (slen > FUZZY_MAX_TEXT_LEN) { slen = FUZZY_MAX_TEXT_LEN; }
    var prev = _fuzzy_row_a;
    var curr = _fuzzy_row_b;
    var j = 0;
    while (j <= slen) {
        store64(prev + j * 8, j);
        j = j + 1;
    }
    var i = 1;
    while (i <= plen) {
        store64(curr, i);  # curr[0] = i
        var pc = _fuzzy_fold(load8(pat + i - 1), casefold);
        var k = 1;
        while (k <= slen) {
            var sc = _fuzzy_fold(load8(s + k - 1), casefold);
            var sub_cost = 1;
            if (sc == pc) { sub_cost = 0; }
            var del_d = load64(prev + k * 8) + 1;
            var ins_d = load64(curr + (k - 1) * 8) + 1;
            var sub_d = load64(prev + (k - 1) * 8) + sub_cost;
            store64(curr + k * 8, _fuzzy_min3(del_d, ins_d, sub_d));
            k = k + 1;
        }
        var swap = prev;
        prev = curr;
        curr = swap;
        i = i + 1;
    }
    return load64(prev + slen * 8);
}

# Substring DP: minimum Levenshtein distance between pat and any
# contiguous substring of s. Returns the (best_distance, end_position)
# packed: best_distance is returned, and the end position is written
# to *out_end_pos via store64. Caller passes a pointer to an i64.
#
# Base case: prev[j] = 0 (empty pattern matches anywhere — no penalty
# for skipping leading text bytes).
fn _fuzzy_dp_substring(pat, plen, s, slen, casefold, out_end_pos): i64 {
    if (slen > FUZZY_MAX_TEXT_LEN) { slen = FUZZY_MAX_TEXT_LEN; }
    var prev = _fuzzy_row_a;
    var curr = _fuzzy_row_b;
    var j = 0;
    while (j <= slen) {
        store64(prev + j * 8, 0);
        j = j + 1;
    }
    var i = 1;
    while (i <= plen) {
        store64(curr, i);
        var pc = _fuzzy_fold(load8(pat + i - 1), casefold);
        var k = 1;
        while (k <= slen) {
            var sc = _fuzzy_fold(load8(s + k - 1), casefold);
            var sub_cost = 1;
            if (sc == pc) { sub_cost = 0; }
            var del_d = load64(prev + k * 8) + 1;
            var ins_d = load64(curr + (k - 1) * 8) + 1;
            var sub_d = load64(prev + (k - 1) * 8) + sub_cost;
            store64(curr + k * 8, _fuzzy_min3(del_d, ins_d, sub_d));
            k = k + 1;
        }
        var swap = prev;
        prev = curr;
        curr = swap;
        i = i + 1;
    }
    # Find min over prev[0..slen+1] — best ending position.
    var best = load64(prev);
    var best_j = 0;
    var jj = 1;
    while (jj <= slen) {
        var v = load64(prev + jj * 8);
        if (v < best) {
            best = v;
            best_j = jj;
        }
        jj = jj + 1;
    }
    store64(out_end_pos, best_j);
    return best;
}

# v0.8.0 — exact start-position recovery for substring search.
# After the forward substring DP found the best end_pos with distance D,
# this reverse pass finds the actual start_pos. Runs substring DP with
# pat read backwards (pat[plen-1-i]) and input read backwards
# (input[end_pos-1-k]). The "best end" in the reversed problem equals
# end_pos - start_pos in the original. Same O(plen × end_pos)
# complexity as the forward pass; reuses the row scratch buffers.
fn _fuzzy_recover_start(pat, plen, s, end_pos, casefold): i64 {
    if (end_pos > FUZZY_MAX_TEXT_LEN) { end_pos = FUZZY_MAX_TEXT_LEN; }
    var prev = _fuzzy_row_a;
    var curr = _fuzzy_row_b;
    var j = 0;
    while (j <= end_pos) {
        store64(prev + j * 8, 0);
        j = j + 1;
    }
    var i = 1;
    while (i <= plen) {
        store64(curr, i);
        # Read pat backwards: 1-indexed i ↔ pat[plen - i].
        var pc = _fuzzy_fold(load8(pat + (plen - i)), casefold);
        var k = 1;
        while (k <= end_pos) {
            # Read input backwards: 1-indexed k ↔ s[end_pos - k].
            var sc = _fuzzy_fold(load8(s + (end_pos - k)), casefold);
            var sub_cost = 1;
            if (sc == pc) { sub_cost = 0; }
            var del_d = load64(prev + k * 8) + 1;
            var ins_d = load64(curr + (k - 1) * 8) + 1;
            var sub_d = load64(prev + (k - 1) * 8) + sub_cost;
            store64(curr + k * 8, _fuzzy_min3(del_d, ins_d, sub_d));
            k = k + 1;
        }
        var swap = prev;
        prev = curr;
        curr = swap;
        i = i + 1;
    }
    var best = load64(prev);
    var best_j = 0;
    var jj = 1;
    while (jj <= end_pos) {
        var v = load64(prev + jj * 8);
        if (v < best) {
            best = v;
            best_j = jj;
        }
        jj = jj + 1;
    }
    return end_pos - best_j;
}

# Prefix DP: minimum Levenshtein distance between pat and any prefix
# of s. Same DP as full, but final answer is min over the last row.
fn _fuzzy_dp_prefix(pat, plen, s, slen, casefold): i64 {
    if (slen > FUZZY_MAX_TEXT_LEN) { slen = FUZZY_MAX_TEXT_LEN; }
    var prev = _fuzzy_row_a;
    var curr = _fuzzy_row_b;
    var j = 0;
    while (j <= slen) {
        store64(prev + j * 8, j);
        j = j + 1;
    }
    var i = 1;
    while (i <= plen) {
        store64(curr, i);
        var pc = _fuzzy_fold(load8(pat + i - 1), casefold);
        var k = 1;
        while (k <= slen) {
            var sc = _fuzzy_fold(load8(s + k - 1), casefold);
            var sub_cost = 1;
            if (sc == pc) { sub_cost = 0; }
            var del_d = load64(prev + k * 8) + 1;
            var ins_d = load64(curr + (k - 1) * 8) + 1;
            var sub_d = load64(prev + (k - 1) * 8) + sub_cost;
            store64(curr + k * 8, _fuzzy_min3(del_d, ins_d, sub_d));
            k = k + 1;
        }
        var swap = prev;
        prev = curr;
        curr = swap;
        i = i + 1;
    }
    var best = load64(prev);
    var jj = 1;
    while (jj <= slen) {
        var v = load64(prev + jj * 8);
        if (v < best) { best = v; }
        jj = jj + 1;
    }
    return best;
}

# === Public matchers =================================================

# v0.8.0 — if NFD flag is set on the handle, normalize the input string
# in place via stdlib str_normalize before the DP runs. Returns input
# pointer + length packed in globals to keep the call sites simple.
var _fuzzy_norm_buf = 0;
var _fuzzy_norm_len = 0;

fn _fuzzy_maybe_normalize(s, slen, flags): i64 {
    if ((flags & FUZZY_FLAG_UNICODE_NFD) == 0) {
        _fuzzy_norm_buf = s;
        _fuzzy_norm_len = slen;
        return 0;
    }
    var nfd = str_normalize(str_new(s, slen), NFD);
    _fuzzy_norm_buf = str_data(nfd);
    _fuzzy_norm_len = str_len(nfd);
    return 0;
}

fn niyama_fuzzy_distance(h, s): i64 {
    if (h == 0) { return 0 - 1; }
    var plen = load64(h + FUZZY_OFF_PAT_LEN);
    var flags = load64(h + FUZZY_OFF_FLAGS);
    var casefold = 0;
    if ((flags & FUZZY_FLAG_CASE_INSENSITIVE) != 0) { casefold = 1; }
    var slen = strlen(s);
    _fuzzy_maybe_normalize(s, slen, flags);
    var d = _fuzzy_dp_full(h + FUZZY_OFF_PAT, plen, _fuzzy_norm_buf, _fuzzy_norm_len, casefold);
    _fuzzy_last_dist = d;
    return d;
}

fn niyama_fuzzy_match(h, s): i64 {
    if (h == 0) { return 0; }
    var max_edits = load64(h + FUZZY_OFF_MAX_EDITS);
    var d = niyama_fuzzy_distance(h, s);
    if (d <= max_edits) { return 1; }
    return 0;
}

# Substring fuzzy: does some contiguous slice of s have edit distance
# ≤ max_edits to pat? Returns approximate start offset on hit, or -1.
# Start is computed as `end - plen` clamped to [0, slen) — exact start
# recovery is deferred per ADR 0005.
fn niyama_fuzzy_search(h, s): i64 {
    if (h == 0) { return 0 - 1; }
    var plen = load64(h + FUZZY_OFF_PAT_LEN);
    var max_edits = load64(h + FUZZY_OFF_MAX_EDITS);
    var flags = load64(h + FUZZY_OFF_FLAGS);
    var casefold = 0;
    if ((flags & FUZZY_FLAG_CASE_INSENSITIVE) != 0) { casefold = 1; }
    var slen = strlen(s);
    _fuzzy_maybe_normalize(s, slen, flags);
    var nbuf = _fuzzy_norm_buf;
    var nlen = _fuzzy_norm_len;
    # Allocate a stack slot for the end-pos out param.
    var end_pos_buf = alloc(8);
    var d = _fuzzy_dp_substring(h + FUZZY_OFF_PAT, plen, nbuf, nlen, casefold, end_pos_buf);
    _fuzzy_last_dist = d;
    if (d > max_edits) { return 0 - 1; }
    var end_pos = load64(end_pos_buf);
    # v0.8.0 — exact start via reverse-DP (was: heuristic end_pos - plen).
    var start = _fuzzy_recover_start(h + FUZZY_OFF_PAT, plen, nbuf, end_pos, casefold);
    if (start < 0) { start = 0; }
    if (start > nlen) { start = nlen; }
    return start;
}

# Prefix fuzzy: is some prefix of s within max_edits of pat? Returns 1
# or 0. Useful for shell completion (typed input is a typo-tolerant
# prefix of the candidate).
fn niyama_fuzzy_search_prefix(h, s): i64 {
    if (h == 0) { return 0; }
    var plen = load64(h + FUZZY_OFF_PAT_LEN);
    var max_edits = load64(h + FUZZY_OFF_MAX_EDITS);
    var flags = load64(h + FUZZY_OFF_FLAGS);
    var casefold = 0;
    if ((flags & FUZZY_FLAG_CASE_INSENSITIVE) != 0) { casefold = 1; }
    var slen = strlen(s);
    _fuzzy_maybe_normalize(s, slen, flags);
    var d = _fuzzy_dp_prefix(h + FUZZY_OFF_PAT, plen, _fuzzy_norm_buf, _fuzzy_norm_len, casefold);
    _fuzzy_last_dist = d;
    if (d <= max_edits) { return 1; }
    return 0;
}

# --- vim.cyr ---

# vim.cyr — niyama vim/cyim flavor engine.
#
# Pike NFA matcher with vim-flavor parser, exposed via the niyama_vim_*
# ABI defined in docs/adr/0006-vim-engine-abi-and-scope.md.
#
# Architecture: forked from src/re2.cyr (Pike NFA kernel) with a
# vim-flavor parser. Same instruction model, same matcher kernel; the
# parser handles four magicness modes and vim-specific metachars.
#
# Public API (mirrors niyama_re2_* per ADR 0002):
#   niyama_vim_compile(pat)              -> handle (default mode = MAGIC)
#   niyama_vim_compile_opts(pat, mode)   -> handle (specific mode)
#   niyama_vim_match(nfa, s)             -> 1 if anchored match, else 0
#   niyama_vim_search(nfa, s)            -> first match offset, or -1
#   niyama_vim_search_at(nfa, s, len, from) -> match starting at `from`
#   niyama_vim_group_start(nfa, n)       -> group n start or -1
#   niyama_vim_group_end(nfa, n)         -> group n end or -1
#   niyama_vim_last_error()              -> error code from most recent compile
#
# vim features in M4 (per ADR 0006):
#   - All four magicness modes (very-magic, magic, nomagic, very-nomagic)
#   - vim metachars: . * \+ \? \= \{n,m\} \| \(\) [...]
#   - \< \> word boundaries
#   - \zs \ze match-position markers
#   - POSIX bracket classes [[:alpha:]] etc. inside char classes
#   - \d \D \w \W \s \S predefined classes
#   - \1-\9 backreferences REJECTED at compile (default; v0.9.0 revisit)
#
# Out of scope for M4 (per ADR 0006):
#   - Mid-pattern mode switching (\v \m \M \V mid-pattern) — opts-flag only
#   - vim's vast \X escape menagerie (\a \A \l \L \u \U \x \X \o \O \h \H ...)
#   - Replacement-language helpers (~, &, \u/\l etc.)
#
# Precondition: alloc_init() must have been called.

# === Opcodes (mirrors bre/re2) =======================================

var VIM_OP_MATCH      = 0;
var VIM_OP_CHAR       = 1;
var VIM_OP_ANY        = 2;
var VIM_OP_CLASS      = 3;
var VIM_OP_NCLASS     = 4;
var VIM_OP_JMP        = 5;
var VIM_OP_SPLIT      = 6;
var VIM_OP_SAVE       = 7;
var VIM_OP_BOL        = 8;
var VIM_OP_EOL        = 9;
var VIM_OP_BOUNDARY   = 10;
var VIM_OP_NBOUNDARY  = 11;
# v0.8.0 — Unicode property class \p{L} / \P{L} via stdlib lib/unicode.
# 30-bit GeneralCategory mask packed into upper 32 bits of word0.
var VIM_OP_UPROP      = 12;     # \p{NAME} — cp_category(cp) ∈ mask
var VIM_OP_NUPROP     = 13;     # \P{NAME} — cp_category(cp) ∉ mask
# v0.8.0 — multi-byte literal char in pattern (codepoint stored in
# upper 32 bits of word0). See re2.cyr's UCHAR comment for rationale.
var VIM_OP_UCHAR      = 14;     # codepoint literal — match cp == stored

var VIM_NFA_HEADER_SIZE = 216;
var VIM_OFF_INSTR_COUNT = 0;
var VIM_OFF_INSTRS_OFF  = 8;
var VIM_OFF_CLASS_COUNT = 16;
var VIM_OFF_CLASSES_OFF = 24;
var VIM_OFF_CAPTURES    = 32;
var VIM_OFF_MATCH_START = 40;
var VIM_OFF_MATCH_END   = 48;
var VIM_OFF_SAVES       = 56;

var VIM_MAX_INSTRS  = 4096;
var VIM_MAX_CLASSES = 64;
var VIM_MAX_SAVES   = 20;

# === Magicness modes (frozen ABI from M4 onward) =====================

var VIM_MODE_VERY_MAGIC   = 0;
var VIM_MODE_MAGIC        = 1;
var VIM_MODE_NOMAGIC      = 2;
var VIM_MODE_VERY_NOMAGIC = 3;

# === Error codes (frozen ABI from M4 onward) =========================

var VIM_E_OK                   = 0;
var VIM_E_SYNTAX               = 1;
var VIM_E_BACKREF_UNSUPPORTED  = 2;
var VIM_E_INVALID_MODE         = 3;
var VIM_E_TOO_LARGE            = 4;
var VIM_E_BAD_PROPERTY         = 5;  # v0.8.0: \p{Xy} unrecognized name

# === Compile-time globals ============================================

var _vim_pat = 0;
var _vim_pat_len = 0;
var _vim_pos = 0;
var _vim_mode = 1;        # default = MAGIC
var _vim_nfa = 0;
var _vim_instr_base = 0;
var _vim_class_base = 0;
var _vim_instr_n = 0;
var _vim_class_n = 0;
var _vim_capture_n = 0;
var _vim_err = 0;
var _vim_last_err = 0;
var _vim_saw_ze = 0;      # if 1, suppress implicit final SAVE 1

# Process-lifetime scratch (lazy-init).
var _vim_m_init = 0;
var _vim_m_cur = 0;
var _vim_m_next = 0;
var _vim_m_lastgen = 0;
var _vim_m_gen = 0;
var _vim_q_splits = 0;
# v0.8.0 — UTF-8 codepoint scratch slot for UPROP / NUPROP.
var _vim_m_cp_slot = 0;

fn _vim_lazy_init(): i64 {
    if (_vim_m_init == 1) { return 0; }
    _vim_m_cur     = alloc(8 + VIM_MAX_INSTRS * 168);
    _vim_m_next    = alloc(8 + VIM_MAX_INSTRS * 168);
    _vim_m_lastgen = alloc(VIM_MAX_INSTRS * 8);
    _vim_q_splits  = alloc(64 * 8);
    _vim_m_cp_slot = alloc(8);
    var i = 0;
    while (i < VIM_MAX_INSTRS) {
        store64(_vim_m_lastgen + i * 8, 0);
        i = i + 1;
    }
    _vim_m_init = 1;
    _vim_m_gen = 1;
    return 0;
}

# === Instruction emit / patch helpers (mirrors re2) ==================

fn _vim_w0(op, small, arg1): i64 {
    return op | (small << 8) | (arg1 << 32);
}

fn _vim_emit_raw(w0, w1): i64 {
    var i = _vim_instr_n;
    if (i >= VIM_MAX_INSTRS) { _vim_err = VIM_E_TOO_LARGE; return i; }
    store64(_vim_instr_base + i * 16, w0);
    store64(_vim_instr_base + i * 16 + 8, w1);
    _vim_instr_n = i + 1;
    return i;
}

fn _vim_emit_op(op): i64 { return _vim_emit_raw(op, 0); }
fn _vim_emit_char(c): i64 { return _vim_emit_raw(VIM_OP_CHAR | (c << 8), 0); }
fn _vim_emit_class(neg, ci): i64 {
    var op = VIM_OP_CLASS;
    if (neg == 1) { op = VIM_OP_NCLASS; }
    return _vim_emit_raw(op | (ci << 8), 0);
}
fn _vim_emit_save(idx): i64 { return _vim_emit_raw(VIM_OP_SAVE | (idx << 8), 0); }
fn _vim_emit_jmp(target): i64 { return _vim_emit_raw(VIM_OP_JMP | (target << 32), 0); }
fn _vim_emit_split(a, b): i64 { return _vim_emit_raw(VIM_OP_SPLIT | (a << 32), b); }
fn _vim_emit_uprop(neg, mask): i64 {
    var op = VIM_OP_UPROP;
    if (neg == 1) { op = VIM_OP_NUPROP; }
    return _vim_emit_raw(op | (mask << 32), 0);
}
fn _vim_emit_uchar(cp): i64 {
    return _vim_emit_raw(VIM_OP_UCHAR | (cp << 32), 0);
}

fn _vim_patch_arg1(idx, arg1): i64 {
    var off = _vim_instr_base + idx * 16;
    var w0 = load64(off);
    store64(off, (w0 & 0xFFFFFFFF) | (arg1 << 32));
    return 0;
}

fn _vim_patch_arg2(idx, arg2): i64 {
    store64(_vim_instr_base + idx * 16 + 8, arg2);
    return 0;
}

fn _vim_shift_right(lo, hi): i64 {
    var k = (hi - lo) * 16 - 1;
    while (k >= 0) {
        var src = _vim_instr_base + lo * 16 + k;
        store8(src + 16, load8(src));
        k = k - 1;
    }
    return 0;
}

fn _vim_shift_targets_one(lo, hi): i64 {
    var i = lo + 1;
    var end = hi + 1;
    while (i < end) {
        var off = _vim_instr_base + i * 16;
        var w0 = load64(off);
        var op = w0 & 0xFF;
        var is_branch = 0;
        if (op == VIM_OP_JMP)   { is_branch = 1; }
        if (op == VIM_OP_SPLIT) { is_branch = 1; }
        if (is_branch == 1) {
            var arg1 = (w0 >> 32) & 0xFFFFFFFF;
            if (arg1 >= lo && arg1 <= hi) {
                _vim_patch_arg1(i, arg1 + 1);
            }
            if (op == VIM_OP_SPLIT) {
                var arg2 = load64(off + 8);
                if (arg2 >= lo && arg2 <= hi) {
                    _vim_patch_arg2(i, arg2 + 1);
                }
            }
        }
        i = i + 1;
    }
    return 0;
}

# === Class bitmap helpers ============================================

fn _vim_alloc_class(): i64 {
    var ci = _vim_class_n;
    if (ci >= VIM_MAX_CLASSES) { _vim_err = VIM_E_TOO_LARGE; return ci; }
    var z = 0;
    while (z < 32) {
        store8(_vim_class_base + ci * 32 + z, 0);
        z = z + 1;
    }
    _vim_class_n = ci + 1;
    return ci;
}

fn _vim_class_set(ci, c): i64 {
    if (c < 0)   { return 0; }
    if (c > 255) { return 0; }
    var off = _vim_class_base + ci * 32 + (c >> 3);
    store8(off, load8(off) | (1 << (c & 7)));
    return 0;
}

fn _vim_class_range(ci, lo, hi): i64 {
    var c = lo;
    while (c <= hi) {
        _vim_class_set(ci, c);
        c = c + 1;
    }
    return 0;
}

fn _vim_class_invert(ci): i64 {
    var z = 0;
    while (z < 32) {
        var off = _vim_class_base + ci * 32 + z;
        store8(off, 255 ^ load8(off));
        z = z + 1;
    }
    return 0;
}

fn _vim_class_fill_digit(ci): i64 { _vim_class_range(ci, 48, 57); return 0; }

fn _vim_class_fill_word(ci): i64 {
    _vim_class_range(ci, 48, 57);
    _vim_class_range(ci, 65, 90);
    _vim_class_range(ci, 97, 122);
    _vim_class_set(ci, 95);
    return 0;
}

fn _vim_class_fill_space(ci): i64 {
    _vim_class_set(ci, 32);
    _vim_class_set(ci, 9);
    _vim_class_set(ci, 10);
    _vim_class_set(ci, 11);
    _vim_class_set(ci, 12);
    _vim_class_set(ci, 13);
    return 0;
}

# === POSIX bracket classes — delegate to src/posix_classes.cyr (v0.8.0) ==
#
# Pre-v0.8.0 vim carried duplicate alpha/alnum/upper/lower/blank/cntrl/
# print/graph/punct/xdigit fillers and a 12-name keyword recognizer
# parallel to posix_classes.cyr (deliberate duplication to keep the
# v0.7.0 catch-up risk-bounded — see ADR 0007). v0.8.0 folds them onto
# the shared module per ADR 0008's M5-prep cleanup. _vim_class_fill_*
# survive only for vim-specific classes (\d, \w, \s).

# Match a POSIX class header `[:name:]` starting at _vim_pos (which is
# past the leading "[:"). Delegates to _posix_match_class_name. On
# success advances _vim_pos past ":]" and returns the category id
# (1..12 — same numbering as posix_classes.cyr). On mismatch, returns
# 0 and leaves _vim_pos unchanged.
fn _vim_match_posix_class(): i64 {
    var save_pos = _vim_pos;
    var category = _posix_match_class_name(_vim_pat, _vim_pos, _vim_pat_len);
    if (category == 0) {
        _vim_pos = save_pos;
        return 0;
    }
    _vim_pos = _posix_match_end_pos;
    return category;
}

fn _vim_class_apply_posix(ci, category): i64 {
    return _posix_apply_filler(_vim_class_base, ci, category);
}

# === Mode dispatch helpers ===========================================
#
# The four magicness modes change which characters are special. Helpers
# answer "what does this byte mean here?" for the current _vim_mode.

# Is `c` a quantifier (after an atom) in the current mode WITHOUT
# backslash? Magic and lower modes require `\+` etc., so only `*` is
# bare in m / M (and `*` is literal in M).
# In V (very-nomagic), `*` is also literal.
# Returns: 0 (not), 1 (`*` zero-or-more)
fn _vim_quant_bare(c): i64 {
    if (_vim_mode == VIM_MODE_VERY_MAGIC) {
        if (c == 42 || c == 43 || c == 63 || c == 61) { return 1; }
    }
    elif (_vim_mode == VIM_MODE_MAGIC) {
        if (c == 42) { return 1; }
    }
    return 0;
}

# Map a bare quantifier byte to its op-char for _vim_apply_simple_q
# (* = 42, + = 43, ? = 63; we map = → 63 since vim's \= is a synonym
# for \?).
fn _vim_quant_op(c): i64 {
    if (c == 61) { return 63; }
    return c;
}

# Is `c` a backslash-quantifier (after `\`) in this mode?
# `\+`, `\?`, `\=` are quantifiers in m, M, V (always available).
# `\*` is the quantifier in nomagic / very-nomagic (where bare `*` is
# literal); in magic / very-magic, `\*` is a literal `*`.
fn _vim_quant_after_bs(c): i64 {
    if (c == 43 || c == 63 || c == 61) { return 1; }
    if (c == 42 && (_vim_mode == VIM_MODE_NOMAGIC || _vim_mode == VIM_MODE_VERY_NOMAGIC)) {
        return 1;
    }
    return 0;
}

# Is `c` a bare alternation? `|` in v; needs `\|` in m, M, V.
fn _vim_alt_bare(c): i64 {
    if (c == 124 && _vim_mode == VIM_MODE_VERY_MAGIC) { return 1; }
    return 0;
}

# Is `c` a backslash-alternation? `\|` in m, M, V.
fn _vim_alt_after_bs(c): i64 {
    if (c == 124 && _vim_mode != VIM_MODE_VERY_MAGIC) { return 1; }
    return 0;
}

# Is `c` a bare open-paren? `(` in v; literal in m, M, V (which use `\(`).
fn _vim_open_paren_bare(c): i64 {
    if (c == 40 && _vim_mode == VIM_MODE_VERY_MAGIC) { return 1; }
    return 0;
}

fn _vim_open_paren_after_bs(c): i64 {
    if (c == 40 && _vim_mode != VIM_MODE_VERY_MAGIC) { return 1; }
    return 0;
}

fn _vim_close_paren_bare(c): i64 {
    if (c == 41 && _vim_mode == VIM_MODE_VERY_MAGIC) { return 1; }
    return 0;
}

fn _vim_close_paren_after_bs(c): i64 {
    if (c == 41 && _vim_mode != VIM_MODE_VERY_MAGIC) { return 1; }
    return 0;
}

# Is `c` a bare brace-quantifier opener? `{` in v; needs `\{` elsewhere.
fn _vim_brace_open_bare(c): i64 {
    if (c == 123 && _vim_mode == VIM_MODE_VERY_MAGIC) { return 1; }
    return 0;
}

fn _vim_brace_open_after_bs(c): i64 {
    if (c == 123 && _vim_mode != VIM_MODE_VERY_MAGIC) { return 1; }
    return 0;
}

# `.` is special in v, m; literal in M, V.
fn _vim_dot_bare(c): i64 {
    if (c != 46) { return 0; }
    if (_vim_mode == VIM_MODE_VERY_MAGIC) { return 1; }
    if (_vim_mode == VIM_MODE_MAGIC)      { return 1; }
    return 0;
}

# `[` is special in v, m; literal in M, V.
fn _vim_bracket_open_bare(c): i64 {
    if (c != 91) { return 0; }
    if (_vim_mode == VIM_MODE_VERY_MAGIC) { return 1; }
    if (_vim_mode == VIM_MODE_MAGIC)      { return 1; }
    return 0;
}

# `^` is BOL (at pattern-start) in v, m, M; literal in V (needs `\^`).
fn _vim_anchor_bol_bare(c, at_start): i64 {
    if (c != 94) { return 0; }
    if (_vim_mode == VIM_MODE_VERY_NOMAGIC) { return 0; }
    if (_vim_mode == VIM_MODE_VERY_MAGIC) { return 1; }
    # m, M: only special at pattern start
    if (at_start == 1) { return 1; }
    return 0;
}

# `$` is EOL (at pattern-end) in v, m, M; literal in V.
fn _vim_anchor_eol_bare(c, at_end): i64 {
    if (c != 36) { return 0; }
    if (_vim_mode == VIM_MODE_VERY_NOMAGIC) { return 0; }
    if (_vim_mode == VIM_MODE_VERY_MAGIC) { return 1; }
    if (at_end == 1) { return 1; }
    return 0;
}

# === Pattern decoder =================================================

fn _vim_lit_byte(): i64 {
    if (_vim_pos >= _vim_pat_len) { _vim_err = VIM_E_SYNTAX; return 0; }
    var c = load8(_vim_pat + _vim_pos);
    _vim_pos = _vim_pos + 1;
    if (c != 92) { return c; }
    if (_vim_pos >= _vim_pat_len) { _vim_err = VIM_E_SYNTAX; return 0; }
    var e = load8(_vim_pat + _vim_pos);
    _vim_pos = _vim_pos + 1;
    if (e == 110) { return 10; }
    if (e == 114) { return 13; }
    if (e == 116) { return 9; }
    if (e == 48)  { return 0; }
    if (e == 97)  { return 7; }
    if (e == 102) { return 12; }
    if (e == 118) { return 11; }
    return e;
}

# Parse `[...]` body (caller consumed `[`). Returns class index;
# negation as -(ci+1).
fn _vim_parse_class(): i64 {
    var ci = _vim_alloc_class();
    if (_vim_err != VIM_E_OK) { return ci; }
    var neg = 0;
    if (_vim_pos < _vim_pat_len && load8(_vim_pat + _vim_pos) == 94) {
        neg = 1;
        _vim_pos = _vim_pos + 1;
    }
    var first = 1;
    var done = 0;
    while (done == 0) {
        if (_vim_pos >= _vim_pat_len) { _vim_err = VIM_E_SYNTAX; return 0 - 1; }
        var pc = load8(_vim_pat + _vim_pos);
        if (pc == 93 && first == 0) {
            _vim_pos = _vim_pos + 1;
            done = 1;
        }
        # POSIX bracket class: [: ... :]
        elif (pc == 91 && _vim_pos + 1 < _vim_pat_len && load8(_vim_pat + _vim_pos + 1) == 58) {
            _vim_pos = _vim_pos + 2;  # consume "[:"
            var category = _vim_match_posix_class();
            if (category == 0) {
                _vim_err = VIM_E_SYNTAX;
                return 0 - 1;
            }
            _vim_class_apply_posix(ci, category);
            first = 0;
        }
        elif (pc == 92 && _vim_pos + 1 < _vim_pat_len) {
            var nx = load8(_vim_pat + _vim_pos + 1);
            if (nx == 100)      { _vim_class_fill_digit(ci); _vim_pos = _vim_pos + 2; }
            elif (nx == 119)    { _vim_class_fill_word(ci);  _vim_pos = _vim_pos + 2; }
            elif (nx == 115)    { _vim_class_fill_space(ci); _vim_pos = _vim_pos + 2; }
            elif (nx == 68) {
                var tmp = _vim_alloc_class();
                if (_vim_err != VIM_E_OK) { return 0 - 1; }
                _vim_class_fill_digit(tmp);
                _vim_class_invert(tmp);
                var z = 0;
                while (z < 32) {
                    var d = _vim_class_base + ci * 32 + z;
                    var s = _vim_class_base + tmp * 32 + z;
                    store8(d, load8(d) | load8(s));
                    z = z + 1;
                }
                _vim_class_n = _vim_class_n - 1;
                _vim_pos = _vim_pos + 2;
            }
            elif (nx == 87) {
                var tmp2 = _vim_alloc_class();
                if (_vim_err != VIM_E_OK) { return 0 - 1; }
                _vim_class_fill_word(tmp2);
                _vim_class_invert(tmp2);
                var z2 = 0;
                while (z2 < 32) {
                    var d2 = _vim_class_base + ci * 32 + z2;
                    var s2 = _vim_class_base + tmp2 * 32 + z2;
                    store8(d2, load8(d2) | load8(s2));
                    z2 = z2 + 1;
                }
                _vim_class_n = _vim_class_n - 1;
                _vim_pos = _vim_pos + 2;
            }
            elif (nx == 83) {
                var tmp3 = _vim_alloc_class();
                if (_vim_err != VIM_E_OK) { return 0 - 1; }
                _vim_class_fill_space(tmp3);
                _vim_class_invert(tmp3);
                var z3 = 0;
                while (z3 < 32) {
                    var d3 = _vim_class_base + ci * 32 + z3;
                    var s3 = _vim_class_base + tmp3 * 32 + z3;
                    store8(d3, load8(d3) | load8(s3));
                    z3 = z3 + 1;
                }
                _vim_class_n = _vim_class_n - 1;
                _vim_pos = _vim_pos + 2;
            }
            else {
                var lc = _vim_lit_byte();
                if (_vim_err != VIM_E_OK) { return 0 - 1; }
                if (_vim_pos + 1 < _vim_pat_len && load8(_vim_pat + _vim_pos) == 45 && load8(_vim_pat + _vim_pos + 1) != 93) {
                    _vim_pos = _vim_pos + 1;
                    var hi = _vim_lit_byte();
                    if (_vim_err != VIM_E_OK) { return 0 - 1; }
                    _vim_class_range(ci, lc, hi);
                } else {
                    _vim_class_set(ci, lc);
                }
            }
            first = 0;
        }
        else {
            var lc2 = _vim_lit_byte();
            if (_vim_err != VIM_E_OK) { return 0 - 1; }
            if (_vim_pos + 1 < _vim_pat_len && load8(_vim_pat + _vim_pos) == 45 && load8(_vim_pat + _vim_pos + 1) != 93) {
                _vim_pos = _vim_pos + 1;
                var hi2 = _vim_lit_byte();
                if (_vim_err != VIM_E_OK) { return 0 - 1; }
                _vim_class_range(ci, lc2, hi2);
            } else {
                _vim_class_set(ci, lc2);
            }
            first = 0;
        }
    }
    if (neg == 1) { return 0 - (ci + 1); }
    return ci;
}

# === Recursive-descent vim compiler ==================================

fn _vim_parse_primary(at_start): i64 {
    if (_vim_pos >= _vim_pat_len) { _vim_err = VIM_E_SYNTAX; return 0; }
    var c = load8(_vim_pat + _vim_pos);

    # Bare `^` BOL anchor?
    if (_vim_anchor_bol_bare(c, at_start) == 1) {
        _vim_pos = _vim_pos + 1;
        _vim_emit_op(VIM_OP_BOL);
        return 0;
    }

    # Bare `$` EOL anchor? Need to check if at end of pattern.
    if (c == 36) {
        var at_end = 0;
        if (_vim_pos + 1 == _vim_pat_len) { at_end = 1; }
        # also at end of group: next char would be `\)` or `)` — but we
        # treat any `$` not followed by more pattern in the current
        # concat as anchor. Simpler: just check at_end-of-pattern.
        if (_vim_anchor_eol_bare(c, at_end) == 1) {
            _vim_pos = _vim_pos + 1;
            _vim_emit_op(VIM_OP_EOL);
            return 0;
        }
    }

    # Bare `.` any-byte?
    if (_vim_dot_bare(c) == 1) {
        _vim_pos = _vim_pos + 1;
        _vim_emit_op(VIM_OP_ANY);
        return 0;
    }

    # Bare `[` bracket class?
    if (_vim_bracket_open_bare(c) == 1) {
        _vim_pos = _vim_pos + 1;
        var ci = _vim_parse_class();
        if (_vim_err != VIM_E_OK) { return 0; }
        var neg = 0;
        if (ci < 0) { neg = 1; ci = 0 - (ci + 1); }
        _vim_emit_class(neg, ci);
        return 0;
    }

    # Bare `(` open-group (very-magic only)?
    if (_vim_open_paren_bare(c) == 1) {
        _vim_pos = _vim_pos + 1;
        _vim_capture_n = _vim_capture_n + 1;
        var capture_idx = _vim_capture_n;
        if (capture_idx > 9) { _vim_err = VIM_E_SYNTAX; return 0; }
        _vim_emit_save(capture_idx * 2);
        _vim_parse_alt();
        if (_vim_err != VIM_E_OK) { return 0; }
        if (_vim_pos >= _vim_pat_len || load8(_vim_pat + _vim_pos) != 41) { _vim_err = VIM_E_SYNTAX; return 0; }
        _vim_pos = _vim_pos + 1;
        _vim_emit_save(capture_idx * 2 + 1);
        return 0;
    }

    # Backslash forms.
    if (c == 92) {
        if (_vim_pos + 1 >= _vim_pat_len) { _vim_err = VIM_E_SYNTAX; return 0; }
        var e = load8(_vim_pat + _vim_pos + 1);

        # \1-\9 — REJECTED per ADR 0006 (M4 default; v0.9.0 revisit).
        if (e >= 49 && e <= 57) {
            _vim_err = VIM_E_BACKREF_UNSUPPORTED;
            return 0;
        }

        # \( open-group (in m, M, V).
        if (_vim_open_paren_after_bs(e) == 1) {
            _vim_pos = _vim_pos + 2;
            _vim_capture_n = _vim_capture_n + 1;
            var capture_idx2 = _vim_capture_n;
            if (capture_idx2 > 9) { _vim_err = VIM_E_SYNTAX; return 0; }
            _vim_emit_save(capture_idx2 * 2);
            _vim_parse_alt();
            if (_vim_err != VIM_E_OK) { return 0; }
            # Expect `\)`.
            if (_vim_pos + 1 >= _vim_pat_len) { _vim_err = VIM_E_SYNTAX; return 0; }
            if (load8(_vim_pat + _vim_pos) != 92 || load8(_vim_pat + _vim_pos + 1) != 41) {
                _vim_err = VIM_E_SYNTAX; return 0;
            }
            _vim_pos = _vim_pos + 2;
            _vim_emit_save(capture_idx2 * 2 + 1);
            return 0;
        }

        # \) outside group is syntax error (handled by alt-parser stop).
        if (_vim_close_paren_after_bs(e) == 1) {
            _vim_err = VIM_E_SYNTAX; return 0;
        }

        # \< start-of-word boundary (BOUNDARY at word-start position is
        # close enough to vim's semantics; vim's \< is essentially \b).
        if (e == 60) {
            _vim_pos = _vim_pos + 2;
            _vim_emit_op(VIM_OP_BOUNDARY);
            return 0;
        }

        # \> end-of-word boundary.
        if (e == 62) {
            _vim_pos = _vim_pos + 2;
            _vim_emit_op(VIM_OP_BOUNDARY);
            return 0;
        }

        # \zs — match-start marker. Emit SAVE 0 (overrides implicit start).
        if (e == 122 && _vim_pos + 2 < _vim_pat_len && load8(_vim_pat + _vim_pos + 2) == 115) {
            _vim_pos = _vim_pos + 3;
            _vim_emit_save(0);
            return 0;
        }

        # \ze — match-end marker. Emit SAVE 1; suppress implicit final SAVE 1.
        if (e == 122 && _vim_pos + 2 < _vim_pat_len && load8(_vim_pat + _vim_pos + 2) == 101) {
            _vim_pos = _vim_pos + 3;
            _vim_emit_save(1);
            _vim_saw_ze = 1;
            return 0;
        }

        # \p{NAME} / \P{NAME} — Unicode property class (v0.8.0, ADR 0008).
        if (e == 112 || e == 80) {
            var neg_p = 0;
            if (e == 80) { neg_p = 1; }
            var u_mask = _uprops_parse_class(_vim_pat, _vim_pos + 2, _vim_pat_len);
            if (u_mask == 0) {
                _vim_err = VIM_E_BAD_PROPERTY;
                return 0;
            }
            _vim_pos = _uprops_match_end_pos;
            _vim_emit_uprop(neg_p, u_mask);
            return 0;
        }

        # Predefined classes: \d \D \w \W \s \S
        if (e == 100) {
            _vim_pos = _vim_pos + 2;
            var cd = _vim_alloc_class(); if (_vim_err != VIM_E_OK) { return 0; }
            _vim_class_fill_digit(cd);
            _vim_emit_class(0, cd);
            return 0;
        }
        if (e == 68) {
            _vim_pos = _vim_pos + 2;
            var cD = _vim_alloc_class(); if (_vim_err != VIM_E_OK) { return 0; }
            _vim_class_fill_digit(cD);
            _vim_emit_class(1, cD);
            return 0;
        }
        if (e == 119) {
            _vim_pos = _vim_pos + 2;
            var cw = _vim_alloc_class(); if (_vim_err != VIM_E_OK) { return 0; }
            _vim_class_fill_word(cw);
            _vim_emit_class(0, cw);
            return 0;
        }
        if (e == 87) {
            _vim_pos = _vim_pos + 2;
            var cW = _vim_alloc_class(); if (_vim_err != VIM_E_OK) { return 0; }
            _vim_class_fill_word(cW);
            _vim_emit_class(1, cW);
            return 0;
        }
        if (e == 115) {
            _vim_pos = _vim_pos + 2;
            var cs = _vim_alloc_class(); if (_vim_err != VIM_E_OK) { return 0; }
            _vim_class_fill_space(cs);
            _vim_emit_class(0, cs);
            return 0;
        }
        if (e == 83) {
            _vim_pos = _vim_pos + 2;
            var cS = _vim_alloc_class(); if (_vim_err != VIM_E_OK) { return 0; }
            _vim_class_fill_space(cS);
            _vim_emit_class(1, cS);
            return 0;
        }

        # \. \* \[ \] etc. — backslashed-special-char in lower modes,
        # but interpreted as literals here. Dispatch: if the char
        # would be bare-special in this mode, the `\` makes it literal.
        # Otherwise the char is just a literal byte.
        # \^ \$ are literal in any mode.
        # In nomagic and very-nomagic, \. and \* may be specials
        # (becoming dot-any / star-quantifier). We don't yet have
        # mode-dependent backslash-special for these in this branch —
        # the ones we DO handle are nomagic-special quantifiers and
        # parens (above). For nomagic+below:
        #   \. → dot-any (since . is literal in nomagic; \. is special)
        if (e == 46 && (_vim_mode == VIM_MODE_NOMAGIC || _vim_mode == VIM_MODE_VERY_NOMAGIC)) {
            _vim_pos = _vim_pos + 2;
            _vim_emit_op(VIM_OP_ANY);
            return 0;
        }
        if (e == 91 && (_vim_mode == VIM_MODE_NOMAGIC || _vim_mode == VIM_MODE_VERY_NOMAGIC)) {
            _vim_pos = _vim_pos + 2;
            var cci = _vim_parse_class();
            if (_vim_err != VIM_E_OK) { return 0; }
            var neg2 = 0;
            if (cci < 0) { neg2 = 1; cci = 0 - (cci + 1); }
            _vim_emit_class(neg2, cci);
            return 0;
        }
        # \^ in very-nomagic = anchor BOL (at pattern-start).
        if (e == 94 && _vim_mode == VIM_MODE_VERY_NOMAGIC && at_start == 1) {
            _vim_pos = _vim_pos + 2;
            _vim_emit_op(VIM_OP_BOL);
            return 0;
        }
        # \$ in very-nomagic = anchor EOL (at pattern-end).
        if (e == 36 && _vim_mode == VIM_MODE_VERY_NOMAGIC) {
            var at_end2 = 0;
            if (_vim_pos + 2 == _vim_pat_len) { at_end2 = 1; }
            if (at_end2 == 1) {
                _vim_pos = _vim_pos + 2;
                _vim_emit_op(VIM_OP_EOL);
                return 0;
            }
        }

        # Otherwise: plain escape -> literal byte.
        var lc = _vim_lit_byte();
        if (_vim_err == VIM_E_OK) { _vim_emit_char(lc); }
        return 0;
    }

    # In very-magic mode, `|` `)` are reserved (not literal).
    if (_vim_mode == VIM_MODE_VERY_MAGIC) {
        if (c == 124 || c == 41 || c == 42 || c == 43 || c == 63 || c == 123 || c == 125) {
            _vim_err = VIM_E_SYNTAX; return 0;
        }
    }

    # Otherwise: literal char (byte for ASCII, codepoint for multi-byte).
    if (c >= 128) {
        # v0.8.0 — multi-byte literal. Codepoint-step the matcher
        # treats this as one unit; emit single UCHAR.
        var u_step = _uc_decode_utf8(_vim_pat, _vim_pos, _vim_pat_len, _vim_m_cp_slot);
        var u_cp = load64(_vim_m_cp_slot);
        _vim_pos = _vim_pos + u_step;
        _vim_emit_uchar(u_cp);
    } else {
        _vim_pos = _vim_pos + 1;
        _vim_emit_char(c);
    }
    return 0;
}

fn _vim_apply_simple_q(atom_start, op_char, lazy): i64 {
    var atom_end = _vim_instr_n;
    if (atom_end == atom_start) { _vim_err = VIM_E_SYNTAX; return 0; }
    if (op_char == 42) {
        _vim_shift_right(atom_start, atom_end);
        _vim_shift_targets_one(atom_start, atom_end);
        _vim_instr_n = _vim_instr_n + 1;
        var body_pc = atom_start + 1;
        if (lazy == 1) {
            store64(_vim_instr_base + atom_start * 16, _vim_w0(VIM_OP_SPLIT, 0, 0));
            store64(_vim_instr_base + atom_start * 16 + 8, body_pc);
        } else {
            store64(_vim_instr_base + atom_start * 16, _vim_w0(VIM_OP_SPLIT, 0, body_pc));
            store64(_vim_instr_base + atom_start * 16 + 8, 0);
        }
        _vim_emit_jmp(atom_start);
        var exit_pc = _vim_instr_n;
        if (lazy == 1) { _vim_patch_arg1(atom_start, exit_pc); }
        else            { _vim_patch_arg2(atom_start, exit_pc); }
    }
    elif (op_char == 43) {
        if (lazy == 1) {
            var s = _vim_emit_split(0, atom_start);
            _vim_patch_arg1(s, _vim_instr_n);
        } else {
            var s2 = _vim_emit_split(atom_start, 0);
            _vim_patch_arg2(s2, _vim_instr_n);
        }
    }
    elif (op_char == 63) {
        _vim_shift_right(atom_start, atom_end);
        _vim_shift_targets_one(atom_start, atom_end);
        _vim_instr_n = _vim_instr_n + 1;
        var body = atom_start + 1;
        if (lazy == 1) {
            store64(_vim_instr_base + atom_start * 16, _vim_w0(VIM_OP_SPLIT, 0, 0));
            store64(_vim_instr_base + atom_start * 16 + 8, body);
            _vim_patch_arg1(atom_start, _vim_instr_n);
        } else {
            store64(_vim_instr_base + atom_start * 16, _vim_w0(VIM_OP_SPLIT, 0, body));
            store64(_vim_instr_base + atom_start * 16 + 8, _vim_instr_n);
        }
    }
    return 0;
}

fn _vim_apply_star_inline(body_start, lazy): i64 {
    var body_end = _vim_instr_n;
    _vim_shift_right(body_start, body_end);
    _vim_shift_targets_one(body_start, body_end);
    _vim_instr_n = _vim_instr_n + 1;
    var body_pc = body_start + 1;
    if (lazy == 1) {
        store64(_vim_instr_base + body_start * 16, _vim_w0(VIM_OP_SPLIT, 0, 0));
        store64(_vim_instr_base + body_start * 16 + 8, body_pc);
    } else {
        store64(_vim_instr_base + body_start * 16, _vim_w0(VIM_OP_SPLIT, 0, body_pc));
        store64(_vim_instr_base + body_start * 16 + 8, 0);
    }
    _vim_emit_jmp(body_start);
    var exit_pc = _vim_instr_n;
    if (lazy == 1) { _vim_patch_arg1(body_start, exit_pc); }
    else            { _vim_patch_arg2(body_start, exit_pc); }
    return 0;
}

# Apply brace quantifier: {n} {n,m} {n,} optionally with `-` for lazy.
# At entry, _vim_pos is just past the opening `{` (whether bare or
# backslash-prefixed). Caller passed `save_primary_start` to re-parse.
fn _vim_apply_brace_q(save_primary_start, atom_start, has_bs): i64 {
    if (_vim_instr_n == atom_start) { _vim_err = VIM_E_SYNTAX; return 0; }
    var lazy = 0;
    if (_vim_pos < _vim_pat_len && load8(_vim_pat + _vim_pos) == 45) {
        # `\{-` or `{-` is lazy variant.
        lazy = 1;
        _vim_pos = _vim_pos + 1;
    }
    var n_min = 0;
    var have_min = 0;
    while (_vim_pos < _vim_pat_len && load8(_vim_pat + _vim_pos) >= 48 && load8(_vim_pat + _vim_pos) <= 57) {
        n_min = n_min * 10 + (load8(_vim_pat + _vim_pos) - 48);
        _vim_pos = _vim_pos + 1;
        have_min = 1;
    }
    var n_max = n_min;
    var open_ended = 0;
    if (_vim_pos < _vim_pat_len && load8(_vim_pat + _vim_pos) == 44) {
        _vim_pos = _vim_pos + 1;
        n_max = 0;
        var have_max = 0;
        while (_vim_pos < _vim_pat_len && load8(_vim_pat + _vim_pos) >= 48 && load8(_vim_pat + _vim_pos) <= 57) {
            n_max = n_max * 10 + (load8(_vim_pat + _vim_pos) - 48);
            _vim_pos = _vim_pos + 1;
            have_max = 1;
        }
        if (have_max == 0) { open_ended = 1; n_max = 0; }
    }
    if (have_min == 0 && lazy == 0) { _vim_err = VIM_E_SYNTAX; return 0; }
    if (lazy == 1 && have_min == 0) {
        # `\{-}` (vim shorthand for lazy `*`).
        n_min = 0;
        open_ended = 1;
    }
    # Expect closing brace. In magic+below: `\}`. In very-magic: `}`.
    if (has_bs == 1) {
        if (_vim_pos + 1 >= _vim_pat_len) { _vim_err = VIM_E_SYNTAX; return 0; }
        if (load8(_vim_pat + _vim_pos) != 92 || load8(_vim_pat + _vim_pos + 1) != 125) {
            _vim_err = VIM_E_SYNTAX; return 0;
        }
        _vim_pos = _vim_pos + 2;
    } else {
        if (_vim_pos >= _vim_pat_len || load8(_vim_pat + _vim_pos) != 125) {
            _vim_err = VIM_E_SYNTAX; return 0;
        }
        _vim_pos = _vim_pos + 1;
    }
    var pos_after_q = _vim_pos;
    if (open_ended == 0 && n_max < n_min) { _vim_err = VIM_E_SYNTAX; return 0; }
    if (n_max > 1000) { _vim_err = VIM_E_TOO_LARGE; return 0; }
    if (n_min == 0) {
        _vim_instr_n = atom_start;
        if (open_ended == 1) {
            var ts = _vim_instr_n;
            _vim_pos = save_primary_start;
            _vim_parse_primary(0);
            if (_vim_err != VIM_E_OK) { return 0; }
            _vim_apply_star_inline(ts, lazy);
        } else {
            var sn = 0;
            var k = 0;
            while (k < n_max) {
                if (sn >= 64) { _vim_err = VIM_E_TOO_LARGE; return 0; }
                var sx = _vim_emit_split(0, 0);
                store64(_vim_q_splits + sn * 8, sx);
                sn = sn + 1;
                _vim_pos = save_primary_start;
                _vim_parse_primary(0);
                if (_vim_err != VIM_E_OK) { return 0; }
                k = k + 1;
            }
            var exit_pc = _vim_instr_n;
            var ti = 0;
            while (ti < sn) {
                var sxi = load64(_vim_q_splits + ti * 8);
                if (lazy == 1) { _vim_patch_arg1(sxi, exit_pc); _vim_patch_arg2(sxi, sxi + 1); }
                else            { _vim_patch_arg1(sxi, sxi + 1); _vim_patch_arg2(sxi, exit_pc); }
                ti = ti + 1;
            }
        }
    } else {
        var k1 = 1;
        while (k1 < n_min) {
            _vim_pos = save_primary_start;
            _vim_parse_primary(0);
            if (_vim_err != VIM_E_OK) { return 0; }
            k1 = k1 + 1;
        }
        if (open_ended == 1) {
            var ts2 = _vim_instr_n;
            _vim_pos = save_primary_start;
            _vim_parse_primary(0);
            if (_vim_err != VIM_E_OK) { return 0; }
            _vim_apply_star_inline(ts2, lazy);
        } elif (n_max > n_min) {
            var sn2 = 0;
            var k2 = n_min;
            while (k2 < n_max) {
                if (sn2 >= 64) { _vim_err = VIM_E_TOO_LARGE; return 0; }
                var sy = _vim_emit_split(0, 0);
                store64(_vim_q_splits + sn2 * 8, sy);
                sn2 = sn2 + 1;
                _vim_pos = save_primary_start;
                _vim_parse_primary(0);
                if (_vim_err != VIM_E_OK) { return 0; }
                k2 = k2 + 1;
            }
            var exit_pc2 = _vim_instr_n;
            var tj = 0;
            while (tj < sn2) {
                var syi = load64(_vim_q_splits + tj * 8);
                if (lazy == 1) { _vim_patch_arg1(syi, exit_pc2); _vim_patch_arg2(syi, syi + 1); }
                else            { _vim_patch_arg1(syi, syi + 1); _vim_patch_arg2(syi, exit_pc2); }
                tj = tj + 1;
            }
        }
    }
    _vim_pos = pos_after_q;
    return 0;
}

fn _vim_parse_atom(at_start): i64 {
    var save_primary_start = _vim_pos;
    var atom_start = _vim_instr_n;
    _vim_parse_primary(at_start);
    if (_vim_err != VIM_E_OK) { return 0; }
    if (_vim_pos >= _vim_pat_len) { return 0; }
    var c = load8(_vim_pat + _vim_pos);

    # Bare quantifier?
    if (_vim_quant_bare(c) == 1) {
        _vim_pos = _vim_pos + 1;
        _vim_apply_simple_q(atom_start, _vim_quant_op(c), 0);
        return 0;
    }

    # Bare brace-quantifier?
    if (_vim_brace_open_bare(c) == 1) {
        _vim_pos = _vim_pos + 1;
        _vim_apply_brace_q(save_primary_start, atom_start, 0);
        return 0;
    }

    # Backslash quantifier?
    if (c == 92 && _vim_pos + 1 < _vim_pat_len) {
        var e = load8(_vim_pat + _vim_pos + 1);
        if (_vim_quant_after_bs(e) == 1) {
            _vim_pos = _vim_pos + 2;
            _vim_apply_simple_q(atom_start, _vim_quant_op(e), 0);
            return 0;
        }
        if (_vim_brace_open_after_bs(e) == 1) {
            _vim_pos = _vim_pos + 2;
            _vim_apply_brace_q(save_primary_start, atom_start, 1);
            return 0;
        }
    }
    return 0;
}

fn _vim_parse_concat(at_start): i64 {
    var first = at_start;
    while (_vim_pos < _vim_pat_len) {
        # Stop at alternation or close-paren.
        var c = load8(_vim_pat + _vim_pos);
        if (_vim_alt_bare(c) == 1) { return 0; }
        if (_vim_close_paren_bare(c) == 1) { return 0; }
        if (c == 92 && _vim_pos + 1 < _vim_pat_len) {
            var e = load8(_vim_pat + _vim_pos + 1);
            if (_vim_alt_after_bs(e) == 1) { return 0; }
            if (_vim_close_paren_after_bs(e) == 1) { return 0; }
        }
        _vim_parse_atom(first);
        first = 0;
        if (_vim_err != VIM_E_OK) { return 0; }
    }
    return 0;
}

fn _vim_parse_alt(): i64 {
    var left_start = _vim_instr_n;
    _vim_parse_concat(0);
    if (_vim_err != VIM_E_OK) { return 0; }
    while (_vim_pos < _vim_pat_len) {
        var c = load8(_vim_pat + _vim_pos);
        var is_alt = 0;
        if (_vim_alt_bare(c) == 1) { is_alt = 1; _vim_pos = _vim_pos + 1; }
        elif (c == 92 && _vim_pos + 1 < _vim_pat_len) {
            var e = load8(_vim_pat + _vim_pos + 1);
            if (_vim_alt_after_bs(e) == 1) { is_alt = 1; _vim_pos = _vim_pos + 2; }
        }
        if (is_alt == 0) { return 0; }
        var left_end = _vim_instr_n;
        _vim_shift_right(left_start, left_end);
        _vim_shift_targets_one(left_start, left_end);
        _vim_instr_n = _vim_instr_n + 1;
        store64(_vim_instr_base + left_start * 16, _vim_w0(VIM_OP_SPLIT, 0, left_start + 1));
        store64(_vim_instr_base + left_start * 16 + 8, 0);
        var jmp_idx = _vim_emit_jmp(0);
        var right_start = _vim_instr_n;
        _vim_patch_arg2(left_start, right_start);
        _vim_parse_concat(0);
        if (_vim_err != VIM_E_OK) { return 0; }
        _vim_patch_arg1(jmp_idx, _vim_instr_n);
    }
    return 0;
}

# === Compiler entry ==================================================

fn niyama_vim_compile_opts(pat, mode): i64 {
    _vim_lazy_init();
    if (mode < 0 || mode > 3) {
        _vim_last_err = VIM_E_INVALID_MODE;
        return 0;
    }
    var n = strlen(pat);
    var instr_bytes = VIM_MAX_INSTRS * 16;
    var class_bytes = VIM_MAX_CLASSES * 32;
    var nfa = alloc(VIM_NFA_HEADER_SIZE + instr_bytes + class_bytes);
    var instrs = nfa + VIM_NFA_HEADER_SIZE;
    var classes = instrs + instr_bytes;
    store64(nfa + VIM_OFF_INSTRS_OFF,  VIM_NFA_HEADER_SIZE);
    store64(nfa + VIM_OFF_CLASSES_OFF, VIM_NFA_HEADER_SIZE + instr_bytes);
    store64(nfa + VIM_OFF_MATCH_START, 0 - 1);
    store64(nfa + VIM_OFF_MATCH_END,   0 - 1);
    var sv = 0;
    while (sv < VIM_MAX_SAVES) {
        store64(nfa + VIM_OFF_SAVES + sv * 8, 0 - 1);
        sv = sv + 1;
    }
    _vim_pat = pat;
    _vim_pat_len = n;
    _vim_pos = 0;
    _vim_mode = mode;
    _vim_nfa = nfa;
    _vim_instr_base = instrs;
    _vim_class_base = classes;
    _vim_instr_n = 0;
    _vim_class_n = 0;
    _vim_capture_n = 0;
    _vim_err = VIM_E_OK;
    _vim_saw_ze = 0;
    _vim_emit_save(0);
    # Top-level concat (handles alternations).
    # at_start = 1 for first primary so `^` is recognized as anchor.
    var lstart = _vim_instr_n;
    _vim_parse_concat(1);
    if (_vim_err != VIM_E_OK) {
        _vim_last_err = _vim_err;
        return 0;
    }
    while (_vim_pos < _vim_pat_len) {
        var c = load8(_vim_pat + _vim_pos);
        var is_alt = 0;
        if (_vim_alt_bare(c) == 1) { is_alt = 1; _vim_pos = _vim_pos + 1; }
        elif (c == 92 && _vim_pos + 1 < _vim_pat_len) {
            var e = load8(_vim_pat + _vim_pos + 1);
            if (_vim_alt_after_bs(e) == 1) { is_alt = 1; _vim_pos = _vim_pos + 2; }
        }
        if (is_alt == 0) { _vim_err = VIM_E_SYNTAX; _vim_last_err = _vim_err; return 0; }
        var lend = _vim_instr_n;
        _vim_shift_right(lstart, lend);
        _vim_shift_targets_one(lstart, lend);
        _vim_instr_n = _vim_instr_n + 1;
        store64(_vim_instr_base + lstart * 16, _vim_w0(VIM_OP_SPLIT, 0, lstart + 1));
        store64(_vim_instr_base + lstart * 16 + 8, 0);
        var jidx = _vim_emit_jmp(0);
        var rstart = _vim_instr_n;
        _vim_patch_arg2(lstart, rstart);
        _vim_parse_concat(0);
        if (_vim_err != VIM_E_OK) { _vim_last_err = _vim_err; return 0; }
        _vim_patch_arg1(jidx, _vim_instr_n);
    }
    if (_vim_pos != _vim_pat_len) {
        _vim_err = VIM_E_SYNTAX; _vim_last_err = _vim_err; return 0;
    }
    if (_vim_saw_ze == 0) {
        _vim_emit_save(1);
    }
    _vim_emit_op(VIM_OP_MATCH);
    if (_vim_err != VIM_E_OK) { _vim_last_err = _vim_err; return 0; }
    store64(nfa + VIM_OFF_INSTR_COUNT, _vim_instr_n);
    store64(nfa + VIM_OFF_CLASS_COUNT, _vim_class_n);
    store64(nfa + VIM_OFF_CAPTURES,    _vim_capture_n);
    _vim_last_err = VIM_E_OK;
    return nfa;
}

fn niyama_vim_compile(pat): i64 {
    return niyama_vim_compile_opts(pat, VIM_MODE_MAGIC);
}

fn niyama_vim_last_error(): i64 {
    return _vim_last_err;
}

# === Pike NFA matcher (mirrors re2.cyr) ==============================

fn _vim_at_word_char(input, input_len, pos): i64 {
    if (pos < 0)         { return 0; }
    if (pos >= input_len){ return 0; }
    var c = load8(input + pos);
    if (c >= 48 && c <= 57)   { return 1; }
    if (c >= 65 && c <= 90)   { return 1; }
    if (c >= 97 && c <= 122)  { return 1; }
    if (c == 95)              { return 1; }
    return 0;
}

fn _vim_is_boundary(input, input_len, pos): i64 {
    var l = _vim_at_word_char(input, input_len, pos - 1);
    var r = _vim_at_word_char(input, input_len, pos);
    if (l != r) { return 1; }
    return 0;
}

fn _vim_class_get_at(class_base, ci, c): i64 {
    if (c < 0)   { return 0; }
    if (c > 255) { return 0; }
    var off = class_base + ci * 32 + (c >> 3);
    var b = load8(off);
    if ((b >> (c & 7)) & 1) { return 1; }
    return 0;
}

fn _vim_add_thread(list_base, pc, input, input_len, pos, saves, instrs): i64 {
    if (pc < 0)                 { return 0; }
    if (load64(_vim_m_lastgen + pc * 8) == _vim_m_gen) { return 0; }
    store64(_vim_m_lastgen + pc * 8, _vim_m_gen);
    var off = instrs + pc * 16;
    var w0 = load64(off);
    var op = w0 & 0xFF;
    if (op == VIM_OP_JMP) {
        var t = (w0 >> 32) & 0xFFFFFFFF;
        _vim_add_thread(list_base, t, input, input_len, pos, saves, instrs);
    }
    elif (op == VIM_OP_SPLIT) {
        var a = (w0 >> 32) & 0xFFFFFFFF;
        var b = load64(off + 8);
        _vim_add_thread(list_base, a, input, input_len, pos, saves, instrs);
        _vim_add_thread(list_base, b, input, input_len, pos, saves, instrs);
    }
    elif (op == VIM_OP_SAVE) {
        var idx = (w0 >> 8) & 0xFF;
        var prev = load64(saves + idx * 8);
        store64(saves + idx * 8, pos);
        _vim_add_thread(list_base, pc + 1, input, input_len, pos, saves, instrs);
        store64(saves + idx * 8, prev);
    }
    elif (op == VIM_OP_BOL) {
        var ok = 0;
        if (pos == 0) { ok = 1; }
        else {
            if (load8(input + pos - 1) == 10) { ok = 1; }
        }
        if (ok == 1) { _vim_add_thread(list_base, pc + 1, input, input_len, pos, saves, instrs); }
    }
    elif (op == VIM_OP_EOL) {
        var ok2 = 0;
        if (pos == input_len) { ok2 = 1; }
        elif (load8(input + pos) == 10) { ok2 = 1; }
        if (ok2 == 1) { _vim_add_thread(list_base, pc + 1, input, input_len, pos, saves, instrs); }
    }
    elif (op == VIM_OP_BOUNDARY) {
        if (_vim_is_boundary(input, input_len, pos) == 1) {
            _vim_add_thread(list_base, pc + 1, input, input_len, pos, saves, instrs);
        }
    }
    elif (op == VIM_OP_NBOUNDARY) {
        if (_vim_is_boundary(input, input_len, pos) == 0) {
            _vim_add_thread(list_base, pc + 1, input, input_len, pos, saves, instrs);
        }
    }
    else {
        var n = load64(list_base);
        store64(list_base + 8 + n * 168, pc);
        var k = 0;
        while (k < VIM_MAX_SAVES) {
            var v = load64(saves + k * 8);
            store64(list_base + 8 + n * 168 + 8 + k * 8, v);
            k = k + 1;
        }
        store64(list_base, n + 1);
    }
    return 0;
}

fn _vim_pike_run(nfa, input, input_len, start_pos): i64 {
    _vim_lazy_init();
    var instrs = nfa + load64(nfa + VIM_OFF_INSTRS_OFF);
    var class_base = nfa + load64(nfa + VIM_OFF_CLASSES_OFF);
    var matched = 0 - 1;
    var saves_scratch = alloc(VIM_MAX_SAVES * 8);
    var k = 0;
    while (k < VIM_MAX_SAVES) {
        store64(saves_scratch + k * 8, 0 - 1);
        k = k + 1;
    }
    var match_saves = alloc(VIM_MAX_SAVES * 8);
    var k2 = 0;
    while (k2 < VIM_MAX_SAVES) {
        store64(match_saves + k2 * 8, 0 - 1);
        k2 = k2 + 1;
    }
    var cur = _vim_m_cur;
    var nxt = _vim_m_next;
    store64(cur, 0);
    store64(nxt, 0);
    _vim_m_gen = _vim_m_gen + 1;
    _vim_add_thread(cur, 0, input, input_len, start_pos, saves_scratch, instrs);
    var pos = start_pos;
    var done = 0;
    while (done == 0) {
        # v0.8.0 — codepoint-stepped (mirrors re2). Decode UTF-8 cp +
        # step at top so all consumers schedule successors at pos + step.
        var c = 0 - 1;
        var cp = 0 - 1;
        var step = 1;
        if (pos < input_len) {
            c = load8(input + pos);
            if (c < 128) {
                cp = c;
            } else {
                step = _uc_decode_utf8(input, pos, input_len, _vim_m_cp_slot);
                cp = load64(_vim_m_cp_slot);
            }
        }
        _vim_m_gen = _vim_m_gen + 1;
        var n_cur = load64(cur);
        var ti = 0;
        while (ti < n_cur) {
            var pc = load64(cur + 8 + ti * 168);
            var iw0 = load64(instrs + pc * 16);
            var iop = iw0 & 0xFF;
            if (iop == VIM_OP_MATCH) {
                matched = pos;
                var ks = 0;
                while (ks < VIM_MAX_SAVES) {
                    store64(match_saves + ks * 8, load64(cur + 8 + ti * 168 + 8 + ks * 8));
                    ks = ks + 1;
                }
                ti = n_cur;
            }
            elif (iop == VIM_OP_CHAR) {
                var want = (iw0 >> 8) & 0xFF;
                if (c >= 0 && c == want) {
                    var ks2 = 0;
                    while (ks2 < VIM_MAX_SAVES) {
                        store64(saves_scratch + ks2 * 8, load64(cur + 8 + ti * 168 + 8 + ks2 * 8));
                        ks2 = ks2 + 1;
                    }
                    _vim_add_thread(nxt, pc + 1, input, input_len, pos + step, saves_scratch, instrs);
                }
            }
            elif (iop == VIM_OP_UCHAR) {
                # v0.8.0 — codepoint literal match.
                var u_want = (iw0 >> 32) & 0x1FFFFF;
                if (cp >= 0 && cp == u_want) {
                    var ks_uc = 0;
                    while (ks_uc < VIM_MAX_SAVES) {
                        store64(saves_scratch + ks_uc * 8, load64(cur + 8 + ti * 168 + 8 + ks_uc * 8));
                        ks_uc = ks_uc + 1;
                    }
                    _vim_add_thread(nxt, pc + 1, input, input_len, pos + step, saves_scratch, instrs);
                }
            }
            elif (iop == VIM_OP_ANY) {
                if (c >= 0) {
                    var ks3 = 0;
                    while (ks3 < VIM_MAX_SAVES) {
                        store64(saves_scratch + ks3 * 8, load64(cur + 8 + ti * 168 + 8 + ks3 * 8));
                        ks3 = ks3 + 1;
                    }
                    _vim_add_thread(nxt, pc + 1, input, input_len, pos + step, saves_scratch, instrs);
                }
            }
            elif (iop == VIM_OP_CLASS || iop == VIM_OP_NCLASS) {
                if (c >= 0) {
                    var ci = (iw0 >> 8) & 0xFF;
                    var hit = _vim_class_get_at(class_base, ci, c);
                    if (iop == VIM_OP_NCLASS) {
                        if (hit == 1) { hit = 0; } else { hit = 1; }
                    }
                    if (hit == 1) {
                        var ks4 = 0;
                        while (ks4 < VIM_MAX_SAVES) {
                            store64(saves_scratch + ks4 * 8, load64(cur + 8 + ti * 168 + 8 + ks4 * 8));
                            ks4 = ks4 + 1;
                        }
                        _vim_add_thread(nxt, pc + 1, input, input_len, pos + step, saves_scratch, instrs);
                    }
                }
            }
            elif (iop == VIM_OP_UPROP || iop == VIM_OP_NUPROP) {
                # v0.8.0 — \p{NAME} / \P{NAME} via stdlib unicode_category.
                if (cp >= 0) {
                    var u_mask = (iw0 >> 32) & 0x3FFFFFFF;
                    var u_hit = _uprops_test(cp, u_mask);
                    if (iop == VIM_OP_NUPROP) {
                        if (u_hit == 1) { u_hit = 0; } else { u_hit = 1; }
                    }
                    if (u_hit == 1) {
                        var ks_u = 0;
                        while (ks_u < VIM_MAX_SAVES) {
                            store64(saves_scratch + ks_u * 8, load64(cur + 8 + ti * 168 + 8 + ks_u * 8));
                            ks_u = ks_u + 1;
                        }
                        _vim_add_thread(nxt, pc + 1, input, input_len, pos + step, saves_scratch, instrs);
                    }
                }
            }
            ti = ti + 1;
        }
        var swap = cur;
        cur = nxt;
        nxt = swap;
        store64(nxt, 0);
        if (pos > input_len) { done = 1; }
        elif (load64(cur) == 0) { done = 1; }
        else { pos = pos + step; }
    }
    if (matched >= 0) {
        var ks5 = 0;
        while (ks5 < VIM_MAX_SAVES) {
            store64(nfa + VIM_OFF_SAVES + ks5 * 8, load64(match_saves + ks5 * 8));
            ks5 = ks5 + 1;
        }
        store64(nfa + VIM_OFF_MATCH_START, load64(match_saves));
        store64(nfa + VIM_OFF_MATCH_END,   matched);
    } else {
        store64(nfa + VIM_OFF_MATCH_START, 0 - 1);
        store64(nfa + VIM_OFF_MATCH_END,   0 - 1);
    }
    return matched;
}

# === Public API ======================================================

fn niyama_vim_match(nfa, s): i64 {
    if (nfa == 0) { return 0; }
    var len = strlen(s);
    var r = _vim_pike_run(nfa, s, len, 0);
    if (r >= 0) { return 1; }
    return 0;
}

fn niyama_vim_search(nfa, s): i64 {
    if (nfa == 0) { return 0 - 1; }
    var len = strlen(s);
    return niyama_vim_search_at(nfa, s, len, 0);
}

fn niyama_vim_search_at(nfa, s, len, from): i64 {
    if (nfa == 0) { return 0 - 1; }
    var i = from;
    while (i <= len) {
        var r = _vim_pike_run(nfa, s, len, i);
        if (r >= 0) { return i; }
        i = i + 1;
    }
    return 0 - 1;
}

fn niyama_vim_group_start(nfa, n): i64 {
    if (nfa == 0)        { return 0 - 1; }
    if (n < 0 || n > 9)  { return 0 - 1; }
    return load64(nfa + VIM_OFF_SAVES + n * 16);
}

fn niyama_vim_group_end(nfa, n): i64 {
    if (nfa == 0)        { return 0 - 1; }
    if (n < 0 || n > 9)  { return 0 - 1; }
    return load64(nfa + VIM_OFF_SAVES + n * 16 + 8);
}
