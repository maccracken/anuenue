    if (s == AGENT_PENDING)          { return "Pending"; }
    elif (s == AGENT_STARTING)       { return "Starting"; }
    elif (s == AGENT_RUNNING)        { return "Running"; }
    elif (s == AGENT_PAUSED)         { return "Paused"; }
    elif (s == AGENT_STOPPING)       { return "Stopping"; }
    elif (s == AGENT_STOPPED)        { return "Stopped"; }
    elif (s == AGENT_RESTARTING)     { return "Restarting"; }
    elif (s == AGENT_TERMINATED)     { return "Terminated"; }
    elif (s == AGENT_FAILED)         { return "Failed"; }
    return "Unknown";
}
