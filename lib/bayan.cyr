fn json_v_is_arr(v): i64 { return bayan_json_v_is_arr(v); }
fn json_v_is_obj(v): i64 { return bayan_json_v_is_obj(v); }
fn json_v_bool(v): i64 { return bayan_json_v_bool(v); }
