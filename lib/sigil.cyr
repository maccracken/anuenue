# --- types.cyr ---

# types.cyr — sigil type system
# Enums, structs, constructors, accessors for the trust verification module.

# ================================================================
# SignatureAlgorithm
# ================================================================

enum SignatureAlgorithm {
    SIG_ALG_ED25519 = 0;
    SIG_ALG_ML_DSA_65 = 1;
    SIG_ALG_HYBRID = 2;
}

# Returns a static display name C-string for a SignatureAlgorithm enum
# value ("Ed25519", "ML-DSA-65", "Hybrid(...)", or "unknown").
fn sig_alg_name(alg): i64 {
    if (alg == SIG_ALG_ED25519) { return "Ed25519"; }
    if (alg == SIG_ALG_ML_DSA_65) { return "ML-DSA-65"; }
    if (alg == SIG_ALG_HYBRID) { return "Hybrid(Ed25519+ML-DSA-65)"; }
    return "unknown";
}

# ================================================================
# HashAlgorithm
# ================================================================

enum HashAlgorithm {
    HASH_ALG_SHA256 = 0;
    HASH_ALG_SHA512 = 1;
}

# Returns a static display name C-string for a HashAlgorithm enum value
# ("SHA-256", "SHA-512", or "unknown").
fn hash_alg_name(alg): i64 {
    if (alg == HASH_ALG_SHA256) { return "SHA-256"; }
    if (alg == HASH_ALG_SHA512) { return "SHA-512"; }
    return "unknown";
}

# ================================================================
# TrustLevel
# ================================================================
# Ordered from highest trust to lowest conceptually.
# Rank: SystemCore(4) > Verified(3) > Unverified(1) > Revoked(0)
#
# 3.0 removed TRUST_COMMUNITY (value 2) — unused across all
# AGNOS consumers (post-3.0-branch audit). The numeric slot at
# value 2 is intentionally left unassigned rather than
# renumbered so that any persisted state carrying `level: 3`
# (Unverified) or `level: 4` (Revoked) decodes identically
# pre- and post-3.0. Old `level: 2` entries decode as
# "unknown" / rank 0 — safe degraded default for a deprecated
# level.

enum TrustLevel {
    TRUST_SYSTEM_CORE = 0;
    TRUST_VERIFIED = 1;
    TRUST_UNVERIFIED = 3;
    TRUST_REVOKED = 4;
}

# Maps a TrustLevel enum value to its comparable integer rank
# (SystemCore=4 > Verified=3 > Unverified=1 > Revoked=0).
fn trust_level_rank(level): i64 {
    if (level == TRUST_SYSTEM_CORE) { return 4; }
    if (level == TRUST_VERIFIED) { return 3; }
    if (level == TRUST_UNVERIFIED) { return 1; }
    if (level == TRUST_REVOKED) { return 0; }
    return 0;
}

# Returns 1 if trust level `a` ranks at least as high as `b`, else 0.
fn trust_level_ge(a, b): i64 {
    if (trust_level_rank(a) >= trust_level_rank(b)) { return 1; }
    return 0;
}

# Returns a static display name C-string for a TrustLevel enum value
# ("SystemCore", "Verified", "Unverified", "Revoked", or "unknown").
fn trust_level_name(level): i64 {
    if (level == TRUST_SYSTEM_CORE) { return "SystemCore"; }
    if (level == TRUST_VERIFIED) { return "Verified"; }
    if (level == TRUST_UNVERIFIED) { return "Unverified"; }
    if (level == TRUST_REVOKED) { return "Revoked"; }
    return "unknown";
}

# ================================================================
# TrustEnforcement
# ================================================================

enum TrustEnforcement {
    ENFORCE_STRICT = 0;
    ENFORCE_PERMISSIVE = 1;
    ENFORCE_AUDIT_ONLY = 2;
}

# Returns a static display name C-string for a TrustEnforcement enum
# value ("Strict", "Permissive", "AuditOnly", or "unknown").
fn enforcement_name(mode): i64 {
    if (mode == ENFORCE_STRICT) { return "Strict"; }
    if (mode == ENFORCE_PERMISSIVE) { return "Permissive"; }
    if (mode == ENFORCE_AUDIT_ONLY) { return "AuditOnly"; }
    return "unknown";
}

# ================================================================
# ArtifactType
# ================================================================

enum ArtifactType {
    ARTIFACT_AGENT_BINARY = 0;
    ARTIFACT_SYSTEM_BINARY = 1;
    ARTIFACT_CONFIG = 2;
    ARTIFACT_PACKAGE = 3;
    ARTIFACT_BOOT_COMPONENT = 4;
}

# Returns a static display name C-string for an ArtifactType enum value
# ("AgentBinary", "SystemBinary", "Config", "Package", "BootComponent",
# or "unknown").
fn artifact_type_name(t): i64 {
    if (t == ARTIFACT_AGENT_BINARY) { return "AgentBinary"; }
    if (t == ARTIFACT_SYSTEM_BINARY) { return "SystemBinary"; }
    if (t == ARTIFACT_CONFIG) { return "Config"; }
    if (t == ARTIFACT_PACKAGE) { return "Package"; }
    if (t == ARTIFACT_BOOT_COMPONENT) { return "BootComponent"; }
    return "unknown";
}

# ================================================================
# TrustPolicy (72 bytes)
# ================================================================
# Layout:
#   +0   enforcement           (i64)
#   +8   minimum_trust_level   (i64)
#   +16  allow_unsigned        (i64, 0=false 1=true)
#   +24  verify_on_boot        (i64)
#   +32  verify_on_install     (i64)
#   +40  verify_on_execute     (i64)
#   +48  revocation_check      (i64)
#   +56  hash_algorithm        (i64)
#   +64  required_sig_alg      (i64, SignatureAlgorithm enum)
#
# required_sig_alg added in 2.10.0 alongside ML-DSA-65 landing.
# Default is SIG_ALG_ED25519 so legacy policies behave exactly as
# before. Consumers opting in to PQC set it to SIG_ALG_HYBRID
# (requires both Ed25519 and ML-DSA-65 signatures to verify) or
# SIG_ALG_ML_DSA_65 (PQC-only, future state).

# Allocates a 72-byte TrustPolicy with secure defaults: strict
# enforcement, minimum trust Verified, unsigned artifacts rejected,
# verify-on-boot/install/execute and revocation checks all on, SHA-256,
# and Ed25519 as the required signature algorithm. Returns the pointer.
fn trust_policy_new(): i64 {
    var p = fl_alloc(72);
    store64(p, ENFORCE_STRICT);
    store64(p + 8, TRUST_VERIFIED);
    store64(p + 16, 0);
    store64(p + 24, 1);
    store64(p + 32, 1);
    store64(p + 40, 1);
    store64(p + 48, 1);
    store64(p + 56, HASH_ALG_SHA256);
    store64(p + 64, SIG_ALG_ED25519);
    return p;
}

# Returns the enforcement mode (TrustEnforcement) of policy `p`.
fn policy_enforcement(p): i64 { return load64(p); }
# Returns the minimum acceptable trust level (TrustLevel) of policy `p`.
fn policy_min_trust(p): i64 { return load64(p + 8); }
# Returns 1 if policy `p` permits unsigned artifacts, else 0.
fn policy_allow_unsigned(p): i64 { return load64(p + 16); }
# Returns 1 if policy `p` requires verification at boot, else 0.
fn policy_verify_on_boot(p): i64 { return load64(p + 24); }
# Returns 1 if policy `p` requires verification at install, else 0.
fn policy_verify_on_install(p): i64 { return load64(p + 32); }
# Returns 1 if policy `p` requires verification at execute, else 0.
fn policy_verify_on_execute(p): i64 { return load64(p + 40); }
# Returns 1 if policy `p` enables revocation-list checking, else 0.
fn policy_revocation_check(p): i64 { return load64(p + 48); }
# Returns the hash algorithm (HashAlgorithm) configured on policy `p`.
fn policy_hash_alg(p): i64 { return load64(p + 56); }
# Returns the required signature algorithm (SignatureAlgorithm) of `p`.
fn policy_required_sig_alg(p): i64 { return load64(p + 64); }

# Sets the enforcement mode of policy `p` to `v`; returns `p`.
fn policy_set_enforcement(p, v): i64 { store64(p, v); return p; }
# Sets the minimum acceptable trust level of policy `p` to `v`; returns `p`.
fn policy_set_min_trust(p, v): i64 { store64(p + 8, v); return p; }
# Sets the allow-unsigned flag of policy `p` to `v`; returns `p`.
fn policy_set_allow_unsigned(p, v): i64 { store64(p + 16, v); return p; }
# Sets the verify-on-boot flag of policy `p` to `v`; returns `p`.
fn policy_set_verify_on_boot(p, v): i64 { store64(p + 24, v); return p; }
# Sets the verify-on-install flag of policy `p` to `v`; returns `p`.
fn policy_set_verify_on_install(p, v): i64 { store64(p + 32, v); return p; }
# Sets the verify-on-execute flag of policy `p` to `v`; returns `p`.
fn policy_set_verify_on_execute(p, v): i64 { store64(p + 40, v); return p; }
# Sets the revocation-check flag of policy `p` to `v`; returns `p`.
fn policy_set_revocation_check(p, v): i64 { store64(p + 48, v); return p; }
# Sets the hash algorithm of policy `p` to `v`; returns `p`.
fn policy_set_hash_alg(p, v): i64 { store64(p + 56, v); return p; }
# Sets the required signature algorithm of policy `p` to `v`; returns `p`.
fn policy_set_required_sig_alg(p, v): i64 { store64(p + 64, v); return p; }

# ================================================================
# TrustCheck (24 bytes)
# ================================================================
# Layout:
#   +0   name     (C-string pointer)
#   +8   passed   (i64, 0 or 1)
#   +16  detail   (C-string pointer)

# Allocates a 24-byte TrustCheck recording a named check, its pass/fail
# result (`passed` 0 or 1), and a `detail` C-string. Returns the pointer.
fn trust_check_new(name, passed, detail): i64 {
    var tc = fl_alloc(24);
    store64(tc, name);
    store64(tc + 8, passed);
    store64(tc + 16, detail);
    return tc;
}

# Returns the name C-string of trust check `tc`.
fn check_name(tc): i64 { return load64(tc); }
# Returns the pass/fail result (0 or 1) of trust check `tc`.
fn check_passed(tc): i64 { return load64(tc + 8); }
# Returns the detail C-string of trust check `tc`.
fn check_detail(tc): i64 { return load64(tc + 16); }

# ================================================================
# TrustedArtifact (48 bytes)
# ================================================================
# Layout:
#   +0   path              (C-string pointer)
#   +8   artifact_type     (i64)
#   +16  content_hash      (C-string pointer, hex)
#   +24  signature         (pointer to raw bytes, 0 = none)
#   +32  signer_key_id     (C-string pointer, 0 = none)
#   +40  trust_level       (i64)
#
# Dropped in 2.6.0 (write-only or no-read-path dead fields):
#   signature_len — Ed25519 signatures are always 64 bytes.
#   signature_algorithm — always SIG_ALG_ED25519; sigil does not
#     support algorithm negotiation. Add back when hybrid/PQC lands.
#   verified_at — written by sv_sign_artifact, never read.
#   metadata — never populated.

# Allocates a 48-byte TrustedArtifact for `path` (an ArtifactType and a
# hex content-hash C-string), with no signature/signer and an initial
# trust level of Unverified. Returns the pointer.
fn trusted_artifact_new(path, artifact_type, content_hash): i64 {
    var a = fl_alloc(48);
    store64(a, path);
    store64(a + 8, artifact_type);
    store64(a + 16, content_hash);
    store64(a + 24, 0);
    store64(a + 32, 0);
    store64(a + 40, TRUST_UNVERIFIED);
    return a;
}

# Returns the path C-string of artifact `a`.
fn artifact_path(a): i64 { return load64(a); }
# Returns the ArtifactType of artifact `a`.
fn artifact_type(a): i64 { return load64(a + 8); }
# Returns the hex content-hash C-string of artifact `a`.
fn artifact_content_hash(a): i64 { return load64(a + 16); }
# Returns the raw signature pointer of artifact `a` (0 if unsigned).
fn artifact_signature(a): i64 { return load64(a + 24); }
# Returns the signer key-id C-string of artifact `a` (0 if unsigned).
fn artifact_signer_key_id(a): i64 { return load64(a + 32); }
# Returns the current TrustLevel of artifact `a`.
fn artifact_trust_level(a): i64 { return load64(a + 40); }

# Ed25519 signatures are always 64 bytes; `sig_len` parameter from
# the pre-2.6.0 signature was always 64 at every call site. Dropped.
fn artifact_set_signature(a, sig): i64 { store64(a + 24, sig); return a; }
# Sets the signer key-id C-string of artifact `a`; returns `a`.
fn artifact_set_signer(a, key_id): i64 { store64(a + 32, key_id); return a; }
# Sets the TrustLevel of artifact `a` to `level`; returns `a`.
fn artifact_set_trust_level(a, level): i64 { store64(a + 40, level); return a; }

# ================================================================
# VerificationResult (32 bytes)
# ================================================================
# Layout:
#   +0   artifact     (TrustedArtifact pointer)
#   +8   passed       (i64)
#   +16  checks       (vec of TrustCheck pointers)
#   +24  verified_at  (i64, epoch seconds)

# Allocates a 32-byte VerificationResult binding a TrustedArtifact, an
# overall pass/fail flag, an empty vec of per-check results, and the
# `verified_at` epoch-seconds timestamp. Returns the pointer.
fn verification_result_new(artifact, passed, verified_at): i64 {
    var vr = fl_alloc(32);
    store64(vr, artifact);
    store64(vr + 8, passed);
    store64(vr + 16, vec_new());
    store64(vr + 24, verified_at);
    return vr;
}

# Returns the TrustedArtifact pointer of verification result `vr`.
fn vresult_artifact(vr): i64 { return load64(vr); }
# Returns the overall pass/fail flag (0 or 1) of verification result `vr`.
fn vresult_passed(vr): i64 { return load64(vr + 8); }
# Returns the vec of per-check TrustCheck pointers of result `vr`.
fn vresult_checks(vr): i64 { return load64(vr + 16); }
# vresult_verified_at getter removed in 2.6.0. The field stays in
# the struct (constructor takes it) for API symmetry, but no caller
# reads it. Re-introduce when reporting code actually uses it.

# Appends TrustCheck `tc` to verification result `vr`'s check vec;
# returns `vr`.
fn vresult_add_check(vr, tc): i64 {
    vec_push(load64(vr + 16), tc);
    return vr;
}

# Sets the overall pass/fail flag of verification result `vr`; returns `vr`.
fn vresult_set_passed(vr, passed): i64 {
    store64(vr + 8, passed);
    return vr;
}

# ================================================================
# SigilStats (40 bytes)
# ================================================================
# Layout:
#   +0   total_artifacts   (i64)
#   +8   verified_count    (i64)
#   +16  revoked_count     (i64)
#   +24  trust_level_counts (hashmap pointer)

# Allocates a SigilStats counter block with all counts zeroed. Returns
# the pointer.
fn sigil_stats_new(): i64 {
    var s = fl_alloc(32);
    store64(s, 0);
    store64(s + 8, 0);
    store64(s + 16, 0);
    store64(s + 24, 0);
    return s;
}

# Returns the total-artifacts count of stats block `s`.
fn stats_total(s): i64 { return load64(s); }
# Returns the verified-artifacts count of stats block `s`.
fn stats_verified(s): i64 { return load64(s + 8); }
# Returns the revoked-artifacts count of stats block `s`.
fn stats_revoked(s): i64 { return load64(s + 16); }

# --- error.cyr ---

# error.cyr — sigil error codes and error construction
# Follows packed-struct pattern (like sakshi) for error objects.

# ================================================================
# Error codes
# ================================================================

enum SigilError {
    ERR_NONE = 0;
    ERR_KEY_NOT_FOUND = 1;
    ERR_SIGNATURE_INVALID = 2;
    ERR_REVOCATION = 3;
    ERR_INTEGRITY_MISMATCH = 4;
    ERR_INVALID_INPUT = 5;
    ERR_IO = 6;
    ERR_SERIALIZATION = 7;
    ERR_CRYPTO = 8;
}

# ================================================================
# Error predicates
# ================================================================

# Returns 1 if `code` is ERR_NONE (success), 0 otherwise.
fn sigil_is_ok(code): i64 {
    if (code == ERR_NONE) { return 1; }
    return 0;
}

# Returns 1 if `code` is any non-ERR_NONE error code, 0 otherwise.
fn sigil_is_err(code): i64 {
    if (code != ERR_NONE) { return 1; }
    return 0;
}

# ================================================================
# Error object (16 bytes)
# ================================================================
# Layout:
#   +0   code   (i64, ERR_* constant)
#   +8   msg    (C-string pointer)

# Allocates a 16-byte error object holding `code` and `msg` (a C-string
# pointer). Returns the object pointer; free with sigil_err_free.
fn sigil_err(code, msg): i64 {
    var e = fl_alloc(16);
    store64(e, code);
    store64(e + 8, msg);
    return e;
}

# Returns the ERR_* code stored in error object `e`.
fn sigil_err_code(e): i64 { return load64(e); }
# Returns the message C-string pointer stored in error object `e`.
fn sigil_err_msg(e): i64 { return load64(e + 8); }
# Frees an error object allocated by sigil_err. Returns 0.
fn sigil_err_free(e): i64 { fl_free(e); return 0; }

# --- crypto_scratch.cyr ---

# crypto_scratch.cyr — per-thread working-buffer bank selection for
# the parallel batch-verify path (sigil 3.6).
#
# WHY THIS EXISTS
# ---------------
# A `var X[N]` declared inside a function in cyrius is a STATIC
# function-scope global, not a per-call stack array (CLAUDE.md quirk
# #1; tests/tcyr/var_array_semantics.tcyr — re-confirmed under cycc
# 6.0.52 during the 3.6 open). The transient working arrays inside
# the crypto primitives (SHA-256/512 message schedules, the Ed25519
# field/group temporaries) are therefore shared across threads, which
# is exactly why `sv_verify_batch` had to serialise every artifact
# behind `_sigil_batch_mutex` (see the threading-safety contract in
# src/verify.cyr).
#
# THE 3.6 MECHANISM — per-thread BANKS
# ------------------------------------
# Each racing `var X[N]` is widened to `var X[N * SIGIL_CRYPTO_BANKS]`
# and the function operates on its own lane `&X + cbank()*N`. `cbank()`
# returns the calling thread's bank index, read from a thread-local
# slot (cyrius 6.0.52 `lib/thread_local.cyr`):
#   - the main thread / serial path uses bank 0 (a fresh TLS slot
#     reads 0);
#   - batch workers are assigned distinct banks 1..workers at spawn
#     (`crypto_bank_set`).
# Distinct concurrent banks ⇒ disjoint memory ⇒ no data race — with
# NO signature changes, NO caller changes, and NO cross-function
# offset map. Each function still owns its own array; a worker simply
# writes a different lane of it. Collisions are impossible by
# construction (every lane is owned by exactly one live thread).
#
# This is deliberately cheaper and far lower-risk than threading a
# caller-provided scratch pointer through every `fp_mul` / `ge_add` /
# `sha256_transform` signature (the shape the v3.6 roadmap sketched
# before cyrius shipped thread-local storage): no signature churn, and
# the bank arithmetic is local and self-evidently collision-free.
#
# TLS LIFECYCLE
# -------------
# Worker threads spawned via `thread_create` get a zeroed 4 KB TLS
# block installed automatically by CLONE_SETTLS (cyrius lib/thread.cyr),
# so they need no init — their slot reads 0 until `crypto_bank_set`
# overwrites it. The MAIN thread has no TLS block until one is
# installed, so `cbank()` self-installs one on first use (and the
# batch path pre-warms it on the main thread before fan-out). The
# `& (SIGIL_CRYPTO_BANKS-1)` mask makes an out-of-range slot value
# impossible to turn into an out-of-bounds lane — defence in depth.
#
# Requires: lib/thread_local.cyr (cyrius >= 6.0.52). Must be included
# before any banked crypto module (src/sha_ni.cyr onward).

# Number of concurrent crypto-scratch lanes. MUST be a power of two
# (the `cbank()` mask relies on it) and MUST exceed _SIGIL_BATCH_WORKERS
# (src/verify.cyr) since bank 0 is reserved for the main/serial path
# and workers take banks 1..workers. 8 covers the default 4 workers
# with headroom; widening only costs a few KB of static scratch.
var SIGIL_CRYPTO_BANKS = 8;
var _SIGIL_CBANK_MASK = 7;      # SIGIL_CRYPTO_BANKS - 1
var _SIGIL_CBANK_SLOT = 0;      # thread-local slot holding the bank index
var _crypto_tls_inited = 0;

# Install a TLS block on the calling (main) thread so `cbank()` is
# well-defined on the serial path. Idempotent. The batch path calls
# this on the main thread before fan-out; `cbank()` also calls it
# lazily as a backstop. Returns 0.
fn crypto_tls_main_init(): i64 {
    if (_crypto_tls_inited == 1) { return 0; }
    thread_local_init();
    _crypto_tls_inited = 1;
    return 0;
}

# Assign the calling (worker) thread its bank index. Called once at
# worker entry, before any banked primitive runs on that thread. Bank
# must be in 1 .. SIGIL_CRYPTO_BANKS-1. Returns 0.
fn crypto_bank_set(bank): i64 {
    thread_local_set(_SIGIL_CBANK_SLOT, bank);
    return 0;
}

# Bank index for the calling thread: 0 on the main/serial path,
# 1..workers inside a batch worker. Self-installs the main-thread TLS
# block on first use so direct (non-batch) crypto calls are safe. The
# mask guarantees the result is always a valid lane index.
fn cbank(): i64 {
    if (_crypto_tls_inited == 0) { crypto_tls_main_init(); }
    return thread_local_get(_SIGIL_CBANK_SLOT) & _SIGIL_CBANK_MASK;
}

# --- sha_ni.cyr ---

# sha_ni.cyr — SHA-NI hardware-acceleration dispatch.
#
# Lays the CPUID-probe + dispatch infrastructure for the Intel SHA
# extensions (SHA256RNDS2 / SHA256MSG1 / SHA256MSG2) and ships a
# byte-encoded single-block SHA-256 compress that `sha256_transform`
# (in src/sha256.cyr) routes to when `sha_ni_available()` returns 1.
#
# History:
#   2.9.2 — probe live, compress was a -1 stub.
#   2.9.3 — compress shipped; cross-path tested against the FIPS
#           180-4 software path on every input the test suite
#           exercises (empty, "abc", 56-byte two-block vector,
#           1KB, 64KB).
#
# Design and sourcing notes live in
# `docs/development/issues/archive/2026-04-25-sha-ni-compress-design.md`.
# The compress sequence below is byte-for-byte derived from the
# Linux kernel's arch/x86/crypto/sha256_ni_asm.S (Intel
# Corporation, dual BSD/GPLv2 — Sigil is GPL-3.0 so the GPL leg
# applies). State-pack/unpack at the function boundaries adapts
# the kernel's 4-dword digest layout to sigil's 8-byte-per-h_i
# context layout (see design doc §"State-layout impedance").
#
# Detection reference (Intel SDM Vol 2A §3.2):
#   CPUID leaf 7, sub-leaf 0 → EBX bit 29 = SHA extensions
#
# SHA-NI opcode reference (Intel SDM Vol 2A §3.2, §5):
#   SHA256RNDS2 xmm1, xmm2/m128, <XMM0>     0F 38 CB /r
#       Two SHA-256 rounds. K+W in implicit XMM0.
#       xmm1=CDGH input; xmm2=ABEF input; xmm1=new ABEF output.
#   SHA256MSG1  xmm1, xmm2/m128             0F 38 CC /r
#       xmm1 = xmm1 + sigma0(window from xmm1[1..3] || xmm2[0]).
#   SHA256MSG2  xmm1, xmm2/m128             0F 38 CD /r
#       xmm1 = xmm1 + sigma1(window built from xmm1 + xmm2).

# _sha_ni_cache: 2 = uncached, 0 = unavailable, 1 = available.
# Same sentinel discipline as _aes_ni_cache; one CPUID probe
# per process. The "available" gate now requires BOTH the CPUID
# bit AND the FIPS 180-4 "abc" self-test passing — defense-in-
# depth against cyrius prologue drift breaking the `[rbp-N]`
# parameter loads inside `_sha_ni_compress_one`.
var _sha_ni_cache = 2;
var _sha_ni_probe_out = 0;      # 8-byte scratch for the probe's *out param

# Self-test scratch — module-level so the 144-byte ctx and the
# expected-digest slots live in BSS rather than on the stack. ctx
# is touched by `_sha_ni_compress_one` via `movdqu` loads/stores
# only (no alignment requirement on ctx itself), but keeping the
# buffer at module scope avoids per-call zeroization cost in the
# happy path.
var _sha_ni_st_ctx[144];

# Runtime SHA-NI capability gate. Returns 1 if the CPU advertises the
# SHA extensions (CPUID leaf 7 EBX bit 29) AND the hardware compress
# reproduces the FIPS 180-4 "abc" digest; 0 otherwise. Result is
# cached after the first probe (one CPUID + self-test per process).
fn sha_ni_available(): i64 {
    if (_sha_ni_cache != 2) { return _sha_ni_cache; }
    if (_sha_ni_probe_out == 0) { _sha_ni_probe_out = alloc(8); }
    store64(_sha_ni_probe_out, 0);
    _sha_ni_cpuid_probe(_sha_ni_probe_out);
    var ebx = load64(_sha_ni_probe_out);
    # EBX bit 29 = SHA (Intel SDM Vol 2A §3.2 CPUID leaf 7 sub-leaf 0).
    if ((ebx & (1 << 29)) == 0) {
        _sha_ni_cache = 0;
        return 0;
    }
    # Defense-in-depth: confirm the NI compress produces the FIPS
    # 180-4 §B.1 single-block "abc" digest before going live. Same
    # rationale as aes_ni — catches asm-misencode caused by cyrius
    # prologue drift breaking the `[rbp-N]` parameter loads inside
    # `_sha_ni_compress_one`. Downgrades to the software path on
    # mismatch. See docs/development/issues/2026-05-10-cyrius-510-
    # asm-stack-frame-drift-breaks-ni-paths.md.
    if (_sha_ni_self_test() == 0) {
        _sha_ni_cache = 1;
    } else {
        _sha_ni_cache = 0;
    }
    return _sha_ni_cache;
}

# _sha_ni_cpuid_probe — write CPUID leaf 7 sub-leaf 0 EBX to *out.
# Caller-supplied pointer keeps the CPUID-clobbered registers'
# lifetime confined to the asm block; reload via load64 after.
fn _sha_ni_cpuid_probe(out): i64 {
    #ifdef CYRIUS_ARCH_X86
    asm {
        # Param out = [rbp-8]. Load into rdi.
        0x48; 0x8B; 0x7D; 0xF8;        # mov rdi, [rbp-8]
        0x53;                          # push rbx (callee-saved; CPUID clobbers it)
        0xB8; 0x07; 0x00; 0x00; 0x00;  # mov eax, 7   (leaf 7)
        0x31; 0xC9;                    # xor ecx, ecx (sub-leaf 0)
        0x0F; 0xA2;                    # cpuid
        0x48; 0x89; 0x1F;              # mov [rdi], rbx  ; *out = ebx
        0x5B;                          # pop rbx
    }
    #endif
    return 0;
}

# ================================================================
# Read-only shared globals (lazy init on first transform).
#
#   _sha_ni_K          — 256 bytes: 64 packed dwords of the K constants
#   _sha_ni_bswap_src  — 16 bytes:  PSHUFFLE_BYTE_FLIP_MASK template
#                                   (memcpy'd into per-call buf+64)
#
# 3.3: the pre-3.3 design used a single module-global 80-byte
# `_sha_ni_buf` that held the packed-state in/out + ABEF/CDGH
# saves + bswap mask. That made the SHA-NI compress non-
# reentrant — concurrent batch-verify workers (3.3 dropped the
# serialising mutex) stomped each other's state every block.
#
# Splitting the bswap mask (read-only) out of the working area
# lets the working area become a per-call stack buffer.
# `_sha_ni_compress_one` keeps its 3-parameter signature (the
# safe cc5/cc6 prologue-spill shape).
#
# alloc() is 8-byte aligned but PSHUFB / PADDD with an m128
# operand both require the memory address to be 16-aligned or
# they raise #GP. Each buffer is over-allocated by 16 bytes and
# aligned via `_sha_ni_align16`.
# ================================================================

var _sha_ni_K = 0;
var _sha_ni_bswap_src = 0;

# _sha_ni_pack_k_word — write K[i] as 4 little-endian bytes at dst+0..3.
fn _sha_ni_pack_k_word(dst, k): i64 {
    store8(dst + 0, k & 0xFF);
    store8(dst + 1, (k >> 8) & 0xFF);
    store8(dst + 2, (k >> 16) & 0xFF);
    store8(dst + 3, (k >> 24) & 0xFF);
    return 0;
}

# _sha_ni_align16 — round addr up to a 16-byte boundary. The bump
# allocator is 8-byte aligned, but PSHUFB / PADDD with an m128
# operand both require the memory address to be 16-aligned or
# they raise #GP. Caller over-allocates by 16 bytes and aligns
# the returned base.
fn _sha_ni_align16(addr): i64 {
    var off = addr & 15;
    if (off == 0) { return addr; }
    return addr + (16 - off);
}

fn _sha_ni_init(): i64 {
    if (_sha_ni_K != 0) { return 0; }

    _sha_ni_bswap_src = _sha_ni_align16(alloc(16 + 16));
    _sha_ni_K         = _sha_ni_align16(alloc(256 + 16));

    # PSHUFFLE_BYTE_FLIP_MASK — reverses bytes within each 32-bit
    # dword. Matches the kernel constant
    # 0x0c0d0e0f08090a0b0405060700010203. Read-only after init;
    # memcpy'd into per-call bufs at the top of each transform.
    store8(_sha_ni_bswap_src + 0,  0x03); store8(_sha_ni_bswap_src + 1,  0x02);
    store8(_sha_ni_bswap_src + 2,  0x01); store8(_sha_ni_bswap_src + 3,  0x00);
    store8(_sha_ni_bswap_src + 4,  0x07); store8(_sha_ni_bswap_src + 5,  0x06);
    store8(_sha_ni_bswap_src + 6,  0x05); store8(_sha_ni_bswap_src + 7,  0x04);
    store8(_sha_ni_bswap_src + 8,  0x0B); store8(_sha_ni_bswap_src + 9,  0x0A);
    store8(_sha_ni_bswap_src + 10, 0x09); store8(_sha_ni_bswap_src + 11, 0x08);
    store8(_sha_ni_bswap_src + 12, 0x0F); store8(_sha_ni_bswap_src + 13, 0x0E);
    store8(_sha_ni_bswap_src + 14, 0x0D); store8(_sha_ni_bswap_src + 15, 0x0C);

    # K constants from FIPS 180-4 §4.2.2 — packed 64×4-byte LE dwords.
    # Embedded directly rather than read from sha256.cyr's _sha256_K
    # so this module has no init-order dependency on sha256.cyr.
    _sha_ni_pack_k_word(_sha_ni_K + 0,   0x428a2f98);
    _sha_ni_pack_k_word(_sha_ni_K + 4,   0x71374491);
    _sha_ni_pack_k_word(_sha_ni_K + 8,   0xb5c0fbcf);
    _sha_ni_pack_k_word(_sha_ni_K + 12,  0xe9b5dba5);
    _sha_ni_pack_k_word(_sha_ni_K + 16,  0x3956c25b);
    _sha_ni_pack_k_word(_sha_ni_K + 20,  0x59f111f1);
    _sha_ni_pack_k_word(_sha_ni_K + 24,  0x923f82a4);
    _sha_ni_pack_k_word(_sha_ni_K + 28,  0xab1c5ed5);
    _sha_ni_pack_k_word(_sha_ni_K + 32,  0xd807aa98);
    _sha_ni_pack_k_word(_sha_ni_K + 36,  0x12835b01);
    _sha_ni_pack_k_word(_sha_ni_K + 40,  0x243185be);
    _sha_ni_pack_k_word(_sha_ni_K + 44,  0x550c7dc3);
    _sha_ni_pack_k_word(_sha_ni_K + 48,  0x72be5d74);
    _sha_ni_pack_k_word(_sha_ni_K + 52,  0x80deb1fe);
    _sha_ni_pack_k_word(_sha_ni_K + 56,  0x9bdc06a7);
    _sha_ni_pack_k_word(_sha_ni_K + 60,  0xc19bf174);
    _sha_ni_pack_k_word(_sha_ni_K + 64,  0xe49b69c1);
    _sha_ni_pack_k_word(_sha_ni_K + 68,  0xefbe4786);
    _sha_ni_pack_k_word(_sha_ni_K + 72,  0x0fc19dc6);
    _sha_ni_pack_k_word(_sha_ni_K + 76,  0x240ca1cc);
    _sha_ni_pack_k_word(_sha_ni_K + 80,  0x2de92c6f);
    _sha_ni_pack_k_word(_sha_ni_K + 84,  0x4a7484aa);
    _sha_ni_pack_k_word(_sha_ni_K + 88,  0x5cb0a9dc);
    _sha_ni_pack_k_word(_sha_ni_K + 92,  0x76f988da);
    _sha_ni_pack_k_word(_sha_ni_K + 96,  0x983e5152);
    _sha_ni_pack_k_word(_sha_ni_K + 100, 0xa831c66d);
    _sha_ni_pack_k_word(_sha_ni_K + 104, 0xb00327c8);
    _sha_ni_pack_k_word(_sha_ni_K + 108, 0xbf597fc7);
    _sha_ni_pack_k_word(_sha_ni_K + 112, 0xc6e00bf3);
    _sha_ni_pack_k_word(_sha_ni_K + 116, 0xd5a79147);
    _sha_ni_pack_k_word(_sha_ni_K + 120, 0x06ca6351);
    _sha_ni_pack_k_word(_sha_ni_K + 124, 0x14292967);
    _sha_ni_pack_k_word(_sha_ni_K + 128, 0x27b70a85);
    _sha_ni_pack_k_word(_sha_ni_K + 132, 0x2e1b2138);
    _sha_ni_pack_k_word(_sha_ni_K + 136, 0x4d2c6dfc);
    _sha_ni_pack_k_word(_sha_ni_K + 140, 0x53380d13);
    _sha_ni_pack_k_word(_sha_ni_K + 144, 0x650a7354);
    _sha_ni_pack_k_word(_sha_ni_K + 148, 0x766a0abb);
    _sha_ni_pack_k_word(_sha_ni_K + 152, 0x81c2c92e);
    _sha_ni_pack_k_word(_sha_ni_K + 156, 0x92722c85);
    _sha_ni_pack_k_word(_sha_ni_K + 160, 0xa2bfe8a1);
    _sha_ni_pack_k_word(_sha_ni_K + 164, 0xa81a664b);
    _sha_ni_pack_k_word(_sha_ni_K + 168, 0xc24b8b70);
    _sha_ni_pack_k_word(_sha_ni_K + 172, 0xc76c51a3);
    _sha_ni_pack_k_word(_sha_ni_K + 176, 0xd192e819);
    _sha_ni_pack_k_word(_sha_ni_K + 180, 0xd6990624);
    _sha_ni_pack_k_word(_sha_ni_K + 184, 0xf40e3585);
    _sha_ni_pack_k_word(_sha_ni_K + 188, 0x106aa070);
    _sha_ni_pack_k_word(_sha_ni_K + 192, 0x19a4c116);
    _sha_ni_pack_k_word(_sha_ni_K + 196, 0x1e376c08);
    _sha_ni_pack_k_word(_sha_ni_K + 200, 0x2748774c);
    _sha_ni_pack_k_word(_sha_ni_K + 204, 0x34b0bcb5);
    _sha_ni_pack_k_word(_sha_ni_K + 208, 0x391c0cb3);
    _sha_ni_pack_k_word(_sha_ni_K + 212, 0x4ed8aa4a);
    _sha_ni_pack_k_word(_sha_ni_K + 216, 0x5b9cca4f);
    _sha_ni_pack_k_word(_sha_ni_K + 220, 0x682e6ff3);
    _sha_ni_pack_k_word(_sha_ni_K + 224, 0x748f82ee);
    _sha_ni_pack_k_word(_sha_ni_K + 228, 0x78a5636f);
    _sha_ni_pack_k_word(_sha_ni_K + 232, 0x84c87814);
    _sha_ni_pack_k_word(_sha_ni_K + 236, 0x8cc70208);
    _sha_ni_pack_k_word(_sha_ni_K + 240, 0x90befffa);
    _sha_ni_pack_k_word(_sha_ni_K + 244, 0xa4506ceb);
    _sha_ni_pack_k_word(_sha_ni_K + 248, 0xbef9a3f7);
    _sha_ni_pack_k_word(_sha_ni_K + 252, 0xc67178f2);
    return 0;
}

# ================================================================
# _sha_ni_compress_one — single-block SHA-NI compress.
#
# Parameters arrive on the stack at:
#   [rbp-8]  ctx     — 144-byte SHA-256 context (h0..h7 at +0,
#                       block buffer at +64)
#   [rbp-16] buf     — 80-byte module global. Layout:
#                        +0..31  packed state in/out
#                        +32..47 ABEF_save
#                        +48..63 CDGH_save
#                        +64..79 PSHUFFLE_BYTE_FLIP_MASK
#   [rbp-24] kbuf    — 256-byte packed K table
#
# 3 params (rather than 4) so the [rbp-N] spill convention is the
# one cc5 has used reliably for asm-block functions since 2.9.1
# (`aes_ni.cyr`'s 3-param `aes256_encrypt_block_ni`); cc5.5.30 may
# spill a 4th param into a register rather than the stack, which
# breaks the `mov ..., [rbp-32]` form.
#
# Register usage inside the asm block:
#   rdi = ctx, rsi = buf, rcx = kbuf, rdx = scalar tmp
#   xmm0 = MSG, xmm1 = STATE0 (ABEF), xmm2 = STATE1 (CDGH),
#   xmm3 = MSGTMP0, xmm4 = MSGTMP1, xmm5 = MSGTMP2, xmm6 = MSGTMP3,
#   xmm7 = MSGTMP4 (palignr scratch)
#
# All XMM registers are caller-saved in System V x86-64 — clobber
# is safe because the asm block is straight-line with no calls
# and Cyrius does not expect XMM state across the block.
# ================================================================
fn _sha_ni_compress_one(ctx, buf, kbuf): i64 {
    #ifdef CYRIUS_ARCH_X86
    asm {
        # -- Param loads --
        0x48; 0x8B; 0x7D; 0xF8;    # mov rdi, [rbp-8]   (ctx)
        0x48; 0x8B; 0x75; 0xF0;    # mov rsi, [rbp-16]  (buf)
        0x48; 0x8B; 0x4D; 0xE8;    # mov rcx, [rbp-24]  (kbuf)

        # ── Pack ctx h0..h7 (8 sparse 64-bit slots, low 32 bits each)
        #    into scratch[0..31] (8 packed little-endian dwords).
        #    Each pair is `mov edx, [rdi+8i]` + `mov [rsi+4i], edx`.
        0x8B; 0x57; 0x00; 0x89; 0x56; 0x00;
        0x8B; 0x57; 0x08; 0x89; 0x56; 0x04;
        0x8B; 0x57; 0x10; 0x89; 0x56; 0x08;
        0x8B; 0x57; 0x18; 0x89; 0x56; 0x0C;
        0x8B; 0x57; 0x20; 0x89; 0x56; 0x10;
        0x8B; 0x57; 0x28; 0x89; 0x56; 0x14;
        0x8B; 0x57; 0x30; 0x89; 0x56; 0x18;
        0x8B; 0x57; 0x38; 0x89; 0x56; 0x1C;

        # ── State setup: load packed ABCD/EFGH, permute to ABEF/CDGH ─
        0xF3; 0x0F; 0x6F; 0x4E; 0x00;          # movdqu xmm1, [rsi+0]   STATE0=ABCD
        0xF3; 0x0F; 0x6F; 0x56; 0x10;          # movdqu xmm2, [rsi+16]  STATE1=EFGH
        0x66; 0x0F; 0x70; 0xC9; 0xB1;          # pshufd xmm1, xmm1, 0xB1   →[b,a,d,c]
        0x66; 0x0F; 0x70; 0xD2; 0x1B;          # pshufd xmm2, xmm2, 0x1B   →[h,g,f,e]
        0x66; 0x0F; 0x6F; 0xF9;                # movdqa xmm7, xmm1     save pre-palignr
        0x66; 0x0F; 0x3A; 0x0F; 0xCA; 0x08;    # palignr xmm1, xmm2, 8 STATE0=ABEF=[f,e,b,a]
        0x66; 0x0F; 0x3A; 0x0E; 0xD7; 0xF0;    # pblendw xmm2, xmm7,F0 STATE1=CDGH=[h,g,d,c]

        # ── Save ABEF/CDGH for the post-loop add ──────────────────
        0xF3; 0x0F; 0x7F; 0x4E; 0x20;          # movdqu [rsi+32], xmm1  (ABEF_save)
        0xF3; 0x0F; 0x7F; 0x56; 0x30;          # movdqu [rsi+48], xmm2  (CDGH_save)

        # ── Iter 0 — Rounds 0..3 — load MSGTMP0 = W[0..3] ─────────
        0xF3; 0x0F; 0x6F; 0x47; 0x40;          # movdqu xmm0, [rdi+64]
        0x66; 0x0F; 0x38; 0x00; 0x46; 0x40;    # pshufb xmm0, [rsi+64]
        0x66; 0x0F; 0x6F; 0xD8;                # movdqa xmm3, xmm0      MSGTMP0
        0x66; 0x0F; 0xFE; 0x41; 0x00;          # paddd  xmm0, [rcx+0]
        0x0F; 0x38; 0xCB; 0xD1;                # sha256rnds2 xmm2, xmm1
        0x66; 0x0F; 0x70; 0xC0; 0x0E;          # pshufd xmm0, xmm0, 0x0E
        0x0F; 0x38; 0xCB; 0xCA;                # sha256rnds2 xmm1, xmm2

        # ── Iter 1 — Rounds 4..7 — load MSGTMP1 = W[4..7] ─────────
        0xF3; 0x0F; 0x6F; 0x47; 0x50;          # movdqu xmm0, [rdi+80]
        0x66; 0x0F; 0x38; 0x00; 0x46; 0x40;    # pshufb xmm0, [rsi+64]
        0x66; 0x0F; 0x6F; 0xE0;                # movdqa xmm4, xmm0      MSGTMP1
        0x66; 0x0F; 0xFE; 0x41; 0x10;          # paddd  xmm0, [rcx+16]
        0x0F; 0x38; 0xCB; 0xD1;                # sha256rnds2 xmm2, xmm1
        0x66; 0x0F; 0x70; 0xC0; 0x0E;          # pshufd xmm0, xmm0, 0x0E
        0x0F; 0x38; 0xCB; 0xCA;                # sha256rnds2 xmm1, xmm2
        0x0F; 0x38; 0xCC; 0xDC;                # sha256msg1 xmm3, xmm4   MSGTMP0+=σ0

        # ── Iter 2 — Rounds 8..11 — load MSGTMP2 = W[8..11] ───────
        0xF3; 0x0F; 0x6F; 0x47; 0x60;          # movdqu xmm0, [rdi+96]
        0x66; 0x0F; 0x38; 0x00; 0x46; 0x40;    # pshufb xmm0, [rsi+64]
        0x66; 0x0F; 0x6F; 0xE8;                # movdqa xmm5, xmm0      MSGTMP2
        0x66; 0x0F; 0xFE; 0x41; 0x20;          # paddd  xmm0, [rcx+32]
        0x0F; 0x38; 0xCB; 0xD1;                # sha256rnds2 xmm2, xmm1
        0x66; 0x0F; 0x70; 0xC0; 0x0E;          # pshufd xmm0, xmm0, 0x0E
        0x0F; 0x38; 0xCB; 0xCA;                # sha256rnds2 xmm1, xmm2
        0x0F; 0x38; 0xCC; 0xE5;                # sha256msg1 xmm4, xmm5   MSGTMP1+=σ0

        # ── Iter 3 — Rounds 12..15 — load MSGTMP3 = W[12..15];
        #    also compute MSGTMP0 = W[16..19] for iter 4. ──────────
        0xF3; 0x0F; 0x6F; 0x47; 0x70;          # movdqu xmm0, [rdi+112]
        0x66; 0x0F; 0x38; 0x00; 0x46; 0x40;    # pshufb xmm0, [rsi+64]
        0x66; 0x0F; 0x6F; 0xF0;                # movdqa xmm6, xmm0      MSGTMP3
        0x66; 0x0F; 0xFE; 0x41; 0x30;          # paddd  xmm0, [rcx+48]
        0x0F; 0x38; 0xCB; 0xD1;                # sha256rnds2 xmm2, xmm1
        0x66; 0x0F; 0x6F; 0xFE;                # movdqa xmm7, xmm6      tmp ← MSGTMP3
        0x66; 0x0F; 0x3A; 0x0F; 0xFD; 0x04;    # palignr xmm7, xmm5, 4  W[9..12]
        0x66; 0x0F; 0xFE; 0xDF;                # paddd  xmm3, xmm7      MSGTMP0 += W[9..12]
        0x0F; 0x38; 0xCD; 0xDE;                # sha256msg2 xmm3, xmm6  MSGTMP0 = W[16..19]
        0x66; 0x0F; 0x70; 0xC0; 0x0E;          # pshufd xmm0, xmm0, 0x0E
        0x0F; 0x38; 0xCB; 0xCA;                # sha256rnds2 xmm1, xmm2
        0x0F; 0x38; 0xCC; 0xEE;                # sha256msg1 xmm5, xmm6   MSGTMP2+=σ0

        # ── Iter 4 — Rounds 16..19 — MSGTMP0 already W[16..19];
        #    compute MSGTMP1 = W[20..23]
        0x66; 0x0F; 0x6F; 0xC3;                # movdqa xmm0, xmm3
        0x66; 0x0F; 0xFE; 0x41; 0x40;          # paddd  xmm0, [rcx+64]
        0x0F; 0x38; 0xCB; 0xD1;                # sha256rnds2 xmm2, xmm1
        0x66; 0x0F; 0x6F; 0xFB;                # movdqa xmm7, xmm3
        0x66; 0x0F; 0x3A; 0x0F; 0xFE; 0x04;    # palignr xmm7, xmm6, 4
        0x66; 0x0F; 0xFE; 0xE7;                # paddd  xmm4, xmm7
        0x0F; 0x38; 0xCD; 0xE3;                # sha256msg2 xmm4, xmm3   MSGTMP1=W[20..23]
        0x66; 0x0F; 0x70; 0xC0; 0x0E;          # pshufd xmm0, xmm0, 0x0E
        0x0F; 0x38; 0xCB; 0xCA;                # sha256rnds2 xmm1, xmm2
        0x0F; 0x38; 0xCC; 0xF3;                # sha256msg1 xmm6, xmm3

        # ── Iter 5 — Rounds 20..23 — compute MSGTMP2 = W[24..27] ──
        0x66; 0x0F; 0x6F; 0xC4;                # movdqa xmm0, xmm4
        0x66; 0x0F; 0xFE; 0x41; 0x50;          # paddd  xmm0, [rcx+80]
        0x0F; 0x38; 0xCB; 0xD1;
        0x66; 0x0F; 0x6F; 0xFC;                # movdqa xmm7, xmm4
        0x66; 0x0F; 0x3A; 0x0F; 0xFB; 0x04;    # palignr xmm7, xmm3, 4
        0x66; 0x0F; 0xFE; 0xEF;                # paddd  xmm5, xmm7
        0x0F; 0x38; 0xCD; 0xEC;                # sha256msg2 xmm5, xmm4
        0x66; 0x0F; 0x70; 0xC0; 0x0E;
        0x0F; 0x38; 0xCB; 0xCA;
        0x0F; 0x38; 0xCC; 0xDC;                # sha256msg1 xmm3, xmm4

        # ── Iter 6 — Rounds 24..27 — compute MSGTMP3 = W[28..31] ──
        0x66; 0x0F; 0x6F; 0xC5;                # movdqa xmm0, xmm5
        0x66; 0x0F; 0xFE; 0x41; 0x60;          # paddd  xmm0, [rcx+96]
        0x0F; 0x38; 0xCB; 0xD1;
        0x66; 0x0F; 0x6F; 0xFD;                # movdqa xmm7, xmm5
        0x66; 0x0F; 0x3A; 0x0F; 0xFC; 0x04;    # palignr xmm7, xmm4, 4
        0x66; 0x0F; 0xFE; 0xF7;                # paddd  xmm6, xmm7
        0x0F; 0x38; 0xCD; 0xF5;                # sha256msg2 xmm6, xmm5
        0x66; 0x0F; 0x70; 0xC0; 0x0E;
        0x0F; 0x38; 0xCB; 0xCA;
        0x0F; 0x38; 0xCC; 0xE5;                # sha256msg1 xmm4, xmm5

        # ── Iter 7 — Rounds 28..31 — compute MSGTMP0 = W[32..35] ──
        0x66; 0x0F; 0x6F; 0xC6;                # movdqa xmm0, xmm6
        0x66; 0x0F; 0xFE; 0x41; 0x70;          # paddd  xmm0, [rcx+112]
        0x0F; 0x38; 0xCB; 0xD1;
        0x66; 0x0F; 0x6F; 0xFE;                # movdqa xmm7, xmm6
        0x66; 0x0F; 0x3A; 0x0F; 0xFD; 0x04;    # palignr xmm7, xmm5, 4
        0x66; 0x0F; 0xFE; 0xDF;                # paddd  xmm3, xmm7
        0x0F; 0x38; 0xCD; 0xDE;                # sha256msg2 xmm3, xmm6
        0x66; 0x0F; 0x70; 0xC0; 0x0E;
        0x0F; 0x38; 0xCB; 0xCA;
        0x0F; 0x38; 0xCC; 0xEE;                # sha256msg1 xmm5, xmm6

        # ── Iter 8 — Rounds 32..35 — disp32 K offset 128 onward ──
        0x66; 0x0F; 0x6F; 0xC3;                # movdqa xmm0, xmm3
        0x66; 0x0F; 0xFE; 0x81; 0x80; 0x00; 0x00; 0x00;  # paddd xmm0, [rcx+128]
        0x0F; 0x38; 0xCB; 0xD1;
        0x66; 0x0F; 0x6F; 0xFB;                # movdqa xmm7, xmm3
        0x66; 0x0F; 0x3A; 0x0F; 0xFE; 0x04;    # palignr xmm7, xmm6, 4
        0x66; 0x0F; 0xFE; 0xE7;                # paddd  xmm4, xmm7
        0x0F; 0x38; 0xCD; 0xE3;                # sha256msg2 xmm4, xmm3
        0x66; 0x0F; 0x70; 0xC0; 0x0E;
        0x0F; 0x38; 0xCB; 0xCA;
        0x0F; 0x38; 0xCC; 0xF3;                # sha256msg1 xmm6, xmm3

        # -- Iter 9 -- Rounds 36..39 --
        0x66; 0x0F; 0x6F; 0xC4;
        0x66; 0x0F; 0xFE; 0x81; 0x90; 0x00; 0x00; 0x00;  # [rcx+144]
        0x0F; 0x38; 0xCB; 0xD1;
        0x66; 0x0F; 0x6F; 0xFC;
        0x66; 0x0F; 0x3A; 0x0F; 0xFB; 0x04;
        0x66; 0x0F; 0xFE; 0xEF;
        0x0F; 0x38; 0xCD; 0xEC;
        0x66; 0x0F; 0x70; 0xC0; 0x0E;
        0x0F; 0x38; 0xCB; 0xCA;
        0x0F; 0x38; 0xCC; 0xDC;

        # -- Iter 10 -- Rounds 40..43 --
        0x66; 0x0F; 0x6F; 0xC5;
        0x66; 0x0F; 0xFE; 0x81; 0xA0; 0x00; 0x00; 0x00;  # [rcx+160]
        0x0F; 0x38; 0xCB; 0xD1;
        0x66; 0x0F; 0x6F; 0xFD;
        0x66; 0x0F; 0x3A; 0x0F; 0xFC; 0x04;
        0x66; 0x0F; 0xFE; 0xF7;
        0x0F; 0x38; 0xCD; 0xF5;
        0x66; 0x0F; 0x70; 0xC0; 0x0E;
        0x0F; 0x38; 0xCB; 0xCA;
        0x0F; 0x38; 0xCC; 0xE5;

        # -- Iter 11 -- Rounds 44..47 --
        0x66; 0x0F; 0x6F; 0xC6;
        0x66; 0x0F; 0xFE; 0x81; 0xB0; 0x00; 0x00; 0x00;  # [rcx+176]
        0x0F; 0x38; 0xCB; 0xD1;
        0x66; 0x0F; 0x6F; 0xFE;
        0x66; 0x0F; 0x3A; 0x0F; 0xFD; 0x04;
        0x66; 0x0F; 0xFE; 0xDF;
        0x0F; 0x38; 0xCD; 0xDE;
        0x66; 0x0F; 0x70; 0xC0; 0x0E;
        0x0F; 0x38; 0xCB; 0xCA;
        0x0F; 0x38; 0xCC; 0xEE;

        # -- Iter 12 -- Rounds 48..51 --
        0x66; 0x0F; 0x6F; 0xC3;
        0x66; 0x0F; 0xFE; 0x81; 0xC0; 0x00; 0x00; 0x00;  # [rcx+192]
        0x0F; 0x38; 0xCB; 0xD1;
        0x66; 0x0F; 0x6F; 0xFB;
        0x66; 0x0F; 0x3A; 0x0F; 0xFE; 0x04;
        0x66; 0x0F; 0xFE; 0xE7;
        0x0F; 0x38; 0xCD; 0xE3;
        0x66; 0x0F; 0x70; 0xC0; 0x0E;
        0x0F; 0x38; 0xCB; 0xCA;
        0x0F; 0x38; 0xCC; 0xF3;

        # ── Iter 13 — Rounds 52..55 — drop sha256msg1 (no longer
        #    needed: msg1 precomputes for iter+3 = 16, out of range) ─
        0x66; 0x0F; 0x6F; 0xC4;
        0x66; 0x0F; 0xFE; 0x81; 0xD0; 0x00; 0x00; 0x00;  # [rcx+208]
        0x0F; 0x38; 0xCB; 0xD1;
        0x66; 0x0F; 0x6F; 0xFC;
        0x66; 0x0F; 0x3A; 0x0F; 0xFB; 0x04;
        0x66; 0x0F; 0xFE; 0xEF;
        0x0F; 0x38; 0xCD; 0xEC;
        0x66; 0x0F; 0x70; 0xC0; 0x0E;
        0x0F; 0x38; 0xCB; 0xCA;

        # -- Iter 14 -- Rounds 56..59 --
        0x66; 0x0F; 0x6F; 0xC5;
        0x66; 0x0F; 0xFE; 0x81; 0xE0; 0x00; 0x00; 0x00;  # [rcx+224]
        0x0F; 0x38; 0xCB; 0xD1;
        0x66; 0x0F; 0x6F; 0xFD;
        0x66; 0x0F; 0x3A; 0x0F; 0xFC; 0x04;
        0x66; 0x0F; 0xFE; 0xF7;
        0x0F; 0x38; 0xCD; 0xF5;
        0x66; 0x0F; 0x70; 0xC0; 0x0E;
        0x0F; 0x38; 0xCB; 0xCA;

        # ── Iter 15 — Rounds 60..63 — drop ALL schedule work ───
        0x66; 0x0F; 0x6F; 0xC6;
        0x66; 0x0F; 0xFE; 0x81; 0xF0; 0x00; 0x00; 0x00;  # [rcx+240]
        0x0F; 0x38; 0xCB; 0xD1;
        0x66; 0x0F; 0x70; 0xC0; 0x0E;
        0x0F; 0x38; 0xCB; 0xCA;

        # ── Final add: STATE0 += ABEF_save; STATE1 += CDGH_save ──
        0x66; 0x0F; 0xFE; 0x4E; 0x20;          # paddd xmm1, [rsi+32]
        0x66; 0x0F; 0xFE; 0x56; 0x30;          # paddd xmm2, [rsi+48]

        # ── Reverse state setup: ABEF/CDGH → ABCD/EFGH packed ───
        0x66; 0x0F; 0x70; 0xC9; 0x1B;          # pshufd xmm1, xmm1, 0x1B → [A,B,E,F]
        0x66; 0x0F; 0x70; 0xD2; 0xB1;          # pshufd xmm2, xmm2, 0xB1 → [G,H,C,D]
        0x66; 0x0F; 0x6F; 0xF9;                # movdqa xmm7, xmm1
        0x66; 0x0F; 0x3A; 0x0E; 0xCA; 0xF0;    # pblendw xmm1, xmm2, 0xF0 → [A,B,C,D]
        0x66; 0x0F; 0x3A; 0x0F; 0xD7; 0x08;    # palignr xmm2, xmm7, 8   → [E,F,G,H]
        0xF3; 0x0F; 0x7F; 0x4E; 0x00;          # movdqu [rsi+0],  xmm1
        0xF3; 0x0F; 0x7F; 0x56; 0x10;          # movdqu [rsi+16], xmm2

        # ── Unpack scratch packed dwords back to ctx h0..h7 with
        #    zero-extending 64-bit stores so the high 32 bits of
        #    each ctx slot stay zero (sha256.cyr's invariant). ────
        0x8B; 0x56; 0x00; 0x48; 0x89; 0x57; 0x00;
        0x8B; 0x56; 0x04; 0x48; 0x89; 0x57; 0x08;
        0x8B; 0x56; 0x08; 0x48; 0x89; 0x57; 0x10;
        0x8B; 0x56; 0x0C; 0x48; 0x89; 0x57; 0x18;
        0x8B; 0x56; 0x10; 0x48; 0x89; 0x57; 0x20;
        0x8B; 0x56; 0x14; 0x48; 0x89; 0x57; 0x28;
        0x8B; 0x56; 0x18; 0x48; 0x89; 0x57; 0x30;
        0x8B; 0x56; 0x1C; 0x48; 0x89; 0x57; 0x38;
    }
    #endif
    return 0;
}

# sha256_transform_ni — SHA-NI single-block compression (live in 2.9.3).
#
# Caller contract:
#   - ctx points to a 144-byte SHA-256 context (h0..h7 at +0,
#     buf at +64)
#   - returns 0 on success (compressed in hardware)
#
# `sha256_transform`'s dispatcher in src/sha256.cyr falls through
# to the FIPS 180-4 software path on hosts where the CPUID probe
# returns 0; this entry point is only invoked when SHA-NI is live.
fn sha256_transform_ni(ctx): i64 {
    if (_sha_ni_K == 0) { _sha_ni_init(); }
    # Per-call working area. 80 bytes needed; over-allocate by 16
    # so we can align the base to a 16-byte boundary (PSHUFB / PADDD
    # m128 reads of buf+0/+16/+64 require alignment). Banked per
    # thread (3.6): each batch worker writes its own 96-byte lane so
    # concurrent compresses never stomp this shared static scratch
    # (CLAUDE.md quirk #1). 96 is a multiple of 16, so each lane stays
    # 16-aligned and `_sha_ni_align16` is a no-op within it.
    var raw[768];   # 96 * SIGIL_CRYPTO_BANKS
    var buf = _sha_ni_align16(&raw + cbank() * 96);
    memcpy(buf + 64, _sha_ni_bswap_src, 16);
    _sha_ni_compress_one(ctx, buf, _sha_ni_K);
    return 0;
}

# _sha_ni_self_test — run SHA-NI against the FIPS 180-4 §B.1 single-
# block "abc" example and compare the resulting state to the spec's
# published digest. Returns 0 on match (NI safe to enable), non-zero
# on mismatch (downgrade to software). Constant-time compare (OR-
# accumulating, no early exit).
#
# Calls `_sha_ni_compress_one` directly rather than going through
# `sha256_transform`'s dispatcher (which would call back into
# `sha_ni_available` → infinite recursion through this very fn).
# `_sha_ni_init` is idempotent so the K-table + bswap-mask setup
# costs nothing on the second-and-later probe.
#
# FIPS 180-4 §B.1 SHA-256 example:
#   Msg:     "abc"                        (3 bytes, single block)
#   Digest:  BA7816BF 8F01CFEA 414140DE 5DAE2223
#            B00361A3 96177A9C B410FF61 F20015AD
#
# Ctx layout (per src/sha256.cyr): h0..h7 at +0..+63 (8 slots × 8B,
# low 32 bits hold the dword), block buf at +64..+127, buf_len at
# +128, total_len at +136.
fn _sha_ni_self_test(): i64 {
    if (_sha_ni_K == 0) { _sha_ni_init(); }

    # Zero ctx slots.
    var i = 0;
    while (i < 144) { store8(&_sha_ni_st_ctx + i, 0); i = i + 1; }

    # FIPS 180-4 §5.3.3 initial hash values for SHA-256.
    store64(&_sha_ni_st_ctx +  0, 0x6a09e667);
    store64(&_sha_ni_st_ctx +  8, 0xbb67ae85);
    store64(&_sha_ni_st_ctx + 16, 0x3c6ef372);
    store64(&_sha_ni_st_ctx + 24, 0xa54ff53a);
    store64(&_sha_ni_st_ctx + 32, 0x510e527f);
    store64(&_sha_ni_st_ctx + 40, 0x9b05688c);
    store64(&_sha_ni_st_ctx + 48, 0x1f83d9ab);
    store64(&_sha_ni_st_ctx + 56, 0x5be0cd19);

    # Padded "abc" block at +64..+127:
    #   bytes 0..2 = 'a','b','c'
    #   byte 3     = 0x80 (padding terminator per FIPS 180-4 §5.1.1)
    #   bytes 4..62 = zeros
    #   bytes 56..63 = length-in-bits big-endian (3 * 8 = 24 = 0x18)
    store8(&_sha_ni_st_ctx + 64, 0x61);
    store8(&_sha_ni_st_ctx + 65, 0x62);
    store8(&_sha_ni_st_ctx + 66, 0x63);
    store8(&_sha_ni_st_ctx + 67, 0x80);
    store8(&_sha_ni_st_ctx + 127, 0x18);

    var raw[96];
    var buf = _sha_ni_align16(&raw);
    memcpy(buf + 64, _sha_ni_bswap_src, 16);
    _sha_ni_compress_one(&_sha_ni_st_ctx, buf, _sha_ni_K);

    # Compare h0..h7 to FIPS 180-4 §B.1 expected digest. The high 32
    # bits of each 64-bit slot are guaranteed zero by the asm's
    # zero-extending 64-bit stores at unpack time (see line 472 of
    # this file), so a `& 0xFFFFFFFF` mask is sufficient for the
    # XOR-accumulate compare.
    var diff = 0;
    diff = diff | ((load64(&_sha_ni_st_ctx +  0) ^ 0xba7816bf) & 0xFFFFFFFF);
    diff = diff | ((load64(&_sha_ni_st_ctx +  8) ^ 0x8f01cfea) & 0xFFFFFFFF);
    diff = diff | ((load64(&_sha_ni_st_ctx + 16) ^ 0x414140de) & 0xFFFFFFFF);
    diff = diff | ((load64(&_sha_ni_st_ctx + 24) ^ 0x5dae2223) & 0xFFFFFFFF);
    diff = diff | ((load64(&_sha_ni_st_ctx + 32) ^ 0xb00361a3) & 0xFFFFFFFF);
    diff = diff | ((load64(&_sha_ni_st_ctx + 40) ^ 0x96177a9c) & 0xFFFFFFFF);
    diff = diff | ((load64(&_sha_ni_st_ctx + 48) ^ 0xb410ff61) & 0xFFFFFFFF);
    diff = diff | ((load64(&_sha_ni_st_ctx + 56) ^ 0xf20015ad) & 0xFFFFFFFF);
    return diff;
}

# --- sha256.cyr ---

# sha256.cyr — FIPS 180-4 SHA-256 implementation
# All arithmetic masked to 32 bits. Working state is per-call
# (function-local) so concurrent workers don't race; the round
# constants K[0..63] are read-only after init and remain shared.
#
# Historical note: 2.x and 3.0–3.2 lifted the round state into
# module globals as a cycc 3 local-clobbering workaround
# (CLAUDE.md quirk #1). 3.3's empirical probe
# (tests/tcyr/sha256_locals_probe.tcyr) confirmed cycc 6.0.1
# preserves locals across the helper calls, unblocking the
# refactor and the mutex-drop on the parallel-verify path.
#
# `sha256_transform` dispatches to the SHA-NI hardware path via
# `sha_ni_available()` / `sha256_transform_ni()`; pull the dispatch
# infrastructure in so single-file consumers (test harnesses that
# include only `src/sha256.cyr`) link cleanly.

include "src/sha_ni.cyr"

var MASK32 = 0xFFFFFFFF;

# ================================================================
# Bitwise helpers (32-bit)
# ================================================================

# 32-bit circular right rotation of `x` by `n` bits (result masked
# to 32 bits). FIPS 180-4 §3.2 ROTR^n.
fn rotr32(x, n): i64 {
    return ((x >> n) | ((x << (32 - n)) & MASK32)) & MASK32;
}

# 32-bit logical right shift of `x` by `n` bits. FIPS 180-4 §3.2 SHR^n.
fn shr32(x, n): i64 {
    return (x >> n) & MASK32;
}

# ================================================================
# SHA-256 sub-functions
# ================================================================

# SHA-256 Ch(x,y,z) choice function (FIPS 180-4 §4.1.2).
fn sha256_ch(x, y, z): i64 {
    return ((x & y) ^ ((x ^ MASK32) & z)) & MASK32;
}

# SHA-256 Maj(x,y,z) majority function (FIPS 180-4 §4.1.2).
fn sha256_maj(x, y, z): i64 {
    return ((x & y) ^ (x & z) ^ (y & z)) & MASK32;
}

# SHA-256 big-sigma-0 (Σ0) of `x` (FIPS 180-4 §4.1.2).
fn sha256_bsig0(x): i64 {
    return (rotr32(x, 2) ^ rotr32(x, 13) ^ rotr32(x, 22)) & MASK32;
}

# SHA-256 big-sigma-1 (Σ1) of `x` (FIPS 180-4 §4.1.2).
fn sha256_bsig1(x): i64 {
    return (rotr32(x, 6) ^ rotr32(x, 11) ^ rotr32(x, 25)) & MASK32;
}

# SHA-256 small-sigma-0 (σ0) of `x` (FIPS 180-4 §4.1.2).
fn sha256_ssig0(x): i64 {
    return (rotr32(x, 7) ^ rotr32(x, 18) ^ shr32(x, 3)) & MASK32;
}

# SHA-256 small-sigma-1 (σ1) of `x` (FIPS 180-4 §4.1.2).
fn sha256_ssig1(x): i64 {
    return (rotr32(x, 17) ^ rotr32(x, 19) ^ shr32(x, 10)) & MASK32;
}

# ================================================================
# Round constants K[0..63] and initialization
# ================================================================

var _sha256_K = 0;
var _sha256_inited = 0;

# Lazily allocates and fills the 64-entry SHA-256 round-constant table
# K[0..63] (FIPS 180-4 §4.2.2). Idempotent — runs the fill once per
# process; subsequent calls return immediately. Returns 0.
fn sha256_global_init(): i64 {
    if (_sha256_inited == 1) { return 0; }

    _sha256_K = alloc(512);
    store64(_sha256_K + 0, 0x428a2f98);
    store64(_sha256_K + 8, 0x71374491);
    store64(_sha256_K + 16, 0xb5c0fbcf);
    store64(_sha256_K + 24, 0xe9b5dba5);
    store64(_sha256_K + 32, 0x3956c25b);
    store64(_sha256_K + 40, 0x59f111f1);
    store64(_sha256_K + 48, 0x923f82a4);
    store64(_sha256_K + 56, 0xab1c5ed5);
    store64(_sha256_K + 64, 0xd807aa98);
    store64(_sha256_K + 72, 0x12835b01);
    store64(_sha256_K + 80, 0x243185be);
    store64(_sha256_K + 88, 0x550c7dc3);
    store64(_sha256_K + 96, 0x72be5d74);
    store64(_sha256_K + 104, 0x80deb1fe);
    store64(_sha256_K + 112, 0x9bdc06a7);
    store64(_sha256_K + 120, 0xc19bf174);
    store64(_sha256_K + 128, 0xe49b69c1);
    store64(_sha256_K + 136, 0xefbe4786);
    store64(_sha256_K + 144, 0x0fc19dc6);
    store64(_sha256_K + 152, 0x240ca1cc);
    store64(_sha256_K + 160, 0x2de92c6f);
    store64(_sha256_K + 168, 0x4a7484aa);
    store64(_sha256_K + 176, 0x5cb0a9dc);
    store64(_sha256_K + 184, 0x76f988da);
    store64(_sha256_K + 192, 0x983e5152);
    store64(_sha256_K + 200, 0xa831c66d);
    store64(_sha256_K + 208, 0xb00327c8);
    store64(_sha256_K + 216, 0xbf597fc7);
    store64(_sha256_K + 224, 0xc6e00bf3);
    store64(_sha256_K + 232, 0xd5a79147);
    store64(_sha256_K + 240, 0x06ca6351);
    store64(_sha256_K + 248, 0x14292967);
    store64(_sha256_K + 256, 0x27b70a85);
    store64(_sha256_K + 264, 0x2e1b2138);
    store64(_sha256_K + 272, 0x4d2c6dfc);
    store64(_sha256_K + 280, 0x53380d13);
    store64(_sha256_K + 288, 0x650a7354);
    store64(_sha256_K + 296, 0x766a0abb);
    store64(_sha256_K + 304, 0x81c2c92e);
    store64(_sha256_K + 312, 0x92722c85);
    store64(_sha256_K + 320, 0xa2bfe8a1);
    store64(_sha256_K + 328, 0xa81a664b);
    store64(_sha256_K + 336, 0xc24b8b70);
    store64(_sha256_K + 344, 0xc76c51a3);
    store64(_sha256_K + 352, 0xd192e819);
    store64(_sha256_K + 360, 0xd6990624);
    store64(_sha256_K + 368, 0xf40e3585);
    store64(_sha256_K + 376, 0x106aa070);
    store64(_sha256_K + 384, 0x19a4c116);
    store64(_sha256_K + 392, 0x1e376c08);
    store64(_sha256_K + 400, 0x2748774c);
    store64(_sha256_K + 408, 0x34b0bcb5);
    store64(_sha256_K + 416, 0x391c0cb3);
    store64(_sha256_K + 424, 0x4ed8aa4a);
    store64(_sha256_K + 432, 0x5b9cca4f);
    store64(_sha256_K + 440, 0x682e6ff3);
    store64(_sha256_K + 448, 0x748f82ee);
    store64(_sha256_K + 456, 0x78a5636f);
    store64(_sha256_K + 464, 0x84c87814);
    store64(_sha256_K + 472, 0x8cc70208);
    store64(_sha256_K + 480, 0x90befffa);
    store64(_sha256_K + 488, 0xa4506ceb);
    store64(_sha256_K + 496, 0xbef9a3f7);
    store64(_sha256_K + 504, 0xc67178f2);

    _sha256_inited = 1;
    return 0;
}

# ================================================================
# SHA-256 context
# ================================================================
# Layout (144 bytes):
#   +0   h0..h7   (8 x 8 = 64 bytes) hash state words
#   +64  buf      (64 bytes) partial block buffer
#   +128 buf_len  (8 bytes)
#   +136 total_len (8 bytes)

# Allocates a 144-byte SHA-256 context from the freelist and seeds it
# with the FIPS 180-4 initial hash values. Returns the context pointer;
# free with fl_free after sha256_finalize.
fn sha256_init(): i64 {
    var ctx = fl_alloc(144);
    return sha256_init_into(ctx);
}

# Alloc-free variant of sha256_init (3.2.0). Initialises an
# existing 144-byte context buffer with the FIPS 180-4 §5.3.3
# initial hash values and zeroes the block buffer + counters.
# Caller MUST size `ctx` to at least 144 bytes.
#
# Used by `hash_file_into` and the parallel-batch worker scratch
# so a SHA-256 streaming hash can run without touching the
# freelist allocator — `fl_alloc` mutates shared state and is
# unsafe under concurrent fan-out (CLAUDE.md quirk #7).
fn sha256_init_into(ctx): i64 {
    sha256_global_init();
    store64(ctx, 0x6a09e667);
    store64(ctx + 8, 0xbb67ae85);
    store64(ctx + 16, 0x3c6ef372);
    store64(ctx + 24, 0xa54ff53a);
    store64(ctx + 32, 0x510e527f);
    store64(ctx + 40, 0x9b05688c);
    store64(ctx + 48, 0x1f83d9ab);
    store64(ctx + 56, 0x5be0cd19);
    memset(ctx + 64, 0, 64);
    store64(ctx + 128, 0);
    store64(ctx + 136, 0);
    return ctx;
}

# ================================================================
# Compression function — per-call working state (3.3 refactor)
# ================================================================
# All working state (a..hv, t1, t2, i, W) lives in function-local
# variables. The pre-3.3 module-global pattern was a cycc 3
# local-clobbering workaround that the cycc 6.0.1 codegen no
# longer needs; verified by tests/tcyr/sha256_locals_probe.tcyr
# against published FIPS 180-2 vectors and multi-block cross-
# check against the reference path.
#
# Concurrency consequence: this function is now race-free across
# threads, which unblocks dropping the _sigil_batch_mutex on the
# parallel-verify hot path. Read-only globals (_sha256_K) remain
# shared and safe under concurrent read.

# Compresses one 64-byte message block held in `ctx`'s block buffer
# into the running hash state (FIPS 180-4 §6.2.2). Dispatches to the
# SHA-NI hardware path when available, else the software round loop.
# Returns 0.
fn sha256_transform(ctx): i64 {
    # SHA-NI dispatch wire-point (2.9.2 foundation).
    # When sha256_transform_ni returns 0 it has fully transformed
    # the block and we return early. The 2.9.2 stub returns -1 so
    # this falls through to the software path on every host; 2.9.3
    # replaces the stub body with a byte-encoded SHA-NI compress.
    if (sha_ni_available() == 1) {
        if (sha256_transform_ni(ctx) == 0) { return 0; }
    }

    # Message schedule, banked per thread (3.6): `var W[N]` is a
    # static function-scope global (CLAUDE.md quirk #1), so concurrent
    # batch workers must each use their own lane to avoid stomping the
    # schedule mid-compress. `Wb` is this thread's 512-byte lane.
    var W[4096];          # 64 words × 8 bytes × SIGIL_CRYPTO_BANKS
    var Wb = &W + cbank() * 512;
    var buf = ctx + 64;

    # Prepare message schedule W[0..15] from block (big-endian).
    var i = 0;
    while (i < 16) {
        var off = i * 4;
        var w = ((load8(buf + off) & 0xFF) << 24)
        | ((load8(buf + off + 1) & 0xFF) << 16)
        | ((load8(buf + off + 2) & 0xFF) << 8)
        | (load8(buf + off + 3) & 0xFF);
        store64(Wb + i * 8, w & MASK32);
        i = i + 1;
    }

    # Extend W[16..63].
    i = 16;
    while (i < 64) {
        var w16 = load64(Wb + (i - 16) * 8);
        var w15 = load64(Wb + (i - 15) * 8);
        var w7 = load64(Wb + (i - 7) * 8);
        var w2 = load64(Wb + (i - 2) * 8);
        var s0 = sha256_ssig0(w15);
        var s1 = sha256_ssig1(w2);
        store64(Wb + i * 8, (w16 + s0 + w7 + s1) & MASK32);
        i = i + 1;
    }

    # Initialize working variables.
    var a = load64(ctx);
    var b = load64(ctx + 8);
    var c = load64(ctx + 16);
    var d = load64(ctx + 24);
    var e = load64(ctx + 32);
    var f = load64(ctx + 40);
    var g = load64(ctx + 48);
    var hv = load64(ctx + 56);

    # 64 rounds.
    i = 0;
    while (i < 64) {
        var t1 = hv;
        t1 = (t1 + sha256_bsig1(e)) & MASK32;
        t1 = (t1 + sha256_ch(e, f, g)) & MASK32;
        t1 = (t1 + load64(_sha256_K + i * 8)) & MASK32;
        t1 = (t1 + load64(Wb + i * 8)) & MASK32;

        var t2 = sha256_bsig0(a);
        t2 = (t2 + sha256_maj(a, b, c)) & MASK32;

        hv = g;
        g = f;
        f = e;
        e = (d + t1) & MASK32;
        d = c;
        c = b;
        b = a;
        a = (t1 + t2) & MASK32;
        i = i + 1;
    }

    # Add compressed chunk to current hash value.
    store64(ctx, (load64(ctx) + a) & MASK32);
    store64(ctx + 8, (load64(ctx + 8) + b) & MASK32);
    store64(ctx + 16, (load64(ctx + 16) + c) & MASK32);
    store64(ctx + 24, (load64(ctx + 24) + d) & MASK32);
    store64(ctx + 32, (load64(ctx + 32) + e) & MASK32);
    store64(ctx + 40, (load64(ctx + 40) + f) & MASK32);
    store64(ctx + 48, (load64(ctx + 48) + g) & MASK32);
    store64(ctx + 56, (load64(ctx + 56) + hv) & MASK32);
    return 0;
}

# ================================================================
# Update — feed data into the hash context
# ================================================================

# Feeds `len` bytes at `data` into the streaming hash context `ctx`,
# buffering any partial trailing block and compressing full 64-byte
# blocks as they accumulate. May be called repeatedly. Returns 0.
fn sha256_update(ctx, data, len): i64 {
    var buf_len = load64(ctx + 128);
    var total = load64(ctx + 136);
    total = total + len;
    store64(ctx + 136, total);

    var pos = 0;

    # Fill partial buffer first
    if (buf_len > 0) {
        var need = 64 - buf_len;
        if (len < need) {
            memcpy(ctx + 64 + buf_len, data, len);
            store64(ctx + 128, buf_len + len);
            return 0;
        }
        memcpy(ctx + 64 + buf_len, data, need);
        sha256_transform(ctx);
        pos = need;
        buf_len = 0;
    }

    # Process full 64-byte blocks
    while (pos + 64 <= len) {
        memcpy(ctx + 64, data + pos, 64);
        sha256_transform(ctx);
        pos = pos + 64;
    }

    # Buffer remaining bytes
    var remaining = len - pos;
    if (remaining > 0) {
        memcpy(ctx + 64, data + pos, remaining);
    }
    store64(ctx + 128, remaining);
    return 0;
}

# ================================================================
# Finalize — pad and produce 32-byte digest
# ================================================================

# Applies FIPS 180-4 §5.1.1 padding (0x80, zero fill, 64-bit big-endian
# length), runs the final compression, and writes the 32-byte digest to
# `out` in big-endian order. Consumes `ctx` (caller frees it). Returns 0.
fn sha256_finalize(ctx, out): i64 {
    var buf_len = load64(ctx + 128);
    var total_bits = load64(ctx + 136) * 8;

    # Append 0x80 byte
    store8(ctx + 64 + buf_len, 0x80);
    buf_len = buf_len + 1;

    # If buffer > 56 bytes, pad and process extra block
    if (buf_len > 56) {
        memset(ctx + 64 + buf_len, 0, 64 - buf_len);
        sha256_transform(ctx);
        buf_len = 0;
    }
    memset(ctx + 64 + buf_len, 0, 56 - buf_len);

    # Append total length as 64-bit big-endian at bytes 56-63
    store8(ctx + 64 + 56, (total_bits >> 56) & 0xFF);
    store8(ctx + 64 + 57, (total_bits >> 48) & 0xFF);
    store8(ctx + 64 + 58, (total_bits >> 40) & 0xFF);
    store8(ctx + 64 + 59, (total_bits >> 32) & 0xFF);
    store8(ctx + 64 + 60, (total_bits >> 24) & 0xFF);
    store8(ctx + 64 + 61, (total_bits >> 16) & 0xFF);
    store8(ctx + 64 + 62, (total_bits >> 8) & 0xFF);
    store8(ctx + 64 + 63, total_bits & 0xFF);

    sha256_transform(ctx);

    # Write 32-byte digest in big-endian from h0-h7
    var di = 0;
    while (di < 8) {
        var word = load64(ctx + di * 8);
        store8(out + di * 4, (word >> 24) & 0xFF);
        store8(out + di * 4 + 1, (word >> 16) & 0xFF);
        store8(out + di * 4 + 2, (word >> 8) & 0xFF);
        store8(out + di * 4 + 3, word & 0xFF);
        di = di + 1;
    }
    return 0;
}

# ================================================================
# Convenience — hash data in one shot
# ================================================================

# One-shot SHA-256: hashes `len` bytes at `data` and writes the 32-byte
# digest to `out`. Allocates, drives, and frees a context internally.
# Returns 0.
fn sha256(data, len, out): i64 {
    var ctx = sha256_init();
    sha256_update(ctx, data, len);
    sha256_finalize(ctx, out);
    fl_free(ctx);
    return 0;
}

# --- hex.cyr ---

# hex.cyr — hex encoding and decoding

# ================================================================
# Hex encode: bytes -> lowercase hex C-string
# ================================================================

# Encodes `len` raw bytes as a freshly-allocated, NUL-terminated
# lowercase hex C-string (2*len + 1 bytes). Returns the string pointer.
fn hex_encode(bytes, len): i64 {
    var out = alloc(len * 2 + 1);
    var i = 0;
    while (i < len) {
        var b = load8(bytes + i) & 0xFF;
        var hi = (b >> 4) & 0xF;
        var lo = b & 0xF;
        if (hi < 10) { store8(out + i * 2, 48 + hi); }
        else { store8(out + i * 2, 87 + hi); }
        if (lo < 10) { store8(out + i * 2 + 1, 48 + lo); }
        else { store8(out + i * 2 + 1, 87 + lo); }
        i = i + 1;
    }
    store8(out + len * 2, 0);
    return out;
}

# ================================================================
# Hex decode: hex C-string + length -> raw bytes
# ================================================================

fn _hex_nibble(c): i64 {
    if (c >= 48) { if (c <= 57) { return c - 48; } }
    if (c >= 97) { if (c <= 102) { return c - 87; } }
    if (c >= 65) { if (c <= 70) { return c - 55; } }
    return (0 - 1);
}

fn _hex_is_valid_char(c): i64 {
    if (c >= 48) { if (c <= 57) { return 1; } }
    if (c >= 97) { if (c <= 102) { return 1; } }
    if (c >= 65) { if (c <= 70) { return 1; } }
    return 0;
}

# Returns 1 if hex_str is a valid even-length hex C-string of hex_len chars.
fn hex_is_valid(hex_str, hex_len): i64 {
    if (hex_len == 0) { return 0; }
    if ((hex_len & 1) == 1) { return 0; }
    var i = 0;
    while (i < hex_len) {
        if (_hex_is_valid_char(load8(hex_str + i) & 0xFF) == 0) { return 0; }
        i = i + 1;
    }
    return 1;
}

# Decode hex to bytes. Returns 0 (null) on invalid input
# (odd length, non-hex char). Caller MUST null-check.
fn hex_decode(hex_str, hex_len): i64 {
    if ((hex_len & 1) == 1) { return 0; }
    var blen = hex_len / 2;
    if (blen == 0) { return 0; }
    var out = alloc(blen);
    if (hex_decode_into(hex_str, hex_len, out) == 0) { return 0; }
    return out;
}

# Alloc-free variant of hex_decode (3.2.0). Writes `hex_len/2`
# bytes into `out` and returns 1 on success, 0 if `hex_len` is
# odd, zero, or any character is not a valid hex nibble. Caller
# MUST size `out` to at least `hex_len / 2` bytes.
#
# Same input validation surface as hex_decode but no allocation —
# safe to call from a parallel-batch worker body where the
# bump-pointer allocator can't be touched (CLAUDE.md quirk #7).
fn hex_decode_into(hex_str, hex_len, out): i64 {
    if ((hex_len & 1) == 1) { return 0; }
    var blen = hex_len / 2;
    if (blen == 0) { return 0; }
    var i = 0;
    while (i < blen) {
        var hi = _hex_nibble(load8(hex_str + i * 2) & 0xFF);
        var lo = _hex_nibble(load8(hex_str + i * 2 + 1) & 0xFF);
        if (hi < 0) { return 0; }
        if (lo < 0) { return 0; }
        store8(out + i, (hi << 4) | lo);
        i = i + 1;
    }
    return 1;
}

# ================================================================
# Convenience: hash bytes to hex string
# ================================================================

# SHA-256 of `len` bytes, returned as a 64-char lowercase hex C-string.
fn sha256_hex(data, len): i64 {
    var digest[32];
    sha256(data, len, &digest);
    return hex_encode(&digest, 32);
}

# SHA-512 of `len` bytes, returned as a 128-char lowercase hex C-string.
fn sha512_hex(data, len): i64 {
    var digest[64];
    sha512(data, len, &digest);
    return hex_encode(&digest, 64);
}

# --- hmac.cyr ---

# hmac.cyr — HMAC-SHA256 (RFC 2104)
# Proper ipad/opad construction, not simplified SHA-256(key||msg).
#
# Status in 3.0: sigil-internal primitive. Public consumers should
# call `hkdf_*` (src/hkdf.cyr) rather than `hmac_sha256` directly
# — HMAC's hot-path role in sigil is as the HKDF extract/expand
# building block, and exposing it as a top-level API would
# encourage miscomposition (consumers rolling their own KDFs when
# HKDF already covers the use case correctly). The 2.x roadmap
# entry proposing a full drop of this module is retired: the
# 2.9.0 HKDF landing pulled `hmac_sha256` into sigil's internal
# call graph, so it stays. `tests/tcyr/crypto.tcyr` and
# `tests/tcyr/security.tcyr` retain hmac-level test vectors as
# unit coverage of the primitive.
#
# HMAC(K, m) = H((K' xor opad) || H((K' xor ipad) || m))
# where:
#   K' = H(K) if len(K) > 64, else K padded to 64 bytes
#   ipad = 0x36 repeated 64 times
#   opad = 0x5c repeated 64 times

# ================================================================
# HMAC-SHA256
# ================================================================

# Computes HMAC-SHA256 (RFC 2104) over `msg` under `key`, writing the
# 32-byte MAC to `out`. Keys longer than the 64-byte block are first
# SHA-256-hashed per the spec; shorter keys are zero-padded. The K'
# / ipad / opad scratch buffers are `secret var` and zeroized on
# return. Returns 0.
fn hmac_sha256(key, key_len, msg, msg_len, out): i64 {
    # Step 1: Derive K' (64 bytes). `secret var` guarantees the
    # buffer is zeroed on function exit (Cyrius 5.3.5+). The init
    # memset below is retained for program correctness — the
    # key_len < 64 branch relies on the upper bytes being zero.
    secret var kprime[64];
    memset(&kprime, 0, 64);

    if (key_len > 64) {
        # Key too long — hash it
        sha256(key, key_len, &kprime);
        # kprime is now 32 bytes of hash + 32 bytes of zeros
    } else {
        memcpy(&kprime, key, key_len);
        # Rest already zeroed
    }

    # Step 2: inner = SHA-256((K' xor ipad) || message)
    secret var ipad[64];
    var i = 0;
    while (i < 64) {
        store8(&ipad + i, (load8(&kprime + i) & 0xFF) ^ 0x36);
        i = i + 1;
    }

    var inner_ctx = sha256_init();
    sha256_update(inner_ctx, &ipad, 64);
    sha256_update(inner_ctx, msg, msg_len);
    var inner_hash[32];
    sha256_finalize(inner_ctx, &inner_hash);
    fl_free(inner_ctx);

    # Step 3: outer = SHA-256((K' xor opad) || inner)
    secret var opad[64];
    i = 0;
    while (i < 64) {
        store8(&opad + i, (load8(&kprime + i) & 0xFF) ^ 0x5c);
        i = i + 1;
    }

    var outer_ctx = sha256_init();
    sha256_update(outer_ctx, &opad, 64);
    sha256_update(outer_ctx, &inner_hash, 32);
    sha256_finalize(outer_ctx, out);
    fl_free(outer_ctx);

    # kprime / ipad / opad are `secret var` — zeroed on return by
    # the compiler. inner_hash is a public digest; left as a plain
    # var (no security need to clear).
    return 0;
}


# --- hkdf.cyr ---

# hkdf.cyr — HKDF (RFC 5869) on top of HMAC-SHA256
#
# HKDF is a two-stage key derivation function:
#   1. Extract: PRK = HMAC-SHA256(salt, IKM)       (32-byte PRK)
#   2. Expand: OKM = T(1) || T(2) || ... || T(N)
#      where T(0) = empty, T(i) = HMAC-SHA256(PRK, T(i-1) || info || i)
#
# HashLen = 32 (SHA-256), so max OKM length = 255 * 32 = 8160 bytes
# per RFC 5869 §2.3.
#
# Security hygiene (matches sigil's existing pattern):
#   - PRK (the pseudorandom key) is key material and is zeroized
#     before free when the extract+expand convenience function is
#     used. When callers drive extract+expand themselves, they own
#     the PRK buffer and are responsible for zeroization.
#   - T(i-1) and every HMAC intermediate is zeroized after the last
#     block is emitted.
#   - No branch on secret data: the loop count is derived from
#     out_len which is public.
#
# RFC 5869 §2.2: if salt is empty / not provided, use a string of
# HashLen zeros (32 zeros for SHA-256). Callers can pass
# (salt=0, salt_len=0) and this module handles the substitution.
#
# RFC 5869 §2.3: if info is empty / not provided, the concatenation
# "T(i-1) || info || i" collapses to "T(i-1) || i" (info contributes
# zero bytes). Callers can pass (info=0, info_len=0) and this module
# handles that cleanly.

# ================================================================
# hkdf_extract — PRK = HMAC-SHA256(salt, IKM)
# ================================================================
# salt    : pointer to salt bytes (may be 0 if salt_len == 0)
# salt_len: length of salt in bytes
# ikm     : pointer to input keying material
# ikm_len : length of IKM in bytes
# prk_out : caller-provided 32-byte output buffer; receives the PRK
# Returns 0 on success, non-zero on input-validation failure.
fn hkdf_extract(salt, salt_len, ikm, ikm_len, prk_out): i64 {
    if (salt_len < 0) { return (0 - 1); }
    if (ikm_len < 0) { return (0 - 1); }

    # RFC 5869 §2.2: a NULL/empty salt is treated as HashLen zero bytes.
    if (salt_len == 0) {
        var zero_salt[32];
        memset(&zero_salt, 0, 32);
        hmac_sha256(&zero_salt, 32, ikm, ikm_len, prk_out);
        memset(&zero_salt, 0, 32);
        return 0;
    }

    hmac_sha256(salt, salt_len, ikm, ikm_len, prk_out);
    return 0;
}

# ================================================================
# hkdf_expand — OKM = T(1) || T(2) || ... || T(N)
# ================================================================
# prk      : pointer to 32-byte pseudorandom key (output of extract)
# prk_len  : length of PRK (should be >= 32; SHA-256 always gives 32)
# info     : pointer to context/application info (may be 0 if info_len == 0)
# info_len : length of info in bytes
# out      : caller-provided buffer of size >= out_len
# out_len  : number of OKM bytes to produce
#
# Returns:
#   0   on success
#  -1   on negative-length input
#  -2   on out_len > 255*32 (RFC 5869 §2.3 cap)

# Globals: Cyrius single-pass compiler can clobber locals across
# nested call chains. hkdf_expand has a deep call chain (hmac_sha256
# itself calls sha256_init / update / finalize with memcpy/memset
# around them), so the round state lives in globals.
var _hkdf_scratch = 0;
var _hkdf_scratch_len = 0;
var _hkdf_prk = 0;
var _hkdf_prk_len = 0;
var _hkdf_info = 0;
var _hkdf_info_len = 0;
var _hkdf_out = 0;
var _hkdf_out_len = 0;
var _hkdf_produced = 0;
var _hkdf_counter = 0;

# Expands `prk` into `out_len` bytes of output keying material bound to
# `info` (RFC 5869 §2.3). Returns 0 on success, -1 on negative-length
# input, -2 when out_len exceeds the 255*32 = 8160-byte HashLen cap.
# Every HMAC intermediate is zeroized before return.
fn hkdf_expand(prk, prk_len, info, info_len, out, out_len): i64 {
    if (prk_len < 0) { return (0 - 1); }
    if (info_len < 0) { return (0 - 1); }
    if (out_len < 0) { return (0 - 1); }
    # HashLen = 32. Max OKM = 255 * 32 = 8160 bytes.
    if (out_len > 8160) { return (0 - 2); }
    if (out_len == 0) { return 0; }

    # Promote all parameters to globals so nested HMAC calls can't
    # clobber them via cc5's register allocator.
    _hkdf_prk = prk;
    _hkdf_prk_len = prk_len;
    _hkdf_info = info;
    _hkdf_info_len = info_len;
    _hkdf_out = out;
    _hkdf_out_len = out_len;

    # Scratch holds "T(i-1) || info || counter" — the HMAC input for
    # each round. Max size = 32 + info_len + 1. `alloc` via fl_alloc
    # because we want a proper free at the end + secret material.
    _hkdf_scratch_len = 32 + info_len + 1;
    _hkdf_scratch = fl_alloc(_hkdf_scratch_len);
    memset(_hkdf_scratch, 0, _hkdf_scratch_len);

    # T(i-1) and T(i) are HMAC outputs and therefore key material
    # per RFC 5869. `secret var` zeroes both on function exit
    # (covers the happy-path ret and any early errors); init
    # memsets retained because the counter==1 branch leaves t_prev
    # untouched and we memcpy out of it.
    secret var t_prev[32];
    memset(&t_prev, 0, 32);
    secret var t_current[32];
    memset(&t_current, 0, 32);

    _hkdf_produced = 0;
    _hkdf_counter = 1;   # RFC 5869: i starts at 1

    while (_hkdf_produced < _hkdf_out_len) {
        # Build input to HMAC: T(i-1) || info || counter
        # First round (counter=1): T(0) is empty, so skip the T_prev copy.
        var scratch_write = 0;
        if (_hkdf_counter > 1) {
            memcpy(_hkdf_scratch, &t_prev, 32);
            scratch_write = 32;
        }
        if (_hkdf_info_len > 0) {
            memcpy(_hkdf_scratch + scratch_write, _hkdf_info, _hkdf_info_len);
            scratch_write = scratch_write + _hkdf_info_len;
        }
        store8(_hkdf_scratch + scratch_write, _hkdf_counter & 0xFF);
        scratch_write = scratch_write + 1;

        # T(i) = HMAC-SHA256(PRK, scratch[0..scratch_write])
        hmac_sha256(_hkdf_prk, _hkdf_prk_len, _hkdf_scratch, scratch_write, &t_current);

        # Copy min(32, out_len - produced) bytes into the output.
        var take = 32;
        if (_hkdf_out_len - _hkdf_produced < 32) {
            take = _hkdf_out_len - _hkdf_produced;
        }
        memcpy(_hkdf_out + _hkdf_produced, &t_current, take);
        _hkdf_produced = _hkdf_produced + take;

        # Save T(i) for the next iteration.
        memcpy(&t_prev, &t_current, 32);

        _hkdf_counter = _hkdf_counter + 1;
    }

    # Zeroize the heap scratch before free. t_prev / t_current are
    # `secret var` — zeroed on function exit by the compiler.
    memset(_hkdf_scratch, 0, _hkdf_scratch_len);
    fl_free(_hkdf_scratch);
    # Wipe the global pointers so nothing leaks between calls.
    _hkdf_scratch = 0;
    _hkdf_prk = 0;
    _hkdf_info = 0;
    _hkdf_out = 0;
    return 0;
}

# ================================================================
# hkdf — extract + expand convenience wrapper
# ================================================================
# One-shot HKDF. Derives out_len bytes of OKM from (salt, IKM, info).
# The intermediate PRK is allocated on the stack, used, and zeroized
# before return — callers never see it.
#
# Returns:
#   0   on success
#  -1   on negative-length input
#  -2   on out_len > 255*32
fn hkdf(salt, salt_len, ikm, ikm_len, info, info_len, out, out_len): i64 {
    # PRK is key material. `secret var` handles zeroization on
    # every return path (both rc1 error and rc2 success/error).
    secret var prk[32];
    var rc1 = hkdf_extract(salt, salt_len, ikm, ikm_len, &prk);
    if (rc1 != 0) { return rc1; }
    return hkdf_expand(&prk, 32, info, info_len, out, out_len);
}

# --- aes_ni.cyr ---

# aes_ni.cyr — AES-NI hardware-acceleration dispatch (live since 2.9.1).
#
# Cyrius 5.5.21's array-global 16-byte alignment fix closed out the
# SSE m128-operand fault that had kept this path dormant through
# 2.9.0 and part of 2.9.x development. With `var rk[240]` reliably
# landing on a 16-aligned VA, PXOR / AESENC / AESENCLAST memory
# operands on the round-key table no longer trip #GP, and the
# inline-asm stores through caller-supplied output pointers reach
# memory cleanly. Verified against FIPS 197 §C.3 in
# tests/tcyr/aes_ni.tcyr.
#
# The module exposes three entry points:
#   - aes_ni_available()        — runtime CPUID probe, cached
#   - aes256_encrypt_block_ni(round_keys, in, out)
#                               — 14-round AES-256 block encrypt
#   - aes128_encrypt_block_ni(round_keys, in, out)
#                               — 10-round AES-128 block encrypt
# aes_gcm.cyr's aes256_encrypt_block / aes128_encrypt_block dispatch
# here when the probe returns 1, falling back to the FIPS 197 §5.1
# software path when the host lacks AES-NI. Downstream callers should
# call the dispatchers (aes256_encrypt_block / aes128_encrypt_block),
# not the _ni variants directly, unless they're writing their own
# fast path. The boot self-test validates BOTH the AES-256 (FIPS 197
# §C.3) and AES-128 (§C.1) NI paths before going live; either vector
# diverging pins the cache to 0 and routes both key sizes to software.
#
# AES-NI opcode reference (Intel SDM Vol 2A §3.2, §5):
#   AESENC xmm0, [rdi+disp]       66 0F 38 DC 47/87 <disp>
#   AESENCLAST xmm0, [rdi+disp]   66 0F 38 DD 47/87 <disp>
#   CPUID                          0F A2     (eax=1 → ECX bit 25 = AES-NI)
#   PXOR xmm0, [rdi]               66 0F EF 07
#   MOVDQU xmm0, [rsi]             F3 0F 6F 06
#   MOVDQU [rdx], xmm0             F3 0F 7F 02

# _aes_ni_cache: 2 = uncached, 0 = unavailable (software path), 1 = available.
# First call to aes_ni_available() runs the CPUID probe AND the
# FIPS 197 §C.3 self-test; on either gate failure the cache pins to
# 0 and sigil silently falls through to the software path. The probe
# is a serializing instruction so we want to pay it exactly once.
var _aes_ni_cache = 2;
var _aes_ni_probe_out = 0;      # 8-byte scratch for the probe's *out param

# Self-test scratch — module-level so `var rk[240]` lands on a
# 16-byte boundary (CLAUDE.md quirk #6). Required because the
# `pxor xmm0, [rdi]` / `aesenc xmm0, [rdi+disp]` opcodes in
# aes256_encrypt_block_ni take m128 operands and #GP on unaligned
# addresses. Local-stack `var rk[240]` carries no alignment guarantee.
var _aes_ni_st_key[32];
var _aes_ni_st_rk[240];
var _aes_ni_st_pt[16];
var _aes_ni_st_ct[16];

fn aes_ni_available(): i64 {
    if (_aes_ni_cache != 2) { return _aes_ni_cache; }
    if (_aes_ni_probe_out == 0) { _aes_ni_probe_out = alloc(8); }
    store64(_aes_ni_probe_out, 0);
    _aes_ni_cpuid_probe(_aes_ni_probe_out);
    var ecx = load64(_aes_ni_probe_out);
    # ECX bit 25 = AES-NI (Intel SDM Vol 2A §3.2 CPUID leaf 1).
    if ((ecx & (1 << 25)) == 0) {
        _aes_ni_cache = 0;
        return 0;
    }
    # Defense-in-depth: confirm the NI asm path produces FIPS 197 §C.3
    # output before going live. Catches the class of bug documented in
    # docs/development/issues/2026-05-10-cyrius-510-asm-stack-frame-
    # drift-breaks-ni-paths.md — hardcoded `[rbp-N]` parameter loads
    # coupling to a cyrius prologue layout that drifts across toolchain
    # versions. If the prologue ever shifts so that aes256_encrypt_block_ni
    # reads garbage from the wrong stack slot, the dispatcher would have
    # historically gone live on a broken NI path. Now it silently
    # downgrades to software. Catches wrong-output cases (asm reads a
    # mis-spilled pointer, executes against unrelated memory, produces
    # nonsense). Does NOT catch SIGILL (no cyrius signal-handling
    # primitive); for that, see the upstream cyrius ask filed alongside
    # this fix (asm-block global-symbol pseudo for [rip+global] loads).
    # Validate both the AES-256 (§C.3) and AES-128 (§C.1) NI paths.
    # They share the CPUID feature bit and the asm-prologue parameter
    # shape, so a single mismatch in either downgrades both key sizes
    # to software — conservative and correct.
    if (_aes_ni_self_test() == 0) {
        if (_aes128_ni_self_test() == 0) {
            _aes_ni_cache = 1;
        } else {
            _aes_ni_cache = 0;
        }
    } else {
        _aes_ni_cache = 0;
    }
    return _aes_ni_cache;
}

# _aes_ni_cpuid_probe — write CPUID leaf 1 ECX to *out.
# Takes a caller-supplied pointer to keep the CPUID-clobbered
# registers' lifetime confined to the inline-asm block; the caller
# reloads via load64 after the call returns.
fn _aes_ni_cpuid_probe(out): i64 {
    #ifdef CYRIUS_ARCH_X86
    asm {
        # Param out = [rbp-8]. Load into rdi.
        0x48; 0x8B; 0x7D; 0xF8;        # mov rdi, [rbp-8]
        0x53;                          # push rbx (callee-saved; CPUID clobbers it)
        0xB8; 0x01; 0x00; 0x00; 0x00;  # mov eax, 1
        0x31; 0xC9;                    # xor ecx, ecx (subleaf 0)
        0x0F; 0xA2;                    # cpuid
        0x48; 0x89; 0x0F;              # mov [rdi], rcx  ; *out = ecx
        0x5B;                          # pop rbx
    }
    #endif
    return 0;
}

# aes256_encrypt_block_ni — hardware AES-256 single-block encrypt.
#
# Byte-accurate AESENC + AESENCLAST sequence over round_keys
# (240-byte expanded schedule, same layout as the software
# encryptor). Consumes:
#   round_keys — rdi — 15 round keys of 16 bytes each
#   in_block   — rsi — 16-byte plaintext
#   out_block  — rdx — 16-byte ciphertext (caller-allocated)
#
# Status: reaches the CPU's AESENC machinery correctly when called
# directly inside a single-compilation-unit build. Not wired into
# aes_gcm_encrypt in 2.9.0 (see module header).
fn aes256_encrypt_block_ni(round_keys, in_block, out_block): i64 {
    #ifdef CYRIUS_ARCH_X86
    asm {
        # Params: round_keys=[rbp-8], in_block=[rbp-16], out_block=[rbp-24]
        0x48; 0x8B; 0x7D; 0xF8;        # mov rdi, [rbp-8]   (round_keys)
        0x48; 0x8B; 0x75; 0xF0;        # mov rsi, [rbp-16]  (in_block)
        0x48; 0x8B; 0x55; 0xE8;        # mov rdx, [rbp-24]  (out_block)

        # movdqu xmm0, [rsi]           ; state = in_block
        0xF3; 0x0F; 0x6F; 0x06;
        # pxor xmm0, [rdi]             ; state ^= round_key[0]
        0x66; 0x0F; 0xEF; 0x07;

        # Rounds 1..7: AESENC xmm0, [rdi + N*16]  (disp8 form)
        0x66; 0x0F; 0x38; 0xDC; 0x47; 0x10;
        0x66; 0x0F; 0x38; 0xDC; 0x47; 0x20;
        0x66; 0x0F; 0x38; 0xDC; 0x47; 0x30;
        0x66; 0x0F; 0x38; 0xDC; 0x47; 0x40;
        0x66; 0x0F; 0x38; 0xDC; 0x47; 0x50;
        0x66; 0x0F; 0x38; 0xDC; 0x47; 0x60;
        0x66; 0x0F; 0x38; 0xDC; 0x47; 0x70;
        # Rounds 8..13: AESENC xmm0, [rdi + N*16]  (disp32 form; 128..208 beyond disp8 range)
        0x66; 0x0F; 0x38; 0xDC; 0x87; 0x80; 0x00; 0x00; 0x00;
        0x66; 0x0F; 0x38; 0xDC; 0x87; 0x90; 0x00; 0x00; 0x00;
        0x66; 0x0F; 0x38; 0xDC; 0x87; 0xA0; 0x00; 0x00; 0x00;
        0x66; 0x0F; 0x38; 0xDC; 0x87; 0xB0; 0x00; 0x00; 0x00;
        0x66; 0x0F; 0x38; 0xDC; 0x87; 0xC0; 0x00; 0x00; 0x00;
        0x66; 0x0F; 0x38; 0xDC; 0x87; 0xD0; 0x00; 0x00; 0x00;
        # Round 14 (final): AESENCLAST xmm0, [rdi+224]
        0x66; 0x0F; 0x38; 0xDD; 0x87; 0xE0; 0x00; 0x00; 0x00;

        # movdqu [rdx], xmm0           ; out_block = state
        0xF3; 0x0F; 0x7F; 0x02;
    }
    #endif
    return 0;
}

# aes128_encrypt_block_ni — hardware AES-128 single-block encrypt.
#
# Identical AESENC pipeline to the AES-256 variant but only 10 rounds
# (9 AESENC + 1 AESENCLAST) over an 11-key / 176-byte expanded
# schedule. Round keys 0..10 sit at offsets 0x00..0xA0; offsets
# 0x10..0x70 use the disp8 AESENC form, 0x80/0x90/0xA0 the disp32
# form. Same prologue/parameter shape and alignment requirement as
# aes256_encrypt_block_ni. Consumes:
#   round_keys — rdi — 11 round keys of 16 bytes each (176 bytes)
#   in_block   — rsi — 16-byte plaintext
#   out_block  — rdx — 16-byte ciphertext (caller-allocated)
fn aes128_encrypt_block_ni(round_keys, in_block, out_block): i64 {
    #ifdef CYRIUS_ARCH_X86
    asm {
        # Params: round_keys=[rbp-8], in_block=[rbp-16], out_block=[rbp-24]
        0x48; 0x8B; 0x7D; 0xF8;        # mov rdi, [rbp-8]   (round_keys)
        0x48; 0x8B; 0x75; 0xF0;        # mov rsi, [rbp-16]  (in_block)
        0x48; 0x8B; 0x55; 0xE8;        # mov rdx, [rbp-24]  (out_block)

        # movdqu xmm0, [rsi]           ; state = in_block
        0xF3; 0x0F; 0x6F; 0x06;
        # pxor xmm0, [rdi]             ; state ^= round_key[0]
        0x66; 0x0F; 0xEF; 0x07;

        # Rounds 1..7: AESENC xmm0, [rdi + N*16]  (disp8 form)
        0x66; 0x0F; 0x38; 0xDC; 0x47; 0x10;
        0x66; 0x0F; 0x38; 0xDC; 0x47; 0x20;
        0x66; 0x0F; 0x38; 0xDC; 0x47; 0x30;
        0x66; 0x0F; 0x38; 0xDC; 0x47; 0x40;
        0x66; 0x0F; 0x38; 0xDC; 0x47; 0x50;
        0x66; 0x0F; 0x38; 0xDC; 0x47; 0x60;
        0x66; 0x0F; 0x38; 0xDC; 0x47; 0x70;
        # Rounds 8..9: AESENC xmm0, [rdi + N*16]  (disp32 form; 128/144 beyond disp8 range)
        0x66; 0x0F; 0x38; 0xDC; 0x87; 0x80; 0x00; 0x00; 0x00;
        0x66; 0x0F; 0x38; 0xDC; 0x87; 0x90; 0x00; 0x00; 0x00;
        # Round 10 (final): AESENCLAST xmm0, [rdi+160]
        0x66; 0x0F; 0x38; 0xDD; 0x87; 0xA0; 0x00; 0x00; 0x00;

        # movdqu [rdx], xmm0           ; out_block = state
        0xF3; 0x0F; 0x7F; 0x02;
    }
    #endif
    return 0;
}

# _aes_ni_self_test — run AES-NI against FIPS 197 §C.3 and compare
# the resulting ciphertext to the spec's published expected output.
# Returns 0 if the NI path produced the right ciphertext (NI is
# safe to enable), non-zero if the bytes diverged (downgrade to
# software). Constant-time compare (OR-accumulating, no early exit).
#
# Forward references `aes256_key_expand` from `src/aes_gcm.cyr`,
# which is included after this module in `src/lib.cyr`. Cyrius's
# symbol resolution is per-translation-unit, so by the time this
# fn executes at runtime, `aes256_key_expand` is fully registered.
#
# FIPS 197 §C.3 AES-256 vector:
#   Key:       000102…1F                              (32 bytes)
#   Plaintext: 00112233445566778899AABBCCDDEEFF       (16 bytes)
#   Expected:  8EA2B7CA516745BFEAFC49904B496089       (16 bytes)
fn _aes_ni_self_test(): i64 {
    var i = 0;
    while (i < 32) { store8(&_aes_ni_st_key + i, i); i = i + 1; }
    i = 0;
    while (i < 16) { store8(&_aes_ni_st_pt + i, (i * 17) & 0xFF); i = i + 1; }
    i = 0;
    while (i < 16) { store8(&_aes_ni_st_ct + i, 0xA5); i = i + 1; }   # sentinel
    i = 0;
    while (i < 240) { store8(&_aes_ni_st_rk + i, 0); i = i + 1; }

    aes256_key_expand(&_aes_ni_st_key, &_aes_ni_st_rk);
    aes256_encrypt_block_ni(&_aes_ni_st_rk, &_aes_ni_st_pt, &_aes_ni_st_ct);

    var diff = 0;
    diff = diff | ((load8(&_aes_ni_st_ct +  0) ^ 0x8E) & 0xFF);
    diff = diff | ((load8(&_aes_ni_st_ct +  1) ^ 0xA2) & 0xFF);
    diff = diff | ((load8(&_aes_ni_st_ct +  2) ^ 0xB7) & 0xFF);
    diff = diff | ((load8(&_aes_ni_st_ct +  3) ^ 0xCA) & 0xFF);
    diff = diff | ((load8(&_aes_ni_st_ct +  4) ^ 0x51) & 0xFF);
    diff = diff | ((load8(&_aes_ni_st_ct +  5) ^ 0x67) & 0xFF);
    diff = diff | ((load8(&_aes_ni_st_ct +  6) ^ 0x45) & 0xFF);
    diff = diff | ((load8(&_aes_ni_st_ct +  7) ^ 0xBF) & 0xFF);
    diff = diff | ((load8(&_aes_ni_st_ct +  8) ^ 0xEA) & 0xFF);
    diff = diff | ((load8(&_aes_ni_st_ct +  9) ^ 0xFC) & 0xFF);
    diff = diff | ((load8(&_aes_ni_st_ct + 10) ^ 0x49) & 0xFF);
    diff = diff | ((load8(&_aes_ni_st_ct + 11) ^ 0x90) & 0xFF);
    diff = diff | ((load8(&_aes_ni_st_ct + 12) ^ 0x4B) & 0xFF);
    diff = diff | ((load8(&_aes_ni_st_ct + 13) ^ 0x49) & 0xFF);
    diff = diff | ((load8(&_aes_ni_st_ct + 14) ^ 0x60) & 0xFF);
    diff = diff | ((load8(&_aes_ni_st_ct + 15) ^ 0x89) & 0xFF);
    return diff;
}

# _aes128_ni_self_test — run the AES-128 NI path against FIPS 197 §C.1
# and compare to the spec's published ciphertext. Reuses the §C.3
# self-test scratch globals (the §C.3 test runs first and completes
# before this one starts — sequential reuse, fully written before
# read; CLAUDE.md quirk #1). Returns 0 on a byte-for-byte match,
# non-zero on divergence. Constant-time OR-accumulating compare.
#
# Forward-references aes_128_key_expand from src/aes_gcm.cyr (included
# after this module) — resolved per-TU at runtime, same as the §C.3
# test's reference to aes256_key_expand.
#
# FIPS 197 §C.1 AES-128 vector:
#   Key:       000102030405060708090A0B0C0D0E0F       (16 bytes)
#   Plaintext: 00112233445566778899AABBCCDDEEFF       (16 bytes)
#   Expected:  69C4E0D86A7B0430D8CDB78070B4C55A       (16 bytes)
fn _aes128_ni_self_test(): i64 {
    var i = 0;
    while (i < 16) { store8(&_aes_ni_st_key + i, i); i = i + 1; }
    i = 0;
    while (i < 16) { store8(&_aes_ni_st_pt + i, (i * 17) & 0xFF); i = i + 1; }
    i = 0;
    while (i < 16) { store8(&_aes_ni_st_ct + i, 0xA5); i = i + 1; }   # sentinel
    i = 0;
    while (i < 176) { store8(&_aes_ni_st_rk + i, 0); i = i + 1; }

    aes_128_key_expand(&_aes_ni_st_key, &_aes_ni_st_rk);
    aes128_encrypt_block_ni(&_aes_ni_st_rk, &_aes_ni_st_pt, &_aes_ni_st_ct);

    var diff = 0;
    diff = diff | ((load8(&_aes_ni_st_ct +  0) ^ 0x69) & 0xFF);
    diff = diff | ((load8(&_aes_ni_st_ct +  1) ^ 0xC4) & 0xFF);
    diff = diff | ((load8(&_aes_ni_st_ct +  2) ^ 0xE0) & 0xFF);
    diff = diff | ((load8(&_aes_ni_st_ct +  3) ^ 0xD8) & 0xFF);
    diff = diff | ((load8(&_aes_ni_st_ct +  4) ^ 0x6A) & 0xFF);
    diff = diff | ((load8(&_aes_ni_st_ct +  5) ^ 0x7B) & 0xFF);
    diff = diff | ((load8(&_aes_ni_st_ct +  6) ^ 0x04) & 0xFF);
    diff = diff | ((load8(&_aes_ni_st_ct +  7) ^ 0x30) & 0xFF);
    diff = diff | ((load8(&_aes_ni_st_ct +  8) ^ 0xD8) & 0xFF);
    diff = diff | ((load8(&_aes_ni_st_ct +  9) ^ 0xCD) & 0xFF);
    diff = diff | ((load8(&_aes_ni_st_ct + 10) ^ 0xB7) & 0xFF);
    diff = diff | ((load8(&_aes_ni_st_ct + 11) ^ 0x80) & 0xFF);
    diff = diff | ((load8(&_aes_ni_st_ct + 12) ^ 0x70) & 0xFF);
    diff = diff | ((load8(&_aes_ni_st_ct + 13) ^ 0xB4) & 0xFF);
    diff = diff | ((load8(&_aes_ni_st_ct + 14) ^ 0xC5) & 0xFF);
    diff = diff | ((load8(&_aes_ni_st_ct + 15) ^ 0x5A) & 0xFF);
    return diff;
}

# --- aes_gcm.cyr ---

# aes_gcm.cyr — AES-256-GCM + AES-128-GCM (AEAD) implementation
# FIPS 197 (AES block cipher: 14 rounds for AES-256, 10 for AES-128)
# + NIST SP 800-38D (Galois/Counter Mode) — the AEAD primitive for
# the AGNOS ecosystem.
#
# Scope:
#   - AES-256 + AES-128 block cipher, forward direction only (GCM
#     never invokes the inverse cipher). Rijndael over 32-byte
#     (14-round) and 16-byte (10-round) keys, 16-byte blocks. The
#     two variants differ ONLY in the key schedule (240-byte / 15-key
#     vs 176-byte / 11-key table) and the round count; the block
#     transform, GHASH, CTR mode, and GCM framing are shared and
#     parametrized on the round count.
#   - GHASH under GF(2^128) with reduction polynomial
#     x^128 + x^7 + x^2 + x + 1, bit-by-bit multiply (constant-time).
#   - GCM encrypt / decrypt over 12-byte (96-bit) IVs — the RFC
#     fast-path. Arbitrary-length IVs deferred to a follow-up.
#   - Tag: 128-bit, constant-time compared via cyrius stdlib's
#     `ct_eq_bytes_lens` (was sigil's hand-rolled `ct_eq` pre-3.0.2).
#
# Security floor (matches CLAUDE.md § Security Hardening):
#   - AES block encrypt dispatches to AES-NI when available
#     (runtime CPUID probe in src/aes_ni.cyr), otherwise runs the
#     constant-time software path in this file. Both paths produce
#     byte-identical output against FIPS 197 §C.3.
#   - Constant-time tag compare; no early exit on secret data.
#   - No branches on key bytes or plaintext.
#   - Round-key buffers and the GHASH subkey H are zeroized
#     before free after every encrypt / decrypt call.
#   - Input lengths validated at the GCM boundary.
#
# Working state: per-call function locals. The pre-3.3 module-
# global pattern was a cycc 3 local-clobbering workaround that
# cycc 6.0.1 no longer needs (CLAUDE.md quirk #1, verified by
# tests/tcyr/sha256_locals_probe.tcyr). Read-only init tables
# (`_aes_sbox`, `_aes_rcon`) remain shared and safe under
# concurrent read.

# aes_ni.cyr supplies aes_ni_available() and aes256_encrypt_block_ni
# for the dispatcher in aes256_encrypt_block below. Including it
# here means any consumer of aes_gcm automatically pulls the
# hardware path in without having to list it separately.
include "src/aes_ni.cyr"

# ================================================================
# AES S-box (forward direction, FIPS 197 Fig. 7)
# ================================================================
# 256 bytes. Allocated once at init and never mutated. Read-only
# in the cipher body.

var _aes_sbox = 0;
var _aes_rcon = 0;
var _aes_inited = 0;

# S-box as a hex string (512 chars → 256 bytes). Single literal
# keeps the fixup count tiny — we decode it in a small loop at
# init time rather than emitting 256 store8 calls.
# Canonical Rijndael S-box, FIPS 197 Figure 7, rows 0..F:
#   row 0: 63 7c 77 7b f2 6b 6f c5 30 01 67 2b fe d7 ab 76
#   row 1: ca 82 c9 7d fa 59 47 f0 ad d4 a2 af 9c a4 72 c0
#   row 2: b7 fd 93 26 36 3f f7 cc 34 a5 e5 f1 71 d8 31 15
#   row 3: 04 c7 23 c3 18 96 05 9a 07 12 80 e2 eb 27 b2 75
#   row 4: 09 83 2c 1a 1b 6e 5a a0 52 3b d6 b3 29 e3 2f 84
#   row 5: 53 d1 00 ed 20 fc b1 5b 6a cb be 39 4a 4c 58 cf
#   row 6: d0 ef aa fb 43 4d 33 85 45 f9 02 7f 50 3c 9f a8
#   row 7: 51 a3 40 8f 92 9d 38 f5 bc b6 da 21 10 ff f3 d2
#   row 8: cd 0c 13 ec 5f 97 44 17 c4 a7 7e 3d 64 5d 19 73
#   row 9: 60 81 4f dc 22 2a 90 88 46 ee b8 14 de 5e 0b db
#   row a: e0 32 3a 0a 49 06 24 5c c2 d3 ac 62 91 95 e4 79
#   row b: e7 c8 37 6d 8d d5 4e a9 6c 56 f4 ea 65 7a ae 08
#   row c: ba 78 25 2e 1c a6 b4 c6 e8 dd 74 1f 4b bd 8b 8a
#   row d: 70 3e b5 66 48 03 f6 0e 61 35 57 b9 86 c1 1d 9e
#   row e: e1 f8 98 11 69 d9 8e 94 9b 1e 87 e9 ce 55 28 df
#   row f: 8c a1 89 0d bf e6 42 68 41 99 2d 0f b0 54 bb 16
fn _aes_sbox_hex(): i64 {
    return "";
}

# rcon[0..10] as hex: rcon[0] is padding (8d), never used.
fn _aes_rcon_hex(): i64 {
    return "8d01020408102040801b36";
}

fn _aes_decode_nibble(c): i64 {
    if (c >= 48) { if (c <= 57) { return c - 48; } }
    if (c >= 97) { if (c <= 102) { return c - 87; } }
    return 0;
}

fn _aes_decode_hex(buf, hex_str, byte_len): i64 {
    var i = 0;
    while (i < byte_len) {
        var hi = _aes_decode_nibble(load8(hex_str + i * 2) & 0xFF);
        var lo = _aes_decode_nibble(load8(hex_str + i * 2 + 1) & 0xFF);
        store8(buf + i, ((hi << 4) | lo) & 0xFF);
        i = i + 1;
    }
    return 0;
}

fn aes_gcm_global_init(): i64 {
    if (_aes_inited == 1) { return 0; }
    _aes_sbox = alloc(256);
    _aes_rcon = alloc(16);
    _aes_decode_hex(_aes_sbox, _aes_sbox_hex(), 256);
    _aes_decode_hex(_aes_rcon, _aes_rcon_hex(), 11);
    _aes_inited = 1;
    return 0;
}

fn _aes_sub(b): i64 {
    return load8(_aes_sbox + (b & 0xFF)) & 0xFF;
}

# ================================================================
# xtime — multiply a byte by x in GF(2^8) with the AES polynomial
# (x^8 + x^4 + x^3 + x + 1). FIPS 197 § 4.2.1.
# ================================================================

fn _aes_xtime(b): i64 {
    var shifted = (b << 1) & 0xFF;
    if ((b & 0x80) != 0) {
        return (shifted ^ 0x1b) & 0xFF;
    }
    return shifted & 0xFF;
}

# ================================================================
# Key expansion — AES-256: 32-byte key → 240 bytes (15 round keys).
# FIPS 197 § 5.2 algorithm. Nk=8, Nr=14, total expanded size = 4*4*(Nr+1)=240.
# ================================================================

fn aes256_key_expand(key, round_keys): i64 {
    aes_gcm_global_init();
    # First 32 bytes of the expanded key = raw key material.
    memcpy(round_keys, key, 32);

    var i = 8;   # word index into the expanded key
    while (i < 60) {
        # temp = previous word (4 bytes)
        var base = (i - 1) * 4;
        var t0 = load8(round_keys + base + 0) & 0xFF;
        var t1 = load8(round_keys + base + 1) & 0xFF;
        var t2 = load8(round_keys + base + 2) & 0xFF;
        var t3 = load8(round_keys + base + 3) & 0xFF;

        if ((i & 7) == 0) {
            # RotWord
            var rot0 = t1;
            var rot1 = t2;
            var rot2 = t3;
            var rot3 = t0;
            # SubWord
            t0 = _aes_sub(rot0);
            t1 = _aes_sub(rot1);
            t2 = _aes_sub(rot2);
            t3 = _aes_sub(rot3);
            # XOR Rcon[i/8] into t0
            t0 = t0 ^ (load8(_aes_rcon + (i / 8)) & 0xFF);
        } else {
            if ((i & 3) == 0) {
                # Nk=8 path: SubWord only
                t0 = _aes_sub(t0);
                t1 = _aes_sub(t1);
                t2 = _aes_sub(t2);
                t3 = _aes_sub(t3);
            }
        }

        # W[i] = W[i-Nk] XOR temp
        var prev_base = (i - 8) * 4;
        var dst_base = i * 4;
        store8(round_keys + dst_base + 0, (load8(round_keys + prev_base + 0) ^ t0) & 0xFF);
        store8(round_keys + dst_base + 1, (load8(round_keys + prev_base + 1) ^ t1) & 0xFF);
        store8(round_keys + dst_base + 2, (load8(round_keys + prev_base + 2) ^ t2) & 0xFF);
        store8(round_keys + dst_base + 3, (load8(round_keys + prev_base + 3) ^ t3) & 0xFF);

        i = i + 1;
    }
    return 0;
}

# ================================================================
# Key expansion — AES-128: 16-byte key → 176 bytes (11 round keys).
# FIPS 197 § 5.2 algorithm. Nk=4, Nr=10, total expanded size = 4*4*(Nr+1)=176.
# ================================================================
# Differs from AES-256 only in Nk (4 vs 8) and the per-word
# transform schedule: every Nk=4th word gets RotWord+SubWord+Rcon;
# there is no separate "i%4==0 SubWord-only" branch (that branch in
# the AES-256 path exists only because Nk=8 > 4).

fn aes_128_key_expand(key, round_keys): i64 {
    aes_gcm_global_init();
    # First 16 bytes of the expanded key = raw key material.
    memcpy(round_keys, key, 16);

    var i = 4;   # word index into the expanded key
    while (i < 44) {
        # temp = previous word (4 bytes)
        var base = (i - 1) * 4;
        var t0 = load8(round_keys + base + 0) & 0xFF;
        var t1 = load8(round_keys + base + 1) & 0xFF;
        var t2 = load8(round_keys + base + 2) & 0xFF;
        var t3 = load8(round_keys + base + 3) & 0xFF;

        if ((i & 3) == 0) {
            # RotWord
            var rot0 = t1;
            var rot1 = t2;
            var rot2 = t3;
            var rot3 = t0;
            # SubWord
            t0 = _aes_sub(rot0);
            t1 = _aes_sub(rot1);
            t2 = _aes_sub(rot2);
            t3 = _aes_sub(rot3);
            # XOR Rcon[i/4] into t0
            t0 = t0 ^ (load8(_aes_rcon + (i / 4)) & 0xFF);
        }

        # W[i] = W[i-Nk] XOR temp
        var prev_base = (i - 4) * 4;
        var dst_base = i * 4;
        store8(round_keys + dst_base + 0, (load8(round_keys + prev_base + 0) ^ t0) & 0xFF);
        store8(round_keys + dst_base + 1, (load8(round_keys + prev_base + 1) ^ t1) & 0xFF);
        store8(round_keys + dst_base + 2, (load8(round_keys + prev_base + 2) ^ t2) & 0xFF);
        store8(round_keys + dst_base + 3, (load8(round_keys + prev_base + 3) ^ t3) & 0xFF);

        i = i + 1;
    }
    return 0;
}

# ================================================================
# AES single-block encrypt — forward direction (14 or 10 rounds)
# ================================================================
# state is laid out column-major in the spec, but since SubBytes
# and AddRoundKey are per-byte we keep it in native byte order
# and just transpose the ShiftRows / MixColumns accesses.
#
# Layout: state[r*4 + c] = byte at row r, column c.
# AES input is read column-major: in[0]=s[0,0], in[1]=s[1,0],
# in[2]=s[2,0], in[3]=s[3,0], in[4]=s[0,1], etc.
# We store state[col*4 + row] to match that wire order — so
# state[0..3] = column 0, state[4..7] = column 1, etc.

fn _aes_add_round_key(state, rk, round): i64 {
    var off = round * 16;
    var i = 0;
    while (i < 16) {
        store8(state + i,
        (load8(state + i) ^ load8(rk + off + i)) & 0xFF);
        i = i + 1;
    }
    return 0;
}

fn _aes_sub_bytes(state): i64 {
    var i = 0;
    while (i < 16) {
        store8(state + i, _aes_sub(load8(state + i) & 0xFF));
        i = i + 1;
    }
    return 0;
}

fn _aes_shift_rows(state): i64 {
    # State in column-major order: s[c,r] at state[c*4 + r].
    # ShiftRows rotates row r left by r columns: row 0 unchanged,
    # row 1 rotated by 1, row 2 by 2, row 3 by 3.
    # Read into tmp then write back permuted.
    var tmp[16];
    memcpy(&tmp, state, 16);

    # Row 0 (unchanged): columns 0,1,2,3
    # store8(state + 0*4 + 0, load8(&tmp + 0*4 + 0));  (no-op)

    # Row 1 rotated left by 1:
    #   new s[0,1] = old s[1,1]    → state[0*4+1] = tmp[1*4+1]
    #   new s[1,1] = old s[2,1]    → state[1*4+1] = tmp[2*4+1]
    #   new s[2,1] = old s[3,1]    → state[2*4+1] = tmp[3*4+1]
    #   new s[3,1] = old s[0,1]    → state[3*4+1] = tmp[0*4+1]
    store8(state +  1, load8(&tmp +  5));
    store8(state +  5, load8(&tmp +  9));
    store8(state +  9, load8(&tmp + 13));
    store8(state + 13, load8(&tmp +  1));

    # Row 2 rotated left by 2:
    store8(state +  2, load8(&tmp + 10));
    store8(state +  6, load8(&tmp + 14));
    store8(state + 10, load8(&tmp +  2));
    store8(state + 14, load8(&tmp +  6));

    # Row 3 rotated left by 3 (equivalently: right by 1):
    store8(state +  3, load8(&tmp + 15));
    store8(state +  7, load8(&tmp +  3));
    store8(state + 11, load8(&tmp +  7));
    store8(state + 15, load8(&tmp + 11));
    return 0;
}

fn _aes_mix_columns(state): i64 {
    # MixColumns transforms each column independently.
    # s'[0,c] = 2·s[0,c] ^ 3·s[1,c] ^ s[2,c] ^ s[3,c]
    # s'[1,c] = s[0,c] ^ 2·s[1,c] ^ 3·s[2,c] ^ s[3,c]
    # s'[2,c] = s[0,c] ^ s[1,c] ^ 2·s[2,c] ^ 3·s[3,c]
    # s'[3,c] = 3·s[0,c] ^ s[1,c] ^ s[2,c] ^ 2·s[3,c]
    # Where 2·x = xtime(x), 3·x = xtime(x) ^ x.
    var c = 0;
    while (c < 4) {
        var a0 = load8(state + c * 4 + 0) & 0xFF;
        var a1 = load8(state + c * 4 + 1) & 0xFF;
        var a2 = load8(state + c * 4 + 2) & 0xFF;
        var a3 = load8(state + c * 4 + 3) & 0xFF;

        var x0 = _aes_xtime(a0);
        var x1 = _aes_xtime(a1);
        var x2 = _aes_xtime(a2);
        var x3 = _aes_xtime(a3);

        var n0 = (x0 ^ (x1 ^ a1) ^ a2 ^ a3) & 0xFF;
        var n1 = (a0 ^ x1 ^ (x2 ^ a2) ^ a3) & 0xFF;
        var n2 = (a0 ^ a1 ^ x2 ^ (x3 ^ a3)) & 0xFF;
        var n3 = ((x0 ^ a0) ^ a1 ^ a2 ^ x3) & 0xFF;

        store8(state + c * 4 + 0, n0);
        store8(state + c * 4 + 1, n1);
        store8(state + c * 4 + 2, n2);
        store8(state + c * 4 + 3, n3);
        c = c + 1;
    }
    return 0;
}

# _aes_encrypt_block_sw — FIPS 197 §5.1 software block encrypt,
# parametrized on the round count `nr` (14 for AES-256, 10 for
# AES-128). The round transform is identical across key sizes; only
# the number of middle rounds and the index of the final round key
# differ. `nr - 1` middle rounds (SubBytes/ShiftRows/MixColumns/
# AddRoundKey), then the final round drops MixColumns.
fn _aes_encrypt_block_sw(round_keys, in_block, out_block, nr): i64 {
    var state[16];
    memcpy(&state, in_block, 16);

    # Initial round key
    _aes_add_round_key(&state, round_keys, 0);

    # Middle rounds
    var r = 1;
    while (r < nr) {
        _aes_sub_bytes(&state);
        _aes_shift_rows(&state);
        _aes_mix_columns(&state);
        _aes_add_round_key(&state, round_keys, r);
        r = r + 1;
    }

    # Final round (no MixColumns)
    _aes_sub_bytes(&state);
    _aes_shift_rows(&state);
    _aes_add_round_key(&state, round_keys, nr);

    memcpy(out_block, &state, 16);
    return 0;
}

# AES-NI dispatch note (applies to both block dispatchers below).
# The PXOR / AESENC memory-operand forms used by the _ni variants
# require the round_keys pointer to be 16-byte aligned (#GP
# otherwise). Cyrius 5.5.21 guarantees 16-alignment for array globals
# `var rk[240]` / `var rk[176]`, and `fl_alloc(N)` returns 16-aligned
# pointers because the block header is a multiple of 16.
# Bump-`alloc(N)` is only 8-byte aligned, so callers using that path
# bypass the NI branch here and run the software fallback — matches
# the CLAUDE.md discipline ("fl_alloc for round keys") without
# requiring every call site to know about the alignment invariant.

fn aes256_encrypt_block(round_keys, in_block, out_block): i64 {
    if (aes_ni_available() == 1) {
        if ((round_keys & 15) == 0) {
            aes256_encrypt_block_ni(round_keys, in_block, out_block);
            return 0;
        }
    }
    return _aes_encrypt_block_sw(round_keys, in_block, out_block, 14);
}

fn aes128_encrypt_block(round_keys, in_block, out_block): i64 {
    if (aes_ni_available() == 1) {
        if ((round_keys & 15) == 0) {
            aes128_encrypt_block_ni(round_keys, in_block, out_block);
            return 0;
        }
    }
    return _aes_encrypt_block_sw(round_keys, in_block, out_block, 10);
}

# Round-count-parametrized dispatch helpers — let the shared GCM /
# CTR machinery drive either key size by passing `nr` (14 = AES-256,
# 10 = AES-128). `nr` also fixes the expanded key-schedule size:
# rk_size = 16 * (nr + 1) → 240 for AES-256, 176 for AES-128.
fn _aes_keyexp(key, round_keys, nr): i64 {
    if (nr == 14) { return aes256_key_expand(key, round_keys); }
    return aes_128_key_expand(key, round_keys);
}

fn _aes_block_enc(round_keys, in_block, out_block, nr): i64 {
    if (nr == 14) { return aes256_encrypt_block(round_keys, in_block, out_block); }
    return aes128_encrypt_block(round_keys, in_block, out_block);
}

# ================================================================
# GHASH — GF(2^128) multiplication with reduction polynomial
# R = x^128 + x^7 + x^2 + x + 1. NIST SP 800-38D § 6.3.
# ================================================================
# Inputs are 128-bit blocks laid out big-endian (bit 0 is the MSB
# of byte 0 by GCM convention).
#
# Bit-by-bit right-shift multiply (Algorithm in NIST SP 800-38D
# Appendix A — constant-time, no table):
#     Z = 0, V = Y
#     for i = 0..127:
#         if bit i of X (high-to-low) == 1: Z ^= V
#         if V's LSbit == 0: V >>= 1
#         else: V = (V >> 1) ^ R_reduced
#
# The reduction polynomial R in the bit-reversed GCM convention
# becomes 0xE1000...00 as the MSByte after a right-shift on V.

fn _ghash_shift_right_and_reduce(v): i64 {
    # v is a 16-byte little-endian-of-bytes / big-endian-of-bits
    # block. Shift the whole block right by 1 bit, with carry
    # propagating from byte 0 → byte 1 → ... → byte 15.
    # If the original v[15] LSbit was 1, after the shift XOR 0xE1
    # into v[0] (the GCM reduction R').
    var lsb_set = load8(v + 15) & 1;
    var i = 15;
    while (i > 0) {
        var hi = (load8(v + i - 1) & 1) << 7;
        var cur = ((load8(v + i) & 0xFF) >> 1) & 0x7F;
        store8(v + i, (cur | hi) & 0xFF);
        i = i - 1;
    }
    store8(v, ((load8(v) & 0xFF) >> 1) & 0x7F);
    if (lsb_set == 1) {
        store8(v, (load8(v) ^ 0xE1) & 0xFF);
    }
    return 0;
}

fn _ghash_xor_16(dst, src): i64 {
    var i = 0;
    while (i < 16) {
        store8(dst + i, (load8(dst + i) ^ load8(src + i)) & 0xFF);
        i = i + 1;
    }
    return 0;
}

# _ghash_mul: Z = X * H in GF(2^128).
# X: 16 bytes (input, read-only). H: 16 bytes (hash subkey, read-only).
# z: 16 bytes (output, caller-provided, will be overwritten).
# V is a 16-byte working copy of H — secret material; `secret var`
# zeroizes it on every return path.
fn _ghash_mul(z, x, h): i64 {
    secret var v[16];
    memcpy(&v, h, 16);
    memset(z, 0, 16);

    var byte = 0;
    while (byte < 16) {
        var b = load8(x + byte) & 0xFF;
        var bit = 0;
        while (bit < 8) {
            var mask = (b >> (7 - bit)) & 1;
            if (mask == 1) {
                _ghash_xor_16(z, &v);
            }
            _ghash_shift_right_and_reduce(&v);
            bit = bit + 1;
        }
        byte = byte + 1;
    }
    return 0;
}

# GHASH over an arbitrary-length buffer: splits into 16-byte
# blocks, zero-pads the tail, XOR-then-multiplies each block into
# the running tag. Caller supplies the 16-byte output buffer `y`
# initialized to zeros (for the outer GHASH call) or to the
# running accumulator.
fn _ghash_update(y, h, data, len): i64 {
    # block holds plaintext / ciphertext bytes during GHASH absorb;
    # scratch / scratch2 hold the GF(2^128) product. All three are
    # secret-derived — `secret var` zeroes them on return.
    secret var block[16];
    secret var scratch[16];
    secret var scratch2[16];
    var pos = 0;
    while (pos + 16 <= len) {
        memcpy(&block, data + pos, 16);
        _ghash_xor_16(y, &block);
        # Z = Y * H, stored back into Y via scratch.
        _ghash_mul(&scratch, y, h);
        memcpy(y, &scratch, 16);
        pos = pos + 16;
    }
    var remaining = len - pos;
    if (remaining > 0) {
        # Re-zero block: only `remaining` bytes get copied in below;
        # the upper (16 - remaining) bytes must be zero for the
        # zero-padded tail-block convention.
        memset(&block, 0, 16);
        memcpy(&block, data + pos, remaining);
        _ghash_xor_16(y, &block);
        _ghash_mul(&scratch2, y, h);
        memcpy(y, &scratch2, 16);
    }
    return 0;
}

# ================================================================
# Big-endian 64-bit store — used for GHASH length block
# ================================================================

fn _be64_store(buf, v): i64 {
    store8(buf + 0, (v >> 56) & 0xFF);
    store8(buf + 1, (v >> 48) & 0xFF);
    store8(buf + 2, (v >> 40) & 0xFF);
    store8(buf + 3, (v >> 32) & 0xFF);
    store8(buf + 4, (v >> 24) & 0xFF);
    store8(buf + 5, (v >> 16) & 0xFF);
    store8(buf + 6, (v >>  8) & 0xFF);
    store8(buf + 7,  v        & 0xFF);
    return 0;
}

fn _be32_store(buf, v): i64 {
    store8(buf + 0, (v >> 24) & 0xFF);
    store8(buf + 1, (v >> 16) & 0xFF);
    store8(buf + 2, (v >>  8) & 0xFF);
    store8(buf + 3,  v        & 0xFF);
    return 0;
}

fn _be32_load(buf): i64 {
    return ((load8(buf + 0) & 0xFF) << 24)
    | ((load8(buf + 1) & 0xFF) << 16)
    | ((load8(buf + 2) & 0xFF) <<  8)
    | ((load8(buf + 3) & 0xFF)      );
}

# ================================================================
# CTR-mode XOR: produce keystream block AES(K, counter) and XOR
# into data. The low 32 bits of the 16-byte counter increment
# between blocks (big-endian).
# ================================================================

fn _aes_gcm_ctr_xor(round_keys, counter, src, dst, len, nr): i64 {
    # CTR keystream block — XOR-masks the plaintext, so leakage
    # recovers plaintext. `secret var` zeroes on every return.
    secret var ks[16];
    var pos = 0;
    while (pos < len) {
        _aes_block_enc(round_keys, counter, &ks, nr);
        var chunk = 16;
        if (len - pos < 16) { chunk = len - pos; }
        var i = 0;
        while (i < chunk) {
            store8(dst + pos + i,
            (load8(src + pos + i) ^ load8(&ks + i)) & 0xFF);
            i = i + 1;
        }
        # Increment low 32 bits, big-endian, in place.
        var ctr_val = _be32_load(counter + 12);
        ctr_val = (ctr_val + 1) & 0xFFFFFFFF;
        _be32_store(counter + 12, ctr_val);
        pos = pos + chunk;
    }
    return 0;
}

# ================================================================
# GCM AEAD encrypt — shared driver, parametrized on round count
# ================================================================
# `nr` selects the cipher: 14 = AES-256 (32-byte key), 10 = AES-128
# (16-byte key). rk_size = 16 * (nr + 1). All GCM framing (J0, CTR,
# GHASH, tag) is key-size-independent. Public entry points
# aes_gcm_encrypt / aes_128_gcm_encrypt wrap this with the fixed nr.
#
# Inputs:
#   key      — 32 bytes (nr=14) or 16 bytes (nr=10)
#   iv       — 12 bytes (96-bit IV; RFC fast path)
#   aad      — additional authenticated data, aad_len bytes (may be 0)
#   pt       — plaintext, pt_len bytes (may be 0)
# Outputs:
#   ct_out   — ciphertext buffer, pt_len bytes (caller-allocated)
#   tag_out  — 16-byte authentication tag (caller-allocated)
# Returns 0 on success, non-zero on input-validation failure.
#
# Security: round-key buffer and H are zeroized before free.

fn _aes_gcm_encrypt_impl(key, iv, aad, aad_len, pt, pt_len, ct_out, tag_out, nr): i64 {
    if (aad_len < 0) { return (0 - 1); }
    if (pt_len < 0) { return (0 - 1); }

    aes_gcm_global_init();

    var rk_size = 16 * (nr + 1);
    var round_keys = fl_alloc(rk_size);
    _aes_keyexp(key, round_keys, nr);

    # H = AES_K(0^128). h is the GHASH subkey — key-derived secret.
    var zero_block[16];
    memset(&zero_block, 0, 16);
    secret var h[16];
    _aes_block_enc(round_keys, &zero_block, &h, nr);

    # J0 = IV || 0x00000001
    var j0[16];
    memcpy(&j0, iv, 12);
    store8(&j0 + 12, 0);
    store8(&j0 + 13, 0);
    store8(&j0 + 14, 0);
    store8(&j0 + 15, 1);

    # Counter starts at inc32(J0) — low 32 bits incremented.
    var counter[16];
    memcpy(&counter, &j0, 16);
    var ctr_val = _be32_load(&counter + 12);
    ctr_val = (ctr_val + 1) & 0xFFFFFFFF;
    _be32_store(&counter + 12, ctr_val);

    # Encrypt plaintext via CTR mode
    if (pt_len > 0) {
        _aes_gcm_ctr_xor(round_keys, &counter, pt, ct_out, pt_len, nr);
    }

    # GHASH over AAD || pad || CT || pad || len(AAD)||len(CT) in bits BE.
    # y is the running GHASH accumulator — secret-derived.
    secret var y[16];
    memset(&y, 0, 16);
    if (aad_len > 0) {
        _ghash_update(&y, &h, aad, aad_len);
    }
    if (pt_len > 0) {
        _ghash_update(&y, &h, ct_out, pt_len);
    }
    var len_block[16];
    memset(&len_block, 0, 16);
    _be64_store(&len_block + 0, aad_len * 8);
    _be64_store(&len_block + 8, pt_len * 8);
    _ghash_update(&y, &h, &len_block, 16);

    # Tag = Y XOR AES_K(J0). s = AES_K(J0) — key-derived secret.
    secret var s[16];
    _aes_block_enc(round_keys, &j0, &s, nr);
    var i = 0;
    while (i < 16) {
        store8(tag_out + i, (load8(&y + i) ^ load8(&s + i)) & 0xFF);
        i = i + 1;
    }

    # round_keys is heap (fl_alloc) — `secret var` doesn't reach it;
    # zero explicitly before free. h/y/s are `secret var` — zeroed
    # by the compiler on return. j0/counter/zero_block/len_block are
    # IV / length / constant inputs (not key material); zeroed
    # explicitly as defense-in-depth.
    memset(round_keys, 0, rk_size);
    fl_free(round_keys);
    memset(&counter, 0, 16);
    memset(&j0, 0, 16);
    memset(&zero_block, 0, 16);
    memset(&len_block, 0, 16);
    return 0;
}

# aes_gcm_encrypt — AES-256-GCM AEAD encrypt (FIPS 197 + NIST SP
# 800-38D). key is 32 bytes; iv is 12 bytes; aad/pt may be empty.
# Writes pt_len ciphertext bytes to ct_out and a 16-byte tag to
# tag_out. Returns 0 on success, non-zero on input-validation failure.
fn aes_gcm_encrypt(key, iv, aad, aad_len, pt, pt_len, ct_out, tag_out): i64 {
    return _aes_gcm_encrypt_impl(key, iv, aad, aad_len, pt, pt_len, ct_out, tag_out, 14);
}

# aes_128_gcm_encrypt — AES-128-GCM AEAD encrypt (FIPS 197 + NIST SP
# 800-38D). Identical contract to aes_gcm_encrypt but with a 16-byte
# key (10-round schedule). Drives the TLS 1.3 TLS_AES_128_GCM_SHA256
# (0x1301) ciphersuite and the TLS 1.2 *_WITH_AES_128_GCM_SHA256
# suites. Returns 0 on success, non-zero on input-validation failure.
fn aes_128_gcm_encrypt(key, iv, aad, aad_len, pt, pt_len, ct_out, tag_out): i64 {
    return _aes_gcm_encrypt_impl(key, iv, aad, aad_len, pt, pt_len, ct_out, tag_out, 10);
}

# ================================================================
# GCM AEAD decrypt with tag verification — shared driver
# ================================================================
# `nr` selects the cipher (14 = AES-256, 10 = AES-128); see the
# encrypt driver above. Public entry points aes_gcm_decrypt /
# aes_128_gcm_decrypt wrap this with the fixed nr.
#
# Inputs:
#   key      — 32 bytes (nr=14) or 16 bytes (nr=10)
#   iv       — 12 bytes
#   aad      — aad_len bytes
#   ct       — ciphertext, ct_len bytes
#   tag      — 16-byte received tag
# Output:
#   pt_out   — plaintext, ct_len bytes (caller-allocated)
# Returns:
#   ERR_NONE on success
#   ERR_INTEGRITY_MISMATCH on tag mismatch (pt_out NOT populated
#       with real plaintext — it is zeroed on failure).
#   ERR_INVALID_INPUT on length validation failure.
#
# AEAD contract: plaintext MUST NOT be released until the tag is
# verified. We compute & verify the tag first, then derive pt.

fn _aes_gcm_decrypt_impl(key, iv, aad, aad_len, ct, ct_len, tag, pt_out, nr): i64 {
    if (aad_len < 0) { return ERR_INVALID_INPUT; }
    if (ct_len < 0) { return ERR_INVALID_INPUT; }

    aes_gcm_global_init();

    var rk_size = 16 * (nr + 1);
    var round_keys = fl_alloc(rk_size);
    _aes_keyexp(key, round_keys, nr);

    # H = AES_K(0). h is the GHASH subkey — key-derived secret.
    var zero_block[16];
    memset(&zero_block, 0, 16);
    secret var h[16];
    _aes_block_enc(round_keys, &zero_block, &h, nr);

    # J0 = IV || 0x00000001
    var j0[16];
    memcpy(&j0, iv, 12);
    store8(&j0 + 12, 0);
    store8(&j0 + 13, 0);
    store8(&j0 + 14, 0);
    store8(&j0 + 15, 1);

    # Compute expected tag over received ciphertext BEFORE
    # touching pt_out. y is the running GHASH accumulator — secret.
    secret var y[16];
    memset(&y, 0, 16);
    if (aad_len > 0) {
        _ghash_update(&y, &h, aad, aad_len);
    }
    if (ct_len > 0) {
        _ghash_update(&y, &h, ct, ct_len);
    }
    var len_block[16];
    memset(&len_block, 0, 16);
    _be64_store(&len_block + 0, aad_len * 8);
    _be64_store(&len_block + 8, ct_len * 8);
    _ghash_update(&y, &h, &len_block, 16);

    # s = AES_K(J0); expected_tag = Y XOR s. Both key-derived.
    secret var s[16];
    _aes_block_enc(round_keys, &j0, &s, nr);
    secret var expected_tag[16];
    var i = 0;
    while (i < 16) {
        store8(&expected_tag + i, (load8(&y + i) ^ load8(&s + i)) & 0xFF);
        i = i + 1;
    }

    # Constant-time tag compare. ct_eq_bytes_lens loops the full
    # length even on first mismatch — no early exit on secret data.
    # Lengths equal-by-construction (both 16 = poly1305 tag); could
    # equivalently call ct_eq_bytes(_, _, 16) since the dual-length
    # form's mismatch-fast-path is unreachable here. Kept dual-length
    # for symmetry with the v5.9.20 sigil 3.0.2 migration shape.
    var ok = ct_eq_bytes_lens(&expected_tag, 16, tag, 16);

    # Decrypt via CTR starting at inc32(J0) — we perform the CTR
    # pass unconditionally to keep the work profile flat across
    # valid and forged tag paths. If the tag failed, pt_out is
    # zeroed *after* CTR so no real plaintext ever escapes.
    var counter[16];
    memcpy(&counter, &j0, 16);
    var ctr_val = _be32_load(&counter + 12);
    ctr_val = (ctr_val + 1) & 0xFFFFFFFF;
    _be32_store(&counter + 12, ctr_val);

    if (ct_len > 0) {
        _aes_gcm_ctr_xor(round_keys, &counter, ct, pt_out, ct_len, nr);
    }

    var rc = ERR_NONE;
    if (ok != 1) {
        # Overwrite the computed plaintext so the caller never
        # observes pre-auth bytes. AEAD no-plaintext-leak contract.
        if (ct_len > 0) {
            memset(pt_out, 0, ct_len);
        }
        rc = ERR_INTEGRITY_MISMATCH;
    }

    # round_keys is heap (fl_alloc); zero explicitly before free.
    # h/y/s/expected_tag are `secret var` — zeroed on return by the
    # compiler. j0/counter/zero_block/len_block are IV / length /
    # constant inputs (not key material); zeroed as defense-in-depth.
    memset(round_keys, 0, rk_size);
    fl_free(round_keys);
    memset(&counter, 0, 16);
    memset(&j0, 0, 16);
    memset(&zero_block, 0, 16);
    memset(&len_block, 0, 16);
    return rc;
}

# aes_gcm_decrypt — AES-256-GCM AEAD decrypt with tag verification.
# key is 32 bytes; iv is 12 bytes. Returns ERR_NONE on success,
# ERR_INTEGRITY_MISMATCH on tag mismatch (pt_out zeroed), or
# ERR_INVALID_INPUT on length-validation failure.
fn aes_gcm_decrypt(key, iv, aad, aad_len, ct, ct_len, tag, pt_out): i64 {
    return _aes_gcm_decrypt_impl(key, iv, aad, aad_len, ct, ct_len, tag, pt_out, 14);
}

# aes_128_gcm_decrypt — AES-128-GCM AEAD decrypt with tag
# verification. Identical contract to aes_gcm_decrypt but with a
# 16-byte key (10-round schedule). Drives the TLS 1.3
# TLS_AES_128_GCM_SHA256 (0x1301) ciphersuite and the TLS 1.2
# *_WITH_AES_128_GCM_SHA256 suites.
fn aes_128_gcm_decrypt(key, iv, aad, aad_len, ct, ct_len, tag, pt_out): i64 {
    return _aes_gcm_decrypt_impl(key, iv, aad, aad_len, ct, ct_len, tag, pt_out, 10);
}

# --- poly1305.cyr ---

# poly1305.cyr — Poly1305 one-time message authenticator (RFC 8439 §2.5)
#
# Poly1305 authenticates a message under a 32-byte ONE-TIME key:
#   tag = (((acc) * r) mod (2^130 - 5)) + s   mod 2^128
# where the key splits into r (clamped, bytes 0..15) and s
# (bytes 16..31). It is the MAC half of the ChaCha20-Poly1305 AEAD
# (RFC 8439 §2.8), but ships here standalone ahead of that arc — a
# MAC primitive has no dependency on ChaCha20 or TLS.
#
# === SECURITY CONTRACT: ONE-TIME KEY ===========================
# The 32-byte key MUST be unique per message. Authenticating two
# distinct messages under the same key lets an attacker recover r
# and forge tags (RFC 8439 §2.6). Unlike HMAC (src/hmac.cyr),
# Poly1305 is NOT a reusable-key MAC. For the AEAD, the one-time
# key is derived fresh from the ChaCha20 keystream (counter 0) per
# nonce.
# ===============================================================
#
# Implementation: the 26-bit-limb ("poly1305-donna") form. Five
# 26-bit limbs keep every intermediate product below 2^59, so the
# whole reduction runs in signed i64 with no 128-bit arithmetic
# path. The final freeze is constant-time (mask-select, no branch
# on the key-derived accumulator) per sigil's constant-time-on-
# secret-data rule (CLAUDE.md Key Principles).
#
# THREAD-SAFETY: `_p1305_block` scratch is a single-call buffer;
# `poly1305_mac` fully writes it before reading (CLAUDE.md quirk
# #1). Serial use is correct. Parallel-batch callers must follow
# the per-worker-scratch discipline coming in the v3.6 cycle —
# until then this MAC is not on a multi-threaded path.
#
# Citation: RFC 8439 §2.5 (algorithm), §2.5.2 (worked example),
# Appendix A.3 (test vectors). See docs/sources.md.

# ================================================================
# Little-endian 4-byte codec
# ================================================================

# Read 4 little-endian bytes at p as an i64 in [0, 2^32).
fn _p1305_u8to32(p): i64 {
    return (load8(p) & 0xFF)
         | ((load8(p + 1) & 0xFF) << 8)
         | ((load8(p + 2) & 0xFF) << 16)
         | ((load8(p + 3) & 0xFF) << 24);
}

# Write the low 32 bits of v as 4 little-endian bytes at p.
fn _p1305_u32to8(p, v): i64 {
    store8(p,     v & 0xFF);
    store8(p + 1, (v >> 8) & 0xFF);
    store8(p + 2, (v >> 16) & 0xFF);
    store8(p + 3, (v >> 24) & 0xFF);
    return 0;
}

# ================================================================
# poly1305_mac — one-shot tag computation
#   key      — 32 bytes (r || s), one-time
#   msg      — message bytes
#   msg_len  — message length in bytes (any length, incl. 0)
#   out      — 16-byte tag buffer (caller-allocated)
# Returns 0.
# ================================================================
fn poly1305_mac(key, msg, msg_len, out): i64 {
    # ---- Load + clamp r (bytes 0..15), split into 5×26-bit limbs.
    # The masks fold RFC 8439's r-clamp
    # (0x0ffffffc0ffffffc0ffffffc0fffffff) into the limb split.
    var t0 = _p1305_u8to32(key);
    var t1 = _p1305_u8to32(key + 4);
    var t2 = _p1305_u8to32(key + 8);
    var t3 = _p1305_u8to32(key + 12);

    var r0 = t0 & 0x3ffffff;
    var r1 = ((t0 >> 26) | (t1 << 6)) & 0x3ffff03;
    var r2 = ((t1 >> 20) | (t2 << 12)) & 0x3ffc0ff;
    var r3 = ((t2 >> 14) | (t3 << 18)) & 0x3f03fff;
    var r4 = (t3 >> 8) & 0x00fffff;

    # Precompute 5*r_i for the wrap-around terms (2^130 ≡ 5 mod p).
    var s1 = r1 * 5;
    var s2 = r2 * 5;
    var s3 = r3 * 5;
    var s4 = r4 * 5;

    # ---- s (pad, bytes 16..31) as four 32-bit words.
    var pad0 = _p1305_u8to32(key + 16);
    var pad1 = _p1305_u8to32(key + 20);
    var pad2 = _p1305_u8to32(key + 24);
    var pad3 = _p1305_u8to32(key + 28);

    # ---- Accumulator (5×26-bit limbs), starts at 0.
    var h0 = 0; var h1 = 0; var h2 = 0; var h3 = 0; var h4 = 0;

    # Single-call scratch for the final partial block; `secret var`
    # zeroes it on return (it transiently holds message bytes).
    secret var block[16];

    var done = 0;
    while (done < msg_len) {
        var remaining = msg_len - done;
        var mp = msg + done;
        # Full block: implicit high bit via hibit = 2^128 (1<<24 in
        # limb 4). Partial block: pad to 16 with an explicit 0x01
        # after the data and hibit = 0.
        var hibit = 1 << 24;
        if (remaining < 16) {
            memset(&block, 0, 16);
            memcpy(&block, msg + done, remaining);
            store8(&block + remaining, 1);
            mp = &block;
            hibit = 0;
        }

        # h += block (read overlapping 32-bit windows into limbs)
        h0 = h0 + (_p1305_u8to32(mp) & 0x3ffffff);
        h1 = h1 + ((_p1305_u8to32(mp + 3) >> 2) & 0x3ffffff);
        h2 = h2 + ((_p1305_u8to32(mp + 6) >> 4) & 0x3ffffff);
        h3 = h3 + ((_p1305_u8to32(mp + 9) >> 6) & 0x3ffffff);
        h4 = h4 + ((_p1305_u8to32(mp + 12) >> 8) | hibit);

        # h *= r  (schoolbook with 2^130 ≡ 5 wrap; products < 2^59)
        var d0 = h0 * r0 + h1 * s4 + h2 * s3 + h3 * s2 + h4 * s1;
        var d1 = h0 * r1 + h1 * r0 + h2 * s4 + h3 * s3 + h4 * s2;
        var d2 = h0 * r2 + h1 * r1 + h2 * r0 + h3 * s4 + h4 * s3;
        var d3 = h0 * r3 + h1 * r2 + h2 * r1 + h3 * r0 + h4 * s4;
        var d4 = h0 * r4 + h1 * r3 + h2 * r2 + h3 * r1 + h4 * r0;

        # Carry-propagate back into 26-bit limbs.
        var c = d0 >> 26; h0 = d0 & 0x3ffffff;
        d1 = d1 + c; c = d1 >> 26; h1 = d1 & 0x3ffffff;
        d2 = d2 + c; c = d2 >> 26; h2 = d2 & 0x3ffffff;
        d3 = d3 + c; c = d3 >> 26; h3 = d3 & 0x3ffffff;
        d4 = d4 + c; c = d4 >> 26; h4 = d4 & 0x3ffffff;
        h0 = h0 + c * 5; c = h0 >> 26; h0 = h0 & 0x3ffffff;
        h1 = h1 + c;

        done = done + 16;
    }

    # ---- Fully carry h (h0 already < 2^26 from the last block).
    var c = h1 >> 26; h1 = h1 & 0x3ffffff;
    h2 = h2 + c; c = h2 >> 26; h2 = h2 & 0x3ffffff;
    h3 = h3 + c; c = h3 >> 26; h3 = h3 & 0x3ffffff;
    h4 = h4 + c; c = h4 >> 26; h4 = h4 & 0x3ffffff;
    h0 = h0 + c * 5; c = h0 >> 26; h0 = h0 & 0x3ffffff;
    h1 = h1 + c;

    # ---- Compute g = h + 5 (then subtract 2^130 from the top
    # limb). If h >= p the top borrow stays clear (g4 >= 0); if
    # h < p the subtraction underflows (g4 < 0). Constant-time
    # select between h and g with no branch on the accumulator.
    var g0 = h0 + 5; c = g0 >> 26; g0 = g0 & 0x3ffffff;
    var g1 = h1 + c; c = g1 >> 26; g1 = g1 & 0x3ffffff;
    var g2 = h2 + c; c = g2 >> 26; g2 = g2 & 0x3ffffff;
    var g3 = h3 + c; c = g3 >> 26; g3 = g3 & 0x3ffffff;
    var g4 = h4 + c - (1 << 26);

    # sign = 1 ⟺ g4 negative ⟺ h < p (keep h); 0 ⟺ h >= p (take g).
    # Isolate the sign bit with &1 so the result is independent of
    # whether `>>` is arithmetic or logical.
    var sign = (g4 >> 63) & 1;
    var mask_g = sign - 1;   # all-ones when h >= p
    var mask_h = 0 - sign;   # all-ones when h <  p
    h0 = (h0 & mask_h) | (g0 & mask_g);
    h1 = (h1 & mask_h) | (g1 & mask_g);
    h2 = (h2 & mask_h) | (g2 & mask_g);
    h3 = (h3 & mask_h) | (g3 & mask_g);
    h4 = (h4 & mask_h) | (g4 & mask_g);

    # ---- Collapse 5×26-bit limbs into 4×32-bit words.
    h0 = (h0 | (h1 << 26)) & 0xffffffff;
    h1 = ((h1 >> 6) | (h2 << 20)) & 0xffffffff;
    h2 = ((h2 >> 12) | (h3 << 14)) & 0xffffffff;
    h3 = ((h3 >> 18) | (h4 << 8)) & 0xffffffff;

    # ---- tag = (h + s) mod 2^128, little-endian.
    var f = h0 + pad0;             h0 = f & 0xffffffff;
    f = h1 + pad1 + (f >> 32);     h1 = f & 0xffffffff;
    f = h2 + pad2 + (f >> 32);     h2 = f & 0xffffffff;
    f = h3 + pad3 + (f >> 32);     h3 = f & 0xffffffff;

    _p1305_u32to8(out,      h0);
    _p1305_u32to8(out + 4,  h1);
    _p1305_u32to8(out + 8,  h2);
    _p1305_u32to8(out + 12, h3);

    # Best-effort scrub of key-derived scalars. (Cyrius `secret var`
    # guarantees zeroization for stack arrays only; scalar locals
    # rely on these explicit clears — same stance as the mldsa
    # module-global workspace buffers.)
    r0 = 0; r1 = 0; r2 = 0; r3 = 0; r4 = 0;
    s1 = 0; s2 = 0; s3 = 0; s4 = 0;
    pad0 = 0; pad1 = 0; pad2 = 0; pad3 = 0;
    t0 = 0; t1 = 0; t2 = 0; t3 = 0;
    return 0;
}

# ================================================================
# poly1305_verify — constant-time tag check
#   Returns 1 if the recomputed tag matches `tag`, 0 otherwise.
#   Compares via the stdlib constant-time `ct_eq_bytes` so a
#   forgery attempt learns nothing from comparison timing.
# ================================================================
fn poly1305_verify(key, msg, msg_len, tag): i64 {
    secret var computed[16];
    poly1305_mac(key, msg, msg_len, &computed);
    var ok = ct_eq_bytes(&computed, tag, 16);
    return ok;
}

# --- chacha20.cyr ---

# chacha20.cyr — ChaCha20 stream cipher (RFC 8439 §2.3 / §2.4)
#
# ChaCha20 is D. J. Bernstein's 256-bit stream cipher. It keys a
# 4x4 matrix of 32-bit words — 4 constant words ("expand 32-byte
# k"), 8 key words, a 32-bit block counter, and a 96-bit nonce —
# then applies 20 rounds (10 column/diagonal double-rounds) of the
# ARX quarter-round and adds the original state back to produce a
# 64-byte keystream block. Encryption XORs the keystream into the
# plaintext; decryption is the identical XOR.
#
# It is the cipher half of the ChaCha20-Poly1305 AEAD (RFC 8439
# §2.8) — TLS 1.3's `TLS_CHACHA20_POLY1305_SHA256` suite — and the
# source of the Poly1305 one-time key (block at counter 0).
#
# THREAD-SAFETY: the `chacha20_block` working state lives in
# function-scope `var` arrays (Cyrius static globals, quirk #1);
# each call fully writes them before reading, so serial use is
# correct. Multi-threaded callers follow the per-worker-scratch
# discipline of the v3.6 cycle — ChaCha20 is not yet on a parallel
# path.
#
# Citation: RFC 8439 §2.1 (quarter round), §2.3 (block function),
# §2.3.2 / §2.4.2 (test vectors). See docs/sources.md.

# ================================================================
# Little-endian 4-byte codec
# ================================================================

fn _chacha_u8to32le(p): i64 {
    return (load8(p) & 0xFF)
         | ((load8(p + 1) & 0xFF) << 8)
         | ((load8(p + 2) & 0xFF) << 16)
         | ((load8(p + 3) & 0xFF) << 24);
}

fn _chacha_u32to8le(p, v): i64 {
    store8(p,     v & 0xFF);
    store8(p + 1, (v >> 8) & 0xFF);
    store8(p + 2, (v >> 16) & 0xFF);
    store8(p + 3, (v >> 24) & 0xFF);
    return 0;
}

# 32-bit left rotation. v is held in [0, 2^32); mask after the
# shift-or so the result stays a clean 32-bit word.
fn _chacha_rotl32(v, n): i64 {
    return ((v << n) | (v >> (32 - n))) & 0xffffffff;
}

# ================================================================
# Quarter round (RFC 8439 §2.1) over four words of the working
# state array `ws` (16 i64 slots, one 32-bit word each).
# ================================================================
fn _chacha_qr(ws, a, b, c, d): i64 {
    var va = load64(ws + a * 8);
    var vb = load64(ws + b * 8);
    var vc = load64(ws + c * 8);
    var vd = load64(ws + d * 8);

    va = (va + vb) & 0xffffffff; vd = _chacha_rotl32(vd ^ va, 16);
    vc = (vc + vd) & 0xffffffff; vb = _chacha_rotl32(vb ^ vc, 12);
    va = (va + vb) & 0xffffffff; vd = _chacha_rotl32(vd ^ va, 8);
    vc = (vc + vd) & 0xffffffff; vb = _chacha_rotl32(vb ^ vc, 7);

    store64(ws + a * 8, va);
    store64(ws + b * 8, vb);
    store64(ws + c * 8, vc);
    store64(ws + d * 8, vd);
    return 0;
}

# ================================================================
# chacha20_block — one 64-byte keystream block
#   key      — 32 bytes
#   nonce    — 12 bytes (96-bit)
#   counter  — 32-bit block counter
#   out      — 64-byte keystream buffer (caller-allocated)
# Returns 0.
# ================================================================
fn chacha20_block(key, nonce, counter, out): i64 {
    secret var st[128];   # 16 words: constants | key | counter | nonce

    # Constants — little-endian words of "expand 32-byte k".
    store64(&st + 0,  0x61707865);
    store64(&st + 8,  0x3320646e);
    store64(&st + 16, 0x79622d32);
    store64(&st + 24, 0x6b206574);

    # Key words 4..11.
    var i = 0;
    while (i < 8) {
        store64(&st + (4 + i) * 8, _chacha_u8to32le(key + i * 4));
        i = i + 1;
    }

    # Block counter — word 12.
    store64(&st + 12 * 8, counter & 0xffffffff);

    # Nonce words 13..15.
    i = 0;
    while (i < 3) {
        store64(&st + (13 + i) * 8, _chacha_u8to32le(nonce + i * 4));
        i = i + 1;
    }

    # Working copy.
    secret var ws[128];
    memcpy(&ws, &st, 128);

    # 20 rounds = 10 column+diagonal double-rounds.
    var r = 0;
    while (r < 10) {
        _chacha_qr(&ws, 0, 4, 8, 12);
        _chacha_qr(&ws, 1, 5, 9, 13);
        _chacha_qr(&ws, 2, 6, 10, 14);
        _chacha_qr(&ws, 3, 7, 11, 15);
        _chacha_qr(&ws, 0, 5, 10, 15);
        _chacha_qr(&ws, 1, 6, 11, 12);
        _chacha_qr(&ws, 2, 7, 8, 13);
        _chacha_qr(&ws, 3, 4, 9, 14);
        r = r + 1;
    }

    # Add the original state and serialize little-endian.
    i = 0;
    while (i < 16) {
        var v = (load64(&ws + i * 8) + load64(&st + i * 8)) & 0xffffffff;
        _chacha_u32to8le(out + i * 4, v);
        i = i + 1;
    }
    return 0;
}

# ================================================================
# chacha20_xor — encrypt/decrypt `in_len` bytes
#   Generates keystream from `counter` upward, one 64-byte block at
#   a time, XORing into the input. Decryption calls this with the
#   ciphertext (XOR is involutive). The counter increments per
#   block mod 2^32.
#   key/nonce/counter as chacha20_block; input/out are in_len bytes.
# Returns 0.
#
# USAGE LIMIT: the 32-bit counter wraps after 2^32 blocks, so a
# single (key, nonce) pair must encrypt at most 2^32 * 64 B = 256
# GiB (RFC 8439 §2.4). Beyond that the keystream repeats. Far above
# any sigil payload, but a hard cap the caller must respect — never
# reuse a (key, nonce) across messages totalling more than that.
# ================================================================
fn chacha20_xor(key, nonce, counter, input, in_len, out): i64 {
    secret var ks[64];
    var done = 0;
    var ctr = counter & 0xffffffff;
    while (done < in_len) {
        chacha20_block(key, nonce, ctr, &ks);
        var n = in_len - done;
        if (n > 64) { n = 64; }
        var j = 0;
        while (j < n) {
            store8(out + done + j,
                   (load8(input + done + j) ^ load8(&ks + j)) & 0xFF);
            j = j + 1;
        }
        ctr = (ctr + 1) & 0xffffffff;
        done = done + 64;
    }
    return 0;
}

# --- chacha20poly1305.cyr ---

# chacha20poly1305.cyr — ChaCha20-Poly1305 AEAD (RFC 8439 §2.8)
#
# The IETF AEAD construction: ChaCha20 (src/chacha20.cyr) for
# confidentiality, Poly1305 (src/poly1305.cyr) for authenticity.
# This is TLS 1.3's `TLS_CHACHA20_POLY1305_SHA256` suite and the
# pure-Cyrius alternative to AES-256-GCM (src/aes_gcm.cyr) for the
# native-TLS arc.
#
# Construction (RFC 8439 §2.8):
#   1. one-time Poly1305 key = first 32 bytes of the ChaCha20
#      keystream block at counter 0 (key, nonce).
#   2. ciphertext = ChaCha20(key, nonce, counter=1, plaintext).
#   3. mac_data = AAD || pad16(AAD) || ct || pad16(ct)
#                 || le64(len AAD) || le64(len ct).
#   4. tag = Poly1305(one-time key, mac_data).
# Decryption recomputes and verifies the tag in constant time
# BEFORE releasing plaintext (AEAD contract — matches aes_gcm).
#
# The per-message Poly1305 key is fresh per (key, nonce), so the
# one-time-key contract of src/poly1305.cyr is satisfied by
# construction — the caller must still never reuse a nonce under
# one key (standard AEAD requirement).
#
# Citation: RFC 8439 §2.8 (AEAD), §2.8.2 (test vector). See
# docs/sources.md.

# Bytes of zero-padding needed to round `n` up to a 16-byte
# multiple (0 when already aligned).
fn _cp_pad16len(n): i64 {
    var rem = n % 16;
    if (rem == 0) { return 0; }
    return 16 - rem;
}

# Store `v` as 8 little-endian bytes at p (mac-data length field).
fn _cp_store_le64(p, v): i64 {
    var i = 0;
    while (i < 8) {
        store8(p + i, (v >> (i * 8)) & 0xFF);
        i = i + 1;
    }
    return 0;
}

# Derive the one-time Poly1305 key: first 32 bytes of the ChaCha20
# keystream block at counter 0.
fn _cp_keygen(key, nonce, otk_out): i64 {
    secret var block[64];
    chacha20_block(key, nonce, 0, &block);
    memcpy(otk_out, &block, 32);
    return 0;
}

# Compute the Poly1305 tag over the RFC 8439 §2.8 mac_data layout.
# mac_data is built in a per-call fl_alloc scratch buffer (public
# data — AAD + ciphertext — so no zeroization needed) and freed
# before return.
fn _cp_tag(otk, aad, aad_len, ct, ct_len, tag_out): i64 {
    var aad_pad = _cp_pad16len(aad_len);
    var ct_pad = _cp_pad16len(ct_len);
    var mac_len = aad_len + aad_pad + ct_len + ct_pad + 16;

    var md = fl_alloc(mac_len);
    memset(md, 0, mac_len);           # zero-fills both pad regions

    var off = 0;
    memcpy(md + off, aad, aad_len);
    off = off + aad_len + aad_pad;
    memcpy(md + off, ct, ct_len);
    off = off + ct_len + ct_pad;
    _cp_store_le64(md + off, aad_len);
    off = off + 8;
    _cp_store_le64(md + off, ct_len);

    poly1305_mac(otk, md, mac_len, tag_out);
    fl_free(md);
    return 0;
}

# ================================================================
# chacha20poly1305_encrypt
#   key      — 32 bytes
#   nonce    — 12 bytes (96-bit)
#   aad      — aad_len bytes of additional authenticated data
#   pt       — plaintext, pt_len bytes
#   ct_out   — ciphertext, pt_len bytes (caller-allocated)
#   tag_out  — 16-byte tag (caller-allocated)
# Returns ERR_NONE, or ERR_INVALID_INPUT on a negative length.
# ================================================================
fn chacha20poly1305_encrypt(key, nonce, aad, aad_len, pt, pt_len, ct_out, tag_out): i64 {
    if (aad_len < 0) { return ERR_INVALID_INPUT; }
    if (pt_len < 0) { return ERR_INVALID_INPUT; }

    secret var otk[32];
    _cp_keygen(key, nonce, &otk);

    chacha20_xor(key, nonce, 1, pt, pt_len, ct_out);
    _cp_tag(&otk, aad, aad_len, ct_out, pt_len, tag_out);
    return ERR_NONE;
}

# ================================================================
# chacha20poly1305_decrypt
#   key/nonce/aad as above; ct/ct_len the received ciphertext;
#   tag the received 16-byte tag; pt_out the recovered plaintext
#   (caller-allocated, ct_len bytes).
# Returns:
#   ERR_NONE on success (pt_out populated).
#   ERR_INTEGRITY_MISMATCH on tag mismatch (pt_out zeroed, plaintext
#       NOT released — AEAD contract).
#   ERR_INVALID_INPUT on a negative length.
# ================================================================
fn chacha20poly1305_decrypt(key, nonce, aad, aad_len, ct, ct_len, tag, pt_out): i64 {
    if (aad_len < 0) { return ERR_INVALID_INPUT; }
    if (ct_len < 0) { return ERR_INVALID_INPUT; }

    secret var otk[32];
    _cp_keygen(key, nonce, &otk);

    # Verify the tag over the received ciphertext BEFORE deriving
    # plaintext. Constant-time compare via the stdlib ct_eq_bytes.
    secret var expected[16];
    _cp_tag(&otk, aad, aad_len, ct, ct_len, &expected);
    if (ct_eq_bytes(&expected, tag, 16) == 0) {
        memset(pt_out, 0, ct_len);
        return ERR_INTEGRITY_MISMATCH;
    }

    chacha20_xor(key, nonce, 1, ct, ct_len, pt_out);
    return ERR_NONE;
}

# --- sha512.cyr ---

# sha512.cyr — FIPS 180-4 SHA-512 implementation
# Required by Ed25519 (RFC 8032) for key expansion and signing.
# All arithmetic uses 64-bit words (native Cyrius i64).

# ================================================================
# SHA-512 round constants K[0..79]
# ================================================================

var _sha512_K = 0;
var _sha512_inited = 0;

fn _sha512_rotr(x, n): i64 {
    return (x >> n) | (x << (64 - n));
}

fn sha512_ch(x, y, z): i64 {
    return (x & y) ^ ((x ^ 0xFFFFFFFFFFFFFFFF) & z);
}

fn sha512_maj(x, y, z): i64 {
    return (x & y) ^ (x & z) ^ (y & z);
}

fn sha512_bsig0(x): i64 {
    return _sha512_rotr(x, 28) ^ _sha512_rotr(x, 34) ^ _sha512_rotr(x, 39);
}

fn sha512_bsig1(x): i64 {
    return _sha512_rotr(x, 14) ^ _sha512_rotr(x, 18) ^ _sha512_rotr(x, 41);
}

fn sha512_ssig0(x): i64 {
    return _sha512_rotr(x, 1) ^ _sha512_rotr(x, 8) ^ (x >> 7);
}

fn sha512_ssig1(x): i64 {
    return _sha512_rotr(x, 19) ^ _sha512_rotr(x, 61) ^ (x >> 6);
}

fn sha512_global_init(): i64 {
    if (_sha512_inited == 1) { return 0; }

    _sha512_K = alloc(640);
    store64(_sha512_K + 0, 0x428a2f98d728ae22);
    store64(_sha512_K + 8, 0x7137449123ef65cd);
    store64(_sha512_K + 16, 0xb5c0fbcfec4d3b2f);
    store64(_sha512_K + 24, 0xe9b5dba58189dbbc);
    store64(_sha512_K + 32, 0x3956c25bf348b538);
    store64(_sha512_K + 40, 0x59f111f1b605d019);
    store64(_sha512_K + 48, 0x923f82a4af194f9b);
    store64(_sha512_K + 56, 0xab1c5ed5da6d8118);
    store64(_sha512_K + 64, 0xd807aa98a3030242);
    store64(_sha512_K + 72, 0x12835b0145706fbe);
    store64(_sha512_K + 80, 0x243185be4ee4b28c);
    store64(_sha512_K + 88, 0x550c7dc3d5ffb4e2);
    store64(_sha512_K + 96, 0x72be5d74f27b896f);
    store64(_sha512_K + 104, 0x80deb1fe3b1696b1);
    store64(_sha512_K + 112, 0x9bdc06a725c71235);
    store64(_sha512_K + 120, 0xc19bf174cf692694);
    store64(_sha512_K + 128, 0xe49b69c19ef14ad2);
    store64(_sha512_K + 136, 0xefbe4786384f25e3);
    store64(_sha512_K + 144, 0x0fc19dc68b8cd5b5);
    store64(_sha512_K + 152, 0x240ca1cc77ac9c65);
    store64(_sha512_K + 160, 0x2de92c6f592b0275);
    store64(_sha512_K + 168, 0x4a7484aa6ea6e483);
    store64(_sha512_K + 176, 0x5cb0a9dcbd41fbd4);
    store64(_sha512_K + 184, 0x76f988da831153b5);
    store64(_sha512_K + 192, 0x983e5152ee66dfab);
    store64(_sha512_K + 200, 0xa831c66d2db43210);
    store64(_sha512_K + 208, 0xb00327c898fb213f);
    store64(_sha512_K + 216, 0xbf597fc7beef0ee4);
    store64(_sha512_K + 224, 0xc6e00bf33da88fc2);
    store64(_sha512_K + 232, 0xd5a79147930aa725);
    store64(_sha512_K + 240, 0x06ca6351e003826f);
    store64(_sha512_K + 248, 0x142929670a0e6e70);
    store64(_sha512_K + 256, 0x27b70a8546d22ffc);
    store64(_sha512_K + 264, 0x2e1b21385c26c926);
    store64(_sha512_K + 272, 0x4d2c6dfc5ac42aed);
    store64(_sha512_K + 280, 0x53380d139d95b3df);
    store64(_sha512_K + 288, 0x650a73548baf63de);
    store64(_sha512_K + 296, 0x766a0abb3c77b2a8);
    store64(_sha512_K + 304, 0x81c2c92e47edaee6);
    store64(_sha512_K + 312, 0x92722c851482353b);
    store64(_sha512_K + 320, 0xa2bfe8a14cf10364);
    store64(_sha512_K + 328, 0xa81a664bbc423001);
    store64(_sha512_K + 336, 0xc24b8b70d0f89791);
    store64(_sha512_K + 344, 0xc76c51a30654be30);
    store64(_sha512_K + 352, 0xd192e819d6ef5218);
    store64(_sha512_K + 360, 0xd69906245565a910);
    store64(_sha512_K + 368, 0xf40e35855771202a);
    store64(_sha512_K + 376, 0x106aa07032bbd1b8);
    store64(_sha512_K + 384, 0x19a4c116b8d2d0c8);
    store64(_sha512_K + 392, 0x1e376c085141ab53);
    store64(_sha512_K + 400, 0x2748774cdf8eeb99);
    store64(_sha512_K + 408, 0x34b0bcb5e19b48a8);
    store64(_sha512_K + 416, 0x391c0cb3c5c95a63);
    store64(_sha512_K + 424, 0x4ed8aa4ae3418acb);
    store64(_sha512_K + 432, 0x5b9cca4f7763e373);
    store64(_sha512_K + 440, 0x682e6ff3d6b2b8a3);
    store64(_sha512_K + 448, 0x748f82ee5defb2fc);
    store64(_sha512_K + 456, 0x78a5636f43172f60);
    store64(_sha512_K + 464, 0x84c87814a1f0ab72);
    store64(_sha512_K + 472, 0x8cc702081a6439ec);
    store64(_sha512_K + 480, 0x90befffa23631e28);
    store64(_sha512_K + 488, 0xa4506cebde82bde9);
    store64(_sha512_K + 496, 0xbef9a3f7b2c67915);
    store64(_sha512_K + 504, 0xc67178f2e372532b);
    store64(_sha512_K + 512, 0xca273eceea26619c);
    store64(_sha512_K + 520, 0xd186b8c721c0c207);
    store64(_sha512_K + 528, 0xeada7dd6cde0eb1e);
    store64(_sha512_K + 536, 0xf57d4f7fee6ed178);
    store64(_sha512_K + 544, 0x06f067aa72176fba);
    store64(_sha512_K + 552, 0x0a637dc5a2c898a6);
    store64(_sha512_K + 560, 0x113f9804bef90dae);
    store64(_sha512_K + 568, 0x1b710b35131c471b);
    store64(_sha512_K + 576, 0x28db77f523047d84);
    store64(_sha512_K + 584, 0x32caab7b40c72493);
    store64(_sha512_K + 592, 0x3c9ebe0a15c9bebc);
    store64(_sha512_K + 600, 0x431d67c49c100d4c);
    store64(_sha512_K + 608, 0x4cc5d4becb3e42b6);
    store64(_sha512_K + 616, 0x597f299cfc657e2a);
    store64(_sha512_K + 624, 0x5fcb6fab3ad6faec);
    store64(_sha512_K + 632, 0x6c44198c4a475817);

    _sha512_inited = 1;
    return 0;
}

# ================================================================
# SHA-512 context (272 bytes)
# ================================================================
# Layout:
#   +0    h0..h7 (8 x 8 = 64 bytes) hash state
#   +64   buf    (128 bytes) partial block buffer
#   +192  buf_len (8 bytes)
#   +200  total_len (8 bytes)

fn sha512_init(): i64 {
    var ctx = fl_alloc(208);
    return sha512_init_into(ctx);
}

# Alloc-free variant of sha512_init. Initialises an existing
# 208-byte context buffer with the FIPS 180-4 §5.3.5 initial
# hash values and zeroes the block buffer + counters. Caller
# MUST size `ctx` to at least 208 bytes.
#
# Used by `ed25519_verify` and other parallel-friendly callers
# so a streaming SHA-512 hash can run without touching the
# freelist allocator (CLAUDE.md quirk #7: `fl_alloc` is not
# thread-safe).
fn sha512_init_into(ctx): i64 {
    sha512_global_init();
    store64(ctx, 0x6a09e667f3bcc908);
    store64(ctx + 8, 0xbb67ae8584caa73b);
    store64(ctx + 16, 0x3c6ef372fe94f82b);
    store64(ctx + 24, 0xa54ff53a5f1d36f1);
    store64(ctx + 32, 0x510e527fade682d1);
    store64(ctx + 40, 0x9b05688c2b3e6c1f);
    store64(ctx + 48, 0x1f83d9abfb41bd6b);
    store64(ctx + 56, 0x5be0cd19137e2179);
    memset(ctx + 64, 0, 128);
    store64(ctx + 192, 0);
    store64(ctx + 200, 0);
    return ctx;
}

# ================================================================
# SHA-512 transform — per-call working state (3.3 refactor)
# ================================================================
# Mirror of sha256.cyr's 3.3 refactor: working state (a..hv,
# t1, t2, i, W) lives in function locals. Round constants K
# remain read-only-after-init and shared across threads.

fn sha512_transform(ctx): i64 {
    # Message schedule, banked per thread (3.6): `var W[N]` is a
    # static function-scope global (CLAUDE.md quirk #1); each batch
    # worker uses its own 640-byte lane so concurrent compresses on
    # the Ed25519 HRAM hash never race. `Wb` is this thread's lane.
    var W[5120];          # 80 words × 8 bytes × SIGIL_CRYPTO_BANKS
    var Wb = &W + cbank() * 640;
    var buf = ctx + 64;

    # Prepare message schedule W[0..15] from block (big-endian 64-bit words)
    var i = 0;
    while (i < 16) {
        var off = i * 8;
        var w = ((load8(buf + off) & 0xFF) << 56)
        | ((load8(buf + off + 1) & 0xFF) << 48)
        | ((load8(buf + off + 2) & 0xFF) << 40)
        | ((load8(buf + off + 3) & 0xFF) << 32)
        | ((load8(buf + off + 4) & 0xFF) << 24)
        | ((load8(buf + off + 5) & 0xFF) << 16)
        | ((load8(buf + off + 6) & 0xFF) << 8)
        | (load8(buf + off + 7) & 0xFF);
        store64(Wb + i * 8, w);
        i = i + 1;
    }

    # Extend W[16..79]
    i = 16;
    while (i < 80) {
        var w16 = load64(Wb + (i - 16) * 8);
        var w15 = load64(Wb + (i - 15) * 8);
        var w7 = load64(Wb + (i - 7) * 8);
        var w2 = load64(Wb + (i - 2) * 8);
        var s0 = sha512_ssig0(w15);
        var s1 = sha512_ssig1(w2);
        store64(Wb + i * 8, w16 + s0 + w7 + s1);
        i = i + 1;
    }

    # Initialize working variables
    var a = load64(ctx);
    var b = load64(ctx + 8);
    var c = load64(ctx + 16);
    var d = load64(ctx + 24);
    var e = load64(ctx + 32);
    var f = load64(ctx + 40);
    var g = load64(ctx + 48);
    var hv = load64(ctx + 56);

    # 80 rounds
    i = 0;
    while (i < 80) {
        var t1 = hv + sha512_bsig1(e) + sha512_ch(e, f, g);
        t1 = t1 + load64(_sha512_K + i * 8) + load64(Wb + i * 8);
        var t2 = sha512_bsig0(a) + sha512_maj(a, b, c);

        hv = g;
        g = f;
        f = e;
        e = d + t1;
        d = c;
        c = b;
        b = a;
        a = t1 + t2;
        i = i + 1;
    }

    # Add compressed chunk to current hash value
    store64(ctx, load64(ctx) + a);
    store64(ctx + 8, load64(ctx + 8) + b);
    store64(ctx + 16, load64(ctx + 16) + c);
    store64(ctx + 24, load64(ctx + 24) + d);
    store64(ctx + 32, load64(ctx + 32) + e);
    store64(ctx + 40, load64(ctx + 40) + f);
    store64(ctx + 48, load64(ctx + 48) + g);
    store64(ctx + 56, load64(ctx + 56) + hv);
    return 0;
}

# ================================================================
# SHA-512 update
# ================================================================

fn sha512_update(ctx, data, len): i64 {
    var buf_len = load64(ctx + 192);
    var total = load64(ctx + 200);
    total = total + len;
    store64(ctx + 200, total);

    var pos = 0;

    if (buf_len > 0) {
        var need = 128 - buf_len;
        if (len < need) {
            memcpy(ctx + 64 + buf_len, data, len);
            store64(ctx + 192, buf_len + len);
            return 0;
        }
        memcpy(ctx + 64 + buf_len, data, need);
        sha512_transform(ctx);
        pos = need;
        buf_len = 0;
    }

    while (pos + 128 <= len) {
        memcpy(ctx + 64, data + pos, 128);
        sha512_transform(ctx);
        pos = pos + 128;
    }

    var remaining = len - pos;
    if (remaining > 0) {
        memcpy(ctx + 64, data + pos, remaining);
    }
    store64(ctx + 192, remaining);
    return 0;
}

# ================================================================
# SHA-512 finalize — produce 64-byte digest
# ================================================================

fn sha512_finalize(ctx, out): i64 {
    var buf_len = load64(ctx + 192);
    var total_bits = load64(ctx + 200) * 8;

    store8(ctx + 64 + buf_len, 0x80);
    buf_len = buf_len + 1;

    if (buf_len > 112) {
        memset(ctx + 64 + buf_len, 0, 128 - buf_len);
        sha512_transform(ctx);
        buf_len = 0;
    }
    memset(ctx + 64 + buf_len, 0, 112 - buf_len);

    # Append total length as 128-bit big-endian (high 64 bits = 0 for < 2^64 bits)
    memset(ctx + 64 + 112, 0, 8);
    store8(ctx + 64 + 120, (total_bits >> 56) & 0xFF);
    store8(ctx + 64 + 121, (total_bits >> 48) & 0xFF);
    store8(ctx + 64 + 122, (total_bits >> 40) & 0xFF);
    store8(ctx + 64 + 123, (total_bits >> 32) & 0xFF);
    store8(ctx + 64 + 124, (total_bits >> 24) & 0xFF);
    store8(ctx + 64 + 125, (total_bits >> 16) & 0xFF);
    store8(ctx + 64 + 126, (total_bits >> 8) & 0xFF);
    store8(ctx + 64 + 127, total_bits & 0xFF);

    sha512_transform(ctx);

    # Write 64-byte digest in big-endian from h0-h7
    var di = 0;
    while (di < 8) {
        var word = load64(ctx + di * 8);
        store8(out + di * 8, (word >> 56) & 0xFF);
        store8(out + di * 8 + 1, (word >> 48) & 0xFF);
        store8(out + di * 8 + 2, (word >> 40) & 0xFF);
        store8(out + di * 8 + 3, (word >> 32) & 0xFF);
        store8(out + di * 8 + 4, (word >> 24) & 0xFF);
        store8(out + di * 8 + 5, (word >> 16) & 0xFF);
        store8(out + di * 8 + 6, (word >> 8) & 0xFF);
        store8(out + di * 8 + 7, word & 0xFF);
        di = di + 1;
    }
    return 0;
}

# ================================================================
# Convenience — hash data in one shot
# ================================================================

fn sha512(data, len, out): i64 {
    var ctx = sha512_init();
    sha512_update(ctx, data, len);
    sha512_finalize(ctx, out);
    fl_free(ctx);
    return 0;
}

# --- sha384.cyr ---

# sha384.cyr — FIPS 180-4 SHA-384.
#
# SHA-384 reuses SHA-512's compression core (`src/sha512.cyr`) with
# two changes per FIPS 180-4 §5.3.4 / §6.5:
#   1. Different initial hash value (IV).
#   2. Output is the leftmost 48 bytes of the final 64-byte state.
#
# Used by:
#   • SEV-SNP attestation reports — measurement field is a SHA-384
#     digest of the guest's launch state (per AMD's spec).
#   • Future ECDSA P-384 signature workflows where the message
#     representative is SHA-384(msg).
#
# Wrapper-style implementation — the heavy lifting stays in
# `sha512_transform` / `sha512_update` / `sha512_finalize`. Sigil
# 2.x's `sha256.cyr` / `sha512.cyr` / `hkdf.cyr` separation
# pattern is preserved.

# SHA-384 initial hash (FIPS 180-4 §5.3.4)
fn sha384_init(): i64 {
    sha512_global_init();
    var ctx = fl_alloc(208);
    store64(ctx +  0, 0xcbbb9d5dc1059ed8);
    store64(ctx +  8, 0x629a292a367cd507);
    store64(ctx + 16, 0x9159015a3070dd17);
    store64(ctx + 24, 0x152fecd8f70e5939);
    store64(ctx + 32, 0x67332667ffc00b31);
    store64(ctx + 40, 0x8eb44a8768581511);
    store64(ctx + 48, 0xdb0c2e0d64f98fa7);
    store64(ctx + 56, 0x47b5481dbefa4fa4);
    memset(ctx + 64, 0, 128);
    store64(ctx + 192, 0);
    store64(ctx + 200, 0);
    return ctx;
}

# Update — identical streaming behaviour to SHA-512 (same block size).
fn sha384_update(ctx, data, len): i64 {
    return sha512_update(ctx, data, len);
}

# Finalize — run the SHA-512 finaliser into a 64-byte scratch, then
# truncate to the leftmost 48 bytes.
fn sha384_finalize(ctx, out): i64 {
    var tmp[64];
    sha512_finalize(ctx, &tmp);
    memcpy(out, &tmp, 48);
    return 0;
}

# Convenience — hash `data` (len bytes) into `out` (48 bytes).
fn sha384(data, len, out): i64 {
    var ctx = sha384_init();
    sha384_update(ctx, data, len);
    sha384_finalize(ctx, out);
    fl_free(ctx);
    return 0;
}

# --- hmac_sha384.cyr ---

# hmac_sha384.cyr — HMAC-SHA384 (FIPS 198-1 / RFC 4231 §3)
#
# Companion to `src/hmac.cyr`'s HMAC-SHA256. Split into its own
# module because it depends on `src/sha384.cyr`, which is included
# AFTER `src/hmac.cyr` / `src/hkdf.cyr` in the dependency order
# (`src/lib.cyr`) — sha384 layers on sha512's compression core. This
# module therefore lives after sha384 in the include chain.
#
# Added at 3.5.6 for the cyrius native TLS 1.3 arc: the
# `TLS_AES_256_GCM_SHA384` (0x1302) ciphersuite drives its RFC 8446
# §7.1 key schedule off HKDF-SHA384, whose extract/expand primitive
# is HMAC-SHA384. See `docs/development/issues/2026-05-28-cyrius-tls-
# native-needs-hkdf-sha384.md`.
#
# HMAC(K, m) = H((K' xor opad) || H((K' xor ipad) || m))
# where:
#   K' = H(K) if len(K) > B, else K padded to B bytes
#   ipad = 0x36 repeated B times
#   opad = 0x5c repeated B times
#
# THE WRINKLE: SHA-384's block size B is **128 bytes**, not 64 like
# SHA-256. The digest is **48 bytes**, not 32. Copying the SHA-256
# variant and only swapping the hash function produces wrong output
# — every block/digest constant below cascades from B=128 / L=48.

# ================================================================
# HMAC-SHA384
# ================================================================

# Computes HMAC-SHA384 (FIPS 198-1 / RFC 4231 §3) over `msg` under
# `key`, writing the 48-byte MAC to `out48`. Keys longer than the
# 128-byte block are first SHA-384-hashed per the spec (yielding 48
# bytes, zero-padded to 128); shorter keys are zero-padded. The K' /
# ipad / opad scratch buffers are `secret var` and zeroized on
# return. Returns 0.
fn hmac_sha384(key, key_len, msg, msg_len, out48): i64 {
    # Step 1: Derive K' (128 bytes — the SHA-384 block size).
    # `secret var` zeroes the buffer on function exit (Cyrius 5.3.5+).
    # The init memset is retained because the key_len <= 128 branch
    # relies on the upper bytes being zero.
    secret var kprime384[128];
    memset(&kprime384, 0, 128);

    if (key_len > 128) {
        # Key longer than block — replace with its 48-byte hash.
        sha384(key, key_len, &kprime384);
        # kprime384 is now 48 bytes of hash + 80 bytes of zeros.
    } else {
        memcpy(&kprime384, key, key_len);
        # Rest already zeroed.
    }

    # Step 2: inner = SHA-384((K' xor ipad) || message)
    secret var ipad384[128];
    var i = 0;
    while (i < 128) {
        store8(&ipad384 + i, (load8(&kprime384 + i) & 0xFF) ^ 0x36);
        i = i + 1;
    }

    var inner_ctx = sha384_init();
    sha384_update(inner_ctx, &ipad384, 128);
    sha384_update(inner_ctx, msg, msg_len);
    var inner_hash384[48];
    sha384_finalize(inner_ctx, &inner_hash384);
    fl_free(inner_ctx);

    # Step 3: outer = SHA-384((K' xor opad) || inner)
    secret var opad384[128];
    i = 0;
    while (i < 128) {
        store8(&opad384 + i, (load8(&kprime384 + i) & 0xFF) ^ 0x5c);
        i = i + 1;
    }

    var outer_ctx = sha384_init();
    sha384_update(outer_ctx, &opad384, 128);
    sha384_update(outer_ctx, &inner_hash384, 48);
    sha384_finalize(outer_ctx, out48);
    fl_free(outer_ctx);

    # kprime384 / ipad384 / opad384 are `secret var` — zeroed on
    # return by the compiler. inner_hash384 is a public digest; left
    # as a plain var (no security need to clear).
    return 0;
}

# --- hkdf_sha384.cyr ---

# hkdf_sha384.cyr — HKDF (RFC 5869) on top of HMAC-SHA384
#
# Companion to `src/hkdf.cyr`'s HKDF-SHA256. Depends on
# `src/hmac_sha384.cyr` (and transitively `src/sha384.cyr`), so it
# is included after both in `src/lib.cyr`'s dependency order.
#
# Added at 3.5.6 for the cyrius native TLS 1.3 arc — the
# `TLS_AES_256_GCM_SHA384` (0x1302) ciphersuite key schedule
# (RFC 8446 §7.1) derives its secrets via HKDF-SHA384. See
# `docs/development/issues/2026-05-28-cyrius-tls-native-needs-
# hkdf-sha384.md`.
#
# HKDF is a two-stage key derivation function:
#   1. Extract: PRK = HMAC-SHA384(salt, IKM)       (48-byte PRK)
#   2. Expand: OKM = T(1) || T(2) || ... || T(N)
#      where T(0) = empty, T(i) = HMAC-SHA384(PRK, T(i-1) || info || i)
#
# HashLen = 48 (SHA-384), so max OKM length = 255 * 48 = 12240 bytes
# per RFC 5869 §2.3 (NOT 8160 — that's the SHA-256 cap).
#
# Security hygiene mirrors `src/hkdf.cyr`:
#   - The PRK is zeroized before return in the combined helper.
#   - Every HMAC intermediate (T(i-1) / T(i)) is `secret var`,
#     zeroed on scope exit.
#   - No branch on secret data: the loop count derives from out_len,
#     which is public.
#
# RFC 5869 §2.2: an empty/NULL salt is treated as HashLen (48) zero
# bytes. RFC 5869 §2.3: empty info collapses "T(i-1) || info || i"
# to "T(i-1) || i" cleanly.

# ================================================================
# hkdf_extract_sha384 — PRK = HMAC-SHA384(salt, IKM)
# ================================================================
# salt      : pointer to salt bytes (may be 0 if salt_len == 0)
# salt_len  : length of salt in bytes
# ikm       : pointer to input keying material
# ikm_len   : length of IKM in bytes
# prk_out48 : caller-provided 48-byte output buffer; receives the PRK
# Returns 0 on success, non-zero on input-validation failure.
fn hkdf_extract_sha384(salt, salt_len, ikm, ikm_len, prk_out48): i64 {
    if (salt_len < 0) { return (0 - 1); }
    if (ikm_len < 0) { return (0 - 1); }

    # RFC 5869 §2.2: a NULL/empty salt is HashLen (48) zero bytes.
    if (salt_len == 0) {
        var zero_salt384[48];
        memset(&zero_salt384, 0, 48);
        hmac_sha384(&zero_salt384, 48, ikm, ikm_len, prk_out48);
        memset(&zero_salt384, 0, 48);
        return 0;
    }

    hmac_sha384(salt, salt_len, ikm, ikm_len, prk_out48);
    return 0;
}

# ================================================================
# hkdf_expand_sha384 — OKM = T(1) || T(2) || ... || T(N)
# ================================================================
# prk      : pointer to 48-byte pseudorandom key (output of extract)
# prk_len  : length of PRK (should be >= 48; SHA-384 always gives 48)
# info     : pointer to context/application info (may be 0 if info_len == 0)
# info_len : length of info in bytes
# out      : caller-provided buffer of size >= out_len
# out_len  : number of OKM bytes to produce
#
# Returns:
#   0   on success
#  -1   on negative-length input
#  -2   on out_len > 255*48 (RFC 5869 §2.3 cap)

# Globals: same rationale as `src/hkdf.cyr` — hkdf_expand has a deep
# nested call chain (hmac_sha384 -> sha384_init/update/finalize with
# memcpy/memset around them) that the single-pass register allocator
# can clobber locals across, so the round state lives in globals.
# Distinct `_hkdf384_*` names so they never alias the SHA-256 set.
var _hkdf384_scratch = 0;
var _hkdf384_scratch_len = 0;
var _hkdf384_prk = 0;
var _hkdf384_prk_len = 0;
var _hkdf384_info = 0;
var _hkdf384_info_len = 0;
var _hkdf384_out = 0;
var _hkdf384_out_len = 0;
var _hkdf384_produced = 0;
var _hkdf384_counter = 0;

# Expands `prk` into `out_len` bytes of output keying material bound to
# `info` (RFC 5869 §2.3). Returns 0 on success, -1 on negative-length
# input, -2 when out_len exceeds the 255*48 = 12240-byte HashLen cap.
# Every HMAC intermediate is zeroized before return.
fn hkdf_expand_sha384(prk, prk_len, info, info_len, out, out_len): i64 {
    if (prk_len < 0) { return (0 - 1); }
    if (info_len < 0) { return (0 - 1); }
    if (out_len < 0) { return (0 - 1); }
    # HashLen = 48. Max OKM = 255 * 48 = 12240 bytes.
    if (out_len > 12240) { return (0 - 2); }
    if (out_len == 0) { return 0; }

    # Promote all parameters to globals so nested HMAC calls can't
    # clobber them via the register allocator.
    _hkdf384_prk = prk;
    _hkdf384_prk_len = prk_len;
    _hkdf384_info = info;
    _hkdf384_info_len = info_len;
    _hkdf384_out = out;
    _hkdf384_out_len = out_len;

    # Scratch holds "T(i-1) || info || counter" — the HMAC input for
    # each round. Max size = 48 + info_len + 1.
    _hkdf384_scratch_len = 48 + info_len + 1;
    _hkdf384_scratch = fl_alloc(_hkdf384_scratch_len);
    memset(_hkdf384_scratch, 0, _hkdf384_scratch_len);

    # T(i-1) and T(i) are HMAC outputs and therefore key material per
    # RFC 5869. `secret var` zeroes both on function exit (covers the
    # happy path and any early errors); init memsets retained because
    # the counter==1 branch leaves t384_prev untouched and we memcpy
    # out of it.
    secret var t384_prev[48];
    memset(&t384_prev, 0, 48);
    secret var t384_current[48];
    memset(&t384_current, 0, 48);

    _hkdf384_produced = 0;
    _hkdf384_counter = 1;   # RFC 5869: i starts at 1

    while (_hkdf384_produced < _hkdf384_out_len) {
        # Build input to HMAC: T(i-1) || info || counter.
        # First round (counter=1): T(0) is empty, so skip the T_prev copy.
        var scratch_write = 0;
        if (_hkdf384_counter > 1) {
            memcpy(_hkdf384_scratch, &t384_prev, 48);
            scratch_write = 48;
        }
        if (_hkdf384_info_len > 0) {
            memcpy(_hkdf384_scratch + scratch_write, _hkdf384_info, _hkdf384_info_len);
            scratch_write = scratch_write + _hkdf384_info_len;
        }
        store8(_hkdf384_scratch + scratch_write, _hkdf384_counter & 0xFF);
        scratch_write = scratch_write + 1;

        # T(i) = HMAC-SHA384(PRK, scratch[0..scratch_write])
        hmac_sha384(_hkdf384_prk, _hkdf384_prk_len, _hkdf384_scratch, scratch_write, &t384_current);

        # Copy min(48, out_len - produced) bytes into the output.
        var take = 48;
        if (_hkdf384_out_len - _hkdf384_produced < 48) {
            take = _hkdf384_out_len - _hkdf384_produced;
        }
        memcpy(_hkdf384_out + _hkdf384_produced, &t384_current, take);
        _hkdf384_produced = _hkdf384_produced + take;

        # Save T(i) for the next iteration.
        memcpy(&t384_prev, &t384_current, 48);

        _hkdf384_counter = _hkdf384_counter + 1;
    }

    # Zeroize the heap scratch before free. t384_prev / t384_current
    # are `secret var` — zeroed on function exit by the compiler.
    memset(_hkdf384_scratch, 0, _hkdf384_scratch_len);
    fl_free(_hkdf384_scratch);
    # Wipe the global pointers so nothing leaks between calls.
    _hkdf384_scratch = 0;
    _hkdf384_prk = 0;
    _hkdf384_info = 0;
    _hkdf384_out = 0;
    return 0;
}

# ================================================================
# hkdf_sha384 — extract + expand convenience wrapper
# ================================================================
# One-shot HKDF-SHA384. Derives out_len bytes of OKM from
# (salt, IKM, info). The intermediate 48-byte PRK is a `secret var`,
# used and zeroized on every return path — callers never see it.
#
# Returns:
#   0   on success
#  -1   on negative-length input
#  -2   on out_len > 255*48
fn hkdf_sha384(salt, salt_len, ikm, ikm_len, info, info_len, out, out_len): i64 {
    # PRK is key material. `secret var` handles zeroization on every
    # return path (both rc1 error and rc2 success/error).
    secret var prk384[48];
    var rc1 = hkdf_extract_sha384(salt, salt_len, ikm, ikm_len, &prk384);
    if (rc1 != 0) { return rc1; }
    return hkdf_expand_sha384(&prk384, 48, info, info_len, out, out_len);
}

# --- tls12_prf.cyr ---

# tls12_prf.cyr -- TLS 1.2 pseudorandom function (RFC 5246 sec 5)
#
# TLS 1.2's key schedule is:
#   PRF(sec, label, seed) = P_<hash>(sec, label || seed)
#   P_hash(sec, seed) = HMAC_hash(sec, A(1) || seed)
#                        || HMAC_hash(sec, A(2) || seed)
#                        || HMAC_hash(sec, A(3) || seed) || ...
#   with A(0) = seed,  A(i) = HMAC_hash(sec, A(i-1)).
#
# TLS 1.2 (RFC 5246 sec 5) replaced the TLS 1.0/1.1 MD5xorSHA-1 split PRF
# with a single negotiated hash: the default cipher suites use
# `P_SHA256`; the `*_SHA384` suites (RFC 5288/5289) use `P_SHA384`.
# Both are provided here. Built directly on the existing
# `hmac_sha256` (src/hmac.cyr) and `hmac_sha384` (src/hmac_sha384.cyr);
# no new hashing primitive is introduced.
#
# Scope: this is the TLS 1.2 master-secret / key-block / Finished KDF
# for the cyrius native-TLS arc. Like the rest of sigil's HMAC/HKDF
# surface (and unlike the banked batch-verify path), the working
# buffers here are plain static function-scope scratch -- the KDF is
# called per-handshake on a single thread, not fanned out across the
# batch workers. Output (master secret / key block) is key material,
# so the intermediates are `secret var` (zeroized on scope exit); the
# caller owns zeroization of `out`.
#
# Combined `label || seed` is capped at TLS12_PRF_SEED_MAX bytes
# (generous: real TLS seeds are label<=~15 + two 32-byte randoms ~ 80).
# Over-cap inputs return 0 (no output written) rather than truncating.

var TLS12_PRF_SEED_MAX = 256;   # max length of (label || seed)

# Internal P_hash core. `is384` selects HMAC-SHA384 (hlen 48) vs
# HMAC-SHA256 (hlen 32). `seedp`/`seedp_len` is the already-built
# `label || seed`. Writes exactly `out_len` bytes to `out`; returns
# `out_len`, or 0 if `seedp_len` exceeds the cap.
fn _tls12_p_hash(is384, sec, secret_len, seedp, seedp_len, out, out_len): i64 {
    if (seedp_len > TLS12_PRF_SEED_MAX) { return 0; }
    var hlen = 32;
    if (is384 == 1) { hlen = 48; }

    # A(i), one HMAC output block, and the HMAC input `A(i) || seedp`.
    # All hold derived key material ? `secret var` (zeroized on exit).
    secret var A[48];
    secret var block[48];
    secret var hin[304];        # 48 (max hlen) + TLS12_PRF_SEED_MAX

    # A(1) = HMAC(sec, seedp)
    if (is384 == 1) { hmac_sha384(sec, secret_len, seedp, seedp_len, &A); }
    else { hmac_sha256(sec, secret_len, seedp, seedp_len, &A); }

    var filled = 0;
    while (filled < out_len) {
        # block = HMAC(sec, A(i) || seedp)
        memcpy(&hin, &A, hlen);
        memcpy(&hin + hlen, seedp, seedp_len);
        if (is384 == 1) { hmac_sha384(sec, secret_len, &hin, hlen + seedp_len, &block); }
        else { hmac_sha256(sec, secret_len, &hin, hlen + seedp_len, &block); }

        # Emit min(hlen, remaining) bytes of this block.
        var take = hlen;
        var rem = out_len - filled;
        if (take > rem) { take = rem; }
        memcpy(out + filled, &block, take);
        filled = filled + take;

        # A(i+1) = HMAC(sec, A(i))
        if (is384 == 1) { hmac_sha384(sec, secret_len, &A, hlen, &block); }
        else { hmac_sha256(sec, secret_len, &A, hlen, &block); }
        memcpy(&A, &block, hlen);
    }
    return out_len;
}

# TLS 1.2 PRF over SHA-256 (RFC 5246 sec 5). Derives `out_len` bytes into
# `out` from `secret`, the ASCII `label`, and `seed`. Returns `out_len`
# on success, or 0 if `label_len + seed_len > TLS12_PRF_SEED_MAX`.
fn tls12_prf_sha256(sec, secret_len, label, label_len, seed, seed_len, out, out_len): i64 {
    var slen = label_len + seed_len;
    if (slen > TLS12_PRF_SEED_MAX) { return 0; }
    secret var seedp[256];      # label || seed (TLS12_PRF_SEED_MAX)
    memcpy(&seedp, label, label_len);
    memcpy(&seedp + label_len, seed, seed_len);
    return _tls12_p_hash(0, sec, secret_len, &seedp, slen, out, out_len);
}

# TLS 1.2 PRF over SHA-384 (RFC 5246 sec 5 with the SHA-384 suites'
# negotiated hash). Same contract as `tls12_prf_sha256`.
fn tls12_prf_sha384(sec, secret_len, label, label_len, seed, seed_len, out, out_len): i64 {
    var slen = label_len + seed_len;
    if (slen > TLS12_PRF_SEED_MAX) { return 0; }
    secret var seedp[256];      # label || seed (TLS12_PRF_SEED_MAX)
    memcpy(&seedp, label, label_len);
    memcpy(&seedp + label_len, seed, seed_len);
    return _tls12_p_hash(1, sec, secret_len, &seedp, slen, out, out_len);
}

# --- bigint_ext.cyr ---

# bigint_ext.cyr — extended 256-bit arithmetic for Ed25519
# Adds: full 512-bit multiply, modular reduction for p=2^255-19,
# modular inversion, modular exponentiation, LE byte codec.
# Builds on lib/bigint.cyr

# ================================================================
# u256 <-> little-endian byte codec
# Previously inlined at 7 sites (5 decode + 2 encode loops, ~11 lines
# each) across ed25519.cyr. Safe to factor out: no nested function
# calls inside the loop body, so locals survive despite Cyrius'
# parameter-clobber rule.
# ================================================================

# Load 32 little-endian bytes from src into dst as four i64 limbs.
fn u256_load_le(dst, src): i64 {
    var i = 0;
    while (i < 4) {
        store64(dst + i * 8,
        (load8(src + i*8) & 0xFF)
        | ((load8(src + i*8 + 1) & 0xFF) << 8)
        | ((load8(src + i*8 + 2) & 0xFF) << 16)
        | ((load8(src + i*8 + 3) & 0xFF) << 24)
        | ((load8(src + i*8 + 4) & 0xFF) << 32)
        | ((load8(src + i*8 + 5) & 0xFF) << 40)
        | ((load8(src + i*8 + 6) & 0xFF) << 48)
        | ((load8(src + i*8 + 7) & 0xFF) << 56));
        i = i + 1;
    }
    return 0;
}

# Store src (four i64 limbs) as 32 little-endian bytes at dst.
fn u256_store_le(dst, src): i64 {
    var i = 0;
    while (i < 4) {
        var v = load64(src + i * 8);
        store8(dst + i*8, v & 0xFF);
        store8(dst + i*8 + 1, (v >> 8) & 0xFF);
        store8(dst + i*8 + 2, (v >> 16) & 0xFF);
        store8(dst + i*8 + 3, (v >> 24) & 0xFF);
        store8(dst + i*8 + 4, (v >> 32) & 0xFF);
        store8(dst + i*8 + 5, (v >> 40) & 0xFF);
        store8(dst + i*8 + 6, (v >> 48) & 0xFF);
        store8(dst + i*8 + 7, (v >> 56) & 0xFF);
        i = i + 1;
    }
    return 0;
}

# ================================================================
# Full 256×256 → 512-bit multiply
# out: 64 bytes (8 limbs)
# ================================================================
# 3.3: per-call working state. The pre-3.3 module-globals were a
# cycc 3 local-clobbering workaround that cycc 6.0.1 no longer
# needs. `_mul64_full` is inlined here — it was its only caller
# and returning two values via globals (`_m64_lo` / `_m64_hi`)
# had no clean local equivalent.

fn u256_mul_full(out, a, b): i64 {
    memset(out, 0, 64);
    var sbit = 1 << 63;
    var mask32 = 0xFFFFFFFF;
    var i = 0;
    while (i < 4) {
        var carry = 0;
        var j = 0;
        while (j < 4) {
            # Inlined 64×64 → 128-bit multiply.
            var av = load64(a + i * 8);
            var bv = load64(b + j * 8);
            var aL = av & mask32;
            var aH = (av >> 32) & mask32;
            var bL = bv & mask32;
            var bH = (bv >> 32) & mask32;
            var ll = aL * bL;
            var lh = aL * bH;
            var hl = aH * bL;
            var hh = aH * bH;
            var mid = lh + hl;
            var mid_carry = 0;
            if ((mid ^ sbit) < (lh ^ sbit)) { mid_carry = 1; }
            var m_lo = ll + (mid << 32);
            var lo_carry = 0;
            if ((m_lo ^ sbit) < (ll ^ sbit)) { lo_carry = 1; }
            var m_hi = hh + (mid >> 32) + (mid_carry << 32) + lo_carry;

            var k = i + j;
            var prev = load64(out + k * 8);

            # s1 = prev + m_lo; c1 = overflow
            var s1 = prev + m_lo;
            var c1 = 0;
            if ((s1 ^ sbit) < (prev ^ sbit)) { c1 = 1; }

            # s2 = s1 + carry; c2 = overflow
            var s2 = s1 + carry;
            var c2 = 0;
            if ((s2 ^ sbit) < (s1 ^ sbit)) { c2 = 1; }

            store64(out + k * 8, s2);
            carry = m_hi + c1 + c2;
            j = j + 1;
        }
        if (i + 4 < 8) {
            store64(out + (i + 4) * 8, load64(out + (i + 4) * 8) + carry);
        }
        i = i + 1;
    }
    return 0;
}

# ================================================================
# Reduction mod p = 2^255 - 19
# Uses: 2^256 ≡ 38 (mod p), so for 512-bit val = aH*2^256 + aL:
#   val mod p ≡ aL + 38*aH (mod p)
# May need 1-2 further subtractions.
# ================================================================

# Read-only-after-init: curve modulus p = 2^255 - 19 and the
# Solinas constant 38 (= 2 · 19) used in 2^256 ≡ 38 (mod p).
var _ed_p = 0;
var _ed_p_inited = 0;
var _mod_38 = 0;

fn _init_ed_p(): i64 {
    if (_ed_p_inited == 1) { return 0; }
    _ed_p = u256_from_hex("7fffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffed");
    _mod_38 = u256_from(38);
    _ed_p_inited = 1;
    return 0;
}

fn u512_mod_p(out, val): i64 {
    _init_ed_p();

    # Per-thread banked scratch (3.6): every `var X[N]` here is a
    # static function-scope global (CLAUDE.md quirk #1), so each
    # batch-verify worker carves its own lane. One `cbank()` read per
    # call; all lanes derive from the same bank index.
    var bk = cbank();
    var aH[256];   var aHb = &aH + bk * 32;     # 32 * SIGIL_CRYPTO_BANKS
    var aL[256];   var aLb = &aL + bk * 32;
    var prod[512]; var prodb = &prod + bk * 64; # 64 * SIGIL_CRYPTO_BANKS
    var lowp[256]; var lowpb = &lowp + bk * 32;
    var r[256];    var rb = &r + bk * 32;
    var extra[256];var extrab = &extra + bk * 32;

    store64(aHb, load64(val + 32));
    store64(aHb + 8, load64(val + 40));
    store64(aHb + 16, load64(val + 48));
    store64(aHb + 24, load64(val + 56));

    store64(aLb, load64(val));
    store64(aLb + 8, load64(val + 8));
    store64(aLb + 16, load64(val + 16));
    store64(aLb + 24, load64(val + 24));

    u256_mul_full(prodb, aHb, _mod_38);

    store64(lowpb, load64(prodb));
    store64(lowpb + 8, load64(prodb + 8));
    store64(lowpb + 16, load64(prodb + 16));
    store64(lowpb + 24, load64(prodb + 24));

    var carry = u256_add(rb, aLb, lowpb);
    var overflow = carry + load64(prodb + 32);

    while (overflow > 0) {
        store64(extrab, overflow * 38);
        store64(extrab + 8, 0);
        store64(extrab + 16, 0);
        store64(extrab + 24, 0);
        overflow = u256_add(rb, rb, extrab);
    }

    while (u256_cmp(rb, _ed_p) >= 0) {
        u256_sub(rb, rb, _ed_p);
    }

    u256_copy(out, rb);
    return 0;
}

# ================================================================
# Field arithmetic mod p
# ================================================================

fn fp_add(r, a, b): i64 {
    _init_ed_p();
    u256_add(r, a, b);
    if (u256_cmp(r, _ed_p) >= 0) { u256_sub(r, r, _ed_p); }
    return 0;
}

fn fp_sub(r, a, b): i64 {
    _init_ed_p();
    var borrow = u256_sub(r, a, b);
    if (borrow > 0) { u256_add(r, r, _ed_p); }
    return 0;
}

fn fp_neg(r, a): i64 {
    _init_ed_p();
    if (u256_is_zero(a) == 1) {
        u256_copy(r, a);
        return 0;
    }
    u256_sub(r, _ed_p, a);
    return 0;
}

fn fp_mul(r, a, b): i64 {
    # Per-thread banked scratch (3.6): `var prod[N]` is a static
    # function-scope global (CLAUDE.md quirk #1). Each batch-verify
    # worker uses its own 64-byte lane so concurrent field
    # multiplies on the [h]A / [S]B ladders never collide.
    var prod[512];                       # 64 * SIGIL_CRYPTO_BANKS
    var prodb = &prod + cbank() * 64;
    u256_mul_full(prodb, a, b);
    u512_mod_p(r, prodb);
    return 0;
}

fn fp_sq(r, a): i64 {
    return fp_mul(r, a, a);
}

# ================================================================
# Modular exponentiation: r = base^exp mod p
# ================================================================

fn fp_pow(r, base, exp): i64 {
    _init_ed_p();
    # Per-thread banked scratch (3.6) — see fp_mul / u512_mod_p.
    var bk = cbank();
    var tmp[256];      var tmpb = &tmp + bk * 32;       # 32 * SIGIL_CRYPTO_BANKS
    var result[256];   var resultb = &result + bk * 32;
    var base_buf[256]; var base_bufb = &base_buf + bk * 32;
    store64(resultb, 1);
    store64(resultb + 8, 0);
    store64(resultb + 16, 0);
    store64(resultb + 24, 0);
    u256_copy(base_bufb, base);
    var i = 0;
    while (i < 256) {
        var limb_idx = i / 64;
        var bit_idx = i % 64;
        var bit = (load64(exp + limb_idx * 8) >> bit_idx) & 1;
        if (bit == 1) {
            fp_mul(tmpb, resultb, base_bufb);
            u256_copy(resultb, tmpb);
        }
        fp_mul(tmpb, base_bufb, base_bufb);
        u256_copy(base_bufb, tmpb);
        i = i + 1;
    }
    u256_copy(r, resultb);
    return 0;
}

# ================================================================
# Modular inversion: r = a^(p-2) mod p for p = 2^255 - 19
# Bernstein's addition chain from the curve25519 reference:
# 254 squarings + 11 multiplies = 265 fp_mul calls
# (vs the generic fp_pow(p-2): ~512 fp_mul calls).
# ================================================================

fn _fpi_sq_n(buf, n): i64 {
    # In-place square `buf` n times.
    var i = 0;
    while (i < n) {
        fp_sq(buf, buf);
        i = i + 1;
    }
    return 0;
}

fn fp_inv(r, a): i64 {
    _init_ed_p();
    # Per-thread banked scratch (3.6): these 8 chain temporaries are
    # static function-scope globals (CLAUDE.md quirk #1) and fp_inv is
    # on the parallel verify path (ge_to_bytes → fp_inv), so each
    # worker inverts into its own lane. One `cbank()` read per call.
    var bk = cbank();
    var t0[256];    var t0b = &t0 + bk * 32;       # 32 * SIGIL_CRYPTO_BANKS
    var z9[256];    var z9b = &z9 + bk * 32;
    var z11[256];   var z11b = &z11 + bk * 32;
    var z5[256];    var z5b = &z5 + bk * 32;
    var z10[256];   var z10b = &z10 + bk * 32;
    var z50[256];   var z50b = &z50 + bk * 32;
    var z100[256];  var z100b = &z100 + bk * 32;
    var a_buf[256]; var a_bufb = &a_buf + bk * 32;
    u256_copy(a_bufb, a);

    # z2 in t0: t0 = a^2
    fp_sq(t0b, a_bufb);
    # z9 = t0^4 * a   = a^9
    fp_sq(z9b, t0b);
    fp_sq(z9b, z9b);
    fp_mul(z9b, z9b, a_bufb);
    # z11 = z9 * z2(=t0) = a^11
    fp_mul(z11b, z9b, t0b);
    # z5 = z11^2 * z9  = a^(2^5 - 1) = a^31
    fp_sq(z5b, z11b);
    fp_mul(z5b, z5b, z9b);

    # z10 = z5^(2^5) * z5 = a^(2^10 - 1)
    fp_sq(z10b, z5b);
    _fpi_sq_n(z10b, 4);
    fp_mul(z10b, z10b, z5b);

    # t0 = z10^(2^10) * z10 = a^(2^20 - 1)
    fp_sq(t0b, z10b);
    _fpi_sq_n(t0b, 9);
    fp_mul(t0b, t0b, z10b);

    # t0 = t0^(2^20) * t0 = a^(2^40 - 1)
    # Save current t0 into z9 (which is dead after this point —
    # the last use was building z11).
    u256_copy(z9b, t0b);
    _fpi_sq_n(t0b, 20);
    fp_mul(t0b, t0b, z9b);

    # t0 = t0^(2^10) * z10 = a^(2^50 - 1)
    _fpi_sq_n(t0b, 10);
    fp_mul(z50b, t0b, z10b);

    # t0 = z50^(2^50) * z50 = a^(2^100 - 1)
    fp_sq(t0b, z50b);
    _fpi_sq_n(t0b, 49);
    fp_mul(z100b, t0b, z50b);

    # t0 = z100^(2^100) * z100 = a^(2^200 - 1)
    fp_sq(t0b, z100b);
    _fpi_sq_n(t0b, 99);
    fp_mul(t0b, t0b, z100b);

    # t0 = t0^(2^50) * z50 = a^(2^250 - 1)
    _fpi_sq_n(t0b, 50);
    fp_mul(t0b, t0b, z50b);

    # r = t0^(2^5) * z11 = a^(2^255 - 21) = a^(p - 2)
    _fpi_sq_n(t0b, 5);
    fp_mul(r, t0b, z11b);
    return 0;
}

# --- bignum.cyr ---

# bignum.cyr -- general variable-width big-integer arithmetic.
#
# WHY A THIRD BIGINT MODULE
# -------------------------
# `lib/bigint.cyr` is fixed 256-bit (u256) and `src/bigint_ext.cyr` is
# Curve25519 field arithmetic (mod 2^255-19 only). RSA needs arbitrary
# modular exponentiation over 2048/3072/4096-bit operands, so this
# module provides general big integers: little-endian arrays of 64-bit
# limbs, backed by caller-provided byte buffers (limb i lives at byte
# offset i*8; `var X[N]` is N BYTES, CLAUDE.md quirk #3). Schoolbook
# multiply (reusing stdlib `_mul64`) + binary long-division reduction +
# left-to-right square-and-multiply modexp.
#
# SCOPE / THREADING / TIMING
# --------------------------
# This is the engine for RSA. RSA *verification* (the first consumer)
# operates entirely on PUBLIC data -- signature, public modulus n,
# public exponent e -- so:
#   * no constant-time requirement (data-dependent branches in the
#     reduction loop are fine; there is no secret to leak). RSA *sign*
#     (a later bite) must use blinding + a constant-time ladder; do NOT
#     reuse `bn_modexp` for secret exponents without that work.
#   * not on the parallel batch-verify path (that is Ed25519); like
#     sigil's HMAC/HKDF/PRF surface the working buffers are plain
#     static function-scope scratch, single-threaded by construction.
#     If RSA ever joins a parallel path, these need the 3.6 bank
#     treatment (see src/crypto_scratch.cyr).
#
# Correctness is the bar; speed is not (schoolbook + bit-by-bit
# reduction). A Montgomery/Barrett pass is a later perf bite, mirroring
# the EC Solinas follow-up.

# Max width: 64 limbs = 4096 bits (RSA-4096). Products are 2x = 128
# limbs. The reduction's running remainder needs 1 extra limb.
var BN_MAX_LIMBS = 64;

# Static scratch (single-threaded; see header). Sizes are BYTES.
var _bn_modrem[520];        # (BN_MAX_LIMBS+1) limbs -- bn_mod remainder
var _bn_modn1[520];         # (BN_MAX_LIMBS+1) limbs -- zero-extended modulus
var _bn_exp_result[512];    # BN_MAX_LIMBS limbs -- modexp accumulator
var _bn_exp_prod[1024];     # 2*BN_MAX_LIMBS limbs -- modexp product
var _bn_exp_base[512];      # BN_MAX_LIMBS limbs -- modexp base copy

# ----------------------------------------------------------------
# Basic limb ops (all take a `limbs` count; buffers are byte ptrs)
# ----------------------------------------------------------------

fn bn_zero(a, limbs): i64 {
    var i = 0;
    while (i < limbs) { store64(a + i * 8, 0); i = i + 1; }
    return 0;
}

fn bn_copy(dst, src, limbs): i64 {
    memcpy(dst, src, limbs * 8);
    return 0;
}

fn bn_is_zero(a, limbs): i64 {
    var acc = 0;
    var i = 0;
    while (i < limbs) { acc = acc | load64(a + i * 8); i = i + 1; }
    if (acc == 0) { return 1; }
    return 0;
}

# Unsigned compare of two `limbs`-limb numbers: 1 if a>b, -1 if a<b,
# 0 if equal. (i64 `<` is signed, so flip the sign bit for unsigned.)
fn bn_cmp(a, b, limbs): i64 {
    var sbit = 1 << 63;
    var i = limbs - 1;
    while (i >= 0) {
        var av = load64(a + i * 8);
        var bv = load64(b + i * 8);
        if (av != bv) {
            if ((av ^ sbit) < (bv ^ sbit)) { return 0 - 1; }
            return 1;
        }
        i = i - 1;
    }
    return 0;
}

# a -= b (both `limbs` limbs); caller guarantees a >= b. Returns the
# out-borrow (0 on a valid subtraction).
fn bn_sub_assign(a, b, limbs): i64 {
    var sbit = 1 << 63;
    var borrow = 0;
    var i = 0;
    while (i < limbs) {
        var av = load64(a + i * 8);
        var bv = load64(b + i * 8);
        if (borrow == 0) {
            store64(a + i * 8, av - bv);
            # borrow out iff av < bv (unsigned)
            if ((av ^ sbit) < (bv ^ sbit)) { borrow = 1; } else { borrow = 0; }
        } else {
            store64(a + i * 8, av - bv - 1);
            # borrow out iff av <= bv (unsigned), i.e. NOT (bv < av)
            if ((bv ^ sbit) < (av ^ sbit)) { borrow = 0; } else { borrow = 1; }
        }
        i = i + 1;
    }
    return borrow;
}

# a <<= 1 over `limbs` limbs; returns the bit shifted out of the top.
fn bn_shl1(a, limbs): i64 {
    var carry = 0;
    var i = 0;
    while (i < limbs) {
        var v = load64(a + i * 8);
        var top = (v >> 63) & 1;
        store64(a + i * 8, (v << 1) | carry);
        carry = top;
        i = i + 1;
    }
    return carry;
}

# a >>= 1 (logical) over `limbs` limbs; returns the bit shifted out of
# the bottom. The 0x7FFF.. mask clears the sign bit that cyrius's
# arithmetic `>>` would otherwise smear in.
fn bn_shr1(a, limbs): i64 {
    var carry = 0;                  # bit descending from the limb above
    var i = limbs - 1;
    while (i >= 0) {
        var v = load64(a + i * 8);
        var low = v & 1;
        store64(a + i * 8, ((v >> 1) & 0x7FFFFFFFFFFFFFFF) | (carry << 63));
        carry = low;
        i = i - 1;
    }
    return carry;
}

# a += b (both `limbs` limbs); returns the carry out.
fn bn_add_assign(a, b, limbs): i64 {
    var sbit = 1 << 63;
    var carry = 0;
    var i = 0;
    while (i < limbs) {
        var av = load64(a + i * 8);
        var bv = load64(b + i * 8);
        var s1 = av + bv;
        var c1 = 0;
        if ((s1 ^ sbit) < (av ^ sbit)) { c1 = 1; }
        var s2 = s1 + carry;
        var c2 = 0;
        if ((s2 ^ sbit) < (s1 ^ sbit)) { c2 = 1; }
        store64(a + i * 8, s2);
        carry = c1 + c2;
        i = i + 1;
    }
    return carry;
}

# 1 if the `limbs`-limb value equals 1, else 0.
fn bn_is_one(a, limbs): i64 {
    if (load64(a) != 1) { return 0; }
    var i = 1;
    while (i < limbs) {
        if (load64(a + i * 8) != 0) { return 0; }
        i = i + 1;
    }
    return 1;
}

# Index of the highest set bit + 1 (0 for a zero value).
fn bn_bitlen(a, limbs): i64 {
    var i = limbs - 1;
    while (i >= 0) {
        var v = load64(a + i * 8);
        if (v != 0) {
            var b = 63;
            while (b >= 0) {
                if (((v >> b) & 1) == 1) { return i * 64 + b + 1; }
                b = b - 1;
            }
        }
        i = i - 1;
    }
    return 0;
}

# Bit `idx` (0 = LSB) of an arbitrarily-wide little-endian number.
fn bn_test_bit(a, idx): i64 {
    var limb = idx / 64;
    var bit = idx % 64;
    return (load64(a + limb * 8) >> bit) & 1;
}

# ----------------------------------------------------------------
# Serialization (big-endian bytes <-> little-endian limbs)
# ----------------------------------------------------------------

# Parse `blen` big-endian bytes into `limbs` little-endian limbs.
# `out` is zeroed first; bytes beyond the buffer width are dropped.
fn bn_from_be(out, limbs, bytes, blen): i64 {
    bn_zero(out, limbs);
    var i = 0;                          # byte index counting from the LSB
    while (i < blen) {
        var b = load8(bytes + (blen - 1 - i)) & 0xFF;
        var limb = i / 8;
        var shift = (i % 8) * 8;
        if (limb < limbs) {
            store64(out + limb * 8, load64(out + limb * 8) | (b << shift));
        }
        i = i + 1;
    }
    return 0;
}

# Serialize `limbs` little-endian limbs to `blen` big-endian bytes,
# left-zero-padded (or truncated to the low `blen` bytes).
fn bn_to_be(bytes, blen, a, limbs): i64 {
    var i = 0;
    while (i < blen) {
        var b = 0;
        if (i < limbs * 8) {
            var limb = i / 8;
            var shift = (i % 8) * 8;
            b = (load64(a + limb * 8) >> shift) & 0xFF;
        }
        store8(bytes + (blen - 1 - i), b);
        i = i + 1;
    }
    return 0;
}

# ----------------------------------------------------------------
# Multiply and reduce
# ----------------------------------------------------------------

# out (2*limbs) = a * b (each `limbs` limbs). Schoolbook; out is zeroed.
fn bn_mul(out, a, b, limbs): i64 {
    bn_zero(out, 2 * limbs);
    var sbit = 1 << 63;
    var i = 0;
    while (i < limbs) {
        var av = load64(a + i * 8);
        var carry = 0;
        var j = 0;
        while (j < limbs) {
            var bv = load64(b + j * 8);
            var lo[8];
            var hi[8];
            _mul64(av, bv, &lo, &hi);
            var lov = load64(&lo);
            var hiv = load64(&hi);
            var prev = load64(out + (i + j) * 8);
            # s1 = prev + lov
            var s1 = prev + lov;
            var c1 = 0;
            if ((s1 ^ sbit) < (prev ^ sbit)) { c1 = 1; }
            # s2 = s1 + carry
            var s2 = s1 + carry;
            var c2 = 0;
            if ((s2 ^ sbit) < (s1 ^ sbit)) { c2 = 1; }
            store64(out + (i + j) * 8, s2);
            carry = hiv + c1 + c2;
            j = j + 1;
        }
        # propagate the final column carry upward
        var k = i + limbs;
        while (carry != 0) {
            var prev = load64(out + k * 8);
            var s = prev + carry;
            var cc = 0;
            if ((s ^ sbit) < (prev ^ sbit)) { cc = 1; }
            store64(out + k * 8, s);
            carry = cc;
            k = k + 1;
        }
        i = i + 1;
    }
    return 0;
}

# rem (m_limbs) = x (x_limbs) mod modulus (m_limbs), via binary long
# division. NOT constant-time -- intended for public operands (RSA
# verify). Running remainder uses m_limbs+1 limbs internally so the
# pre-subtract shift can't overflow.
fn bn_mod(rem, x, x_limbs, modulus, m_limbs): i64 {
    var rl = m_limbs + 1;
    bn_zero(&_bn_modrem, rl);
    # zero-extended modulus (top limb 0) so cmp/sub run over rl limbs
    bn_copy(&_bn_modn1, modulus, m_limbs);
    store64(&_bn_modn1 + m_limbs * 8, 0);

    var i = bn_bitlen(x, x_limbs) - 1;
    while (i >= 0) {
        bn_shl1(&_bn_modrem, rl);
        # bring down bit i of x into the LSB
        store64(&_bn_modrem, load64(&_bn_modrem) | bn_test_bit(x, i));
        if (bn_cmp(&_bn_modrem, &_bn_modn1, rl) >= 0) {
            bn_sub_assign(&_bn_modrem, &_bn_modn1, rl);
        }
        i = i - 1;
    }
    bn_copy(rem, &_bn_modrem, m_limbs);
    return 0;
}

# Bit `idx` of a big-endian byte string `exp` (blen bytes), 0 = LSB.
fn _bn_exp_bit(exp, blen, idx): i64 {
    var byte_from_end = idx / 8;
    var bit = idx % 8;
    return (load8(exp + (blen - 1 - byte_from_end)) >> bit) & 1;
}

# out (limbs) = base^exp mod modulus, where `exp` is `exp_blen`
# big-endian bytes. Left-to-right square-and-multiply. PUBLIC exponent
# only (see header) -- NOT for secret-exponent (sign) use.
fn bn_modexp(out, base, exp, exp_blen, modulus, limbs): i64 {
    bn_zero(&_bn_exp_result, limbs);
    store64(&_bn_exp_result, 1);            # result = 1
    bn_copy(&_bn_exp_base, base, limbs);

    # Locate the highest set bit of exp (hb = -1 when exp == 0, leaving
    # result = 1 = base^0). cyrius has no break/continue, so guard the
    # scan with hb < 0.
    var hb = 0 - 1;
    var i = exp_blen * 8 - 1;
    while (i >= 0) {
        if (hb < 0) {
            if (_bn_exp_bit(exp, exp_blen, i) == 1) { hb = i; }
        }
        i = i - 1;
    }

    i = hb;
    while (i >= 0) {
        # result = result^2 mod modulus
        bn_mul(&_bn_exp_prod, &_bn_exp_result, &_bn_exp_result, limbs);
        bn_mod(&_bn_exp_result, &_bn_exp_prod, 2 * limbs, modulus, limbs);
        # if bit i set: result = result * base mod modulus
        if (_bn_exp_bit(exp, exp_blen, i) == 1) {
            bn_mul(&_bn_exp_prod, &_bn_exp_result, &_bn_exp_base, limbs);
            bn_mod(&_bn_exp_result, &_bn_exp_prod, 2 * limbs, modulus, limbs);
        }
        i = i - 1;
    }
    bn_copy(out, &_bn_exp_result, limbs);
    return 0;
}

# ================================================================
# Constant-time Montgomery modular exponentiation (3.6.3c)
# ================================================================
# For the SECRET exponent (RSA sign): unlike `bn_modexp`, this does a
# square AND a multiply every iteration over a FIXED bit count, with a
# constant-time select instead of a branch on the exponent bit — so the
# control flow and memory-access pattern do not depend on the secret.
# (Residual: the per-multiply Montgomery final conditional subtract and
# `bn_sub_assign`'s borrow chain are minor value-dependent timing paths;
# RSA sign blinds the base so they don't correlate with the key.)
#
# CIOS Montgomery multiplication (Koc et al.). Modulus must be ODD
# (true for RSA n and primes p, q). R = 2^(64*limbs).

var _bn_mont_t[528];        # CIOS accumulator (BN_MAX_LIMBS+2 limbs)
var _bn_mont_r2[512];       # R^2 mod n
var _bn_mont_r2src[1040];   # 2^(128*limbs) source (2*BN_MAX_LIMBS+1 limbs)
var _bn_mont_base[512];     # base in Montgomery form
var _bn_mont_res[512];      # running result (Montgomery form)
var _bn_mont_tmp[512];      # multiply temp
var _bn_mont_one[512];      # the integer 1

# ================================================================
# Modular inverse (binary inversion, odd modulus)
# ================================================================
# Used only for the ephemeral per-signature RSA blinding factor (r is
# random, not the key), so this is NOT constant-time. GECC Alg. 2.22
# shape, kept fully reduced in [0, n) throughout.
var _bn_inv_u[512];
var _bn_inv_v[512];
var _bn_inv_x1[512];
var _bn_inv_x2[512];

# x = x/2 mod n (n odd): if x even, plain halve; else (x+n)/2 — x+n is
# even and < 2n, so capture the add-carry into the top bit after the
# shift.
fn _bn_halve_mod(x, n, limbs): i64 {
    if ((load64(x) & 1) == 0) {
        bn_shr1(x, limbs);
    } else {
        var c = bn_add_assign(x, n, limbs);
        bn_shr1(x, limbs);
        if (c == 1) {
            store64(x + (limbs - 1) * 8, load64(x + (limbs - 1) * 8) | (1 << 63));
        }
    }
    return 0;
}

# a = (a - b) mod n, with a, b in [0, n).
fn _bn_submod(a, b, n, limbs): i64 {
    if (bn_cmp(a, b, limbs) < 0) { bn_add_assign(a, n, limbs); }
    bn_sub_assign(a, b, limbs);
    return 0;
}

# rinv = r^-1 mod n  (n odd, gcd(r,n)=1). Returns 0 on success, -1 if r
# is 0 or not invertible (iteration cap). NOT constant-time.
fn bn_modinv(rinv, r, n, limbs): i64 {
    if (bn_is_zero(r, limbs) == 1) { return 0 - 1; }
    bn_copy(&_bn_inv_u, r, limbs);
    bn_copy(&_bn_inv_v, n, limbs);
    bn_zero(&_bn_inv_x1, limbs);
    store64(&_bn_inv_x1, 1);
    bn_zero(&_bn_inv_x2, limbs);

    var cap = 64 * limbs * 4;
    var it = 0;
    var done = 0;
    while (done == 0) {
        if (bn_is_one(&_bn_inv_u, limbs) == 1) { done = 1; }
        else { if (bn_is_one(&_bn_inv_v, limbs) == 1) { done = 2; }
        else { if (bn_is_zero(&_bn_inv_u, limbs) == 1) { done = 3; }   # gcd>1: not invertible
        else { if (bn_is_zero(&_bn_inv_v, limbs) == 1) { done = 3; }
        else { if (it >= cap) { done = 3; }
        else {
            while ((load64(&_bn_inv_u) & 1) == 0) {
                bn_shr1(&_bn_inv_u, limbs);
                _bn_halve_mod(&_bn_inv_x1, n, limbs);
            }
            while ((load64(&_bn_inv_v) & 1) == 0) {
                bn_shr1(&_bn_inv_v, limbs);
                _bn_halve_mod(&_bn_inv_x2, n, limbs);
            }
            if (bn_cmp(&_bn_inv_u, &_bn_inv_v, limbs) >= 0) {
                bn_sub_assign(&_bn_inv_u, &_bn_inv_v, limbs);
                _bn_submod(&_bn_inv_x1, &_bn_inv_x2, n, limbs);
            } else {
                bn_sub_assign(&_bn_inv_v, &_bn_inv_u, limbs);
                _bn_submod(&_bn_inv_x2, &_bn_inv_x1, n, limbs);
            }
            it = it + 1;
        } } } } }
    }

    if (done == 3) { return 0 - 1; }
    if (done == 1) { bn_copy(rinv, &_bn_inv_x1, limbs); }
    else { bn_copy(rinv, &_bn_inv_x2, limbs); }
    return 0;
}

# -n[0]^-1 mod 2^64 via Newton's iteration (n0 odd). Each step doubles
# the number of correct low bits: 1 -> 2 -> 4 -> ... -> 64.
fn _bn_mont_n0inv(n0): i64 {
    var inv = 1;
    var i = 0;
    while (i < 6) {
        inv = inv * (2 - n0 * inv);   # mod 2^64 (natural i64 wraparound)
        i = i + 1;
    }
    return 0 - inv;                   # -inv mod 2^64
}

# out = a * b * R^-1 mod n   (CIOS). a, b, n, out are `limbs` limbs.
fn _bn_mont_mul(out, a, b, n, n0inv, limbs): i64 {
    var s = limbs;
    var sbit = 1 << 63;
    bn_zero(&_bn_mont_t, s + 2);

    var i = 0;
    while (i < s) {
        var bi = load64(b + i * 8);
        # t += a * b[i]
        var C = 0;
        var j = 0;
        while (j < s) {
            var lo[8];
            var hi[8];
            _mul64(load64(a + j * 8), bi, &lo, &hi);
            var tj = load64(&_bn_mont_t + j * 8);
            var s1 = tj + load64(&lo);
            var c1 = 0;
            if ((s1 ^ sbit) < (tj ^ sbit)) { c1 = 1; }
            var s2 = s1 + C;
            var c2 = 0;
            if ((s2 ^ sbit) < (s1 ^ sbit)) { c2 = 1; }
            store64(&_bn_mont_t + j * 8, s2);
            C = load64(&hi) + c1 + c2;
            j = j + 1;
        }
        var ts = load64(&_bn_mont_t + s * 8);
        var s3 = ts + C;
        var c3 = 0;
        if ((s3 ^ sbit) < (ts ^ sbit)) { c3 = 1; }
        store64(&_bn_mont_t + s * 8, s3);
        store64(&_bn_mont_t + (s + 1) * 8, c3);

        # m = t[0] * n0inv mod 2^64; t += m * n; shift down one limb
        var m = load64(&_bn_mont_t) * n0inv;
        var lo0[8];
        var hi0[8];
        _mul64(m, load64(n), &lo0, &hi0);
        var t0 = load64(&_bn_mont_t);
        var u0 = t0 + load64(&lo0);
        var d0 = 0;
        if ((u0 ^ sbit) < (t0 ^ sbit)) { d0 = 1; }
        C = load64(&hi0) + d0;          # t[0]+m*n[0] is == 0 mod 2^64 by construction
        j = 1;
        while (j < s) {
            var loj[8];
            var hij[8];
            _mul64(m, load64(n + j * 8), &loj, &hij);
            var tj = load64(&_bn_mont_t + j * 8);
            var x1 = tj + load64(&loj);
            var e1 = 0;
            if ((x1 ^ sbit) < (tj ^ sbit)) { e1 = 1; }
            var x2 = x1 + C;
            var e2 = 0;
            if ((x2 ^ sbit) < (x1 ^ sbit)) { e2 = 1; }
            store64(&_bn_mont_t + (j - 1) * 8, x2);
            C = load64(&hij) + e1 + e2;
            j = j + 1;
        }
        var ts2 = load64(&_bn_mont_t + s * 8);
        var y = ts2 + C;
        var f = 0;
        if ((y ^ sbit) < (ts2 ^ sbit)) { f = 1; }
        store64(&_bn_mont_t + (s - 1) * 8, y);
        store64(&_bn_mont_t + s * 8, load64(&_bn_mont_t + (s + 1) * 8) + f);
        i = i + 1;
    }

    # t (low s limbs + carry t[s]) is < 2n; reduce to [0, n).
    bn_copy(out, &_bn_mont_t, s);
    var extra = load64(&_bn_mont_t + s * 8);
    # subtract n iff extra != 0 OR out >= n
    var dosub = 0;
    if (extra != 0) { dosub = 1; }
    else { if (bn_cmp(out, n, s) >= 0) { dosub = 1; } }
    if (dosub == 1) { bn_sub_assign(out, n, s); }
    return 0;
}

# out (limbs) = a ? a_buf : b_buf, per limb, constant-time. `bit` is 0/1.
fn _bn_ct_select(out, a_buf, b_buf, bit, limbs): i64 {
    var mask = 0 - bit;               # all-ones if bit==1, else 0
    var nmask = mask ^ (0 - 1);
    var i = 0;
    while (i < limbs) {
        store64(out + i * 8,
                (load64(a_buf + i * 8) & mask) | (load64(b_buf + i * 8) & nmask));
        i = i + 1;
    }
    return 0;
}

# out (limbs) = base^exp mod modulus, `exp` = `exp_blen` big-endian
# bytes. Constant-time in the exponent (square+multiply every bit over
# the full width). Modulus MUST be odd. Safe for the secret exponent.
fn bn_mont_modexp(out, base, exp, exp_blen, modulus, limbs): i64 {
    var n0inv = _bn_mont_n0inv(load64(modulus));

    # R^2 mod n  =  2^(128*limbs) mod n
    var r2limbs = 2 * limbs + 1;
    bn_zero(&_bn_mont_r2src, r2limbs);
    store64(&_bn_mont_r2src + (2 * limbs) * 8, 1);
    bn_mod(&_bn_mont_r2, &_bn_mont_r2src, r2limbs, modulus, limbs);

    bn_zero(&_bn_mont_one, limbs);
    store64(&_bn_mont_one, 1);

    # base_m = base*R mod n ; res = 1*R mod n (Montgomery 1)
    _bn_mont_mul(&_bn_mont_base, base, &_bn_mont_r2, modulus, n0inv, limbs);
    _bn_mont_mul(&_bn_mont_res, &_bn_mont_one, &_bn_mont_r2, modulus, n0inv, limbs);

    var i = exp_blen * 8 - 1;
    while (i >= 0) {
        _bn_mont_mul(&_bn_mont_res, &_bn_mont_res, &_bn_mont_res, modulus, n0inv, limbs);
        _bn_mont_mul(&_bn_mont_tmp, &_bn_mont_res, &_bn_mont_base, modulus, n0inv, limbs);
        _bn_ct_select(&_bn_mont_res, &_bn_mont_tmp, &_bn_mont_res, _bn_exp_bit(exp, exp_blen, i), limbs);
        i = i - 1;
    }

    # convert out of Montgomery form: out = res * 1 * R^-1 mod n
    _bn_mont_mul(out, &_bn_mont_res, &_bn_mont_one, modulus, n0inv, limbs);
    return 0;
}

# --- ed25519.cyr ---

# ed25519.cyr — Ed25519 signing and verification (RFC 8032)
# Built on bigint.cyr (u256) and bigint_ext.cyr (fp_* field ops)
#
# Curve: -x^2 + y^2 = 1 + d*x^2*y^2 (mod p)
# p = 2^255 - 19
# d = -121665/121666 mod p
# L = 2^252 + 27742317777372353535851937790883648493 (group order)
# B = base point (y = 4/5 mod p)
#
# Points: extended coordinates (X, Y, Z, T) where x=X/Z, y=Y/Z, T=X*Y/Z
# Each coordinate is a u256 (32 bytes), point = 128 bytes

# ================================================================
# Constants (allocated on init)
# ================================================================

var _ed_d = 0;
var _ed_2d = 0;
var _ed_B = 0;       # base point (128 bytes: X,Y,Z,T)
var _ed_B_table = 0; # fixed-base table: 64 rows × 16 pts × 128B = 128KB
var _ed_L = 0;       # group order (32 bytes)
var _ed_sqrtm1 = 0;
var _ed25519_inited = 0;

# ================================================================
# Point layout: 128 bytes = 4 x u256
# ================================================================
# +0:   X (32 bytes)
# +32:  Y (32 bytes)
# +64:  Z (32 bytes)
# +96:  T (32 bytes)

fn ge_alloc(): i64 { return alloc(128); }

fn ge_x(p): i64 { return p; }
fn ge_y(p): i64 { return p + 32; }
fn ge_z(p): i64 { return p + 64; }
fn ge_t(p): i64 { return p + 96; }

fn ge_identity(p): i64 {
    # Identity in extended coordinates: (X,Y,Z,T) = (0,1,1,0).
    # Written limb-direct rather than via u256_from(0)/u256_from(1),
    # which each `alloc(32)`: the stdlib bump allocator is NOT
    # thread-safe (CLAUDE.md quirk #7), and ge_identity is on the
    # parallel verify hot path (ge_scalarmult / _ge_table_select),
    # so any alloc here would race once `_sigil_batch_mutex` is
    # dropped. memset + two stores is also faster.
    memset(p, 0, 128);
    store64(p + 32, 1);   # Y = 1
    store64(p + 64, 1);   # Z = 1
    return 0;
}

fn ge_copy(dst, src): i64 {
    memcpy(dst, src, 128);
    return 0;
}

# ================================================================
# Point addition (extended coordinates)
# From "Twisted Edwards Curves Revisited" — HWCD08
# Cost: 8M + 1D (D = multiply by 2d)
# ================================================================

fn ge_add(r, p, q): i64 {
    # Per-thread banked working scratch (3.6): every `var X[N]` is a
    # static function-scope global (CLAUDE.md quirk #1). Each batch
    # worker uses its own 32-byte lane (one `cbank()` read per call).
    var bk = cbank();
    var t1[256]; var t1b = &t1 + bk * 32;   # 32 * SIGIL_CRYPTO_BANKS
    var t2[256]; var t2b = &t2 + bk * 32;
    var A[256];  var Ab  = &A  + bk * 32;
    var B2[256]; var B2b = &B2 + bk * 32;
    var C[256];  var Cb  = &C  + bk * 32;
    var D[256];  var Db  = &D  + bk * 32;
    var E[256];  var Eb  = &E  + bk * 32;
    var F[256];  var Fb  = &F  + bk * 32;
    var G[256];  var Gb  = &G  + bk * 32;
    var H2[256]; var H2b = &H2 + bk * 32;

    # A = (Y1-X1)*(Y2-X2)
    fp_sub(t1b, ge_y(p), ge_x(p));
    fp_sub(t2b, ge_y(q), ge_x(q));
    fp_mul(Ab, t1b, t2b);

    # B = (Y1+X1)*(Y2+X2)
    fp_add(t1b, ge_y(p), ge_x(p));
    fp_add(t2b, ge_y(q), ge_x(q));
    fp_mul(B2b, t1b, t2b);

    # C = T1*2d*T2
    fp_mul(Cb, ge_t(p), ge_t(q));
    fp_mul(Cb, Cb, _ed_2d);

    # D = Z1*2*Z2
    fp_mul(Db, ge_z(p), ge_z(q));
    fp_add(Db, Db, Db);

    # E=B-A, F=D-C, G=D+C, H=B+A
    fp_sub(Eb, B2b, Ab);
    fp_sub(Fb, Db, Cb);
    fp_add(Gb, Db, Cb);
    fp_add(H2b, B2b, Ab);

    # X3=E*F, Y3=G*H, T3=E*H, Z3=F*G
    fp_mul(ge_x(r), Eb, Fb);
    fp_mul(ge_y(r), Gb, H2b);
    fp_mul(ge_t(r), Eb, H2b);
    fp_mul(ge_z(r), Fb, Gb);
    return 0;
}

# ================================================================
# Point doubling
# ================================================================

fn ge_double(r, p): i64 {
    # Per-thread banked working scratch (3.6) — see ge_add.
    var bk = cbank();
    var A[256]; var Ab = &A + bk * 32;     # 32 * SIGIL_CRYPTO_BANKS
    var B[256]; var Bb = &B + bk * 32;
    var C[256]; var Cb = &C + bk * 32;
    var D[256]; var Db = &D + bk * 32;
    var E[256]; var Eb = &E + bk * 32;
    var F[256]; var Fb = &F + bk * 32;
    var G[256]; var Gb = &G + bk * 32;
    var H[256]; var Hb = &H + bk * 32;
    var t[256]; var tb = &t + bk * 32;

    fp_sq(Ab, ge_x(p));
    fp_sq(Bb, ge_y(p));
    fp_sq(Cb, ge_z(p));
    fp_add(Cb, Cb, Cb);
    fp_neg(Db, Ab);  # a=-1 for ed25519

    fp_add(tb, ge_x(p), ge_y(p));
    fp_sq(Eb, tb);
    fp_sub(Eb, Eb, Ab);
    fp_sub(Eb, Eb, Bb);

    fp_add(Gb, Db, Bb);
    fp_sub(Fb, Gb, Cb);
    fp_sub(Hb, Db, Bb);

    fp_mul(ge_x(r), Eb, Fb);
    fp_mul(ge_y(r), Gb, Hb);
    fp_mul(ge_t(r), Eb, Hb);
    fp_mul(ge_z(r), Fb, Gb);
    return 0;
}

# ================================================================
# Scalar multiplication: R = [s]P  (constant-time double-and-add)
# s is 32 bytes little-endian scalar.
#
# This loop MUST NOT branch on any bit of s: s is secret when called
# from ed25519_keypair / ed25519_sign (the clamped private scalar).
# Every iteration unconditionally computes both (r + q) and (2q) and
# uses a branchless select to either adopt or discard the addition.
# ================================================================

# Constant-time conditional move on a 128-byte extended point.
# If bit == 1: dst := src.  If bit == 0: dst unchanged.
# Per-limb select via stdlib ct_select (lib/ct.cyr) — identical
# mask-xor arithmetic, single audit surface across the codebase.
fn ge_cmov(dst, src, bit): i64 {
    var i = 0;
    while (i < 128) {
        var d = load64(dst + i);
        var sv = load64(src + i);
        store64(dst + i, ct_select(bit, d, sv));
        i = i + 8;
    }
    return 0;
}

fn ge_scalarmult(r, s, p): i64 {
    # Per-thread banked working points (3.6) — see ge_add.
    var bk = cbank();
    var q[1024];   var qb = &q + bk * 128;     # 128 * SIGIL_CRYPTO_BANKS
    var tmp[1024]; var tmpb = &tmp + bk * 128;
    ge_identity(r);
    ge_copy(qb, p);

    var i = 0;
    while (i < 256) {
        var byte_idx = i / 8;
        var bit_idx = i % 8;
        var bit = (load8(s + byte_idx) >> bit_idx) & 1;

        # Unconditional add; unconditional select.
        ge_add(tmpb, r, qb);
        ge_cmov(r, tmpb, bit);

        # Unconditional double of q.
        ge_double(tmpb, qb);
        ge_copy(qb, tmpb);
        i = i + 1;
    }
    return 0;
}

# ================================================================
# Fixed-base scalar multiplication: R = [s]B  (uses _ed_B_table)
# 4-bit windowed comb: 64 windows × 16 precomputed points per window.
# Cost: 64 constant-time table selects + 64 ge_adds, no doublings.
# Must be constant-time — s is secret in keypair/sign.
# ================================================================

# Branchless: sets dst := row[digit] in constant time. Iterates all
# 16 entries and cmoves the one whose index equals digit. Memory
# access pattern does not depend on digit.
fn _ge_table_select(dst, row, digit): i64 {
    # Initialize dst to identity (entry k=0) — equivalent and simpler
    # than reading row[0], which is also identity.
    ge_identity(dst);
    var k = 1;
    while (k < 16) {
        # eq = 1 iff k == digit, else 0  (branchless).
        # diff|(-diff) has its high bit set iff diff != 0.
        var diff = k ^ digit;
        var neg = 0 - diff;
        var eq = 1 - (((diff | neg) >> 63) & 1);
        ge_cmov(dst, row + k * 128, eq);
        k = k + 1;
    }
    return 0;
}

fn ge_scalarmult_base(r, s): i64 {
    # Per-thread banked working points (3.6) — see ge_add.
    var bk = cbank();
    var sel[1024]; var selb = &sel + bk * 128;   # 128 * SIGIL_CRYPTO_BANKS
    var tmp[1024]; var tmpb = &tmp + bk * 128;
    ge_identity(r);

    var i = 0;
    while (i < 64) {
        # Public-index nibble extract: byte i/2, low or high nibble.
        var byte_idx = i / 2;
        var b = load8(s + byte_idx) & 0xFF;
        var digit = b & 0xF;
        if ((i & 1) == 1) { digit = (b >> 4) & 0xF; }

        # Constant-time select into sel.
        _ge_table_select(selb, _ed_B_table + i * 16 * 128, digit);

        # r = r + sel  (ge_add handles r==identity and sel==identity correctly;
        # HWCD08 addition formula is complete on twisted Edwards curves).
        ge_add(tmpb, r, selb);
        ge_copy(r, tmpb);
        i = i + 1;
    }
    return 0;
}

# ================================================================
# Build _ed_B_table at init — runs once, not perf-critical.
# Layout: table[i][k] = k * (16^i) * B. 64 rows × 16 entries × 128B.
# ================================================================

fn _build_ed_B_table(): i64 {
    _ed_B_table = alloc(131072);   # 64 * 16 * 128
    var base_i[128];
    ge_copy(&base_i, _ed_B);

    var table_i = 0;
    while (table_i < 64) {
        var row = _ed_B_table + table_i * 16 * 128;
        ge_identity(row);                          # k=0 → identity
        ge_copy(row + 128, &base_i);               # k=1 → base_i
        var k = 2;
        while (k < 16) {
            # row[k] = row[k-1] + base_i
            ge_add(row + k * 128, row + (k - 1) * 128, &base_i);
            k = k + 1;
        }
        if (table_i < 63) {
            # base_{i+1} = 16 * base_i → four in-place doublings
            ge_double(&base_i, &base_i);
            ge_double(&base_i, &base_i);
            ge_double(&base_i, &base_i);
            ge_double(&base_i, &base_i);
        }
        table_i = table_i + 1;
    }
    return 0;
}

# ================================================================
# Point compression: point -> 32 bytes
# Encode y with sign of x in high bit of last byte
# ================================================================

fn ge_to_bytes(out, p): i64 {
    # Per-thread banked working scratch (3.6) — see ge_add.
    var bk = cbank();
    var recip[256]; var recipb = &recip + bk * 32;   # 32 * SIGIL_CRYPTO_BANKS
    var x[256];     var xb = &x + bk * 32;
    var y[256];     var yb = &y + bk * 32;
    fp_inv(recipb, ge_z(p));
    fp_mul(xb, ge_x(p), recipb);
    fp_mul(yb, ge_y(p), recipb);

    # Encode y as 32 bytes little-endian
    u256_store_le(out, yb);

    # Set high bit to sign of x (low bit of x)
    var x_sign = u256_limb(xb, 0) & 1;
    store8(out + 31, (load8(out + 31) & 0xFF) | (x_sign << 7));
    return 0;
}

# ================================================================
# Point decompression: 32 bytes -> point
# Recover x from y using curve equation: x^2 = (y^2-1)/(dy^2+1)
# ================================================================

# (p-5)/8 — exponent for the curve-equation x-recovery. Read-only
# after init; computed once in ed25519_init alongside the other
# curve constants.
var _ed_decomp_exp = 0;

fn ge_from_bytes(p, s): i64 {
    ed25519_init();

    # Working scratch, banked per thread (3.6): each `var X[N]` is a
    # static function-scope global (CLAUDE.md quirk #1); each batch
    # worker decompresses into its own 32-byte lanes. One `cbank()`
    # read per call.  (32 * SIGIL_CRYPTO_BANKS each.)
    var bk = cbank();
    var u[256];      var ub = &u + bk * 32;
    var v[256];      var vb = &v + bk * 32;
    var y2[256];     var y2b = &y2 + bk * 32;
    var v3[256];     var v3b = &v3 + bk * 32;
    var v7[256];     var v7b = &v7 + bk * 32;
    var uv3[256];    var uv3b = &uv3 + bk * 32;
    var uv7[256];    var uv7b = &uv7 + bk * 32;
    var pow[256];    var powb = &pow + bk * 32;
    var x[256];      var xb = &x + bk * 32;
    var check[256];  var checkb = &check + bk * 32;
    var vx2[256];    var vx2b = &vx2 + bk * 32;
    var y[256];      var yb = &y + bk * 32;
    var s_copy[256]; var s_copyb = &s_copy + bk * 32;
    var one[256];    var oneb = &one + bk * 32;

    memset(oneb, 0, 32);
    store64(oneb, 1);

    # Decode y from bytes, clear sign bit
    var x_sign = (load8(s + 31) >> 7) & 1;
    memcpy(s_copyb, s, 32);
    store8(s_copyb + 31, load8(s_copyb + 31) & 0x7F);

    # Load y as u256 from little-endian bytes
    u256_load_le(yb, s_copyb);

    # u = y^2 - 1
    fp_sq(y2b, yb);
    fp_sub(ub, y2b, oneb);

    # v = d*y^2 + 1
    fp_mul(vb, _ed_d, y2b);
    fp_add(vb, vb, oneb);

    # candidate = u * v^3 * (u*v^7)^((p-5)/8)
    fp_sq(v3b, vb);
    fp_mul(v3b, v3b, vb);        # v^3
    fp_sq(v7b, v3b);
    fp_mul(v7b, v7b, vb);        # v^7
    fp_mul(uv7b, ub, v7b);       # u*v^7
    fp_mul(uv3b, ub, v3b);       # u*v^3

    fp_pow(powb, uv7b, _ed_decomp_exp);

    # x = u*v^3 * pow
    fp_mul(xb, uv3b, powb);

    # Verify: v*x^2 == u?
    fp_sq(vx2b, xb);
    fp_mul(checkb, vb, vx2b);

    # If check != u, try x * sqrt(-1)
    if (u256_eq(checkb, ub) == 0) {
        fp_mul(xb, xb, _ed_sqrtm1);
    }

    # Adjust sign
    if ((u256_limb(xb, 0) & 1) != x_sign) {
        fp_neg(xb, xb);
    }

    # Set point: X=x, Y=y, Z=1, T=x*y
    u256_copy(ge_x(p), xb);
    u256_copy(ge_y(p), yb);
    u256_copy(ge_z(p), oneb);
    fp_mul(ge_t(p), xb, yb);
    return 0;
}

# ================================================================
# Ed25519 initialization
# ================================================================

fn ed25519_init(): i64 {
    if (_ed25519_inited == 1) { return 0; }
    _init_ed_p();

    # Pre-computed constants (avoids expensive fp_pow at init)

    # d = -121665/121666 mod p
    # = 0x52036cee2b6ffe738cc740797779e89800700a4d4141d8ab75eb4dca135978a3
    _ed_d = u256_from_hex("52036cee2b6ffe738cc740797779e89800700a4d4141d8ab75eb4dca135978a3");

    # 2*d
    _ed_2d = alloc(32);
    fp_add(_ed_2d, _ed_d, _ed_d);

    # sqrt(-1) mod p
    # = 0x2b8324804fc1df0b2b4d00993dfbd7a72f431806ad2fe478c4ee1b274a0ea0b0
    _ed_sqrtm1 = u256_from_hex("2b8324804fc1df0b2b4d00993dfbd7a72f431806ad2fe478c4ee1b274a0ea0b0");

    # L (group order)
    _ed_L = u256_from_hex("1000000000000000000000000000000014def9dea2f79cd65812631a5cf5d3ed");

    # Base point B: pre-computed extended coordinates
    # B.y = 4/5 mod p = 0x6666...6658
    # B.x = recovered from curve equation
    # Encoded point (compressed): 5866666666666666666666666666666666666666666666666666666666666666
    # X = 0x216936d3cd6e53fec0a4e231fdd6dc5c692cc7609525a7b2c9562d608f25d51a
    # Y = 0x6666666666666666666666666666666666666666666666666666666666666658
    _ed_B = alloc(128);
    var Bx = u256_from_hex("216936d3cd6e53fec0a4e231fdd6dc5c692cc7609525a7b2c9562d608f25d51a");
    var By = u256_from_hex("6666666666666666666666666666666666666666666666666666666666666658");
    var Bz = u256_from(1);
    var Bt = alloc(32);
    fp_mul(Bt, Bx, By);
    u256_copy(ge_x(_ed_B), Bx);
    u256_copy(ge_y(_ed_B), By);
    u256_copy(ge_z(_ed_B), Bz);
    u256_copy(ge_t(_ed_B), Bt);

    # Precomputed fixed-base table for signing/keypair/verify (2.3.0).
    _build_ed_B_table();

    # (p-5)/8 exponent for ge_from_bytes square-root recovery.
    _ed_decomp_exp = u256_from_hex("0ffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffd");

    # R = 2^256 mod L for sc_reduce. Initialised here so the
    # parallel-batch main-thread pre-warm in sv_verify_batch
    # covers it (sc_reduce is called from ed25519_verify).
    _scr_r256 = u256_from_hex("0ffffffffffffffffffffffffffffffec6ef5bf4737dcf70d6ec31748d98951d");

    _ed25519_inited = 1;
    return 0;
}

# ================================================================
# Scalar reduce: 64-byte hash -> 32-byte scalar mod L
# ================================================================

# R = 2^256 mod L — read-only constant, init-once via
# ed25519_init() so the parallel-batch pre-warm covers it.
var _scr_r256 = 0;

fn sc_reduce(out, s64): i64 {
    # Reduce 512-bit value mod L using: val = hi*2^256 + lo ≡ hi*R + lo (mod L)
    # where R = 2^256 mod L. Iterate until hi == 0.
    #
    # Working scratch, banked per thread (3.6): `var X[N]` is a
    # static function-scope global (CLAUDE.md quirk #1), so each
    # batch-verify worker reduces into its own lane. One `cbank()`
    # read per call.
    var bk = cbank();
    var lo[256];   var lob = &lo + bk * 32;     # 32 * SIGIL_CRYPTO_BANKS
    var hi[256];   var hib = &hi + bk * 32;
    var prod[512]; var prodb = &prod + bk * 64; # 64 * SIGIL_CRYPTO_BANKS

    # Load 64-byte input as two u256 (little-endian).
    u256_load_le(lob, s64);
    u256_load_le(hib, s64 + 32);

    # Iteratively reduce: lo = lo + hi*R, split result, repeat until hi == 0
    while (u256_is_zero(hib) == 0) {
        u256_mul_full(prodb, hib, _scr_r256);
        # new_hi = product high 256 bits
        store64(hib, load64(prodb + 32));
        store64(hib + 8, load64(prodb + 40));
        store64(hib + 16, load64(prodb + 48));
        store64(hib + 24, load64(prodb + 56));
        # new_lo = old_lo + product_lo (carry propagates to hi)
        var carry = u256_add(lob, lob, prodb);
        if (carry > 0) {
            # Add carry to hi limb 0, propagate manually
            var h0 = load64(hib) + 1;
            store64(hib, h0);
            if (h0 == 0) {
                var h1 = load64(hib + 8) + 1;
                store64(hib + 8, h1);
                if (h1 == 0) {
                    var h2 = load64(hib + 16) + 1;
                    store64(hib + 16, h2);
                    if (h2 == 0) {
                        store64(hib + 24, load64(hib + 24) + 1);
                    }
                }
            }
        }
    }

    # Final reduction mod L
    while (u256_cmp(lob, _ed_L) >= 0) {
        u256_sub(lob, lob, _ed_L);
    }

    u256_copy(out, lob);
    return 0;
}

# ================================================================
# sc_muladd: out = (a * b + c) mod L
# ================================================================

fn sc_muladd(out, a, b, c): i64 {
    var prod[64];
    u256_mul_full(&prod, a, b);

    # Add c to the 512-bit product (low 256 bits, propagate carry to high)
    var carry = u256_add(&prod, &prod, c);
    if (carry > 0) {
        store64(&prod + 32, load64(&prod + 32) + carry);
    }

    sc_reduce(out, &prod);
    return 0;
}

# ================================================================
# Ed25519 keypair: seed (32 bytes) -> sk (64 bytes), pk (32 bytes)
# ================================================================

fn ed25519_keypair(seed, sk_out, pk_out): i64 {
    ed25519_init();
    # `secret var` (cyrius 5.3.5+) gives compiler-guaranteed
    # zeroization on scope exit — replaces the pre-3.3 manual
    # memset(_kp_*, 0, ...) pattern against module-global buffers.
    secret var hash[64];
    secret var scalar[32];
    sha512(seed, 32, &hash);

    # Clamp scalar (first 32 bytes)
    store8(&hash, load8(&hash) & 0xF8);
    store8(&hash + 31, (load8(&hash + 31) & 0x7F) | 0x40);

    memcpy(&scalar, &hash, 32);

    # A = [a]B  (fixed-base, constant-time table lookup)
    var A[128];
    ge_scalarmult_base(&A, &scalar);
    ge_to_bytes(pk_out, &A);

    memcpy(sk_out, seed, 32);
    memcpy(sk_out + 32, pk_out, 32);
    return 0;
}

# ================================================================
# Ed25519 sign: sk (64b), msg, msg_len -> sig (64b)
# ================================================================

fn ed25519_sign(sk, msg, msg_len, sig_out): i64 {
    ed25519_init();
    # Secret material — compiler-guaranteed zeroize on exit.
    # az holds H(sk)[0..64] (clamped scalar a + nonce seed);
    # r_scalar is the per-signature nonce; a_scalar is the
    # long-term scalar a re-loaded as u256. Leaking any one
    # recovers the signing secret.
    secret var az[64];
    secret var nhash[64];
    secret var r_scalar[32];
    secret var a_scalar[32];
    # Public-derivable; no need to zeroize.
    var hram[64];
    var h_scalar[32];
    var R_point[128];
    var S_result[32];

    sha512(sk, 32, &az);
    store8(&az, load8(&az) & 0xF8);
    store8(&az + 31, (load8(&az + 31) & 0x7F) | 0x40);

    # r = SHA-512(az[32..64] || msg) mod L
    var nctx = sha512_init();
    sha512_update(nctx, &az + 32, 32);
    sha512_update(nctx, msg, msg_len);
    sha512_finalize(nctx, &nhash);
    fl_free(nctx);

    sc_reduce(&r_scalar, &nhash);

    # R = [r]B  (fixed-base, constant-time table lookup)
    ge_scalarmult_base(&R_point, &r_scalar);
    ge_to_bytes(sig_out, &R_point);

    # h = SHA-512(R || pk || msg) mod L
    var hctx = sha512_init();
    sha512_update(hctx, sig_out, 32);
    sha512_update(hctx, sk + 32, 32);
    sha512_update(hctx, msg, msg_len);
    sha512_finalize(hctx, &hram);
    fl_free(hctx);

    sc_reduce(&h_scalar, &hram);

    # Load a from az[0..32] as u256
    u256_load_le(&a_scalar, &az);

    # S = (r + h*a) mod L
    sc_muladd(&S_result, &h_scalar, &a_scalar, &r_scalar);

    # Write S as little-endian bytes to sig_out+32
    u256_store_le(sig_out + 32, &S_result);
    return 0;
}

# ================================================================
# Ed25519 verify: pk (32b), msg, msg_len, sig (64b) -> 0/1
# ================================================================

# 3.3: alloc-free on the hot path — no bump-allocator calls in the
# verify body (the stdlib allocator is not thread-safe, quirk #7).
# 3.6: every per-call buffer below is banked per thread. A `var X[N]`
# is a static function-scope global (CLAUDE.md quirk #1), NOT a
# stack-local, so concurrent sv_verify_batch workers MUST each use
# their own lane — this is what lets the batch path drop
# `_sigil_batch_mutex`. One `cbank()` read per verify; every banked
# helper it calls (ge_*, fp_*, sc_reduce, sha*) banks its own
# scratch the same way.
fn ed25519_verify(pk, msg, msg_len, sig): i64 {
    ed25519_init();
    var bk = cbank();
    var hram[512];     var hramb = &hram + bk * 64;       # 64 * SIGIL_CRYPTO_BANKS
    var h_scalar[256]; var h_scalarb = &h_scalar + bk * 32;
    var S_scalar[256]; var S_scalarb = &S_scalar + bk * 32;
    var R_bytes[256];  var R_bytesb = &R_bytes + bk * 32;
    var A[1024];       var Ab = &A + bk * 128;            # 128 * SIGIL_CRYPTO_BANKS
    var SB[1024];      var SBb = &SB + bk * 128;
    var hA[1024];      var hAb = &hA + bk * 128;
    var R_check[1024]; var R_checkb = &R_check + bk * 128;

    ge_from_bytes(Ab, pk);

    # h = SHA-512(R || pk || msg) mod L. Stack-allocated (banked)
    # SHA-512 context — sha512_init() would fl_alloc, which is not
    # thread-safe under concurrent batch-verify workers.
    var hctx[1664];    var hctxb = &hctx + bk * 208;      # 208 * SIGIL_CRYPTO_BANKS
    sha512_init_into(hctxb);
    sha512_update(hctxb, sig, 32);
    sha512_update(hctxb, pk, 32);
    sha512_update(hctxb, msg, msg_len);
    sha512_finalize(hctxb, hramb);

    sc_reduce(h_scalarb, hramb);

    # Load S from sig[32..64] as scalar
    u256_load_le(S_scalarb, sig + 32);

    # RFC 8032 §5.1.7 / §8.4: reject non-canonical S (S must be < L).
    # Prevents signature malleability — the same (pk, msg) must have
    # exactly one valid signature encoding.
    if (u256_cmp(S_scalarb, _ed_L) >= 0) { return 0; }

    # [S]B  (fixed-base; S is public, but base table wins on speed anyway)
    ge_scalarmult_base(SBb, S_scalarb);

    # [h]A
    ge_scalarmult(hAb, h_scalarb, Ab);

    # R_check = [S]B - [h]A (negate hA: negate X and T)
    fp_neg(ge_x(hAb), ge_x(hAb));
    fp_neg(ge_t(hAb), ge_t(hAb));

    ge_add(R_checkb, SBb, hAb);

    ge_to_bytes(R_bytesb, R_checkb);

    return ct_eq_bytes_lens(R_bytesb, 32, sig, 32);
}

# ================================================================
# Generate random keypair
# ================================================================

fn ed25519_generate_keypair(sk_out, pk_out): i64 {
    # The prior implementation had two silent-failure paths:
    #   * no check of file_open's return value — fd=-1 would then
    #     be passed to file_read, leaving the stack-allocated seed
    #     with whatever bytes were already there.
    #   * single unchecked file_read — a short read (say 16 bytes)
    #     left the upper half of the seed uninitialised.
    # Either would derive an Ed25519 key from partial / zero / stale
    # entropy. This loop mirrors the /dev/urandom handling in
    # trust.cyr's `generate_keypair`: bail on open failure, accumulate
    # until 32 bytes, zeroise on any failure path.
    #
    # Returns 1 on success, 0 on entropy failure. Callers that ignore
    # the return value retain the previous "always 0" ABI, but keys
    # produced in that case are all-zero (sk_out / pk_out are set from
    # a zeroed seed) so any verify against them will fail deterministically
    # rather than silently accepting a garbage key.
    # `secret var` clears seed on every return path (Cyrius 5.3.5+).
    # Init memset retained because file_read into a partial buffer
    # on the error path below might leave upper bytes stale.
    secret var seed[32];
    memset(&seed, 0, 32);
    var fd = file_open("/dev/urandom", 0, 0);
    if (fd < 0) {
        memset(sk_out, 0, 64);
        memset(pk_out, 0, 32);
        return 0;
    }
    var got = 0;
    while (got < 32) {
        var n = file_read(fd, (&seed) + got, 32 - got);
        if (n <= 0) {
            file_close(fd);
            memset(sk_out, 0, 64);
            memset(pk_out, 0, 32);
            return 0;
        }
        got = got + n;
    }
    file_close(fd);
    ed25519_keypair(&seed, sk_out, pk_out);
    return 1;
}

# --- x25519.cyr ---

# x25519.cyr — X25519 Diffie-Hellman key agreement (RFC 7748)
#
# X25519 is ECDH on Curve25519 in Montgomery form
#   v^2 = u^3 + 486662*u^2 + u   over GF(2^255 - 19).
# It is an x-coordinate-only scalar multiplication: given a 32-byte
# scalar and a 32-byte u-coordinate, the Montgomery ladder computes
# scalar·u and returns the resulting u-coordinate. This is TLS
# 1.3's default key-exchange group (`x25519`).
#
# The field arithmetic is reused wholesale from src/bigint_ext.cyr
# (`fp_add/sub/mul/sq/inv`, all mod 2^255-19) — the same primitives
# that back Ed25519. X25519 adds only the Montgomery ladder, the
# RFC 7748 scalar clamp, and the constant-time conditional swap.
#
# CONSTANT-TIME: the ladder is the classic Montgomery double-and-
# add with a `cswap` driven by an arithmetic mask, so the sequence
# of field operations is independent of the secret scalar bits.
#
# ZEROIZATION: all working state — the clamped scalar and every
# ladder field element — lives in a single `secret var` scratch
# block (`W`), zeroized by the compiler on return. (One block, not
# eighteen: Cyrius caps a function at 8 `secret`/`defer` blocks, and
# a single sliced block is also the shape the v3.6 caller-scratch
# cycle wants.) Named pointer locals slice W for readability. Cap
# raise filed upstream:
# https://github.com/MacCracken/cyrius/blob/main/docs/development/issues/2026-05-27-secret-defer-block-per-fn-cap.md
#
# THREAD-SAFETY: `W` is a function-scope `var` array (Cyrius static
# global, quirk #1); each x25519 call reinitializes it up front, so
# serial use is correct. Not yet on a parallel path.
#
# Citation: RFC 7748 §5 (the ladder + clamp), §5.2 / §6.1 (test
# vectors). a24 = (486662 - 2) / 4 = 121665. See docs/sources.md.

# Constant-time conditional swap of two field elements (4 limbs).
# When swap==1 the mask is all-ones and the xor-swap exchanges a/b;
# when swap==0 the mask is zero and both are left unchanged.
fn _x25519_cswap(swap, a, b): i64 {
    var mask = 0 - swap;
    var i = 0;
    while (i < 4) {
        var t = mask & (load64(a + i * 8) ^ load64(b + i * 8));
        store64(a + i * 8, load64(a + i * 8) ^ t);
        store64(b + i * 8, load64(b + i * 8) ^ t);
        i = i + 1;
    }
    return 0;
}

# ================================================================
# x25519 — scalar·u on Curve25519
#   scalar — 32-byte little-endian secret scalar
#   u_in   — 32-byte little-endian u-coordinate (peer public key)
#   out    — 32-byte little-endian result u-coordinate
# Returns 0.
# ================================================================
fn x25519(scalar, u_in, out): i64 {
    # Single zeroized scratch block; 18 field-element slots.
    secret var W[576];
    memset(&W, 0, 576);
    var x_1 = &W + 0;
    var x_2 = &W + 32;
    var z_2 = &W + 64;
    var x_3 = &W + 96;
    var z_3 = &W + 128;
    var A   = &W + 160;
    var AA  = &W + 192;
    var B   = &W + 224;
    var BB  = &W + 256;
    var E   = &W + 288;
    var C   = &W + 320;
    var D   = &W + 352;
    var DA  = &W + 384;
    var CB  = &W + 416;
    var t0  = &W + 448;
    var t1  = &W + 480;
    var a24 = &W + 512;
    var k   = &W + 544;

    # Clamp the scalar (RFC 7748 §5): clear the low 3 bits, clear
    # the top bit, set the second-highest bit.
    memcpy(k, scalar, 32);
    store8(k, load8(k) & 248);
    store8(k + 31, (load8(k + 31) & 127) | 64);

    # Decode the u-coordinate: mask off the most significant bit,
    # then load little-endian into limb form. (Plain `var` — public
    # peer data, and arrays that aren't `secret`/`defer` don't count
    # against the 8-block cap.)
    var ub[32];
    memcpy(&ub, u_in, 32);
    store8(&ub + 31, load8(&ub + 31) & 127);
    u256_load_le(x_1, &ub);

    # Ladder state: (x_2,z_2) = (1,0), (x_3,z_3) = (u,1).
    store64(x_2, 1);
    memcpy(x_3, x_1, 32);
    store64(z_3, 1);

    # a24 = 121665.
    store64(a24, 121665);

    var swap = 0;
    var t = 254;
    while (t >= 0) {
        var k_t = ((load8(k + (t >> 3)) & 0xFF) >> (t & 7)) & 1;
        swap = swap ^ k_t;
        _x25519_cswap(swap, x_2, x_3);
        _x25519_cswap(swap, z_2, z_3);
        swap = k_t;

        # Differential add-and-double (RFC 7748 §5).
        fp_add(A, x_2, z_2);        # A  = x2 + z2
        fp_sq(AA, A);               # AA = A^2
        fp_sub(B, x_2, z_2);        # B  = x2 - z2
        fp_sq(BB, B);               # BB = B^2
        fp_sub(E, AA, BB);          # E  = AA - BB
        fp_add(C, x_3, z_3);        # C  = x3 + z3
        fp_sub(D, x_3, z_3);        # D  = x3 - z3
        fp_mul(DA, D, A);           # DA = D * A
        fp_mul(CB, C, B);           # CB = C * B
        fp_add(t0, DA, CB);         # x3 = (DA + CB)^2
        fp_sq(x_3, t0);
        fp_sub(t1, DA, CB);         # z3 = x1 * (DA - CB)^2
        fp_sq(t1, t1);
        fp_mul(z_3, x_1, t1);
        fp_mul(x_2, AA, BB);        # x2 = AA * BB
        fp_mul(t0, a24, E);         # z2 = E * (AA + a24 * E)
        fp_add(t0, AA, t0);
        fp_mul(z_2, E, t0);

        t = t - 1;
    }
    # Undo the final pending swap.
    _x25519_cswap(swap, x_2, x_3);
    _x25519_cswap(swap, z_2, z_3);

    # Result = x_2 / z_2 = x_2 * z_2^(p-2).
    fp_inv(t0, z_2);
    fp_mul(t1, x_2, t0);
    u256_store_le(out, t1);
    return 0;
}

# ================================================================
# x25519_base — public key from a secret scalar: scalar · 9
#   The Curve25519 base point has u-coordinate 9.
# ================================================================
fn x25519_base(scalar, out): i64 {
    var base[32];
    memset(&base, 0, 32);
    store8(&base, 9);
    return x25519(scalar, &base, out);
}

# --- ecdsa_p256.cyr ---

# ecdsa_p256.cyr — ECDSA verify on NIST P-256 (secp256r1)
#
# Surface (Sigil 3.2.1):
#   fn ecdsa_p256_verify(pk, msg, msg_len, sig): i64
#   fn ecdsa_p256_verify_der(pk, msg, msg_len, sig_der, sig_der_len): i64
#
# Inputs (big-endian byte strings, per SEC 1 v2.0 §2.3):
#   pk:  64 bytes — Qx || Qy uncompressed affine public key
#   sig: 64 bytes — r || s, both big-endian
#
# Implementation references:
#   • FIPS 186-5 §6 — ECDSA algorithm
#   • SEC 1 v2.0 §4.1.4 — verifying operation
#   • FIPS 186-4 D.1.2.3 / SP 800-186 — P-256 curve parameters
#
# Constant-time discipline:
#   • Verify takes only public inputs (msg, pk, sig). No secret-data
#     branches exist on this path. The Montgomery-ladder scalar
#     multiplication is still used because (a) it's the same shape a
#     future sign path would need and (b) defense in depth — any
#     future caller composing internal sign / DH against the same
#     point-mul primitive inherits constant-time behaviour for free.
#   • Final r comparison uses OR-accumulation (`ct_eq_bytes_lens`
#     from `lib/ct.cyr`), matching the pattern in `ed25519.cyr`.
#
# All working state lives in module globals because Cyrius'
# single-pass compiler can clobber locals across nested call chains
# (CLAUDE.md quirk #1). Same pattern as `bigint_ext.cyr` and
# `ed25519.cyr`.

# ================================================================
# Curve constants — initialised on first call via `_p256_init`.
# ================================================================

# Field prime p = 2^256 - 2^224 + 2^192 + 2^96 - 1
#   = 0xFFFFFFFF00000001 0000000000000000 00000000FFFFFFFF FFFFFFFFFFFFFFFF
var _p256_p = 0;

# Group order n =
#   0xFFFFFFFF00000000 FFFFFFFFFFFFFFFF BCE6FAADA7179E84 F3B9CAC2FC632551
var _p256_n = 0;

# Curve coefficient b for y^2 = x^3 - 3x + b:
#   b = 0x5AC635D8AA3A93E7 B3EBBD55769886BC 651D06B0CC53B0F6 3BCE3C3E27D2604B
var _p256_b = 0;

# Base point G (affine) — Gx, Gy
var _p256_gx = 0;
var _p256_gy = 0;

# Long-lived scratch (one allocation each, reused per call)
var _p256_prod = 0;        # 512-bit (64 B) full-product scratch
var _p256_tmp1 = 0;        # 32 B scratch
var _p256_tmp2 = 0;        # 32 B scratch
var _p256_one  = 0;        # constant 1 (256-bit)

var _p256_inited = 0;

fn _p256_init(): i64 {
    if (_p256_inited == 1) { return 0; }
    _p256_p  = u256_from_hex("ffffffff00000001000000000000000000000000ffffffffffffffffffffffff");
    _p256_n  = u256_from_hex("ffffffff00000000ffffffffffffffffbce6faada7179e84f3b9cac2fc632551");
    _p256_b  = u256_from_hex("5ac635d8aa3a93e7b3ebbd55769886bc651d06b0cc53b0f63bce3c3e27d2604b");
    _p256_gx = u256_from_hex("6b17d1f2e12c4247f8bce6e563a440f277037d812deb33a0f4a13945d898c296");
    _p256_gy = u256_from_hex("4fe342e2fe1a7f9b8ee7eb4a7c0f9e162bce33576b315ececbb6406837bf51f5");
    _p256_prod = alloc(64);
    _p256_tmp1 = alloc(32);
    _p256_tmp2 = alloc(32);
    _p256_one  = u256_from(1);
    _p256_inited = 1;
    return 0;
}

# ================================================================
# Big-endian byte ⇄ u256 codec
#
# SEC 1 §2.3.5: integers are encoded most-significant-byte-first.
# This differs from Ed25519 (RFC 8032 little-endian) so we cannot
# reuse `u256_load_le` from `bigint_ext.cyr` — the byte order
# inverts. Defined here local to the P-256 module.
# ================================================================

# Load 32 big-endian bytes from src into dst as four LE i64 limbs.
fn u256_load_be(dst, src): i64 {
    var i = 0;
    while (i < 4) {
        # limb[i] (low → high) holds bytes [src + (3-i)*8 .. src + (3-i)*8 + 7]
        # where byte 0 of that range is the MSB of the limb.
        var off = (3 - i) * 8;
        store64(dst + i * 8,
        ((load8(src + off + 0) & 0xFF) << 56)
        | ((load8(src + off + 1) & 0xFF) << 48)
        | ((load8(src + off + 2) & 0xFF) << 40)
        | ((load8(src + off + 3) & 0xFF) << 32)
        | ((load8(src + off + 4) & 0xFF) << 24)
        | ((load8(src + off + 5) & 0xFF) << 16)
        | ((load8(src + off + 6) & 0xFF) << 8)
        | (load8(src + off + 7) & 0xFF));
        i = i + 1;
    }
    return 0;
}

# Store src (four LE i64 limbs) as 32 big-endian bytes at dst.
fn u256_store_be(dst, src): i64 {
    var i = 0;
    while (i < 4) {
        var off = (3 - i) * 8;
        var v = load64(src + i * 8);
        store8(dst + off + 0, (v >> 56) & 0xFF);
        store8(dst + off + 1, (v >> 48) & 0xFF);
        store8(dst + off + 2, (v >> 40) & 0xFF);
        store8(dst + off + 3, (v >> 32) & 0xFF);
        store8(dst + off + 4, (v >> 24) & 0xFF);
        store8(dst + off + 5, (v >> 16) & 0xFF);
        store8(dst + off + 6, (v >> 8) & 0xFF);
        store8(dst + off + 7, v & 0xFF);
        i = i + 1;
    }
    return 0;
}

# ================================================================
# Modular reduction mod p256 (or any 256-bit prime)
#
# Algorithm: textbook long-division.
#   R = 0
#   For each bit of val from bit 511 down to bit 0:
#       R = (R << 1) | bit
#       if R >= p, R -= p
#   Return R
#
# Each iteration runs on 256-bit values plus a single carry bit; the
# 257-bit transient (R = 2·prev_R + bit, which may exceed 2^256) is
# folded back via the identity:
#   (2^256 + R')  mod p  =  R' - p  mod 2^256     when R' < p
# i.e. when the carry bit is set, an unconditional `R -= p` realises
# the correct residue because the 256-bit unsigned wraparound supplies
# the missing +2^256 implicitly. After the conditional subtract,
# R < p again, restoring the loop invariant.
#
# 256 iterations × ~12 limb ops per iteration — slow but trivially
# correct. A Solinas word-level reduction is the natural follow-up
# optimisation for the 3.2.x cycle's bench tuning pass once the
# arithmetic surface is well-exercised by tests.
# ================================================================

# Process bits 255 .. 0 of `lo` into accumulator R (mod p),
# given an initial R that is already in [0, p). Used by both p256_reduce
# (val high half pre-loaded) and modular ops that need it directly.
var _p256_R = 0;

fn _p256_long_div_reduce(R, lo): i64 {
    var i = 255;
    while (i >= 0) {
        var byte_off = i / 8;
        var bit_off = i & 7;
        var bit = (load8(lo + byte_off) >> bit_off) & 1;

        var carry = u256_shl1(R, R);
        store64(R, load64(R) | bit);

        # Single conditional subtract covers both branches:
        #   • carry == 1 → V ∈ [2^256, 2p), V - p ∈ [2^256 - p, p), always valid
        #   • carry == 0, R >= p → standard reduce
        # When carry == 1 the unsigned wraparound of R - p gives the correct
        # residue because the implied +2^256 cancels.
        if (carry == 1) {
            u256_sub(R, R, _p256_p);
        } else {
            if (u256_cmp(R, _p256_p) >= 0) { u256_sub(R, R, _p256_p); }
        }
        i = i - 1;
    }
    return 0;
}

# r = val mod p256 (val is 512-bit, r is 256-bit)
fn p256_reduce(out, val): i64 {
    _p256_init();
    if (_p256_R == 0) { _p256_R = alloc(32); }

    # Initialise R = high half of val, pre-reduce if R >= p.
    store64(_p256_R + 0, load64(val + 32));
    store64(_p256_R + 8, load64(val + 40));
    store64(_p256_R + 16, load64(val + 48));
    store64(_p256_R + 24, load64(val + 56));
    if (u256_cmp(_p256_R, _p256_p) >= 0) { u256_sub(_p256_R, _p256_R, _p256_p); }

    _p256_long_div_reduce(_p256_R, val);
    u256_copy(out, _p256_R);
    return 0;
}

# ================================================================
# Field arithmetic mod p256
# ================================================================

# r = (a + b) mod p
fn fp_p256_add(r, a, b): i64 {
    _p256_init();
    var carry = u256_add(r, a, b);
    # If a 257-bit carry occurred, treat as (R + 2^256) and subtract p
    # (same trick as the long-division reduce: u256_sub wraparound
    # supplies the implicit +2^256). After: r < 2^256 always.
    if (carry == 1) {
        u256_sub(r, r, _p256_p);
    }
    if (u256_cmp(r, _p256_p) >= 0) { u256_sub(r, r, _p256_p); }
    return 0;
}

# r = (a - b) mod p (handles underflow by adding p)
fn fp_p256_sub(r, a, b): i64 {
    _p256_init();
    var borrow = u256_sub(r, a, b);
    if (borrow > 0) { u256_add(r, r, _p256_p); }
    return 0;
}

# r = (-a) mod p
fn fp_p256_neg(r, a): i64 {
    _p256_init();
    if (u256_is_zero(a) == 1) { u256_copy(r, a); return 0; }
    u256_sub(r, _p256_p, a);
    return 0;
}

# r = (a * b) mod p
fn fp_p256_mul(r, a, b): i64 {
    _p256_init();
    u256_mul_full(_p256_prod, a, b);
    p256_reduce(r, _p256_prod);
    return 0;
}

# r = a^2 mod p
fn fp_p256_sq(r, a): i64 {
    return fp_p256_mul(r, a, a);
}

# ================================================================
# Affine public-key validation — closes audit 2026-05-21 LOW-1.
#
# Verify that (x, y) satisfies the P-256 curve equation:
#     y^2 ≡ x^3 - 3*x + b  (mod p)
# and that both coordinates are in the field [0, p). Rejects the
# point at infinity ((0, 0) treated as such here per SEC 1 §3.2.2),
# off-curve points (invalid-curve attack, Bos et al. 2014), and
# coordinates outside the canonical range.
#
# Returns 1 if (x, y) is a valid affine point on P-256, 0 otherwise.
# x and y are 32-byte LE u256 limb buffers (the post-load_be form).
# ================================================================

var _onc_lhs = 0;
var _onc_rhs = 0;
var _onc_tmp = 0;
var _onc_three_x = 0;
var _onc_inited = 0;

fn _onc_init(): i64 {
    if (_onc_inited == 1) { return 0; }
    _p256_init();
    _onc_lhs = alloc(32);
    _onc_rhs = alloc(32);
    _onc_tmp = alloc(32);
    _onc_three_x = alloc(32);
    _onc_inited = 1;
    return 0;
}

fn pt_is_on_curve(x, y): i64 {
    _onc_init();
    # Range check: 0 ≤ x < p and 0 ≤ y < p.
    if (u256_cmp(x, _p256_p) >= 0) { return 0; }
    if (u256_cmp(y, _p256_p) >= 0) { return 0; }
    # Reject point at infinity (encoded as (0, 0) in affine).
    if (u256_is_zero(x) == 1) {
        if (u256_is_zero(y) == 1) { return 0; }
    }
    # lhs = y^2
    fp_p256_sq(_onc_lhs, y);
    # rhs = x^3 - 3x + b
    fp_p256_sq(_onc_tmp, x);
    fp_p256_mul(_onc_rhs, _onc_tmp, x);
    fp_p256_add(_onc_tmp, x, x);
    fp_p256_add(_onc_three_x, _onc_tmp, x);
    fp_p256_sub(_onc_rhs, _onc_rhs, _onc_three_x);
    fp_p256_add(_onc_rhs, _onc_rhs, _p256_b);
    if (u256_eq(_onc_lhs, _onc_rhs) == 1) { return 1; }
    return 0;
}

# ================================================================
# Modular inversion: r = a^(p-2) mod p (Fermat's little theorem)
#
# Generic square-and-multiply over the 256-bit exponent p-2.
# Cost: 256 squarings + ~128 multiplies (Hamming weight of p-2 ≈ 128).
# An addition-chain optimisation (à la `fp_inv` in `bigint_ext.cyr`)
# can drop this to ~265 muls; deferred to the 3.2.x bench-tuning
# pass once verify is end-to-end green.
# ================================================================

var _p256_inv_tmp = 0;
var _p256_inv_res = 0;
var _p256_inv_base = 0;
var _p256_inv_exp = 0;     # p-2, precomputed
var _p256_inv_inited = 0;

fn _p256_inv_init(): i64 {
    if (_p256_inv_inited == 1) { return 0; }
    _p256_init();
    _p256_inv_tmp  = alloc(32);
    _p256_inv_res  = alloc(32);
    _p256_inv_base = alloc(32);
    _p256_inv_exp  = u256_clone(_p256_p);
    # exp = p - 2
    store64(_p256_inv_exp, load64(_p256_inv_exp) - 2);
    _p256_inv_inited = 1;
    return 0;
}

# r = a^(-1) mod p. If a == 0 the result is 0 (caller's responsibility
# to check; ECDSA verify already gates on s != 0).
fn fp_p256_inv(r, a): i64 {
    _p256_inv_init();
    # res = 1
    store64(_p256_inv_res + 0, 1);
    store64(_p256_inv_res + 8, 0);
    store64(_p256_inv_res + 16, 0);
    store64(_p256_inv_res + 24, 0);
    u256_copy(_p256_inv_base, a);

    var i = 0;
    while (i < 256) {
        var limb_idx = i / 64;
        var bit_idx  = i & 63;
        var bit = (load64(_p256_inv_exp + limb_idx * 8) >> bit_idx) & 1;
        if (bit == 1) {
            fp_p256_mul(_p256_inv_tmp, _p256_inv_res, _p256_inv_base);
            u256_copy(_p256_inv_res, _p256_inv_tmp);
        }
        fp_p256_sq(_p256_inv_tmp, _p256_inv_base);
        u256_copy(_p256_inv_base, _p256_inv_tmp);
        i = i + 1;
    }
    u256_copy(r, _p256_inv_res);
    return 0;
}

# ================================================================
# Scalar field arithmetic mod n (group order)
#
# Same long-division reduction as the field, but parameterised on
# `_p256_n` instead of `_p256_p`. ECDSA verify needs:
#   • reduce e (the SHA-256 message digest) mod n
#   • r, s ∈ [1, n-1] range checks (no reduction needed)
#   • s^(-1) mod n
#   • u1 = e * s^(-1) mod n, u2 = r * s^(-1) mod n
# ================================================================

var _p256_n_R = 0;

fn _p256_long_div_reduce_n(R, lo): i64 {
    var i = 255;
    while (i >= 0) {
        var byte_off = i / 8;
        var bit_off = i & 7;
        var bit = (load8(lo + byte_off) >> bit_off) & 1;

        var carry = u256_shl1(R, R);
        store64(R, load64(R) | bit);

        if (carry == 1) {
            u256_sub(R, R, _p256_n);
        } else {
            if (u256_cmp(R, _p256_n) >= 0) { u256_sub(R, R, _p256_n); }
        }
        i = i - 1;
    }
    return 0;
}

# r = val mod n (val is 512-bit, r is 256-bit)
fn n_reduce(out, val): i64 {
    _p256_init();
    if (_p256_n_R == 0) { _p256_n_R = alloc(32); }
    store64(_p256_n_R + 0, load64(val + 32));
    store64(_p256_n_R + 8, load64(val + 40));
    store64(_p256_n_R + 16, load64(val + 48));
    store64(_p256_n_R + 24, load64(val + 56));
    if (u256_cmp(_p256_n_R, _p256_n) >= 0) { u256_sub(_p256_n_R, _p256_n_R, _p256_n); }
    _p256_long_div_reduce_n(_p256_n_R, val);
    u256_copy(out, _p256_n_R);
    return 0;
}

# r = a mod n for a 256-bit `a` (avoid full 512-bit reduce when not needed).
fn fn_p256_reduce256(out, a): i64 {
    _p256_init();
    u256_copy(out, a);
    if (u256_cmp(out, _p256_n) >= 0) { u256_sub(out, out, _p256_n); }
    return 0;
}

# r = (a * b) mod n
var _p256_n_prod = 0;

fn fn_p256_mul(r, a, b): i64 {
    _p256_init();
    if (_p256_n_prod == 0) { _p256_n_prod = alloc(64); }
    u256_mul_full(_p256_n_prod, a, b);
    n_reduce(r, _p256_n_prod);
    return 0;
}

# r = a^(-1) mod n (Fermat: a^(n-2) mod n).
var _p256_ninv_tmp = 0;
var _p256_ninv_res = 0;
var _p256_ninv_base = 0;
var _p256_ninv_exp = 0;
var _p256_ninv_inited = 0;

fn _p256_ninv_init(): i64 {
    if (_p256_ninv_inited == 1) { return 0; }
    _p256_init();
    _p256_ninv_tmp  = alloc(32);
    _p256_ninv_res  = alloc(32);
    _p256_ninv_base = alloc(32);
    _p256_ninv_exp  = u256_clone(_p256_n);
    store64(_p256_ninv_exp, load64(_p256_ninv_exp) - 2);
    _p256_ninv_inited = 1;
    return 0;
}

fn fn_p256_inv(r, a): i64 {
    _p256_ninv_init();
    store64(_p256_ninv_res + 0, 1);
    store64(_p256_ninv_res + 8, 0);
    store64(_p256_ninv_res + 16, 0);
    store64(_p256_ninv_res + 24, 0);
    u256_copy(_p256_ninv_base, a);

    var i = 0;
    while (i < 256) {
        var limb_idx = i / 64;
        var bit_idx  = i & 63;
        var bit = (load64(_p256_ninv_exp + limb_idx * 8) >> bit_idx) & 1;
        if (bit == 1) {
            fn_p256_mul(_p256_ninv_tmp, _p256_ninv_res, _p256_ninv_base);
            u256_copy(_p256_ninv_res, _p256_ninv_tmp);
        }
        fn_p256_mul(_p256_ninv_tmp, _p256_ninv_base, _p256_ninv_base);
        u256_copy(_p256_ninv_base, _p256_ninv_tmp);
        i = i + 1;
    }
    u256_copy(r, _p256_ninv_res);
    return 0;
}

# ================================================================
# Jacobian point arithmetic on P-256
#
# Representation: 96 bytes per point — concatenation of X, Y, Z (each
# 32 B, little-endian limbs). Affine (x, y) = (X/Z^2, Y/Z^3) for Z≠0;
# Z == 0 represents the point at infinity (identity element).
#
# Formulas: explicit-formulas-database "dbl-2001-b" (for a=-3) and
# "add-2007-bl" (general affine + Jacobian add). 4M+4S for double,
# 12M+4S for add — matches openssl/ec/ecp_nistz256.c reference.
# ================================================================

# Field offsets within a 96-byte point.
fn _pt_x(p): i64 { return p; }
fn _pt_y(p): i64 { return p + 32; }
fn _pt_z(p): i64 { return p + 64; }

# Allocate a fresh point (zeroed; represents point at infinity).
fn pt_alloc(): i64 {
    var p = alloc(96);
    memset(p, 0, 96);
    return p;
}

fn pt_set_infinity(p): i64 {
    memset(p, 0, 96);
    return 0;
}

fn pt_is_infinity(p): i64 {
    if (u256_is_zero(_pt_z(p)) == 1) { return 1; }
    return 0;
}

fn pt_copy(dst, src): i64 {
    memcpy(dst, src, 96);
    return 0;
}

# Constant-time conditional swap of two 96-byte points.
#   if swap == 1: a <-> b
#   if swap == 0: no change
# No branches on point data. (swap itself is treated as public — it
# is derived from the public scalar bits during Montgomery-ladder
# scalar multiplication.)
fn pt_cswap(swap, a, b): i64 {
    var mask = 0 - swap;     # 0 or 0xFF..FF
    var i = 0;
    while (i < 12) {         # 12 × 8 bytes = 96
        var av = load64(a + i * 8);
        var bv = load64(b + i * 8);
        var t  = mask & (av ^ bv);
        store64(a + i * 8, av ^ t);
        store64(b + i * 8, bv ^ t);
        i = i + 1;
    }
    return 0;
}

# Load an affine point (x, y) into Jacobian (x, y, 1).
fn pt_from_affine(p, x, y): i64 {
    u256_copy(_pt_x(p), x);
    u256_copy(_pt_y(p), y);
    store64(_pt_z(p) + 0, 1);
    store64(_pt_z(p) + 8, 0);
    store64(_pt_z(p) + 16, 0);
    store64(_pt_z(p) + 24, 0);
    return 0;
}

# Convert Jacobian → affine. Out_x, out_y receive the affine coords.
# Returns 0 if p is the point at infinity (no inverse), 1 otherwise.
var _pt_aff_zinv  = 0;
var _pt_aff_zinv2 = 0;
var _pt_aff_zinv3 = 0;

fn pt_to_affine(out_x, out_y, p): i64 {
    if (pt_is_infinity(p) == 1) { return 0; }
    if (_pt_aff_zinv  == 0) { _pt_aff_zinv  = alloc(32); }
    if (_pt_aff_zinv2 == 0) { _pt_aff_zinv2 = alloc(32); }
    if (_pt_aff_zinv3 == 0) { _pt_aff_zinv3 = alloc(32); }

    fp_p256_inv(_pt_aff_zinv, _pt_z(p));
    fp_p256_sq(_pt_aff_zinv2, _pt_aff_zinv);
    fp_p256_mul(_pt_aff_zinv3, _pt_aff_zinv2, _pt_aff_zinv);
    fp_p256_mul(out_x, _pt_x(p), _pt_aff_zinv2);
    fp_p256_mul(out_y, _pt_y(p), _pt_aff_zinv3);
    return 1;
}

# ----------------------------------------------------------------
# Point doubling — Jacobian, a = -3
# Source: explicit-formulas-database dbl-2001-b
#   delta = Z^2
#   gamma = Y^2
#   beta  = X * gamma
#   alpha = 3 * (X - delta) * (X + delta)         (uses a = -3)
#   X3 = alpha^2 - 8*beta
#   Z3 = (Y + Z)^2 - gamma - delta
#   Y3 = alpha * (4*beta - X3) - 8 * gamma^2
# ----------------------------------------------------------------

var _ptd_delta = 0;
var _ptd_gamma = 0;
var _ptd_beta  = 0;
var _ptd_alpha = 0;
var _ptd_t1    = 0;
var _ptd_t2    = 0;
var _ptd_x3    = 0;
var _ptd_y3    = 0;
var _ptd_z3    = 0;
var _ptd_inited = 0;

fn _ptd_init(): i64 {
    if (_ptd_inited == 1) { return 0; }
    _ptd_delta = alloc(32);
    _ptd_gamma = alloc(32);
    _ptd_beta  = alloc(32);
    _ptd_alpha = alloc(32);
    _ptd_t1    = alloc(32);
    _ptd_t2    = alloc(32);
    _ptd_x3    = alloc(32);
    _ptd_y3    = alloc(32);
    _ptd_z3    = alloc(32);
    _ptd_inited = 1;
    return 0;
}

fn pt_double(out, p): i64 {
    _p256_init();
    _ptd_init();
    if (pt_is_infinity(p) == 1) { pt_set_infinity(out); return 0; }

    # delta = Z^2
    fp_p256_sq(_ptd_delta, _pt_z(p));
    # gamma = Y^2
    fp_p256_sq(_ptd_gamma, _pt_y(p));
    # beta = X * gamma
    fp_p256_mul(_ptd_beta, _pt_x(p), _ptd_gamma);

    # alpha = 3 * (X - delta) * (X + delta)
    fp_p256_sub(_ptd_t1, _pt_x(p), _ptd_delta);
    fp_p256_add(_ptd_t2, _pt_x(p), _ptd_delta);
    fp_p256_mul(_ptd_alpha, _ptd_t1, _ptd_t2);
    # alpha = 3*alpha
    fp_p256_add(_ptd_t1, _ptd_alpha, _ptd_alpha);
    fp_p256_add(_ptd_alpha, _ptd_t1, _ptd_alpha);

    # X3 = alpha^2 - 8*beta
    fp_p256_sq(_ptd_x3, _ptd_alpha);
    # 8*beta
    fp_p256_add(_ptd_t1, _ptd_beta, _ptd_beta);      # 2*beta
    fp_p256_add(_ptd_t1, _ptd_t1, _ptd_t1);          # 4*beta
    fp_p256_add(_ptd_t2, _ptd_t1, _ptd_t1);          # 8*beta
    fp_p256_sub(_ptd_x3, _ptd_x3, _ptd_t2);

    # Z3 = (Y + Z)^2 - gamma - delta
    fp_p256_add(_ptd_t1, _pt_y(p), _pt_z(p));
    fp_p256_sq(_ptd_z3, _ptd_t1);
    fp_p256_sub(_ptd_z3, _ptd_z3, _ptd_gamma);
    fp_p256_sub(_ptd_z3, _ptd_z3, _ptd_delta);

    # Y3 = alpha * (4*beta - X3) - 8 * gamma^2
    fp_p256_add(_ptd_t1, _ptd_beta, _ptd_beta);      # 2*beta
    fp_p256_add(_ptd_t1, _ptd_t1, _ptd_t1);          # 4*beta
    fp_p256_sub(_ptd_t1, _ptd_t1, _ptd_x3);          # 4*beta - X3
    fp_p256_mul(_ptd_y3, _ptd_alpha, _ptd_t1);
    fp_p256_sq(_ptd_t2, _ptd_gamma);                 # gamma^2
    fp_p256_add(_ptd_t1, _ptd_t2, _ptd_t2);          # 2*gamma^2
    fp_p256_add(_ptd_t1, _ptd_t1, _ptd_t1);          # 4*gamma^2
    fp_p256_add(_ptd_t1, _ptd_t1, _ptd_t1);          # 8*gamma^2
    fp_p256_sub(_ptd_y3, _ptd_y3, _ptd_t1);

    u256_copy(_pt_x(out), _ptd_x3);
    u256_copy(_pt_y(out), _ptd_y3);
    u256_copy(_pt_z(out), _ptd_z3);
    return 0;
}

# ----------------------------------------------------------------
# Point addition — Jacobian P + Q
# Source: explicit-formulas-database add-2007-bl
#   Z1Z1 = Z1^2,  Z2Z2 = Z2^2
#   U1 = X1 * Z2Z2,  U2 = X2 * Z1Z1
#   S1 = Y1 * Z2 * Z2Z2,  S2 = Y2 * Z1 * Z1Z1
#   H  = U2 - U1
#   I  = (2H)^2,  J = H * I
#   r  = 2*(S2 - S1)
#   V  = U1 * I
#   X3 = r^2 - J - 2V
#   Y3 = r * (V - X3) - 2 * S1 * J
#   Z3 = ((Z1 + Z2)^2 - Z1Z1 - Z2Z2) * H
#
# Handles all special cases: P=O → out=Q, Q=O → out=P, P=Q → double,
# P=-Q → infinity.
# ----------------------------------------------------------------

var _pta_z1z1 = 0;
var _pta_z2z2 = 0;
var _pta_u1   = 0;
var _pta_u2   = 0;
var _pta_s1   = 0;
var _pta_s2   = 0;
var _pta_h    = 0;
var _pta_i    = 0;
var _pta_j    = 0;
var _pta_r    = 0;
var _pta_v    = 0;
var _pta_t1   = 0;
var _pta_t2   = 0;
var _pta_x3   = 0;
var _pta_y3   = 0;
var _pta_z3   = 0;
var _pta_inited = 0;

fn _pta_init(): i64 {
    if (_pta_inited == 1) { return 0; }
    _pta_z1z1 = alloc(32);
    _pta_z2z2 = alloc(32);
    _pta_u1   = alloc(32);
    _pta_u2   = alloc(32);
    _pta_s1   = alloc(32);
    _pta_s2   = alloc(32);
    _pta_h    = alloc(32);
    _pta_i    = alloc(32);
    _pta_j    = alloc(32);
    _pta_r    = alloc(32);
    _pta_v    = alloc(32);
    _pta_t1   = alloc(32);
    _pta_t2   = alloc(32);
    _pta_x3   = alloc(32);
    _pta_y3   = alloc(32);
    _pta_z3   = alloc(32);
    _pta_inited = 1;
    return 0;
}

fn pt_add(out, p, q): i64 {
    _p256_init();
    _pta_init();

    if (pt_is_infinity(p) == 1) { pt_copy(out, q); return 0; }
    if (pt_is_infinity(q) == 1) { pt_copy(out, p); return 0; }

    # Z1Z1, Z2Z2
    fp_p256_sq(_pta_z1z1, _pt_z(p));
    fp_p256_sq(_pta_z2z2, _pt_z(q));

    # U1 = X1 * Z2Z2; U2 = X2 * Z1Z1
    fp_p256_mul(_pta_u1, _pt_x(p), _pta_z2z2);
    fp_p256_mul(_pta_u2, _pt_x(q), _pta_z1z1);

    # S1 = Y1 * Z2 * Z2Z2; S2 = Y2 * Z1 * Z1Z1
    fp_p256_mul(_pta_t1, _pt_z(q), _pta_z2z2);
    fp_p256_mul(_pta_s1, _pt_y(p), _pta_t1);
    fp_p256_mul(_pta_t1, _pt_z(p), _pta_z1z1);
    fp_p256_mul(_pta_s2, _pt_y(q), _pta_t1);

    # H = U2 - U1
    fp_p256_sub(_pta_h, _pta_u2, _pta_u1);

    # If H == 0: either P == Q (double) or P == -Q (infinity).
    if (u256_is_zero(_pta_h) == 1) {
        if (u256_eq(_pta_s1, _pta_s2) == 1) {
            return pt_double(out, p);
        } else {
            pt_set_infinity(out);
            return 0;
        }
    }

    # I = (2H)^2
    fp_p256_add(_pta_t1, _pta_h, _pta_h);            # 2H
    fp_p256_sq(_pta_i, _pta_t1);
    # J = H * I
    fp_p256_mul(_pta_j, _pta_h, _pta_i);
    # r = 2 * (S2 - S1)
    fp_p256_sub(_pta_t1, _pta_s2, _pta_s1);
    fp_p256_add(_pta_r, _pta_t1, _pta_t1);
    # V = U1 * I
    fp_p256_mul(_pta_v, _pta_u1, _pta_i);

    # X3 = r^2 - J - 2V
    fp_p256_sq(_pta_x3, _pta_r);
    fp_p256_sub(_pta_x3, _pta_x3, _pta_j);
    fp_p256_add(_pta_t1, _pta_v, _pta_v);            # 2V
    fp_p256_sub(_pta_x3, _pta_x3, _pta_t1);

    # Y3 = r * (V - X3) - 2 * S1 * J
    fp_p256_sub(_pta_t1, _pta_v, _pta_x3);
    fp_p256_mul(_pta_y3, _pta_r, _pta_t1);
    fp_p256_mul(_pta_t1, _pta_s1, _pta_j);
    fp_p256_add(_pta_t2, _pta_t1, _pta_t1);          # 2*S1*J
    fp_p256_sub(_pta_y3, _pta_y3, _pta_t2);

    # Z3 = ((Z1 + Z2)^2 - Z1Z1 - Z2Z2) * H
    fp_p256_add(_pta_t1, _pt_z(p), _pt_z(q));
    fp_p256_sq(_pta_t2, _pta_t1);
    fp_p256_sub(_pta_t2, _pta_t2, _pta_z1z1);
    fp_p256_sub(_pta_t2, _pta_t2, _pta_z2z2);
    fp_p256_mul(_pta_z3, _pta_t2, _pta_h);

    u256_copy(_pt_x(out), _pta_x3);
    u256_copy(_pt_y(out), _pta_y3);
    u256_copy(_pt_z(out), _pta_z3);
    return 0;
}

# ----------------------------------------------------------------
# Constant-time scalar multiplication via Montgomery ladder.
#   R0 = O, R1 = P, prev = 0
#   for i = 255 .. 0:
#       bit = scalar bit i
#       cswap(R0, R1, prev XOR bit)   # bring "double target" to R0
#       R1 = R0 + R1
#       R0 = 2 * R0
#       prev = bit
#   cswap(R0, R1, prev)               # final unswap
#   return R0
#
# Branches only on public swap masks; field/point ops always run in
# fixed sequence. Defense-in-depth: ECDSA verify inputs are public,
# but any future sign / DH path through this primitive inherits the
# constant-time behaviour for free.
# ----------------------------------------------------------------

var _ptm_r0 = 0;
var _ptm_r1 = 0;
var _ptm_sum = 0;
var _ptm_dbl = 0;
var _ptm_scalar = 0;
var _ptm_inited = 0;

fn _ptm_init(): i64 {
    if (_ptm_inited == 1) { return 0; }
    _ptm_r0 = pt_alloc();
    _ptm_r1 = pt_alloc();
    _ptm_sum = pt_alloc();
    _ptm_dbl = pt_alloc();
    _ptm_inited = 1;
    return 0;
}

# out = k * P, where k is a 256-bit scalar (LE limbs) and P is Jacobian.
fn pt_scalarmul(out, k, P): i64 {
    _p256_init();
    _ptm_init();

    pt_set_infinity(_ptm_r0);
    pt_copy(_ptm_r1, P);

    _ptm_scalar = k;
    var prev = 0;
    var i = 255;
    while (i >= 0) {
        var limb_idx = i / 64;
        var bit_idx  = i & 63;
        var bit = (load64(_ptm_scalar + limb_idx * 8) >> bit_idx) & 1;
        var swap = prev ^ bit;
        pt_cswap(swap, _ptm_r0, _ptm_r1);

        pt_add(_ptm_sum, _ptm_r0, _ptm_r1);
        pt_double(_ptm_dbl, _ptm_r0);
        pt_copy(_ptm_r1, _ptm_sum);
        pt_copy(_ptm_r0, _ptm_dbl);

        prev = bit;
        i = i - 1;
    }
    pt_cswap(prev, _ptm_r0, _ptm_r1);
    pt_copy(out, _ptm_r0);
    return 0;
}

# ================================================================
# ECDSA verify (SEC 1 v2.0 §4.1.4 / FIPS 186-5 §6.4.2)
#
# Inputs:
#   pk    — 64 bytes, Qx || Qy (big-endian)
#   msg   — message bytes (caller has not yet hashed)
#   sig   — 64 bytes, r || s   (big-endian)
#
# Algorithm:
#   1. Verify r, s ∈ [1, n-1].
#   2. e = leftmost 256 bits of SHA-256(msg) — for P-256 this is the
#      full digest; reduce mod n.
#   3. w = s^(-1) mod n
#   4. u1 = e*w mod n,  u2 = r*w mod n
#   5. R = u1*G + u2*Q  (Jacobian, then to affine)
#   6. If R is the point at infinity, reject.
#   7. v = Rx mod n. Accept iff v == r.
# ================================================================

var _ecv_e        = 0;
var _ecv_r        = 0;
var _ecv_s        = 0;
var _ecv_w        = 0;
var _ecv_u1       = 0;
var _ecv_u2       = 0;
var _ecv_qx       = 0;
var _ecv_qy       = 0;
var _ecv_digest   = 0;
var _ecv_digest_padded = 0;
var _ecv_P_u1G    = 0;
var _ecv_P_u2Q    = 0;
var _ecv_R        = 0;
var _ecv_Rx       = 0;
var _ecv_Ry       = 0;
var _ecv_Rx_modn  = 0;
var _ecv_G        = 0;
var _ecv_Q        = 0;
var _ecv_inited   = 0;

fn _ecv_init(): i64 {
    if (_ecv_inited == 1) { return 0; }
    _p256_init();
    _ecv_e        = alloc(32);
    _ecv_r        = alloc(32);
    _ecv_s        = alloc(32);
    _ecv_w        = alloc(32);
    _ecv_u1       = alloc(32);
    _ecv_u2       = alloc(32);
    _ecv_qx       = alloc(32);
    _ecv_qy       = alloc(32);
    _ecv_digest   = alloc(32);
    _ecv_digest_padded = alloc(64);
    _ecv_P_u1G    = pt_alloc();
    _ecv_P_u2Q    = pt_alloc();
    _ecv_R        = pt_alloc();
    _ecv_Rx       = alloc(32);
    _ecv_Ry       = alloc(32);
    _ecv_Rx_modn  = alloc(32);
    _ecv_G        = pt_alloc();
    _ecv_Q        = pt_alloc();
    pt_from_affine(_ecv_G, _p256_gx, _p256_gy);
    _ecv_inited = 1;
    return 0;
}

# Public entry. Returns 1 on valid, 0 on invalid.
fn ecdsa_p256_verify(pk, msg, msg_len, sig): i64 {
    _ecv_init();

    # 1. Decode r, s from sig (big-endian).
    u256_load_be(_ecv_r, sig);
    u256_load_be(_ecv_s, sig + 32);

    # Range check r, s ∈ [1, n-1].
    if (u256_is_zero(_ecv_r) == 1) { return 0; }
    if (u256_is_zero(_ecv_s) == 1) { return 0; }
    if (u256_cmp(_ecv_r, _p256_n) >= 0) { return 0; }
    if (u256_cmp(_ecv_s, _p256_n) >= 0) { return 0; }

    # 2. Decode Q from pk and validate it is on the curve.
    # Closes audit 2026-05-21 LOW-1 (invalid-curve attack — Bos et al.
    # 2014). pt_is_on_curve also rejects (0,0) and out-of-range
    # coordinates so the prior explicit checks are subsumed.
    u256_load_be(_ecv_qx, pk);
    u256_load_be(_ecv_qy, pk + 32);
    if (pt_is_on_curve(_ecv_qx, _ecv_qy) == 0) { return 0; }
    pt_from_affine(_ecv_Q, _ecv_qx, _ecv_qy);

    # 3. e = SHA-256(msg) mod n.
    sha256(msg, msg_len, _ecv_digest);
    # The digest is big-endian (SEC 1 §4.1.4 step 3). Load as BE int.
    u256_load_be(_ecv_e, _ecv_digest);
    if (u256_cmp(_ecv_e, _p256_n) >= 0) { u256_sub(_ecv_e, _ecv_e, _p256_n); }

    # 4. w = s^-1 mod n
    fn_p256_inv(_ecv_w, _ecv_s);

    # 5. u1 = e*w mod n, u2 = r*w mod n
    fn_p256_mul(_ecv_u1, _ecv_e, _ecv_w);
    fn_p256_mul(_ecv_u2, _ecv_r, _ecv_w);

    # 6. R = u1*G + u2*Q
    pt_scalarmul(_ecv_P_u1G, _ecv_u1, _ecv_G);
    pt_scalarmul(_ecv_P_u2Q, _ecv_u2, _ecv_Q);
    pt_add(_ecv_R, _ecv_P_u1G, _ecv_P_u2Q);

    if (pt_is_infinity(_ecv_R) == 1) { return 0; }

    # 7. v = Rx mod n; accept iff v == r.
    pt_to_affine(_ecv_Rx, _ecv_Ry, _ecv_R);
    fn_p256_reduce256(_ecv_Rx_modn, _ecv_Rx);
    if (u256_eq(_ecv_Rx_modn, _ecv_r) == 1) { return 1; }
    return 0;
}

# ================================================================
# DER signature decode wrapper
#
# X.509 / DER-encoded ECDSA signature shape:
#   SEQUENCE { INTEGER r, INTEGER s }
# Tag bytes: 0x30 (SEQUENCE), 0x02 (INTEGER).
# Each INTEGER may be 32 or 33 bytes (leading 0x00 if the MSB would
# otherwise set the sign bit). Short ints (< 32 bytes) are 0-padded
# on the left to 32 bytes for raw verify.
# ================================================================

# Decode one DER INTEGER starting at off into a 32-byte big-endian
# destination buffer. Returns the next offset on success, or -1 on
# any malformed input. `dst` must be 32 bytes; on success, contents
# are big-endian r/s value zero-padded on the left.
fn _ecdsa_der_int(src, off, src_len, dst): i64 {
    if (off + 2 > src_len) { return 0 - 1; }
    if ((load8(src + off) & 0xFF) != 0x02) { return 0 - 1; }
    var raw_len = load8(src + off + 1) & 0xFF;
    if (raw_len > 33) { return 0 - 1; }      # too long for P-256
    if (off + 2 + raw_len > src_len) { return 0 - 1; }

    var int_off = off + 2;
    var int_len = raw_len;
    # Strip a single leading 0x00 sign byte, if any. (DER requires it
    # when the next byte's high bit is set; we tolerate either.)
    if (raw_len == 33) {
        if ((load8(src + int_off) & 0xFF) != 0x00) { return 0 - 1; }
        int_off = int_off + 1;
        int_len = int_len - 1;
    }
    if (int_len > 32) { return 0 - 1; }

    # Left-pad with zeros into the 32-byte big-endian destination.
    memset(dst, 0, 32);
    var pad = 32 - int_len;
    var i = 0;
    while (i < int_len) {
        store8(dst + pad + i, load8(src + int_off + i) & 0xFF);
        i = i + 1;
    }
    return off + 2 + raw_len;   # consume the original encoded length
}

fn ecdsa_p256_verify_der(pk, msg, msg_len, sig_der, sig_der_len): i64 {
    if (sig_der_len < 8) { return 0; }
    if ((load8(sig_der) & 0xFF) != 0x30) { return 0; }
    var seq_len = load8(sig_der + 1) & 0xFF;
    if (seq_len >= 0x80) { return 0; }   # short-form length only (always under 71 bytes for P-256)
    if (2 + seq_len > sig_der_len) { return 0; }

    var raw_sig = alloc(64);
    var off = _ecdsa_der_int(sig_der, 2, sig_der_len, raw_sig);
    if (off < 0) { return 0; }
    off = _ecdsa_der_int(sig_der, off, sig_der_len, raw_sig + 32);
    if (off < 0) { return 0; }

    return ecdsa_p256_verify(pk, msg, msg_len, raw_sig);
}

# --- ecdsa_p384.cyr ---

# ecdsa_p384.cyr — ECDSA verify on NIST P-384 (secp384r1)
#
# Sigil 3.2.4 — bite 4 of the TEE attestation arc. Mirrors
# `src/ecdsa_p256.cyr` (3.2.1) at 384 bits. The structural shape is
# identical (constants → BE codec → reduction → field arithmetic →
# scalar field → Jacobian point ops → Montgomery-ladder scalar mul
# → verify); the only differences are the 6-limb (48-byte) value
# width and the curve constants.
#
# Surface:
#   fn ecdsa_p384_verify(pk, msg, msg_len, sig): i64
#       — pk: 96 bytes (Qx || Qy big-endian)
#       — sig: 96 bytes (r || s big-endian)
#       — msg-rep: SHA-384(msg), per FIPS 186-5 §6.4.2 step 3
#         with hash output L = field width
#   fn pt_p384_is_on_curve(x, y): i64
#       — affine curve-equation + in-field-range gate; same shape
#         as `pt_is_on_curve` for P-256.
#
# Implementation references:
#   • FIPS 186-5 §6 — ECDSA algorithm
#   • SEC 1 v2.0 §4.1.4 — verifying operation
#   • FIPS 186-4 D.1.2.4 / SP 800-186 — P-384 curve params
#
# All u384 helpers are private to this module. If 3.2.5 (TDX) or a
# future consumer needs P-384 arithmetic outside ECDSA, lift them
# into `lib/bigint.cyr` as `u384_*` analogues at that point.

# ================================================================
# Curve constants — initialised on first call via `_p384_init`.
# ================================================================

# Field prime p384 = 2^384 - 2^128 - 2^96 + 2^32 - 1
#   = FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFEFFFFFFFF0000000000000000FFFFFFFF
var _p384_p = 0;

# Group order n384
var _p384_n = 0;

# Curve coefficient b for y² = x³ - 3x + b
var _p384_b = 0;

# Base point G affine
var _p384_gx = 0;
var _p384_gy = 0;

# Long-lived scratch (init-time alloc, reused)
var _p384_prod = 0;        # 96-byte (768-bit) full-product
var _p384_tmp1 = 0;        # 48-byte
var _p384_tmp2 = 0;        # 48-byte
var _p384_one  = 0;

var _p384_inited = 0;

# ----------------------------------------------------------------
# u384 helpers — 6 × 64-bit LE limbs = 48 bytes
# ----------------------------------------------------------------

fn u384_zero(): i64 {
    var r = alloc(48);
    memset(r, 0, 48);
    return r;
}

fn u384_from(val): i64 {
    var r = alloc(48);
    memset(r, 0, 48);
    store64(r, val);
    return r;
}

fn u384_copy(dst, src): i64 {
    memcpy(dst, src, 48);
    return 0;
}

fn u384_clone(a): i64 {
    var r = alloc(48);
    memcpy(r, a, 48);
    return r;
}

fn u384_is_zero(a): i64 {
    var i = 0;
    while (i < 6) {
        if (load64(a + i * 8) != 0) { return 0; }
        i = i + 1;
    }
    return 1;
}

fn u384_eq(a, b): i64 {
    var i = 0;
    while (i < 6) {
        if (load64(a + i * 8) != load64(b + i * 8)) { return 0; }
        i = i + 1;
    }
    return 1;
}

# Returns 1 if a > b, -1 if a < b, 0 if equal (unsigned).
fn u384_cmp(a, b): i64 {
    var sbit = 1 << 63;
    var i = 5;
    while (i >= 0) {
        var al = load64(a + i * 8);
        var bl = load64(b + i * 8);
        var ax = al ^ sbit;
        var bx = bl ^ sbit;
        if (ax > bx) { return 1; }
        if (ax < bx) { return 0 - 1; }
        i = i - 1;
    }
    return 0;
}

# r = a + b mod 2^384; returns carry-out (0 or 1).
fn u384_add(r, a, b): i64 {
    var sbit = 1 << 63;
    var carry = 0;
    var i = 0;
    while (i < 6) {
        var av = load64(a + i * 8);
        var bv = load64(b + i * 8);
        var s1 = av + bv;
        var c1 = 0;
        if ((s1 ^ sbit) < (av ^ sbit)) { c1 = 1; }
        var s2 = s1 + carry;
        var c2 = 0;
        if ((s2 ^ sbit) < (s1 ^ sbit)) { c2 = 1; }
        store64(r + i * 8, s2);
        carry = c1 + c2;
        i = i + 1;
    }
    return carry;
}

# r = a - b mod 2^384; returns borrow-out (0 or 1).
fn u384_sub(r, a, b): i64 {
    var sbit = 1 << 63;
    var borrow = 0;
    var i = 0;
    while (i < 6) {
        var av = load64(a + i * 8);
        var bv = load64(b + i * 8);
        var nb = 0;
        if (borrow > 0) {
            if (bv == (0 - 1)) {
                nb = 1;
                store64(r + i * 8, av);
            } else {
                var bv2 = bv + 1;
                if ((bv2 ^ sbit) > (av ^ sbit)) { nb = 1; }
                store64(r + i * 8, av - bv2);
            }
        } else {
            if ((bv ^ sbit) > (av ^ sbit)) { nb = 1; }
            store64(r + i * 8, av - bv);
        }
        borrow = nb;
        i = i + 1;
    }
    return borrow;
}

# r = a << 1; returns MSB-out.
fn u384_shl1(r, a): i64 {
    var carry = 0;
    var i = 0;
    while (i < 6) {
        var v = load64(a + i * 8);
        store64(r + i * 8, (v << 1) | carry);
        carry = (v >> 63) & 1;
        i = i + 1;
    }
    return carry;
}

# 64×64 → 128 bit multiply (lo/hi via 32-bit halves).
var _p384_m64_lo = 0;
var _p384_m64_hi = 0;

fn _p384_mul64(a, b): i64 {
    var mask32 = 0xFFFFFFFF;
    var aL = a & mask32;
    var aH = (a >> 32) & mask32;
    var bL = b & mask32;
    var bH = (b >> 32) & mask32;
    var ll = aL * bL;
    var lh = aL * bH;
    var hl = aH * bL;
    var hh = aH * bH;
    var mid = lh + hl;
    var mid_carry = 0;
    if ((mid ^ (1 << 63)) < (lh ^ (1 << 63))) { mid_carry = 1; }
    var lo = ll + (mid << 32);
    var lo_carry = 0;
    if ((lo ^ (1 << 63)) < (ll ^ (1 << 63))) { lo_carry = 1; }
    _p384_m64_lo = lo;
    _p384_m64_hi = hh + (mid >> 32) + (mid_carry << 32) + lo_carry;
    return 0;
}

# Schoolbook 384×384 → 768-bit multiply.
# out: 96 bytes (12 limbs)
fn u384_mul_full(out, a, b): i64 {
    memset(out, 0, 96);
    var sbit = 1 << 63;
    var i = 0;
    while (i < 6) {
        var carry = 0;
        var j = 0;
        while (j < 6) {
            _p384_mul64(load64(a + i * 8), load64(b + j * 8));
            var k = i + j;
            var prev = load64(out + k * 8);
            var s1 = prev + _p384_m64_lo;
            var c1 = 0;
            if ((s1 ^ sbit) < (prev ^ sbit)) { c1 = 1; }
            var s2 = s1 + carry;
            var c2 = 0;
            if ((s2 ^ sbit) < (s1 ^ sbit)) { c2 = 1; }
            store64(out + k * 8, s2);
            carry = _p384_m64_hi + c1 + c2;
            j = j + 1;
        }
        if (i + 6 < 12) {
            store64(out + (i + 6) * 8, load64(out + (i + 6) * 8) + carry);
        }
        i = i + 1;
    }
    return 0;
}

# Parse a 96-char big-endian hex string into a 48-byte LE-limb buffer.
fn u384_from_hex(s): i64 {
    var r = u384_zero();
    var len = strlen(s);
    if (len > 96) { len = 96; }
    var i = 0;
    while (i < len) {
        # Shift left by 4 bits.
        var carry = 0;
        var li = 0;
        while (li < 6) {
            var v = load64(r + li * 8);
            store64(r + li * 8, (v << 4) | carry);
            carry = (v >> 60) & 0xF;
            li = li + 1;
        }
        var c = load8(s + i);
        var d = 0;
        if (c >= 48) { if (c <= 57) { d = c - 48; } }
        if (c >= 97) { if (c <= 102) { d = c - 87; } }
        if (c >= 65) { if (c <= 70) { d = c - 55; } }
        store64(r, load64(r) | d);
        i = i + 1;
    }
    return r;
}

# 48 BE bytes → 6 LE limbs.
fn u384_load_be(dst, src): i64 {
    var i = 0;
    while (i < 6) {
        var off = (5 - i) * 8;
        store64(dst + i * 8,
        ((load8(src + off + 0) & 0xFF) << 56)
        | ((load8(src + off + 1) & 0xFF) << 48)
        | ((load8(src + off + 2) & 0xFF) << 40)
        | ((load8(src + off + 3) & 0xFF) << 32)
        | ((load8(src + off + 4) & 0xFF) << 24)
        | ((load8(src + off + 5) & 0xFF) << 16)
        | ((load8(src + off + 6) & 0xFF) << 8)
        | (load8(src + off + 7) & 0xFF));
        i = i + 1;
    }
    return 0;
}

# 6 LE limbs → 48 BE bytes.
fn u384_store_be(dst, src): i64 {
    var i = 0;
    while (i < 6) {
        var off = (5 - i) * 8;
        var v = load64(src + i * 8);
        store8(dst + off + 0, (v >> 56) & 0xFF);
        store8(dst + off + 1, (v >> 48) & 0xFF);
        store8(dst + off + 2, (v >> 40) & 0xFF);
        store8(dst + off + 3, (v >> 32) & 0xFF);
        store8(dst + off + 4, (v >> 24) & 0xFF);
        store8(dst + off + 5, (v >> 16) & 0xFF);
        store8(dst + off + 6, (v >> 8) & 0xFF);
        store8(dst + off + 7, v & 0xFF);
        i = i + 1;
    }
    return 0;
}

# ----------------------------------------------------------------
# Initialisation
# ----------------------------------------------------------------

fn _p384_init(): i64 {
    if (_p384_inited == 1) { return 0; }
    _p384_p  = u384_from_hex(
        "fffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffeffffffff0000000000000000ffffffff");
    _p384_n  = u384_from_hex(
        "ffffffffffffffffffffffffffffffffffffffffffffffffc7634d81f4372ddf581a0db248b0a77aecec196accc52973");
    _p384_b  = u384_from_hex(
        "b3312fa7e23ee7e4988e056be3f82d19181d9c6efe8141120314088f5013875ac656398d8a2ed19d2a85c8edd3ec2aef");
    _p384_gx = u384_from_hex(
        "aa87ca22be8b05378eb1c71ef320ad746e1d3b628ba79b9859f741e082542a385502f25dbf55296c3a545e3872760ab7");
    _p384_gy = u384_from_hex(
        "3617de4a96262c6f5d9e98bf9292dc29f8f41dbd289a147ce9da3113b5f0b8c00a60b1ce1d7e819d7a431d7c90ea0e5f");
    _p384_prod = alloc(96);
    _p384_tmp1 = alloc(48);
    _p384_tmp2 = alloc(48);
    _p384_one  = u384_from(1);
    _p384_inited = 1;
    return 0;
}

# ================================================================
# Reduction mod p384 — textbook long-division (384 iterations of
# shl1 + conditional subtract). Same shape as `p256_reduce`; the
# carry-bit invariant analysis carries over (V = 2·R + bit < 2p,
# so one conditional subtract per iteration suffices). Slow but
# correct and easy to audit; Solinas word-level reduction is the
# bench-tuning follow-up tracked in roadmap.
# ================================================================

var _p384_R = 0;

fn _p384_long_div_reduce(R, lo): i64 {
    var i = 383;
    while (i >= 0) {
        var byte_off = i / 8;
        var bit_off = i & 7;
        var bit = (load8(lo + byte_off) >> bit_off) & 1;

        var carry = u384_shl1(R, R);
        store64(R, load64(R) | bit);

        if (carry == 1) {
            u384_sub(R, R, _p384_p);
        } else {
            if (u384_cmp(R, _p384_p) >= 0) { u384_sub(R, R, _p384_p); }
        }
        i = i - 1;
    }
    return 0;
}

# r = val mod p384 (val is 768-bit, r is 384-bit).
fn p384_reduce(out, val): i64 {
    _p384_init();
    if (_p384_R == 0) { _p384_R = alloc(48); }
    # R = high half of val
    memcpy(_p384_R, val + 48, 48);
    if (u384_cmp(_p384_R, _p384_p) >= 0) { u384_sub(_p384_R, _p384_R, _p384_p); }
    _p384_long_div_reduce(_p384_R, val);
    u384_copy(out, _p384_R);
    return 0;
}

# ================================================================
# Field arithmetic mod p384
# ================================================================

fn fp_p384_add(r, a, b): i64 {
    _p384_init();
    var carry = u384_add(r, a, b);
    if (carry == 1) { u384_sub(r, r, _p384_p); }
    if (u384_cmp(r, _p384_p) >= 0) { u384_sub(r, r, _p384_p); }
    return 0;
}

fn fp_p384_sub(r, a, b): i64 {
    _p384_init();
    var borrow = u384_sub(r, a, b);
    if (borrow > 0) { u384_add(r, r, _p384_p); }
    return 0;
}

fn fp_p384_neg(r, a): i64 {
    _p384_init();
    if (u384_is_zero(a) == 1) { u384_copy(r, a); return 0; }
    u384_sub(r, _p384_p, a);
    return 0;
}

fn fp_p384_mul(r, a, b): i64 {
    _p384_init();
    u384_mul_full(_p384_prod, a, b);
    p384_reduce(r, _p384_prod);
    return 0;
}

fn fp_p384_sq(r, a): i64 {
    return fp_p384_mul(r, a, a);
}

# Modular inversion via Fermat: a^(p-2) mod p.
var _p384_inv_tmp = 0;
var _p384_inv_res = 0;
var _p384_inv_base = 0;
var _p384_inv_exp = 0;
var _p384_inv_inited = 0;

fn _p384_inv_init(): i64 {
    if (_p384_inv_inited == 1) { return 0; }
    _p384_init();
    _p384_inv_tmp  = alloc(48);
    _p384_inv_res  = alloc(48);
    _p384_inv_base = alloc(48);
    _p384_inv_exp  = u384_clone(_p384_p);
    store64(_p384_inv_exp, load64(_p384_inv_exp) - 2);
    _p384_inv_inited = 1;
    return 0;
}

fn fp_p384_inv(r, a): i64 {
    _p384_inv_init();
    memset(_p384_inv_res, 0, 48);
    store64(_p384_inv_res, 1);
    u384_copy(_p384_inv_base, a);

    var i = 0;
    while (i < 384) {
        var limb_idx = i / 64;
        var bit_idx  = i & 63;
        var bit = (load64(_p384_inv_exp + limb_idx * 8) >> bit_idx) & 1;
        if (bit == 1) {
            fp_p384_mul(_p384_inv_tmp, _p384_inv_res, _p384_inv_base);
            u384_copy(_p384_inv_res, _p384_inv_tmp);
        }
        fp_p384_sq(_p384_inv_tmp, _p384_inv_base);
        u384_copy(_p384_inv_base, _p384_inv_tmp);
        i = i + 1;
    }
    u384_copy(r, _p384_inv_res);
    return 0;
}

# ================================================================
# Scalar field arithmetic mod n384
# ================================================================

var _p384_n_R = 0;

fn _p384_long_div_reduce_n(R, lo): i64 {
    var i = 383;
    while (i >= 0) {
        var byte_off = i / 8;
        var bit_off = i & 7;
        var bit = (load8(lo + byte_off) >> bit_off) & 1;
        var carry = u384_shl1(R, R);
        store64(R, load64(R) | bit);
        if (carry == 1) {
            u384_sub(R, R, _p384_n);
        } else {
            if (u384_cmp(R, _p384_n) >= 0) { u384_sub(R, R, _p384_n); }
        }
        i = i - 1;
    }
    return 0;
}

fn n384_reduce(out, val): i64 {
    _p384_init();
    if (_p384_n_R == 0) { _p384_n_R = alloc(48); }
    memcpy(_p384_n_R, val + 48, 48);
    if (u384_cmp(_p384_n_R, _p384_n) >= 0) { u384_sub(_p384_n_R, _p384_n_R, _p384_n); }
    _p384_long_div_reduce_n(_p384_n_R, val);
    u384_copy(out, _p384_n_R);
    return 0;
}

fn fn_p384_reduce384(out, a): i64 {
    _p384_init();
    u384_copy(out, a);
    if (u384_cmp(out, _p384_n) >= 0) { u384_sub(out, out, _p384_n); }
    return 0;
}

var _p384_n_prod = 0;

fn fn_p384_mul(r, a, b): i64 {
    _p384_init();
    if (_p384_n_prod == 0) { _p384_n_prod = alloc(96); }
    u384_mul_full(_p384_n_prod, a, b);
    n384_reduce(r, _p384_n_prod);
    return 0;
}

# r = a^-1 mod n via Fermat (a^(n-2) mod n).
var _p384_ninv_tmp = 0;
var _p384_ninv_res = 0;
var _p384_ninv_base = 0;
var _p384_ninv_exp = 0;
var _p384_ninv_inited = 0;

fn _p384_ninv_init(): i64 {
    if (_p384_ninv_inited == 1) { return 0; }
    _p384_init();
    _p384_ninv_tmp  = alloc(48);
    _p384_ninv_res  = alloc(48);
    _p384_ninv_base = alloc(48);
    _p384_ninv_exp  = u384_clone(_p384_n);
    store64(_p384_ninv_exp, load64(_p384_ninv_exp) - 2);
    _p384_ninv_inited = 1;
    return 0;
}

fn fn_p384_inv(r, a): i64 {
    _p384_ninv_init();
    memset(_p384_ninv_res, 0, 48);
    store64(_p384_ninv_res, 1);
    u384_copy(_p384_ninv_base, a);
    var i = 0;
    while (i < 384) {
        var limb_idx = i / 64;
        var bit_idx  = i & 63;
        var bit = (load64(_p384_ninv_exp + limb_idx * 8) >> bit_idx) & 1;
        if (bit == 1) {
            fn_p384_mul(_p384_ninv_tmp, _p384_ninv_res, _p384_ninv_base);
            u384_copy(_p384_ninv_res, _p384_ninv_tmp);
        }
        fn_p384_mul(_p384_ninv_tmp, _p384_ninv_base, _p384_ninv_base);
        u384_copy(_p384_ninv_base, _p384_ninv_tmp);
        i = i + 1;
    }
    u384_copy(r, _p384_ninv_res);
    return 0;
}

# ================================================================
# On-curve check
# ================================================================

var _onc384_lhs = 0;
var _onc384_rhs = 0;
var _onc384_tmp = 0;
var _onc384_three_x = 0;
var _onc384_inited = 0;

fn _onc384_init(): i64 {
    if (_onc384_inited == 1) { return 0; }
    _p384_init();
    _onc384_lhs = alloc(48);
    _onc384_rhs = alloc(48);
    _onc384_tmp = alloc(48);
    _onc384_three_x = alloc(48);
    _onc384_inited = 1;
    return 0;
}

fn pt_p384_is_on_curve(x, y): i64 {
    _onc384_init();
    if (u384_cmp(x, _p384_p) >= 0) { return 0; }
    if (u384_cmp(y, _p384_p) >= 0) { return 0; }
    if (u384_is_zero(x) == 1) {
        if (u384_is_zero(y) == 1) { return 0; }
    }
    fp_p384_sq(_onc384_lhs, y);
    fp_p384_sq(_onc384_tmp, x);
    fp_p384_mul(_onc384_rhs, _onc384_tmp, x);
    fp_p384_add(_onc384_tmp, x, x);
    fp_p384_add(_onc384_three_x, _onc384_tmp, x);
    fp_p384_sub(_onc384_rhs, _onc384_rhs, _onc384_three_x);
    fp_p384_add(_onc384_rhs, _onc384_rhs, _p384_b);
    if (u384_eq(_onc384_lhs, _onc384_rhs) == 1) { return 1; }
    return 0;
}

# ================================================================
# Jacobian point arithmetic on P-384
#
# Point representation: 144 bytes (X 48 || Y 48 || Z 48 of LE limbs).
# Z == 0 represents the point at infinity.
# Formulas: same EFD references as P-256 (dbl-2001-b for a=-3,
# add-2007-bl for general add).
# ================================================================

fn _pt384_x(p): i64 { return p; }
fn _pt384_y(p): i64 { return p + 48; }
fn _pt384_z(p): i64 { return p + 96; }

fn pt384_alloc(): i64 {
    var p = alloc(144);
    memset(p, 0, 144);
    return p;
}

fn pt384_set_infinity(p): i64 {
    memset(p, 0, 144);
    return 0;
}

fn pt384_is_infinity(p): i64 {
    if (u384_is_zero(_pt384_z(p)) == 1) { return 1; }
    return 0;
}

fn pt384_copy(dst, src): i64 {
    memcpy(dst, src, 144);
    return 0;
}

fn pt384_cswap(swap, a, b): i64 {
    var mask = 0 - swap;
    var i = 0;
    while (i < 18) {       # 18 × 8 bytes = 144
        var av = load64(a + i * 8);
        var bv = load64(b + i * 8);
        var t  = mask & (av ^ bv);
        store64(a + i * 8, av ^ t);
        store64(b + i * 8, bv ^ t);
        i = i + 1;
    }
    return 0;
}

fn pt384_from_affine(p, x, y): i64 {
    u384_copy(_pt384_x(p), x);
    u384_copy(_pt384_y(p), y);
    memset(_pt384_z(p), 0, 48);
    store64(_pt384_z(p), 1);
    return 0;
}

var _pt384_aff_zinv  = 0;
var _pt384_aff_zinv2 = 0;
var _pt384_aff_zinv3 = 0;

fn pt384_to_affine(out_x, out_y, p): i64 {
    if (pt384_is_infinity(p) == 1) { return 0; }
    if (_pt384_aff_zinv  == 0) { _pt384_aff_zinv  = alloc(48); }
    if (_pt384_aff_zinv2 == 0) { _pt384_aff_zinv2 = alloc(48); }
    if (_pt384_aff_zinv3 == 0) { _pt384_aff_zinv3 = alloc(48); }
    fp_p384_inv(_pt384_aff_zinv, _pt384_z(p));
    fp_p384_sq(_pt384_aff_zinv2, _pt384_aff_zinv);
    fp_p384_mul(_pt384_aff_zinv3, _pt384_aff_zinv2, _pt384_aff_zinv);
    fp_p384_mul(out_x, _pt384_x(p), _pt384_aff_zinv2);
    fp_p384_mul(out_y, _pt384_y(p), _pt384_aff_zinv3);
    return 1;
}

# Point doubling (EFD dbl-2001-b, a = -3).
var _ptd384_delta = 0;
var _ptd384_gamma = 0;
var _ptd384_beta  = 0;
var _ptd384_alpha = 0;
var _ptd384_t1    = 0;
var _ptd384_t2    = 0;
var _ptd384_x3    = 0;
var _ptd384_y3    = 0;
var _ptd384_z3    = 0;
var _ptd384_inited = 0;

fn _ptd384_init(): i64 {
    if (_ptd384_inited == 1) { return 0; }
    _ptd384_delta = alloc(48);
    _ptd384_gamma = alloc(48);
    _ptd384_beta  = alloc(48);
    _ptd384_alpha = alloc(48);
    _ptd384_t1    = alloc(48);
    _ptd384_t2    = alloc(48);
    _ptd384_x3    = alloc(48);
    _ptd384_y3    = alloc(48);
    _ptd384_z3    = alloc(48);
    _ptd384_inited = 1;
    return 0;
}

fn pt384_double(out, p): i64 {
    _p384_init();
    _ptd384_init();
    if (pt384_is_infinity(p) == 1) { pt384_set_infinity(out); return 0; }

    fp_p384_sq(_ptd384_delta, _pt384_z(p));
    fp_p384_sq(_ptd384_gamma, _pt384_y(p));
    fp_p384_mul(_ptd384_beta, _pt384_x(p), _ptd384_gamma);

    fp_p384_sub(_ptd384_t1, _pt384_x(p), _ptd384_delta);
    fp_p384_add(_ptd384_t2, _pt384_x(p), _ptd384_delta);
    fp_p384_mul(_ptd384_alpha, _ptd384_t1, _ptd384_t2);
    fp_p384_add(_ptd384_t1, _ptd384_alpha, _ptd384_alpha);
    fp_p384_add(_ptd384_alpha, _ptd384_t1, _ptd384_alpha);

    fp_p384_sq(_ptd384_x3, _ptd384_alpha);
    fp_p384_add(_ptd384_t1, _ptd384_beta, _ptd384_beta);
    fp_p384_add(_ptd384_t1, _ptd384_t1, _ptd384_t1);
    fp_p384_add(_ptd384_t2, _ptd384_t1, _ptd384_t1);
    fp_p384_sub(_ptd384_x3, _ptd384_x3, _ptd384_t2);

    fp_p384_add(_ptd384_t1, _pt384_y(p), _pt384_z(p));
    fp_p384_sq(_ptd384_z3, _ptd384_t1);
    fp_p384_sub(_ptd384_z3, _ptd384_z3, _ptd384_gamma);
    fp_p384_sub(_ptd384_z3, _ptd384_z3, _ptd384_delta);

    fp_p384_add(_ptd384_t1, _ptd384_beta, _ptd384_beta);
    fp_p384_add(_ptd384_t1, _ptd384_t1, _ptd384_t1);
    fp_p384_sub(_ptd384_t1, _ptd384_t1, _ptd384_x3);
    fp_p384_mul(_ptd384_y3, _ptd384_alpha, _ptd384_t1);
    fp_p384_sq(_ptd384_t2, _ptd384_gamma);
    fp_p384_add(_ptd384_t1, _ptd384_t2, _ptd384_t2);
    fp_p384_add(_ptd384_t1, _ptd384_t1, _ptd384_t1);
    fp_p384_add(_ptd384_t1, _ptd384_t1, _ptd384_t1);
    fp_p384_sub(_ptd384_y3, _ptd384_y3, _ptd384_t1);

    u384_copy(_pt384_x(out), _ptd384_x3);
    u384_copy(_pt384_y(out), _ptd384_y3);
    u384_copy(_pt384_z(out), _ptd384_z3);
    return 0;
}

# Point addition (EFD add-2007-bl).
var _pta384_z1z1 = 0;
var _pta384_z2z2 = 0;
var _pta384_u1   = 0;
var _pta384_u2   = 0;
var _pta384_s1   = 0;
var _pta384_s2   = 0;
var _pta384_h    = 0;
var _pta384_i    = 0;
var _pta384_j    = 0;
var _pta384_r    = 0;
var _pta384_v    = 0;
var _pta384_t1   = 0;
var _pta384_t2   = 0;
var _pta384_x3   = 0;
var _pta384_y3   = 0;
var _pta384_z3   = 0;
var _pta384_inited = 0;

fn _pta384_init(): i64 {
    if (_pta384_inited == 1) { return 0; }
    _pta384_z1z1 = alloc(48);
    _pta384_z2z2 = alloc(48);
    _pta384_u1   = alloc(48);
    _pta384_u2   = alloc(48);
    _pta384_s1   = alloc(48);
    _pta384_s2   = alloc(48);
    _pta384_h    = alloc(48);
    _pta384_i    = alloc(48);
    _pta384_j    = alloc(48);
    _pta384_r    = alloc(48);
    _pta384_v    = alloc(48);
    _pta384_t1   = alloc(48);
    _pta384_t2   = alloc(48);
    _pta384_x3   = alloc(48);
    _pta384_y3   = alloc(48);
    _pta384_z3   = alloc(48);
    _pta384_inited = 1;
    return 0;
}

fn pt384_add(out, p, q): i64 {
    _p384_init();
    _pta384_init();

    if (pt384_is_infinity(p) == 1) { pt384_copy(out, q); return 0; }
    if (pt384_is_infinity(q) == 1) { pt384_copy(out, p); return 0; }

    fp_p384_sq(_pta384_z1z1, _pt384_z(p));
    fp_p384_sq(_pta384_z2z2, _pt384_z(q));

    fp_p384_mul(_pta384_u1, _pt384_x(p), _pta384_z2z2);
    fp_p384_mul(_pta384_u2, _pt384_x(q), _pta384_z1z1);

    fp_p384_mul(_pta384_t1, _pt384_z(q), _pta384_z2z2);
    fp_p384_mul(_pta384_s1, _pt384_y(p), _pta384_t1);
    fp_p384_mul(_pta384_t1, _pt384_z(p), _pta384_z1z1);
    fp_p384_mul(_pta384_s2, _pt384_y(q), _pta384_t1);

    fp_p384_sub(_pta384_h, _pta384_u2, _pta384_u1);

    if (u384_is_zero(_pta384_h) == 1) {
        if (u384_eq(_pta384_s1, _pta384_s2) == 1) {
            return pt384_double(out, p);
        } else {
            pt384_set_infinity(out);
            return 0;
        }
    }

    fp_p384_add(_pta384_t1, _pta384_h, _pta384_h);
    fp_p384_sq(_pta384_i, _pta384_t1);
    fp_p384_mul(_pta384_j, _pta384_h, _pta384_i);
    fp_p384_sub(_pta384_t1, _pta384_s2, _pta384_s1);
    fp_p384_add(_pta384_r, _pta384_t1, _pta384_t1);
    fp_p384_mul(_pta384_v, _pta384_u1, _pta384_i);

    fp_p384_sq(_pta384_x3, _pta384_r);
    fp_p384_sub(_pta384_x3, _pta384_x3, _pta384_j);
    fp_p384_add(_pta384_t1, _pta384_v, _pta384_v);
    fp_p384_sub(_pta384_x3, _pta384_x3, _pta384_t1);

    fp_p384_sub(_pta384_t1, _pta384_v, _pta384_x3);
    fp_p384_mul(_pta384_y3, _pta384_r, _pta384_t1);
    fp_p384_mul(_pta384_t1, _pta384_s1, _pta384_j);
    fp_p384_add(_pta384_t2, _pta384_t1, _pta384_t1);
    fp_p384_sub(_pta384_y3, _pta384_y3, _pta384_t2);

    fp_p384_add(_pta384_t1, _pt384_z(p), _pt384_z(q));
    fp_p384_sq(_pta384_t2, _pta384_t1);
    fp_p384_sub(_pta384_t2, _pta384_t2, _pta384_z1z1);
    fp_p384_sub(_pta384_t2, _pta384_t2, _pta384_z2z2);
    fp_p384_mul(_pta384_z3, _pta384_t2, _pta384_h);

    u384_copy(_pt384_x(out), _pta384_x3);
    u384_copy(_pt384_y(out), _pta384_y3);
    u384_copy(_pt384_z(out), _pta384_z3);
    return 0;
}

# Montgomery-ladder scalar multiplication.
var _ptm384_r0 = 0;
var _ptm384_r1 = 0;
var _ptm384_sum = 0;
var _ptm384_dbl = 0;
var _ptm384_scalar = 0;
var _ptm384_inited = 0;

fn _ptm384_init(): i64 {
    if (_ptm384_inited == 1) { return 0; }
    _ptm384_r0 = pt384_alloc();
    _ptm384_r1 = pt384_alloc();
    _ptm384_sum = pt384_alloc();
    _ptm384_dbl = pt384_alloc();
    _ptm384_inited = 1;
    return 0;
}

fn pt384_scalarmul(out, k, P): i64 {
    _p384_init();
    _ptm384_init();

    pt384_set_infinity(_ptm384_r0);
    pt384_copy(_ptm384_r1, P);
    _ptm384_scalar = k;
    var prev = 0;
    var i = 383;
    while (i >= 0) {
        var limb_idx = i / 64;
        var bit_idx  = i & 63;
        var bit = (load64(_ptm384_scalar + limb_idx * 8) >> bit_idx) & 1;
        var swap = prev ^ bit;
        pt384_cswap(swap, _ptm384_r0, _ptm384_r1);
        pt384_add(_ptm384_sum, _ptm384_r0, _ptm384_r1);
        pt384_double(_ptm384_dbl, _ptm384_r0);
        pt384_copy(_ptm384_r1, _ptm384_sum);
        pt384_copy(_ptm384_r0, _ptm384_dbl);
        prev = bit;
        i = i - 1;
    }
    pt384_cswap(prev, _ptm384_r0, _ptm384_r1);
    pt384_copy(out, _ptm384_r0);
    return 0;
}

# ================================================================
# ECDSA P-384 verify (SEC 1 v2.0 §4.1.4)
#
# Inputs:
#   pk    — 96 bytes, Qx || Qy (big-endian)
#   sig   — 96 bytes, r || s   (big-endian)
#   msg   — message bytes; SHA-384(msg) is the message representative
# ================================================================

var _ecv384_e        = 0;
var _ecv384_r        = 0;
var _ecv384_s        = 0;
var _ecv384_w        = 0;
var _ecv384_u1       = 0;
var _ecv384_u2       = 0;
var _ecv384_qx       = 0;
var _ecv384_qy       = 0;
var _ecv384_digest   = 0;
var _ecv384_P_u1G    = 0;
var _ecv384_P_u2Q    = 0;
var _ecv384_R        = 0;
var _ecv384_Rx       = 0;
var _ecv384_Ry       = 0;
var _ecv384_Rx_modn  = 0;
var _ecv384_G        = 0;
var _ecv384_Q        = 0;
var _ecv384_inited   = 0;

fn _ecv384_init(): i64 {
    if (_ecv384_inited == 1) { return 0; }
    _p384_init();
    _ecv384_e        = alloc(48);
    _ecv384_r        = alloc(48);
    _ecv384_s        = alloc(48);
    _ecv384_w        = alloc(48);
    _ecv384_u1       = alloc(48);
    _ecv384_u2       = alloc(48);
    _ecv384_qx       = alloc(48);
    _ecv384_qy       = alloc(48);
    _ecv384_digest   = alloc(48);
    _ecv384_P_u1G    = pt384_alloc();
    _ecv384_P_u2Q    = pt384_alloc();
    _ecv384_R        = pt384_alloc();
    _ecv384_Rx       = alloc(48);
    _ecv384_Ry       = alloc(48);
    _ecv384_Rx_modn  = alloc(48);
    _ecv384_G        = pt384_alloc();
    _ecv384_Q        = pt384_alloc();
    pt384_from_affine(_ecv384_G, _p384_gx, _p384_gy);
    _ecv384_inited = 1;
    return 0;
}

fn ecdsa_p384_verify(pk, msg, msg_len, sig): i64 {
    _ecv384_init();

    # 1. Decode r, s
    u384_load_be(_ecv384_r, sig);
    u384_load_be(_ecv384_s, sig + 48);
    if (u384_is_zero(_ecv384_r) == 1) { return 0; }
    if (u384_is_zero(_ecv384_s) == 1) { return 0; }
    if (u384_cmp(_ecv384_r, _p384_n) >= 0) { return 0; }
    if (u384_cmp(_ecv384_s, _p384_n) >= 0) { return 0; }

    # 2. Decode + validate Q
    u384_load_be(_ecv384_qx, pk);
    u384_load_be(_ecv384_qy, pk + 48);
    if (pt_p384_is_on_curve(_ecv384_qx, _ecv384_qy) == 0) { return 0; }
    pt384_from_affine(_ecv384_Q, _ecv384_qx, _ecv384_qy);

    # 3. e = SHA-384(msg) reduced mod n (the message representative has
    # the same bit length as the field; for P-384 / SHA-384 it matches
    # exactly so we just load BE and reduce once if ≥ n).
    sha384(msg, msg_len, _ecv384_digest);
    u384_load_be(_ecv384_e, _ecv384_digest);
    if (u384_cmp(_ecv384_e, _p384_n) >= 0) { u384_sub(_ecv384_e, _ecv384_e, _p384_n); }

    # 4. w = s^-1 mod n
    fn_p384_inv(_ecv384_w, _ecv384_s);

    # 5. u1 = e*w mod n, u2 = r*w mod n
    fn_p384_mul(_ecv384_u1, _ecv384_e, _ecv384_w);
    fn_p384_mul(_ecv384_u2, _ecv384_r, _ecv384_w);

    # 6. R = u1*G + u2*Q
    pt384_scalarmul(_ecv384_P_u1G, _ecv384_u1, _ecv384_G);
    pt384_scalarmul(_ecv384_P_u2Q, _ecv384_u2, _ecv384_Q);
    pt384_add(_ecv384_R, _ecv384_P_u1G, _ecv384_P_u2Q);

    if (pt384_is_infinity(_ecv384_R) == 1) { return 0; }

    # 7. v = Rx mod n; accept iff v == r
    pt384_to_affine(_ecv384_Rx, _ecv384_Ry, _ecv384_R);
    fn_p384_reduce384(_ecv384_Rx_modn, _ecv384_Rx);
    if (u384_eq(_ecv384_Rx_modn, _ecv384_r) == 1) { return 1; }
    return 0;
}

# --- ecdsa_sign.cyr ---

# ecdsa_sign.cyr — ECDSA P-256 / P-384 signing with RFC 6979
# deterministic nonces. Issue line item 3 of the cyrius native-TLS
# arc (3.5.9). Pairs with the existing ecdsa_p256_verify /
# ecdsa_p384_verify and consumes the private scalars parsed by
# src/privkey.cyr (3.5.8).
#
# Construction (SEC 1 §4.1.3 + RFC 6979 §3.2):
#   e   = leftmost qlen bits of H(m), reduced mod n
#   k   = RFC 6979 deterministic nonce (HMAC_DRBG over the curve hash)
#   R   = k·G ; r = R.x mod n
#   s   = k^(-1) · (e + r·d) mod n
#   sig = r || s  (raw, big-endian, fixed length) or DER SEQUENCE.
#
# Determinism (RFC 6979) removes the catastrophic dependence on a
# per-signature random nonce — a repeated or biased k leaks the
# private key (PS3 / Sony 2010). The nonce is derived from (d, H(m))
# via HMAC_DRBG keyed on the curve's hash (SHA-256 for P-256,
# SHA-384 for P-384), so signing is a pure function of key + message.
#
# Security floor (CLAUDE.md § Security Hardening):
#   - The nonce k, the HMAC_DRBG state (K, V), the private scalar, and
#     every (e + r·d) / k^(-1) intermediate live in `secret var` stack
#     buffers, zeroized on scope exit. r and s are public outputs.
#   - Scalar inversion / multiply reuse the curve's existing mod-n
#     primitives (fn_p256_inv / fn_p256_mul, etc.).
#   - add-mod-n is carry-correct (the lib `u256_addmod` drops the
#     2^256 carry, which is wrong for the P-256/P-384 scalar field
#     where n ≈ 2^256 and a+b can exceed 2^256 — see _ecs_addmod_*).

# ================================================================
# Carry-correct scalar add mod n
# ================================================================
# r = (a + b) mod n, for a, b < n (n < 2^256). a+b can be up to
# 2n-2 > 2^256, so the 2^256 carry from u256_add MUST be honored.
# When carry == 1 the true sum is 2^256 + low; since a,b < n the low
# limbs are < n, so a single `u256_sub(r, r, n)` (which borrows and
# wraps, adding 2^256-n) yields the correct residue in [0, n).
fn _ecs_addmod_n_p256(r, a, b): i64 {
    var carry = u256_add(r, a, b);
    if (carry == 1) {
        u256_sub(r, r, _p256_n);
    } else {
        if (u256_cmp(r, _p256_n) >= 0) { u256_sub(r, r, _p256_n); }
    }
    return 0;
}

fn _ecs_addmod_n_p384(r, a, b): i64 {
    var carry = u384_add(r, a, b);
    if (carry == 1) {
        u384_sub(r, r, _p384_n);
    } else {
        if (u384_cmp(r, _p384_n) >= 0) { u384_sub(r, r, _p384_n); }
    }
    return 0;
}

# ================================================================
# RFC 6979 §3.2 — deterministic nonce (P-256 / HMAC-SHA256)
# ================================================================
# d_be:  32-byte big-endian private scalar (int2octets(x)).
# h1oct: 32-byte big-endian bits2octets(H(m)) = int2octets(e mod n).
# k_out: 32-byte big-endian nonce in [1, n-1].
# Returns 0 on success, -1 if no valid nonce within the retry bound.
#
# qlen == hlen == 256 for this curve/hash pair, so each HMAC round
# yields exactly one qlen block (T = V), and bits2int(T) = T.

# data = V(32) || sep(1) || d(32) || h1(32)  →  97 bytes
fn _rfc6979_build_p256(data, V, sep, d, h1): i64 {
    memcpy(data, V, 32);
    store8(data + 32, sep & 0xFF);
    memcpy(data + 33, d, 32);
    memcpy(data + 65, h1, 32);
    return 0;
}

fn _rfc6979_k_p256(d_be, h1oct, k_out): i64 {
    secret var V[32];
    secret var K[32];
    secret var Kt[32];
    secret var Vt[32];
    secret var data[97];
    secret var d1[33];     # V || 0x00 (for the regen step)
    secret var kint[32];

    var i = 0;
    while (i < 32) { store8(&V + i, 0x01); store8(&K + i, 0x00); i = i + 1; }

    # K = HMAC_K(V || 0x00 || int2octets(x) || bits2octets(h1))
    _rfc6979_build_p256(&data, &V, 0x00, d_be, h1oct);
    hmac_sha256(&K, 32, &data, 97, &Kt);
    memcpy(&K, &Kt, 32);
    # V = HMAC_K(V)
    hmac_sha256(&K, 32, &V, 32, &Vt);
    memcpy(&V, &Vt, 32);
    # K = HMAC_K(V || 0x01 || int2octets(x) || bits2octets(h1))
    _rfc6979_build_p256(&data, &V, 0x01, d_be, h1oct);
    hmac_sha256(&K, 32, &data, 97, &Kt);
    memcpy(&K, &Kt, 32);
    # V = HMAC_K(V)
    hmac_sha256(&K, 32, &V, 32, &Vt);
    memcpy(&V, &Vt, 32);

    var tries = 0;
    while (tries < 256) {
        # T = HMAC_K(V) (one block = qlen)
        hmac_sha256(&K, 32, &V, 32, &Vt);
        memcpy(&V, &Vt, 32);
        # k = bits2int(T); accept iff 1 <= k <= n-1.
        u256_load_be(&kint, &V);
        if (u256_is_zero(&kint) == 0) {
            if (u256_cmp(&kint, _p256_n) < 0) {
                u256_store_be(k_out, &kint);
                return 0;
            }
        }
        # Reject: K = HMAC_K(V || 0x00); V = HMAC_K(V).
        memcpy(&d1, &V, 32);
        store8(&d1 + 32, 0x00);
        hmac_sha256(&K, 32, &d1, 33, &Kt);
        memcpy(&K, &Kt, 32);
        hmac_sha256(&K, 32, &V, 32, &Vt);
        memcpy(&V, &Vt, 32);
        tries = tries + 1;
    }
    return 0 - 1;
}

# ================================================================
# RFC 6979 §3.2 — deterministic nonce (P-384 / HMAC-SHA384)
# ================================================================
# 48-byte HMAC-SHA384 blocks; qlen == hlen == 384.

# data = V(48) || sep(1) || d(48) || h1(48)  →  145 bytes
fn _rfc6979_build_p384(data, V, sep, d, h1): i64 {
    memcpy(data, V, 48);
    store8(data + 48, sep & 0xFF);
    memcpy(data + 49, d, 48);
    memcpy(data + 97, h1, 48);
    return 0;
}

fn _rfc6979_k_p384(d_be, h1oct, k_out): i64 {
    secret var V[48];
    secret var K[48];
    secret var Kt[48];
    secret var Vt[48];
    secret var data[145];
    secret var d1[49];
    secret var kint[48];

    var i = 0;
    while (i < 48) { store8(&V + i, 0x01); store8(&K + i, 0x00); i = i + 1; }

    _rfc6979_build_p384(&data, &V, 0x00, d_be, h1oct);
    hmac_sha384(&K, 48, &data, 145, &Kt);
    memcpy(&K, &Kt, 48);
    hmac_sha384(&K, 48, &V, 48, &Vt);
    memcpy(&V, &Vt, 48);
    _rfc6979_build_p384(&data, &V, 0x01, d_be, h1oct);
    hmac_sha384(&K, 48, &data, 145, &Kt);
    memcpy(&K, &Kt, 48);
    hmac_sha384(&K, 48, &V, 48, &Vt);
    memcpy(&V, &Vt, 48);

    var tries = 0;
    while (tries < 256) {
        hmac_sha384(&K, 48, &V, 48, &Vt);
        memcpy(&V, &Vt, 48);
        u384_load_be(&kint, &V);
        if (u384_is_zero(&kint) == 0) {
            if (u384_cmp(&kint, _p384_n) < 0) {
                u384_store_be(k_out, &kint);
                return 0;
            }
        }
        memcpy(&d1, &V, 48);
        store8(&d1 + 48, 0x00);
        hmac_sha384(&K, 48, &d1, 49, &Kt);
        memcpy(&K, &Kt, 48);
        hmac_sha384(&K, 48, &V, 48, &Vt);
        memcpy(&V, &Vt, 48);
        tries = tries + 1;
    }
    return 0 - 1;
}

# ================================================================
# Point scratch (allocated once; G and R are public data)
# ================================================================
var _ecs256_inited = 0;
var _ecs256_G = 0;
var _ecs256_R = 0;

fn _ecs256_init(): i64 {
    if (_ecs256_inited == 1) { return 0; }
    _p256_init();
    _ecs256_G = pt_alloc();
    _ecs256_R = pt_alloc();
    pt_from_affine(_ecs256_G, _p256_gx, _p256_gy);
    _ecs256_inited = 1;
    return 0;
}

var _ecs384_inited = 0;
var _ecs384_G = 0;
var _ecs384_R = 0;

fn _ecs384_init(): i64 {
    if (_ecs384_inited == 1) { return 0; }
    _p384_init();
    _ecs384_G = alloc(144);
    _ecs384_R = alloc(144);
    pt384_from_affine(_ecs384_G, _p384_gx, _p384_gy);
    _ecs384_inited = 1;
    return 0;
}

# ================================================================
# ecdsa_p256_sign — raw r||s (64 bytes, big-endian)
# ================================================================
# d_be: 32-byte big-endian private scalar in [1, n-1].
# Hashes msg with SHA-256 internally (matches ecdsa_p256_verify).
# Returns 0 on success, -1 on failure (degenerate r/s or no nonce).
fn ecdsa_p256_sign(d_be, msg, msg_len, sig_out): i64 {
    _ecs256_init();

    # One secret scratch block (cyrius caps secret/defer blocks at 8
    # per function); carve 13 × 32-byte slots by offset. Zeroized on
    # scope exit. All slots hold key-derived or intermediate values.
    secret var sc[416];
    var digest = &sc + 0;
    var e      = &sc + 32;
    var h1oct  = &sc + 64;
    var k      = &sc + 96;
    var kint   = &sc + 128;
    var kinv   = &sc + 160;
    var dint   = &sc + 192;
    var rint   = &sc + 224;
    var sint   = &sc + 256;
    var rd     = &sc + 288;
    var hpd    = &sc + 320;
    var Rx     = &sc + 352;
    var Ry     = &sc + 384;

    # e = SHA-256(msg) as BE int, reduced mod n.
    sha256(msg, msg_len, digest);
    u256_load_be(e, digest);
    if (u256_cmp(e, _p256_n) >= 0) { u256_sub(e, e, _p256_n); }
    # bits2octets(H(m)) = int2octets(e mod n)
    u256_store_be(h1oct, e);

    # k = RFC 6979 deterministic nonce.
    if (_rfc6979_k_p256(d_be, h1oct, k) != 0) { return 0 - 1; }
    u256_load_be(kint, k);

    # R = k·G ; r = R.x mod n.
    pt_scalarmul(_ecs256_R, kint, _ecs256_G);
    if (pt_is_infinity(_ecs256_R) == 1) { return 0 - 1; }
    pt_to_affine(Rx, Ry, _ecs256_R);
    fn_p256_reduce256(rint, Rx);
    if (u256_is_zero(rint) == 1) { return 0 - 1; }

    # s = k^(-1) · (e + r·d) mod n.
    u256_load_be(dint, d_be);
    fn_p256_mul(rd, rint, dint);
    _ecs_addmod_n_p256(hpd, e, rd);
    fn_p256_inv(kinv, kint);
    fn_p256_mul(sint, kinv, hpd);
    if (u256_is_zero(sint) == 1) { return 0 - 1; }

    u256_store_be(sig_out, rint);
    u256_store_be(sig_out + 32, sint);
    return 0;
}

# ================================================================
# ecdsa_p384_sign — raw r||s (96 bytes, big-endian)
# ================================================================
fn ecdsa_p384_sign(d_be, msg, msg_len, sig_out): i64 {
    _ecs384_init();

    # Single secret scratch (8-block cap); 13 × 48-byte slots.
    secret var sc[624];
    var digest = &sc + 0;
    var e      = &sc + 48;
    var h1oct  = &sc + 96;
    var k      = &sc + 144;
    var kint   = &sc + 192;
    var kinv   = &sc + 240;
    var dint   = &sc + 288;
    var rint   = &sc + 336;
    var sint   = &sc + 384;
    var rd     = &sc + 432;
    var hpd    = &sc + 480;
    var Rx     = &sc + 528;
    var Ry     = &sc + 576;

    sha384(msg, msg_len, digest);
    u384_load_be(e, digest);
    if (u384_cmp(e, _p384_n) >= 0) { u384_sub(e, e, _p384_n); }
    u384_store_be(h1oct, e);

    if (_rfc6979_k_p384(d_be, h1oct, k) != 0) { return 0 - 1; }
    u384_load_be(kint, k);

    pt384_scalarmul(_ecs384_R, kint, _ecs384_G);
    if (pt384_is_infinity(_ecs384_R) == 1) { return 0 - 1; }
    pt384_to_affine(Rx, Ry, _ecs384_R);
    fn_p384_reduce384(rint, Rx);
    if (u384_is_zero(rint) == 1) { return 0 - 1; }

    u384_load_be(dint, d_be);
    fn_p384_mul(rd, rint, dint);
    _ecs_addmod_n_p384(hpd, e, rd);
    fn_p384_inv(kinv, kint);
    fn_p384_mul(sint, kinv, hpd);
    if (u384_is_zero(sint) == 1) { return 0 - 1; }

    u384_store_be(sig_out, rint);
    u384_store_be(sig_out + 48, sint);
    return 0;
}

# ================================================================
# DER encoding — SEQUENCE { INTEGER r, INTEGER s }
# ================================================================
# Emit one minimal DER INTEGER from a `len`-byte big-endian value:
# strip leading zero bytes (keep at least one), prepend 0x00 when the
# top bit of the leading byte is set. Returns bytes written.
fn _ecs_der_emit_int(out, val, len): i64 {
    var start = 0;
    var done = 0;
    while (done == 0) {
        if (start >= len - 1) { done = 1; }
        else {
            if ((load8(val + start) & 0xFF) != 0) { done = 1; }
            else { start = start + 1; }
        }
    }
    var vlen = len - start;
    var pad = 0;
    if ((load8(val + start) & 0xFF) >= 0x80) { pad = 1; }
    var p = 0;
    store8(out + p, 0x02); p = p + 1;
    store8(out + p, (vlen + pad) & 0xFF); p = p + 1;
    if (pad == 1) { store8(out + p, 0x00); p = p + 1; }
    var i = 0;
    while (i < vlen) {
        store8(out + p, load8(val + start + i) & 0xFF);
        p = p + 1;
        i = i + 1;
    }
    return p;
}

# Wrap a raw r||s signature (each `comp_len` BE bytes) as DER. Returns
# the DER byte length, or -1 if it would exceed `out_max`. For P-256
# /P-384 the total content is < 128 bytes, so the SEQUENCE length is
# always single-byte.
fn _ecs_der_from_raw(sig, comp_len, out, out_max): i64 {
    var body[110];
    var bp = 0;
    bp = bp + _ecs_der_emit_int(&body + bp, sig, comp_len);
    bp = bp + _ecs_der_emit_int(&body + bp, sig + comp_len, comp_len);
    var total = 2 + bp;
    if (total > out_max) { return 0 - 1; }
    store8(out + 0, 0x30);
    store8(out + 1, bp & 0xFF);
    memcpy(out + 2, &body, bp);
    return total;
}

# ecdsa_p256_sign_der — DER-encoded signature (TLS 1.3 CertificateVerify
# form, RFC 8446 §4.2.3 ecdsa_secp256r1_sha256). Returns the DER byte
# length, or -1 on failure / insufficient `out_max`.
fn ecdsa_p256_sign_der(d_be, msg, msg_len, out, out_max): i64 {
    secret var sig[64];
    if (ecdsa_p256_sign(d_be, msg, msg_len, &sig) != 0) { return 0 - 1; }
    return _ecs_der_from_raw(&sig, 32, out, out_max);
}

# ecdsa_p384_sign_der — DER-encoded P-384 signature
# (ecdsa_secp384r1_sha384). Returns the DER byte length, or -1.
fn ecdsa_p384_sign_der(d_be, msg, msg_len, out, out_max): i64 {
    secret var sig[96];
    if (ecdsa_p384_sign(d_be, msg, msg_len, &sig) != 0) { return 0 - 1; }
    return _ecs_der_from_raw(&sig, 48, out, out_max);
}

# --- x509.cyr ---

# x509.cyr — minimal X.509 cert-chain walker for the 3.2.x TEE arc.
#
# Sigil 3.2.2 — bite 2 of the TEE attestation arc (origin:
# `docs/development/3.2-tee-arc.md`). Just enough X.509 to walk
# IAS root → SGX intermediate → leaf, and ARK → ASK → VCEK
# (SEV-SNP). Explicitly NOT a general PKIX library:
#   • only ecdsa-with-SHA256 signatures (the algo used by SGX/SEV
#     attestation chains today)
#   • only P-256 subjectPublicKeyInfo (id-ecPublicKey + prime256v1)
#   • no policy mapping, no name constraints, no CRL fetching, no
#     general TLS chain walk
#   • no support for v1/v2 certs — TBSCertificate version must be
#     v3 (the integer 2)
#   • basicConstraints / keyUsage parsed against a small allow-list
#     (CA bit must be set on intermediates and the root; leaf must
#     be end-entity with no CA flag)
#
# Surface:
#   fn x509_parse(der, der_len, out_cert): i64
#       — parses a DER-encoded Certificate into out_cert (256 B
#         struct allocated via `x509_cert_alloc`). Returns 1 on
#         success, 0 on any malformed / unsupported input. Performs
#         pt_is_on_curve on the subject public key as part of parse;
#         a cert with an off-curve key never reaches the chain walker.
#
#   fn x509_verify_chain(leaf, intermediates, intermediates_len,
#                         root, now_unix): i64
#       — verifies the chain: each non-root cert is hashed (TBS) and
#         its signature checked against the issuer's public key,
#         issuer/subject DN bytes must match across the link, each
#         cert must be valid at `now_unix`, and intermediates must
#         have the CA basicConstraints bit set. Returns 1 on a fully
#         verified chain, 0 otherwise.
#
# Threat model:
#   The DER buffer comes from an untrusted channel (a remote SGX
#   quoting enclave or SEV-SNP firmware response). This is the
#   highest-risk parser in sigil to date. Every TLV walk is bounds-
#   checked against the buffer length; no offset arithmetic crosses
#   the validated boundary. See `docs/audit/2026-05-22-audit.md`
#   for the 3.2.2 hardening review.

# ================================================================
# ASN.1 / DER tag constants
# ================================================================

var DER_TAG_BOOLEAN          = 0x01;
var DER_TAG_INTEGER          = 0x02;
var DER_TAG_BIT_STRING       = 0x03;
var DER_TAG_OCTET_STRING     = 0x04;
var DER_TAG_NULL             = 0x05;
var DER_TAG_OBJECT_ID        = 0x06;
var DER_TAG_UTF8STRING       = 0x0C;
var DER_TAG_PRINTABLESTRING  = 0x13;
var DER_TAG_TELETEXSTRING    = 0x14;
var DER_TAG_IA5STRING        = 0x16;
var DER_TAG_UTCTIME          = 0x17;
var DER_TAG_GENTIME          = 0x18;
var DER_TAG_SEQUENCE         = 0x30;
var DER_TAG_SET              = 0x31;
var DER_TAG_CONTEXT_0_EXP    = 0xA0;   # [0] EXPLICIT — version, etc.
var DER_TAG_CONTEXT_3_EXP    = 0xA3;   # [3] EXPLICIT — extensions

# Supported signature algorithm enum stored in X509Cert.sig_algo.
var X509_SIG_ECDSA_SHA256    = 1;

# Supported curve enum stored in X509Cert.curve. The leaf cert in an
# AMD VCEK chain holds a P-384 pubkey; chain-link signatures (root →
# intermediates → leaf) remain ECDSA-SHA256, so the issuer of every
# verified link MUST still be P-256. Mixed-curve chains where an
# intermediate is P-384 are out of scope for 3.4.1 — they'd require
# ecdsa_p384_verify dispatch inside `_x509_verify_link` (deferred).
var X509_CURVE_P256          = 1;
var X509_CURVE_P384          = 2;

# ================================================================
# DER primitive walker
#
# Two layers:
#   _der_len(buf, pos, buf_len, out_content_pos): reads the length
#       field at `pos` (assumes tag already consumed). Sets
#       *out_content_pos to the first byte of the content. Returns
#       the content length, or -1 on malformed.
#   der_walk(buf, buf_len, pos, expected_tag, out_content_pos,
#             out_next_pos): asserts the tag at `pos` equals
#       `expected_tag`, decodes length, sets *out_content_pos and
#       *out_next_pos = pos_after_tlv. Returns content length, -1
#       on tag mismatch / OOB.
# ================================================================

# Read DER length. `pos` points to the length byte. `buf_len` is the
# total buffer length. Returns content length or -1.
fn _der_len(buf, pos, buf_len, out_content_pos): i64 {
    if (pos >= buf_len) { return 0 - 1; }
    var b0 = load8(buf + pos) & 0xFF;
    if (b0 < 0x80) {
        # short form
        store64(out_content_pos, pos + 1);
        return b0;
    }
    var nbytes = b0 & 0x7F;
    # 0x80 (indefinite-length) and lengths > 4 bytes are rejected.
    # P-256 certs never have any single field exceed 2^31 - 1.
    if (nbytes == 0) { return 0 - 1; }
    if (nbytes > 4) { return 0 - 1; }
    if (pos + 1 + nbytes > buf_len) { return 0 - 1; }
    var len = 0;
    var i = 0;
    while (i < nbytes) {
        len = (len << 8) | (load8(buf + pos + 1 + i) & 0xFF);
        i = i + 1;
    }
    # DER strictly requires minimum-length encoding: a length that
    # could fit in fewer bytes must use the shorter form. We allow
    # long-form for compatibility with widely-deployed CAs that
    # technically violate this but otherwise validate.
    if (len < 0) { return 0 - 1; }
    store64(out_content_pos, pos + 1 + nbytes);
    return len;
}

# Walk one TLV at `pos`, asserting its tag.
# Returns content length (≥ 0) on success, -1 on tag mismatch / OOB.
# Sets *out_content_pos = first byte of content,
#      *out_next_pos    = byte after the TLV.
fn der_walk(buf, buf_len, pos, expected_tag, out_content_pos, out_next_pos): i64 {
    if (pos >= buf_len) { return 0 - 1; }
    var tag = load8(buf + pos) & 0xFF;
    if (tag != (expected_tag & 0xFF)) { return 0 - 1; }
    var content_pos = 0;
    var len = _der_len(buf, pos + 1, buf_len, &content_pos);
    if (len < 0) { return 0 - 1; }
    if (content_pos + len > buf_len) { return 0 - 1; }
    store64(out_content_pos, content_pos);
    store64(out_next_pos, content_pos + len);
    return len;
}

# Same as der_walk but only returns the next-pos via out_next_pos;
# discards content position. Used to skip over fields we don't read.
fn der_skip(buf, buf_len, pos, expected_tag, out_next_pos): i64 {
    var content_pos = 0;
    var len = der_walk(buf, buf_len, pos, expected_tag, &content_pos, out_next_pos);
    return len;
}

# ================================================================
# OID matching
#
# We compare against a fixed set of OIDs by raw DER encoding:
#   id-ecPublicKey:       1.2.840.10045.2.1   →  06 07 2A 86 48 CE 3D 02 01
#   prime256v1:           1.2.840.10045.3.1.7 →  06 08 2A 86 48 CE 3D 03 01 07
#   secp384r1:            1.3.132.0.34        →  06 05 2B 81 04 00 22
#   ecdsa-with-SHA256:    1.2.840.10045.4.3.2 →  06 08 2A 86 48 CE 3D 04 03 02
#   basicConstraints:     2.5.29.19           →  06 03 55 1D 13
#   keyUsage:             2.5.29.15           →  06 03 55 1D 0F
#
# We hold the *contents* (after the OID tag+len) for direct compare.
# ================================================================

var _oid_ec_pub_key       = 0;
var _oid_prime256v1       = 0;
var _oid_secp384r1         = 0;
var _oid_ecdsa_with_sha256 = 0;
var _oid_basic_constraints = 0;
var _oid_key_usage         = 0;
var _x509_oids_inited      = 0;

# Build a small heap buffer holding the OID's content bytes.
fn _build_oid(bytes_hex, hex_len): i64 {
    return hex_decode(bytes_hex, hex_len);
}

fn _x509_oids_init(): i64 {
    if (_x509_oids_inited == 1) { return 0; }
    # 7-byte content for id-ecPublicKey: 2A 86 48 CE 3D 02 01
    _oid_ec_pub_key        = _build_oid("2a8648ce3d0201", 14);
    # 8-byte content for prime256v1:    2A 86 48 CE 3D 03 01 07
    _oid_prime256v1        = _build_oid("2a8648ce3d030107", 16);
    # 5-byte content for secp384r1:     2B 81 04 00 22
    _oid_secp384r1         = _build_oid("2b81040022", 10);
    # 8-byte content for ecdsa-with-SHA256: 2A 86 48 CE 3D 04 03 02
    _oid_ecdsa_with_sha256 = _build_oid("2a8648ce3d040302", 16);
    # 3-byte content for basicConstraints: 55 1D 13
    _oid_basic_constraints = _build_oid("551d13", 6);
    # 3-byte content for keyUsage:       55 1D 0F
    _oid_key_usage         = _build_oid("551d0f", 6);
    _x509_oids_inited = 1;
    return 0;
}

# Compare DER OID content at (buf + off, len) to a reference content
# buffer (ref, ref_len). Returns 1 if equal, 0 otherwise.
fn _oid_eq(buf, off, len, ref, ref_len): i64 {
    if (len != ref_len) { return 0; }
    var i = 0;
    while (i < len) {
        if ((load8(buf + off + i) & 0xFF) != (load8(ref + i) & 0xFF)) { return 0; }
        i = i + 1;
    }
    return 1;
}

# ================================================================
# X509Cert struct — 256 bytes (parsed cert metadata + extracted key)
#
# Offsets (in bytes, all little-endian i64 unless noted):
#    0  der_ptr           — pointer to the original DER buffer
#    8  der_len           — total length of the DER cert
#   16  tbs_off           — offset of TBSCertificate SEQUENCE start
#   24  tbs_total_len     — full TLV length of TBS (tag+len+content)
#   32  serial_off        — offset of serial INTEGER content
#   40  serial_len        — length of serial content
#   48  issuer_off        — offset of issuer SEQUENCE tag (full TLV)
#   56  issuer_total_len  — length of issuer TLV
#   64  subject_off       — offset of subject SEQUENCE tag (full TLV)
#   72  subject_total_len — length of subject TLV
#   80  not_before        — epoch seconds
#   88  not_after         — epoch seconds
#   96  pubkey[96]        — raw affine point: Qx || Qy. For
#                            X509_CURVE_P256, the LOWER 64 bytes hold
#                            the pubkey and the upper 32 bytes are
#                            zero. For X509_CURVE_P384, all 96 bytes
#                            hold Qx (48) || Qy (48). Already
#                            on-curve-validated at parse time
#                            (pt_is_on_curve for P-256,
#                            pt_p384_is_on_curve for P-384).
#  192  sig_algo          — X509_SIG_ECDSA_SHA256 only (== 1)
#  200  sig_off           — offset of signature value (P-256 raw
#                            r || s, after BIT STRING + DER int
#                            unwrapping)
#  208  sig_len           — must equal 64
#  216  is_ca             — 1 if basicConstraints CA bit set
#  224  path_len          — -1 if absent, else value
#  232  curve             — X509_CURVE_P256 or X509_CURVE_P384
#  240  pubkey_len        — 64 for P-256, 96 for P-384
#  248..256  reserved / pad
# ================================================================

fn x509_cert_alloc(): i64 {
    var c = alloc(256);
    memset(c, 0, 256);
    return c;
}

fn x509_cert_pubkey(c): i64        { return c + 96; }
fn x509_cert_not_before(c): i64    { return load64(c + 80); }
fn x509_cert_not_after(c): i64     { return load64(c + 88); }
fn x509_cert_is_ca(c): i64         { return load64(c + 216); }
fn x509_cert_path_len(c): i64      { return load64(c + 224); }
fn x509_cert_sig_algo(c): i64      { return load64(c + 192); }
fn x509_cert_curve(c): i64         { return load64(c + 232); }
fn x509_cert_pubkey_len(c): i64    { return load64(c + 240); }

# Internal setters (for x509_parse below).
fn _x509_set_der(c, ptr, len): i64        { store64(c + 0, ptr); store64(c + 8, len); return 0; }
fn _x509_set_tbs(c, off, len): i64        { store64(c + 16, off); store64(c + 24, len); return 0; }
fn _x509_set_serial(c, off, len): i64     { store64(c + 32, off); store64(c + 40, len); return 0; }
fn _x509_set_issuer(c, off, len): i64     { store64(c + 48, off); store64(c + 56, len); return 0; }
fn _x509_set_subject(c, off, len): i64    { store64(c + 64, off); store64(c + 72, len); return 0; }
fn _x509_set_not_before(c, t): i64        { store64(c + 80, t); return 0; }
fn _x509_set_not_after(c, t): i64         { store64(c + 88, t); return 0; }
fn _x509_set_sig_algo(c, a): i64          { store64(c + 192, a); return 0; }
fn _x509_set_sig(c, off, len): i64        { store64(c + 200, off); store64(c + 208, len); return 0; }
fn _x509_set_is_ca(c, v): i64             { store64(c + 216, v); return 0; }
fn _x509_set_path_len(c, v): i64          { store64(c + 224, v); return 0; }
fn _x509_set_curve(c, v): i64             { store64(c + 232, v); return 0; }
fn _x509_set_pubkey_len(c, v): i64        { store64(c + 240, v); return 0; }

# ================================================================
# ASN.1 time decoders
#
# UTCTime:         YYMMDDHHMMSSZ  (13 bytes)   years 50-99 → 19xx, 00-49 → 20xx
# GeneralizedTime: YYYYMMDDHHMMSSZ (15 bytes)
#
# Both use Z (Zulu / UTC). Anything else rejected. We don't support
# the "no seconds" YYMMDDHHMMZ shortcut (rare in modern certs).
# ================================================================

# Days-in-month table (non-leap). Initialised once.
var _x509_mdays = 0;
var _x509_mdays_inited = 0;
fn _x509_init_mdays(): i64 {
    if (_x509_mdays_inited == 1) { return 0; }
    _x509_mdays = alloc(96);   # 12 × 8 bytes
    store64(_x509_mdays + 0,  31);
    store64(_x509_mdays + 8,  28);
    store64(_x509_mdays + 16, 31);
    store64(_x509_mdays + 24, 30);
    store64(_x509_mdays + 32, 31);
    store64(_x509_mdays + 40, 30);
    store64(_x509_mdays + 48, 31);
    store64(_x509_mdays + 56, 31);
    store64(_x509_mdays + 64, 30);
    store64(_x509_mdays + 72, 31);
    store64(_x509_mdays + 80, 30);
    store64(_x509_mdays + 88, 31);
    _x509_mdays_inited = 1;
    return 0;
}

fn _x509_is_leap(y): i64 {
    if (y % 4 != 0) { return 0; }
    if (y % 100 != 0) { return 1; }
    if (y % 400 != 0) { return 0; }
    return 1;
}

# Convert (yr, mo, dy, hr, mn, sc) to epoch seconds. Returns -1 on
# range-invalid input.
fn _x509_date_to_epoch(yr, mo, dy, hr, mn, sc): i64 {
    if (mo < 1) { return 0 - 1; }
    if (mo > 12) { return 0 - 1; }
    if (dy < 1) { return 0 - 1; }
    if (dy > 31) { return 0 - 1; }
    if (hr > 23) { return 0 - 1; }
    if (mn > 59) { return 0 - 1; }
    if (sc > 59) { return 0 - 1; }
    if (yr < 1970) { return 0 - 1; }
    _x509_init_mdays();
    var days = 0;
    var y = 1970;
    while (y < yr) {
        days = days + 365;
        if (_x509_is_leap(y) == 1) { days = days + 1; }
        y = y + 1;
    }
    var m = 1;
    while (m < mo) {
        days = days + load64(_x509_mdays + (m - 1) * 8);
        if (m == 2) { if (_x509_is_leap(yr) == 1) { days = days + 1; } }
        m = m + 1;
    }
    # Validate day-in-month
    var max_dy = load64(_x509_mdays + (mo - 1) * 8);
    if (mo == 2) { if (_x509_is_leap(yr) == 1) { max_dy = max_dy + 1; } }
    if (dy > max_dy) { return 0 - 1; }
    days = days + dy - 1;
    return days * 86400 + hr * 3600 + mn * 60 + sc;
}

# Read 2 ASCII digits at (buf + pos). Returns the value or -1.
fn _x509_dec2(buf, pos): i64 {
    var c0 = load8(buf + pos) & 0xFF;
    var c1 = load8(buf + pos + 1) & 0xFF;
    if (c0 < 48) { return 0 - 1; }
    if (c0 > 57) { return 0 - 1; }
    if (c1 < 48) { return 0 - 1; }
    if (c1 > 57) { return 0 - 1; }
    return (c0 - 48) * 10 + (c1 - 48);
}

# Read 4 ASCII digits.
fn _x509_dec4(buf, pos): i64 {
    var hi = _x509_dec2(buf, pos);
    var lo = _x509_dec2(buf, pos + 2);
    if (hi < 0) { return 0 - 1; }
    if (lo < 0) { return 0 - 1; }
    return hi * 100 + lo;
}

# Parse UTCTime content at (buf + off, len) → epoch seconds, or -1.
fn _x509_parse_utctime(buf, off, len): i64 {
    if (len != 13) { return 0 - 1; }
    if ((load8(buf + off + 12) & 0xFF) != 0x5A) { return 0 - 1; }   # 'Z'
    var yy = _x509_dec2(buf, off);
    var mo = _x509_dec2(buf, off + 2);
    var dy = _x509_dec2(buf, off + 4);
    var hr = _x509_dec2(buf, off + 6);
    var mn = _x509_dec2(buf, off + 8);
    var sc = _x509_dec2(buf, off + 10);
    if (yy < 0) { return 0 - 1; }
    if (mo < 0) { return 0 - 1; }
    if (dy < 0) { return 0 - 1; }
    if (hr < 0) { return 0 - 1; }
    if (mn < 0) { return 0 - 1; }
    if (sc < 0) { return 0 - 1; }
    var yr = 0;
    if (yy < 50) { yr = 2000 + yy; }
    else         { yr = 1900 + yy; }
    return _x509_date_to_epoch(yr, mo, dy, hr, mn, sc);
}

# Parse GeneralizedTime content at (buf + off, len) → epoch seconds, or -1.
fn _x509_parse_gentime(buf, off, len): i64 {
    if (len != 15) { return 0 - 1; }
    if ((load8(buf + off + 14) & 0xFF) != 0x5A) { return 0 - 1; }
    var yr = _x509_dec4(buf, off);
    var mo = _x509_dec2(buf, off + 4);
    var dy = _x509_dec2(buf, off + 6);
    var hr = _x509_dec2(buf, off + 8);
    var mn = _x509_dec2(buf, off + 10);
    var sc = _x509_dec2(buf, off + 12);
    if (yr < 0) { return 0 - 1; }
    if (mo < 0) { return 0 - 1; }
    if (dy < 0) { return 0 - 1; }
    if (hr < 0) { return 0 - 1; }
    if (mn < 0) { return 0 - 1; }
    if (sc < 0) { return 0 - 1; }
    return _x509_date_to_epoch(yr, mo, dy, hr, mn, sc);
}

# Parse either UTCTime or GeneralizedTime starting at `pos`. Returns
# the next position (positive) on success, -1 on failure. Sets the
# `out_epoch` ptr to the decoded epoch seconds.
fn _x509_parse_time(buf, buf_len, pos, out_epoch, out_next_pos): i64 {
    if (pos >= buf_len) { return 0 - 1; }
    var tag = load8(buf + pos) & 0xFF;
    var content_pos = 0;
    var next_pos = 0;
    var len = 0;
    if (tag == DER_TAG_UTCTIME) {
        len = der_walk(buf, buf_len, pos, DER_TAG_UTCTIME, &content_pos, &next_pos);
        if (len < 0) { return 0 - 1; }
        var t = _x509_parse_utctime(buf, content_pos, len);
        if (t < 0) { return 0 - 1; }
        store64(out_epoch, t);
        store64(out_next_pos, next_pos);
        return 1;
    }
    if (tag == DER_TAG_GENTIME) {
        len = der_walk(buf, buf_len, pos, DER_TAG_GENTIME, &content_pos, &next_pos);
        if (len < 0) { return 0 - 1; }
        var t2 = _x509_parse_gentime(buf, content_pos, len);
        if (t2 < 0) { return 0 - 1; }
        store64(out_epoch, t2);
        store64(out_next_pos, next_pos);
        return 1;
    }
    return 0 - 1;
}

# ================================================================
# X.509 Certificate parsing
#
#   Certificate ::= SEQUENCE {
#       tbsCertificate       TBSCertificate,
#       signatureAlgorithm   AlgorithmIdentifier,
#       signature            BIT STRING
#   }
#
#   TBSCertificate ::= SEQUENCE {
#       version              [0] EXPLICIT INTEGER DEFAULT v1,
#       serialNumber         INTEGER,
#       signature            AlgorithmIdentifier,
#       issuer               Name,
#       validity             Validity,
#       subject              Name,
#       subjectPublicKeyInfo SubjectPublicKeyInfo,
#       extensions           [3] EXPLICIT Extensions OPTIONAL
#   }
#
# This parser walks the structure once, validates each field, and
# stashes offsets into the X509Cert struct. Every step bounds-
# checks against `der_len`.
# ================================================================

# Globals for nested-call survival (Cyrius quirk #1).
var _xp_buf = 0;
var _xp_buf_len = 0;
var _xp_cert = 0;
var _xp_cp = 0;        # scratch content_pos
var _xp_np = 0;        # scratch next_pos
var _xp_n2p = 0;       # second scratch next_pos
var _xp_alloced = 0;

fn _xp_init(): i64 {
    if (_xp_alloced == 1) { return 0; }
    _xp_cp  = alloc(8);
    _xp_np  = alloc(8);
    _xp_n2p = alloc(8);
    _xp_alloced = 1;
    return 0;
}

# Parse the AlgorithmIdentifier at `pos` and check it is
# ecdsa-with-SHA256. The parameters field, if present, must be NULL
# (the absence of curve parameters is implicit for this algorithm).
# Returns the next position on success, -1 on failure.
fn _xp_parse_algid_ecdsa_sha256(buf, buf_len, pos): i64 {
    _x509_oids_init();
    var content_pos = 0;
    var next_pos = 0;
    var seq_len = der_walk(buf, buf_len, pos, DER_TAG_SEQUENCE, &content_pos, &next_pos);
    if (seq_len < 0) { return 0 - 1; }
    var seq_end = content_pos + seq_len;

    # OID
    var oid_cp = 0;
    var oid_np = 0;
    var oid_len = der_walk(buf, buf_len, content_pos, DER_TAG_OBJECT_ID, &oid_cp, &oid_np);
    if (oid_len < 0) { return 0 - 1; }
    if (_oid_eq(buf, oid_cp, oid_len, _oid_ecdsa_with_sha256, 8) == 0) { return 0 - 1; }

    # Optional parameters — for ecdsa-with-SHA256 RFC 5758 §3.2 says
    # absent. Some certs encode NULL, some omit. Accept either.
    if (oid_np < seq_end) {
        # If present, must be NULL with zero-length content.
        if ((load8(buf + oid_np) & 0xFF) != DER_TAG_NULL) { return 0 - 1; }
        if (oid_np + 2 > seq_end) { return 0 - 1; }
        if ((load8(buf + oid_np + 1) & 0xFF) != 0x00) { return 0 - 1; }
    }
    return next_pos;
}

# Parse SubjectPublicKeyInfo at `pos`. Must be id-ecPublicKey with
# either prime256v1 (P-256, 64-byte pubkey) or secp384r1 (P-384,
# 96-byte pubkey) parameters. Extracts the raw uncompressed point
# into cert.pubkey, on-curve-validates via the appropriate curve
# primitive, and sets cert.curve + cert.pubkey_len accordingly.
# Returns next position on success, -1 on failure.
fn _xp_parse_spki(buf, buf_len, pos, cert): i64 {
    _x509_oids_init();
    var spki_cp = 0;
    var spki_np = 0;
    var spki_len = der_walk(buf, buf_len, pos, DER_TAG_SEQUENCE, &spki_cp, &spki_np);
    if (spki_len < 0) { return 0 - 1; }
    var spki_end = spki_cp + spki_len;

    # AlgorithmIdentifier: SEQUENCE { id-ecPublicKey, curve OID }
    var alg_cp = 0;
    var alg_np = 0;
    var alg_len = der_walk(buf, buf_len, spki_cp, DER_TAG_SEQUENCE, &alg_cp, &alg_np);
    if (alg_len < 0) { return 0 - 1; }
    var alg_end = alg_cp + alg_len;

    var oid_cp = 0;
    var oid_np = 0;
    var oid_len = der_walk(buf, buf_len, alg_cp, DER_TAG_OBJECT_ID, &oid_cp, &oid_np);
    if (oid_len < 0) { return 0 - 1; }
    if (_oid_eq(buf, oid_cp, oid_len, _oid_ec_pub_key, 7) == 0) { return 0 - 1; }

    # Parameters must be either prime256v1 (P-256) or secp384r1 (P-384).
    if (oid_np >= alg_end) { return 0 - 1; }
    var pcp = 0; var pnp = 0;
    var p_len = der_walk(buf, buf_len, oid_np, DER_TAG_OBJECT_ID, &pcp, &pnp);
    if (p_len < 0) { return 0 - 1; }

    var curve = 0;
    var pk_len = 0;
    var coord_len = 0;
    if (_oid_eq(buf, pcp, p_len, _oid_prime256v1, 8) == 1) {
        curve = X509_CURVE_P256;
        pk_len = 64;
        coord_len = 32;
    } else {
        if (_oid_eq(buf, pcp, p_len, _oid_secp384r1, 5) == 1) {
            curve = X509_CURVE_P384;
            pk_len = 96;
            coord_len = 48;
        } else {
            return 0 - 1;
        }
    }

    # subjectPublicKey BIT STRING — 0x04 (uncompressed) || Qx ||
    # Qy. The BIT STRING begins with one byte counting unused bits
    # (must be 0). Total length: 1 + 1 + 2*coord_len.
    var bs_cp = 0;
    var bs_np = 0;
    var bs_len = der_walk(buf, buf_len, alg_np, DER_TAG_BIT_STRING, &bs_cp, &bs_np);
    if (bs_len < 0) { return 0 - 1; }
    if (bs_len != 2 + pk_len) { return 0 - 1; }
    if ((load8(buf + bs_cp) & 0xFF) != 0) { return 0 - 1; }
    if ((load8(buf + bs_cp + 1) & 0xFF) != 0x04) { return 0 - 1; }

    # Stash raw pubkey (Qx || Qy) into cert.pubkey. The slot is
    # 96 bytes wide; P-256 pubkeys land in the lower 64 with the
    # upper 32 left at the memset(0) baseline.
    var pk = x509_cert_pubkey(cert);
    var i = 0;
    while (i < pk_len) {
        store8(pk + i, load8(buf + bs_cp + 2 + i) & 0xFF);
        i = i + 1;
    }

    # On-curve check — dispatch on curve.
    if (curve == X509_CURVE_P256) {
        var qx_limbs[32];
        var qy_limbs[32];
        u256_load_be(&qx_limbs, pk);
        u256_load_be(&qy_limbs, pk + 32);
        if (pt_is_on_curve(&qx_limbs, &qy_limbs) == 0) { return 0 - 1; }
    } else {
        var qx_limbs6[48];
        var qy_limbs6[48];
        u384_load_be(&qx_limbs6, pk);
        u384_load_be(&qy_limbs6, pk + 48);
        if (pt_p384_is_on_curve(&qx_limbs6, &qy_limbs6) == 0) { return 0 - 1; }
    }

    _x509_set_curve(cert, curve);
    _x509_set_pubkey_len(cert, pk_len);
    return spki_np;
}

# Parse extensions. We only look at basicConstraints and keyUsage;
# everything else is skipped. Critical extensions we don't understand
# are rejected (RFC 5280 §4.2 — must reject critical unknown).
fn _xp_parse_extensions(buf, buf_len, pos, cert): i64 {
    _x509_oids_init();
    var ext_cp = 0;
    var ext_np = 0;
    # [3] EXPLICIT Extensions
    var outer_len = der_walk(buf, buf_len, pos, DER_TAG_CONTEXT_3_EXP, &ext_cp, &ext_np);
    if (outer_len < 0) { return 0 - 1; }

    # Inner SEQUENCE OF Extension
    var inner_cp = 0;
    var inner_np = 0;
    var inner_len = der_walk(buf, buf_len, ext_cp, DER_TAG_SEQUENCE, &inner_cp, &inner_np);
    if (inner_len < 0) { return 0 - 1; }
    var seq_end = inner_cp + inner_len;

    var cur = inner_cp;
    while (cur < seq_end) {
        var e_cp = 0;
        var e_np = 0;
        var e_len = der_walk(buf, buf_len, cur, DER_TAG_SEQUENCE, &e_cp, &e_np);
        if (e_len < 0) { return 0 - 1; }
        var e_end = e_cp + e_len;

        # extnID OBJECT IDENTIFIER
        var oid_cp = 0;
        var oid_np = 0;
        var oid_len = der_walk(buf, buf_len, e_cp, DER_TAG_OBJECT_ID, &oid_cp, &oid_np);
        if (oid_len < 0) { return 0 - 1; }

        # Optional critical BOOLEAN (default FALSE)
        var critical = 0;
        var after_crit = oid_np;
        if (oid_np < e_end) {
            if ((load8(buf + oid_np) & 0xFF) == DER_TAG_BOOLEAN) {
                var b_cp = 0;
                var b_np = 0;
                var b_len = der_walk(buf, buf_len, oid_np, DER_TAG_BOOLEAN, &b_cp, &b_np);
                if (b_len != 1) { return 0 - 1; }
                if ((load8(buf + b_cp) & 0xFF) != 0) { critical = 1; }
                after_crit = b_np;
            }
        }

        # extnValue OCTET STRING — wraps the actual extension content.
        var v_cp = 0;
        var v_np = 0;
        var v_len = der_walk(buf, buf_len, after_crit, DER_TAG_OCTET_STRING, &v_cp, &v_np);
        if (v_len < 0) { return 0 - 1; }

        var matched = 0;

        # basicConstraints
        if (_oid_eq(buf, oid_cp, oid_len, _oid_basic_constraints, 3) == 1) {
            matched = 1;
            # Content: SEQUENCE { cA BOOLEAN DEFAULT FALSE, pathLenConstraint INTEGER OPTIONAL }
            var bc_cp = 0;
            var bc_np = 0;
            var bc_len = der_walk(buf, buf_len, v_cp, DER_TAG_SEQUENCE, &bc_cp, &bc_np);
            if (bc_len < 0) { return 0 - 1; }
            var bc_end = bc_cp + bc_len;
            var bccur = bc_cp;
            var is_ca = 0;
            if (bccur < bc_end) {
                if ((load8(buf + bccur) & 0xFF) == DER_TAG_BOOLEAN) {
                    var bp = 0; var bn = 0;
                    var bl = der_walk(buf, buf_len, bccur, DER_TAG_BOOLEAN, &bp, &bn);
                    if (bl != 1) { return 0 - 1; }
                    if ((load8(buf + bp) & 0xFF) != 0) { is_ca = 1; }
                    bccur = bn;
                }
            }
            _x509_set_is_ca(cert, is_ca);
            # path_len: only meaningful if cA == TRUE
            if (bccur < bc_end) {
                var ip = 0; var inn = 0;
                var il = der_walk(buf, buf_len, bccur, DER_TAG_INTEGER, &ip, &inn);
                if (il < 0) { return 0 - 1; }
                if (il > 8) { return 0 - 1; }
                # Decode big-endian integer into i64.
                var pl = 0;
                var k = 0;
                while (k < il) {
                    pl = (pl << 8) | (load8(buf + ip + k) & 0xFF);
                    k = k + 1;
                }
                _x509_set_path_len(cert, pl);
            } else {
                _x509_set_path_len(cert, 0 - 1);
            }
        }

        # keyUsage: parsed but not enforced beyond keeping the chain
        # walker honest about CA-vs-leaf via basicConstraints. We
        # accept the extension without inspecting bits; future work
        # can tighten this when an integration calls for it.

        # Critical extension we don't recognise → reject.
        if (matched == 0) {
            if (critical == 1) {
                if (_oid_eq(buf, oid_cp, oid_len, _oid_key_usage, 3) == 0) {
                    return 0 - 1;
                }
            }
        }
        cur = e_np;
    }
    return ext_np;
}

# Top-level parser. See header for the grammar walked.
fn x509_parse(der, der_len, out_cert): i64 {
    _xp_init();
    _x509_oids_init();
    memset(out_cert, 0, 256);
    _x509_set_der(out_cert, der, der_len);
    _x509_set_path_len(out_cert, 0 - 1);

    # Certificate ::= SEQUENCE { ... }
    var cert_cp = 0;
    var cert_np = 0;
    var cert_seq_len = der_walk(der, der_len, 0, DER_TAG_SEQUENCE, &cert_cp, &cert_np);
    if (cert_seq_len < 0) { return 0; }

    # tbsCertificate — capture its full TLV (tag+len+content) so the
    # chain walker can re-hash the exact bytes the signer signed.
    var tbs_cp = 0;
    var tbs_np = 0;
    var tbs_inner_len = der_walk(der, der_len, cert_cp, DER_TAG_SEQUENCE, &tbs_cp, &tbs_np);
    if (tbs_inner_len < 0) { return 0; }
    _x509_set_tbs(out_cert, cert_cp, tbs_np - cert_cp);
    var tbs_end = tbs_cp + tbs_inner_len;

    var cur = tbs_cp;

    # version [0] EXPLICIT INTEGER — must be v3 (== 2).
    if ((load8(der + cur) & 0xFF) != DER_TAG_CONTEXT_0_EXP) { return 0; }
    var v_cp = 0; var v_np = 0;
    if (der_walk(der, der_len, cur, DER_TAG_CONTEXT_0_EXP, &v_cp, &v_np) < 0) { return 0; }
    var vi_cp = 0; var vi_np = 0;
    var vi_len = der_walk(der, der_len, v_cp, DER_TAG_INTEGER, &vi_cp, &vi_np);
    if (vi_len != 1) { return 0; }
    if ((load8(der + vi_cp) & 0xFF) != 0x02) { return 0; }   # version v3
    cur = v_np;

    # serialNumber
    var s_cp = 0; var s_np = 0;
    var s_len = der_walk(der, der_len, cur, DER_TAG_INTEGER, &s_cp, &s_np);
    if (s_len < 0) { return 0; }
    _x509_set_serial(out_cert, s_cp, s_len);
    cur = s_np;

    # signature (inner) — AlgorithmIdentifier. Must match outer sig
    # algo (we'll check that consistency below after parsing the
    # outer one). For now, require ecdsa-with-SHA256.
    var inner_algo_next = _xp_parse_algid_ecdsa_sha256(der, der_len, cur);
    if (inner_algo_next < 0) { return 0; }
    cur = inner_algo_next;

    # issuer — capture full TLV
    var iss_cp = 0; var iss_np = 0;
    var iss_len = der_walk(der, der_len, cur, DER_TAG_SEQUENCE, &iss_cp, &iss_np);
    if (iss_len < 0) { return 0; }
    _x509_set_issuer(out_cert, cur, iss_np - cur);
    cur = iss_np;

    # validity SEQUENCE { notBefore, notAfter }
    var val_cp = 0; var val_np = 0;
    var val_len = der_walk(der, der_len, cur, DER_TAG_SEQUENCE, &val_cp, &val_np);
    if (val_len < 0) { return 0; }
    var nb = 0; var nb_next = 0;
    if (_x509_parse_time(der, der_len, val_cp, &nb, &nb_next) < 0) { return 0; }
    var na = 0; var na_next = 0;
    if (_x509_parse_time(der, der_len, nb_next, &na, &na_next) < 0) { return 0; }
    if (na_next != val_cp + val_len) { return 0; }   # trailing garbage
    _x509_set_not_before(out_cert, nb);
    _x509_set_not_after(out_cert, na);
    cur = val_np;

    # subject
    var sub_cp = 0; var sub_np = 0;
    var sub_len = der_walk(der, der_len, cur, DER_TAG_SEQUENCE, &sub_cp, &sub_np);
    if (sub_len < 0) { return 0; }
    _x509_set_subject(out_cert, cur, sub_np - cur);
    cur = sub_np;

    # subjectPublicKeyInfo
    var spki_next = _xp_parse_spki(der, der_len, cur, out_cert);
    if (spki_next < 0) { return 0; }
    cur = spki_next;

    # Optional [3] extensions
    if (cur < tbs_end) {
        if ((load8(der + cur) & 0xFF) == DER_TAG_CONTEXT_3_EXP) {
            var ext_next = _xp_parse_extensions(der, der_len, cur, out_cert);
            if (ext_next < 0) { return 0; }
            cur = ext_next;
        }
    }
    if (cur != tbs_end) { return 0; }    # trailing garbage in TBS

    # outer signatureAlgorithm
    var outer_algo_next = _xp_parse_algid_ecdsa_sha256(der, der_len, tbs_np);
    if (outer_algo_next < 0) { return 0; }
    _x509_set_sig_algo(out_cert, X509_SIG_ECDSA_SHA256);

    # signature BIT STRING — wraps an ECDSA signature DER SEQUENCE
    # of two INTEGERs. We unwrap into a fixed 64-byte r||s buffer
    # (allocated separately, stashed via sig_off/sig_len in the cert).
    var sb_cp = 0; var sb_np = 0;
    var sb_len = der_walk(der, der_len, outer_algo_next, DER_TAG_BIT_STRING, &sb_cp, &sb_np);
    if (sb_len < 0) { return 0; }
    if (sb_len < 1) { return 0; }
    if ((load8(der + sb_cp) & 0xFF) != 0) { return 0; }    # unused bits must be 0
    var inner_sig_off = sb_cp + 1;
    var inner_sig_len = sb_len - 1;

    # Unwrap r || s into a 64-byte heap buffer. Same decode shape as
    # _ecdsa_der_int in src/ecdsa_p256.cyr — we reuse that helper.
    var raw_sig = alloc(64);
    memset(raw_sig, 0, 64);
    var pos_after_seq_tag = 0;
    var inner_seq_len = der_walk(der, der_len, inner_sig_off, DER_TAG_SEQUENCE,
                                   &pos_after_seq_tag, &sb_np);
    if (inner_seq_len < 0) { return 0; }
    var inner_seq_end = pos_after_seq_tag + inner_seq_len;
    var r_next = _ecdsa_der_int(der, pos_after_seq_tag, inner_seq_end, raw_sig);
    if (r_next < 0) { return 0; }
    var s_next2 = _ecdsa_der_int(der, r_next, inner_seq_end, raw_sig + 32);
    if (s_next2 < 0) { return 0; }
    if (s_next2 != inner_seq_end) { return 0; }

    # Store raw_sig as a pointer-style "offset" = the absolute heap
    # address. sig_off/sig_len semantics for ECDSA sigs are "raw r||s
    # bytes at this address" (not an offset into der). Distinguish by
    # length: 64 = raw r||s; everything else is a parse error above.
    _x509_set_sig(out_cert, raw_sig, 64);

    if (sb_np != cert_cp + cert_seq_len) { return 0; }
    return 1;
}

# ================================================================
# Chain verification
#
# x509_verify_chain(leaf, intermediates, intermediates_len, root,
#                    now_unix):
#   • Walk the chain root → intermediates[0] → ... → intermediates[n-1]
#     → leaf. (Caller supplies intermediates in issuer-towards-leaf
#     order; `intermediates_len` may be 0 for a directly-root-signed
#     leaf.)
#   • For every link: hash issuer-cert's TBS, verify the child's
#     signature against the issuer's pubkey via ecdsa_p256_verify;
#     check child.issuer DN bytes == parent.subject DN bytes; check
#     child.not_before ≤ now_unix ≤ child.not_after; intermediates
#     must have basicConstraints CA bit set.
#   • The root is treated as a trust anchor — its self-signature
#     and basicConstraints are NOT re-checked. (Trust establishment
#     is by sigil's caller — the kavach attestation backend, the
#     ark publisher keyring, etc.)
# ================================================================

# Helper: compare two DN byte slices for equality.
fn _x509_dn_eq(buf_a, off_a, len_a, buf_b, off_b, len_b): i64 {
    if (len_a != len_b) { return 0; }
    var i = 0;
    while (i < len_a) {
        if ((load8(buf_a + off_a + i) & 0xFF) != (load8(buf_b + off_b + i) & 0xFF)) {
            return 0;
        }
        i = i + 1;
    }
    return 1;
}

# Hash the TBSCertificate of `cert` and verify `child`'s signature
# against the *issuer pubkey* — i.e. the signature on `child` was
# produced by the holder of `issuer_cert`'s private key. We pack
# the issuer's 64-byte (Qx || Qy) into the 64-byte form that
# `ecdsa_p256_verify` expects.
fn _x509_verify_link(child, issuer_cert): i64 {
    # Sanity: sig algo on child must be ecdsa-with-SHA256
    if (x509_cert_sig_algo(child) != X509_SIG_ECDSA_SHA256) { return 0; }

    var der_ptr = load64(child + 0);
    var tbs_off = load64(child + 16);
    var tbs_len = load64(child + 24);
    var sig_addr = load64(child + 200);
    var sig_len  = load64(child + 208);
    if (sig_len != 64) { return 0; }
    # Issuer must be P-256 — chain-link signatures are
    # ECDSA-SHA256, so the verify primitive only understands P-256
    # pubkeys. A P-384 issuer would imply a P-384 chain-link
    # signature (out of scope for 3.4.1). The leaf may still be
    # P-384; this restriction applies only to certs that SIGN a
    # subsequent link, never to the leaf itself.
    if (x509_cert_curve(issuer_cert) != X509_CURVE_P256) { return 0; }

    var pk = x509_cert_pubkey(issuer_cert);
    # ecdsa_p256_verify takes (pk, msg, msg_len, sig). We pass the
    # raw TBS bytes; the verify entry sha256-hashes them internally.
    return ecdsa_p256_verify(pk, der_ptr + tbs_off, tbs_len, sig_addr);
}

# Check time validity. now_unix == 0 disables the check (caller's
# explicit opt-out; the SGX bite may use this when the host clock
# is untrusted and verification rides on the report's TCB nonce).
fn _x509_in_window(cert, now_unix): i64 {
    if (now_unix == 0) { return 1; }
    if (now_unix < x509_cert_not_before(cert)) { return 0; }
    if (now_unix > x509_cert_not_after(cert))  { return 0; }
    return 1;
}

# Check issuer DN of `child` matches subject DN of `parent`.
fn _x509_issuer_matches(child, parent): i64 {
    var c_buf = load64(child + 0);
    var c_off = load64(child + 48);
    var c_len = load64(child + 56);
    var p_buf = load64(parent + 0);
    var p_off = load64(parent + 64);
    var p_len = load64(parent + 72);
    return _x509_dn_eq(c_buf, c_off, c_len, p_buf, p_off, p_len);
}

# `intermediates` is a contiguous array of `intermediates_len` cert
# pointers, in issuer-towards-leaf order.
fn x509_verify_chain(leaf, intermediates, intermediates_len, root, now_unix): i64 {
    # 1. Validate the leaf is in its validity window.
    if (_x509_in_window(leaf, now_unix) == 0) { return 0; }

    # 2. Walk intermediates, validating each is CA + in-window.
    var i = 0;
    while (i < intermediates_len) {
        var inter = load64(intermediates + i * 8);
        if (_x509_in_window(inter, now_unix) == 0) { return 0; }
        if (x509_cert_is_ca(inter) != 1) { return 0; }
        i = i + 1;
    }
    if (_x509_in_window(root, now_unix) == 0) { return 0; }
    if (x509_cert_is_ca(root) != 1) { return 0; }

    # 3. Walk the signature chain: root signs intermediates[0],
    #    intermediates[k] signs intermediates[k+1], last intermediate
    #    signs leaf (or root signs leaf if intermediates_len == 0).
    var parent = root;
    i = 0;
    while (i < intermediates_len) {
        var child = load64(intermediates + i * 8);
        if (_x509_issuer_matches(child, parent) == 0) { return 0; }
        if (_x509_verify_link(child, parent) == 0) { return 0; }
        parent = child;
        i = i + 1;
    }
    # Final link: parent signs leaf.
    if (_x509_issuer_matches(leaf, parent) == 0) { return 0; }
    if (_x509_verify_link(leaf, parent) == 0) { return 0; }

    return 1;
}

# --- pem.cyr ---

# pem.cyr — minimal PEM decoder for embedded cert chains.
#
# Sigil 3.5 — bite 1 of the TEE-attestation completion arc
# (origin: `docs/development/roadmap.md` "Road to v3.5"). The
# 3.2.x parsers (`src/sgx.cyr`, `src/tdx.cyr`) record an
# `qe_cert_data` byte range that, when `qe_cert_data_type == 5`,
# holds a PEM-encoded PCK cert chain (typically root → ...→
# leaf, 2–3 certs). SEV-SNP's VCEK chain is fetched out-of-band
# from AMD KDS in a similar PEM shape. 3.5's *_verify_full
# orchestrators want one decoder that turns those PEM bytes
# into a (cert_ptr, der_len) array consumable by
# `x509_parse` + `x509_verify_chain`.
#
# Scope (deliberately narrow):
#   • Recognises ONLY `-----BEGIN CERTIFICATE-----` /
#     `-----END CERTIFICATE-----` markers. Encrypted-PEM, RSA-key,
#     EC-key, CSR markers are ignored / rejected.
#   • Base64 alphabet is RFC 4648 §4 (standard, not URL-safe).
#     `+`, `/` valid; `-`, `_` rejected.
#   • Padding (`=`) accepted at the end of the body in 0/1/2-char
#     forms per RFC 4648. Padding inside the body is rejected.
#   • Whitespace (LF, CR, space, tab) inside the body is skipped
#     transparently — real-world PEMs wrap at 64 cols.
#   • No tolerance for extra content between blocks (e.g. embedded
#     human-readable cert summaries from `openssl x509 -text`).
#     The decoder allows arbitrary bytes BEFORE the first BEGIN
#     marker and BETWEEN END/BEGIN-of-next-block (so trailing
#     newlines / preamble are fine) but rejects any malformed
#     marker sequencing.
#
# Threat model: the PEM bytes are fully attacker-controlled (they
# travel from a remote untrusted host inside the TEE quote's
# `qe_cert_data` region). Every byte read is bounds-checked
# against `pem_len`; every byte write is bounds-checked against
# `der_pool_size`; the chain count is bounds-checked against
# `max_certs`. Any malformation returns -1 with the chain array
# untouched beyond the malformed entry; the caller MUST treat
# a non-positive return as a hard failure.
#
# Surface:
#   fn pem_decode_certs_into(pem, pem_len, out_chain, max_certs,
#                              der_pool, der_pool_size): i64
#       — _into variant: caller provides the DER scratch pool.
#         Returns count of decoded certs (≥ 1) on success, -1 on
#         any malformed input. `out_chain` is a contiguous array
#         of `max_certs * 16` bytes; each 16-byte entry is
#         (der_ptr: i64, der_len: i64) with der_ptr pointing into
#         der_pool. Entries beyond the returned count are
#         untouched.
#   fn pem_decode_certs(pem, pem_len, out_chain, max_certs): i64
#       — convenience wrapper. Bump-allocates a der_pool sized to
#         `pem_len` (a strict upper bound on the decoded DER) and
#         delegates. Lifetime is the process; suitable for one-
#         shot verify paths. See the LOW audit note in
#         `docs/audit/2026-05-XX-audit.md`.
#
# Layout of out_chain entries (16 B each):
#   0..7   der_ptr (absolute address into der_pool)
#   8..15  der_len (bytes, > 0)

# ================================================================
# Format constants
# ================================================================

var PEM_BEGIN_CERT_LEN = 27;
var PEM_END_CERT_LEN   = 25;

# Base64 lookup table: 256 entries
#   0..63  → base64 digit
#   64     → `=` padding
#   65     → whitespace (LF/CR/space/tab)
#   66     → invalid
var _pem_b64_table = 0;
var _pem_begin     = 0;
var _pem_end       = 0;
var _pem_inited    = 0;

fn _pem_init(): i64 {
    if (_pem_inited == 1) { return 0; }

    # Build the lookup table.
    _pem_b64_table = alloc(256);
    var i = 0;
    while (i < 256) {
        store8(_pem_b64_table + i, 66);   # default: invalid
        i = i + 1;
    }
    # A-Z → 0..25
    i = 0;
    while (i < 26) {
        store8(_pem_b64_table + 65 + i, i);
        i = i + 1;
    }
    # a-z → 26..51
    i = 0;
    while (i < 26) {
        store8(_pem_b64_table + 97 + i, 26 + i);
        i = i + 1;
    }
    # 0-9 → 52..61
    i = 0;
    while (i < 10) {
        store8(_pem_b64_table + 48 + i, 52 + i);
        i = i + 1;
    }
    # `+` → 62, `/` → 63
    store8(_pem_b64_table + 43, 62);
    store8(_pem_b64_table + 47, 63);
    # `=` → padding marker
    store8(_pem_b64_table + 61, 64);
    # whitespace: LF, CR, space, tab
    store8(_pem_b64_table + 10, 65);
    store8(_pem_b64_table + 13, 65);
    store8(_pem_b64_table + 32, 65);
    store8(_pem_b64_table + 9,  65);

    # Marker strings (use raw bytes, not C-strings — we compare
    # byte-by-byte over a known length).
    _pem_begin = alloc(PEM_BEGIN_CERT_LEN);
    var b = "-----BEGIN CERTIFICATE-----";
    i = 0;
    while (i < PEM_BEGIN_CERT_LEN) {
        store8(_pem_begin + i, load8(b + i) & 0xFF);
        i = i + 1;
    }
    _pem_end = alloc(PEM_END_CERT_LEN);
    var e = "-----END CERTIFICATE-----";
    i = 0;
    while (i < PEM_END_CERT_LEN) {
        store8(_pem_end + i, load8(e + i) & 0xFF);
        i = i + 1;
    }

    _pem_inited = 1;
    return 0;
}

# ================================================================
# Helpers
# ================================================================

# Compare `len` bytes at buf+pos against marker[0..len]. Returns 1
# if they match exactly, 0 otherwise. `pos + len` must be ≤ buf_len.
fn _pem_match_at(buf, buf_len, pos, marker, len): i64 {
    if (pos + len > buf_len) { return 0; }
    var i = 0;
    while (i < len) {
        if ((load8(buf + pos + i) & 0xFF) != (load8(marker + i) & 0xFF)) {
            return 0;
        }
        i = i + 1;
    }
    return 1;
}

# Search buf[start..buf_len] for the first occurrence of `marker`.
# Returns the absolute offset on success, -1 if not found.
fn _pem_find(buf, buf_len, start, marker, marker_len): i64 {
    if (marker_len <= 0) { return 0 - 1; }
    var i = start;
    var end = buf_len - marker_len + 1;
    while (i < end) {
        if (_pem_match_at(buf, buf_len, i, marker, marker_len) == 1) {
            return i;
        }
        i = i + 1;
    }
    return 0 - 1;
}

# Decode a single base64 body from pem[body_start..body_end) into
# out (must have room for the worst-case output). Returns the
# number of decoded bytes (> 0) on success, -1 on malformed input
# (invalid char, padding inside body, wrong padding count, zero
# body length). `out_max` is the maximum bytes the caller can
# accept in `out` — if the decoded size would exceed it, returns
# -1.
fn _pem_b64_decode(pem, body_start, body_end, out, out_max): i64 {
    var i = body_start;
    var op = 0;
    var quad[4];
    var quad_n = 0;
    var seen_pad = 0;

    while (i < body_end) {
        var c = load8(pem + i) & 0xFF;
        i = i + 1;
        var v = load8(_pem_b64_table + c) & 0xFF;

        if (v == 65) { continue; }      # whitespace: skip
        if (v == 66) { return 0 - 1; }   # invalid byte
        if (v == 64) {
            # Padding `=`. Allowed only in the final quad, after
            # at least 2 alphabet chars in that quad. Once we see
            # padding, only padding + whitespace may follow.
            if (seen_pad == 0) {
                if (quad_n < 2) { return 0 - 1; }
                seen_pad = 1;
            }
            quad_n = quad_n + 1;
            if (quad_n > 4) { return 0 - 1; }
            store8(&quad + quad_n - 1, 64);
        } else {
            if (seen_pad == 1) { return 0 - 1; }  # alphabet after pad
            quad_n = quad_n + 1;
            if (quad_n > 4) { return 0 - 1; }
            store8(&quad + quad_n - 1, v);
        }

        if (quad_n == 4) {
            # Emit. Determine how many output bytes (1/2/3) by
            # counting pads at the tail.
            var pads = 0;
            if ((load8(&quad + 3) & 0xFF) == 64) { pads = 1; }
            if ((load8(&quad + 2) & 0xFF) == 64) { pads = 2; }
            # All-pad or three-pad quads are malformed.
            if (pads == 2) {
                if ((load8(&quad + 3) & 0xFF) != 64) { return 0 - 1; }
            }
            var out_n = 3 - pads;
            if (op + out_n > out_max) { return 0 - 1; }

            var b0 = load8(&quad + 0) & 0xFF;
            var b1 = load8(&quad + 1) & 0xFF;
            var b2 = load8(&quad + 2) & 0xFF;
            var b3 = load8(&quad + 3) & 0xFF;
            store8(out + op, ((b0 << 2) | (b1 >> 4)) & 0xFF);
            if (out_n >= 2) {
                store8(out + op + 1, (((b1 & 0xF) << 4) | (b2 >> 2)) & 0xFF);
            }
            if (out_n >= 3) {
                store8(out + op + 2, (((b2 & 0x3) << 6) | b3) & 0xFF);
            }
            op = op + out_n;
            quad_n = 0;
            # If we saw padding, no more data allowed (only WS).
            if (seen_pad == 1) {
                while (i < body_end) {
                    var c2 = load8(pem + i) & 0xFF;
                    var v2 = load8(_pem_b64_table + c2) & 0xFF;
                    if (v2 != 65) { return 0 - 1; }
                    i = i + 1;
                }
            }
        }
    }

    # End of body. Must have consumed a whole number of quads.
    if (quad_n != 0) { return 0 - 1; }
    if (op == 0) { return 0 - 1; }   # empty body — reject

    return op;
}

# ================================================================
# Public surface
# ================================================================

# _into variant — caller-provided DER scratch pool.
fn pem_decode_certs_into(pem, pem_len, out_chain, max_certs,
                          der_pool, der_pool_size): i64 {
    _pem_init();

    if (pem_len < 0) { return 0 - 1; }
    if (max_certs <= 0) { return 0 - 1; }
    if (der_pool_size < 0) { return 0 - 1; }

    var count = 0;
    var pool_used = 0;
    var cur = 0;

    while (cur < pem_len) {
        # Find next BEGIN marker.
        var begin_off = _pem_find(pem, pem_len, cur, _pem_begin, PEM_BEGIN_CERT_LEN);
        if (begin_off < 0) {
            # No more BEGIN markers. Done — return whatever we
            # have. (count == 0 is still a malformation case: a
            # caller asking us to decode something with no BEGIN
            # at all should hear about it.)
            if (count == 0) { return 0 - 1; }
            return count;
        }

        var body_start = begin_off + PEM_BEGIN_CERT_LEN;

        # Find the matching END marker after body_start.
        var end_off = _pem_find(pem, pem_len, body_start, _pem_end, PEM_END_CERT_LEN);
        if (end_off < 0) { return 0 - 1; }   # unmatched BEGIN

        # Decode base64 between body_start and end_off into the
        # pool (sliced at pool_used).
        if (count >= max_certs) { return 0 - 1; }
        if (pool_used > der_pool_size) { return 0 - 1; }  # paranoid
        var pool_avail = der_pool_size - pool_used;
        var decoded = _pem_b64_decode(pem, body_start, end_off,
                                       der_pool + pool_used, pool_avail);
        if (decoded < 0) { return 0 - 1; }

        # Record entry in the chain array.
        store64(out_chain + count * 16,     der_pool + pool_used);
        store64(out_chain + count * 16 + 8, decoded);
        pool_used = pool_used + decoded;
        count = count + 1;

        cur = end_off + PEM_END_CERT_LEN;
    }

    if (count == 0) { return 0 - 1; }
    return count;
}

# Convenience wrapper — bump-allocates a DER pool sized at
# `pem_len` (strict upper bound: base64 expands by 4/3×, so DER ≤
# (3/4) × PEM, plus a small overhead for markers/whitespace; pem_len
# is conservative).
#
# NOTE (audit follow-up): the bump-allocator pool is freed only at
# program exit. Long-running consumers (kavach attestation loop)
# should call `pem_decode_certs_into` with their own pool to avoid
# slow allocator drift; see roadmap 3.5 "_into-shape variants".
fn pem_decode_certs(pem, pem_len, out_chain, max_certs): i64 {
    if (pem_len <= 0) { return 0 - 1; }
    var pool = alloc(pem_len);
    return pem_decode_certs_into(pem, pem_len, out_chain, max_certs,
                                   pool, pem_len);
}

# --- privkey.cyr ---

# privkey.cyr — private-key parsers (DER, PEM follows) for the EC +
# Ed25519 key types sigil already owns. First half of issue line
# item 4 (docs/development/issues/2026-05-28-cyrius-tls-arc-full-audit.md);
# the RSA private-key DER parser shipped in 3.6.3 as
# `rsa_privkey_from_der` (src/rsa.cyr, into an RSAK struct);
# `pem_decode_privkey` below still returns the SIG_PRIVKEY_RSA sentinel
# (emitting an RSAK struct from here is a later follow-up).
#
# Scope:
#   - Ed25519 PKCS#8 / RFC 8410 → 32-byte seed.
#   - ECDSA P-256 / P-384, SEC1 (RFC 5915) OR PKCS#8 (RFC 5208) →
#     the private scalar d as fixed-length big-endian (32 / 48 bytes),
#     matching the byte order ecdsa_p256_verify / ecdsa_p384_verify
#     (and the 3.5.9 sign path) consume.
#
# These extract raw key bytes only — no curve arithmetic, so the
# module depends solely on the DER walker in src/x509.cyr. Callers
# own the destination buffer and SHOULD declare it `secret var` so
# the parsed scalar/seed is zeroized on scope exit (cyrius 5.3.5+);
# the parser keeps no key material in locals beyond the direct copy
# into the caller's buffer.
#
# Security floor (CLAUDE.md § Security Hardening):
#   - Every der_walk return is bounds-checked (-1 → reject) before
#     the content offset is used; no raw offset arithmetic on
#     untrusted length fields.
#   - Algorithm / curve OIDs are full-byte matched (no prefix-only
#     acceptance) so a P-384 key cannot be misparsed as P-256.
#   - Fixed-length scalar copy left-pads short values and rejects
#     over-length ones — no buffer overrun on a malformed length.

# Private-key algorithm tags (returned by pem_decode_privkey in the
# PEM follow-up; defined here so the DER layer and the PEM layer
# share one vocabulary).
var SIG_PRIVKEY_UNKNOWN    = 0;
var SIG_PRIVKEY_ED25519    = 1;
var SIG_PRIVKEY_ECDSA_P256 = 2;
var SIG_PRIVKEY_ECDSA_P384 = 3;
var SIG_PRIVKEY_RSA        = 4;   # DER parser: rsa_privkey_from_der (3.6.3)

# DER [1] EXPLICIT context tag (SEC1 publicKey field). [0] (params)
# is DER_TAG_CONTEXT_0_EXP, already defined in src/x509.cyr.
var DER_TAG_CONTEXT_1_EXP = 0xA1;

# Compare the OID content at buf[off .. off+len) against a reference
# byte buffer. Returns 1 on full match, 0 otherwise.
fn _privkey_oid_eq(buf, off, len, ref, ref_len): i64 {
    if (len != ref_len) { return 0; }
    var i = 0;
    while (i < len) {
        if ((load8(buf + off + i) & 0xFF) != (load8(ref + i) & 0xFF)) { return 0; }
        i = i + 1;
    }
    return 1;
}

# Ed25519 OID 1.3.101.112 → content 2B 65 70.
fn _privkey_oid_is_ed25519(buf, off, len): i64 {
    var ref[3];
    store8(&ref + 0, 0x2B);
    store8(&ref + 1, 0x65);
    store8(&ref + 2, 0x70);
    return _privkey_oid_eq(buf, off, len, &ref, 3);
}

# id-ecPublicKey OID 1.2.840.10045.2.1 → content 2A 86 48 CE 3D 02 01.
fn _privkey_oid_is_ecpublickey(buf, off, len): i64 {
    var ref[7];
    store8(&ref + 0, 0x2A);
    store8(&ref + 1, 0x86);
    store8(&ref + 2, 0x48);
    store8(&ref + 3, 0xCE);
    store8(&ref + 4, 0x3D);
    store8(&ref + 5, 0x02);
    store8(&ref + 6, 0x01);
    return _privkey_oid_eq(buf, off, len, &ref, 7);
}

# Map a namedCurve OID to its bit-size (256 / 384), or -1.
#   prime256v1 / secp256r1: 1.2.840.10045.3.1.7 → 2A 86 48 CE 3D 03 01 07
#   secp384r1:              1.3.132.0.34         → 2B 81 04 00 22
fn _privkey_oid_curve(buf, off, len): i64 {
    var p256[8];
    store8(&p256 + 0, 0x2A);
    store8(&p256 + 1, 0x86);
    store8(&p256 + 2, 0x48);
    store8(&p256 + 3, 0xCE);
    store8(&p256 + 4, 0x3D);
    store8(&p256 + 5, 0x03);
    store8(&p256 + 6, 0x01);
    store8(&p256 + 7, 0x07);
    if (_privkey_oid_eq(buf, off, len, &p256, 8) == 1) { return 256; }
    var p384[5];
    store8(&p384 + 0, 0x2B);
    store8(&p384 + 1, 0x81);
    store8(&p384 + 2, 0x04);
    store8(&p384 + 3, 0x00);
    store8(&p384 + 4, 0x22);
    if (_privkey_oid_eq(buf, off, len, &p384, 5) == 1) { return 384; }
    return 0 - 1;
}

# Copy a big-endian field of `src_len` bytes into a fixed `dst_len`
# destination, left-padding with zeros. Rejects over-length input.
# Returns 0 on success, -1 on overflow.
fn _privkey_copy_be_fixed(dst, dst_len, src, src_off, src_len): i64 {
    if (src_len > dst_len) { return 0 - 1; }
    memset(dst, 0, dst_len);
    var pad = dst_len - src_len;
    var i = 0;
    while (i < src_len) {
        store8(dst + pad + i, load8(src + src_off + i) & 0xFF);
        i = i + 1;
    }
    return 0;
}

# ed25519_privkey_from_der — parse a PKCS#8 / RFC 8410 Ed25519
# private key into its 32-byte seed.
#
# Structure (RFC 8410 §7):
#   SEQUENCE {
#     INTEGER 0,                          -- version
#     SEQUENCE { OID 1.3.101.112 },       -- Ed25519 AlgorithmIdentifier
#     OCTET STRING {                      -- privateKey
#       OCTET STRING (32-byte seed)       -- CurvePrivateKey (inner)
#     }
#   }
#
# `seed_out` receives 32 bytes. Returns 0 on success, -1 on any
# tag / length / OID mismatch.
fn ed25519_privkey_from_der(der, der_len, seed_out): i64 {
    var seq_c = 0;
    var seq_n = 0;
    if (der_walk(der, der_len, 0, DER_TAG_SEQUENCE, &seq_c, &seq_n) < 0) { return 0 - 1; }

    var pos = seq_c;
    var vc = 0;
    var vn = 0;
    if (der_walk(der, der_len, pos, DER_TAG_INTEGER, &vc, &vn) < 0) { return 0 - 1; }
    pos = vn;

    # AlgorithmIdentifier SEQUENCE { OID }
    var ac = 0;
    var an = 0;
    if (der_walk(der, der_len, pos, DER_TAG_SEQUENCE, &ac, &an) < 0) { return 0 - 1; }
    var oc = 0;
    var on = 0;
    var oidlen = der_walk(der, der_len, ac, DER_TAG_OBJECT_ID, &oc, &on);
    if (oidlen < 0) { return 0 - 1; }
    if (_privkey_oid_is_ed25519(der, oc, oidlen) != 1) { return 0 - 1; }
    pos = an;

    # privateKey OCTET STRING, content = inner OCTET STRING (seed).
    var pc = 0;
    var pn = 0;
    if (der_walk(der, der_len, pos, DER_TAG_OCTET_STRING, &pc, &pn) < 0) { return 0 - 1; }
    var ic = 0;
    var inx = 0;
    var ilen = der_walk(der, der_len, pc, DER_TAG_OCTET_STRING, &ic, &inx);
    if (ilen != 32) { return 0 - 1; }
    memcpy(seed_out, der + ic, 32);
    return 0;
}

# _ec_privkey_parse — parse a SEC1 (RFC 5915) or PKCS#8 (RFC 5208)
# EC private key into the fixed-length big-endian scalar `d_out`.
# `d_len` is 32 (P-256) or 48 (P-384); `want_curve` is 256 / 384.
# The version INTEGER discriminates the two containers (SEC1 = 1,
# PKCS#8 = 0). Any embedded curve OID must match `want_curve`.
# Returns 0 on success, -1 on any mismatch.
fn _ec_privkey_parse(der, der_len, d_out, d_len, want_curve): i64 {
    var seq_c = 0;
    var seq_n = 0;
    if (der_walk(der, der_len, 0, DER_TAG_SEQUENCE, &seq_c, &seq_n) < 0) { return 0 - 1; }

    var pos = seq_c;
    var vc = 0;
    var vn = 0;
    var vlen = der_walk(der, der_len, pos, DER_TAG_INTEGER, &vc, &vn);
    if (vlen < 1) { return 0 - 1; }
    var version = load8(der + vc) & 0xFF;
    pos = vn;

    if (version == 1) {
        # ---- SEC1 ECPrivateKey ----
        # OCTET STRING privateKey (d, big-endian fixed length)
        var oc = 0;
        var onx = 0;
        var olen = der_walk(der, der_len, pos, DER_TAG_OCTET_STRING, &oc, &onx);
        if (olen < 0) { return 0 - 1; }
        if (_privkey_copy_be_fixed(d_out, d_len, der, oc, olen) != 0) { return 0 - 1; }
        pos = onx;

        # Optional [0] EXPLICIT parameters { namedCurve OID }. If
        # present, it must match the requested curve.
        if (pos < seq_n) {
            var tag = load8(der + pos) & 0xFF;
            if (tag == DER_TAG_CONTEXT_0_EXP) {
                var cc = 0;
                var cn = 0;
                if (der_walk(der, der_len, pos, DER_TAG_CONTEXT_0_EXP, &cc, &cn) < 0) { return 0 - 1; }
                var oidc = 0;
                var oidn = 0;
                var oidl = der_walk(der, der_len, cc, DER_TAG_OBJECT_ID, &oidc, &oidn);
                if (oidl < 0) { return 0 - 1; }
                if (_privkey_oid_curve(der, oidc, oidl) != want_curve) { return 0 - 1; }
            }
        }
        return 0;
    }

    # ---- PKCS#8 PrivateKeyInfo (version 0) ----
    # privateKeyAlgorithm SEQUENCE { OID id-ecPublicKey, OID curve }
    var ac = 0;
    var an = 0;
    if (der_walk(der, der_len, pos, DER_TAG_SEQUENCE, &ac, &an) < 0) { return 0 - 1; }
    var o1c = 0;
    var o1n = 0;
    var o1l = der_walk(der, der_len, ac, DER_TAG_OBJECT_ID, &o1c, &o1n);
    if (o1l < 0) { return 0 - 1; }
    if (_privkey_oid_is_ecpublickey(der, o1c, o1l) != 1) { return 0 - 1; }
    var o2c = 0;
    var o2n = 0;
    var o2l = der_walk(der, der_len, o1n, DER_TAG_OBJECT_ID, &o2c, &o2n);
    if (o2l < 0) { return 0 - 1; }
    if (_privkey_oid_curve(der, o2c, o2l) != want_curve) { return 0 - 1; }
    pos = an;

    # privateKey OCTET STRING wraps an inner SEC1 ECPrivateKey.
    var pc = 0;
    var pn = 0;
    if (der_walk(der, der_len, pos, DER_TAG_OCTET_STRING, &pc, &pn) < 0) { return 0 - 1; }
    var isc = 0;
    var isn = 0;
    if (der_walk(der, der_len, pc, DER_TAG_SEQUENCE, &isc, &isn) < 0) { return 0 - 1; }
    var ip = isc;
    var ivc = 0;
    var ivn = 0;
    if (der_walk(der, der_len, ip, DER_TAG_INTEGER, &ivc, &ivn) < 0) { return 0 - 1; }
    ip = ivn;
    var idc = 0;
    var idn = 0;
    var idl = der_walk(der, der_len, ip, DER_TAG_OCTET_STRING, &idc, &idn);
    if (idl < 0) { return 0 - 1; }
    if (_privkey_copy_be_fixed(d_out, d_len, der, idc, idl) != 0) { return 0 - 1; }
    return 0;
}

# ecdsa_p256_privkey_from_der — parse a SEC1 or PKCS#8 P-256 private
# key into the 32-byte big-endian scalar `d_out`. Validates the
# curve is prime256v1. Returns 0 on success, -1 on error.
fn ecdsa_p256_privkey_from_der(der, der_len, d_out): i64 {
    return _ec_privkey_parse(der, der_len, d_out, 32, 256);
}

# ecdsa_p384_privkey_from_der — parse a SEC1 or PKCS#8 P-384 private
# key into the 48-byte big-endian scalar `d_out`. Validates the
# curve is secp384r1. Returns 0 on success, -1 on error.
fn ecdsa_p384_privkey_from_der(der, der_len, d_out): i64 {
    return _ec_privkey_parse(der, der_len, d_out, 48, 384);
}

# ================================================================
# PEM layer — pem_decode_privkey
# ================================================================
# Reuses the base64 table + decoder + marker search from src/pem.cyr
# (`_pem_init`, `_pem_find`, `_pem_b64_decode`), which are generic
# over the marker bytes. Recognizes the three private-key PEM labels:
#   -----BEGIN EC PRIVATE KEY-----    SEC1 (RFC 5915)
#   -----BEGIN PRIVATE KEY-----       PKCS#8 (RFC 5208) — any algo
#   -----BEGIN RSA PRIVATE KEY-----   PKCS#1 RSA
# RSA returns the dedicated `0 - SIG_PRIVKEY_RSA` sentinel (vs -1 for a
# malformed blob). The DER parse itself shipped in 3.6.3
# (`rsa_privkey_from_der`, src/rsa.cyr) into an RSAK struct; a caller
# that sees this sentinel base64-decodes the PEM body and calls it.
# (Having `pem_decode_privkey` emit the RSAK struct directly is a later
# follow-up — its EC/Ed25519 contract decodes into a single scalar.)

# rsaEncryption OID 1.2.840.113549.1.1.1 → content 2A 86 48 86 F7 0D 01 01 01.
fn _privkey_oid_is_rsa(buf, off, len): i64 {
    var ref[9];
    store8(&ref + 0, 0x2A);
    store8(&ref + 1, 0x86);
    store8(&ref + 2, 0x48);
    store8(&ref + 3, 0x86);
    store8(&ref + 4, 0xF7);
    store8(&ref + 5, 0x0D);
    store8(&ref + 6, 0x01);
    store8(&ref + 7, 0x01);
    store8(&ref + 8, 0x01);
    return _privkey_oid_eq(buf, off, len, &ref, 9);
}

# Copy `len` bytes of a marker string literal into a destination buffer.
fn _privkey_load_marker(dst, s, len): i64 {
    var i = 0;
    while (i < len) {
        store8(dst + i, load8(s + i) & 0xFF);
        i = i + 1;
    }
    return 0;
}

# Detect the named curve of a SEC1 ECPrivateKey from its [0]
# parameters field. Returns 256 / 384, or -1 if absent / unknown.
fn _ec_privkey_detect_curve(der, der_len): i64 {
    var seq_c = 0;
    var seq_n = 0;
    if (der_walk(der, der_len, 0, DER_TAG_SEQUENCE, &seq_c, &seq_n) < 0) { return 0 - 1; }
    var pos = seq_c;
    var vc = 0;
    var vn = 0;
    if (der_walk(der, der_len, pos, DER_TAG_INTEGER, &vc, &vn) < 0) { return 0 - 1; }
    pos = vn;
    var oc = 0;
    var onx = 0;
    if (der_walk(der, der_len, pos, DER_TAG_OCTET_STRING, &oc, &onx) < 0) { return 0 - 1; }
    pos = onx;
    if (pos >= seq_n) { return 0 - 1; }
    if ((load8(der + pos) & 0xFF) != DER_TAG_CONTEXT_0_EXP) { return 0 - 1; }
    var cc = 0;
    var cn = 0;
    if (der_walk(der, der_len, pos, DER_TAG_CONTEXT_0_EXP, &cc, &cn) < 0) { return 0 - 1; }
    var oidc = 0;
    var oidn = 0;
    var oidl = der_walk(der, der_len, cc, DER_TAG_OBJECT_ID, &oidc, &oidn);
    if (oidl < 0) { return 0 - 1; }
    return _privkey_oid_curve(der, oidc, oidl);
}

# Detect the algorithm of a PKCS#8 PrivateKeyInfo from its
# privateKeyAlgorithm OID(s). Returns a SIG_PRIVKEY_* tag.
fn _privkey_pkcs8_algo(der, der_len): i64 {
    var seq_c = 0;
    var seq_n = 0;
    if (der_walk(der, der_len, 0, DER_TAG_SEQUENCE, &seq_c, &seq_n) < 0) { return SIG_PRIVKEY_UNKNOWN; }
    var pos = seq_c;
    var vc = 0;
    var vn = 0;
    if (der_walk(der, der_len, pos, DER_TAG_INTEGER, &vc, &vn) < 0) { return SIG_PRIVKEY_UNKNOWN; }
    pos = vn;
    var ac = 0;
    var an = 0;
    if (der_walk(der, der_len, pos, DER_TAG_SEQUENCE, &ac, &an) < 0) { return SIG_PRIVKEY_UNKNOWN; }
    var o1c = 0;
    var o1n = 0;
    var o1l = der_walk(der, der_len, ac, DER_TAG_OBJECT_ID, &o1c, &o1n);
    if (o1l < 0) { return SIG_PRIVKEY_UNKNOWN; }
    if (_privkey_oid_is_ed25519(der, o1c, o1l) == 1) { return SIG_PRIVKEY_ED25519; }
    if (_privkey_oid_is_rsa(der, o1c, o1l) == 1) { return SIG_PRIVKEY_RSA; }
    if (_privkey_oid_is_ecpublickey(der, o1c, o1l) == 1) {
        var o2c = 0;
        var o2n = 0;
        var o2l = der_walk(der, der_len, o1n, DER_TAG_OBJECT_ID, &o2c, &o2n);
        if (o2l < 0) { return SIG_PRIVKEY_UNKNOWN; }
        var curve = _privkey_oid_curve(der, o2c, o2l);
        if (curve == 256) { return SIG_PRIVKEY_ECDSA_P256; }
        if (curve == 384) { return SIG_PRIVKEY_ECDSA_P384; }
        return SIG_PRIVKEY_UNKNOWN;
    }
    return SIG_PRIVKEY_UNKNOWN;
}

# pem_decode_privkey — decode a PEM private key, auto-detecting the
# label and algorithm. Writes the raw scalar/seed to `key_out`
# (`key_max` must be ≥ 48 to hold the largest, P-384) and the
# SIG_PRIVKEY_* tag to `*out_algo`.
#
# Returns:
#   32 / 48        — number of key bytes written (success).
#   0 - SIG_PRIVKEY_RSA  — RSA recognized but not yet supported
#                          (parser lands in 3.5.10); *out_algo = RSA.
#   -1             — malformed / unknown / unsupported curve.
#
# The DER scratch is bump-allocated (sized to pem_len, a strict upper
# bound). Long-running consumers wanting allocator hygiene should
# decode DER themselves and call the *_from_der parsers directly —
# same caveat as pem_decode_certs (see its audit note).
fn pem_decode_privkey(pem, pem_len, key_out, key_max, out_algo): i64 {
    _pem_init();
    store64(out_algo, SIG_PRIVKEY_UNKNOWN);
    if (pem_len <= 0) { return 0 - 1; }
    if (key_max < 48) { return 0 - 1; }

    # Build the three BEGIN/END marker pairs.
    var b_ec[30];
    var e_ec[28];
    _privkey_load_marker(&b_ec, "-----BEGIN EC PRIVATE KEY-----", 30);
    _privkey_load_marker(&e_ec, "-----END EC PRIVATE KEY-----", 28);
    var b_rsa[31];
    var e_rsa[29];
    _privkey_load_marker(&b_rsa, "-----BEGIN RSA PRIVATE KEY-----", 31);
    _privkey_load_marker(&e_rsa, "-----END RSA PRIVATE KEY-----", 29);
    var b_p8[27];
    var e_p8[25];
    _privkey_load_marker(&b_p8, "-----BEGIN PRIVATE KEY-----", 27);
    _privkey_load_marker(&e_p8, "-----END PRIVATE KEY-----", 25);

    # Detect which label is present. EC / RSA labels are distinct
    # substrings from the bare PKCS#8 label, so order is for clarity
    # only (no false-match risk). kind: 1=SEC1, 2=RSA(PKCS#1), 3=PKCS#8.
    var kind = 0;
    var blen = 0;
    var emk = 0;
    var elen = 0;
    var bpos = _pem_find(pem, pem_len, 0, &b_ec, 30);
    if (bpos >= 0) {
        kind = 1; blen = 30; emk = &e_ec; elen = 28;
    } else {
        bpos = _pem_find(pem, pem_len, 0, &b_rsa, 31);
        if (bpos >= 0) {
            kind = 2; blen = 31; emk = &e_rsa; elen = 29;
        } else {
            bpos = _pem_find(pem, pem_len, 0, &b_p8, 27);
            if (bpos >= 0) { kind = 3; blen = 27; emk = &e_p8; elen = 25; }
        }
    }
    if (kind == 0) { return 0 - 1; }

    var body_start = bpos + blen;
    var end_off = _pem_find(pem, pem_len, body_start, emk, elen);
    if (end_off < 0) { return 0 - 1; }

    # Base64-decode the body into a bump-allocated DER buffer.
    var pool = alloc(pem_len);
    var der_len = _pem_b64_decode(pem, body_start, end_off, pool, pem_len);
    if (der_len < 0) { return 0 - 1; }

    if (kind == 2) {
        # PKCS#1 RSA — recognized, parser arrives in 3.5.10.
        store64(out_algo, SIG_PRIVKEY_RSA);
        return 0 - SIG_PRIVKEY_RSA;
    }

    if (kind == 1) {
        # SEC1 EC — detect curve, dispatch to the typed parser.
        var curve = _ec_privkey_detect_curve(pool, der_len);
        if (curve == 256) {
            if (ecdsa_p256_privkey_from_der(pool, der_len, key_out) != 0) { return 0 - 1; }
            store64(out_algo, SIG_PRIVKEY_ECDSA_P256);
            return 32;
        }
        if (curve == 384) {
            if (ecdsa_p384_privkey_from_der(pool, der_len, key_out) != 0) { return 0 - 1; }
            store64(out_algo, SIG_PRIVKEY_ECDSA_P384);
            return 48;
        }
        return 0 - 1;
    }

    # kind == 3: PKCS#8 — detect the algorithm from the algid.
    var algo = _privkey_pkcs8_algo(pool, der_len);
    if (algo == SIG_PRIVKEY_ED25519) {
        if (ed25519_privkey_from_der(pool, der_len, key_out) != 0) { return 0 - 1; }
        store64(out_algo, SIG_PRIVKEY_ED25519);
        return 32;
    }
    if (algo == SIG_PRIVKEY_ECDSA_P256) {
        if (ecdsa_p256_privkey_from_der(pool, der_len, key_out) != 0) { return 0 - 1; }
        store64(out_algo, SIG_PRIVKEY_ECDSA_P256);
        return 32;
    }
    if (algo == SIG_PRIVKEY_ECDSA_P384) {
        if (ecdsa_p384_privkey_from_der(pool, der_len, key_out) != 0) { return 0 - 1; }
        store64(out_algo, SIG_PRIVKEY_ECDSA_P384);
        return 48;
    }
    if (algo == SIG_PRIVKEY_RSA) {
        store64(out_algo, SIG_PRIVKEY_RSA);
        return 0 - SIG_PRIVKEY_RSA;
    }
    return 0 - 1;
}

# --- rsa.cyr ---

# rsa.cyr -- RSA signature VERIFICATION, PKCS#1 v1.5 (RFC 8017 §8.2.2 /
# §9.2), SHA-256 and SHA-384.
#
# SCOPE: verification only. RSA verify recovers `m = s^e mod n` from the
# signature `s` using the PUBLIC key (n, e) and checks the PKCS#1 v1.5
# encoding. Every operand is public, so:
#   * no constant-time requirement (no secret to leak; the bignum
#     engine's data-dependent reduction is fine here);
#   * not on the parallel batch-verify path, so the static scratch
#     below is plain single-threaded (see src/bignum.cyr header).
# RSA *signing* (private exponent) is a separate, later bite and MUST
# add blinding + a constant-time ladder; it cannot reuse `bn_modexp`.
#
# Interop note: TLS 1.3 / X.509 RSA certs are overwhelmingly
# `rsaEncryption` PKCS#1 v1.5 (and PSS); this lands the v1.5 verify
# path first (the load-bearing one), per the roadmap. PSS is a
# follow-on bite. Built on src/bignum.cyr (modexp) + sha256/sha384.

# DigestInfo working scratch + the RSA bignum buffers. n_len <= 512
# bytes (RSA-4096); limbs = ceil(n_len/8) <= 64.
var _rsa_n[512];
var _rsa_s[512];
var _rsa_m[512];
var _rsa_em[512];           # recovered encoded message (k bytes)
var _rsa_expected[512];     # reconstructed expected EM
var _rsa_hash[64];          # message digest (32 or 48)
var _rsa_di[24];            # DigestInfo AlgorithmIdentifier prefix (19)

# PKCS#1 v1.5 DigestInfo prefixes (RFC 8017 §9.2 note 1): the DER
# `SEQUENCE { SEQUENCE { OID, NULL }, OCTET STRING <hash> }` header that
# precedes the raw digest. Returns the prefix length (19).
fn _rsa_di_sha256(buf): i64 {
    store8(buf + 0, 0x30);  store8(buf + 1, 0x31);  store8(buf + 2, 0x30);
    store8(buf + 3, 0x0d);  store8(buf + 4, 0x06);  store8(buf + 5, 0x09);
    store8(buf + 6, 0x60);  store8(buf + 7, 0x86);  store8(buf + 8, 0x48);
    store8(buf + 9, 0x01);  store8(buf + 10, 0x65); store8(buf + 11, 0x03);
    store8(buf + 12, 0x04); store8(buf + 13, 0x02); store8(buf + 14, 0x01);
    store8(buf + 15, 0x05); store8(buf + 16, 0x00); store8(buf + 17, 0x04);
    store8(buf + 18, 0x20);
    return 19;
}

fn _rsa_di_sha384(buf): i64 {
    store8(buf + 0, 0x30);  store8(buf + 1, 0x41);  store8(buf + 2, 0x30);
    store8(buf + 3, 0x0d);  store8(buf + 4, 0x06);  store8(buf + 5, 0x09);
    store8(buf + 6, 0x60);  store8(buf + 7, 0x86);  store8(buf + 8, 0x48);
    store8(buf + 9, 0x01);  store8(buf + 10, 0x65); store8(buf + 11, 0x03);
    store8(buf + 12, 0x04); store8(buf + 13, 0x02); store8(buf + 14, 0x02);
    store8(buf + 15, 0x05); store8(buf + 16, 0x00); store8(buf + 17, 0x04);
    store8(buf + 18, 0x30);
    return 19;
}

# EMSA-PKCS1-v1.5 encode (RFC 8017 §9.2): write EM = 0x00 01 PS 00 T
# into `out` (k bytes), where T = prefix || hash and PS is (k - 3 -
# |T|) bytes of 0xFF (>= 8 required). Returns 0, or -1 if k is too
# small. Used by both verify (rebuild-and-compare) and sign.
fn _rsa_emsa_encode(out, k, prefix, prefix_len, hash, hash_len): i64 {
    var tlen = prefix_len + hash_len;
    if (k < tlen + 11) { return 0 - 1; }
    var ps_len = k - 3 - tlen;
    store8(out + 0, 0x00);
    store8(out + 1, 0x01);
    var i = 0;
    while (i < ps_len) { store8(out + 2 + i, 0xFF); i = i + 1; }
    store8(out + 2 + ps_len, 0x00);
    memcpy(out + 3 + ps_len, prefix, prefix_len);
    memcpy(out + 3 + ps_len + prefix_len, hash, hash_len);
    return 0;
}

# Core PKCS#1 v1.5 verify. n_be/e_be: public key as big-endian bytes.
# prefix/prefix_len: the DigestInfo prefix. hash/hash_len: the message
# digest. sig/sig_len: the signature. Returns 1 iff valid, else 0.
fn _rsa_pkcs1v15_check(n_be, n_len, e_be, e_len, prefix, prefix_len, hash, hash_len, sig, sig_len): i64 {
    # Length sanity (RFC 8017 §8.2.2 step 1): signature is exactly k
    # octets, and k must fit our buffers.
    if (sig_len != n_len) { return 0; }
    if (n_len > 512) { return 0; }
    var limbs = (n_len + 7) / 8;

    bn_from_be(&_rsa_n, limbs, n_be, n_len);
    bn_from_be(&_rsa_s, limbs, sig, sig_len);

    # RFC 8017 §8.2.2 / §5.2.1: reject s >= n (out of range).
    if (bn_cmp(&_rsa_s, &_rsa_n, limbs) >= 0) { return 0; }

    # m = s^e mod n  (RSAVP1), then I2OSP to k octets.
    bn_modexp(&_rsa_m, &_rsa_s, e_be, e_len, &_rsa_n, limbs);
    bn_to_be(&_rsa_em, n_len, &_rsa_m, limbs);

    # Reconstruct the expected EM and compare all k octets (RFC 8017
    # §9.2). Operands are public, but reuse the OR-accumulating
    # constant-time compare for a single audit surface.
    if (_rsa_emsa_encode(&_rsa_expected, n_len, prefix, prefix_len, hash, hash_len) < 0) { return 0; }
    return ct_eq_bytes(&_rsa_em, &_rsa_expected, n_len);
}

# Verify an RSASSA-PKCS1-v1.5 signature over SHA-256(msg) with public
# key (n_be, e_be). Returns 1 iff valid, else 0.
fn rsa_pkcs1v15_verify_sha256(n_be, n_len, e_be, e_len, msg, msg_len, sig, sig_len): i64 {
    sha256(msg, msg_len, &_rsa_hash);
    var pl = _rsa_di_sha256(&_rsa_di);
    return _rsa_pkcs1v15_check(n_be, n_len, e_be, e_len, &_rsa_di, pl, &_rsa_hash, 32, sig, sig_len);
}

# Verify an RSASSA-PKCS1-v1.5 signature over SHA-384(msg).
fn rsa_pkcs1v15_verify_sha384(n_be, n_len, e_be, e_len, msg, msg_len, sig, sig_len): i64 {
    sha384(msg, msg_len, &_rsa_hash);
    var pl = _rsa_di_sha384(&_rsa_di);
    return _rsa_pkcs1v15_check(n_be, n_len, e_be, e_len, &_rsa_di, pl, &_rsa_hash, 48, sig, sig_len);
}

# ================================================================
# Public-key DER parsing (3.6.3a)
# ================================================================
# Reuses the audited ASN.1/DER walker from src/x509.cyr (`der_walk`,
# `DER_TAG_*`, `_oid_eq`) rather than re-implementing a parser on
# untrusted input. x509.cyr is included before rsa.cyr.

# rsaEncryption OID content (1.2.840.113549.1.1.1), i.e. the 9 bytes
# after the `06 09` tag/length.
fn _rsa_oid_is_rsaencryption(buf, off, len): i64 {
    var ref[9];
    store8(&ref + 0, 0x2a); store8(&ref + 1, 0x86); store8(&ref + 2, 0x48);
    store8(&ref + 3, 0x86); store8(&ref + 4, 0xf7); store8(&ref + 5, 0x0d);
    store8(&ref + 6, 0x01); store8(&ref + 7, 0x01); store8(&ref + 8, 0x01);
    return _oid_eq(buf, off, len, &ref, 9);
}

# Copy a DER INTEGER's magnitude (stripping the leading 0x00 sign byte,
# if present) from buf[pos .. pos+len) into `out`, left-aligned. Returns
# the magnitude length, or -1 if it exceeds `out_max`.
fn _rsa_int_magnitude(buf, pos, len, out, out_max): i64 {
    var p = pos;
    var l = len;
    var go = 1;
    while (go == 1) {
        if (l > 1) {
            if ((load8(buf + p) & 0xFF) == 0) { p = p + 1; l = l - 1; }
            else { go = 0; }
        } else { go = 0; }
    }
    if (l > out_max) { return 0 - 1; }
    memcpy(out, buf + p, l);
    return l;
}

# Parse an RSA public key from DER. Accepts either a bare PKCS#1
# `RSAPublicKey` (SEQUENCE { INTEGER n, INTEGER e }) or an X.509
# SubjectPublicKeyInfo (SEQUENCE { SEQUENCE { rsaEncryption OID, NULL },
# BIT STRING { RSAPublicKey } }). Writes the modulus magnitude to
# `n_out` (big-endian, left-aligned) and the exponent to `e_out`;
# returns the modulus length (> 0) and writes the exponent length to
# `*e_len_out`. Returns -1 on any tag/length/OID mismatch (every
# `der_walk` is bounds-checked).
fn rsa_pubkey_from_der(der, der_len, n_out, n_max, e_out, e_max, e_len_out): i64 {
    var seq_c = 0;
    var seq_n = 0;
    if (der_walk(der, der_len, 0, DER_TAG_SEQUENCE, &seq_c, &seq_n) < 0) { return 0 - 1; }

    # `npos` = position of the INTEGER n (start of the RSAPublicKey body).
    var npos = 0 - 1;

    # Discriminate by the first inner element: INTEGER -> bare PKCS#1;
    # SEQUENCE -> SPKI (AlgorithmIdentifier).
    var ic = 0;
    var icn = 0;
    if (der_walk(der, der_len, seq_c, DER_TAG_INTEGER, &ic, &icn) >= 0) {
        npos = seq_c;
    } else {
        var ac = 0;
        var an = 0;
        if (der_walk(der, der_len, seq_c, DER_TAG_SEQUENCE, &ac, &an) < 0) { return 0 - 1; }
        var oc = 0;
        var on = 0;
        var oidlen = der_walk(der, der_len, ac, DER_TAG_OBJECT_ID, &oc, &on);
        if (oidlen < 0) { return 0 - 1; }
        if (_rsa_oid_is_rsaencryption(der, oc, oidlen) != 1) { return 0 - 1; }
        # BIT STRING (subjectPublicKey) follows the AlgorithmIdentifier.
        var bc = 0;
        var bn = 0;
        var bitlen = der_walk(der, der_len, an, DER_TAG_BIT_STRING, &bc, &bn);
        if (bitlen < 1) { return 0 - 1; }
        # First content byte is the unused-bits count; must be 0 for a
        # byte-aligned key. The RSAPublicKey SEQUENCE follows it.
        if ((load8(der + bc) & 0xFF) != 0) { return 0 - 1; }
        var rc = 0;
        var rn = 0;
        if (der_walk(der, der_len, bc + 1, DER_TAG_SEQUENCE, &rc, &rn) < 0) { return 0 - 1; }
        npos = rc;
    }

    # RSAPublicKey body: INTEGER n, INTEGER e.
    var nc = 0;
    var nn = 0;
    var nlen = der_walk(der, der_len, npos, DER_TAG_INTEGER, &nc, &nn);
    if (nlen < 0) { return 0 - 1; }
    var ec2 = 0;
    var en2 = 0;
    var elen = der_walk(der, der_len, nn, DER_TAG_INTEGER, &ec2, &en2);
    if (elen < 0) { return 0 - 1; }

    var nmag = _rsa_int_magnitude(der, nc, nlen, n_out, n_max);
    if (nmag < 0) { return 0 - 1; }
    var emag = _rsa_int_magnitude(der, ec2, elen, e_out, e_max);
    if (emag < 0) { return 0 - 1; }
    store64(e_len_out, emag);
    return nmag;
}

# ================================================================
# Private-key DER parsing (3.6.3b)
# ================================================================
# RSA private key, parsed into a caller-provided `RSAK_SIZE`-byte
# struct. Components are big-endian, left-aligned in fixed slots (sized
# for RSA-4096), each with a length field. The struct holds SECRET
# material (d, p, q, dp, dq, qinv) — the caller MUST zeroize it after
# use (e.g. wrap in `secret var` or memset before free).
var RSAK_N    = 0;       # 512 bytes (modulus)
var RSAK_E    = 512;     # 16  (public exponent)
var RSAK_D    = 528;     # 512 (private exponent)        [secret]
var RSAK_P    = 1040;    # 256 (prime1)                  [secret]
var RSAK_Q    = 1296;    # 256 (prime2)                  [secret]
var RSAK_DP   = 1552;    # 256 (d mod p-1)               [secret]
var RSAK_DQ   = 1808;    # 256 (d mod q-1)               [secret]
var RSAK_QINV = 2064;    # 256 (q^-1 mod p)              [secret]
var RSAK_NLEN = 2320;
var RSAK_ELEN = 2328;
var RSAK_DLEN = 2336;
var RSAK_PLEN = 2344;
var RSAK_QLEN = 2352;
var RSAK_DPLEN = 2360;
var RSAK_DQLEN = 2368;
var RSAK_QINVLEN = 2376;
var RSAK_SIZE = 2384;

# Walk the next DER INTEGER at *pos_ptr, store its magnitude (leading
# 0x00 stripped) into key+slot_off (cap slot_max), record the length at
# key+len_off, and advance *pos_ptr past it. Returns 0 / -1.
fn _rsa_take_int(der, der_len, pos_ptr, key, slot_off, slot_max, len_off): i64 {
    var c = 0;
    var nx = 0;
    var L = der_walk(der, der_len, load64(pos_ptr), DER_TAG_INTEGER, &c, &nx);
    if (L < 0) { return 0 - 1; }
    var mag = _rsa_int_magnitude(der, c, L, key + slot_off, slot_max);
    if (mag < 0) { return 0 - 1; }
    store64(key + len_off, mag);
    store64(pos_ptr, nx);
    return 0;
}

# Parse an RSA private key from DER into `key` (RSAK_SIZE bytes).
# Accepts a bare PKCS#1 `RSAPrivateKey` (RFC 8017 §A.1.2) or a PKCS#8
# `PrivateKeyInfo` wrapper (rsaEncryption). Extracts the 8 CRT
# components (n, e, d, p, q, dp, dq, qinv). Returns 0 on success, -1 on
# any tag/length/OID mismatch. `key` holds secret material — caller
# zeroizes.
fn rsa_privkey_from_der(der, der_len, key): i64 {
    var sc = 0;
    var sn = 0;
    if (der_walk(der, der_len, 0, DER_TAG_SEQUENCE, &sc, &sn) < 0) { return 0 - 1; }

    # First element is the version INTEGER. The element AFTER it
    # discriminates: INTEGER (modulus) => bare PKCS#1; SEQUENCE
    # (AlgorithmIdentifier) => PKCS#8.
    var vc = 0;
    var vn = 0;
    if (der_walk(der, der_len, sc, DER_TAG_INTEGER, &vc, &vn) < 0) { return 0 - 1; }

    var body = 0 - 1;       # offset of the RSAPrivateKey's version INTEGER
    var tc = 0;
    var tn = 0;
    if (der_walk(der, der_len, vn, DER_TAG_INTEGER, &tc, &tn) >= 0) {
        body = sc;          # bare PKCS#1: RSAPrivateKey starts at the outer version
    } else {
        var ac = 0;
        var an = 0;
        if (der_walk(der, der_len, vn, DER_TAG_SEQUENCE, &ac, &an) < 0) { return 0 - 1; }
        var oc = 0;
        var on = 0;
        var oidlen = der_walk(der, der_len, ac, DER_TAG_OBJECT_ID, &oc, &on);
        if (oidlen < 0) { return 0 - 1; }
        if (_rsa_oid_is_rsaencryption(der, oc, oidlen) != 1) { return 0 - 1; }
        var kc = 0;
        var kn = 0;
        if (der_walk(der, der_len, an, DER_TAG_OCTET_STRING, &kc, &kn) < 0) { return 0 - 1; }
        var ic = 0;
        var inn = 0;
        if (der_walk(der, der_len, kc, DER_TAG_SEQUENCE, &ic, &inn) < 0) { return 0 - 1; }
        body = ic;
    }

    # Skip the RSAPrivateKey version, then take the 8 components in order.
    var pos = body;
    var c = 0;
    var nx = 0;
    if (der_walk(der, der_len, pos, DER_TAG_INTEGER, &c, &nx) < 0) { return 0 - 1; }
    pos = nx;
    if (_rsa_take_int(der, der_len, &pos, key, RSAK_N,    512, RSAK_NLEN)    < 0) { return 0 - 1; }
    if (_rsa_take_int(der, der_len, &pos, key, RSAK_E,    16,  RSAK_ELEN)    < 0) { return 0 - 1; }
    if (_rsa_take_int(der, der_len, &pos, key, RSAK_D,    512, RSAK_DLEN)    < 0) { return 0 - 1; }
    if (_rsa_take_int(der, der_len, &pos, key, RSAK_P,    256, RSAK_PLEN)    < 0) { return 0 - 1; }
    if (_rsa_take_int(der, der_len, &pos, key, RSAK_Q,    256, RSAK_QLEN)    < 0) { return 0 - 1; }
    if (_rsa_take_int(der, der_len, &pos, key, RSAK_DP,   256, RSAK_DPLEN)   < 0) { return 0 - 1; }
    if (_rsa_take_int(der, der_len, &pos, key, RSAK_DQ,   256, RSAK_DQLEN)   < 0) { return 0 - 1; }
    if (_rsa_take_int(der, der_len, &pos, key, RSAK_QINV, 256, RSAK_QINVLEN) < 0) { return 0 - 1; }
    return 0;
}

# ================================================================
# PKCS#1 v1.5 signing (3.6.3d)
# ================================================================
# RSASSA-PKCS1-v1.5 (RFC 8017 §8.2.1), deterministic. The signature is
# `s = m^d mod n` over the secret exponent `d`, computed with the
# constant-time Montgomery ladder `bn_mont_modexp` (NOT the public
# `bn_modexp`). A **verify-after-sign** step recomputes `s^e mod n`
# (public exponent, fast) and refuses to release `s` unless it equals
# `m` — the Bellcore fault-attack guard (a faulty modexp could
# otherwise leak the key).
#
# Hardened in 3.6.4: **base blinding** (`s = (m·r^e)^d·r^-1 mod n`, fresh
# random r per signature — decorrelates the secret modexp from the key)
# and **CRT** (sign mod p,q then recombine, ~4×; the verify-after-sign
# guards the CRT fault surface). `_rsa_sign_*` / `_rsa_blind_*` /
# `_rsa_crt_*` hold message/signature-derived values; the secret is `d`
# (and p, q, dp, dq) inside `key` (caller zeroizes).
var _rsa_sign_em[512];
var _rsa_sign_m[512];
var _rsa_sign_s[512];
var _rsa_sign_chk[512];
var _rsa_sign_n[512];       # modulus as a bignum (little-endian limbs)

# Base-blinding scratch (3.6.4). The blinding factor r is a fresh
# per-signature random; blinding decorrelates the secret-exponent
# modexp's timing/power from the key (DPA / timing-correlation
# defense). The final signature is unchanged (deterministic v1.5).
var _rsa_blind_rand[512];   # raw CSPRNG bytes
var _rsa_blind_r[512];      # r in [1, n)
var _rsa_blind_rinv[512];   # r^-1 mod n
var _rsa_blind_re[512];     # r^e mod n
var _rsa_blind_mb[512];     # blinded message m * r^e mod n
var _rsa_blind_sb[512];     # blinded signature (m*r^e)^d mod n
var _rsa_blind_prod[1024];  # 2*limbs multiply scratch

# Generate a fresh blinding pair (r, r^-1 mod n) with r in [1, n) and
# invertible. Reads /dev/urandom. Returns 0 on success, -1 if no
# entropy or no invertible r within a few tries (effectively never).
fn _rsa_gen_blind(r_out, rinv_out, n_bn, nlen, limbs): i64 {
    var fd = file_open("/dev/urandom", 0, 0);
    if (fd < 0) { return 0 - 1; }
    var tries = 0;
    var ok = 0;
    while (ok == 0) {
        if (tries >= 16) { file_close(fd); return 0 - 1; }
        tries = tries + 1;
        var got = 0;
        while (got < nlen) {
            var nr = file_read(fd, (&_rsa_blind_rand) + got, nlen - got);
            if (nr <= 0) { file_close(fd); return 0 - 1; }
            got = got + nr;
        }
        bn_from_be(r_out, limbs, &_rsa_blind_rand, nlen);
        bn_mod(r_out, r_out, limbs, n_bn, limbs);          # r in [0, n)
        if (bn_is_zero(r_out, limbs) == 0) {
            if (bn_modinv(rinv_out, r_out, n_bn, limbs) == 0) { ok = 1; }
        }
    }
    file_close(fd);
    return 0;
}

# CRT exponentiation scratch (3.6.4). Half-width (RSA-4096 prime side).
var _rsa_crt_p[256];
var _rsa_crt_q[256];
var _rsa_crt_qinv[256];
var _rsa_crt_mp[256];
var _rsa_crt_mq[256];
var _rsa_crt_s1[256];
var _rsa_crt_s2[256];
var _rsa_crt_s2full[512];
var _rsa_crt_h[256];
var _rsa_crt_prod[512];
var _rsa_crt_qh[512];

# sb_out = mb^d mod n via the CRT (Garner): sign mod p and mod q with
# the constant-time Montgomery ladder, then recombine — ~4× faster
# than the full-width modexp. Returns 0, or -1 if the key lacks CRT
# parameters (caller falls back to the full-width path). The
# verify-after-sign in the caller guards the CRT fault surface.
fn _rsa_crt_modexp(key, mb, sb_out, limbs): i64 {
    var plen = load64(key + RSAK_PLEN);
    var qlen = load64(key + RSAK_QLEN);
    if (plen == 0) { return 0 - 1; }
    if (qlen == 0) { return 0 - 1; }
    var hl = limbs / 2;                 # half-width limbs (n_limbs is even)

    bn_from_be(&_rsa_crt_p, hl, key + RSAK_P, plen);
    bn_from_be(&_rsa_crt_q, hl, key + RSAK_Q, qlen);
    bn_from_be(&_rsa_crt_qinv, hl, key + RSAK_QINV, load64(key + RSAK_QINVLEN));

    # s1 = (mb mod p)^dp mod p ; s2 = (mb mod q)^dq mod q
    bn_mod(&_rsa_crt_mp, mb, limbs, &_rsa_crt_p, hl);
    bn_mod(&_rsa_crt_mq, mb, limbs, &_rsa_crt_q, hl);
    bn_mont_modexp(&_rsa_crt_s1, &_rsa_crt_mp, key + RSAK_DP, load64(key + RSAK_DPLEN), &_rsa_crt_p, hl);
    bn_mont_modexp(&_rsa_crt_s2, &_rsa_crt_mq, key + RSAK_DQ, load64(key + RSAK_DQLEN), &_rsa_crt_q, hl);

    # h = (s1 - s2) * qinv mod p
    bn_copy(&_rsa_crt_h, &_rsa_crt_s1, hl);
    _bn_submod(&_rsa_crt_h, &_rsa_crt_s2, &_rsa_crt_p, hl);
    bn_mul(&_rsa_crt_prod, &_rsa_crt_h, &_rsa_crt_qinv, hl);
    bn_mod(&_rsa_crt_h, &_rsa_crt_prod, 2 * hl, &_rsa_crt_p, hl);

    # sb = s2 + q*h   (< n by construction; no final reduction needed)
    bn_mul(&_rsa_crt_qh, &_rsa_crt_q, &_rsa_crt_h, hl);   # 2*hl == limbs
    bn_zero(&_rsa_crt_s2full, limbs);
    bn_copy(&_rsa_crt_s2full, &_rsa_crt_s2, hl);
    bn_copy(sb_out, &_rsa_crt_qh, limbs);
    bn_add_assign(sb_out, &_rsa_crt_s2full, limbs);
    return 0;
}

# Core signer. `key` is an RSAK struct; prefix/hash form the DigestInfo.
# Writes the k-byte signature to `sig_out`. Returns k (>0), or -1 on a
# too-small modulus or a failed verify-after-sign.
fn _rsa_pkcs1v15_sign(key, prefix, prefix_len, hash, hash_len, sig_out): i64 {
    var nlen = load64(key + RSAK_NLEN);
    if (nlen > 512) { return 0 - 1; }
    var limbs = (nlen + 7) / 8;

    var dlen = load64(key + RSAK_DLEN);
    var elen = load64(key + RSAK_ELEN);

    # EM = EMSA-PKCS1-v1.5(hash); m = OS2IP(EM); n as a bignum.
    if (_rsa_emsa_encode(&_rsa_sign_em, nlen, prefix, prefix_len, hash, hash_len) < 0) { return 0 - 1; }
    bn_from_be(&_rsa_sign_m, limbs, &_rsa_sign_em, nlen);
    bn_from_be(&_rsa_sign_n, limbs, key + RSAK_N, nlen);

    # Base blinding: fresh random r, mb = m * r^e mod n  (r^e via the
    # public-exponent modexp). Decorrelates the secret modexp from the
    # key; the final s is unchanged.
    if (_rsa_gen_blind(&_rsa_blind_r, &_rsa_blind_rinv, &_rsa_sign_n, nlen, limbs) < 0) { return 0 - 1; }
    bn_modexp(&_rsa_blind_re, &_rsa_blind_r, key + RSAK_E, elen, &_rsa_sign_n, limbs);
    bn_mul(&_rsa_blind_prod, &_rsa_sign_m, &_rsa_blind_re, limbs);
    bn_mod(&_rsa_blind_mb, &_rsa_blind_prod, 2 * limbs, &_rsa_sign_n, limbs);

    # sb = mb^d mod n  (constant-time). CRT when the key has p/q/dp/dq/
    # qinv (~4×); else the full-width Montgomery ladder.
    if (_rsa_crt_modexp(key, &_rsa_blind_mb, &_rsa_blind_sb, limbs) < 0) {
        bn_mont_modexp(&_rsa_blind_sb, &_rsa_blind_mb, key + RSAK_D, dlen, &_rsa_sign_n, limbs);
    }

    # Unblind: s = sb * r^-1 mod n.
    bn_mul(&_rsa_blind_prod, &_rsa_blind_sb, &_rsa_blind_rinv, limbs);
    bn_mod(&_rsa_sign_s, &_rsa_blind_prod, 2 * limbs, &_rsa_sign_n, limbs);

    # Verify-after-sign (Bellcore guard): s^e mod n must equal m.
    bn_modexp(&_rsa_sign_chk, &_rsa_sign_s, key + RSAK_E, elen, &_rsa_sign_n, limbs);
    if (bn_cmp(&_rsa_sign_chk, &_rsa_sign_m, limbs) != 0) {
        bn_zero(&_rsa_sign_s, limbs);   # discard a faulty signature
        return 0 - 1;
    }

    bn_to_be(sig_out, nlen, &_rsa_sign_s, limbs);
    return nlen;
}

# Sign SHA-256(msg) with RSASSA-PKCS1-v1.5. `key` is an RSAK struct
# (from rsa_privkey_from_der). Writes k bytes to sig_out; returns k.
fn rsa_pkcs1v15_sign_sha256(key, msg, msg_len, sig_out): i64 {
    sha256(msg, msg_len, &_rsa_hash);
    var pl = _rsa_di_sha256(&_rsa_di);
    return _rsa_pkcs1v15_sign(key, &_rsa_di, pl, &_rsa_hash, 32, sig_out);
}

# Sign SHA-384(msg) with RSASSA-PKCS1-v1.5.
fn rsa_pkcs1v15_sign_sha384(key, msg, msg_len, sig_out): i64 {
    sha384(msg, msg_len, &_rsa_hash);
    var pl = _rsa_di_sha384(&_rsa_di);
    return _rsa_pkcs1v15_sign(key, &_rsa_di, pl, &_rsa_hash, 48, sig_out);
}

# --- sgx.cyr ---

# sgx.cyr — Intel SGX DCAP v3 quote parser + verify orchestrator.
#
# Sigil 3.2.3 — bite 3 of the TEE attestation arc (origin:
# `docs/development/3.2-tee-arc.md`).
#
# Scope (per the 3.2.3 user choice — "parser only, defer end-to-end
# verify"): structural walk of a DCAP v3 ECDSA-P256 quote into an
# offsets-into-buffer SgxQuote struct. The verify entry point
# (`sgx_quote_verify_with_pck`) composes the existing primitives
# (`sha256`, `ecdsa_p256_verify`) into the three-step internal
# attestation check; the X.509 chain walk that ties the PCK public
# key to Intel's SGX Root CA is the caller's responsibility for
# 3.2.3 — PEM decoding of the in-quote `qe_cert_data` is its own
# future patch.
#
# Surface:
#   fn sgx_quote_parse(buf, buf_len, out): i64
#       — parse a DCAP v3 quote (1 = ok, 0 = malformed/unsupported)
#   fn sgx_quote_verify_with_pck(quote, pck_pk): i64
#       — given a parsed quote and an externally-validated PCK
#         public key (64 B raw Qx||Qy), verify the three internal
#         signature checks:
#           1. PCK signs the QE report (qe_report_signature over
#              qe_report under pck_pk).
#           2. AK is bound to the QE: qe_report.report_data[0:32]
#              == SHA-256(AK_qx || AK_qy || qe_auth_data).
#           3. AK signs the quote body (ecdsa_signature over
#              header || enclave_report under AK).
#         Returns 1 only if all three pass.
#
# Layout reference — Intel SGX TEE Quote Reference Spec (DCAP v3):
#   QuoteHeader (48 B):
#     version (u16 LE)
#     att_key_type (u16 LE)   — 2 = ECDSA-P256
#     reserved (u32 LE)
#     qe_svn (u16 LE)
#     pce_svn (u16 LE)
#     qe_vendor_id (16 B)
#     user_data (20 B)
#
#   EnclaveReport (384 B):
#     cpu_svn (16 B)
#     misc_select (u32 LE)
#     reserved_1 (28 B)
#     attributes (16 B)
#     mr_enclave (32 B)           offset 64
#     reserved_2 (32 B)
#     mr_signer (32 B)            offset 128
#     reserved_3 (96 B)
#     isv_prod_id (u16 LE)        offset 256
#     isv_svn (u16 LE)            offset 258
#     reserved_4 (60 B)
#     report_data (64 B)          offset 320
#
#   SignatureSection (variable):
#     signature_data_len (u32 LE)
#     ecdsa_signature (64 B)        — over header || enclave_report, signed by AK
#     attestation_key (64 B)        — Qx || Qy of AK
#     qe_report (384 B)             — QE's own enclave report
#     qe_report_signature (64 B)    — over qe_report, signed by PCK
#     qe_auth_data_size (u16 LE)
#     qe_auth_data (qe_auth_data_size B)
#     qe_cert_data_type (u16 LE)
#     qe_cert_data_size (u32 LE)
#     qe_cert_data (qe_cert_data_size B)
#
# Threat model: the quote buffer is fully attacker-controlled (it
# travels from a remote untrusted host via a guest enclave's
# attestation flow). Every length read is bounds-checked against
# `buf_len` before any dereference. See
# `docs/audit/2026-05-23-audit.md` for the 3.2.3 hardening review.

# ================================================================
# Format constants
# ================================================================

var SGX_QUOTE_HEADER_SIZE     = 48;
var SGX_REPORT_BODY_SIZE      = 384;
var SGX_AK_SIZE               = 64;
var SGX_ECDSA_SIG_SIZE        = 64;
var SGX_MIN_QUOTE_SIZE        = 48 + 384 + 4 + 64 + 64 + 384 + 64 + 2 + 2 + 4;

var SGX_QUOTE_VERSION_V3      = 3;
var SGX_ATT_KEY_TYPE_ECDSA_P256 = 2;

# qe_cert_data_type values per Intel spec. 5 = PCK Cert Chain (PEM).
# Other values exist (1=PPID, 7=manifest) but we expose the type
# byte and let the caller decide.
var SGX_CERT_TYPE_PCK_PEM     = 5;

# Field offsets inside an EnclaveReport (used by accessors).
var SGX_REPORT_OFF_MR_ENCLAVE   = 64;
var SGX_REPORT_OFF_MR_SIGNER    = 128;
var SGX_REPORT_OFF_ISV_PROD_ID  = 256;
var SGX_REPORT_OFF_ISV_SVN      = 258;
var SGX_REPORT_OFF_REPORT_DATA  = 320;

# ================================================================
# SgxQuote struct — 256 bytes. All offsets are relative to the
# original buffer (load64(q + 0)); all lengths are in bytes.
#
#    0  buf_ptr
#    8  buf_len
#   16  version (u16 zero-extended to i64)
#   24  att_key_type (u16 → i64)
#   32  header_off (always 0)
#   40  report_body_off (always 48)
#   48  signature_data_len (u32 → i64) — content of the sig section,
#       not including the u32 length prefix
#   56  ecdsa_sig_off            — 64 B raw r||s
#   64  ak_off                   — 64 B Qx||Qy
#   72  qe_report_off            — 384 B
#   80  qe_report_sig_off        — 64 B raw r||s
#   88  qe_auth_data_off
#   96  qe_auth_data_len
#  104  qe_cert_data_type (u16)
#  112  qe_cert_data_off
#  120  qe_cert_data_len (u32)
#  128..255  reserved
# ================================================================

fn sgx_quote_alloc(): i64 {
    var q = alloc(256);
    memset(q, 0, 256);
    return q;
}

# Internal helpers (little-endian word reads — same convention as
# Intel's wire format).
fn _sgx_load_u16(buf, off): i64 {
    return (load8(buf + off) & 0xFF) | ((load8(buf + off + 1) & 0xFF) << 8);
}

fn _sgx_load_u32(buf, off): i64 {
    return (load8(buf + off) & 0xFF)
         | ((load8(buf + off + 1) & 0xFF) << 8)
         | ((load8(buf + off + 2) & 0xFF) << 16)
         | ((load8(buf + off + 3) & 0xFF) << 24);
}

# ================================================================
# Field accessors (post-parse). The integer-valued ones return the
# value directly; the byte-region ones return absolute pointers
# into the original DER buffer.
# ================================================================

fn sgx_quote_version(q): i64        { return load64(q + 16); }
fn sgx_quote_att_key_type(q): i64   { return load64(q + 24); }
fn sgx_quote_buf(q): i64            { return load64(q + 0); }
fn sgx_quote_buf_len(q): i64        { return load64(q + 8); }

fn sgx_quote_report_body_ptr(q): i64 {
    return load64(q + 0) + load64(q + 40);
}

fn sgx_quote_mr_enclave_ptr(q): i64 {
    return sgx_quote_report_body_ptr(q) + SGX_REPORT_OFF_MR_ENCLAVE;
}

fn sgx_quote_mr_signer_ptr(q): i64 {
    return sgx_quote_report_body_ptr(q) + SGX_REPORT_OFF_MR_SIGNER;
}

fn sgx_quote_isv_prod_id(q): i64 {
    return _sgx_load_u16(sgx_quote_buf(q),
                          load64(q + 40) + SGX_REPORT_OFF_ISV_PROD_ID);
}

fn sgx_quote_isv_svn(q): i64 {
    return _sgx_load_u16(sgx_quote_buf(q),
                          load64(q + 40) + SGX_REPORT_OFF_ISV_SVN);
}

fn sgx_quote_report_data_ptr(q): i64 {
    return sgx_quote_report_body_ptr(q) + SGX_REPORT_OFF_REPORT_DATA;
}

fn sgx_quote_ak_ptr(q): i64           { return load64(q + 0) + load64(q + 64); }
fn sgx_quote_ecdsa_sig_ptr(q): i64    { return load64(q + 0) + load64(q + 56); }
fn sgx_quote_qe_report_ptr(q): i64    { return load64(q + 0) + load64(q + 72); }
fn sgx_quote_qe_report_sig_ptr(q): i64 { return load64(q + 0) + load64(q + 80); }
fn sgx_quote_qe_auth_data_ptr(q): i64 { return load64(q + 0) + load64(q + 88); }
fn sgx_quote_qe_auth_data_len(q): i64 { return load64(q + 96); }
fn sgx_quote_cert_data_type(q): i64   { return load64(q + 104); }
fn sgx_quote_cert_data_ptr(q): i64    { return load64(q + 0) + load64(q + 112); }
fn sgx_quote_cert_data_len(q): i64    { return load64(q + 120); }

# ================================================================
# sgx_quote_parse — single-pass linear walk.
#
# Returns 1 on success, 0 on any malformed input.
# ================================================================

fn sgx_quote_parse(buf, buf_len, out): i64 {
    memset(out, 0, 256);

    # Minimum size check: header + body + sig_data_len + minimal
    # signature section payload. Anything smaller cannot possibly
    # be a v3 DCAP quote.
    if (buf_len < SGX_MIN_QUOTE_SIZE) { return 0; }

    # Header
    var version = _sgx_load_u16(buf, 0);
    var att_key_type = _sgx_load_u16(buf, 2);
    if (version != SGX_QUOTE_VERSION_V3) { return 0; }
    if (att_key_type != SGX_ATT_KEY_TYPE_ECDSA_P256) { return 0; }

    store64(out + 0, buf);
    store64(out + 8, buf_len);
    store64(out + 16, version);
    store64(out + 24, att_key_type);
    store64(out + 32, 0);    # header_off
    store64(out + 40, SGX_QUOTE_HEADER_SIZE);  # report_body_off

    # signature_data_len field
    var sig_len_off = SGX_QUOTE_HEADER_SIZE + SGX_REPORT_BODY_SIZE;
    if (sig_len_off + 4 > buf_len) { return 0; }
    var sig_data_len = _sgx_load_u32(buf, sig_len_off);
    var sig_data_off = sig_len_off + 4;
    # Reject sig_data_len that would push past buf_len OR is
    # patently too small to contain the fixed part of the
    # signature section.
    if (sig_data_len < 0) { return 0; }     # u32 read can produce ≥ 2^31 as negative i64; guard anyway
    if (sig_data_off + sig_data_len > buf_len) { return 0; }
    var sig_min_fixed = SGX_ECDSA_SIG_SIZE + SGX_AK_SIZE
                       + SGX_REPORT_BODY_SIZE + SGX_ECDSA_SIG_SIZE
                       + 2 + 2 + 4;
    if (sig_data_len < sig_min_fixed) { return 0; }

    store64(out + 48, sig_data_len);

    # Walk the signature section, recording offsets.
    var cur = sig_data_off;
    var sig_section_end = sig_data_off + sig_data_len;

    # ecdsa_signature (64 B)
    store64(out + 56, cur);
    cur = cur + SGX_ECDSA_SIG_SIZE;
    # attestation_key (64 B)
    store64(out + 64, cur);
    cur = cur + SGX_AK_SIZE;
    # qe_report (384 B)
    store64(out + 72, cur);
    cur = cur + SGX_REPORT_BODY_SIZE;
    # qe_report_signature (64 B)
    store64(out + 80, cur);
    cur = cur + SGX_ECDSA_SIG_SIZE;

    # qe_auth_data: u16 size + bytes
    if (cur + 2 > sig_section_end) { return 0; }
    var auth_len = _sgx_load_u16(buf, cur);
    if (auth_len < 0) { return 0; }
    if (cur + 2 + auth_len > sig_section_end) { return 0; }
    store64(out + 88, cur + 2);
    store64(out + 96, auth_len);
    cur = cur + 2 + auth_len;

    # qe_cert_data: u16 type + u32 size + bytes
    if (cur + 6 > sig_section_end) { return 0; }
    var cert_type = _sgx_load_u16(buf, cur);
    var cert_len  = _sgx_load_u32(buf, cur + 2);
    if (cert_len < 0) { return 0; }
    if (cur + 6 + cert_len > sig_section_end) { return 0; }
    # Allow exact match (no trailing bytes inside the signature section)
    if (cur + 6 + cert_len != sig_section_end) { return 0; }
    store64(out + 104, cert_type);
    store64(out + 112, cur + 6);
    store64(out + 120, cert_len);

    return 1;
}

# ================================================================
# Verify orchestrator (3.2.3 — three internal signature checks).
#
# All three checks must pass.
#
# `pck_pk` is a 64-byte Qx||Qy raw P-256 public key, already
# validated as on-curve and trusted by the caller (the X.509 chain
# walk from the PCK leaf up to Intel SGX Root is the caller's
# responsibility for 3.2.3 — PEM decoding inside the quote will
# land in 3.2.3+).
# ================================================================

# Scratch globals (Cyrius quirk #1 — locals can clobber across
# nested calls).
var _sgxv_binding_input = 0;
var _sgxv_binding_hash  = 0;
var _sgxv_quote_body    = 0;
var _sgxv_inited = 0;

fn _sgxv_init(): i64 {
    if (_sgxv_inited == 1) { return 0; }
    # Max binding input: AK (64) + qe_auth_data (≤ 65535) = 65599 bytes.
    # Allocate generously once. For typical quotes auth_data ≤ ~256.
    _sgxv_binding_input = alloc(65600);
    _sgxv_binding_hash  = alloc(32);
    # Quote body for AK signature = header (48) + report body (384) = 432.
    _sgxv_quote_body    = alloc(432);
    _sgxv_inited = 1;
    return 0;
}

fn sgx_quote_verify_with_pck(quote, pck_pk): i64 {
    _sgxv_init();

    # ----------------------------------------------------------------
    # Step 1 — PCK signs the QE report.
    # ----------------------------------------------------------------
    var qe_report = sgx_quote_qe_report_ptr(quote);
    var qe_report_sig = sgx_quote_qe_report_sig_ptr(quote);
    if (ecdsa_p256_verify(pck_pk, qe_report, SGX_REPORT_BODY_SIZE, qe_report_sig) != 1) {
        return 0;
    }

    # ----------------------------------------------------------------
    # Step 2 — AK is bound to the QE.
    # qe_report.report_data[0:32] == SHA-256(AK || qe_auth_data)
    # The upper 32 bytes of report_data are required to be zero.
    # ----------------------------------------------------------------
    var ak  = sgx_quote_ak_ptr(quote);
    var aux = sgx_quote_qe_auth_data_ptr(quote);
    var aux_len = sgx_quote_qe_auth_data_len(quote);
    if (aux_len < 0) { return 0; }
    if (aux_len > 65536) { return 0; }   # bounded by our scratch

    # Build SHA-256 input: AK || qe_auth_data
    var i = 0;
    while (i < SGX_AK_SIZE) {
        store8(_sgxv_binding_input + i, load8(ak + i) & 0xFF);
        i = i + 1;
    }
    i = 0;
    while (i < aux_len) {
        store8(_sgxv_binding_input + SGX_AK_SIZE + i, load8(aux + i) & 0xFF);
        i = i + 1;
    }
    sha256(_sgxv_binding_input, SGX_AK_SIZE + aux_len, _sgxv_binding_hash);

    # Compare against qe_report.report_data[0:32]
    var rd = qe_report + SGX_REPORT_OFF_REPORT_DATA;
    i = 0;
    while (i < 32) {
        if ((load8(rd + i) & 0xFF) != (load8(_sgxv_binding_hash + i) & 0xFF)) {
            return 0;
        }
        i = i + 1;
    }
    # Upper 32 bytes must be zero (defense in depth — guards against
    # an attacker stuffing additional bytes that affect downstream
    # consumers parsing the full 64-byte report_data).
    i = 32;
    while (i < 64) {
        if ((load8(rd + i) & 0xFF) != 0) { return 0; }
        i = i + 1;
    }

    # ----------------------------------------------------------------
    # Step 3 — AK signs the quote body (header || enclave_report).
    # ----------------------------------------------------------------
    var buf = sgx_quote_buf(quote);
    # Assemble header || report_body into our scratch (they're
    # contiguous in the quote, but copying is the same shape we'd use
    # if the format ever inserted padding — defensive).
    memcpy(_sgxv_quote_body, buf, SGX_QUOTE_HEADER_SIZE);
    memcpy(_sgxv_quote_body + SGX_QUOTE_HEADER_SIZE,
           buf + SGX_QUOTE_HEADER_SIZE, SGX_REPORT_BODY_SIZE);

    var ecdsa_sig = sgx_quote_ecdsa_sig_ptr(quote);
    if (ecdsa_p256_verify(ak, _sgxv_quote_body,
                           SGX_QUOTE_HEADER_SIZE + SGX_REPORT_BODY_SIZE,
                           ecdsa_sig) != 1) {
        return 0;
    }

    return 1;
}

# ================================================================
# sgx_quote_verify_full — end-to-end verify (3.5).
#
# Composes:
#   1. cert_data_type check (must be PCK PEM, type 5)
#   2. pem_decode_certs on the embedded qe_cert_data
#   3. x509_parse on each cert + on caller-provided root CA
#   4. x509_verify_chain anchored at caller's root
#   5. extract leaf (PCK) pubkey
#   6. sgx_quote_verify_with_pck against that key
#
# Intel's PCK cert chain order in qe_cert_data (DCAP v3):
#   PCK leaf (cert[0])
#     → PCK Platform CA / intermediate (cert[1..n-2])
#       → Intel SGX Root CA (cert[n-1], self-issued)
#
# The in-quote root is informational: we anchor verification on the
# CALLER-PROVIDED `root_ca_der` (the trust establishment lives at
# the consumer's policy layer — kavach's keyring, ark's publisher
# set, etc.). The in-quote root copy is recognised by being self-
# issued (subject DN == issuer DN) and silently dropped from the
# intermediate list before chain walk.
#
# `now_unix == 0` disables the time-window check on every cert in
# the chain. Suitable when the verifier doesn't trust the host's
# wall clock (the SGX/TDX TCB nonce carries freshness).
#
# Returns 1 only if every step succeeds; 0 on any failure (parse,
# chain mismatch, signature failure, etc.). No partial-success
# return values — matches the safety stance for attacker-controlled
# input.
#
# NOTE (audit follow-up — 2026-05-22): this entry point uses the
# bump allocator on every call: it decodes a PEM scratch pool
# proportional to qe_cert_data_len, parses up to N certs (each
# x509_cert_alloc + raw_sig alloc) and the root. For long-running
# consumers (kavach attestation loop), per-call drift is ~5–8 KB.
# Defer-to-3.6 carries the unified `_into` API that eliminates the
# drift (matches the four 3.2.x LOW findings). Tracked in
# `docs/audit/2026-05-22-audit.md`.
# ================================================================

# Max in-quote PCK certs we'll accept. Intel's PCK chain ships as
# leaf + 1 intermediate + root = 3 certs. Allow 4 for defence in
# depth against future spec deltas.
var SGX_VERIFY_FULL_MAX_CERTS = 4;

fn _sgx_cert_is_self_issued(c): i64 {
    var buf = load64(c + 0);
    var iss_off = load64(c + 48); var iss_len = load64(c + 56);
    var sub_off = load64(c + 64); var sub_len = load64(c + 72);
    return _x509_dn_eq(buf, iss_off, iss_len, buf, sub_off, sub_len);
}

fn sgx_quote_verify_full(quote, root_ca_der, root_ca_der_len, now_unix): i64 {
    # Step 1 — cert_data_type must be PEM PCK chain.
    if (sgx_quote_cert_data_type(quote) != SGX_CERT_TYPE_PCK_PEM) { return 0; }

    # Step 2 — decode the in-quote PEM cert blob.
    var cert_data = sgx_quote_cert_data_ptr(quote);
    var cert_data_len = sgx_quote_cert_data_len(quote);
    if (cert_data_len <= 0) { return 0; }

    var chain[64];                # 4 entries × 16 bytes (ptr, len)
    memset(&chain, 0, 64);
    var n = pem_decode_certs(cert_data, cert_data_len,
                              &chain, SGX_VERIFY_FULL_MAX_CERTS);
    if (n < 1) { return 0; }

    # Step 3 — parse each in-quote cert + the caller's root anchor.
    var parsed[4];                # array of cert pointers
    var i = 0;
    while (i < n) {
        var c = x509_cert_alloc();
        var ptr = load64(&chain + i * 16);
        var len = load64(&chain + i * 16 + 8);
        if (x509_parse(ptr, len, c) != 1) { return 0; }
        store64(&parsed + i * 8, c);
        i = i + 1;
    }
    if (root_ca_der_len <= 0) { return 0; }
    var root = x509_cert_alloc();
    if (x509_parse(root_ca_der, root_ca_der_len, root) != 1) { return 0; }

    # Step 4 — assemble (leaf, intermediates, root) for the chain
    # walker. Leaf is chain[0]. If the top of the in-quote chain is
    # self-issued, drop it (it's the embedded root copy). Remaining
    # intermediates are reversed into issuer-towards-leaf order.
    var leaf = load64(&parsed + 0);
    var top_idx = n - 1;
    if (n >= 2) {
        var top = load64(&parsed + top_idx * 8);
        if (_sgx_cert_is_self_issued(top) == 1) { top_idx = top_idx - 1; }
    }

    var inters[4];                # cert pointer array, max 4
    memset(&inters, 0, 32);
    var inters_n = 0;
    i = top_idx;
    while (i >= 1) {
        store64(&inters + inters_n * 8, load64(&parsed + i * 8));
        inters_n = inters_n + 1;
        i = i - 1;
    }

    # Step 5 — chain walk anchored on caller's root.
    if (x509_verify_chain(leaf, &inters, inters_n, root, now_unix) != 1) {
        return 0;
    }

    # Step 6 — extract the leaf's pubkey and verify the quote
    # against it. x509_cert_pubkey returns a pointer to the 64-byte
    # raw Qx||Qy region inside the cert struct (offset +96).
    var leaf_pk = x509_cert_pubkey(leaf);
    return sgx_quote_verify_with_pck(quote, leaf_pk);
}

# --- sev_snp.cyr ---

# sev_snp.cyr — AMD SEV-SNP attestation report parser + verify
# orchestrator.
#
# Sigil 3.2.4 — bite 4 of the TEE attestation arc.
#
# Reference: AMD SEV Secure Nested Paging Firmware ABI Specification
# (Pub. 56860), §7.3 (Attestation Report Structure). The report is
# a fixed-size 1184-byte (0x4A0) binary blob; the first 672 bytes
# (0x000..0x2A0) make up the signed body, and the remainder is the
# VCEK signature (r, s) stored little-endian with zero-padding plus
# 368 bytes of reserved space.
#
# Surface:
#   fn snp_report_parse(buf, buf_len, out): i64
#       — parse the fixed layout into an SnpReport struct (1 = ok,
#         0 = malformed/unsupported). version must be 2 (current
#         GenoaPilatos+ firmware); signature_algo must be 1
#         (ECDSA P-384 / SHA-384).
#   fn snp_report_verify(report, vcek_pk): i64
#       — given a parsed report + an externally-validated VCEK
#         public key (96 B raw Qx||Qy big-endian), hash the signed
#         body with SHA-384 and verify the report's signature via
#         `ecdsa_p384_verify`. Returns 1 on success, 0 on any
#         failure.
#
# Scope as of 3.4.1: the per-piece API remains (parser +
# `snp_report_verify` against an externally-validated VCEK
# pubkey), and an integrated `snp_report_verify_full` wrapper is
# now available — see the surface section below. The wrapper
# requires that the VCEK chain delivered alongside the report
# contains a P-384 leaf cert (the standard AMD shape); chain-link
# signatures must still be ECDSA-SHA256 (P-256 issuers) until
# `x509.cyr` gains broader chain-link verify support. Real AMD
# chains use RSA at the ARK/ASK links, which sigil's x509 does
# not parse; consumers integrating against real AMD KDS chains
# will still need an external pre-step that walks ARK → ASK and
# hands sigil only the ASK → VCEK fragment (or skips chain walk
# entirely and uses `snp_report_verify` directly).
#
# Surface additions over 3.2.4:
#   fn snp_report_verify_full(report, vcek_chain_pem,
#                              vcek_chain_pem_len, ark_root_der,
#                              ark_root_der_len, now_unix): i64
#       — composes pem_decode_certs → x509_parse (per cert + root)
#         → x509_verify_chain (anchored at caller's root) →
#         snp_report_verify against the leaf's 96-byte P-384
#         pubkey. Returns 1 on full success, 0 on any failure.

# ================================================================
# Format constants
# ================================================================

var SNP_REPORT_SIZE          = 1184;   # 0x4A0
var SNP_REPORT_BODY_SIZE     = 672;    # 0x2A0 — the signed prefix
var SNP_SIG_PADDED_R_LEN     = 72;     # AMD pads ECDSA r to 72 B LE
var SNP_SIG_PADDED_S_LEN     = 72;
var SNP_P384_FIELD_BYTES     = 48;     # the actual r/s width
var SNP_SIG_RESERVED_LEN     = 368;    # trailer after r||s

var SNP_VERSION_V2           = 2;
var SNP_SIG_ECDSA_P384_SHA384 = 1;

# Field offsets within the report buffer (per AMD spec).
var SNP_OFF_VERSION           = 0x000;
var SNP_OFF_GUEST_SVN         = 0x004;
var SNP_OFF_POLICY            = 0x008;
var SNP_OFF_FAMILY_ID         = 0x010;
var SNP_OFF_IMAGE_ID          = 0x020;
var SNP_OFF_VMPL              = 0x030;
var SNP_OFF_SIG_ALGO          = 0x034;
var SNP_OFF_CURRENT_TCB       = 0x038;
var SNP_OFF_PLATFORM_INFO     = 0x040;
var SNP_OFF_REPORT_DATA       = 0x050;
var SNP_OFF_MEASUREMENT       = 0x090;
var SNP_OFF_HOST_DATA         = 0x0C0;
var SNP_OFF_ID_KEY_DIGEST     = 0x0E0;
var SNP_OFF_AUTHOR_KEY_DIGEST = 0x110;
var SNP_OFF_REPORT_ID         = 0x140;
var SNP_OFF_REPORT_ID_MA      = 0x160;
var SNP_OFF_REPORTED_TCB      = 0x180;
var SNP_OFF_CHIP_ID           = 0x1A0;
var SNP_OFF_SIG_R             = 0x2A0;
var SNP_OFF_SIG_S             = 0x2E8;

# ================================================================
# SnpReport struct — 256 bytes
#
#   0  buf_ptr
#   8  buf_len  (must equal SNP_REPORT_SIZE for a valid parse)
#  16  version
#  24  guest_svn
#  32  policy
#  40  vmpl
#  48  signature_algo
#  56  current_tcb
#  64  platform_info
#  72  reported_tcb
#  80..255  reserved (all field positions are derivable from
#           buf + SNP_OFF_* — no need to store per-field offsets)
# ================================================================

fn snp_report_alloc(): i64 {
    var r = alloc(256);
    memset(r, 0, 256);
    return r;
}

fn _snp_load_u32(buf, off): i64 {
    return (load8(buf + off) & 0xFF)
         | ((load8(buf + off + 1) & 0xFF) << 8)
         | ((load8(buf + off + 2) & 0xFF) << 16)
         | ((load8(buf + off + 3) & 0xFF) << 24);
}

fn _snp_load_u64(buf, off): i64 {
    return (load8(buf + off) & 0xFF)
         | ((load8(buf + off + 1) & 0xFF) << 8)
         | ((load8(buf + off + 2) & 0xFF) << 16)
         | ((load8(buf + off + 3) & 0xFF) << 24)
         | ((load8(buf + off + 4) & 0xFF) << 32)
         | ((load8(buf + off + 5) & 0xFF) << 40)
         | ((load8(buf + off + 6) & 0xFF) << 48)
         | ((load8(buf + off + 7) & 0xFF) << 56);
}

# ----------------------------------------------------------------
# Accessors
# ----------------------------------------------------------------

fn snp_report_buf(r): i64               { return load64(r + 0); }
fn snp_report_version(r): i64            { return load64(r + 16); }
fn snp_report_guest_svn(r): i64          { return load64(r + 24); }
fn snp_report_policy(r): i64             { return load64(r + 32); }
fn snp_report_vmpl(r): i64               { return load64(r + 40); }
fn snp_report_signature_algo(r): i64     { return load64(r + 48); }
fn snp_report_current_tcb(r): i64        { return load64(r + 56); }
fn snp_report_platform_info(r): i64      { return load64(r + 64); }
fn snp_report_reported_tcb(r): i64       { return load64(r + 72); }

fn snp_report_family_id_ptr(r): i64      { return snp_report_buf(r) + SNP_OFF_FAMILY_ID; }
fn snp_report_image_id_ptr(r): i64       { return snp_report_buf(r) + SNP_OFF_IMAGE_ID; }
fn snp_report_data_ptr(r): i64           { return snp_report_buf(r) + SNP_OFF_REPORT_DATA; }
fn snp_report_measurement_ptr(r): i64    { return snp_report_buf(r) + SNP_OFF_MEASUREMENT; }
fn snp_report_host_data_ptr(r): i64      { return snp_report_buf(r) + SNP_OFF_HOST_DATA; }
fn snp_report_id_key_digest_ptr(r): i64  { return snp_report_buf(r) + SNP_OFF_ID_KEY_DIGEST; }
fn snp_report_author_key_digest_ptr(r): i64 { return snp_report_buf(r) + SNP_OFF_AUTHOR_KEY_DIGEST; }
fn snp_report_report_id_ptr(r): i64      { return snp_report_buf(r) + SNP_OFF_REPORT_ID; }
fn snp_report_report_id_ma_ptr(r): i64   { return snp_report_buf(r) + SNP_OFF_REPORT_ID_MA; }
fn snp_report_chip_id_ptr(r): i64        { return snp_report_buf(r) + SNP_OFF_CHIP_ID; }
fn snp_report_sig_r_ptr(r): i64          { return snp_report_buf(r) + SNP_OFF_SIG_R; }
fn snp_report_sig_s_ptr(r): i64          { return snp_report_buf(r) + SNP_OFF_SIG_S; }

# ================================================================
# snp_report_parse — single-pass header validation + offset stash.
#
# AMD's spec mandates the report is exactly 1184 bytes. Reject
# anything else.
# ================================================================

fn snp_report_parse(buf, buf_len, out): i64 {
    memset(out, 0, 256);

    if (buf_len != SNP_REPORT_SIZE) { return 0; }

    var version = _snp_load_u32(buf, SNP_OFF_VERSION);
    if (version != SNP_VERSION_V2) { return 0; }

    var sig_algo = _snp_load_u32(buf, SNP_OFF_SIG_ALGO);
    if (sig_algo != SNP_SIG_ECDSA_P384_SHA384) { return 0; }

    store64(out + 0,  buf);
    store64(out + 8,  buf_len);
    store64(out + 16, version);
    store64(out + 24, _snp_load_u32(buf, SNP_OFF_GUEST_SVN));
    store64(out + 32, _snp_load_u64(buf, SNP_OFF_POLICY));
    store64(out + 40, _snp_load_u32(buf, SNP_OFF_VMPL));
    store64(out + 48, sig_algo);
    store64(out + 56, _snp_load_u64(buf, SNP_OFF_CURRENT_TCB));
    store64(out + 64, _snp_load_u64(buf, SNP_OFF_PLATFORM_INFO));
    store64(out + 72, _snp_load_u64(buf, SNP_OFF_REPORTED_TCB));

    return 1;
}

# ================================================================
# Verify orchestrator
#
# AMD spec: ECDSA P-384 signature is stored as r (72 B LE-padded)
# and s (72 B LE-padded). Sigil's `ecdsa_p384_verify` takes a 96-B
# BE r||s buffer. So we (a) reject non-zero padding in the upper
# 24 bytes of each, (b) reverse the low 48 bytes of each into the
# 96-B BE buffer, (c) pass through `ecdsa_p384_verify`.
#
# The signed body is bytes 0..SNP_REPORT_BODY_SIZE of the
# report — `ecdsa_p384_verify` computes SHA-384 internally.
# ================================================================

var _snp_sig_be = 0;
var _snp_inited = 0;

fn _snp_v_init(): i64 {
    if (_snp_inited == 1) { return 0; }
    _snp_sig_be = alloc(96);
    _snp_inited = 1;
    return 0;
}

# Reverse `src` of length `len` into `dst` (byte-wise reversal).
fn _snp_reverse_bytes(dst, src, len): i64 {
    var i = 0;
    while (i < len) {
        store8(dst + i, load8(src + (len - 1 - i)) & 0xFF);
        i = i + 1;
    }
    return 0;
}

fn snp_report_verify(report, vcek_pk): i64 {
    _snp_v_init();

    # Re-check the signature algorithm — defense in depth (the
    # parser already gated this, but a caller could mutate the
    # struct between parse and verify).
    if (snp_report_signature_algo(report) != SNP_SIG_ECDSA_P384_SHA384) {
        return 0;
    }

    var buf = snp_report_buf(report);
    var sig_r_le = buf + SNP_OFF_SIG_R;
    var sig_s_le = buf + SNP_OFF_SIG_S;

    # Validate the high 24 bytes of each are zero. AMD pads the
    # 48-byte P-384 value to 72 bytes; the high bytes MUST be zero.
    # An attacker setting those would force a malformed-but-accepted
    # signature in a non-strict verifier.
    var i = SNP_P384_FIELD_BYTES;
    while (i < SNP_SIG_PADDED_R_LEN) {
        if ((load8(sig_r_le + i) & 0xFF) != 0) { return 0; }
        if ((load8(sig_s_le + i) & 0xFF) != 0) { return 0; }
        i = i + 1;
    }

    # Convert LE → BE for sigil's ecdsa_p384_verify.
    _snp_reverse_bytes(_snp_sig_be + 0, sig_r_le, SNP_P384_FIELD_BYTES);
    _snp_reverse_bytes(_snp_sig_be + 48, sig_s_le, SNP_P384_FIELD_BYTES);

    return ecdsa_p384_verify(vcek_pk, buf, SNP_REPORT_BODY_SIZE, _snp_sig_be);
}

# ================================================================
# snp_report_verify_full — end-to-end SEV-SNP verify (3.4.1).
#
# Pipeline:
#   1. pem_decode_certs(vcek_chain_pem, …) → array of DER certs.
#   2. x509_parse each in-quote cert + the caller's ARK root.
#   3. Drop self-issued top-of-chain (embedded ARK copy) if
#      present; reverse remaining intermediates into issuer-
#      towards-leaf order.
#   4. x509_verify_chain anchored on caller's `ark_root_der`.
#   5. Verify the leaf is a P-384 cert with a 96-byte pubkey
#      (snp_report_verify requires a P-384 VCEK key).
#   6. Extract the 96-byte VCEK pubkey from the leaf and call
#      snp_report_verify(report, vcek_pk).
#
# Same alloc-drift LOW shape as `sgx_quote_verify_full` /
# `tdx_quote_verify_full` — closes at 3.6 with the unified `_into`
# API. The VCEK chain bytes are caller-owned; sigil reads them
# in-place via the DER pointers stashed in `out_chain` entries.
#
# Returns 1 on full success, 0 on any failure.
# ================================================================

var SNP_VERIFY_FULL_MAX_CERTS = 4;

fn _snp_cert_is_self_issued(c): i64 {
    var buf = load64(c + 0);
    var iss_off = load64(c + 48); var iss_len = load64(c + 56);
    var sub_off = load64(c + 64); var sub_len = load64(c + 72);
    return _x509_dn_eq(buf, iss_off, iss_len, buf, sub_off, sub_len);
}

fn snp_report_verify_full(report, vcek_chain_pem, vcek_chain_pem_len,
                            ark_root_der, ark_root_der_len, now_unix): i64 {
    # Cert chain must be non-empty.
    if (vcek_chain_pem_len <= 0) { return 0; }
    if (ark_root_der_len <= 0) { return 0; }

    # Re-check the report's signature_algo gate — defence in
    # depth; snp_report_verify also gates this, but a malformed
    # report mutated between parse and verify must not slip
    # through verify_full either.
    if (snp_report_signature_algo(report) != SNP_SIG_ECDSA_P384_SHA384) {
        return 0;
    }

    var chain[64];
    memset(&chain, 0, 64);
    var n = pem_decode_certs(vcek_chain_pem, vcek_chain_pem_len,
                              &chain, SNP_VERIFY_FULL_MAX_CERTS);
    if (n < 1) { return 0; }

    var parsed[4];
    var i = 0;
    while (i < n) {
        var c = x509_cert_alloc();
        var ptr = load64(&chain + i * 16);
        var len = load64(&chain + i * 16 + 8);
        if (x509_parse(ptr, len, c) != 1) { return 0; }
        store64(&parsed + i * 8, c);
        i = i + 1;
    }

    var root = x509_cert_alloc();
    if (x509_parse(ark_root_der, ark_root_der_len, root) != 1) { return 0; }

    # Leaf at chain[0]; drop self-issued top (embedded ARK copy).
    var leaf = load64(&parsed + 0);
    var top_idx = n - 1;
    if (n >= 2) {
        var top = load64(&parsed + top_idx * 8);
        if (_snp_cert_is_self_issued(top) == 1) { top_idx = top_idx - 1; }
    }

    var inters[4];
    memset(&inters, 0, 32);
    var inters_n = 0;
    i = top_idx;
    while (i >= 1) {
        store64(&inters + inters_n * 8, load64(&parsed + i * 8));
        inters_n = inters_n + 1;
        i = i - 1;
    }

    if (x509_verify_chain(leaf, &inters, inters_n, root, now_unix) != 1) {
        return 0;
    }

    # VCEK leaf must be P-384 — `snp_report_verify` needs a
    # 96-byte pubkey to chain into `ecdsa_p384_verify`. A P-256
    # leaf would parse cleanly but would silently misalign
    # downstream (only the lower 64 bytes of the pubkey slot
    # hold data); reject explicitly.
    if (x509_cert_curve(leaf) != X509_CURVE_P384) { return 0; }
    if (x509_cert_pubkey_len(leaf) != 96) { return 0; }

    var vcek_pk = x509_cert_pubkey(leaf);
    return snp_report_verify(report, vcek_pk);
}

# --- tdx.cyr ---

# tdx.cyr — Intel TDX v4 TD-quote parser + verify orchestrator.
#
# Sigil 3.2.5 — bite 5 of the TEE attestation arc (origin:
# `docs/development/3.2-tee-arc.md`).
#
# TDX quotes share the SGX DCAP signature-section layout — the
# quoting enclave that signs a TD-quote runs on Intel SGX
# hardware on the same host, so the AK / PCK / QE-report dance is
# byte-identical to SGX (see `src/sgx.cyr`). What differs:
#   • Header byte 0..1: version = 4 (vs SGX's 3)
#   • Header byte 4..7: tee_type = 0x00000081 (TDX) (vs SGX's
#     all-zero reserved word)
#   • Quote body: a 584-byte TD_QUOTE_BODY (vs SGX's 384-byte
#     EnclaveReport) carrying MRTD / MRSEAM / RTMR0..3 etc.
#
# Scope (per the 3.2.3 / 3.2.4 pattern): parser-only with a
# verify orchestrator that takes a pre-validated PCK pubkey. The
# X.509 chain walk from the in-quote PCK leaf up to Intel SGX
# Root CA is the caller's responsibility for now — TDX shares
# the SGX cert chain so reusing kavach's external walk is the
# natural fit.
#
# Both att_key_type variants are supported as of 3.5:
#   • att_key_type = 2 (ECDSA P-256 / SHA-256) — TDX 1.0 default.
#   • att_key_type = 3 (ECDSA P-384 / SHA-384) — TDX 1.5+.
# In both cases the PCK chain itself is P-256 (Intel's PCK is
# always P-256 across SGX and TDX); only the AK (which signs the
# quote body) shifts curves. The AK→QE binding hash in
# qe_report.report_data[0:32] uses SHA-256 for type=2 and the
# lower 32 bytes of SHA-384 for type=3 (the upper 16 bytes are
# unused — the 64-byte report_data slot is too small to carry the
# full 48-byte SHA-384 digest, so the spec truncates).
#
# Surface:
#   fn tdx_quote_parse(buf, buf_len, out): i64
#       — 1 = ok, 0 = malformed/unsupported.
#   fn tdx_quote_verify_with_pck(quote, pck_pk): i64
#       — three internal sig checks (PCK→QE-report, AK binding,
#         AK→quote-body). PCK pubkey is 64 B raw Qx||Qy big-
#         endian, externally validated by the caller's X.509
#         chain walk. Dispatches internally on att_key_type to
#         the P-256 or P-384 AK path.
#   fn tdx_quote_verify_full(quote, root_ca_der, root_ca_der_len,
#                              now_unix): i64
#       — end-to-end: parses the in-quote PEM PCK chain (must be
#         cert_data_type 5), walks it anchored at the caller-
#         provided Intel SGX Root CA, extracts the PCK pubkey
#         from the leaf, and chains into tdx_quote_verify_with_pck.

# ================================================================
# Format constants
# ================================================================

var TDX_QUOTE_HEADER_SIZE        = 48;
var TDX_QUOTE_BODY_SIZE          = 584;   # TD_QUOTE_BODY
var TDX_QUOTE_SIGNED_PREFIX_SIZE = 632;   # header + body

# Per-attestation-key widths. att_key_type=2 → P-256 (64 B); =3 → P-384 (96 B).
var TDX_AK_SIZE_P256             = 64;
var TDX_AK_SIZE_P384             = 96;
var TDX_ECDSA_SIG_SIZE_P256      = 64;
var TDX_ECDSA_SIG_SIZE_P384      = 96;

# Legacy aliases retained for outside-module call sites that
# already use the P-256 names (the original 3.2.5 surface).
var TDX_AK_SIZE                  = 64;
var TDX_ECDSA_SIG_SIZE           = 64;

var TDX_MIN_QUOTE_SIZE           = 48 + 584 + 4 + 64 + 64 + 384 + 64 + 2 + 2 + 4;

var TDX_QUOTE_VERSION_V4         = 4;
var TDX_ATT_KEY_TYPE_ECDSA_P256  = 2;
var TDX_ATT_KEY_TYPE_ECDSA_P384  = 3;
var TDX_TEE_TYPE_TDX             = 0x81;
# qe_cert_data_type 5 = PCK Cert Chain (PEM) — Intel DCAP spec.
var TDX_CERT_TYPE_PCK_PEM        = 5;

# Field offsets inside TD_QUOTE_BODY (per Intel TDX 1.0 quote spec).
var TDX_BODY_OFF_TEE_TCB_SVN     = 0;
var TDX_BODY_OFF_MRSEAM          = 16;
var TDX_BODY_OFF_MRSEAMSIGNER    = 64;
var TDX_BODY_OFF_SEAM_ATTRIBUTES = 112;
var TDX_BODY_OFF_TD_ATTRIBUTES   = 120;
var TDX_BODY_OFF_XFAM            = 128;
var TDX_BODY_OFF_MRTD            = 136;
var TDX_BODY_OFF_MRCONFIGID      = 184;
var TDX_BODY_OFF_MROWNER         = 232;
var TDX_BODY_OFF_MROWNERCONFIG   = 280;
var TDX_BODY_OFF_RTMR0           = 328;
var TDX_BODY_OFF_RTMR1           = 376;
var TDX_BODY_OFF_RTMR2           = 424;
var TDX_BODY_OFF_RTMR3           = 472;
var TDX_BODY_OFF_REPORT_DATA     = 520;

# ================================================================
# TdxQuote struct — 256 bytes
#
#    0  buf_ptr
#    8  buf_len
#   16  version
#   24  att_key_type
#   32  tee_type
#   40  header_off (always 0)
#   48  td_body_off (always 48)
#   56  signature_data_len
#   64  ecdsa_sig_off            — 64 B raw r||s
#   72  ak_off                   — 64 B Qx||Qy
#   80  qe_report_off            — 384 B (SGX enclave report shape)
#   88  qe_report_sig_off        — 64 B raw r||s
#   96  qe_auth_data_off
#  104  qe_auth_data_len
#  112  qe_cert_data_type
#  120  qe_cert_data_off
#  128  qe_cert_data_len
#  136..255  reserved
# ================================================================

fn tdx_quote_alloc(): i64 {
    var q = alloc(256);
    memset(q, 0, 256);
    return q;
}

# Little-endian word loads — same shape as the SGX helpers but
# private to this module (keeps modules loosely coupled; promoting
# to a shared lib/le.cyr can wait until a third consumer arrives).
fn _tdx_load_u16(buf, off): i64 {
    return (load8(buf + off) & 0xFF)
         | ((load8(buf + off + 1) & 0xFF) << 8);
}

fn _tdx_load_u32(buf, off): i64 {
    return (load8(buf + off) & 0xFF)
         | ((load8(buf + off + 1) & 0xFF) << 8)
         | ((load8(buf + off + 2) & 0xFF) << 16)
         | ((load8(buf + off + 3) & 0xFF) << 24);
}

# ================================================================
# Field accessors
# ================================================================

fn tdx_quote_buf(q): i64                { return load64(q + 0); }
fn tdx_quote_buf_len(q): i64            { return load64(q + 8); }
fn tdx_quote_version(q): i64            { return load64(q + 16); }
fn tdx_quote_att_key_type(q): i64       { return load64(q + 24); }
fn tdx_quote_tee_type(q): i64           { return load64(q + 32); }

fn tdx_quote_td_body_ptr(q): i64        { return load64(q + 0) + load64(q + 48); }

fn tdx_quote_mrseam_ptr(q): i64         { return tdx_quote_td_body_ptr(q) + TDX_BODY_OFF_MRSEAM; }
fn tdx_quote_mrseamsigner_ptr(q): i64   { return tdx_quote_td_body_ptr(q) + TDX_BODY_OFF_MRSEAMSIGNER; }
fn tdx_quote_mrtd_ptr(q): i64           { return tdx_quote_td_body_ptr(q) + TDX_BODY_OFF_MRTD; }
fn tdx_quote_mrconfigid_ptr(q): i64     { return tdx_quote_td_body_ptr(q) + TDX_BODY_OFF_MRCONFIGID; }
fn tdx_quote_mrowner_ptr(q): i64        { return tdx_quote_td_body_ptr(q) + TDX_BODY_OFF_MROWNER; }
fn tdx_quote_rtmr0_ptr(q): i64          { return tdx_quote_td_body_ptr(q) + TDX_BODY_OFF_RTMR0; }
fn tdx_quote_rtmr1_ptr(q): i64          { return tdx_quote_td_body_ptr(q) + TDX_BODY_OFF_RTMR1; }
fn tdx_quote_rtmr2_ptr(q): i64          { return tdx_quote_td_body_ptr(q) + TDX_BODY_OFF_RTMR2; }
fn tdx_quote_rtmr3_ptr(q): i64          { return tdx_quote_td_body_ptr(q) + TDX_BODY_OFF_RTMR3; }
fn tdx_quote_report_data_ptr(q): i64    { return tdx_quote_td_body_ptr(q) + TDX_BODY_OFF_REPORT_DATA; }
fn tdx_quote_td_attributes_ptr(q): i64  { return tdx_quote_td_body_ptr(q) + TDX_BODY_OFF_TD_ATTRIBUTES; }
fn tdx_quote_xfam_ptr(q): i64           { return tdx_quote_td_body_ptr(q) + TDX_BODY_OFF_XFAM; }

fn tdx_quote_ak_ptr(q): i64             { return load64(q + 0) + load64(q + 72); }
fn tdx_quote_ecdsa_sig_ptr(q): i64      { return load64(q + 0) + load64(q + 64); }

# Per-att_key_type widths. The signature section's `ecdsa_sig` and
# `attestation_key` are 64 B each for type=2 (P-256) and 96 B each
# for type=3 (P-384). All other fields are width-invariant.
fn tdx_quote_ak_size(q): i64 {
    if (load64(q + 24) == TDX_ATT_KEY_TYPE_ECDSA_P384) { return TDX_AK_SIZE_P384; }
    return TDX_AK_SIZE_P256;
}
fn tdx_quote_ecdsa_sig_size(q): i64 {
    if (load64(q + 24) == TDX_ATT_KEY_TYPE_ECDSA_P384) { return TDX_ECDSA_SIG_SIZE_P384; }
    return TDX_ECDSA_SIG_SIZE_P256;
}
fn tdx_quote_qe_report_ptr(q): i64      { return load64(q + 0) + load64(q + 80); }
fn tdx_quote_qe_report_sig_ptr(q): i64  { return load64(q + 0) + load64(q + 88); }
fn tdx_quote_qe_auth_data_ptr(q): i64   { return load64(q + 0) + load64(q + 96); }
fn tdx_quote_qe_auth_data_len(q): i64   { return load64(q + 104); }
fn tdx_quote_cert_data_type(q): i64     { return load64(q + 112); }
fn tdx_quote_cert_data_ptr(q): i64      { return load64(q + 0) + load64(q + 120); }
fn tdx_quote_cert_data_len(q): i64      { return load64(q + 128); }

# ================================================================
# tdx_quote_parse — single-pass linear walk.
# ================================================================

fn tdx_quote_parse(buf, buf_len, out): i64 {
    memset(out, 0, 256);

    if (buf_len < TDX_MIN_QUOTE_SIZE) { return 0; }

    var version      = _tdx_load_u16(buf, 0);
    var att_key_type = _tdx_load_u16(buf, 2);
    var tee_type     = _tdx_load_u32(buf, 4);

    if (version != TDX_QUOTE_VERSION_V4) { return 0; }
    if (att_key_type != TDX_ATT_KEY_TYPE_ECDSA_P256) {
        if (att_key_type != TDX_ATT_KEY_TYPE_ECDSA_P384) { return 0; }
    }
    if (tee_type != TDX_TEE_TYPE_TDX) { return 0; }

    # Per-att_key_type field widths for ecdsa_sig and ak_pub.
    var ak_w = TDX_AK_SIZE_P256;
    var sig_w = TDX_ECDSA_SIG_SIZE_P256;
    if (att_key_type == TDX_ATT_KEY_TYPE_ECDSA_P384) {
        ak_w = TDX_AK_SIZE_P384;
        sig_w = TDX_ECDSA_SIG_SIZE_P384;
    }

    store64(out + 0,  buf);
    store64(out + 8,  buf_len);
    store64(out + 16, version);
    store64(out + 24, att_key_type);
    store64(out + 32, tee_type);
    store64(out + 40, 0);
    store64(out + 48, TDX_QUOTE_HEADER_SIZE);

    # signature_data_len
    var sig_len_off = TDX_QUOTE_HEADER_SIZE + TDX_QUOTE_BODY_SIZE;
    if (sig_len_off + 4 > buf_len) { return 0; }
    var sig_data_len = _tdx_load_u32(buf, sig_len_off);
    var sig_data_off = sig_len_off + 4;
    if (sig_data_len < 0) { return 0; }
    if (sig_data_off + sig_data_len > buf_len) { return 0; }
    # Fixed-part minimum depends on att_key_type. The QE report's
    # own signature (qe_report_sig) is always 64 B (Intel PCK is
    # P-256 across all variants); only ecdsa_sig + ak widen.
    var sig_min_fixed = sig_w + ak_w + 384 + TDX_ECDSA_SIG_SIZE_P256
                       + 2 + 2 + 4;
    if (sig_data_len < sig_min_fixed) { return 0; }

    store64(out + 56, sig_data_len);

    var cur = sig_data_off;
    var sig_section_end = sig_data_off + sig_data_len;

    # ecdsa_signature (64 or 96 B per att_key_type)
    store64(out + 64, cur);
    cur = cur + sig_w;
    # attestation_key (64 or 96 B per att_key_type)
    store64(out + 72, cur);
    cur = cur + ak_w;
    # qe_report (384 B — SGX enclave report shape)
    store64(out + 80, cur);
    cur = cur + 384;
    # qe_report_signature (64 B — always P-256, Intel PCK is P-256)
    store64(out + 88, cur);
    cur = cur + TDX_ECDSA_SIG_SIZE_P256;

    # qe_auth_data: u16 size + bytes
    if (cur + 2 > sig_section_end) { return 0; }
    var auth_len = _tdx_load_u16(buf, cur);
    if (auth_len < 0) { return 0; }
    if (cur + 2 + auth_len > sig_section_end) { return 0; }
    store64(out + 96, cur + 2);
    store64(out + 104, auth_len);
    cur = cur + 2 + auth_len;

    # qe_cert_data: u16 type + u32 size + bytes
    if (cur + 6 > sig_section_end) { return 0; }
    var cert_type = _tdx_load_u16(buf, cur);
    var cert_len  = _tdx_load_u32(buf, cur + 2);
    if (cert_len < 0) { return 0; }
    if (cur + 6 + cert_len > sig_section_end) { return 0; }
    if (cur + 6 + cert_len != sig_section_end) { return 0; }
    store64(out + 112, cert_type);
    store64(out + 120, cur + 6);
    store64(out + 128, cert_len);

    return 1;
}

# ================================================================
# Verify orchestrator — same three-step shape as SGX, with the
# signed body being 632 bytes (header + TD report body) instead
# of SGX's 432 (header + enclave report).
# ================================================================

# SGX-style report-data offset inside the QE report.
var TDX_QE_REPORT_OFF_REPORT_DATA = 320;

var _tdxv_binding_input = 0;
var _tdxv_binding_hash  = 0;
var _tdxv_quote_body    = 0;
var _tdxv_inited = 0;

fn _tdxv_init(): i64 {
    if (_tdxv_inited == 1) { return 0; }
    # Binding input must hold AK (96 max — P-384 case) + qe_auth_data (≤ 65535).
    _tdxv_binding_input = alloc(96 + 65536);
    # Binding hash: 32 B for SHA-256 (att_key_type=2), 48 B for SHA-384
    # (att_key_type=3). The full SHA-384 digest is computed; only the
    # lower 32 B are compared against qe_report.report_data[0:32].
    _tdxv_binding_hash  = alloc(48);
    # Signed prefix: header (48) + TD body (584) = 632 bytes.
    _tdxv_quote_body    = alloc(TDX_QUOTE_SIGNED_PREFIX_SIZE);
    _tdxv_inited = 1;
    return 0;
}

fn tdx_quote_verify_with_pck(quote, pck_pk): i64 {
    _tdxv_init();

    var att_key_type = tdx_quote_att_key_type(quote);

    # Step 1 — PCK signs the QE report (384 B SGX enclave report shape).
    # PCK is always P-256 across SGX/TDX variants.
    var qe_report = tdx_quote_qe_report_ptr(quote);
    var qe_report_sig = tdx_quote_qe_report_sig_ptr(quote);
    if (ecdsa_p256_verify(pck_pk, qe_report, 384, qe_report_sig) != 1) {
        return 0;
    }

    # Step 2 — AK binding via H(AK || qe_auth_data) in qe_report.report_data.
    # H is SHA-256 for att_key_type=2 (full 32-B digest) or SHA-384 for
    # att_key_type=3 (lower 32 B of the 48-B digest — the report_data
    # slot's first 32 bytes hold the binding; the slot's upper 32 bytes
    # are required-zero in both variants).
    var ak  = tdx_quote_ak_ptr(quote);
    var ak_w = tdx_quote_ak_size(quote);
    var aux = tdx_quote_qe_auth_data_ptr(quote);
    var aux_len = tdx_quote_qe_auth_data_len(quote);
    if (aux_len < 0) { return 0; }
    if (aux_len > 65536) { return 0; }

    var i = 0;
    while (i < ak_w) {
        store8(_tdxv_binding_input + i, load8(ak + i) & 0xFF);
        i = i + 1;
    }
    i = 0;
    while (i < aux_len) {
        store8(_tdxv_binding_input + ak_w + i, load8(aux + i) & 0xFF);
        i = i + 1;
    }
    if (att_key_type == TDX_ATT_KEY_TYPE_ECDSA_P384) {
        sha384(_tdxv_binding_input, ak_w + aux_len, _tdxv_binding_hash);
    } else {
        sha256(_tdxv_binding_input, ak_w + aux_len, _tdxv_binding_hash);
    }

    var rd = qe_report + TDX_QE_REPORT_OFF_REPORT_DATA;
    i = 0;
    while (i < 32) {
        if ((load8(rd + i) & 0xFF) != (load8(_tdxv_binding_hash + i) & 0xFF)) {
            return 0;
        }
        i = i + 1;
    }
    # Upper 32 B of report_data must be zero — defence-in-depth against
    # an attacker stuffing extra bytes that downstream consumers might
    # parse out of the 64-byte slot.
    i = 32;
    while (i < 64) {
        if ((load8(rd + i) & 0xFF) != 0) { return 0; }
        i = i + 1;
    }

    # Step 3 — AK signs the quote body (header || TD report body, 632 B).
    # ecdsa_p256_verify for type=2, ecdsa_p384_verify for type=3.
    var buf = tdx_quote_buf(quote);
    memcpy(_tdxv_quote_body, buf, TDX_QUOTE_SIGNED_PREFIX_SIZE);

    var ecdsa_sig = tdx_quote_ecdsa_sig_ptr(quote);
    if (att_key_type == TDX_ATT_KEY_TYPE_ECDSA_P384) {
        if (ecdsa_p384_verify(ak, _tdxv_quote_body,
                               TDX_QUOTE_SIGNED_PREFIX_SIZE,
                               ecdsa_sig) != 1) {
            return 0;
        }
    } else {
        if (ecdsa_p256_verify(ak, _tdxv_quote_body,
                               TDX_QUOTE_SIGNED_PREFIX_SIZE,
                               ecdsa_sig) != 1) {
            return 0;
        }
    }

    return 1;
}

# ================================================================
# tdx_quote_verify_full — end-to-end verify (3.5).
#
# TDX shares the SGX PCK cert chain, so structurally identical to
# `sgx_quote_verify_full`: parses the in-quote PEM PCK chain via
# `pem_decode_certs`, anchors verification on the caller-provided
# Intel SGX Root CA via `x509_verify_chain`, extracts the PCK
# pubkey from the leaf and chains into `tdx_quote_verify_with_pck`.
#
# The internal verify automatically dispatches on att_key_type
# (type=2 → P-256/SHA-256, type=3 → P-384/SHA-384), so both TDX 1.0
# and TDX 1.5+ deployments traverse the same entry point.
#
# Same alloc-drift LOW as sgx_quote_verify_full carries here —
# tracked in the same 2026-05-22 audit follow-up; closes when the
# unified `_into` API lands in 3.6.
# ================================================================

var TDX_VERIFY_FULL_MAX_CERTS = 4;

fn _tdx_cert_is_self_issued(c): i64 {
    var buf = load64(c + 0);
    var iss_off = load64(c + 48); var iss_len = load64(c + 56);
    var sub_off = load64(c + 64); var sub_len = load64(c + 72);
    return _x509_dn_eq(buf, iss_off, iss_len, buf, sub_off, sub_len);
}

fn tdx_quote_verify_full(quote, root_ca_der, root_ca_der_len, now_unix): i64 {
    # Step 1 — cert_data_type must be PEM PCK chain.
    if (tdx_quote_cert_data_type(quote) != TDX_CERT_TYPE_PCK_PEM) { return 0; }

    var cert_data = tdx_quote_cert_data_ptr(quote);
    var cert_data_len = tdx_quote_cert_data_len(quote);
    if (cert_data_len <= 0) { return 0; }

    # Step 2 — decode in-quote PEM cert blob.
    var chain[64];
    memset(&chain, 0, 64);
    var n = pem_decode_certs(cert_data, cert_data_len,
                              &chain, TDX_VERIFY_FULL_MAX_CERTS);
    if (n < 1) { return 0; }

    # Step 3 — parse each in-quote cert + caller's root.
    var parsed[4];
    var i = 0;
    while (i < n) {
        var c = x509_cert_alloc();
        var ptr = load64(&chain + i * 16);
        var len = load64(&chain + i * 16 + 8);
        if (x509_parse(ptr, len, c) != 1) { return 0; }
        store64(&parsed + i * 8, c);
        i = i + 1;
    }
    if (root_ca_der_len <= 0) { return 0; }
    var root = x509_cert_alloc();
    if (x509_parse(root_ca_der, root_ca_der_len, root) != 1) { return 0; }

    # Step 4 — assemble (leaf, intermediates, root). Drop self-issued
    # top-of-chain if present (the in-quote root copy).
    var leaf = load64(&parsed + 0);
    var top_idx = n - 1;
    if (n >= 2) {
        var top = load64(&parsed + top_idx * 8);
        if (_tdx_cert_is_self_issued(top) == 1) { top_idx = top_idx - 1; }
    }

    var inters[4];
    memset(&inters, 0, 32);
    var inters_n = 0;
    i = top_idx;
    while (i >= 1) {
        store64(&inters + inters_n * 8, load64(&parsed + i * 8));
        inters_n = inters_n + 1;
        i = i - 1;
    }

    # Step 5 — chain walk anchored on caller's root.
    if (x509_verify_chain(leaf, &inters, inters_n, root, now_unix) != 1) {
        return 0;
    }

    # Step 6 — verify quote against leaf pubkey (dispatches internally
    # on att_key_type for the P-256 vs P-384 AK path).
    var leaf_pk = x509_cert_pubkey(leaf);
    return tdx_quote_verify_with_pck(quote, leaf_pk);
}

# --- seal.cyr ---

# seal.cyr — SGX sealing key derivation.
#
# Sigil 3.2.6 — bite 6 (closeout) of the TEE attestation arc
# (origin: `docs/development/3.2-tee-arc.md`).
#
# Scope per the arc plan: a constrained KDF over a caller-provided
# sealing root. Sigil can't call SGX's EGETKEY directly — that
# instruction is only available inside an enclave on real SGX
# hardware. Consumers obtain the sealing root via their runtime's
# enclave entry (Gramine / Occlum / TDX TDG_MR_REPORT bridge) and
# hand the resulting 32-byte CPU-derived secret to this module.
#
# What this module owns:
#   • The KDF context (info-string layout, salt domain-separation
#     tag) that binds a derived key to (policy, measurement, ISVSVN,
#     caller-supplied key_id).
#   • HKDF-SHA256 composition via the existing `hkdf` surface from
#     `src/hkdf.cyr` (2.9.x — already audited).
#   • Symmetric seal/unseal aliases (literally the same derivation;
#     a deterministic KDF needs no inverse).
#
# What this module does NOT own:
#   • The actual sealing operation (AES-GCM encrypt the user payload
#     under the derived key) — the caller composes against
#     `src/aes_gcm.cyr` once they have the key. Keeping the KDF
#     surface narrow lets the caller pick their own AEAD nonce
#     scheme and AAD layout without sigil prescribing one.
#   • Authenticated reads of MRSIGNER / MRENCLAVE / ISVSVN — those
#     come from a parsed SGX quote (3.2.3) or directly from the
#     caller's enclave-side report. Sigil verifies the report; the
#     caller drives the seal_key call with the verified fields.
#
# Surface:
#   fn sgx_derive_seal_key(sealing_root, policy, measurement,
#                          isvsvn, key_id, key_id_len, out_key)
#       — 1 = ok, 0 = invalid policy / key_id_len.
#   fn sgx_seal_key(...)    — alias for derive (seal-side caller).
#   fn sgx_unseal_key(...)  — alias for derive (unseal-side caller).
#
# Reference: Intel SGX SDK sealing model (sgx_seal_data /
# sgx_unseal_data). Sigil takes the EGETKEY-result as input rather
# than emulating EGETKEY — that's a deliberate scope cut (sigil
# has no access to the CPU's sealing-root register).

# ================================================================
# Constants
# ================================================================

# Policy: binds derived keys to either the enclave signer or the
# specific enclave measurement. SGX historically called these
# "POLICY_MRSIGNER" (re-deploys with the same signer can unseal)
# and "POLICY_MRENCLAVE" (only this exact build can unseal).
var SGX_SEAL_POLICY_MRSIGNER  = 0;
var SGX_SEAL_POLICY_MRENCLAVE = 1;

# Output key width — sigil currently fixes at 32 bytes (AES-256-GCM
# native). A future bite that supports 16-byte AES-128 keys can
# parameterise.
var SGX_SEAL_KEY_SIZE         = 32;

# Maximum caller-supplied `key_id` length. The info buffer is
# stack-allocated below at a fixed size; cap key_id so info never
# exceeds the scratch capacity. 256 bytes is generous for the
# binding-tag use case (typical key_ids are ASCII labels under 64
# bytes).
var SGX_SEAL_MAX_KEY_ID       = 256;

# Domain-separation salt — pins the KDF to sigil's seal surface so
# the same sealing_root used in an unrelated HKDF call elsewhere
# cannot derive the same key. v1 reserves room for future
# protocol-level bumps.
var SGX_SEAL_SALT             = "sigil-sgx-seal-v1";
var SGX_SEAL_SALT_LEN         = 17;

# Long-lived scratch (init-time alloc, reused per call).
# Info layout (35 + key_id_len bytes):
#   info[0]      policy (u8)
#   info[1..3]   isvsvn (big-endian u16)
#   info[3..35]  measurement (32 bytes)
#   info[35..]   key_id
var _seal_info     = 0;
var _seal_inited   = 0;

fn _seal_init(): i64 {
    if (_seal_inited == 1) { return 0; }
    # Max info size: 35 + SGX_SEAL_MAX_KEY_ID = 291 bytes.
    _seal_info = alloc(35 + SGX_SEAL_MAX_KEY_ID);
    _seal_inited = 1;
    return 0;
}

# ================================================================
# sgx_derive_seal_key — core KDF
#
# Inputs:
#   sealing_root  — 32 bytes (the EGETKEY result, caller-supplied)
#   policy        — SGX_SEAL_POLICY_MRSIGNER or _MRENCLAVE
#   measurement   — 32 bytes (MRSIGNER for policy=0, MRENCLAVE for 1)
#   isvsvn        — 16-bit unsigned (≥ 0, < 2^16)
#   key_id        — caller-supplied binding bytes
#   key_id_len    — length of key_id (0 ≤ len ≤ SGX_SEAL_MAX_KEY_ID)
#   out_key       — 32-byte output buffer
#
# Returns 1 on success, 0 on input-range failure. The returned key
# is the same byte sequence for identical inputs — both seal and
# unseal call this fn with the same (measurement, isvsvn, key_id).
# ================================================================

fn sgx_derive_seal_key(sealing_root, policy, measurement, isvsvn,
                       key_id, key_id_len, out_key): i64 {
    _seal_init();

    # Validate inputs.
    if (policy != SGX_SEAL_POLICY_MRSIGNER) {
        if (policy != SGX_SEAL_POLICY_MRENCLAVE) { return 0; }
    }
    if (isvsvn < 0) { return 0; }
    if (isvsvn > 65535) { return 0; }
    if (key_id_len < 0) { return 0; }
    if (key_id_len > SGX_SEAL_MAX_KEY_ID) { return 0; }

    # Build info buffer.
    store8(_seal_info + 0, policy & 0xFF);
    # ISVSVN big-endian (matches the on-wire convention used by SGX
    # reports / quotes — keeps any future cross-checks against
    # quote.report_body.isv_svn straightforward).
    store8(_seal_info + 1, (isvsvn >> 8) & 0xFF);
    store8(_seal_info + 2, isvsvn & 0xFF);
    # Measurement (32 bytes).
    var i = 0;
    while (i < 32) {
        store8(_seal_info + 3 + i, load8(measurement + i) & 0xFF);
        i = i + 1;
    }
    # Caller-supplied key_id.
    i = 0;
    while (i < key_id_len) {
        store8(_seal_info + 35 + i, load8(key_id + i) & 0xFF);
        i = i + 1;
    }

    # HKDF-SHA256 over the constructed info. hkdf() returns 0 on
    # success, non-zero on error; normalise to sigil's 1/0 convention.
    var rc = hkdf(SGX_SEAL_SALT, SGX_SEAL_SALT_LEN,
                  sealing_root, 32,
                  _seal_info, 35 + key_id_len,
                  out_key, SGX_SEAL_KEY_SIZE);
    if (rc != 0) { return 0; }
    return 1;
}

# Aliases — same operation, names match the arc plan's surface.
# A deterministic KDF needs no inverse; "seal" and "unseal" are
# semantic labels for the caller's surrounding AEAD encrypt/decrypt
# step.

fn sgx_seal_key(sealing_root, policy, measurement, isvsvn,
                key_id, key_id_len, out_key): i64 {
    return sgx_derive_seal_key(sealing_root, policy, measurement, isvsvn,
                                key_id, key_id_len, out_key);
}

fn sgx_unseal_key(sealing_root, policy, measurement, isvsvn,
                  key_id, key_id_len, out_key): i64 {
    return sgx_derive_seal_key(sealing_root, policy, measurement, isvsvn,
                                key_id, key_id_len, out_key);
}

# --- mldsa_params.cyr ---

# mldsa_params.cyr — ML-DSA parameters (FIPS 204, August 2024)
#
# Module-lattice-based digital signature — the post-quantum signing
# half of sigil 3.0. Keccak / SHAKE plumbing comes from Cyrius
# stdlib (`lib/keccak.cyr`, since 5.4.15); ML-DSA rides on top.
#
# Reference: NIST FIPS 204 final, August 13, 2024.
# Canonical impl: github.com/pq-crystals/dilithium (ref/).
#
# Only ML-DSA-65 (NIST security category 3) is parameterised here.
# ML-DSA-44 and ML-DSA-87 can be layered later without disturbing
# these constants — hence the MLDSA_ vs MLDSA65_ prefix split.
#
# Constants shadow the pq-crystals ref/params.h names so any
# cross-reference against that source reads identically.

# ================================================================
# Universal ML-DSA parameters (shared across 44/65/87)
# ================================================================
# Spec FIPS 204 §4 Table 1. These are independent of the security
# category — every ML-DSA instance uses the same ring Z_q[X]/(X^n+1)
# and the same Power2Round dropped-bit count d.

var MLDSA_N = 256;                  # ring poly degree (also SHAKE sample count per poly)
var MLDSA_Q = 8380417;              # prime modulus = 2^23 - 2^13 + 1
var MLDSA_D = 13;                   # Power2Round drops the bottom d bits of t
var MLDSA_ROOT_OF_UNITY = 1753;     # primitive 512th root of unity mod Q, Montgomery form

# Seed-level sizes
var MLDSA_SEEDBYTES = 32;           # ξ, ρ, rnd: 32-byte inputs to SHAKE
var MLDSA_CRHBYTES = 64;            # CRH output length (SHAKE-256 squeeze depth for μ, ρ')
var MLDSA_TRBYTES = 64;             # tr = SHAKE-256(pk, 64) — key-commitment hash
var MLDSA_RNDBYTES = 32;            # signing randomness (hedged mode)

# ================================================================
# ML-DSA-65 parameters (NIST security category 3)
# ================================================================
# Per spec FIPS 204 §4 Table 1, ML-DSA-65 column.

var MLDSA65_K = 6;                  # matrix rows (t, w, etc. live in R_q^k)
var MLDSA65_L = 5;                  # matrix cols (s1, y, z live in R_q^l)
var MLDSA65_ETA = 4;                # secret-key coefficient range: [-η, η]
var MLDSA65_TAU = 49;               # number of ±1 coefficients in the challenge c
var MLDSA65_BETA = 196;             # = τ * η, commitment-norm bound
var MLDSA65_GAMMA1 = 524288;        # = 1 << 19, mask range for y (§4 Table 1)
var MLDSA65_GAMMA2 = 261888;        # = (Q-1)/32, low-bits decompose radius
var MLDSA65_OMEGA = 55;             # hint-weight cap across the polynomial vector
var MLDSA65_CTILDEBYTES = 48;       # c̃ output length, 2·λ/8 bits at λ=192

# ================================================================
# Packed-poly byte sizes (ML-DSA-65, derived from the params above)
# ================================================================
# Each is bytes-per-poly (one poly = N=256 coefficients). Kept as
# literals rather than expressions because Cyrius module-scope
# var initializers are evaluated as runtime assignment, not CTFE.
# The test file asserts each derivation against the underlying
# parameters so drift is caught immediately.

var MLDSA65_POLYT1_PACKEDBYTES = 320;       # t1 bits = 23-D = 10, so 10*N/8 = 320
var MLDSA65_POLYT0_PACKEDBYTES = 416;       # t0 bits = D+1 = 13, so 13*N/8 = 416 (balanced)
var MLDSA65_POLYZ_PACKEDBYTES = 640;        # z bits = 20 (GAMMA1 = 1<<19 → log2+1), 20*N/8 = 640
var MLDSA65_POLYW1_PACKEDBYTES = 128;       # w1 bits = 4 (GAMMA2 = (Q-1)/32 branch), 4*N/8 = 128
var MLDSA65_POLYETA_PACKEDBYTES = 128;      # η=4 → 4 bits per coeff, 4*N/8 = 128
var MLDSA65_POLYVECH_PACKEDBYTES = 61;      # hint vec: OMEGA + K = 55 + 6 = 61

# ================================================================
# Public API byte sizes (ML-DSA-65)
# ================================================================
# Spec §5.1/§5.2 pk/sk encoding; §7.2 sig encoding.
#   pk = ρ ‖ t1                    = SEEDBYTES + K·POLYT1_PACKEDBYTES
#   sk = ρ ‖ K ‖ tr ‖ s1 ‖ s2 ‖ t0 = 2·SEEDBYTES + TRBYTES
#                                    + L·POLYETA_PACKEDBYTES
#                                    + K·POLYETA_PACKEDBYTES
#                                    + K·POLYT0_PACKEDBYTES
#   sig = c̃ ‖ z ‖ h               = CTILDEBYTES + L·POLYZ_PACKEDBYTES
#                                    + POLYVECH_PACKEDBYTES
# The concrete numbers for ML-DSA-65 land at:

var MLDSA65_PK_BYTES = 1952;        # = 32 + 6*320
var MLDSA65_SK_BYTES = 4032;        # = 64 + 64 + 5*128 + 6*128 + 6*416
var MLDSA65_SIG_BYTES = 3309;       # = 48 + 5*640 + 61

# --- mldsa_reduce.cyr ---

# mldsa_reduce.cyr — modular reduction primitives for ML-DSA
#
# Three operations used throughout the NTT / poly arithmetic
# layers. Bounds and formulas mirror pq-crystals/dilithium
# `ref/reduce.c`, which is the FIPS-204 reference implementation.
#
# Representation: every coefficient is a Cyrius i64 holding the
# signed 32-bit Montgomery-form value. Callers keep the value
# within the documented bounds of each helper; we do not re-check.
#
# Cyrius arithmetic notes (cc5):
#   - `>>` is LOGICAL shift right (zero-fill). Do not use for
#     arithmetic sign-extension.
#   - `/` is SIGNED 64-bit integer division (IDIV). Safe for the
#     Montgomery divide-by-2^32 step because the dividend is
#     always exactly divisible by 2^32.
#   - Integer wraparound is i64 two's-complement; subtracting a
#     larger unsigned value naturally produces a negative i64.
#
# Constants (from pq-crystals ref/reduce.h):
#   MONT  = -4186625  = 2^32  mod Q  in signed form (Montgomery R)
#   QINV  =  58728449 = Q^{-1} mod 2^32 (used in montgomery_reduce)
# Neither constant is parameter-set dependent; both hold for every
# ML-DSA variant since they derive only from (Q, N).

var MLDSA_MONT = 0 - 4186625;           # R = 2^32 mod Q, signed form
var MLDSA_QINV = 58728449;              # Q * QINV ≡ -1 (mod 2^32)

# ================================================================
# mldsa_montgomery_reduce — montgomery_reduce in FIPS 204 notation
# ================================================================
# Input:  a  with |a| ≤ Q * 2^31
# Output: r  with |r| < Q     (r ≡ a * 2^{-32} mod Q)
#
# Algorithm (C reference):
#   t = (int32_t)a * QINV;                # low 32 bits of a*QINV, signed
#   r = (a - (int64_t)t * Q) >> 32;       # arithmetic shift right by 32
# Cyrius port:
#   - Compute low 32 bits of a*QINV via i64 wraparound arithmetic,
#     then sign-extend to i64 by subtracting 2^32 when bit 31 set.
#   - The final shift is implemented as signed division by 2^32,
#     which is equivalent here because `a - t*Q` is always an
#     exact multiple of 2^32 by Montgomery construction.

fn mldsa_montgomery_reduce(a): i64 {
    # Step 1: t_low = low 32 bits of a * QINV (unsigned view).
    var t_raw = a * MLDSA_QINV;
    var t_low = t_raw & 0xFFFFFFFF;
    # Sign-extend to i64: if bit 31 is set, subtract 2^32.
    var t = t_low - ((t_low & 0x80000000) << 1);
    # Step 2: arithmetic shift right by 32 on (a − t·Q).
    # The dividend is an exact multiple of 2^32 (Montgomery
    # construction), so ASR and signed division agree. We use
    # bitwise shift + sign-fill instead of IDIV because IDIV is
    # the slowest instruction in the butterfly hot path
    # (~20 cycles on modern x86 vs ~2 for shift+or) and because
    # IDIV's timing, though bounded here, depends on the quotient
    # magnitude — not strictly constant-time.
    var diff = a - t * MLDSA_Q;
    var logical = diff >> 32;
    var sign = (diff >> 63) & 1;
    var fill = (0 - sign) << 32;
    return logical | fill;
}

# ================================================================
# mldsa_reduce32 — reduce32 in FIPS 204 notation
# ================================================================
# Input:  a  with |a| ≤ 2^31 - 2^22 - 1  (spec constraint)
# Output: r  with -6283008 ≤ r ≤ 6283008  (r ≡ a mod Q)
#
# Barrett-style nearest-multiple reduction: the approximate
# quotient t = ⌊(a + 2^22) / 2^23⌋ rounds a/Q to nearest, and
# t·Q is subtracted from a. The residual's magnitude is at most
# ⌈Q/2⌉ plus a small rounding slack, giving the 6283008 bound.
#
# The `/ 2^23` in the C reference is an **arithmetic** shift —
# rounds toward −∞ — whereas Cyrius's `/` is IDIV, which truncates
# toward zero. The two agree on non-negative dividends but disagree
# on negative ones (for a = −Q, C gives t = −1, Cyrius IDIV would
# give t = 0). Emulate arithmetic shift right by 23 as
# `(x >> 23) | ((−sign(x)) << 41)`:
#   - `x >> 23` is Cyrius's logical right shift, fills zeros.
#   - `(x >> 63) & 1` exposes the i64 sign bit via that same
#     logical shift.
#   - `0 − sign` is all-ones on negative, zero otherwise; shifted
#     left 41 it forms a mask covering the top 23 bits, which the
#     OR folds into the logical-shift result.
# No data-dependent branch; all straight-line arithmetic.

fn mldsa_reduce32(a): i64 {
    var x = a + (1 << 22);
    var logical = x >> 23;
    var sign = (x >> 63) & 1;
    var fill = (0 - sign) << 41;
    var t = logical | fill;
    return a - t * MLDSA_Q;
}

# ================================================================
# mldsa_caddq — caddq in FIPS 204 notation (conditional add Q)
# ================================================================
# Input:  a  with -Q < a < Q
# Output: r  with 0 ≤ r < Q    (r ≡ a mod Q, canonical rep)
#
# The C reference uses `a + ((a >> 31) & Q)` where the shift is
# arithmetic on a signed int32. In Cyrius (logical >>, i64), we
# read the i64 sign bit directly: `(a >> 63) & 1` is 1 for any
# negative i64, 0 otherwise. Multiply by Q to get the conditional
# addend. No data-dependent branch — the sign-bit extraction and
# multiply are straight-line arithmetic.

fn mldsa_caddq(a): i64 {
    var neg = (a >> 63) & 1;
    return a + neg * MLDSA_Q;
}

# ================================================================
# mldsa_freeze — reduce to canonical [0, Q) representation
# ================================================================
# Convenience wrapper = caddq ∘ reduce32. Used at pack boundaries
# where the coefficient must be the unique in-range representative.

fn mldsa_freeze(a): i64 {
    return mldsa_caddq(mldsa_reduce32(a));
}

# --- mldsa_ntt.cyr ---

# mldsa_ntt.cyr — forward / inverse NTT for ML-DSA
#
# Cooley-Tukey negacyclic NTT over Z_q[X] / (X^256 + 1). The full
# inner geometry matches pq-crystals/dilithium `ref/ntt.c` — same
# zetas table, same butterfly layout, same +/- Montgomery form.
#
# Outer contract:
#   mldsa_ntt(a):            in-place forward NTT, natural → bit-reversed.
#                             No reductions after add/sub — callers must
#                             ensure inputs are within a single Q.
#   mldsa_invntt_tomont(a):  in-place inverse NTT, bit-reversed → natural.
#                             Result is pre-multiplied by Montgomery R^2/N
#                             (constant f = 41978 = MONT^2 / 256).
#
# Coefficient format: each coefficient is a Cyrius i64 holding a
# signed i32-range value (Montgomery form). Poly buffer is 256·8
# = 2048 bytes; caller allocates.
#
# Zetas table: 256 i32 constants from the pq-crystals reference,
# stored here as a little-endian hex literal and decoded once into
# an `alloc`-backed buffer at first use. This pattern mirrors
# src/aes_gcm.cyr's S-box bring-up — keeps the fixup count tiny
# (one literal) and avoids 256 store-and-hope init statements.

# ================================================================
# Module state
# ================================================================

var _mldsa_zetas = 0;           # alloc'd, 256 * 8 = 2048 bytes, sign-extended i64
var _mldsa_ntt_inited = 0;

# ================================================================
# Zetas as a little-endian hex string (256 × i32 → 2048 hex chars)
# ================================================================
# Generated from pq-crystals/dilithium ref/ntt.c `zetas[N]` with:
#   python3 -c 'for v in zetas: print("%02x%02x%02x%02x" % (v&0xff,...))'
# Each run of 8 hex chars is one i32, little-endian. Rows are 8
# values wide for diffability against the C reference.

fn _mldsa_zetas_hex(): i64 {
    return "";
}

# ================================================================
# Hex helpers
# ================================================================
# Local copies so ntt.cyr does not become dependent on aes_gcm.cyr
# for the nibble decoder. Inline cost is trivial.

fn _mldsa_nibble(c): i64 {
    if (c >= 48) { if (c <= 57) { return c - 48; } }
    if (c >= 97) { if (c <= 102) { return c - 87; } }
    return 0;
}

# Read 4 bytes (8 hex chars) starting at hex_str[idx * 8], little
# endian, return as sign-extended i64.
fn _mldsa_decode_i32_le(hex_str, idx): i64 {
    var base = idx * 8;
    var b0 = (_mldsa_nibble(load8(hex_str + base + 0) & 0xFF) << 4)
    | _mldsa_nibble(load8(hex_str + base + 1) & 0xFF);
    var b1 = (_mldsa_nibble(load8(hex_str + base + 2) & 0xFF) << 4)
    | _mldsa_nibble(load8(hex_str + base + 3) & 0xFF);
    var b2 = (_mldsa_nibble(load8(hex_str + base + 4) & 0xFF) << 4)
    | _mldsa_nibble(load8(hex_str + base + 5) & 0xFF);
    var b3 = (_mldsa_nibble(load8(hex_str + base + 6) & 0xFF) << 4)
    | _mldsa_nibble(load8(hex_str + base + 7) & 0xFF);
    var u = b0 | (b1 << 8) | (b2 << 16) | (b3 << 24);
    # Sign-extend the 32-bit value to i64.
    return u - ((u & 0x80000000) << 1);
}

# ================================================================
# Init — decode the zetas hex literal once into the module buffer.
# ================================================================

fn mldsa_ntt_init(): i64 {
    if (_mldsa_ntt_inited == 1) { return 0; }
    _mldsa_zetas = alloc(256 * 8);
    var hex = _mldsa_zetas_hex();
    var i = 0;
    while (i < 256) {
        store64(_mldsa_zetas + i * 8, _mldsa_decode_i32_le(hex, i));
        i = i + 1;
    }
    _mldsa_ntt_inited = 1;
    return 0;
}

# ================================================================
# Forward NTT — Cooley-Tukey, bit-reversed output
# ================================================================
# Matches pq-crystals ntt.c layout exactly. No reductions after
# add/sub; caller ensures inputs are small enough that i32 range
# is preserved (bounded by roughly Q after each layer).

fn mldsa_ntt(a): i64 {
    mldsa_ntt_init();
    var k = 0;
    var len = 128;
    while (len > 0) {
        var start = 0;
        while (start < 256) {
            k = k + 1;
            var zeta = load64(_mldsa_zetas + k * 8);
            var j = start;
            while (j < start + len) {
                var ajl = load64(a + (j + len) * 8);
                var t = mldsa_montgomery_reduce(zeta * ajl);
                var aj = load64(a + j * 8);
                store64(a + (j + len) * 8, aj - t);
                store64(a + j * 8, aj + t);
                j = j + 1;
            }
            start = j + len;
        }
        len = len >> 1;
    }
    return 0;
}

# ================================================================
# Inverse NTT (with Montgomery-factor multiply)
# ================================================================
# Output coefficient a[i] ≡ (original a[i]) · 2^32  (mod Q). The
# post-loop multiply by f = 41978 = R^2 / N gives us N^{-1}·R^2
# in a single Montgomery reduction — folding the inverse-N and
# the Montgomery-R correction into one scan of the buffer.

fn mldsa_invntt_tomont(a): i64 {
    mldsa_ntt_init();
    var k = 256;
    var len = 1;
    while (len < 256) {
        var start = 0;
        while (start < 256) {
            k = k - 1;
            var zeta = 0 - load64(_mldsa_zetas + k * 8);
            var j = start;
            while (j < start + len) {
                var aj = load64(a + j * 8);
                var ajl = load64(a + (j + len) * 8);
                store64(a + j * 8, aj + ajl);
                var d = aj - ajl;
                store64(a + (j + len) * 8, mldsa_montgomery_reduce(zeta * d));
                j = j + 1;
            }
            start = j + len;
        }
        len = len << 1;
    }
    # Final Montgomery multiply by f = mont^2 / N = 41978.
    var f = 41978;
    var j = 0;
    while (j < 256) {
        var aj = load64(a + j * 8);
        store64(a + j * 8, mldsa_montgomery_reduce(f * aj));
        j = j + 1;
    }
    return 0;
}

# --- mldsa_poly.cyr ---

# mldsa_poly.cyr — poly + polyvec operations for ML-DSA
#
# Thin layer over the reduce + NTT primitives that expresses
# the FIPS 204 signing / verification algorithms as polynomial
# vector arithmetic. The reference is pq-crystals/dilithium
# `ref/poly.c` + `ref/polyvec.c`; API surface and data layout
# match 1:1.
#
# Buffer layout (all heap-allocated by callers):
#   poly         — 256·8 bytes, one i64 per coefficient
#   polyvecl     — L (=5) × 2048 bytes; vec[i] = base + i·2048
#   polyveck     — K (=6) × 2048 bytes; same scheme
#   matrix A     — K · L × 2048 bytes; row i at base + i · L · 2048
#
# Hot paths (`polyvecl_pointwise_acc_montgomery`,
# `polyvec_matrix_pointwise_montgomery`) promote their loop
# state to module-level globals because cc5 clobbers locals
# across deeply nested call chains (the matrix product goes
# 3 levels deep into per-coefficient Montgomery reduces, same
# call-depth pattern that bit sha256 / ed25519).

# ================================================================
# Per-poly operations
# ================================================================

# c = a + b (componentwise, no modular reduction).
# Caller ensures |coeff| stays within a safe range.
fn mldsa_poly_add(c, a, b): i64 {
    var i = 0;
    while (i < 256) {
        store64(c + i * 8, load64(a + i * 8) + load64(b + i * 8));
        i = i + 1;
    }
    return 0;
}

# c = a - b (componentwise, no modular reduction).
fn mldsa_poly_sub(c, a, b): i64 {
    var i = 0;
    while (i < 256) {
        store64(c + i * 8, load64(a + i * 8) - load64(b + i * 8));
        i = i + 1;
    }
    return 0;
}

# Reduce every coefficient to [-6283008, 6283008] via reduce32.
fn mldsa_poly_reduce(a): i64 {
    var i = 0;
    while (i < 256) {
        store64(a + i * 8, mldsa_reduce32(load64(a + i * 8)));
        i = i + 1;
    }
    return 0;
}

# Bring every coefficient into canonical [0, Q) via caddq.
fn mldsa_poly_caddq(a): i64 {
    var i = 0;
    while (i < 256) {
        store64(a + i * 8, mldsa_caddq(load64(a + i * 8)));
        i = i + 1;
    }
    return 0;
}

# a ← a · 2^D  (used by verify to recover c · 2^D · t1). Assumes
# inputs fit in 2^{31-D} in absolute value — not checked.
fn mldsa_poly_shiftl(a): i64 {
    var i = 0;
    while (i < 256) {
        store64(a + i * 8, load64(a + i * 8) << MLDSA_D);
        i = i + 1;
    }
    return 0;
}

# c[i] = montgomery_reduce(a[i] · b[i]).
# Used in NTT domain: multiplies two NTT-form polys and brings
# the product back into a Montgomery-form representation of the
# same length.
fn mldsa_poly_pointwise_montgomery(c, a, b): i64 {
    var i = 0;
    while (i < 256) {
        var prod = load64(a + i * 8) * load64(b + i * 8);
        store64(c + i * 8, mldsa_montgomery_reduce(prod));
        i = i + 1;
    }
    return 0;
}

# Infinity-norm bound check: returns 1 if any |coeff| ≥ B, else 0.
# Early exit on the first violation is OK — the C ref notes the
# probability of each coefficient violating is independent of
# secret data; what must *not* leak is the sign of the violating
# coefficient, which this branchless abs() handles.
# B > (Q-1)/8 auto-fails to catch out-of-range bounds.
fn mldsa_poly_chknorm(a, B): i64 {
    if (B > (MLDSA_Q - 1) / 8) { return 1; }
    var i = 0;
    while (i < 256) {
        var c = load64(a + i * 8);
        # Branchless absolute value: sign_mask is 0 (c≥0) or −1 (c<0).
        var sign_mask = 0 - ((c >> 63) & 1);
        var abs_c = c - (sign_mask & (c + c));
        if (abs_c >= B) { return 1; }
        i = i + 1;
    }
    return 0;
}

# ================================================================
# Polyvec L (length L = 5)
# ================================================================

fn mldsa_polyvecl_add(w, u, v): i64 {
    var i = 0;
    while (i < MLDSA65_L) {
        mldsa_poly_add(w + i * 2048, u + i * 2048, v + i * 2048);
        i = i + 1;
    }
    return 0;
}

fn mldsa_polyvecl_reduce(v): i64 {
    var i = 0;
    while (i < MLDSA65_L) {
        mldsa_poly_reduce(v + i * 2048);
        i = i + 1;
    }
    return 0;
}

fn mldsa_polyvecl_ntt(v): i64 {
    var i = 0;
    while (i < MLDSA65_L) {
        mldsa_ntt(v + i * 2048);
        i = i + 1;
    }
    return 0;
}

fn mldsa_polyvecl_invntt_tomont(v): i64 {
    var i = 0;
    while (i < MLDSA65_L) {
        mldsa_invntt_tomont(v + i * 2048);
        i = i + 1;
    }
    return 0;
}

# r[i] = a · v[i] for i in 0..L (scalar-poly × vec).
fn mldsa_polyvecl_pointwise_poly_montgomery(r, a, v): i64 {
    var i = 0;
    while (i < MLDSA65_L) {
        mldsa_poly_pointwise_montgomery(r + i * 2048, a, v + i * 2048);
        i = i + 1;
    }
    return 0;
}

fn mldsa_polyvecl_chknorm(v, bound): i64 {
    var i = 0;
    while (i < MLDSA65_L) {
        if (mldsa_poly_chknorm(v + i * 2048, bound) == 1) { return 1; }
        i = i + 1;
    }
    return 0;
}

# ================================================================
# Polyvec K (length K = 6)
# ================================================================

fn mldsa_polyveck_add(w, u, v): i64 {
    var i = 0;
    while (i < MLDSA65_K) {
        mldsa_poly_add(w + i * 2048, u + i * 2048, v + i * 2048);
        i = i + 1;
    }
    return 0;
}

fn mldsa_polyveck_sub(w, u, v): i64 {
    var i = 0;
    while (i < MLDSA65_K) {
        mldsa_poly_sub(w + i * 2048, u + i * 2048, v + i * 2048);
        i = i + 1;
    }
    return 0;
}

fn mldsa_polyveck_reduce(v): i64 {
    var i = 0;
    while (i < MLDSA65_K) {
        mldsa_poly_reduce(v + i * 2048);
        i = i + 1;
    }
    return 0;
}

fn mldsa_polyveck_caddq(v): i64 {
    var i = 0;
    while (i < MLDSA65_K) {
        mldsa_poly_caddq(v + i * 2048);
        i = i + 1;
    }
    return 0;
}

fn mldsa_polyveck_shiftl(v): i64 {
    var i = 0;
    while (i < MLDSA65_K) {
        mldsa_poly_shiftl(v + i * 2048);
        i = i + 1;
    }
    return 0;
}

fn mldsa_polyveck_ntt(v): i64 {
    var i = 0;
    while (i < MLDSA65_K) {
        mldsa_ntt(v + i * 2048);
        i = i + 1;
    }
    return 0;
}

fn mldsa_polyveck_invntt_tomont(v): i64 {
    var i = 0;
    while (i < MLDSA65_K) {
        mldsa_invntt_tomont(v + i * 2048);
        i = i + 1;
    }
    return 0;
}

fn mldsa_polyveck_pointwise_poly_montgomery(r, a, v): i64 {
    var i = 0;
    while (i < MLDSA65_K) {
        mldsa_poly_pointwise_montgomery(r + i * 2048, a, v + i * 2048);
        i = i + 1;
    }
    return 0;
}

fn mldsa_polyveck_chknorm(v, bound): i64 {
    var i = 0;
    while (i < MLDSA65_K) {
        if (mldsa_poly_chknorm(v + i * 2048, bound) == 1) { return 1; }
        i = i + 1;
    }
    return 0;
}

# ================================================================
# Accumulated pointwise product: w = Σ u[i] · v[i]
# ================================================================
# Scratch buffer + loop state promoted to globals (see header
# comment). One-time alloc; reused across every acc call.

var _mldsa_pac_scratch = 0;
var _mldsa_pac_inited = 0;
var _mldsa_pac_w = 0;
var _mldsa_pac_u = 0;
var _mldsa_pac_v = 0;
var _mldsa_pac_i = 0;

fn _mldsa_pac_init(): i64 {
    if (_mldsa_pac_inited == 1) { return 0; }
    _mldsa_pac_scratch = alloc(2048);
    _mldsa_pac_inited = 1;
    return 0;
}

# w = u[0]·v[0] + u[1]·v[1] + ... + u[L-1]·v[L-1] in NTT domain.
# Each inner pointwise is a montgomery_reduce, so the sum is
# already scaled by R^{-1}.
fn mldsa_polyvecl_pointwise_acc_montgomery(w, u, v): i64 {
    _mldsa_pac_init();
    _mldsa_pac_w = w;
    _mldsa_pac_u = u;
    _mldsa_pac_v = v;
    # w = u[0] · v[0].
    mldsa_poly_pointwise_montgomery(_mldsa_pac_w, _mldsa_pac_u, _mldsa_pac_v);
    _mldsa_pac_i = 1;
    while (_mldsa_pac_i < MLDSA65_L) {
        mldsa_poly_pointwise_montgomery(
        _mldsa_pac_scratch,
        _mldsa_pac_u + _mldsa_pac_i * 2048,
        _mldsa_pac_v + _mldsa_pac_i * 2048
        );
        mldsa_poly_add(_mldsa_pac_w, _mldsa_pac_w, _mldsa_pac_scratch);
        _mldsa_pac_i = _mldsa_pac_i + 1;
    }
    return 0;
}

# ================================================================
# Matrix-vector product: t = A · v  (A is K rows × L cols)
# ================================================================
# Used during A·s1, A·y, and A·z computations in keygen / sign /
# verify. Row i of A is an L-element polyvecl at offset
# i · L · 2048 bytes from the matrix base. Each row is reduced
# against v via polyvecl_pointwise_acc_montgomery.

var _mldsa_mat_t = 0;
var _mldsa_mat_A = 0;
var _mldsa_mat_v = 0;
var _mldsa_mat_i = 0;

fn mldsa_polyvec_matrix_pointwise_montgomery(t, A, v): i64 {
    _mldsa_mat_t = t;
    _mldsa_mat_A = A;
    _mldsa_mat_v = v;
    _mldsa_mat_i = 0;
    while (_mldsa_mat_i < MLDSA65_K) {
        mldsa_polyvecl_pointwise_acc_montgomery(
        _mldsa_mat_t + _mldsa_mat_i * 2048,
        _mldsa_mat_A + _mldsa_mat_i * MLDSA65_L * 2048,
        _mldsa_mat_v
        );
        _mldsa_mat_i = _mldsa_mat_i + 1;
    }
    return 0;
}

# --- mldsa_rounding.cyr ---

# mldsa_rounding.cyr — Power2Round, Decompose, HighBits, LowBits,
# MakeHint, UseHint (FIPS 204 §8)
#
# These four primitives plus the Decompose helper make up the
# "rounding layer" that bridges the NTT world (full coefficients
# mod Q) and the signature-encoding world (a1 = high bits, a0 =
# low bits, h = hint bits).
#
# Reference: pq-crystals/dilithium `ref/rounding.c`. We keep the
# same call shapes; the only Cyrius-specific adaptation is the
# multi-return idiom — C uses an out-pointer for a0, we expose
# globals the caller can read after a call. That matches the
# sha256 / ed25519 pattern already in sigil and avoids the
# address-of-local dance for scalars.
#
# All functions operate on i64 values holding the signed-i32
# range of Z_Q coefficients. Assume inputs are standard
# representatives in [0, Q) unless noted.

# ================================================================
# Power2Round (D = 13 dropped bits)
# ================================================================
# Input:  a ∈ [0, Q)
# Output: (a1, a0) with  a = a1 · 2^D + a0  (mod Q),
#         a0 ∈ (−2^{D−1}, 2^{D−1}]
#
# Used in keygen to split t = t1·2^D + t0. t1 is published as
# part of pk (lossy, 10 bits/coeff); t0 stays private in sk
# (13 bits/coeff, balanced).

var _mldsa_p2r_a1 = 0;      # output high part
var _mldsa_p2r_a0 = 0;      # output low part (balanced)

fn mldsa_power2round(a): i64 {
    # Standard trick: add 2^{D-1}-1 before the right-shift so
    # the shift rounds to nearest instead of toward zero. Input
    # is non-negative so the logical >> matches arithmetic >>.
    var a1 = (a + (1 << (MLDSA_D - 1)) - 1) >> MLDSA_D;
    _mldsa_p2r_a1 = a1;
    _mldsa_p2r_a0 = a - (a1 << MLDSA_D);
    return a1;
}

# ================================================================
# Decompose — ML-DSA-65 branch only (GAMMA2 = (Q−1)/32)
# ================================================================
# Input:  a ∈ [0, Q)
# Output: (a1, a0) with  a = a1 · α + a0  (mod Q),  α = 2·γ2,
#         a0 ∈ (−α/2, α/2]  normally, except when a1 rolls over
#         the highest digit (a1 = (Q−1)/α = 16) we set a1 = 0
#         and a0 = a − Q ∈ [−α/2, 0).
#
# The C reference does this via Barrett-style nearest-multiple
# quotient + a sign-bit Q correction. Cyrius equivalent:
#   - the two right-shifts (>>7 and >>22) operate on non-negative
#     intermediates, so logical shift is correct.
#   - the final Q correction is `a0 -= (((Q−1)/2 − a0) >> 31) & Q`;
#     we read the i64 sign bit via `(diff >> 63) & 1` and
#     multiply by Q to pick up the branchless conditional subtract.

var _mldsa_dec_a1 = 0;      # high bits (w1 in the spec)
var _mldsa_dec_a0 = 0;      # low bits (balanced, w0)

fn mldsa_decompose(a): i64 {
    var a1 = (a + 127) >> 7;
    a1 = (a1 * 1025 + (1 << 21)) >> 22;
    a1 = a1 & 15;
    var a0 = a - a1 * 2 * MLDSA65_GAMMA2;
    # Conditional subtract Q: if a0 > (Q−1)/2, bring it into the
    # balanced negative range.
    var diff = (MLDSA_Q - 1) / 2 - a0;
    var sign = (diff >> 63) & 1;        # 1 iff diff < 0 iff a0 > (Q−1)/2
    a0 = a0 - sign * MLDSA_Q;
    _mldsa_dec_a1 = a1;
    _mldsa_dec_a0 = a0;
    return a1;
}

# Convenience accessors — HighBits / LowBits in FIPS 204 notation.
fn mldsa_high_bits(a): i64 {
    mldsa_decompose(a);
    return _mldsa_dec_a1;
}

fn mldsa_low_bits(a): i64 {
    mldsa_decompose(a);
    return _mldsa_dec_a0;
}

# ================================================================
# MakeHint — predict whether adding z flips the HighBits of r
# ================================================================
# Input:  a0 = LowBits(r+z), a1 = HighBits(r)  (per the spec)
# Output: 1 if HighBits(r+z) ≠ HighBits(r), else 0
#
# Branches are fine here — the return value IS what eventually
# ships as part of the public signature, so any control-flow
# signal is already encoded in the output. No timing surface
# beyond what the caller already publishes.

fn mldsa_make_hint(a0, a1): i64 {
    if (a0 > MLDSA65_GAMMA2) { return 1; }
    if (a0 < 0 - MLDSA65_GAMMA2) { return 1; }
    if (a0 == 0 - MLDSA65_GAMMA2) {
        if (a1 != 0) { return 1; }
    }
    return 0;
}

# ================================================================
# UseHint — recover HighBits(r + small) from (r, hint)
# ================================================================
# Input:  a (a coefficient), hint ∈ {0, 1}
# Output: corrected high-bits value
#
# Rule (GAMMA2 = (Q−1)/32 branch): call Decompose(a). If hint=0,
# return a1 verbatim. Otherwise shift a1 by ±1 modulo 16 based
# on the sign of a0. Wrap-around uses the same `& 15` mask as
# the decompose step so a1 stays in [0, 15].

fn mldsa_use_hint(a, hint): i64 {
    mldsa_decompose(a);
    var a1 = _mldsa_dec_a1;
    var a0 = _mldsa_dec_a0;
    if (hint == 0) { return a1; }
    if (a0 > 0) { return (a1 + 1) & 15; }
    return (a1 - 1) & 15;
}

# ================================================================
# Per-poly wrappers (iterate the per-coefficient primitive)
# ================================================================

# a1[i], a0[i] = power2round(a[i])
fn mldsa_poly_power2round(a1, a0, a): i64 {
    var i = 0;
    while (i < 256) {
        mldsa_power2round(load64(a + i * 8));
        store64(a1 + i * 8, _mldsa_p2r_a1);
        store64(a0 + i * 8, _mldsa_p2r_a0);
        i = i + 1;
    }
    return 0;
}

# a1[i], a0[i] = decompose(a[i])
fn mldsa_poly_decompose(a1, a0, a): i64 {
    var i = 0;
    while (i < 256) {
        mldsa_decompose(load64(a + i * 8));
        store64(a1 + i * 8, _mldsa_dec_a1);
        store64(a0 + i * 8, _mldsa_dec_a0);
        i = i + 1;
    }
    return 0;
}

# h[i] = make_hint(a0[i], a1[i]); returns total hint weight s.
fn mldsa_poly_make_hint(h, a0, a1): i64 {
    var s = 0;
    var i = 0;
    while (i < 256) {
        var bit = mldsa_make_hint(load64(a0 + i * 8), load64(a1 + i * 8));
        store64(h + i * 8, bit);
        s = s + bit;
        i = i + 1;
    }
    return s;
}

# r[i] = use_hint(a[i], h[i])
fn mldsa_poly_use_hint(r, a, h): i64 {
    var i = 0;
    while (i < 256) {
        store64(r + i * 8, mldsa_use_hint(load64(a + i * 8), load64(h + i * 8)));
        i = i + 1;
    }
    return 0;
}

# ================================================================
# Polyveck wrappers (K = 6 lanes)
# ================================================================

fn mldsa_polyveck_power2round(v1, v0, v): i64 {
    var i = 0;
    while (i < MLDSA65_K) {
        mldsa_poly_power2round(v1 + i * 2048, v0 + i * 2048, v + i * 2048);
        i = i + 1;
    }
    return 0;
}

fn mldsa_polyveck_decompose(v1, v0, v): i64 {
    var i = 0;
    while (i < MLDSA65_K) {
        mldsa_poly_decompose(v1 + i * 2048, v0 + i * 2048, v + i * 2048);
        i = i + 1;
    }
    return 0;
}

# h[i][j] = make_hint(v0[i][j], v1[i][j]); returns total weight.
fn mldsa_polyveck_make_hint(h, v0, v1): i64 {
    var s = 0;
    var i = 0;
    while (i < MLDSA65_K) {
        s = s + mldsa_poly_make_hint(h + i * 2048, v0 + i * 2048, v1 + i * 2048);
        i = i + 1;
    }
    return s;
}

fn mldsa_polyveck_use_hint(w, u, h): i64 {
    var i = 0;
    while (i < MLDSA65_K) {
        mldsa_poly_use_hint(w + i * 2048, u + i * 2048, h + i * 2048);
        i = i + 1;
    }
    return 0;
}

# --- mldsa_encode.cyr ---

# mldsa_encode.cyr — byte packing for ML-DSA keys and signatures
#
# Every byte that leaves sigil's ML-DSA surface goes through this
# module — public keys, secret keys, and signatures. Reference:
# pq-crystals/dilithium ref/poly.c (per-poly packers) +
# ref/packing.c (pk/sk/sig assembly).
#
# Bit layouts (ML-DSA-65 branches only, GAMMA1 = 2^19, GAMMA2 =
# (Q−1)/32, ETA = 4):
#
#   polyt1 : 10 bits/coeff unsigned — 4 coeffs → 5 bytes → 320 B
#   polyt0 : 13 bits/coeff balanced (2^{D-1}−c) — 8 coeffs → 13 bytes → 416 B
#   polyeta: 4 bits/coeff (η−c) — 2 coeffs → 1 byte → 128 B
#   polyz  : 20 bits/coeff (γ1−c) — 2 coeffs → 5 bytes → 640 B
#   polyw1 : 4 bits/coeff standard rep — 2 coeffs → 1 byte → 128 B
#
# All packers assume coefficients have already been reduced to
# the documented range (caller's responsibility). No modular
# reduction happens inside the packers.
#
# Cyrius note: bytes come from `load8` / go through `store8` with
# explicit `& 0xFF` masks — Cyrius's load8/store8 sign-extend to
# i64 on read and truncate on write, but intermediate arithmetic
# on i64 needs explicit masking to stay within the byte lane.

# ================================================================
# polyt1_pack / polyt1_unpack (10 bits/coeff, 320 bytes per poly)
# ================================================================

fn _mldsa_polyt1_pack(r, a): i64 {
    var i = 0;
    while (i < 256 / 4) {
        var c0 = load64(a + (4 * i + 0) * 8);
        var c1 = load64(a + (4 * i + 1) * 8);
        var c2 = load64(a + (4 * i + 2) * 8);
        var c3 = load64(a + (4 * i + 3) * 8);
        store8(r + 5 * i + 0, c0 & 0xFF);
        store8(r + 5 * i + 1, ((c0 >> 8) | (c1 << 2)) & 0xFF);
        store8(r + 5 * i + 2, ((c1 >> 6) | (c2 << 4)) & 0xFF);
        store8(r + 5 * i + 3, ((c2 >> 4) | (c3 << 6)) & 0xFF);
        store8(r + 5 * i + 4, (c3 >> 2) & 0xFF);
        i = i + 1;
    }
    return 0;
}

fn _mldsa_polyt1_unpack(r, a): i64 {
    var i = 0;
    while (i < 256 / 4) {
        var b0 = load8(a + 5 * i + 0) & 0xFF;
        var b1 = load8(a + 5 * i + 1) & 0xFF;
        var b2 = load8(a + 5 * i + 2) & 0xFF;
        var b3 = load8(a + 5 * i + 3) & 0xFF;
        var b4 = load8(a + 5 * i + 4) & 0xFF;
        store64(r + (4 * i + 0) * 8, ((b0 >> 0) | (b1 << 8)) & 0x3FF);
        store64(r + (4 * i + 1) * 8, ((b1 >> 2) | (b2 << 6)) & 0x3FF);
        store64(r + (4 * i + 2) * 8, ((b2 >> 4) | (b3 << 4)) & 0x3FF);
        store64(r + (4 * i + 3) * 8, ((b3 >> 6) | (b4 << 2)) & 0x3FF);
        i = i + 1;
    }
    return 0;
}

# ================================================================
# polyt0_pack / polyt0_unpack (13 bits/coeff balanced, 416 bytes)
# ================================================================
# Coefficients land in (−2^{D−1}, 2^{D−1}]. Packed as
# 2^{D−1} − c so the stored value is non-negative.

fn _mldsa_polyt0_pack(r, a): i64 {
    var bias = 1 << (MLDSA_D - 1);
    var i = 0;
    while (i < 256 / 8) {
        var t0 = bias - load64(a + (8 * i + 0) * 8);
        var t1 = bias - load64(a + (8 * i + 1) * 8);
        var t2 = bias - load64(a + (8 * i + 2) * 8);
        var t3 = bias - load64(a + (8 * i + 3) * 8);
        var t4 = bias - load64(a + (8 * i + 4) * 8);
        var t5 = bias - load64(a + (8 * i + 5) * 8);
        var t6 = bias - load64(a + (8 * i + 6) * 8);
        var t7 = bias - load64(a + (8 * i + 7) * 8);
        store8(r + 13 * i + 0,  t0 & 0xFF);
        store8(r + 13 * i + 1,  ((t0 >> 8) | (t1 << 5)) & 0xFF);
        store8(r + 13 * i + 2,  (t1 >> 3) & 0xFF);
        store8(r + 13 * i + 3,  ((t1 >> 11) | (t2 << 2)) & 0xFF);
        store8(r + 13 * i + 4,  ((t2 >> 6) | (t3 << 7)) & 0xFF);
        store8(r + 13 * i + 5,  (t3 >> 1) & 0xFF);
        store8(r + 13 * i + 6,  ((t3 >> 9) | (t4 << 4)) & 0xFF);
        store8(r + 13 * i + 7,  (t4 >> 4) & 0xFF);
        store8(r + 13 * i + 8,  ((t4 >> 12) | (t5 << 1)) & 0xFF);
        store8(r + 13 * i + 9,  ((t5 >> 7) | (t6 << 6)) & 0xFF);
        store8(r + 13 * i + 10, (t6 >> 2) & 0xFF);
        store8(r + 13 * i + 11, ((t6 >> 10) | (t7 << 3)) & 0xFF);
        store8(r + 13 * i + 12, (t7 >> 5) & 0xFF);
        i = i + 1;
    }
    return 0;
}

fn _mldsa_polyt0_unpack(r, a): i64 {
    var bias = 1 << (MLDSA_D - 1);
    var i = 0;
    while (i < 256 / 8) {
        var b0 = load8(a + 13 * i + 0) & 0xFF;
        var b1 = load8(a + 13 * i + 1) & 0xFF;
        var b2 = load8(a + 13 * i + 2) & 0xFF;
        var b3 = load8(a + 13 * i + 3) & 0xFF;
        var b4 = load8(a + 13 * i + 4) & 0xFF;
        var b5 = load8(a + 13 * i + 5) & 0xFF;
        var b6 = load8(a + 13 * i + 6) & 0xFF;
        var b7 = load8(a + 13 * i + 7) & 0xFF;
        var b8 = load8(a + 13 * i + 8) & 0xFF;
        var b9 = load8(a + 13 * i + 9) & 0xFF;
        var b10 = load8(a + 13 * i + 10) & 0xFF;
        var b11 = load8(a + 13 * i + 11) & 0xFF;
        var b12 = load8(a + 13 * i + 12) & 0xFF;
        var c0 = (b0 | (b1 << 8)) & 0x1FFF;
        var c1 = ((b1 >> 5) | (b2 << 3) | (b3 << 11)) & 0x1FFF;
        var c2 = ((b3 >> 2) | (b4 << 6)) & 0x1FFF;
        var c3 = ((b4 >> 7) | (b5 << 1) | (b6 << 9)) & 0x1FFF;
        var c4 = ((b6 >> 4) | (b7 << 4) | (b8 << 12)) & 0x1FFF;
        var c5 = ((b8 >> 1) | (b9 << 7)) & 0x1FFF;
        var c6 = ((b9 >> 6) | (b10 << 2) | (b11 << 10)) & 0x1FFF;
        var c7 = ((b11 >> 3) | (b12 << 5)) & 0x1FFF;
        store64(r + (8 * i + 0) * 8, bias - c0);
        store64(r + (8 * i + 1) * 8, bias - c1);
        store64(r + (8 * i + 2) * 8, bias - c2);
        store64(r + (8 * i + 3) * 8, bias - c3);
        store64(r + (8 * i + 4) * 8, bias - c4);
        store64(r + (8 * i + 5) * 8, bias - c5);
        store64(r + (8 * i + 6) * 8, bias - c6);
        store64(r + (8 * i + 7) * 8, bias - c7);
        i = i + 1;
    }
    return 0;
}

# ================================================================
# polyeta_pack / polyeta_unpack (η = 4, 4 bits/coeff, 128 bytes)
# ================================================================
# Store η − c as a 4-bit value; two coefficients per byte.

fn _mldsa_polyeta_pack(r, a): i64 {
    var i = 0;
    while (i < 256 / 2) {
        var t0 = MLDSA65_ETA - load64(a + (2 * i + 0) * 8);
        var t1 = MLDSA65_ETA - load64(a + (2 * i + 1) * 8);
        store8(r + i, (t0 | (t1 << 4)) & 0xFF);
        i = i + 1;
    }
    return 0;
}

fn _mldsa_polyeta_unpack(r, a): i64 {
    var i = 0;
    while (i < 256 / 2) {
        var b = load8(a + i) & 0xFF;
        store64(r + (2 * i + 0) * 8, MLDSA65_ETA - (b & 0x0F));
        store64(r + (2 * i + 1) * 8, MLDSA65_ETA - (b >> 4));
        i = i + 1;
    }
    return 0;
}

# ================================================================
# polyz_pack / polyz_unpack (γ1 = 2^19, 20 bits/coeff, 640 bytes)
# ================================================================

fn _mldsa_polyz_pack(r, a): i64 {
    var i = 0;
    while (i < 256 / 2) {
        var t0 = MLDSA65_GAMMA1 - load64(a + (2 * i + 0) * 8);
        var t1 = MLDSA65_GAMMA1 - load64(a + (2 * i + 1) * 8);
        store8(r + 5 * i + 0, t0 & 0xFF);
        store8(r + 5 * i + 1, (t0 >> 8) & 0xFF);
        store8(r + 5 * i + 2, ((t0 >> 16) | (t1 << 4)) & 0xFF);
        store8(r + 5 * i + 3, (t1 >> 4) & 0xFF);
        store8(r + 5 * i + 4, (t1 >> 12) & 0xFF);
        i = i + 1;
    }
    return 0;
}

fn _mldsa_polyz_unpack(r, a): i64 {
    var i = 0;
    while (i < 256 / 2) {
        var b0 = load8(a + 5 * i + 0) & 0xFF;
        var b1 = load8(a + 5 * i + 1) & 0xFF;
        var b2 = load8(a + 5 * i + 2) & 0xFF;
        var b3 = load8(a + 5 * i + 3) & 0xFF;
        var b4 = load8(a + 5 * i + 4) & 0xFF;
        var c0 = (b0 | (b1 << 8) | (b2 << 16)) & 0xFFFFF;
        var c1 = ((b2 >> 4) | (b3 << 4) | (b4 << 12)) & 0xFFFFF;
        store64(r + (2 * i + 0) * 8, MLDSA65_GAMMA1 - c0);
        store64(r + (2 * i + 1) * 8, MLDSA65_GAMMA1 - c1);
        i = i + 1;
    }
    return 0;
}

# ================================================================
# polyw1_pack (γ2 = (Q−1)/32 branch, 4 bits/coeff, 128 bytes)
# ================================================================
# No unpack — w1 only packs for the challenge-hash step. Input
# coefficients are standard representatives in [0, 15].

fn _mldsa_polyw1_pack(r, a): i64 {
    var i = 0;
    while (i < 256 / 2) {
        var c0 = load64(a + (2 * i + 0) * 8);
        var c1 = load64(a + (2 * i + 1) * 8);
        store8(r + i, (c0 | (c1 << 4)) & 0xFF);
        i = i + 1;
    }
    return 0;
}

fn mldsa_polyveck_pack_w1(r, v): i64 {
    var i = 0;
    while (i < MLDSA65_K) {
        _mldsa_polyw1_pack(r + i * MLDSA65_POLYW1_PACKEDBYTES, v + i * 2048);
        i = i + 1;
    }
    return 0;
}

# ================================================================
# pk / sk / sig assembly
# ================================================================

# pk = ρ (32 B) || t1 (K · 320 = 1920 B)
fn mldsa_pack_pk(pk, rho, t1): i64 {
    memcpy(pk, rho, MLDSA_SEEDBYTES);
    var i = 0;
    while (i < MLDSA65_K) {
        _mldsa_polyt1_pack(
        pk + MLDSA_SEEDBYTES + i * MLDSA65_POLYT1_PACKEDBYTES,
        t1 + i * 2048
        );
        i = i + 1;
    }
    return 0;
}

fn mldsa_unpack_pk(rho, t1, pk): i64 {
    memcpy(rho, pk, MLDSA_SEEDBYTES);
    var i = 0;
    while (i < MLDSA65_K) {
        _mldsa_polyt1_unpack(
        t1 + i * 2048,
        pk + MLDSA_SEEDBYTES + i * MLDSA65_POLYT1_PACKEDBYTES
        );
        i = i + 1;
    }
    return 0;
}

# sk = ρ (32) || K (32) || tr (64) || s1 (L·128) || s2 (K·128) || t0 (K·416)
fn mldsa_pack_sk(sk, rho, key, tr, t0, s1, s2): i64 {
    var off = 0;
    memcpy(sk + off, rho, MLDSA_SEEDBYTES);
    off = off + MLDSA_SEEDBYTES;
    memcpy(sk + off, key, MLDSA_SEEDBYTES);
    off = off + MLDSA_SEEDBYTES;
    memcpy(sk + off, tr, MLDSA_TRBYTES);
    off = off + MLDSA_TRBYTES;
    var i = 0;
    while (i < MLDSA65_L) {
        _mldsa_polyeta_pack(sk + off + i * MLDSA65_POLYETA_PACKEDBYTES, s1 + i * 2048);
        i = i + 1;
    }
    off = off + MLDSA65_L * MLDSA65_POLYETA_PACKEDBYTES;
    i = 0;
    while (i < MLDSA65_K) {
        _mldsa_polyeta_pack(sk + off + i * MLDSA65_POLYETA_PACKEDBYTES, s2 + i * 2048);
        i = i + 1;
    }
    off = off + MLDSA65_K * MLDSA65_POLYETA_PACKEDBYTES;
    i = 0;
    while (i < MLDSA65_K) {
        _mldsa_polyt0_pack(sk + off + i * MLDSA65_POLYT0_PACKEDBYTES, t0 + i * 2048);
        i = i + 1;
    }
    return 0;
}

fn mldsa_unpack_sk(rho, key, tr, t0, s1, s2, sk): i64 {
    var off = 0;
    memcpy(rho, sk + off, MLDSA_SEEDBYTES);
    off = off + MLDSA_SEEDBYTES;
    memcpy(key, sk + off, MLDSA_SEEDBYTES);
    off = off + MLDSA_SEEDBYTES;
    memcpy(tr, sk + off, MLDSA_TRBYTES);
    off = off + MLDSA_TRBYTES;
    var i = 0;
    while (i < MLDSA65_L) {
        _mldsa_polyeta_unpack(s1 + i * 2048, sk + off + i * MLDSA65_POLYETA_PACKEDBYTES);
        i = i + 1;
    }
    off = off + MLDSA65_L * MLDSA65_POLYETA_PACKEDBYTES;
    i = 0;
    while (i < MLDSA65_K) {
        _mldsa_polyeta_unpack(s2 + i * 2048, sk + off + i * MLDSA65_POLYETA_PACKEDBYTES);
        i = i + 1;
    }
    off = off + MLDSA65_K * MLDSA65_POLYETA_PACKEDBYTES;
    i = 0;
    while (i < MLDSA65_K) {
        _mldsa_polyt0_unpack(t0 + i * 2048, sk + off + i * MLDSA65_POLYT0_PACKEDBYTES);
        i = i + 1;
    }
    return 0;
}

# sig = c̃ (CTILDEBYTES) || z (L·POLYZ_PACKEDBYTES) || h (OMEGA+K bytes)
# Hint encoding: bytes [0, OMEGA) hold concatenated non-zero
# coefficient indices across the K hint polys; bytes [OMEGA, OMEGA+K)
# hold the cumulative count of non-zero coefficients after each
# poly i. Strong unforgeability requires strictly-increasing
# indices within each poly and zero-bytes in unused tail slots.
fn mldsa_pack_sig(sig, c, z, h): i64 {
    var off = 0;
    memcpy(sig + off, c, MLDSA65_CTILDEBYTES);
    off = off + MLDSA65_CTILDEBYTES;
    var i = 0;
    while (i < MLDSA65_L) {
        _mldsa_polyz_pack(sig + off + i * MLDSA65_POLYZ_PACKEDBYTES, z + i * 2048);
        i = i + 1;
    }
    off = off + MLDSA65_L * MLDSA65_POLYZ_PACKEDBYTES;
    # Zero the hint region (OMEGA index slots + K count slots).
    memset(sig + off, 0, MLDSA65_OMEGA + MLDSA65_K);
    var k = 0;
    i = 0;
    while (i < MLDSA65_K) {
        var j = 0;
        while (j < 256) {
            if (load64(h + i * 2048 + j * 8) != 0) {
                store8(sig + off + k, j & 0xFF);
                k = k + 1;
            }
            j = j + 1;
        }
        store8(sig + off + MLDSA65_OMEGA + i, k & 0xFF);
        i = i + 1;
    }
    return 0;
}

# Returns 0 on success, 1 on malformed signature. Zeros `h` on
# the way in so unused coefficient positions are explicitly zero.
fn mldsa_unpack_sig(c, z, h, sig): i64 {
    var off = 0;
    memcpy(c, sig + off, MLDSA65_CTILDEBYTES);
    off = off + MLDSA65_CTILDEBYTES;
    var i = 0;
    while (i < MLDSA65_L) {
        _mldsa_polyz_unpack(z + i * 2048, sig + off + i * MLDSA65_POLYZ_PACKEDBYTES);
        i = i + 1;
    }
    off = off + MLDSA65_L * MLDSA65_POLYZ_PACKEDBYTES;
    var k = 0;
    i = 0;
    while (i < MLDSA65_K) {
        # Zero the output hint poly.
        var zj = 0;
        while (zj < 256) {
            store64(h + i * 2048 + zj * 8, 0);
            zj = zj + 1;
        }
        var ki = load8(sig + off + MLDSA65_OMEGA + i) & 0xFF;
        if (ki < k) { return 1; }
        if (ki > MLDSA65_OMEGA) { return 1; }
        var j = k;
        while (j < ki) {
            # Strictly-increasing indices for strong unforgeability.
            if (j > k) {
                var idx_prev = load8(sig + off + j - 1) & 0xFF;
                var idx_curr = load8(sig + off + j) & 0xFF;
                if (idx_curr <= idx_prev) { return 1; }
            }
            var coeff_idx = load8(sig + off + j) & 0xFF;
            store64(h + i * 2048 + coeff_idx * 8, 1);
            j = j + 1;
        }
        k = ki;
        i = i + 1;
    }
    # Tail of the index region must be all zero.
    var j2 = k;
    while (j2 < MLDSA65_OMEGA) {
        if ((load8(sig + off + j2) & 0xFF) != 0) { return 1; }
        j2 = j2 + 1;
    }
    return 0;
}

# --- mldsa_sample.cyr ---

# mldsa_sample.cyr — rejection sampling + challenge expansion
#
# FIPS 204 §7: every pseudo-random poly that shows up during
# keygen / sign / verify is built here. The drivers all sit on
# top of `lib/keccak.cyr` (SHAKE-128 / SHAKE-256, landed in
# Cyrius 5.4.15). Reference: pq-crystals/dilithium ref/poly.c
# (the rej_uniform / rej_eta / poly_uniform_* / poly_challenge
# group) and ref/polyvec.c (polyvec_matrix_expand + polyvec*
# uniform wrappers).
#
# Streaming pattern: the stdlib exposes one-shot `shake128(...)`
# /`shake256(...)` wrappers plus the lower-level `_keccak_absorb`
# and `_keccak_f1600` primitives. We call those two primitives
# directly so the absorb step runs once per seed/nonce and each
# rejection-sampling block squeezes the minimum bytes it needs.
#
# Scratch: a single module-level 200-byte Keccak state buffer
# plus two squeeze buffers (one per rate) are allocated at first
# use. These are *public* across calls — the sampling driver
# resets them per operation, so any hypothetical leak would
# already be public (seed + nonce + produced output).

# ================================================================
# Module state
# ================================================================
# SHAKE-128 rate: 168 bytes. SHAKE-256 rate: 136 bytes.
# Initial-squeeze sizes (matching pq-crystals `POLY_UNIFORM_*_NBLOCKS`):
#   uniform   (A): 5 blocks × 168 = 840 bytes  (covers 256-coeff w.h.p.)
#   uniform_eta:   2 blocks × 136 = 272 bytes  (η=4 needs 227)
#   uniform_gamma1:5 blocks × 136 = 680 bytes  (exactly POLYZ_PACKEDBYTES)

var _mldsa_sample_inited = 0;
var _mldsa_sample_state = 0;        # 200 bytes, Keccak state
var _mldsa_sample_absorb = 0;       # 80 bytes, seed (<=64) + nonce (2) scratch
var _mldsa_sample_buf128 = 0;       # 5 × 168 + 2 bytes (uniform)
var _mldsa_sample_buf256 = 0;       # 5 × 136 bytes (eta + gamma1 + challenge)

fn _mldsa_sample_init(): i64 {
    if (_mldsa_sample_inited == 1) { return 0; }
    _mldsa_sample_state = alloc(200);
    _mldsa_sample_absorb = alloc(80);
    _mldsa_sample_buf128 = alloc(5 * 168 + 2);
    _mldsa_sample_buf256 = alloc(5 * 136);
    _mldsa_sample_inited = 1;
    return 0;
}

# ================================================================
# SHAKE streaming wrappers (one absorb + repeated squeeze)
# ================================================================
# Absorb = pq-crystals dilithium_shake128_stream_init: absorb seed
# then a little-endian 2-byte nonce, finalize. The shared state
# buffer is zeroed first so back-to-back sampling calls don't
# carry over residue.

fn _mldsa_shake128_stream_init(seed, seedlen, nonce): i64 {
    memset(_mldsa_sample_state, 0, 200);
    memcpy(_mldsa_sample_absorb, seed, seedlen);
    store8(_mldsa_sample_absorb + seedlen, nonce & 0xFF);
    store8(_mldsa_sample_absorb + seedlen + 1, (nonce >> 8) & 0xFF);
    _keccak_absorb(_mldsa_sample_state, _mldsa_sample_absorb, seedlen + 2, 168, 0x1F);
    return 0;
}

fn _mldsa_shake256_stream_init(seed, seedlen, nonce): i64 {
    memset(_mldsa_sample_state, 0, 200);
    memcpy(_mldsa_sample_absorb, seed, seedlen);
    store8(_mldsa_sample_absorb + seedlen, nonce & 0xFF);
    store8(_mldsa_sample_absorb + seedlen + 1, (nonce >> 8) & 0xFF);
    _keccak_absorb(_mldsa_sample_state, _mldsa_sample_absorb, seedlen + 2, 136, 0x1F);
    return 0;
}

# Squeeze `nblocks` × `rate` bytes into `out`, permuting the state
# between blocks. After the last squeeze, state is left ready for
# one more block (i.e. the f1600 call is eager).
fn _mldsa_shake_squeeze_blocks(out, nblocks, rate): i64 {
    var b = 0;
    while (b < nblocks) {
        var i = 0;
        while (i < rate) {
            store8(out + b * rate + i, load8(_mldsa_sample_state + i));
            i = i + 1;
        }
        _keccak_f1600(_mldsa_sample_state);
        b = b + 1;
    }
    return 0;
}

# ================================================================
# rej_uniform — sample coeffs in [0, Q) from random bytes
# ================================================================
# Returns number of coefficients successfully sampled (≤ len). May
# return early if buflen is exhausted. Each attempt consumes 3
# bytes; acceptance probability Q / 2^23 ≈ 0.999 so 5 blocks of
# SHAKE-128 (= 840 B) are almost always enough for 256 coeffs.

fn mldsa_rej_uniform(a, len, buf, buflen): i64 {
    var ctr = 0;
    var pos = 0;
    while (ctr < len) {
        if (pos + 3 > buflen) { return ctr; }
        var t = load8(buf + pos) & 0xFF;
        t = t | ((load8(buf + pos + 1) & 0xFF) << 8);
        t = t | ((load8(buf + pos + 2) & 0xFF) << 16);
        t = t & 0x7FFFFF;
        pos = pos + 3;
        if (t < MLDSA_Q) {
            store64(a + ctr * 8, t);
            ctr = ctr + 1;
        }
    }
    return ctr;
}

# ================================================================
# rej_eta — sample coeffs in [-ETA, ETA] for ETA = 4
# ================================================================
# Each byte yields two nibbles; each nibble in [0, 8] accepts to
# `4 - nibble`, nibbles in [9, 15] reject. Acceptance per nibble
# is 9/16. η=4 path only; η=2 rejection tables are not ML-DSA-65.

fn mldsa_rej_eta(a, len, buf, buflen): i64 {
    var ctr = 0;
    var pos = 0;
    while (ctr < len) {
        if (pos >= buflen) { return ctr; }
        var byte = load8(buf + pos) & 0xFF;
        var t0 = byte & 0x0F;
        var t1 = byte >> 4;
        pos = pos + 1;
        if (t0 < 9) {
            store64(a + ctr * 8, MLDSA65_ETA - t0);
            ctr = ctr + 1;
        }
        if (ctr < len) {
            if (t1 < 9) {
                store64(a + ctr * 8, MLDSA65_ETA - t1);
                ctr = ctr + 1;
            }
        }
    }
    return ctr;
}

# polyz_unpack lives in mldsa_encode.cyr (shared with pk/sk/sig
# packing). That module is included before this one in lib.cyr
# so `_mldsa_polyz_unpack` is in scope here.

# ================================================================
# poly_uniform — ExpandA single-poly driver (uses SHAKE-128)
# ================================================================
# Fills `a` with 256 uniformly random coefficients in [0, Q) via
# rejection sampling of a SHAKE-128(ρ ‖ nonce) stream.
# Callers for ExpandA set nonce = (row << 8) | col; nonce is an
# i64 here but only the low 16 bits matter.

# State globals: the sampling chain calls through multiple
# helpers, each with their own locals. Promote the loop state
# to module-level to survive cc5 clobbering.
var _mldsa_pu_ctr = 0;
var _mldsa_pu_off = 0;
var _mldsa_pu_buflen = 0;
var _mldsa_pu_a = 0;

fn mldsa_poly_uniform(a, seed, nonce): i64 {
    _mldsa_sample_init();
    _mldsa_pu_a = a;
    _mldsa_shake128_stream_init(seed, MLDSA_SEEDBYTES, nonce);
    # Initial 5-block squeeze — enough for 256 coeffs ~99% of the time.
    _mldsa_shake_squeeze_blocks(_mldsa_sample_buf128, 5, 168);
    _mldsa_pu_buflen = 5 * 168;
    _mldsa_pu_ctr = mldsa_rej_uniform(_mldsa_pu_a, 256, _mldsa_sample_buf128, _mldsa_pu_buflen);
    # Fallback loop: carry over partial bytes, squeeze one more block.
    while (_mldsa_pu_ctr < 256) {
        _mldsa_pu_off = _mldsa_pu_buflen % 3;
        var i = 0;
        while (i < _mldsa_pu_off) {
            store8(
            _mldsa_sample_buf128 + i,
            load8(_mldsa_sample_buf128 + _mldsa_pu_buflen - _mldsa_pu_off + i)
            );
            i = i + 1;
        }
        # Squeeze one block at offset `off`.
        _mldsa_shake_squeeze_blocks(_mldsa_sample_buf128 + _mldsa_pu_off, 1, 168);
        _mldsa_pu_buflen = 168 + _mldsa_pu_off;
        _mldsa_pu_ctr = _mldsa_pu_ctr + mldsa_rej_uniform(
        _mldsa_pu_a + _mldsa_pu_ctr * 8,
        256 - _mldsa_pu_ctr,
        _mldsa_sample_buf128,
        _mldsa_pu_buflen
        );
    }
    return 0;
}

# ================================================================
# poly_uniform_eta — ExpandS single-poly driver (uses SHAKE-256)
# ================================================================
# Fills `a` with 256 coefficients in [-η, η] via rejection on a
# SHAKE-256(ρ' ‖ nonce) stream.

var _mldsa_pe_ctr = 0;
var _mldsa_pe_a = 0;

fn mldsa_poly_uniform_eta(a, seed, nonce): i64 {
    _mldsa_sample_init();
    _mldsa_pe_a = a;
    _mldsa_shake256_stream_init(seed, MLDSA_CRHBYTES, nonce);
    # η=4 needs ≈ 256·(16/9) ≈ 455 bytes → 4 blocks = 544 bytes
    # (pq-crystals picks 2 blocks then loops; we do the same with
    # a 2-block initial + 1-block fallback to stay within
    # buf256's 5-block capacity).
    _mldsa_shake_squeeze_blocks(_mldsa_sample_buf256, 2, 136);
    _mldsa_pe_ctr = mldsa_rej_eta(_mldsa_pe_a, 256, _mldsa_sample_buf256, 2 * 136);
    while (_mldsa_pe_ctr < 256) {
        _mldsa_shake_squeeze_blocks(_mldsa_sample_buf256, 1, 136);
        _mldsa_pe_ctr = _mldsa_pe_ctr + mldsa_rej_eta(
        _mldsa_pe_a + _mldsa_pe_ctr * 8,
        256 - _mldsa_pe_ctr,
        _mldsa_sample_buf256,
        136
        );
    }
    return 0;
}

# ================================================================
# poly_uniform_gamma1 — ExpandMask single-poly driver
# ================================================================
# Packs SHAKE-256(ρ' ‖ κ) into POLYZ_PACKEDBYTES = 640 bytes of
# output, then unpacks 20 bits per coefficient to produce y
# with coefficients in [1 − γ1, γ1]. No rejection; the unpack
# is exact.

fn mldsa_poly_uniform_gamma1(a, seed, nonce): i64 {
    _mldsa_sample_init();
    _mldsa_shake256_stream_init(seed, MLDSA_CRHBYTES, nonce);
    _mldsa_shake_squeeze_blocks(_mldsa_sample_buf256, 5, 136);
    _mldsa_polyz_unpack(a, _mldsa_sample_buf256);
    return 0;
}

# ================================================================
# poly_challenge — SampleInBall (τ non-zero ±1 coefficients)
# ================================================================
# c̃ (CTILDEBYTES bytes) is absorbed; first 8 output bytes become
# the 64-bit `signs` register (one bit per ±1 choice). Remaining
# bytes drive the Fisher-Yates-like swap that places TAU non-zero
# coefficients in the last TAU positions, shuffled earlier.

var _mldsa_ch_c = 0;
var _mldsa_ch_pos = 0;
var _mldsa_ch_signs = 0;
var _mldsa_ch_i = 0;

fn mldsa_poly_challenge(c, seed): i64 {
    _mldsa_sample_init();
    _mldsa_ch_c = c;
    # Absorb c̃ via the stream wrapper with nonce=0 would append two
    # extra bytes; FIPS 204 SampleInBall has no nonce. Call the
    # lower-level absorb directly with only `seed` as input.
    memset(_mldsa_sample_state, 0, 200);
    _keccak_absorb(_mldsa_sample_state, seed, MLDSA65_CTILDEBYTES, 136, 0x1F);
    _mldsa_shake_squeeze_blocks(_mldsa_sample_buf256, 1, 136);

    # Collect 64 sign bits from the first 8 bytes.
    _mldsa_ch_signs = 0;
    var si = 0;
    while (si < 8) {
        _mldsa_ch_signs = _mldsa_ch_signs | ((load8(_mldsa_sample_buf256 + si) & 0xFF) << (si * 8));
        si = si + 1;
    }
    _mldsa_ch_pos = 8;

    # Zero the output poly.
    var z = 0;
    while (z < 256) {
        store64(_mldsa_ch_c + z * 8, 0);
        z = z + 1;
    }

    # Place ±1 at TAU positions via the swap walk.
    _mldsa_ch_i = 256 - MLDSA65_TAU;
    while (_mldsa_ch_i < 256) {
        # Sample a uniform byte b ∈ [0, i] via rejection.
        var b = 0;
        var accepted = 0;
        while (accepted == 0) {
            if (_mldsa_ch_pos >= 136) {
                _mldsa_shake_squeeze_blocks(_mldsa_sample_buf256, 1, 136);
                _mldsa_ch_pos = 0;
            }
            b = load8(_mldsa_sample_buf256 + _mldsa_ch_pos) & 0xFF;
            _mldsa_ch_pos = _mldsa_ch_pos + 1;
            if (b <= _mldsa_ch_i) { accepted = 1; }
        }
        # c[i] = c[b]; c[b] = 1 - 2·(signs & 1); signs >>= 1
        store64(_mldsa_ch_c + _mldsa_ch_i * 8, load64(_mldsa_ch_c + b * 8));
        var sign_val = 1 - 2 * (_mldsa_ch_signs & 1);
        store64(_mldsa_ch_c + b * 8, sign_val);
        _mldsa_ch_signs = _mldsa_ch_signs >> 1;
        _mldsa_ch_i = _mldsa_ch_i + 1;
    }
    return 0;
}

# ================================================================
# Polyvec / matrix wrappers
# ================================================================

# ExpandA: matrix mat[i][j] = SHAKE-128(ρ ‖ (i<<8)|j) sampled into
# [0, Q). Total K·L = 30 polys.
fn mldsa_polyvec_matrix_expand(mat, rho): i64 {
    var i = 0;
    while (i < MLDSA65_K) {
        var j = 0;
        while (j < MLDSA65_L) {
            var nonce = (i << 8) | j;
            # Row i of A is at offset i * L * 2048; poly (i,j) at +j*2048.
            mldsa_poly_uniform(
            mat + (i * MLDSA65_L + j) * 2048,
            rho,
            nonce
            );
            j = j + 1;
        }
        i = i + 1;
    }
    return 0;
}

# ExpandS → s1 (L polys, nonces 0..L-1)
fn mldsa_polyvecl_uniform_eta(v, seed, nonce_base): i64 {
    var i = 0;
    while (i < MLDSA65_L) {
        mldsa_poly_uniform_eta(v + i * 2048, seed, nonce_base + i);
        i = i + 1;
    }
    return 0;
}

# ExpandS → s2 (K polys, nonces L..L+K-1)
fn mldsa_polyveck_uniform_eta(v, seed, nonce_base): i64 {
    var i = 0;
    while (i < MLDSA65_K) {
        mldsa_poly_uniform_eta(v + i * 2048, seed, nonce_base + i);
        i = i + 1;
    }
    return 0;
}

# ExpandMask: sign-time mask y (L polys), nonces L·κ + ℓ.
fn mldsa_polyvecl_uniform_gamma1(v, seed, nonce_base): i64 {
    var i = 0;
    while (i < MLDSA65_L) {
        mldsa_poly_uniform_gamma1(v + i * 2048, seed, nonce_base + i);
        i = i + 1;
    }
    return 0;
}

# --- mldsa.cyr ---

# mldsa.cyr — ML-DSA-65 keygen / sign / verify (FIPS 204)
#
# The capstone that ties together params, reduce, ntt, poly,
# rounding, sample, and encode into the three public operations
# sigil ships: keypair generation, signature production, and
# signature verification. Reference: pq-crystals/dilithium
# `ref/sign.c`, crypto_sign_keypair / crypto_sign_signature_internal
# / crypto_sign_verify_internal. No randomized-sign mode — sigil
# pins rnd = 0^32 (the FIPS 204 deterministic profile); the
# context prefix is fixed to the empty `(0, 0)` prefix.
#
# Memory: every polyvec / matrix buffer is allocated once at first
# use into module-level globals. Total workspace is ~200 KB; the
# trust boundary is not on the memory-footprint hot path. Globals
# are reused across calls, so callers must complete one operation
# before starting the next (single-threaded). No operation leaves
# secret material in the workspace longer than its own lifetime —
# subsequent calls overwrite the relevant regions.

# ================================================================
# Workspace
# ================================================================

var _mldsa_ws_inited = 0;
var _mldsa_ws_mat = 0;          # K * L * 2048
var _mldsa_ws_s1 = 0;           # L * 2048
var _mldsa_ws_s1hat = 0;        # L * 2048
var _mldsa_ws_s2 = 0;           # K * 2048
var _mldsa_ws_t0 = 0;           # K * 2048
var _mldsa_ws_t1 = 0;           # K * 2048
var _mldsa_ws_y = 0;            # L * 2048
var _mldsa_ws_z = 0;            # L * 2048
var _mldsa_ws_w0 = 0;           # K * 2048
var _mldsa_ws_w1 = 0;           # K * 2048
var _mldsa_ws_h = 0;            # K * 2048
var _mldsa_ws_cp = 0;           # 1 poly
var _mldsa_ws_seedbuf = 0;      # 256 bytes (covers 2·SEED + TR + 2·CRH)
var _mldsa_ws_w1_bytes = 0;     # K · POLYW1_PACKEDBYTES = 768 bytes
var _mldsa_ws_rho = 0;          # 32 bytes
var _mldsa_ws_tr = 0;           # 64 bytes
var _mldsa_ws_mu = 0;           # 64 bytes
var _mldsa_ws_rhoprime = 0;     # 64 bytes
var _mldsa_ws_key = 0;          # 32 bytes
var _mldsa_ws_ctilde = 0;       # CTILDEBYTES = 48
var _mldsa_ws_ctilde2 = 0;      # CTILDEBYTES (verify's recomputed c̃)

# Standalone SHAKE-256 state for the multi-absorb hashes (mu,
# rhoprime, challenge seed). Distinct from the sampling module's
# state so rejection-sampling and hash-absorb don't race.
var _mldsa_sv_state = 0;        # 200 bytes
var _mldsa_sv_pos = 0;

fn _mldsa_ws_init(): i64 {
    if (_mldsa_ws_inited == 1) { return 0; }
    _mldsa_ws_mat = alloc(MLDSA65_K * MLDSA65_L * 256 * 8);
    _mldsa_ws_s1 = alloc(MLDSA65_L * 256 * 8);
    _mldsa_ws_s1hat = alloc(MLDSA65_L * 256 * 8);
    _mldsa_ws_s2 = alloc(MLDSA65_K * 256 * 8);
    _mldsa_ws_t0 = alloc(MLDSA65_K * 256 * 8);
    _mldsa_ws_t1 = alloc(MLDSA65_K * 256 * 8);
    _mldsa_ws_y = alloc(MLDSA65_L * 256 * 8);
    _mldsa_ws_z = alloc(MLDSA65_L * 256 * 8);
    _mldsa_ws_w0 = alloc(MLDSA65_K * 256 * 8);
    _mldsa_ws_w1 = alloc(MLDSA65_K * 256 * 8);
    _mldsa_ws_h = alloc(MLDSA65_K * 256 * 8);
    _mldsa_ws_cp = alloc(256 * 8);
    _mldsa_ws_seedbuf = alloc(256);
    _mldsa_ws_w1_bytes = alloc(MLDSA65_K * MLDSA65_POLYW1_PACKEDBYTES);
    _mldsa_ws_rho = alloc(MLDSA_SEEDBYTES);
    _mldsa_ws_tr = alloc(MLDSA_TRBYTES);
    _mldsa_ws_mu = alloc(MLDSA_CRHBYTES);
    _mldsa_ws_rhoprime = alloc(MLDSA_CRHBYTES);
    _mldsa_ws_key = alloc(MLDSA_SEEDBYTES);
    _mldsa_ws_ctilde = alloc(MLDSA65_CTILDEBYTES);
    _mldsa_ws_ctilde2 = alloc(MLDSA65_CTILDEBYTES);
    _mldsa_sv_state = alloc(200);
    _mldsa_ws_inited = 1;
    return 0;
}

# ================================================================
# Incremental SHAKE-256 (used for mu, rhoprime, and challenge seed)
# ================================================================
# The Cyrius stdlib `shake256` is a one-shot hash-then-squeeze. The
# ML-DSA keygen / sign / verify flows do multi-absorb: `mu =
# SHAKE256(tr ‖ pre ‖ msg)` takes three chunks, `rhoprime` takes
# three, the challenge seed takes two. We keep these tight by
# exposing an init/absorb/finalize/squeeze chain on the
# stdlib-internal `_keccak_f1600` primitive.

fn _mldsa_sv_init(): i64 {
    memset(_mldsa_sv_state, 0, 200);
    _mldsa_sv_pos = 0;
    return 0;
}

fn _mldsa_sv_absorb(data, datalen): i64 {
    var i = 0;
    while (i < datalen) {
        store8(
        _mldsa_sv_state + _mldsa_sv_pos,
        load8(_mldsa_sv_state + _mldsa_sv_pos) ^ load8(data + i)
        );
        _mldsa_sv_pos = _mldsa_sv_pos + 1;
        i = i + 1;
        if (_mldsa_sv_pos == 136) {
            _keccak_f1600(_mldsa_sv_state);
            _mldsa_sv_pos = 0;
        }
    }
    return 0;
}

fn _mldsa_sv_finalize(): i64 {
    store8(
    _mldsa_sv_state + _mldsa_sv_pos,
    load8(_mldsa_sv_state + _mldsa_sv_pos) ^ 0x1F
    );
    store8(_mldsa_sv_state + 135, load8(_mldsa_sv_state + 135) ^ 0x80);
    _keccak_f1600(_mldsa_sv_state);
    _mldsa_sv_pos = 0;
    return 0;
}

fn _mldsa_sv_squeeze(out, outlen): i64 {
    var out_pos = 0;
    while (out_pos < outlen) {
        if (_mldsa_sv_pos == 136) {
            _keccak_f1600(_mldsa_sv_state);
            _mldsa_sv_pos = 0;
        }
        var remain = 136 - _mldsa_sv_pos;
        var take = outlen - out_pos;
        if (take > remain) { take = remain; }
        var j = 0;
        while (j < take) {
            store8(out + out_pos + j, load8(_mldsa_sv_state + _mldsa_sv_pos + j));
            j = j + 1;
        }
        _mldsa_sv_pos = _mldsa_sv_pos + take;
        out_pos = out_pos + take;
    }
    return 0;
}

# ================================================================
# Keypair generation — deterministic from a 32-byte seed
# ================================================================
# seed: caller-provided 32 bytes (use mldsa65_keypair for the
# /dev/urandom-driven convenience wrapper below). Output: pk
# (1952 B), sk (4032 B) buffers pre-allocated by caller.
#
# Steps (FIPS 204 Algorithm 1):
#   1. Expand seed into (rho, rhoprime, key) via SHAKE-256 over
#      seed ‖ K ‖ L (34 bytes in, 128 bytes out).
#   2. Sample matrix A from rho via ExpandA.
#   3. Sample s1 (L polys) + s2 (K polys) from rhoprime via
#      ExpandS (nonces 0..L-1 for s1, L..L+K-1 for s2).
#   4. Compute t = NTT^{-1}(A · NTT(s1)) + s2.
#   5. Split t = t1·2^D + t0 via Power2Round.
#   6. tr = SHAKE-256(pk, 64 bytes).
#   7. Pack pk = rho ‖ t1, sk = rho ‖ key ‖ tr ‖ s1 ‖ s2 ‖ t0.

fn mldsa65_keypair_from_seed(seed, pk, sk): i64 {
    _mldsa_ws_init();

    # Expand seed into (rho, rhoprime, key). Input = seed ‖ K ‖ L.
    memcpy(_mldsa_ws_seedbuf, seed, MLDSA_SEEDBYTES);
    store8(_mldsa_ws_seedbuf + MLDSA_SEEDBYTES + 0, MLDSA65_K);
    store8(_mldsa_ws_seedbuf + MLDSA_SEEDBYTES + 1, MLDSA65_L);
    # Output: 2·SEEDBYTES + CRHBYTES = 128 bytes, in-place back
    # into seedbuf. Layout: rho (32) ‖ rhoprime (64) ‖ key (32).
    shake256(_mldsa_ws_seedbuf, MLDSA_SEEDBYTES + 2, _mldsa_ws_seedbuf, 2 * MLDSA_SEEDBYTES + MLDSA_CRHBYTES);
    memcpy(_mldsa_ws_rho, _mldsa_ws_seedbuf, MLDSA_SEEDBYTES);
    memcpy(_mldsa_ws_rhoprime, _mldsa_ws_seedbuf + MLDSA_SEEDBYTES, MLDSA_CRHBYTES);
    memcpy(_mldsa_ws_key, _mldsa_ws_seedbuf + MLDSA_SEEDBYTES + MLDSA_CRHBYTES, MLDSA_SEEDBYTES);

    # ExpandA, ExpandS.
    mldsa_polyvec_matrix_expand(_mldsa_ws_mat, _mldsa_ws_rho);
    mldsa_polyvecl_uniform_eta(_mldsa_ws_s1, _mldsa_ws_rhoprime, 0);
    mldsa_polyveck_uniform_eta(_mldsa_ws_s2, _mldsa_ws_rhoprime, MLDSA65_L);

    # t1 = NTT^{-1}(A · NTT(s1)) + s2. We stage NTT(s1) in s1hat
    # so the original s1 (needed for sk packing) is preserved.
    var i = 0;
    while (i < MLDSA65_L * 256) {
        store64(_mldsa_ws_s1hat + i * 8, load64(_mldsa_ws_s1 + i * 8));
        i = i + 1;
    }
    mldsa_polyvecl_ntt(_mldsa_ws_s1hat);
    mldsa_polyvec_matrix_pointwise_montgomery(_mldsa_ws_t1, _mldsa_ws_mat, _mldsa_ws_s1hat);
    mldsa_polyveck_reduce(_mldsa_ws_t1);
    mldsa_polyveck_invntt_tomont(_mldsa_ws_t1);
    mldsa_polyveck_add(_mldsa_ws_t1, _mldsa_ws_t1, _mldsa_ws_s2);

    # Split t1 into (t1_high, t0) via Power2Round.
    mldsa_polyveck_caddq(_mldsa_ws_t1);
    mldsa_polyveck_power2round(_mldsa_ws_t1, _mldsa_ws_t0, _mldsa_ws_t1);

    # Assemble pk, then tr = SHAKE-256(pk, 64).
    mldsa_pack_pk(pk, _mldsa_ws_rho, _mldsa_ws_t1);
    shake256(pk, MLDSA65_PK_BYTES, _mldsa_ws_tr, MLDSA_TRBYTES);

    # Assemble sk.
    mldsa_pack_sk(sk, _mldsa_ws_rho, _mldsa_ws_key, _mldsa_ws_tr,
    _mldsa_ws_t0, _mldsa_ws_s1, _mldsa_ws_s2);
    return 0;
}

# Convenience: generate keypair from /dev/urandom. Returns 1 on
# success, 0 if entropy gather fails (partial reads, EOF, etc.)
# — matches ed25519_keypair_from_random's ABI.
fn mldsa65_keypair(pk, sk): i64 {
    secret var seed[32];
    memset(&seed, 0, MLDSA_SEEDBYTES);
    var fd = file_open("/dev/urandom", 0, 0);
    if (fd < 0) { return 0; }
    var got = 0;
    while (got < MLDSA_SEEDBYTES) {
        var n = file_read(fd, (&seed) + got, MLDSA_SEEDBYTES - got);
        if (n <= 0) {
            file_close(fd);
            return 0;
        }
        got = got + n;
    }
    file_close(fd);
    mldsa65_keypair_from_seed(&seed, pk, sk);
    return 1;
}

# ================================================================
# Sign — deterministic (rnd = 0, no context prefix)
# ================================================================
# Produces a 3309-byte signature over `msg` using `sk`.
# The rejection loop iterates until every norm and hint-weight
# check passes; average 4–5 iterations per signature.
#
# Steps:
#   1. unpack_sk.
#   2. mu = SHAKE256(tr ‖ pre ‖ msg), where pre = (0, 0).
#   3. rhoprime = SHAKE256(key ‖ rnd ‖ mu) with rnd = 0^32.
#   4. Expand A; NTT(s1), NTT(s2), NTT(t0).
#   5. Loop: sample y, compute w = A·y; w1 = HighBits(w);
#      c̃ = SHAKE256(mu ‖ pack_w1(w1)); c = SampleInBall(c̃).
#      z = y + c·s1; chknorm(z, γ1 − β); compute w0 − c·s2,
#      chknorm, compute c·t0, chknorm; make hints,
#      chknorm(h, ω); if all checks pass, pack_sig.

# Loop state promoted to globals. Nested calls descend multiple
# layers into montgomery_reduce / SHAKE; locals get clobbered.
var _mldsa_sign_nonce = 0;
var _mldsa_sign_sig = 0;
var _mldsa_sign_sk = 0;

fn mldsa65_sign(sig, msg, msglen, sk): i64 {
    _mldsa_ws_init();
    _mldsa_sign_sig = sig;
    _mldsa_sign_sk = sk;

    # 1. Unpack sk.
    mldsa_unpack_sk(_mldsa_ws_rho, _mldsa_ws_key, _mldsa_ws_tr,
    _mldsa_ws_t0, _mldsa_ws_s1, _mldsa_ws_s2, _mldsa_sign_sk);

    # 2. mu = SHAKE256(tr ‖ 0x00 0x00 ‖ msg).
    _mldsa_sv_init();
    _mldsa_sv_absorb(_mldsa_ws_tr, MLDSA_TRBYTES);
    # pre = (0x00, 0x00) — empty context prefix.
    store8(_mldsa_ws_seedbuf + 0, 0);
    store8(_mldsa_ws_seedbuf + 1, 0);
    _mldsa_sv_absorb(_mldsa_ws_seedbuf, 2);
    _mldsa_sv_absorb(msg, msglen);
    _mldsa_sv_finalize();
    _mldsa_sv_squeeze(_mldsa_ws_mu, MLDSA_CRHBYTES);

    # 3. rhoprime = SHAKE256(key ‖ rnd=0^32 ‖ mu).
    _mldsa_sv_init();
    _mldsa_sv_absorb(_mldsa_ws_key, MLDSA_SEEDBYTES);
    # rnd bytes pinned to zero (deterministic profile).
    memset(_mldsa_ws_seedbuf, 0, MLDSA_RNDBYTES);
    _mldsa_sv_absorb(_mldsa_ws_seedbuf, MLDSA_RNDBYTES);
    _mldsa_sv_absorb(_mldsa_ws_mu, MLDSA_CRHBYTES);
    _mldsa_sv_finalize();
    _mldsa_sv_squeeze(_mldsa_ws_rhoprime, MLDSA_CRHBYTES);

    # 4. Expand matrix and NTT-transform secret vectors.
    mldsa_polyvec_matrix_expand(_mldsa_ws_mat, _mldsa_ws_rho);
    mldsa_polyvecl_ntt(_mldsa_ws_s1);
    mldsa_polyveck_ntt(_mldsa_ws_s2);
    mldsa_polyveck_ntt(_mldsa_ws_t0);

    # 5. Rejection loop.
    _mldsa_sign_nonce = 0;
    var done = 0;
    while (done == 0) {
        # Sample y.
        mldsa_polyvecl_uniform_gamma1(_mldsa_ws_y, _mldsa_ws_rhoprime, _mldsa_sign_nonce);
        _mldsa_sign_nonce = _mldsa_sign_nonce + 1;

        # w = A · NTT(y); z buffer used as staging for NTT(y).
        var i = 0;
        while (i < MLDSA65_L * 256) {
            store64(_mldsa_ws_z + i * 8, load64(_mldsa_ws_y + i * 8));
            i = i + 1;
        }
        mldsa_polyvecl_ntt(_mldsa_ws_z);
        mldsa_polyvec_matrix_pointwise_montgomery(_mldsa_ws_w1, _mldsa_ws_mat, _mldsa_ws_z);
        mldsa_polyveck_reduce(_mldsa_ws_w1);
        mldsa_polyveck_invntt_tomont(_mldsa_ws_w1);

        # Decompose w into (w1, w0).
        mldsa_polyveck_caddq(_mldsa_ws_w1);
        mldsa_polyveck_decompose(_mldsa_ws_w1, _mldsa_ws_w0, _mldsa_ws_w1);
        mldsa_polyveck_pack_w1(_mldsa_ws_w1_bytes, _mldsa_ws_w1);

        # c̃ = SHAKE256(mu ‖ w1_bytes), then c = SampleInBall(c̃).
        _mldsa_sv_init();
        _mldsa_sv_absorb(_mldsa_ws_mu, MLDSA_CRHBYTES);
        _mldsa_sv_absorb(_mldsa_ws_w1_bytes, MLDSA65_K * MLDSA65_POLYW1_PACKEDBYTES);
        _mldsa_sv_finalize();
        _mldsa_sv_squeeze(_mldsa_ws_ctilde, MLDSA65_CTILDEBYTES);
        mldsa_poly_challenge(_mldsa_ws_cp, _mldsa_ws_ctilde);
        mldsa_ntt(_mldsa_ws_cp);

        # z = c · s1 (in NTT domain, then inverse) + y.
        mldsa_polyvecl_pointwise_poly_montgomery(_mldsa_ws_z, _mldsa_ws_cp, _mldsa_ws_s1);
        mldsa_polyvecl_invntt_tomont(_mldsa_ws_z);
        mldsa_polyvecl_add(_mldsa_ws_z, _mldsa_ws_z, _mldsa_ws_y);
        mldsa_polyvecl_reduce(_mldsa_ws_z);
        if (mldsa_polyvecl_chknorm(_mldsa_ws_z, MLDSA65_GAMMA1 - MLDSA65_BETA) == 1) {
            # Rejected: z norm too large. Loop.
        } else {
            # h = c · s2, then w0 = w0 − h; reject if |w0| ≥ γ2 − β.
            mldsa_polyveck_pointwise_poly_montgomery(_mldsa_ws_h, _mldsa_ws_cp, _mldsa_ws_s2);
            mldsa_polyveck_invntt_tomont(_mldsa_ws_h);
            mldsa_polyveck_sub(_mldsa_ws_w0, _mldsa_ws_w0, _mldsa_ws_h);
            mldsa_polyveck_reduce(_mldsa_ws_w0);
            if (mldsa_polyveck_chknorm(_mldsa_ws_w0, MLDSA65_GAMMA2 - MLDSA65_BETA) == 1) {
                # Rejected. Loop.
            } else {
                # h = c · t0; reject if |h| ≥ γ2.
                mldsa_polyveck_pointwise_poly_montgomery(_mldsa_ws_h, _mldsa_ws_cp, _mldsa_ws_t0);
                mldsa_polyveck_invntt_tomont(_mldsa_ws_h);
                mldsa_polyveck_reduce(_mldsa_ws_h);
                if (mldsa_polyveck_chknorm(_mldsa_ws_h, MLDSA65_GAMMA2) == 1) {
                    # Rejected. Loop.
                } else {
                    # Compute hint = make_hint(w0 + c·t0, w1); reject
                    # if weight > ω.
                    mldsa_polyveck_add(_mldsa_ws_w0, _mldsa_ws_w0, _mldsa_ws_h);
                    var weight = mldsa_polyveck_make_hint(_mldsa_ws_h, _mldsa_ws_w0, _mldsa_ws_w1);
                    if (weight > MLDSA65_OMEGA) {
                        # Rejected. Loop.
                    } else {
                        done = 1;
                    }
                }
            }
        }
    }

    # Pack signature: c̃ ‖ z ‖ h.
    mldsa_pack_sig(_mldsa_sign_sig, _mldsa_ws_ctilde, _mldsa_ws_z, _mldsa_ws_h);
    return 0;
}

# ================================================================
# Verify — returns 0 on valid signature, 1 otherwise
# ================================================================
# The sign/verify break points line up with pq-crystals'
# `crypto_sign_verify_internal` (int returning 0/−1 from the C
# ref; we flip to 0/1 to match sigil's other boolean returns).

fn mldsa65_verify(sig, msg, msglen, pk): i64 {
    _mldsa_ws_init();

    # Unpack pk and sig. A malformed sig fails early.
    mldsa_unpack_pk(_mldsa_ws_rho, _mldsa_ws_t1, pk);
    if (mldsa_unpack_sig(_mldsa_ws_ctilde, _mldsa_ws_z, _mldsa_ws_h, sig) == 1) { return 1; }
    # z-norm check: must be strictly < γ1 − β.
    if (mldsa_polyvecl_chknorm(_mldsa_ws_z, MLDSA65_GAMMA1 - MLDSA65_BETA) == 1) { return 1; }

    # Compute mu = SHAKE256( SHAKE256(pk, 64) ‖ pre ‖ msg ).
    shake256(pk, MLDSA65_PK_BYTES, _mldsa_ws_mu, MLDSA_TRBYTES);
    _mldsa_sv_init();
    _mldsa_sv_absorb(_mldsa_ws_mu, MLDSA_TRBYTES);
    store8(_mldsa_ws_seedbuf + 0, 0);
    store8(_mldsa_ws_seedbuf + 1, 0);
    _mldsa_sv_absorb(_mldsa_ws_seedbuf, 2);
    _mldsa_sv_absorb(msg, msglen);
    _mldsa_sv_finalize();
    _mldsa_sv_squeeze(_mldsa_ws_mu, MLDSA_CRHBYTES);

    # c_ntt = NTT(SampleInBall(c̃)).
    mldsa_poly_challenge(_mldsa_ws_cp, _mldsa_ws_ctilde);

    # A · z (in NTT domain).
    mldsa_polyvec_matrix_expand(_mldsa_ws_mat, _mldsa_ws_rho);
    mldsa_polyvecl_ntt(_mldsa_ws_z);
    mldsa_polyvec_matrix_pointwise_montgomery(_mldsa_ws_w1, _mldsa_ws_mat, _mldsa_ws_z);

    # c · 2^D · t1: shift t1 left by D, NTT, then pointwise with c_ntt.
    mldsa_ntt(_mldsa_ws_cp);
    mldsa_polyveck_shiftl(_mldsa_ws_t1);
    mldsa_polyveck_ntt(_mldsa_ws_t1);
    mldsa_polyveck_pointwise_poly_montgomery(_mldsa_ws_t1, _mldsa_ws_cp, _mldsa_ws_t1);

    # w = (A·z) − c·2^D·t1, inverse-NTT.
    mldsa_polyveck_sub(_mldsa_ws_w1, _mldsa_ws_w1, _mldsa_ws_t1);
    mldsa_polyveck_reduce(_mldsa_ws_w1);
    mldsa_polyveck_invntt_tomont(_mldsa_ws_w1);

    # Reconstruct w1 using the hint.
    mldsa_polyveck_caddq(_mldsa_ws_w1);
    mldsa_polyveck_use_hint(_mldsa_ws_w1, _mldsa_ws_w1, _mldsa_ws_h);
    mldsa_polyveck_pack_w1(_mldsa_ws_w1_bytes, _mldsa_ws_w1);

    # Recompute challenge seed c̃' and compare.
    _mldsa_sv_init();
    _mldsa_sv_absorb(_mldsa_ws_mu, MLDSA_CRHBYTES);
    _mldsa_sv_absorb(_mldsa_ws_w1_bytes, MLDSA65_K * MLDSA65_POLYW1_PACKEDBYTES);
    _mldsa_sv_finalize();
    _mldsa_sv_squeeze(_mldsa_ws_ctilde2, MLDSA65_CTILDEBYTES);

    # Constant-time equality: if any byte differs, reject.
    var diff = 0;
    var i = 0;
    while (i < MLDSA65_CTILDEBYTES) {
        diff = diff | ((load8(_mldsa_ws_ctilde + i) & 0xFF) ^ (load8(_mldsa_ws_ctilde2 + i) & 0xFF));
        i = i + 1;
    }
    if (diff != 0) { return 1; }
    return 0;
}

# ================================================================
# Hybrid Ed25519 + ML-DSA-65 verification primitive
# ================================================================
# Gate a message against one, the other, or both algorithms
# according to `required_alg`:
#
#   SIG_ALG_ED25519    — verify ed25519 only; `mldsa_*` may be 0.
#   SIG_ALG_ML_DSA_65  — verify ml-dsa only; `ed_*` may be 0.
#   SIG_ALG_HYBRID     — both must pass (AND).
#
# Ed25519 convention: sig is 64 bytes, pk is 32 bytes.
# ML-DSA-65 convention: sig is MLDSA65_SIG_BYTES, pk is
# MLDSA65_PK_BYTES.
#
# Returns 1 if the requirement is satisfied (all required
# algorithms verify), 0 otherwise. This is the raw crypto gate —
# higher-level verifier logic (trust store, revocation, key pins)
# lives in src/verify.cyr and calls this entry point once it has
# established that the artifact is present and the signer keys
# are known.
fn sigil_verify_hybrid(msg, msg_len, ed_sig, ed_pk, mldsa_sig, mldsa_pk, required_alg): i64 {
    if (required_alg == SIG_ALG_ED25519) {
        return ed25519_verify(ed_pk, msg, msg_len, ed_sig);
    }
    if (required_alg == SIG_ALG_ML_DSA_65) {
        if (mldsa65_verify(mldsa_sig, msg, msg_len, mldsa_pk) == 0) { return 1; }
        return 0;
    }
    if (required_alg == SIG_ALG_HYBRID) {
        if (ed25519_verify(ed_pk, msg, msg_len, ed_sig) != 1) { return 0; }
        if (mldsa65_verify(mldsa_sig, msg, msg_len, mldsa_pk) != 0) { return 0; }
        return 1;
    }
    # Unknown algorithm: fail closed.
    return 0;
}

# --- trust.cyr ---

# trust.cyr — signing, verification, key management
# Ed25519 (RFC 8032) for asymmetric signing, HMAC-SHA256 for symmetric.

# ================================================================
# KeyRole
# ================================================================

enum KeyRole {
    KEY_ROLE_ROOT = 0;
    KEY_ROLE_INTERMEDIATE = 1;
    KEY_ROLE_PUBLISHER = 2;
}

fn key_role_name(role): i64 {
    if (role == KEY_ROLE_ROOT) { return "Root"; }
    if (role == KEY_ROLE_INTERMEDIATE) { return "Intermediate"; }
    if (role == KEY_ROLE_PUBLISHER) { return "Publisher"; }
    return "unknown";
}

# ================================================================
# KeyVersion (96 bytes)
# ================================================================
# Layout:
#   +0   key_id          (C-string ptr)
#   +8   valid_from      (epoch seconds)
#   +16  valid_until     (epoch seconds, 0 = no expiry)
#   +24  public_key_hex  (C-string ptr, 64-char hex)
#   +32  role            (i64 KEY_ROLE_*)
#   +40  issued_by       (C-string ptr, 0 = self-signed)
#   +48  issuer_sig      (ptr to raw bytes, 0 = none)
#   +56  issuer_sig_len  (i64)
#   +64  pub_name        (C-string ptr, 0 = none)
#   +72  pub_contact     (C-string ptr, 0 = none)
#   +80  secret_key      (ptr to 32 raw bytes, 0 = none, for HMAC signing)
#   +88  allowed_types   (vec of ARTIFACT_* i64s, 0 = all types allowed)

fn key_version_new(key_id, public_key_hex): i64 {
    var kv = fl_alloc(96);
    store64(kv, key_id);
    store64(kv + 8, clock_epoch_secs());
    store64(kv + 16, 0);
    store64(kv + 24, public_key_hex);
    store64(kv + 32, KEY_ROLE_PUBLISHER);
    store64(kv + 40, 0);
    store64(kv + 48, 0);
    store64(kv + 56, 0);
    store64(kv + 64, 0);
    store64(kv + 72, 0);
    store64(kv + 80, 0);
    store64(kv + 88, 0);
    return kv;
}

fn kv_key_id(kv): i64 { return load64(kv); }
fn kv_valid_from(kv): i64 { return load64(kv + 8); }
fn kv_valid_until(kv): i64 { return load64(kv + 16); }
fn kv_public_key_hex(kv): i64 { return load64(kv + 24); }
fn kv_role(kv): i64 { return load64(kv + 32); }
fn kv_issued_by(kv): i64 { return load64(kv + 40); }
fn kv_pub_name(kv): i64 { return load64(kv + 64); }
fn kv_pub_contact(kv): i64 { return load64(kv + 72); }
fn kv_secret_key(kv): i64 { return load64(kv + 80); }

fn kv_set_valid_from(kv, v): i64 { store64(kv + 8, v); return kv; }
fn kv_set_valid_until(kv, v): i64 { store64(kv + 16, v); return kv; }
fn kv_set_role(kv, r): i64 { store64(kv + 32, r); return kv; }
fn kv_set_issued_by(kv, v): i64 { store64(kv + 40, v); return kv; }
fn kv_set_pub_name(kv, v): i64 { store64(kv + 64, v); return kv; }
fn kv_set_pub_contact(kv, v): i64 { store64(kv + 72, v); return kv; }
fn kv_set_secret_key(kv, sk): i64 { store64(kv + 80, sk); return kv; }

# Allowed-artifact-type restriction. An unset (0) list means "this key
# is authorized for every ArtifactType" — the Rust `KeyMetadata`
# default. A non-empty list restricts the key to signing only those
# artifact types; any other type fails verification with a dedicated
# "allowed_type" check, independent of the signature itself.
fn kv_allowed_types(kv): i64 { return load64(kv + 88); }

fn kv_add_allowed_type(kv, artifact_type): i64 {
    var v = load64(kv + 88);
    if (v == 0) { v = vec_new(); store64(kv + 88, v); }
    vec_push(v, artifact_type);
    return kv;
}

fn kv_clear_allowed_types(kv): i64 { store64(kv + 88, 0); return kv; }

# Is this key authorized to sign artifacts of `artifact_type`?
# Unrestricted key (no allowed_types list or empty list) → 1.
fn kv_is_type_allowed(kv, artifact_type): i64 {
    var v = load64(kv + 88);
    if (v == 0) { return 1; }
    var n = vec_len(v);
    if (n == 0) { return 1; }
    var i = 0;
    while (i < n) {
        if (vec_get(v, i) == artifact_type) { return 1; }
        i = i + 1;
    }
    return 0;
}

fn kv_is_valid_at(kv, when): i64 {
    if (when < load64(kv + 8)) { return 0; }
    var until = load64(kv + 16);
    if (until != 0) {
        if (when > until) { return 0; }
    }
    return 1;
}

# ================================================================
# PublisherKeyring (16 bytes)
# ================================================================
# Layout:
#   +0   keys_map   (hashmap: key_id -> vec of KeyVersion)
#   +8   keys_dir   (C-string ptr)

fn keyring_new(keys_dir): i64 {
    var kr = fl_alloc(16);
    store64(kr, map_new());
    store64(kr + 8, keys_dir);
    return kr;
}

fn keyring_add_key(kr, kv): i64 {
    var m = load64(kr);
    var kid = kv_key_id(kv);
    var existing = map_get(m, kid);
    if (existing == 0) {
        var v = vec_new();
        vec_push(v, kv);
        map_set(m, kid, v);
    } else {
        vec_push(existing, kv);
    }
    return kr;
}

fn keyring_get_current(kr, key_id): i64 {
    var m = load64(kr);
    var versions = map_get(m, key_id);
    if (versions == 0) { return 0; }
    var now = clock_epoch_secs();
    var vlen = vec_len(versions);
    # Return last valid key
    var i = vlen - 1;
    while (i >= 0) {
        var kv = vec_get(versions, i);
        if (kv_is_valid_at(kv, now) == 1) { return kv; }
        i = i - 1;
    }
    return 0;
}

fn keyring_get_all_versions(kr, key_id): i64 {
    var m = load64(kr);
    var versions = map_get(m, key_id);
    return versions;
}

fn keyring_len(kr): i64 {
    var m = load64(kr);
    return map_count(m);
}

fn keyring_find_by_role(kr, role): i64 {
    var result = vec_new();
    var m = load64(kr);
    var keys = map_keys(m);
    var klen = vec_len(keys);
    var i = 0;
    while (i < klen) {
        var kid = vec_get(keys, i);
        var versions = map_get(m, kid);
        var vlen = vec_len(versions);
        var j = 0;
        while (j < vlen) {
            var kv = vec_get(versions, j);
            if (kv_role(kv) == role) {
                vec_push(result, kv);
            }
            j = j + 1;
        }
        i = i + 1;
    }
    return result;
}

fn keyring_is_empty(kr): i64 {
    if (keyring_len(kr) == 0) { return 1; }
    return 0;
}

# Get key valid at a specific time
fn keyring_get_key_valid_at(kr, key_id, when): i64 {
    var m = load64(kr);
    var versions = map_get(m, key_id);
    if (versions == 0) { return 0; }
    var vlen = vec_len(versions);
    var i = vlen - 1;
    while (i >= 0) {
        var kv = vec_get(versions, i);
        if (kv_is_valid_at(kv, when) == 1) { return kv; }
        i = i - 1;
    }
    return 0;
}

# Get all key IDs in the keyring
fn keyring_key_ids(kr): i64 {
    var m = load64(kr);
    return map_keys(m);
}

# Find keys by publisher name (case-sensitive substring match)
fn keyring_find_by_publisher(kr, name): i64 {
    var result = vec_new();
    var m = load64(kr);
    var keys = map_keys(m);
    var klen = vec_len(keys);
    var nlen = strlen(name);
    var i = 0;
    while (i < klen) {
        var kid = vec_get(keys, i);
        var versions = map_get(m, kid);
        var vlen = vec_len(versions);
        var j = 0;
        while (j < vlen) {
            var kv = vec_get(versions, j);
            var pname = kv_pub_name(kv);
            if (pname != 0) {
                # Simple substring search
                var plen = strlen(pname);
                var k = 0;
                while (k + nlen <= plen) {
                    if (memeq(pname + k, name, nlen) == 1) {
                        vec_push(result, kv);
                        k = plen;  # break
                    }
                    k = k + 1;
                }
            }
            j = j + 1;
        }
        i = i + 1;
    }
    return result;
}

# Rotate key: create new version with overlap period
fn keyring_rotate_key(kr, key_id, new_pk_hex, overlap_until): i64 {
    var new_kv = key_version_new(key_id, new_pk_hex);
    # Set the old key's valid_until to overlap_until
    var m = load64(kr);
    var versions = map_get(m, key_id);
    if (versions != 0) {
        var vlen = vec_len(versions);
        if (vlen > 0) {
            var old_kv = vec_get(versions, vlen - 1);
            kv_set_valid_until(old_kv, overlap_until);
        }
    }
    keyring_add_key(kr, new_kv);
    return new_kv;
}

# Get trust chain from key to root (following issued_by links)
fn keyring_get_chain(kr, key_id): i64 {
    var chain = vec_new();
    var current_id = key_id;
    var max_depth = 10;
    var depth = 0;
    while (current_id != 0) {
        if (depth >= max_depth) { return chain; }
        var kv = keyring_get_current(kr, current_id);
        if (kv == 0) { return chain; }
        vec_push(chain, kv);
        current_id = kv_issued_by(kv);
        if (current_id == 0) { return chain; }
        # Check for self-signed (root)
        if (streq(current_id, key_id) == 1) { return chain; }
        depth = depth + 1;
    }
    return chain;
}

# Validate chain: verify each key was issued by its parent
fn keyring_validate_chain(kr, key_id): i64 {
    var chain = keyring_get_chain(kr, key_id);
    var clen = vec_len(chain);
    if (clen == 0) { return 0; }
    # Last key in chain should be root
    var root = vec_get(chain, clen - 1);
    if (kv_role(root) != KEY_ROLE_ROOT) { return 0; }
    return 1;
}

# Validate key_id as a safe filename:
#   - non-empty, max 64 chars
#   - only [A-Za-z0-9_-] (no '/', '.', or control bytes)
# Returns 1 if safe, 0 otherwise. Prevents path traversal in keyring_save.
fn _is_safe_key_id(kid): i64 {
    if (kid == 0) { return 0; }
    var klen = strlen(kid);
    if (klen == 0) { return 0; }
    if (klen > 64) { return 0; }
    var i = 0;
    while (i < klen) {
        var c = load8(kid + i) & 0xFF;
        var ok = 0;
        if (c >= 48) { if (c <= 57) { ok = 1; } }       # 0-9
        if (c >= 65) { if (c <= 90) { ok = 1; } }       # A-Z
        if (c >= 97) { if (c <= 122) { ok = 1; } }      # a-z
        if (c == 95) { ok = 1; }                        # _
        if (c == 45) { ok = 1; }                        # -
        if (ok == 0) { return 0; }
        i = i + 1;
    }
    return 1;
}

# Save keyring to JSON files in keys_dir.
# Returns count of key versions written. Skips any key_id that
# fails _is_safe_key_id or whose full path exceeds 255 bytes.
fn keyring_save(kr): i64 {
    var keys_dir = load64(kr + 8);
    if (keys_dir == 0) { return 0; }
    var m = load64(kr);
    var kids = map_keys(m);
    var klen = vec_len(kids);
    var count = 0;
    var i = 0;
    while (i < klen) {
        var kid = vec_get(kids, i);
        var versions = map_get(m, kid);
        var vlen = vec_len(versions);
        # Validate key_id — reject path traversal or oversized names
        if (_is_safe_key_id(kid) == 0) { i = i + 1; }
        else {
            var dlen = strlen(keys_dir);
            var kidlen = strlen(kid);
            # dlen + "/" + kidlen + ".json" + NUL
            var need = dlen + 1 + kidlen + 5 + 1;
            if (need > 256) { i = i + 1; }
            else {
                # Write JSON file: keys_dir/key_id.json
                var path = alloc(256);
                var pos = 0;
                memcpy(path, keys_dir, dlen);
                pos = pos + dlen;
                store8(path + pos, 47);  # /
                pos = pos + 1;
                memcpy(path + pos, kid, kidlen);
                pos = pos + kidlen;
                memcpy(path + pos, ".json", 5);
                pos = pos + 5;
                store8(path + pos, 0);

                var fd = file_open(path, 577, 420);  # O_WRONLY|O_CREAT|O_TRUNC, 0644
                if (fd >= 0) {
                    file_write(fd, "[", 1);
                    var j = 0;
                    while (j < vlen) {
                        var kv = vec_get(versions, j);
                        if (j > 0) { file_write(fd, ",", 1); }
                        file_write(fd, "{\"key_id\":\"", 11);
                        json_write_escaped(fd, kv_key_id(kv), strlen(kv_key_id(kv)));
                        file_write(fd, "\",\"public_key_hex\":\"", 20);
                        json_write_escaped(fd, kv_public_key_hex(kv), strlen(kv_public_key_hex(kv)));
                        file_write(fd, "\",\"role\":\"", 10);
                        var rn = key_role_name(kv_role(kv));
                        json_write_escaped(fd, rn, strlen(rn));
                        file_write(fd, "\"}", 2);
                        j = j + 1;
                    }
                    file_write(fd, "]", 1);
                    file_close(fd);
                    count = count + vlen;
                }
                i = i + 1;
            }
        }
    }
    return count;
}

# ================================================================
# JSON string escaping
# ================================================================
# Write `s` (length `slen`) to `fd`, escaping the minimal RFC 8259 set:
# `"`, `\`, and control bytes < 0x20. Non-ASCII bytes pass through
# verbatim (sigil stores UTF-8 path/hex content). Used by persistence
# paths to prevent JSON injection from tampered field values.
fn json_write_escaped(fd, s, slen): i64 {
    if (s == 0) { return 0; }
    var i = 0;
    var chunk_start = 0;
    while (i < slen) {
        var c = load8(s + i) & 0xFF;
        var needs_escape = 0;
        if (c == 34) { needs_escape = 1; }       # "
        elif (c == 92) { needs_escape = 1; }     # \
        elif (c < 32) { needs_escape = 1; }      # control
        if (needs_escape == 1) {
            if (i > chunk_start) {
                file_write(fd, s + chunk_start, i - chunk_start);
            }
            if (c == 34) { file_write(fd, "\\\"", 2); }
            elif (c == 92) { file_write(fd, "\\\\", 2); }
            elif (c == 8) { file_write(fd, "\\b", 2); }
            elif (c == 9) { file_write(fd, "\\t", 2); }
            elif (c == 10) { file_write(fd, "\\n", 2); }
            elif (c == 12) { file_write(fd, "\\f", 2); }
            elif (c == 13) { file_write(fd, "\\r", 2); }
            else {
                # \u00XX for other control bytes
                var hex_buf[6];
                store8(&hex_buf, 92);   # \
                store8(&hex_buf + 1, 117); # u
                store8(&hex_buf + 2, 48);  # 0
                store8(&hex_buf + 3, 48);  # 0
                var hi = (c >> 4) & 0xF;
                var lo = c & 0xF;
                if (hi < 10) { store8(&hex_buf + 4, 48 + hi); }
                else { store8(&hex_buf + 4, 87 + hi); }
                if (lo < 10) { store8(&hex_buf + 5, 48 + lo); }
                else { store8(&hex_buf + 5, 87 + lo); }
                file_write(fd, &hex_buf, 6);
            }
            chunk_start = i + 1;
        }
        i = i + 1;
    }
    if (slen > chunk_start) {
        file_write(fd, s + chunk_start, slen - chunk_start);
    }
    return 0;
}

# ================================================================
# Hash functions
# ================================================================

fn hash_data(data, len): i64 {
    return sha256_hex(data, len);
}

# Dispatch hashing by algorithm (mirrors Rust `hash_data_with`).
# HASH_ALG_SHA256 (default, 32-byte digest) or HASH_ALG_SHA512
# (64-byte digest). Unknown algorithm defaults to SHA-256 rather
# than returning 0 — a trust engine must never silently skip hashing.
fn hash_data_with(data, len, algorithm): i64 {
    if (algorithm == HASH_ALG_SHA512) { return sha512_hex(data, len); }
    return sha256_hex(data, len);
}

fn hash_file(path): i64 {
    var fd = file_open(path, 0, 0);
    if (fd < 0) { return 0; }
    var ctx = sha256_init();
    var buf[4096];
    var n = file_read(fd, &buf, 4096);
    while (n > 0) {
        sha256_update(ctx, &buf, n);
        n = file_read(fd, &buf, 4096);
    }
    file_close(fd);
    var digest[32];
    sha256_finalize(ctx, &digest);
    fl_free(ctx);
    return hex_encode(&digest, 32);
}

# Alloc-free variant of hash_file (3.2.0). Writes a 64-character
# lowercase SHA-256 hex digest plus a NUL terminator (65 bytes
# total) into `hex_out`, using `ctx_buf` as a 144-byte scratch
# SHA-256 context. Returns 1 on success, 0 if the file could not
# be opened.
#
# Caller MUST size:
#   hex_out  ≥ 65 bytes
#   ctx_buf  ≥ 144 bytes
#
# Used by the parallel-batch verify worker so the per-artifact
# hash step doesn't touch the freelist allocator (CLAUDE.md quirk
# #7). The 4 KB file_read buffer remains a stack-local — fine for
# concurrent workers, each thread gets its own stack.
fn hash_file_into(path, hex_out, ctx_buf): i64 {
    var fd = file_open(path, 0, 0);
    if (fd < 0) { return 0; }
    sha256_init_into(ctx_buf);
    # Banked per thread (3.6): the file-read buffer and digest are
    # `var X[N]` static function-scope globals (CLAUDE.md quirk #1).
    # On the parallel batch path each worker streams the file into its
    # own lane; a shared read buffer would interleave bytes across
    # workers and corrupt the content hash. (ctx_buf is already a
    # caller-provided per-artifact slot.)
    var bk = cbank();
    var buf[32768];  var bufb = &buf + bk * 4096;     # 4096 * SIGIL_CRYPTO_BANKS
    var digest[256]; var digestb = &digest + bk * 32; # 32 * SIGIL_CRYPTO_BANKS
    var n = file_read(fd, bufb, 4096);
    while (n > 0) {
        sha256_update(ctx_buf, bufb, n);
        n = file_read(fd, bufb, 4096);
    }
    file_close(fd);
    sha256_finalize(ctx_buf, digestb);
    # Inline hex_encode of the 32-byte digest into hex_out (lowercase,
    # NUL-terminated). Mirrors hex.cyr's hex_encode body but writes
    # into the caller-provided buffer instead of allocating.
    var i = 0;
    while (i < 32) {
        var b = load8(digestb + i) & 0xFF;
        var hi = (b >> 4) & 0xF;
        var lo = b & 0xF;
        if (hi < 10) { store8(hex_out + i * 2, 48 + hi); }
        else { store8(hex_out + i * 2, 87 + hi); }
        if (lo < 10) { store8(hex_out + i * 2 + 1, 48 + lo); }
        else { store8(hex_out + i * 2 + 1, 87 + lo); }
        i = i + 1;
    }
    store8(hex_out + 64, 0);
    return 1;
}

# File hash with algorithm selection (mirror of hash_data_with for
# on-disk content). Returns hex C-string, or 0 on file open failure.
# Unknown algorithm falls back to SHA-256 — trust engine must never
# silently skip hashing.
fn hash_file_with(path, algorithm): i64 {
    if (algorithm != HASH_ALG_SHA512) { return hash_file(path); }
    var fd = file_open(path, 0, 0);
    if (fd < 0) { return 0; }
    var ctx = sha512_init();
    var buf[4096];
    var n = file_read(fd, &buf, 4096);
    while (n > 0) {
        sha512_update(ctx, &buf, n);
        n = file_read(fd, &buf, 4096);
    }
    file_close(fd);
    var digest[64];
    sha512_finalize(ctx, &digest);
    fl_free(ctx);
    return hex_encode(&digest, 64);
}

# ================================================================
# Signing / verification (Ed25519)
# ================================================================

fn sign_data(data, len, secret_key): i64 {
    # secret_key is 64 bytes (seed || pk) from ed25519_keypair
    var sig = alloc(64);
    ed25519_sign(secret_key, data, len, sig);
    return sig;
}

fn verify_data(data, len, sig, public_key): i64 {
    # public_key is 32 bytes
    return ed25519_verify(public_key, data, len, sig);
}

# ================================================================
# Key generation (Ed25519)
# ================================================================

fn generate_keypair(sk_out, pk_out): i64 {
    # sk_out: 64 bytes (seed || pk), pk_out: 32 bytes
    # Returns key_id (C-string) on success, 0 on entropy failure.
    # `secret var` zeroizes seed on every return (Cyrius 5.3.5+).
    secret var seed[32];
    memset(&seed, 0, 32);
    var fd = file_open("/dev/urandom", 0, 0);
    if (fd < 0) { return 0; }
    var got = 0;
    while (got < 32) {
        var n = file_read(fd, (&seed) + got, 32 - got);
        if (n <= 0) {
            file_close(fd);
            return 0;
        }
        got = got + n;
    }
    file_close(fd);
    ed25519_keypair(&seed, sk_out, pk_out);

    # key_id = first 16 hex chars of public key
    var hex = hex_encode(pk_out, 32);
    var kid = alloc(17);
    memcpy(kid, hex, 16);
    store8(kid + 16, 0);
    return kid;
}

# ================================================================
# Key zeroization
# ================================================================

fn zeroize_key(key_buf, len): i64 {
    memset(key_buf, 0, len);
    return 0;
}

# --- integrity.cyr ---

# integrity.cyr — file integrity measurement and verification

# ================================================================
# MeasurementStatus
# ================================================================

enum MeasurementStatus {
    MSTATUS_PENDING = 0;
    MSTATUS_VERIFIED = 1;
    MSTATUS_MISMATCH = 2;
    MSTATUS_FILE_NOT_FOUND = 3;
    MSTATUS_ERROR = 4;
}

fn mstatus_name(s): i64 {
    if (s == MSTATUS_PENDING) { return "Pending"; }
    if (s == MSTATUS_VERIFIED) { return "Verified"; }
    if (s == MSTATUS_MISMATCH) { return "Mismatch"; }
    if (s == MSTATUS_FILE_NOT_FOUND) { return "FileNotFound"; }
    if (s == MSTATUS_ERROR) { return "Error"; }
    return "unknown";
}

# ================================================================
# IntegrityMeasurement (24 bytes)
# ================================================================
# Layout:
#   +0   path          (C-string ptr)
#   +8   expected_hash (C-string ptr)
#   +16  status        (i64 MSTATUS_*)
#
# Dropped in 2.6.0: actual_hash, measured_at, error_msg — all write-
# only. The per-verification computed hash is held in the local `h`
# variable during iv_verify_all and never re-read after the status
# decision.

fn measurement_new(path, expected_hash): i64 {
    var m = fl_alloc(24);
    store64(m, path);
    store64(m + 8, expected_hash);
    store64(m + 16, MSTATUS_PENDING);
    return m;
}

fn meas_path(m): i64 { return load64(m); }
fn meas_expected(m): i64 { return load64(m + 8); }
fn meas_status(m): i64 { return load64(m + 16); }

# ================================================================
# IntegrityPolicy (24 bytes)
# ================================================================
# Layout:
#   +0   measurements   (vec of measurement pointers)
#   +8   check_interval (seconds)
#   +16  enforce        (i64, 0 or 1)

fn integrity_policy_new(): i64 {
    var p = fl_alloc(24);
    store64(p, vec_new());
    store64(p + 8, 300);
    store64(p + 16, 0);
    return p;
}

fn ipolicy_check_interval(p): i64 { return load64(p + 8); }
fn ipolicy_enforce(p): i64 { return load64(p + 16); }

fn ipolicy_set_enforce(p, v): i64 { store64(p + 16, v); return p; }
fn ipolicy_set_interval(p, v): i64 { store64(p + 8, v); return p; }

fn ipolicy_add(p, path, expected_hash): i64 {
    var m = measurement_new(path, expected_hash);
    vec_push(load64(p), m);
    return p;
}

fn ipolicy_remove(p, path): i64 {
    var measurements = load64(p);
    var mlen = vec_len(measurements);
    var i = 0;
    while (i < mlen) {
        var m = vec_get(measurements, i);
        if (streq(load64(m), path) == 1) {
            vec_remove(measurements, i);
            return 1;
        }
        i = i + 1;
    }
    return 0;
}

# ================================================================
# IntegrityReport (32 bytes)
# ================================================================
# Layout:
#   +0   total       (i64)
#   +8   verified    (i64)
#   +16  mismatches  (vec)
#   +24  errors      (vec)
#
# Dropped in 2.6.0: checked_at — no read path. Callers can
# clock_epoch_secs() themselves at report time.

fn integrity_report_new(): i64 {
    var r = fl_alloc(32);
    store64(r, 0);
    store64(r + 8, 0);
    store64(r + 16, vec_new());
    store64(r + 24, vec_new());
    return r;
}

fn ireport_total(r): i64 { return load64(r); }
fn ireport_verified(r): i64 { return load64(r + 8); }
fn ireport_mismatches(r): i64 { return load64(r + 16); }
fn ireport_errors(r): i64 { return load64(r + 24); }

fn ireport_is_clean(r): i64 {
    if (vec_len(load64(r + 16)) == 0) {
        if (vec_len(load64(r + 24)) == 0) {
            return 1;
        }
    }
    return 0;
}

# ================================================================
# IntegrityVerifier (24 bytes)
# ================================================================
# Layout:
#   +0   policy       (IntegrityPolicy ptr)
#   +8   last_report  (IntegrityReport ptr, 0 = none)
#   +16  callback     (fn ptr, 0 = none)

fn integrity_verifier_new(policy): i64 {
    var v = fl_alloc(24);
    store64(v, policy);
    store64(v + 8, 0);
    store64(v + 16, 0);
    return v;
}

fn iv_policy(v): i64 { return load64(v); }
fn iv_last_report(v): i64 { return load64(v + 8); }

fn iv_set_callback(v, cb): i64 { store64(v + 16, cb); return v; }
fn iv_clear_callback(v): i64 { store64(v + 16, 0); return v; }

fn iv_set_policy(v, policy): i64 {
    store64(v, policy);
    store64(v + 8, 0);
    return v;
}

# Verify a single file against policy
fn iv_verify_file(v, path): i64 {
    var policy = load64(v);
    var measurements = load64(policy);
    var mlen = vec_len(measurements);
    var i = 0;
    while (i < mlen) {
        var m = vec_get(measurements, i);
        if (streq(load64(m), path) == 1) {
            var h = hash_file(path);
            if (h == 0) { return MSTATUS_FILE_NOT_FOUND; }
            var expected = load64(m + 8);
            if (ct_eq_bytes_lens(h, strlen(h), expected, strlen(expected)) == 1) {
                return MSTATUS_VERIFIED;
            }
            return MSTATUS_MISMATCH;
        }
        i = i + 1;
    }
    return MSTATUS_ERROR;
}

# Verify all files in policy
fn iv_verify_all(v): i64 {
    var policy = load64(v);
    var measurements = load64(policy);
    var mlen = vec_len(measurements);
    var report = integrity_report_new();
    store64(report, mlen);

    var verified = 0;
    var i = 0;
    while (i < mlen) {
        var m = vec_get(measurements, i);
        var path = load64(m);
        var h = hash_file(path);

        if (h == 0) {
            # File not found or error.
            var rm = measurement_new(path, load64(m + 8));
            store64(rm + 16, MSTATUS_FILE_NOT_FOUND);
            vec_push(load64(report + 24), rm);
        } else {
            var expected = load64(m + 8);
            if (ct_eq_bytes_lens(h, strlen(h), expected, strlen(expected)) == 1) {
                verified = verified + 1;
                store64(m + 16, MSTATUS_VERIFIED);
            } else {
                var rm = measurement_new(path, expected);
                store64(rm + 16, MSTATUS_MISMATCH);
                vec_push(load64(report + 16), rm);
            }
        }
        i = i + 1;
    }
    store64(report + 8, verified);
    store64(v + 8, report);
    return report;
}

# Add baseline: hash file and add to policy
fn iv_add_baseline(v, path): i64 {
    var h = hash_file(path);
    if (h == 0) { return 0; }
    var policy = load64(v);
    ipolicy_add(policy, path, h);
    store64(v + 8, 0);
    return h;
}

# Remove baseline
fn iv_remove_baseline(v, path): i64 {
    var policy = load64(v);
    var removed = ipolicy_remove(policy, path);
    if (removed == 1) { store64(v + 8, 0); }
    return removed;
}

# Get tampered files from last report
fn iv_tampered_files(v): i64 {
    var report = load64(v + 8);
    if (report == 0) { return vec_new(); }
    return load64(report + 16);
}

# ================================================================
# IntegritySnapshot — serializable baseline
# ================================================================
# Layout (8 bytes):
#   +0  entries      (vec of {path, hash} pairs)
#
# Dropped in 2.6.0: exported_at — no read path.

fn integrity_snapshot_new(): i64 {
    var s = fl_alloc(8);
    store64(s, vec_new());
    return s;
}

fn isnap_entries(s): i64 { return load64(s); }

# BaselineEntry (16 bytes): path + expected_hash
fn baseline_entry_new(path, expected_hash): i64 {
    var e = fl_alloc(16);
    store64(e, path);
    store64(e + 8, expected_hash);
    return e;
}

fn bentry_path(e): i64 { return load64(e); }
fn bentry_hash(e): i64 { return load64(e + 8); }

# Export current baseline as snapshot
fn iv_export_baseline(v): i64 {
    var policy = load64(v);
    var measurements = load64(policy);
    var snap = integrity_snapshot_new();
    var entries = load64(snap);
    var mlen = vec_len(measurements);
    var i = 0;
    while (i < mlen) {
        var m = vec_get(measurements, i);
        var be = baseline_entry_new(meas_path(m), meas_expected(m));
        vec_push(entries, be);
        i = i + 1;
    }
    return snap;
}

# Import snapshot, replacing current policy measurements
fn iv_import_baseline(v, snap): i64 {
    var policy = load64(v);
    var interval = ipolicy_check_interval(policy);
    var enforce = ipolicy_enforce(policy);

    var new_policy = integrity_policy_new();
    ipolicy_set_interval(new_policy, interval);
    ipolicy_set_enforce(new_policy, enforce);

    var entries = isnap_entries(snap);
    var elen = vec_len(entries);
    var i = 0;
    while (i < elen) {
        var be = vec_get(entries, i);
        ipolicy_add(new_policy, bentry_path(be), bentry_hash(be));
        i = i + 1;
    }
    store64(v, new_policy);
    store64(v + 8, 0);
    return elen;
}


# --- policy.cyr ---

# policy.cyr — revocation list management

# ================================================================
# RevocationEntry (48 bytes)
# ================================================================
# Layout:
#   +0   key_id        (C-string ptr, 0 = none)
#   +8   content_hash  (C-string ptr, 0 = none)
#   +16  reason        (C-string ptr)
#   +24  revoked_at    (epoch seconds)
#   +32  revoked_by    (C-string ptr)
#   +40  revoked_after (epoch seconds, 0 = unconditional)

fn revocation_entry_new(key_id, content_hash, reason, revoked_by): i64 {
    var e = fl_alloc(48);
    store64(e, key_id);
    store64(e + 8, content_hash);
    store64(e + 16, reason);
    store64(e + 24, clock_epoch_secs());
    store64(e + 32, revoked_by);
    store64(e + 40, 0);
    return e;
}

fn rev_key_id(e): i64 { return load64(e); }
fn rev_content_hash(e): i64 { return load64(e + 8); }
fn rev_reason(e): i64 { return load64(e + 16); }
fn rev_at(e): i64 { return load64(e + 24); }
fn rev_by(e): i64 { return load64(e + 32); }
fn rev_after(e): i64 { return load64(e + 40); }
fn rev_set_after(e, v): i64 { store64(e + 40, v); return e; }

# ================================================================
# RevocationList (24 bytes)
# ================================================================
# Layout:
#   +0   entries       (vec of RevocationEntry ptrs)
#   +8   revoked_keys  (hashmap key_id -> 1)
#   +16  revoked_hashes (hashmap content_hash -> 1)

fn revocation_list_new(): i64 {
    var rl = fl_alloc(24);
    store64(rl, vec_new());
    store64(rl + 8, map_new());
    store64(rl + 16, map_new());
    return rl;
}

fn rl_add(rl, entry): i64 {
    var kid = load64(entry);
    var chash = load64(entry + 8);
    if (kid == 0) {
        if (chash == 0) { return ERR_INVALID_INPUT; }
    }
    if (kid != 0) {
        map_set(load64(rl + 8), kid, 1);
    }
    if (chash != 0) {
        map_set(load64(rl + 16), chash, 1);
    }
    vec_push(load64(rl), entry);
    return ERR_NONE;
}

fn rl_is_key_revoked(rl, key_id): i64 {
    return rl_is_key_revoked_at(rl, key_id, 0);
}

fn rl_is_key_revoked_at(rl, key_id, at): i64 {
    var keys = load64(rl + 8);
    if (map_get(keys, key_id) == 0) { return 0; }
    if (at == 0) { return 1; }
    # Check entries for revoked_after semantics
    var entries = load64(rl);
    var elen = vec_len(entries);
    var i = 0;
    while (i < elen) {
        var e = vec_get(entries, i);
        var ekid = load64(e);
        if (ekid != 0) {
            if (streq(ekid, key_id) == 1) {
                var after = load64(e + 40);
                if (after == 0) { return 1; }
                if (at >= after) { return 1; }
            }
        }
        i = i + 1;
    }
    return 0;
}

fn rl_is_artifact_revoked(rl, content_hash): i64 {
    return rl_is_artifact_revoked_at(rl, content_hash, 0);
}

fn rl_is_artifact_revoked_at(rl, content_hash, at): i64 {
    var hashes = load64(rl + 16);
    if (map_get(hashes, content_hash) == 0) { return 0; }
    if (at == 0) { return 1; }
    var entries = load64(rl);
    var elen = vec_len(entries);
    var i = 0;
    while (i < elen) {
        var e = vec_get(entries, i);
        var ehash = load64(e + 8);
        if (ehash != 0) {
            if (streq(ehash, content_hash) == 1) {
                var after = load64(e + 40);
                if (after == 0) { return 1; }
                if (at >= after) { return 1; }
            }
        }
        i = i + 1;
    }
    return 0;
}

fn rl_len(rl): i64 { return vec_len(load64(rl)); }
fn rl_is_empty(rl): i64 { if (rl_len(rl) == 0) { return 1; } return 0; }

fn rl_merge(rl, other): i64 {
    var other_entries = load64(other);
    var olen = vec_len(other_entries);
    var added = 0;
    var i = 0;
    while (i < olen) {
        var e = vec_get(other_entries, i);
        # Check for duplicate
        var dup = 0;
        var our_entries = load64(rl);
        var ulen = vec_len(our_entries);
        var j = 0;
        while (j < ulen) {
            var oe = vec_get(our_entries, j);
            var kid_match = 0;
            var hash_match = 0;
            if (load64(e) == 0) { if (load64(oe) == 0) { kid_match = 1; } }
            else { if (load64(oe) != 0) { if (streq(load64(e), load64(oe)) == 1) { kid_match = 1; } } }
            if (load64(e + 8) == 0) { if (load64(oe + 8) == 0) { hash_match = 1; } }
            else { if (load64(oe + 8) != 0) { if (streq(load64(e + 8), load64(oe + 8)) == 1) { hash_match = 1; } } }
            if (kid_match == 1) { if (hash_match == 1) { dup = 1; } }
            j = j + 1;
        }
        if (dup == 0) {
            rl_add(rl, e);
            added = added + 1;
        }
        i = i + 1;
    }
    return added;
}

# ================================================================
# CRL — Certificate Revocation List (40 bytes)
# ================================================================
# Layout:
#   +0   version     (i64)
#   +8   issuer      (C-string ptr)
#   +16  issued_at   (epoch seconds)
#   +24  next_update (epoch seconds, 0 = none)
#   +32  entries     (vec of RevocationEntry ptrs)

fn crl_new(version, issuer): i64 {
    var c = fl_alloc(40);
    store64(c, version);
    store64(c + 8, issuer);
    store64(c + 16, clock_epoch_secs());
    store64(c + 24, 0);
    store64(c + 32, vec_new());
    return c;
}

fn crl_version(c): i64 { return load64(c); }
fn crl_issuer(c): i64 { return load64(c + 8); }
fn crl_issued_at(c): i64 { return load64(c + 16); }
fn crl_next_update(c): i64 { return load64(c + 24); }
fn crl_entries(c): i64 { return load64(c + 32); }

fn crl_set_next_update(c, v): i64 { store64(c + 24, v); return c; }

fn crl_add_entry(c, entry): i64 {
    vec_push(load64(c + 32), entry);
    return c;
}

fn crl_is_stale(c): i64 {
    var next = load64(c + 24);
    if (next == 0) { return 0; }
    if (clock_epoch_secs() > next) { return 1; }
    return 0;
}

fn crl_apply_to(c, rl): i64 {
    var entries = load64(c + 32);
    var elen = vec_len(entries);
    var added = 0;
    var i = 0;
    while (i < elen) {
        var e = vec_get(entries, i);
        var result = rl_add(rl, e);
        if (result == ERR_NONE) { added = added + 1; }
        i = i + 1;
    }
    return added;
}

# ================================================================
# JSON Lines serialization (RevocationEntry, RevocationList, Crl)
#
# Deliberate format choice: one JSON object per line, newline-
# separated. Cyrius' lib/json.cyr parses a single object at a time
# and has no array support, so JSONL is the cleanest round-trip
# format and matches `alog_save`.  Rust's `to_json()`
# produced a JSON array; JSONL is trivially convertible with
# `jq -s`.
#
# Null fields use JSON `null` (no quotes). Parsing treats `null`,
# empty, and missing fields as 0 (C-string null ptr).
# ================================================================

# Internal: append JSON-escaped version of a C-string to a
# str_builder. Escapes `"`, `\`, and control chars 0x00-0x1F
# per RFC 8259. Without this, a reason like `key "foo" compromised`
# would produce invalid JSON that the parser choked on.
fn _json_escape_cstr(sb, s): i64 {
    var n = strlen(s);
    var i = 0;
    while (i < n) {
        var c = load8(s + i) & 0xFF;
        if (c == 34) { str_builder_add_cstr(sb, "\\\""); }
        elif (c == 92) { str_builder_add_cstr(sb, "\\\\"); }
        elif (c == 10) { str_builder_add_cstr(sb, "\\n"); }
        elif (c == 13) { str_builder_add_cstr(sb, "\\r"); }
        elif (c == 9)  { str_builder_add_cstr(sb, "\\t"); }
        elif (c == 8)  { str_builder_add_cstr(sb, "\\b"); }
        elif (c == 12) { str_builder_add_cstr(sb, "\\f"); }
        elif (c < 32) {
            # \u00XX for any remaining control char
            str_builder_add_cstr(sb, "\\u00");
            var hi = (c >> 4) & 0xF;
            var lo = c & 0xF;
            if (hi < 10) { str_builder_add_byte(sb, 48 + hi); }
            else         { str_builder_add_byte(sb, 87 + hi); }
            if (lo < 10) { str_builder_add_byte(sb, 48 + lo); }
            else         { str_builder_add_byte(sb, 87 + lo); }
        } else {
            str_builder_add_byte(sb, c);
        }
        i = i + 1;
    }
    return 0;
}

# Internal: emit one entry as a JSONL line into a str_builder.
fn _rev_entry_to_jsonl(sb, e): i64 {
    str_builder_add_cstr(sb, "{\"key_id\":");
    if (rev_key_id(e) != 0) {
        str_builder_add_cstr(sb, "\"");
        _json_escape_cstr(sb, rev_key_id(e));
        str_builder_add_cstr(sb, "\"");
    } else {
        str_builder_add_cstr(sb, "null");
    }
    str_builder_add_cstr(sb, ",\"content_hash\":");
    if (rev_content_hash(e) != 0) {
        str_builder_add_cstr(sb, "\"");
        _json_escape_cstr(sb, rev_content_hash(e));
        str_builder_add_cstr(sb, "\"");
    } else {
        str_builder_add_cstr(sb, "null");
    }
    str_builder_add_cstr(sb, ",\"reason\":\"");
    _json_escape_cstr(sb, rev_reason(e));
    str_builder_add_cstr(sb, "\",\"revoked_at\":");
    str_builder_add_int(sb, rev_at(e));
    str_builder_add_cstr(sb, ",\"revoked_by\":\"");
    _json_escape_cstr(sb, rev_by(e));
    str_builder_add_cstr(sb, "\",\"revoked_after\":");
    str_builder_add_int(sb, rev_after(e));
    str_builder_add_cstr(sb, "}\n");
    return 0;
}

# Serialize a RevocationList to a JSONL C-string. Caller owns the
# returned pointer (alloc'd). Returns 0 on OOM (not expected).
fn rl_to_jsonl(rl): i64 {
    var sb = str_builder_new();
    var entries = load64(rl);
    var elen = vec_len(entries);
    var i = 0;
    while (i < elen) {
        _rev_entry_to_jsonl(sb, vec_get(entries, i));
        i = i + 1;
    }
    # Return C-string: copy builder's underlying buf + terminator.
    var total = load64(sb + 8);
    var out = alloc(total + 1);
    memcpy(out, load64(sb), total);
    store8(out + total, 0);
    return out;
}

# Internal: parse the quoted value at data[pos..] where pos is just
# past the opening quote. Returns end offset (just past closing
# quote). Writes a fresh C-string copy of the contents to *out_ptr.
# Sets *out_ptr to 0 and returns pos unchanged if not a quoted str.
var _rj_out_ptr = 0;

fn _rj_parse_string(data, pos, end): i64 {
    _rj_out_ptr = 0;
    if (pos >= end) { return pos; }
    if ((load8(data + pos) & 0xFF) != 34) { return pos; }
    pos = pos + 1;
    # First pass: find closing quote, handling escapes (\" and \\)
    # so an embedded quote does not end the string prematurely.
    var start = pos;
    while (pos < end) {
        var c = load8(data + pos) & 0xFF;
        if (c == 92) {
            # Escape sequence — skip the next char (it's part of the value)
            pos = pos + 2;
        } elif (c == 34) {
            break;
        } else {
            pos = pos + 1;
        }
    }
    # Second pass: copy content, unescaping \x → x for \" \\ \n \r \t \b \f.
    # \uXXXX is rejected as non-ASCII (caller's writer only emits control
    # chars as \uNNNN for bytes < 32; we decode those back to the raw byte).
    var raw_len = pos - start;
    var out = alloc(raw_len + 1);
    var w = 0;
    var r = 0;
    while (r < raw_len) {
        var c = load8(data + start + r) & 0xFF;
        if (c == 92) {
            r = r + 1;
            if (r >= raw_len) { break; }
            var ec = load8(data + start + r) & 0xFF;
            if (ec == 110) { store8(out + w, 10); }     # \n
            elif (ec == 114) { store8(out + w, 13); }   # \r
            elif (ec == 116) { store8(out + w, 9); }    # \t
            elif (ec == 98)  { store8(out + w, 8); }    # \b
            elif (ec == 102) { store8(out + w, 12); }   # \f
            elif (ec == 117) {
                # \uXXXX — read 4 hex digits, emit as byte if ≤ 0xFF
                if (r + 4 < raw_len) {
                    var v = 0;
                    var k = 1;
                    while (k <= 4) {
                        var h = load8(data + start + r + k) & 0xFF;
                        var d = 0;
                        if (h >= 48) { if (h <= 57) { d = h - 48; } }
                        if (h >= 97) { if (h <= 102) { d = h - 87; } }
                        if (h >= 65) { if (h <= 70)  { d = h - 55; } }
                        v = (v << 4) | d;
                        k = k + 1;
                    }
                    store8(out + w, v & 0xFF);
                    r = r + 4;
                }
            } else {
                # \" \\ / and any other → pass through the second char.
                store8(out + w, ec);
            }
            r = r + 1;
            w = w + 1;
        } else {
            store8(out + w, c);
            r = r + 1;
            w = w + 1;
        }
    }
    store8(out + w, 0);
    _rj_out_ptr = out;
    if (pos < end) { pos = pos + 1; }   # skip closing quote
    return pos;
}

# Parse a single JSONL entry line into a fresh RevocationEntry.
# Returns entry ptr, or 0 on malformed input.
fn _rev_entry_from_jsonl(line, llen): i64 {
    # Six fields: key_id, content_hash, reason, revoked_at,
    # revoked_by, revoked_after.  Walk the line in order, matching
    # on the known key names. Tolerant to reordering that survives a
    # round-trip from our own writer.
    var key_id = 0;
    var chash = 0;
    var reason = 0;
    var revoked_by = 0;
    var revoked_at = 0;
    var revoked_after = 0;

    var pos = 0;
    while (pos < llen) {
        var c = load8(line + pos) & 0xFF;
        if (c != 34) { pos = pos + 1; }   # scan for opening quote
        else {
            pos = _rj_parse_string(line, pos, llen);
            var k = _rj_out_ptr;
            if (k == 0) { return 0; }
            # Skip to colon
            while (pos < llen) {
                if ((load8(line + pos) & 0xFF) == 58) { pos = pos + 1; break; }
                pos = pos + 1;
            }
            # Skip whitespace after colon
            while (pos < llen) {
                var cc = load8(line + pos) & 0xFF;
                if (cc == 32) { pos = pos + 1; }
                elif (cc == 9) { pos = pos + 1; }
                else { break; }
            }
            if (pos >= llen) { return 0; }
            var vc = load8(line + pos) & 0xFF;
            if (vc == 34) {
                # Quoted string value
                pos = _rj_parse_string(line, pos, llen);
                var v = _rj_out_ptr;
                if (streq(k, "key_id") == 1) { key_id = v; }
                elif (streq(k, "content_hash") == 1) { chash = v; }
                elif (streq(k, "reason") == 1) { reason = v; }
                elif (streq(k, "revoked_by") == 1) { revoked_by = v; }
            } else {
                # Non-string value: null or integer.
                var vs = pos;
                while (pos < llen) {
                    var vcc = load8(line + pos) & 0xFF;
                    if (vcc == 44) { break; }  # ','
                    if (vcc == 125) { break; } # '}'
                    if (vcc == 32) { break; }
                    if (vcc == 10) { break; }
                    pos = pos + 1;
                }
                var vlen = pos - vs;
                if (vlen > 0) {
                    # Integer fields
                    var intv = 0;
                    # Reject "null" / "true" / "false" by checking first byte.
                    var fb = load8(line + vs) & 0xFF;
                    if (fb >= 48) {
                        if (fb <= 57) {
                            # digit — parse as int
                            var ii = 0;
                            while (ii < vlen) {
                                intv = intv * 10 + ((load8(line + vs + ii) & 0xFF) - 48);
                                ii = ii + 1;
                            }
                        }
                    }
                    if (streq(k, "revoked_at") == 1) { revoked_at = intv; }
                    elif (streq(k, "revoked_after") == 1) { revoked_after = intv; }
                }
            }
        }
    }

    if (reason == 0) { reason = ""; }
    if (revoked_by == 0) { revoked_by = ""; }
    var e = revocation_entry_new(key_id, chash, reason, revoked_by);
    store64(e + 24, revoked_at);
    store64(e + 40, revoked_after);
    return e;
}

# Load a RevocationList from JSONL content. Returns a new list or 0.
# Invalid entries in the stream are skipped rather than aborting —
# callers building a fresh list from a third-party CRL should not
# be taken down by a single malformed line, but each rejected line
# bumps the returned error count.  Well-formed output from our own
# writer always round-trips cleanly.
var _rl_load_bad = 0;

fn rl_load_bad_count(): i64 { return _rl_load_bad; }

fn rl_from_jsonl(content, content_len): i64 {
    _rl_load_bad = 0;
    var rl = revocation_list_new();
    var pos = 0;
    while (pos < content_len) {
        # Find end of line
        var start = pos;
        while (pos < content_len) {
            if ((load8(content + pos) & 0xFF) == 10) { break; }
            pos = pos + 1;
        }
        var llen = pos - start;
        if (llen > 0) {
            var e = _rev_entry_from_jsonl(content + start, llen);
            if (e == 0) { _rl_load_bad = _rl_load_bad + 1; }
            else {
                if (rl_add(rl, e) != ERR_NONE) { _rl_load_bad = _rl_load_bad + 1; }
            }
        }
        if (pos < content_len) { pos = pos + 1; }   # skip '\n'
    }
    return rl;
}

# File wrappers — idiomatic "save/load via path" shortcuts.
fn rl_save(rl, path): i64 {
    var jsonl = rl_to_jsonl(rl);
    var n = file_write_all(path, jsonl, strlen(jsonl));
    if (n < 0) { return ERR_IO; }
    return ERR_NONE;
}

fn rl_load(path): i64 {
    var buf = alloc(65536);
    var n = file_read_all(path, buf, 65536);
    if (n < 0) { return 0; }
    return rl_from_jsonl(buf, n);
}

# ================================================================
# Crl JSON Lines — first line is the header, subsequent lines are
# entries in the same format as rl_to_jsonl.
# ================================================================

fn crl_to_jsonl(c): i64 {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"version\":");
    str_builder_add_int(sb, crl_version(c));
    str_builder_add_cstr(sb, ",\"issuer\":\"");
    _json_escape_cstr(sb, crl_issuer(c));
    str_builder_add_cstr(sb, "\",\"issued_at\":");
    str_builder_add_int(sb, crl_issued_at(c));
    str_builder_add_cstr(sb, ",\"next_update\":");
    str_builder_add_int(sb, crl_next_update(c));
    str_builder_add_cstr(sb, "}\n");
    var entries = crl_entries(c);
    var elen = vec_len(entries);
    var i = 0;
    while (i < elen) {
        _rev_entry_to_jsonl(sb, vec_get(entries, i));
        i = i + 1;
    }
    var total = load64(sb + 8);
    var out = alloc(total + 1);
    memcpy(out, load64(sb), total);
    store8(out + total, 0);
    return out;
}

# Parse the CRL header line. Returns new Crl struct with the entries
# vec initialized empty. Returns 0 on failure.
fn _crl_parse_header(line, llen): i64 {
    var version = 0;
    var issuer = 0;
    var issued_at = 0;
    var next_update = 0;

    var pos = 0;
    while (pos < llen) {
        var c = load8(line + pos) & 0xFF;
        if (c != 34) { pos = pos + 1; }
        else {
            pos = _rj_parse_string(line, pos, llen);
            var k = _rj_out_ptr;
            if (k == 0) { return 0; }
            while (pos < llen) {
                if ((load8(line + pos) & 0xFF) == 58) { pos = pos + 1; break; }
                pos = pos + 1;
            }
            while (pos < llen) {
                var cc = load8(line + pos) & 0xFF;
                if (cc == 32) { pos = pos + 1; }
                elif (cc == 9) { pos = pos + 1; }
                else { break; }
            }
            if (pos >= llen) { return 0; }
            var vc = load8(line + pos) & 0xFF;
            if (vc == 34) {
                pos = _rj_parse_string(line, pos, llen);
                if (streq(k, "issuer") == 1) { issuer = _rj_out_ptr; }
            } else {
                var vs = pos;
                while (pos < llen) {
                    var vcc = load8(line + pos) & 0xFF;
                    if (vcc == 44) { break; }
                    if (vcc == 125) { break; }
                    pos = pos + 1;
                }
                var vlen = pos - vs;
                var intv = 0;
                if (vlen > 0) {
                    var fb = load8(line + vs) & 0xFF;
                    if (fb >= 48) { if (fb <= 57) {
                            var ii = 0;
                            while (ii < vlen) {
                                intv = intv * 10 + ((load8(line + vs + ii) & 0xFF) - 48);
                                ii = ii + 1;
                            }
                        } }
                }
                if (streq(k, "version") == 1) { version = intv; }
                elif (streq(k, "issued_at") == 1) { issued_at = intv; }
                elif (streq(k, "next_update") == 1) { next_update = intv; }
            }
        }
    }
    if (issuer == 0) { return 0; }
    var c = crl_new(version, issuer);
    store64(c + 16, issued_at);
    store64(c + 24, next_update);
    return c;
}

# Parse CRL from JSONL content. First line = header, subsequent
# lines = revocation entries.
fn crl_from_jsonl(content, content_len): i64 {
    # Extract first line
    var hend = 0;
    while (hend < content_len) {
        if ((load8(content + hend) & 0xFF) == 10) { break; }
        hend = hend + 1;
    }
    if (hend == 0) { return 0; }
    var c = _crl_parse_header(content, hend);
    if (c == 0) { return 0; }
    # Entries start after the header newline
    var pos = hend + 1;
    while (pos < content_len) {
        var start = pos;
        while (pos < content_len) {
            if ((load8(content + pos) & 0xFF) == 10) { break; }
            pos = pos + 1;
        }
        var llen = pos - start;
        if (llen > 0) {
            var e = _rev_entry_from_jsonl(content + start, llen);
            if (e != 0) { crl_add_entry(c, e); }
        }
        if (pos < content_len) { pos = pos + 1; }
    }
    return c;
}

fn crl_save(c, path): i64 {
    var jsonl = crl_to_jsonl(c);
    var n = file_write_all(path, jsonl, strlen(jsonl));
    if (n < 0) { return ERR_IO; }
    return ERR_NONE;
}

fn crl_load(path): i64 {
    var buf = alloc(65536);
    var n = file_read_all(path, buf, 65536);
    if (n < 0) { return 0; }
    return crl_from_jsonl(buf, n);
}

# --- audit.cyr ---

# audit.cyr — structured audit event logging

# ================================================================
# AuditEvent types
# ================================================================

enum AuditEventType {
    AUDIT_ARTIFACT_VERIFIED = 0;
    AUDIT_ARTIFACT_SIGNED = 1;
    AUDIT_REVOCATION_ADDED = 2;
    AUDIT_KEY_ROTATED = 3;
    AUDIT_CHAIN_VALIDATED = 4;
}

fn audit_event_name(t): i64 {
    if (t == AUDIT_ARTIFACT_VERIFIED) { return "artifact_verified"; }
    if (t == AUDIT_ARTIFACT_SIGNED) { return "artifact_signed"; }
    if (t == AUDIT_REVOCATION_ADDED) { return "revocation_added"; }
    if (t == AUDIT_KEY_ROTATED) { return "key_rotated"; }
    if (t == AUDIT_CHAIN_VALIDATED) { return "chain_validated"; }
    return "unknown";
}

# Inverse of audit_event_name. Returns the AUDIT_* constant for a
# known name, or -1 if the string does not match any known event.
fn audit_event_type_from_name(name): i64 {
    if (streq(name, "artifact_verified") == 1) { return AUDIT_ARTIFACT_VERIFIED; }
    if (streq(name, "artifact_signed") == 1) { return AUDIT_ARTIFACT_SIGNED; }
    if (streq(name, "revocation_added") == 1) { return AUDIT_REVOCATION_ADDED; }
    if (streq(name, "key_rotated") == 1) { return AUDIT_KEY_ROTATED; }
    if (streq(name, "chain_validated") == 1) { return AUDIT_CHAIN_VALIDATED; }
    return (0 - 1);
}

# ================================================================
# AuditEvent (64 bytes)
# ================================================================
# Generic event struct that holds all possible fields.
# Layout:
#   +0   event_type    (i64 AUDIT_*)
#   +8   path          (C-string ptr, 0 = n/a)
#   +16  artifact_type (i64, -1 = n/a)
#   +24  trust_level   (i64, -1 = n/a)
#   +32  passed        (i64, -1 = n/a)
#   +40  content_hash  (C-string ptr, 0 = n/a)
#   +48  key_id        (C-string ptr, 0 = n/a)
#   +56  timestamp     (epoch seconds)

fn audit_event_new(event_type): i64 {
    var e = fl_alloc(64);
    store64(e, event_type);
    store64(e + 8, 0);
    store64(e + 16, 0 - 1);
    store64(e + 24, 0 - 1);
    store64(e + 32, 0 - 1);
    store64(e + 40, 0);
    store64(e + 48, 0);
    store64(e + 56, clock_epoch_secs());
    return e;
}

fn ae_type(e): i64 { return load64(e); }
fn ae_path(e): i64 { return load64(e + 8); }
fn ae_artifact_type(e): i64 { return load64(e + 16); }
fn ae_trust_level(e): i64 { return load64(e + 24); }
fn ae_passed(e): i64 { return load64(e + 32); }
fn ae_content_hash(e): i64 { return load64(e + 40); }
fn ae_key_id(e): i64 { return load64(e + 48); }
fn ae_timestamp(e): i64 { return load64(e + 56); }

fn ae_set_path(e, v): i64 { store64(e + 8, v); return e; }
fn ae_set_artifact_type(e, v): i64 { store64(e + 16, v); return e; }
fn ae_set_trust_level(e, v): i64 { store64(e + 24, v); return e; }
fn ae_set_passed(e, v): i64 { store64(e + 32, v); return e; }
fn ae_set_content_hash(e, v): i64 { store64(e + 40, v); return e; }
fn ae_set_key_id(e, v): i64 { store64(e + 48, v); return e; }

# ================================================================
# Convenience constructors
# ================================================================

fn audit_artifact_verified(path, atype, tlevel, passed, chash): i64 {
    var e = audit_event_new(AUDIT_ARTIFACT_VERIFIED);
    ae_set_path(e, path);
    ae_set_artifact_type(e, atype);
    ae_set_trust_level(e, tlevel);
    ae_set_passed(e, passed);
    ae_set_content_hash(e, chash);
    return e;
}

fn audit_artifact_signed(path, atype, key_id, chash): i64 {
    var e = audit_event_new(AUDIT_ARTIFACT_SIGNED);
    ae_set_path(e, path);
    ae_set_artifact_type(e, atype);
    ae_set_key_id(e, key_id);
    ae_set_content_hash(e, chash);
    return e;
}

fn audit_revocation_added(key_id, chash, reason): i64 {
    var e = audit_event_new(AUDIT_REVOCATION_ADDED);
    ae_set_key_id(e, key_id);
    ae_set_content_hash(e, chash);
    return e;
}

fn audit_key_rotated(old_kid, new_kid): i64 {
    var e = audit_event_new(AUDIT_KEY_ROTATED);
    ae_set_key_id(e, old_kid);
    ae_set_content_hash(e, new_kid);  # reuse field for new key id
    return e;
}

# ================================================================
# AuditLog (8 bytes)
# ================================================================
# Layout:
#   +0   events  (vec of AuditEvent ptrs)

fn audit_log_new(): i64 {
    var log = fl_alloc(8);
    store64(log, vec_new());
    return log;
}

fn alog_record(log, event): i64 {
    vec_push(load64(log), event);
    return log;
}

fn alog_events(log): i64 { return load64(log); }
fn alog_len(log): i64 { return vec_len(load64(log)); }
fn alog_is_empty(log): i64 { if (alog_len(log) == 0) { return 1; } return 0; }

fn alog_clear(log): i64 {
    store64(log, vec_new());
    return log;
}

# Append audit events to file (one JSON line per event).
# Renamed from alog_append_to_file in 3.0 to match the rl_save /
# crl_save / sv_save_trust_store vocabulary. Still O_APPEND under
# the hood — the name reflects the contract (persist to disk),
# not the write mode.
fn alog_save(log, path): i64 {
    var fd = file_open(path, 1089, 420);  # O_WRONLY|O_CREAT|O_APPEND, 0644
    if (fd < 0) { return ERR_IO; }
    var events = load64(log);
    var elen = vec_len(events);
    var i = 0;
    while (i < elen) {
        var e = vec_get(events, i);
        # Simple JSON line: {"type":"...","timestamp":...}
        var line = alloc(512);
        var pos = 0;
        pos = pos + _alog_write_str(line + pos, "{\"type\":\"");
        pos = pos + _alog_write_str(line + pos, audit_event_name(ae_type(e)));
        pos = pos + _alog_write_str(line + pos, "\",\"timestamp\":");
        pos = pos + _alog_write_int(line + pos, ae_timestamp(e));
        if (ae_path(e) != 0) {
            pos = pos + _alog_write_str(line + pos, ",\"path\":\"");
            pos = pos + _alog_write_str(line + pos, ae_path(e));
            pos = pos + _alog_write_str(line + pos, "\"");
        }
        if (ae_key_id(e) != 0) {
            pos = pos + _alog_write_str(line + pos, ",\"key_id\":\"");
            pos = pos + _alog_write_str(line + pos, ae_key_id(e));
            pos = pos + _alog_write_str(line + pos, "\"");
        }
        if (ae_content_hash(e) != 0) {
            pos = pos + _alog_write_str(line + pos, ",\"content_hash\":\"");
            pos = pos + _alog_write_str(line + pos, ae_content_hash(e));
            pos = pos + _alog_write_str(line + pos, "\"");
        }
        if (ae_passed(e) != (0 - 1)) {
            pos = pos + _alog_write_str(line + pos, ",\"passed\":");
            if (ae_passed(e) == 1) { pos = pos + _alog_write_str(line + pos, "true"); }
            else { pos = pos + _alog_write_str(line + pos, "false"); }
        }
        pos = pos + _alog_write_str(line + pos, "}\n");
        store8(line + pos, 0);
        file_write(fd, line, pos);
        i = i + 1;
    }
    file_close(fd);
    return ERR_NONE;
}

fn _alog_write_str(dst, src): i64 {
    var len = strlen(src);
    memcpy(dst, src, len);
    return len;
}

# ================================================================
# alog_load(log, path) — inverse of alog_save. Renamed from
# alog_load_from_file in 3.0.
#
# Reads JSONL (one event per line) from `path`, parses each line
# as a flat JSON object, and pushes an AuditEvent into `log`. Lines
# with an unknown `type` are skipped — forensic replay must not
# abort on an unknown event that a newer writer produced.
#
# Reuses `_rj_parse_string` from policy.cyr (same compilation unit)
# for escape-aware string decoding, matching what
# `json_write_escaped` emitted on the writer side.
#
# Returns the number of events loaded, or -1 on IO failure.
# ================================================================

fn _alog_parse_one_line(log, line, llen): i64 {
    var etype = 0 - 1;
    var apath = 0;
    var kid = 0;
    var chash = 0;
    var passed = 0 - 1;
    var ts = 0;

    var pos = 0;
    while (pos < llen) {
        var c = load8(line + pos) & 0xFF;
        if (c != 34) { pos = pos + 1; }
        else {
            pos = _rj_parse_string(line, pos, llen);
            var k = _rj_out_ptr;
            if (k == 0) { break; }
            # Skip to colon
            while (pos < llen) {
                if ((load8(line + pos) & 0xFF) == 58) { pos = pos + 1; break; }
                pos = pos + 1;
            }
            # Skip whitespace
            while (pos < llen) {
                var ws = load8(line + pos) & 0xFF;
                if (ws == 32) { pos = pos + 1; }
                elif (ws == 9) { pos = pos + 1; }
                else { break; }
            }
            if (pos >= llen) { break; }
            var vc = load8(line + pos) & 0xFF;
            if (vc == 34) {
                pos = _rj_parse_string(line, pos, llen);
                var v = _rj_out_ptr;
                if (streq(k, "type") == 1) { etype = audit_event_type_from_name(v); }
                elif (streq(k, "path") == 1) { apath = v; }
                elif (streq(k, "key_id") == 1) { kid = v; }
                elif (streq(k, "content_hash") == 1) { chash = v; }
            } else {
                # Literal: true / false / number
                var vs = pos;
                while (pos < llen) {
                    var vcc = load8(line + pos) & 0xFF;
                    if (vcc == 44) { break; }
                    if (vcc == 125) { break; }
                    if (vcc == 32) { break; }
                    if (vcc == 10) { break; }
                    pos = pos + 1;
                }
                var vlen = pos - vs;
                if (vlen > 0) {
                    var fb = load8(line + vs) & 0xFF;
                    if (fb == 116) {
                        # "true"
                        if (streq(k, "passed") == 1) { passed = 1; }
                    } elif (fb == 102) {
                        # "false"
                        if (streq(k, "passed") == 1) { passed = 0; }
                    } elif (fb >= 48) {
                        if (fb <= 57) {
                            var intv = 0;
                            var ii = 0;
                            while (ii < vlen) {
                                var ch = load8(line + vs + ii) & 0xFF;
                                if (ch >= 48) { if (ch <= 57) { intv = intv * 10 + (ch - 48); } }
                                ii = ii + 1;
                            }
                            if (streq(k, "timestamp") == 1) { ts = intv; }
                        }
                    }
                }
            }
        }
    }

    if (etype < 0) { return 0; }   # unknown event type; skip

    var e = audit_event_new(etype);
    if (apath != 0) { ae_set_path(e, apath); }
    if (kid != 0) { ae_set_key_id(e, kid); }
    if (chash != 0) { ae_set_content_hash(e, chash); }
    if (passed != (0 - 1)) { ae_set_passed(e, passed); }
    store64(e + 56, ts);    # timestamp
    alog_record(log, e);
    return 1;
}

fn alog_load(log, path): i64 {
    var buf = alloc(65536);
    var n = file_read_all(path, buf, 65536);
    if (n < 0) { return (0 - 1); }
    var loaded = 0;
    var pos = 0;
    while (pos < n) {
        var start = pos;
        while (pos < n) {
            if ((load8(buf + pos) & 0xFF) == 10) { break; }
            pos = pos + 1;
        }
        var llen = pos - start;
        if (llen > 0) {
            if (_alog_parse_one_line(log, buf + start, llen) == 1) {
                loaded = loaded + 1;
            }
        }
        if (pos < n) { pos = pos + 1; }   # skip '\n'
    }
    return loaded;
}

# Global to survive nested calls
var _alog_int_buf = 0;

fn _alog_write_int(dst, val): i64 {
    if (_alog_int_buf == 0) { _alog_int_buf = alloc(24); }
    # Manual int-to-string into global buffer
    var v = val;
    var pos = 23;
    store8(_alog_int_buf + pos, 0);
    pos = pos - 1;
    if (v == 0) {
        store8(_alog_int_buf + pos, 48);
        pos = pos - 1;
    } else {
        while (v > 0) {
            store8(_alog_int_buf + pos, 48 + (v % 10));
            v = v / 10;
            pos = pos - 1;
        }
    }
    pos = pos + 1;
    var len = 23 - pos;
    memcpy(dst, _alog_int_buf + pos, len);
    return len;
}

# --- verify.cyr ---

# verify.cyr — SigilVerifier: the main trust engine
# Combines signing, keyring, integrity, revocation, key pinning, audit.

# ================================================================
# VerifyScratch (3.2.0) — pre-allocated per-worker scratch
# ================================================================
# Lifts every allocation out of the verify hot path so the parallel
# `sv_verify_batch` workers can fan out without touching the bump
# allocator / freelist / vec-grow paths (CLAUDE.md quirk #7 —
# alloc, vec, hashmap are NOT thread-safe under cyrius). All
# per-artifact state lives in one 768-byte block; workers receive
# their slot and reset state via `_verify_scratch_reset` per call.
#
# Layout:
#   +0    hash_buf[72]        SHA-256 hex digest (64 chars + NUL + 7 pad)
#   +72   pk_bytes[40]        Ed25519 decoded public key (32 + 8 pad)
#   +112  artifact[48]        TrustedArtifact inline
#   +160  vr_slot[32]         VerificationResult inline
#   +192  checks_pool[192]    8 × 24 TrustCheck slots
#   +384  check_idx (8)       next free check slot
#   +392  vec_hdr (24)        vec struct { data, len=0, cap=16 }
#   +416  vec_data[128]       16 × i64 (pre-allocated cap, never grows)
#   +544  sha256_ctx[144]     SHA-256 streaming context
#   +688  reserved/pad to 768
#
# Cap of 8 TrustCheck slots: `sv_verify_artifact` today emits up
# to 7 checks per call (file_readable, trust_store, signature,
# revocation, key_pin, allowed_type, policy). 8 slots gives one
# slot of headroom for future check additions; past 8 the slot-
# overflow guard pins `vr.passed = 0` and skips the vec_push
# rather than corrupting adjacent scratch memory.

var _VSC_HASH       = 0;
var _VSC_PK         = 72;
var _VSC_ARTIFACT   = 112;
var _VSC_VR         = 160;
var _VSC_CHECKS     = 192;
var _VSC_CHECK_IDX  = 384;
var _VSC_VEC_HDR    = 392;
var _VSC_VEC_DATA   = 416;
var _VSC_SHA_CTX    = 544;
var _VSC_SIZE       = 768;
var _VSC_MAX_CHECKS = 8;

fn verify_scratch_new(): i64 {
    var s = fl_alloc(_VSC_SIZE);
    # Wire the inline vec_hdr to the inline vec_data.
    store64(s + _VSC_VEC_HDR + 0, s + _VSC_VEC_DATA);   # data ptr
    store64(s + _VSC_VEC_HDR + 8, 0);                    # len
    store64(s + _VSC_VEC_HDR + 16, 16);                  # cap (fixed)
    return s;
}

fn _verify_scratch_reset(s): i64 {
    store64(s + _VSC_CHECK_IDX, 0);
    store64(s + _VSC_VEC_HDR + 8, 0);   # vec.len = 0
    return 0;
}

# Acquire the next TrustCheck slot from the pool and write the 3
# fields in-place. Returns the slot pointer (24-byte block, same
# shape as `trust_check_new`'s output). On overflow (more than
# `_VSC_MAX_CHECKS` calls per artifact), pins the caller's
# verification_result to passed=0 and returns 0; the caller's
# `_vresult_add_check_scratch` short-circuits on a 0 slot so the
# `vec_push` is skipped — no scratch corruption.
fn _trust_check_slot(s, name, passed, detail): i64 {
    var idx = load64(s + _VSC_CHECK_IDX);
    if (idx >= _VSC_MAX_CHECKS) {
        # Slot overflow — pin vr.passed to 0 as a degraded-result
        # indicator. Real fix is to grow `_VSC_MAX_CHECKS`; this
        # branch should never fire under the existing 7-check
        # ceiling but exists so a future check addition can't
        # corrupt adjacent scratch memory.
        store64(s + _VSC_VR + 8, 0);
        return 0;
    }
    var slot = s + _VSC_CHECKS + idx * 24;
    store64(slot + 0, name);
    store64(slot + 8, passed);
    store64(slot + 16, detail);
    store64(s + _VSC_CHECK_IDX, idx + 1);
    return slot;
}

# Scratch-side equivalent of `vresult_add_check(vr, trust_check_new(...))`.
# Skips the vec_push if `_trust_check_slot` returned 0 (overflow).
fn _vresult_add_check_scratch(s, name, passed, detail): i64 {
    var slot = _trust_check_slot(s, name, passed, detail);
    if (slot != 0) {
        # vec_push into the pre-allocated cap-16 vec — guaranteed
        # not to grow (we cap usage at _VSC_MAX_CHECKS=6 < 16), so
        # this never touches the allocator.
        vec_push(s + _VSC_VEC_HDR, slot);
    }
    return 0;
}

# ================================================================
# KeyPin (16 bytes)
# ================================================================
# Layout:
#   +0   key_id       (C-string ptr)
#   +8   path_prefix  (C-string ptr)

fn key_pin_new(key_id, path_prefix): i64 {
    var kp = fl_alloc(16);
    store64(kp, key_id);
    store64(kp + 8, path_prefix);
    return kp;
}

fn kpin_key_id(kp): i64 { return load64(kp); }
fn kpin_prefix(kp): i64 { return load64(kp + 8); }

# ================================================================
# ComplianceReport (56 bytes)
# ================================================================
# Layout:
#   +0   total            (i64)
#   +8   compliant_count  (i64)
#   +16  compliant        (vec)
#   +24  below_minimum    (vec)
#   +32  unsigned_list    (vec)
#   +40  revoked_list     (vec)
#   +48  pin_violations   (vec)

fn compliance_report_new(): i64 {
    var cr = fl_alloc(56);
    store64(cr, 0);
    store64(cr + 8, 0);
    store64(cr + 16, vec_new());
    store64(cr + 24, vec_new());
    store64(cr + 32, vec_new());
    store64(cr + 40, vec_new());
    store64(cr + 48, vec_new());
    return cr;
}

fn creport_total(cr): i64 { return load64(cr); }
fn creport_compliant_count(cr): i64 { return load64(cr + 8); }
fn creport_is_compliant(cr): i64 {
    if (load64(cr + 8) == load64(cr)) { return 1; }
    return 0;
}
fn creport_violation_count(cr): i64 {
    return load64(cr) - load64(cr + 8);
}

# ================================================================
# SigilVerifier (56 bytes)
# ================================================================
# Layout:
#   +0   keyring       (PublisherKeyring ptr)
#   +8   policy        (TrustPolicy ptr)
#   +16  revocations   (RevocationList ptr)
#   +24  integrity     (IntegrityVerifier ptr)
#   +32  trust_store   (hashmap: content_hash -> TrustedArtifact)
#   +40  key_pins      (vec of KeyPin)
#   +48  audit_log     (AuditLog ptr)

fn sigil_verifier_new(keyring, policy): i64 {
    var sv = fl_alloc(56);
    store64(sv, keyring);
    store64(sv + 8, policy);
    store64(sv + 16, revocation_list_new());
    store64(sv + 24, integrity_verifier_new(integrity_policy_new()));
    store64(sv + 32, map_new());
    store64(sv + 40, vec_new());
    store64(sv + 48, audit_log_new());
    return sv;
}

fn sv_keyring(sv): i64 { return load64(sv); }
fn sv_policy(sv): i64 { return load64(sv + 8); }
fn sv_revocations(sv): i64 { return load64(sv + 16); }
fn sv_integrity(sv): i64 { return load64(sv + 24); }
fn sv_trust_store(sv): i64 { return load64(sv + 32); }
fn sv_key_pins(sv): i64 { return load64(sv + 40); }
fn sv_audit_log(sv): i64 { return load64(sv + 48); }

# ================================================================
# Key pin management
# ================================================================

fn sv_add_key_pin(sv, pin): i64 {
    vec_push(load64(sv + 40), pin);
    return sv;
}

fn sv_remove_key_pins(sv, path_prefix): i64 {
    var pins = load64(sv + 40);
    var plen = vec_len(pins);
    var removed = 0;
    var i = plen - 1;
    while (i >= 0) {
        var pin = vec_get(pins, i);
        if (streq(kpin_prefix(pin), path_prefix) == 1) {
            vec_remove(pins, i);
            removed = removed + 1;
        }
        i = i - 1;
    }
    return removed;
}

# Check if key is authorized for path (no pin = any key OK)
fn _sv_key_authorized(sv, path, signer_key_id): i64 {
    var pins = load64(sv + 40);
    var plen = vec_len(pins);
    var has_matching_pin = 0;
    var path_len = 0;
    if (path != 0) { path_len = strlen(path); }
    var i = 0;
    while (i < plen) {
        var pin = vec_get(pins, i);
        var prefix = kpin_prefix(pin);
        var plen2 = strlen(prefix);
        # Guard against OOB read: memeq reads plen2 bytes from path,
        # so path must be at least that long.
        if (path_len >= plen2) {
            if (memeq(path, prefix, plen2) == 1) {
                has_matching_pin = 1;
                if (signer_key_id != 0) {
                    if (streq(kpin_key_id(pin), signer_key_id) == 1) {
                        return 1;
                    }
                }
            }
        }
        i = i + 1;
    }
    if (has_matching_pin == 0) { return 1; }
    return 0;
}

# ================================================================
# Register artifacts in trust store
# ================================================================

fn sv_register_trusted(sv, artifact): i64 {
    # Downgrade SystemCore to Verified (only register_system_core allows SystemCore)
    if (artifact_trust_level(artifact) == TRUST_SYSTEM_CORE) {
        artifact_set_trust_level(artifact, TRUST_VERIFIED);
    }
    var chash = artifact_content_hash(artifact);
    map_set(load64(sv + 32), chash, artifact);
    return sv;
}

fn sv_register_system_core(sv, artifact): i64 {
    artifact_set_trust_level(artifact, TRUST_SYSTEM_CORE);
    var chash = artifact_content_hash(artifact);
    map_set(load64(sv + 32), chash, artifact);
    return sv;
}

# ================================================================
# Sign an artifact and register it
# ================================================================

fn sv_sign_artifact(sv, path, secret_key, key_id, artifact_type): i64 {
    var chash = hash_file(path);
    if (chash == 0) { return 0; }

    var sig = sign_data(chash, strlen(chash), secret_key);
    var artifact = trusted_artifact_new(path, artifact_type, chash);
    artifact_set_signature(artifact, sig);
    artifact_set_signer(artifact, key_id);
    artifact_set_trust_level(artifact, TRUST_VERIFIED);

    map_set(load64(sv + 32), chash, artifact);

    # Audit
    var ae = audit_artifact_signed(path, artifact_type, key_id, chash);
    alog_record(load64(sv + 48), ae);

    return artifact;
}

# ================================================================
# Verify an artifact
# ================================================================

# Public API (3.2.0): thin wrapper that allocates a fresh
# VerifyScratch and delegates to `sv_verify_artifact_into`. Same
# return contract as the pre-3.2.0 path (vr ptr, caller does not
# free), but the internal hot path no longer paths through
# `fl_alloc(24)` × ~6, `fl_alloc(48)`, `fl_alloc(32)`, `vec_new()`,
# `alloc(65)`, `alloc(32)` per call — those all land in the
# single 768-byte scratch instead. The new `_into` variant is
# the canonical implementation; this wrapper is for downstream
# code that wants a one-shot "verify and forget the scratch" API.
#
# **Deprecation note (4.0 target):** the heap-allocating
# `verification_result_new` / `trusted_artifact_new` /
# `trust_check_new` constructors will be removed in 4.0 in favour
# of in-place scratch-slot writes. Downstream code that currently
# constructs `TrustCheck` / `TrustedArtifact` / `VerificationResult`
# directly should migrate to the `_init`-into-slot pattern. See
# `docs/development/roadmap.md` § "Towards v4.0".
fn sv_verify_artifact(sv, path, artifact_type): i64 {
    var s = verify_scratch_new();
    var vr = sv_verify_artifact_into(sv, path, artifact_type, s);
    # Audit lives on the wrapper so `_into` stays alloc-free for
    # the parallel-batch path. Single-threaded callers (this one)
    # incur no contention.
    var a = vresult_artifact(vr);
    var ae = audit_artifact_verified(path, artifact_type,
                                     artifact_trust_level(a),
                                     vresult_passed(vr),
                                     artifact_content_hash(a));
    alog_record(load64(sv + 48), ae);
    return vr;
}

# Alloc-free verify orchestrator (3.2.0). Runs the full check
# chain (file_readable, trust_store, signature, revocation,
# key_pin, allowed_type, policy) writing every intermediate
# struct into the caller-provided `scratch` block (see
# VerifyScratch layout above). Returns a pointer to the populated
# `verification_result` slot (scratch + _VSC_VR); same accessor
# contract as the heap-allocated vr from the pre-3.2.0 path.
#
# Thread-safety: the body does not touch `alloc`, `fl_alloc`,
# `vec_new`, or `vec` grow paths. It reads `map_get(trust_store)`,
# which is safe under concurrent fan-out if and only if the trust
# store is not mutated during the batch — `sv_verify_batch`
# documents and relies on that contract.
fn sv_verify_artifact_into(sv, path, artifact_type, scratch): i64 {
    _verify_scratch_reset(scratch);
    var policy = load64(sv + 8);

    # 1. Hash the file directly into the scratch hex slot.
    var hash_ok = hash_file_into(path, scratch + _VSC_HASH, scratch + _VSC_SHA_CTX);
    if (hash_ok == 0) {
        # File unreadable — build a minimal vr in scratch with
        # empty content hash and passed=0. Mirrors the pre-3.2.0
        # error-path shape so callers see the same struct surface.
        store64(scratch + _VSC_ARTIFACT + 0,  path);
        store64(scratch + _VSC_ARTIFACT + 8,  artifact_type);
        store64(scratch + _VSC_ARTIFACT + 16, "");
        store64(scratch + _VSC_ARTIFACT + 24, 0);
        store64(scratch + _VSC_ARTIFACT + 32, 0);
        store64(scratch + _VSC_ARTIFACT + 40, TRUST_UNVERIFIED);
        store64(scratch + _VSC_VR + 0,  scratch + _VSC_ARTIFACT);
        store64(scratch + _VSC_VR + 8,  0);
        store64(scratch + _VSC_VR + 16, scratch + _VSC_VEC_HDR);
        store64(scratch + _VSC_VR + 24, clock_epoch_secs());
        return scratch + _VSC_VR;
    }
    var chash = scratch + _VSC_HASH;   # 64-char hex C-string + NUL

    var trust_level = TRUST_UNVERIFIED;

    # 2. Build TrustedArtifact in-place.
    store64(scratch + _VSC_ARTIFACT + 0,  path);
    store64(scratch + _VSC_ARTIFACT + 8,  artifact_type);
    store64(scratch + _VSC_ARTIFACT + 16, chash);
    store64(scratch + _VSC_ARTIFACT + 24, 0);
    store64(scratch + _VSC_ARTIFACT + 32, 0);
    store64(scratch + _VSC_ARTIFACT + 40, TRUST_UNVERIFIED);

    # 3. Build VerificationResult in-place. checks field points at
    #    the inline cap-16 vec_hdr — vec_push never grows it.
    store64(scratch + _VSC_VR + 0,  scratch + _VSC_ARTIFACT);
    store64(scratch + _VSC_VR + 8,  1);
    store64(scratch + _VSC_VR + 16, scratch + _VSC_VEC_HDR);
    store64(scratch + _VSC_VR + 24, clock_epoch_secs());
    var vr = scratch + _VSC_VR;

    # Check: file readable
    _vresult_add_check_scratch(scratch, "file_readable", 1, "File read successfully");

    # Check: trust store lookup. `map_get` is read-only — concurrent
    # workers in `sv_verify_batch` rely on the documented contract
    # that no thread calls `map_set` on the trust store during a
    # batch. Safe for the open-addressing scan; mutation would
    # corrupt slots mid-probe.
    var store = load64(sv + 32);
    var stored = map_get(store, chash);
    if (stored != 0) {
        trust_level = artifact_trust_level(stored);
        _vresult_add_check_scratch(scratch, "trust_store", 1, "Found in trust store");
    } else {
        _vresult_add_check_scratch(scratch, "trust_store", 0, "Not in trust store");
    }

    # Check: signature verification
    if (stored != 0) {
        var sig = artifact_signature(stored);
        var signer = artifact_signer_key_id(stored);
        if (sig != 0) {
            if (signer != 0) {
                var kr = load64(sv);
                var kv = keyring_get_current(kr, signer);
                if (kv != 0) {
                    var pk = kv_public_key_hex(kv);
                    if (pk != 0) {
                        if (strlen(pk) != 64) {
                            trust_level = TRUST_UNVERIFIED;
                            _vresult_add_check_scratch(scratch, "signature", 0, "Public key hex wrong length");
                        } else {
                            # Decode pk hex into the scratch pk_bytes slot (no alloc).
                            var pk_ok = hex_decode_into(pk, 64, scratch + _VSC_PK);
                            if (pk_ok == 0) {
                                trust_level = TRUST_UNVERIFIED;
                                _vresult_add_check_scratch(scratch, "signature", 0, "Public key hex invalid");
                            } else {
                                var valid = verify_data(chash, strlen(chash), sig, scratch + _VSC_PK);
                                if (valid == 1) {
                                    if (trust_level_rank(trust_level) < trust_level_rank(TRUST_VERIFIED)) {
                                        trust_level = TRUST_VERIFIED;
                                    }
                                    _vresult_add_check_scratch(scratch, "signature", 1, "Signature valid");
                                } else {
                                    trust_level = TRUST_UNVERIFIED;
                                    _vresult_add_check_scratch(scratch, "signature", 0, "Signature invalid");
                                }
                            }
                        }
                    } else {
                        _vresult_add_check_scratch(scratch, "signature", 0, "No public key for verification");
                    }
                } else {
                    _vresult_add_check_scratch(scratch, "signature", 0, "Signer key not in keyring");
                }
            } else {
                _vresult_add_check_scratch(scratch, "signature", 0, "No signer key ID");
            }
        } else {
            _vresult_add_check_scratch(scratch, "signature", 0, "No signature");
        }
    } else {
        _vresult_add_check_scratch(scratch, "signature", 0, "Not in trust store");
    }

    # Check: revocation
    var rl = load64(sv + 16);
    var key_revoked = 0;
    var hash_revoked = rl_is_artifact_revoked(rl, chash);
    if (stored != 0) {
        var signer_r = artifact_signer_key_id(stored);
        if (signer_r != 0) {
            key_revoked = rl_is_key_revoked(rl, signer_r);
        }
    }
    if (key_revoked == 1) {
        trust_level = TRUST_REVOKED;
        _vresult_add_check_scratch(scratch, "revocation", 0, "Signer key revoked");
    } elif (hash_revoked == 1) {
        trust_level = TRUST_REVOKED;
        _vresult_add_check_scratch(scratch, "revocation", 0, "Content hash revoked");
    } else {
        _vresult_add_check_scratch(scratch, "revocation", 1, "Not revoked");
    }

    # Check: key pinning
    if (stored != 0) {
        var signer_p = artifact_signer_key_id(stored);
        var authorized = _sv_key_authorized(sv, path, signer_p);
        if (authorized == 1) {
            _vresult_add_check_scratch(scratch, "key_pin", 1, "Key authorized");
        } else {
            _vresult_add_check_scratch(scratch, "key_pin", 0, "Key not authorized for path");
            trust_level = TRUST_UNVERIFIED;
        }
    }

    # Check: allowed-artifact-type
    if (stored != 0) {
        var signer_atype = artifact_signer_key_id(stored);
        if (signer_atype != 0) {
            var kra = load64(sv);
            var kva = keyring_get_current(kra, signer_atype);
            if (kva != 0) {
                if (kv_is_type_allowed(kva, artifact_type) == 1) {
                    _vresult_add_check_scratch(scratch, "allowed_type", 1, "Key authorized for artifact type");
                } else {
                    _vresult_add_check_scratch(scratch, "allowed_type", 0, "Key not authorized for artifact type");
                    trust_level = TRUST_UNVERIFIED;
                }
            }
        }
    }

    # Check: policy compliance
    var min_trust = policy_min_trust(policy);
    var enforcement = policy_enforcement(policy);
    var meets_min = trust_level_ge(trust_level, min_trust);
    if (meets_min == 1) {
        _vresult_add_check_scratch(scratch, "policy", 1, "Meets minimum trust level");
    } else {
        if (enforcement == ENFORCE_STRICT) {
            _vresult_add_check_scratch(scratch, "policy", 0, "Below minimum trust level");
            vresult_set_passed(vr, 0);
        } elif (enforcement == ENFORCE_PERMISSIVE) {
            _vresult_add_check_scratch(scratch, "policy", 0, "Below minimum (permissive)");
        } else {
            _vresult_add_check_scratch(scratch, "policy", 0, "Below minimum (audit only)");
        }
    }

    artifact_set_trust_level(scratch + _VSC_ARTIFACT, trust_level);

    # NOTE: audit is intentionally NOT emitted here. The 3.2.0
    # alloc-free contract requires zero allocator activity in the
    # worker body. `audit_artifact_verified` allocates the event
    # struct + `alog_record` may grow the audit log's vec — both
    # would race against concurrent workers. Audit is emitted by
    # the caller:
    #   - `sv_verify_artifact` (wrapper) runs audit after `_into`
    #     returns, on the same thread, no contention.
    #   - `sv_verify_batch` runs audit on the main thread after
    #     `thread_join`, serially walking the result slots.
    return vr;
}

# ================================================================
# Convenience: verify agent binary
# ================================================================

fn sv_verify_agent(sv, path): i64 {
    var policy = load64(sv + 8);
    var vr = sv_verify_artifact(sv, path, ARTIFACT_AGENT_BINARY);

    # Additional check: unsigned agents
    if (policy_allow_unsigned(policy) == 0) {
        var checks = vresult_checks(vr);
        var clen = vec_len(checks);
        var has_sig = 0;
        var i = 0;
        while (i < clen) {
            var tc = vec_get(checks, i);
            if (streq(check_name(tc), "signature") == 1) {
                if (check_passed(tc) == 1) { has_sig = 1; }
            }
            i = i + 1;
        }
        if (has_sig == 0) {
            vresult_add_check(vr, trust_check_new("unsigned_agent", 0, "Unsigned agents not allowed"));
            vresult_set_passed(vr, 0);
        }
    }
    return vr;
}

# ================================================================
# sv_verify_package(sv, path, expected_hash)
#
# Package-specific verification path. Calls sv_verify_artifact with
# ARTIFACT_PACKAGE, then — if `expected_hash` is non-zero — layers
# a constant-time content-hash match. A hash mismatch marks the
# whole result as failed. Mirrors the Rust `verify_package(path,
# Option<expected_hash>)` signature (pass 0 as expected_hash for
# "no expected hash").
#
# The Rust version had an early-exit when policy.verify_on_install
# was false; that gate is no longer needed — verify_on_install has
# been a user-set policy knob for several releases and consumers
# (argonaut/ark) enforce it themselves before calling in.
# ================================================================

fn sv_verify_package(sv, path, expected_hash): i64 {
    var vr = sv_verify_artifact(sv, path, ARTIFACT_PACKAGE);
    if (expected_hash == 0) { return vr; }

    var artifact = vresult_artifact(vr);
    var actual = artifact_content_hash(artifact);
    var matches = 0;
    if (actual != 0) {
        if (ct_eq_bytes_lens(actual, strlen(actual), expected_hash, strlen(expected_hash)) == 1) {
            matches = 1;
        }
    }
    if (matches == 1) {
        vresult_add_check(vr, trust_check_new("expected_hash", 1, "Content hash matches expected"));
    } else {
        vresult_add_check(vr, trust_check_new("expected_hash", 0, "Hash mismatch"));
        vresult_set_passed(vr, 0);
    }
    return vr;
}

# ================================================================
# Revocation management
# ================================================================

fn sv_add_revocation(sv, entry): i64 {
    var rl = load64(sv + 16);
    var result = rl_add(rl, entry);
    if (result == ERR_NONE) {
        var ae = audit_revocation_added(rev_key_id(entry), rev_content_hash(entry), rev_reason(entry));
        alog_record(load64(sv + 48), ae);
    }
    return result;
}

fn sv_check_revocation(sv, key_id, content_hash): i64 {
    var rl = load64(sv + 16);
    if (key_id != 0) {
        if (rl_is_key_revoked(rl, key_id) == 1) { return 1; }
    }
    if (content_hash != 0) {
        if (rl_is_artifact_revoked(rl, content_hash) == 1) { return 1; }
    }
    return 0;
}

fn sv_revocation_count(sv): i64 {
    return rl_len(load64(sv + 16));
}

# ================================================================
# Trust store queries
# ================================================================

fn sv_trust_level_for(sv, content_hash): i64 {
    var store = load64(sv + 32);
    var artifact = map_get(store, content_hash);
    if (artifact == 0) { return TRUST_UNVERIFIED; }
    return artifact_trust_level(artifact);
}

fn sv_stats(sv): i64 {
    var store = load64(sv + 32);
    var s = sigil_stats_new();
    var keys = map_keys(store);
    var total = vec_len(keys);
    store64(s, total);
    var verified = 0;
    var revoked = 0;
    var i = 0;
    while (i < total) {
        var chash = vec_get(keys, i);
        var artifact = map_get(store, chash);
        var tl = artifact_trust_level(artifact);
        if (trust_level_ge(tl, TRUST_VERIFIED) == 1) { verified = verified + 1; }
        if (tl == TRUST_REVOKED) { revoked = revoked + 1; }
        i = i + 1;
    }
    store64(s + 8, verified);
    store64(s + 16, revoked);
    return s;
}

# ================================================================
# Boot chain verification
# ================================================================

# ================================================================
# Compliance report
# ================================================================

fn sv_compliance_report(sv): i64 {
    var cr = compliance_report_new();
    var store = load64(sv + 32);
    var policy = load64(sv + 8);
    var min_trust = policy_min_trust(policy);
    var keys = map_keys(store);
    var total = vec_len(keys);
    store64(cr, total);

    var compliant = 0;
    var i = 0;
    while (i < total) {
        var chash = vec_get(keys, i);
        var artifact = map_get(store, chash);
        var tl = artifact_trust_level(artifact);
        var path = artifact_path(artifact);

        if (tl == TRUST_REVOKED) {
            vec_push(load64(cr + 40), artifact);
        } elif (trust_level_ge(tl, min_trust) == 0) {
            vec_push(load64(cr + 24), artifact);
        } else {
            # Check key pin
            var signer = artifact_signer_key_id(artifact);
            if (_sv_key_authorized(sv, path, signer) == 0) {
                vec_push(load64(cr + 48), artifact);
            } else {
                if (artifact_signature(artifact) == 0) {
                    if (policy_allow_unsigned(policy) == 0) {
                        vec_push(load64(cr + 32), artifact);
                    } else {
                        vec_push(load64(cr + 16), artifact);
                        compliant = compliant + 1;
                    }
                } else {
                    vec_push(load64(cr + 16), artifact);
                    compliant = compliant + 1;
                }
            }
        }
        i = i + 1;
    }
    store64(cr + 8, compliant);
    return cr;
}

# ================================================================
# Trust store snapshot and diff
# ================================================================

# Snapshot entry (16 bytes): trust-level + path frozen at snapshot time.
# Previously the snapshot mapped chash → artifact_ptr, but since the
# same pointer was still mutable in the live store, a trust-level
# change was invisible to a subsequent diff. Snapshotting a level
# plus path byvalue gives a real before/after view.

fn _snap_entry_new(trust_level, path): i64 {
    var se = fl_alloc(16);
    store64(se, trust_level);
    store64(se + 8, path);
    return se;
}

fn snap_entry_trust_level(se): i64 { return load64(se); }
fn snap_entry_path(se): i64 { return load64(se + 8); }

fn sv_snapshot_trust_store(sv): i64 {
    var store = load64(sv + 32);
    var keys = map_keys(store);
    var snap = map_new();
    var klen = vec_len(keys);
    var i = 0;
    while (i < klen) {
        var chash = vec_get(keys, i);
        var artifact = map_get(store, chash);
        map_set(snap, chash, _snap_entry_new(
        artifact_trust_level(artifact),
        artifact_path(artifact)
        ));
        i = i + 1;
    }
    return snap;
}

# ================================================================
# ArtifactChange (32 bytes) — Rust-style diff record
# ================================================================
# Layout:
#   +0   content_hash  (C-string ptr)
#   +8   path          (C-string ptr)
#   +16  old_trust_level (i64; -1 = none / this is a newly added artifact)
#   +24  new_trust_level (i64; -1 = none / this artifact was removed)
#
# For a "changed" record, both old and new are set and differ.
# For "added", old = -1. For "removed", new = -1.

fn artifact_change_new(content_hash, path, old_tl, new_tl): i64 {
    var ac = fl_alloc(32);
    store64(ac, content_hash);
    store64(ac + 8, path);
    store64(ac + 16, old_tl);
    store64(ac + 24, new_tl);
    return ac;
}

fn ac_content_hash(ac): i64 { return load64(ac); }
fn ac_path(ac): i64 { return load64(ac + 8); }
fn ac_old_trust_level(ac): i64 { return load64(ac + 16); }
fn ac_new_trust_level(ac): i64 { return load64(ac + 24); }

# TrustStoreDiff (24 bytes): added, removed, changed (all vecs of ArtifactChange ptrs).
# BREAKING vs 2.4.x: vecs previously held raw TrustedArtifact pointers;
# they now hold ArtifactChange records so callers can see both sides
# of a trust-level transition, not just the current side.
fn trust_store_diff_new(): i64 {
    var d = fl_alloc(24);
    store64(d, vec_new());     # added   (ArtifactChange where old_tl = -1)
    store64(d + 8, vec_new()); # removed (ArtifactChange where new_tl = -1)
    store64(d + 16, vec_new()); # changed (both sides set, old != new)
    return d;
}

fn tsdiff_added(d): i64 { return load64(d); }
fn tsdiff_removed(d): i64 { return load64(d + 8); }
fn tsdiff_changed(d): i64 { return load64(d + 16); }
fn tsdiff_is_empty(d): i64 {
    if (vec_len(load64(d)) == 0) {
        if (vec_len(load64(d + 8)) == 0) {
            if (vec_len(load64(d + 16)) == 0) { return 1; }
        }
    }
    return 0;
}

fn sv_diff_trust_store(sv, old_snap): i64 {
    var diff = trust_store_diff_new();
    var store = load64(sv + 32);
    var current_keys = map_keys(store);
    var old_keys = map_keys(old_snap);

    # Find added and changed
    var cklen = vec_len(current_keys);
    var i = 0;
    while (i < cklen) {
        var chash = vec_get(current_keys, i);
        var old_snap_entry = map_get(old_snap, chash);
        var new_art = map_get(store, chash);
        if (old_snap_entry == 0) {
            var ac = artifact_change_new(
            chash,
            artifact_path(new_art),
            0 - 1,
            artifact_trust_level(new_art)
            );
            vec_push(load64(diff), ac);
        } else {
            var old_tl = snap_entry_trust_level(old_snap_entry);
            var new_tl = artifact_trust_level(new_art);
            if (old_tl != new_tl) {
                var ac = artifact_change_new(
                chash,
                artifact_path(new_art),
                old_tl,
                new_tl
                );
                vec_push(load64(diff + 16), ac);
            }
        }
        i = i + 1;
    }

    # Find removed
    var oklen = vec_len(old_keys);
    i = 0;
    while (i < oklen) {
        var chash = vec_get(old_keys, i);
        if (map_get(store, chash) == 0) {
            var old_snap_entry = map_get(old_snap, chash);
            var ac = artifact_change_new(
            chash,
            snap_entry_path(old_snap_entry),
            snap_entry_trust_level(old_snap_entry),
            0 - 1
            );
            vec_push(load64(diff + 8), ac);
        }
        i = i + 1;
    }
    return diff;
}

# ================================================================
# Trust store persistence
# ================================================================

# ================================================================
# sv_load_trust_store(sv, path) — inverse of sv_save_trust_store
#
# Reads the JSON array written by sv_save_trust_store and installs
# every {hash, path, type, trust} record into the verifier's trust
# store. Returns the number of artifacts loaded, or 0 on IO/parse
# failure.
#
# Signatures and signer_key_id are NOT persisted by the save path —
# the serialized form is an inventory of trusted artifacts, not a
# re-verifiable archive. Loaded artifacts come back with signature
# = 0, signer = 0, trust level preserved. A subsequent
# sv_verify_artifact call will treat them as present-but-unsigned.
#
# `_rj_parse_string` is reused from policy.cyr — same compilation
# unit, handles the same escape set (\" \\ \n \r \t \b \f \u00XX)
# as json_write_escaped in trust.cyr.
# ================================================================

fn sv_load_trust_store(sv, path): i64 {
    var buf = alloc(65536);
    var n = file_read_all(path, buf, 65536);
    if (n <= 0) { return 0; }
    var store = load64(sv + 32);

    var pos = 0;
    # Skip to first '{'
    while (pos < n) {
        if ((load8(buf + pos) & 0xFF) == 123) { break; }
        pos = pos + 1;
    }

    var loaded = 0;
    while (pos < n) {
        if ((load8(buf + pos) & 0xFF) != 123) { break; }
        pos = pos + 1;

        var hash = 0;
        var apath = 0;
        var atype = ARTIFACT_AGENT_BINARY;   # default; overwritten when the JSON object provides "type"
        var trust = TRUST_UNVERIFIED;

        while (pos < n) {
            var c = load8(buf + pos) & 0xFF;
            if (c == 125) { pos = pos + 1; break; }
            if (c != 34) { pos = pos + 1; }
            else {
                pos = _rj_parse_string(buf, pos, n);
                var k = _rj_out_ptr;
                if (k == 0) { break; }
                # Skip to colon
                while (pos < n) {
                    if ((load8(buf + pos) & 0xFF) == 58) { pos = pos + 1; break; }
                    pos = pos + 1;
                }
                # Skip whitespace
                while (pos < n) {
                    var ws = load8(buf + pos) & 0xFF;
                    if (ws == 32) { pos = pos + 1; }
                    elif (ws == 9) { pos = pos + 1; }
                    else { break; }
                }
                if (pos >= n) { break; }
                var vc = load8(buf + pos) & 0xFF;
                if (vc == 34) {
                    pos = _rj_parse_string(buf, pos, n);
                    var v = _rj_out_ptr;
                    if (streq(k, "hash") == 1) { hash = v; }
                    elif (streq(k, "path") == 1) { apath = v; }
                } else {
                    var vs = pos;
                    while (pos < n) {
                        var vcc = load8(buf + pos) & 0xFF;
                        if (vcc == 44) { break; }
                        if (vcc == 125) { break; }
                        if (vcc == 32) { break; }
                        pos = pos + 1;
                    }
                    var vlen = pos - vs;
                    var intv = 0;
                    var ii = 0;
                    while (ii < vlen) {
                        var ch = load8(buf + vs + ii) & 0xFF;
                        if (ch >= 48) { if (ch <= 57) { intv = intv * 10 + (ch - 48); } }
                        ii = ii + 1;
                    }
                    if (streq(k, "type") == 1) { atype = intv; }
                    elif (streq(k, "trust") == 1) { trust = intv; }
                }
            }
        }

        if (hash != 0) {
            var art = trusted_artifact_new(apath, atype, hash);
            artifact_set_trust_level(art, trust);
            map_set(store, hash, art);
            loaded = loaded + 1;
        }

        # Scan to next '{' or ']'
        while (pos < n) {
            var c2 = load8(buf + pos) & 0xFF;
            if (c2 == 123) { break; }
            if (c2 == 93) { break; }
            pos = pos + 1;
        }
        if (pos < n) {
            if ((load8(buf + pos) & 0xFF) == 93) { break; }
        }
    }
    return loaded;
}

fn sv_save_trust_store(sv, path): i64 {
    var store = load64(sv + 32);
    var keys = map_keys(store);
    var klen = vec_len(keys);
    var fd = file_open(path, 577, 420);
    if (fd < 0) { return ERR_IO; }
    file_write(fd, "[", 1);
    var i = 0;
    var nbuf[24];
    while (i < klen) {
        var chash = vec_get(keys, i);
        var art = map_get(store, chash);
        if (i > 0) { file_write(fd, ",", 1); }
        file_write(fd, "{\"hash\":\"", 9);
        json_write_escaped(fd, chash, strlen(chash));
        file_write(fd, "\",\"path\":\"", 10);
        var ap = artifact_path(art);
        json_write_escaped(fd, ap, strlen(ap));
        file_write(fd, "\",\"type\":", 9);
        # fmt_int prints to stdout — use fmt_int_buf for file output.
        memset(&nbuf, 0, 24);
        var nlen = fmt_int_buf(artifact_type(art), &nbuf);
        file_write(fd, &nbuf, nlen);
        file_write(fd, ",\"trust\":", 9);
        memset(&nbuf, 0, 24);
        nlen = fmt_int_buf(artifact_trust_level(art), &nbuf);
        file_write(fd, &nbuf, nlen);
        file_write(fd, "}", 1);
        i = i + 1;
    }
    file_write(fd, "]", 1);
    file_close(fd);
    return ERR_NONE;
}

# ================================================================
# Batch verification
# ================================================================
# `sv_verify_batch` fans out across `_SIGIL_BATCH_WORKERS` threads
# at `count >= _SIGIL_BATCH_PARALLEL_THRESHOLD`; below the
# threshold it runs serial inline. The 5.5.x-era
# `-D SIGIL_BATCH_PARALLEL` cmdline gate was dropped in 3.0 once
# cyrius 5.5.37 raised the fixup-table cap (quirk #5) — the
# parallel path is now the default and the test +bench files
# (`tests/tcyr/batch_parallel.tcyr`, `tests/bcyr/batch_parallel.bcyr`)
# exercise it without a build flag.
#
# Threading safety contract (mutex-free since 3.6):
# - 3.0 serialised the whole `sv_verify_artifact` call inside a
#   batch mutex because the call chain hit `alloc` / `vec_push` /
#   `fl_alloc` / `vec_new`, none of which are thread-safe under
#   cyrius (CLAUDE.md quirk #7). The mutex covered the dominant
#   `ed25519_verify` + `sha256_transform` work, so the parallel
#   path gave throughput parity with serial — no real speedup.
# - 3.2.0 lifted all per-artifact allocs out of the worker:
#   `sv_verify_artifact_into(sv, path, type, scratch)` runs
#   alloc-free against a pre-allocated `VerifyScratch` pool.
#   Workers do not touch `alloc` / `fl_alloc` / `vec_new` /
#   `vec_grow`. The batch mutex still wrapped each artifact
#   because the crypto modules used module-global working state.
# - 3.3 confirmed (`tests/tcyr/var_array_semantics.tcyr`, cyrius
#   parse_fn.cyr) that **`var X[N]` inside a function is a static
#   function-scope global**, NOT a stack-local (CLAUDE.md quirk
#   #1) — so the crypto primitives' transient working arrays are
#   shared across threads. That was the sole remaining reason for
#   the mutex, and the mutex-drop was deferred until there was a
#   way to give each worker its own working state.
# - 3.6 drops the mutex. cyrius 6.0.52 shipped thread-local storage
#   (lib/thread_local.cyr); src/crypto_scratch.cyr uses it to give
#   each worker a private *bank* (lane) of every racing crypto
#   array (sha256/sha512 schedules, the SHA-NI block scratch, and
#   the Ed25519 field/group/verify temporaries). Each worker calls
#   `crypto_bank_set` once at entry; the primitives slice their
#   working buffers by `cbank()`. ge_identity was also made
#   alloc-free (it called u256_from → alloc). With disjoint banks
#   and no worker-side alloc, the inner verify is data-race-free
#   and runs fully parallel. See src/crypto_scratch.cyr.
# - `map_get` on the trust store is the only worker-side access
#   to a shared container. Safe under the documented contract
#   that no thread calls `map_set` on the trust store during a
#   batch — open-addressing reads are stable on unmutated
#   storage. The integration test populates the store before
#   fan-out and never mutates during; downstream callers must
#   do the same.
# - Audit emission lifts to the main thread post-join.

var _SIGIL_BATCH_PARALLEL_THRESHOLD = 4;
var _SIGIL_BATCH_WORKERS = 4;

# Worker entry (3.2.0 alloc-free). arg is a 48-byte packed record:
#   +0   sv
#   +8   artifacts (packed path/type buffer base)
#   +16  start_idx
#   +24  end_idx
#   +32  result_slots (base of `count * 8` pointer array)
#   +40  scratch_base (base of `count * _VSC_SIZE` scratch pool)
fn _batch_worker(arg): i64 {
    var sv = load64(arg);
    var artifacts = load64(arg + 8);
    var start = load64(arg + 16);
    var end = load64(arg + 24);
    var slots = load64(arg + 32);
    var scratch_base = load64(arg + 40);
    # Per-thread crypto bank (3.6): claim this worker's lane in the
    # banked crypto scratch (src/crypto_scratch.cyr) so sha*/ed25519/
    # fp_* never collide with sibling workers. thread_create's
    # CLONE_SETTLS already installed a zeroed TLS block; we only write
    # the bank index into the slot. This is what lets the inner
    # `sv_verify_artifact_into` run mutex-free.
    crypto_bank_set(load64(arg + 48));
    var i = start;
    while (i < end) {
        var path = load64(artifacts + i * 16);
        var atype = load64(artifacts + i * 16 + 8);
        # Each artifact gets its own scratch slot (indexed by global
        # artifact index, not worker idx). Workers never share
        # scratch, and per-artifact scratches are not reused, so
        # the returned `vr` ptr stays valid for the full batch
        # lifetime — same address-stability contract as the
        # pre-3.2.0 fl_alloc'd vrs.
        var my_scratch = scratch_base + i * _VSC_SIZE;
        var vr = sv_verify_artifact_into(sv, path, atype, my_scratch);
        store64(slots + i * 8, vr);
        i = i + 1;
    }
    return 0;
}

fn sv_verify_batch(sv, artifacts, count): i64 {
    if (count >= _SIGIL_BATCH_PARALLEL_THRESHOLD) {
        # Pre-warm crypto module init on the main thread so the lazy
        # `_*_inited` guards don't race across workers, and any
        # init-time `alloc` (curve constants, K-tables, the fixed-base
        # comb) happens single-threaded (CLAUDE.md quirk #7:
        # alloc/fl_alloc are not thread-safe). Each guard short-
        # circuits after first call.
        ed25519_init();
        sha256_global_init();
        sha512_global_init();
        # Warm the SHA-NI CPUID probe + self-test so the cache and
        # the K-table allocation happen on the main thread.
        sha_ni_available();
        # Install the main thread's TLS block so the banked crypto
        # scratch (src/crypto_scratch.cyr) is well-defined here and in
        # any serial fallback. Workers get their own block via
        # CLONE_SETTLS. This — plus the per-worker bank assignment
        # below — replaces the 3.2-era `_sigil_batch_mutex` that used
        # to serialise every artifact (dropped in 3.6).
        crypto_tls_main_init();
        var workers = _SIGIL_BATCH_WORKERS;
        if (count < workers) { workers = count; }
        # Each worker needs a distinct crypto bank (1..workers); bank 0
        # is reserved for the main/serial path. Clamp so the bank index
        # can never exceed the scratch width (defence in depth — the
        # default 4 workers sit well inside SIGIL_CRYPTO_BANKS = 8).
        if (workers > SIGIL_CRYPTO_BANKS - 1) { workers = SIGIL_CRYPTO_BANKS - 1; }

        # Pre-allocate everything on main thread before spawn —
        # stdlib `alloc` / `fl_alloc` is not thread-safe (CLAUDE.md
        # quirk #7). The scratch_pool is `count * _VSC_SIZE` bytes
        # (one scratch per artifact, not per worker, so each vr
        # ptr stays stable for the whole batch). For count=64 →
        # 48 KB; count=1024 → 768 KB. Memory cost vs. the 3.0
        # heap-allocated path is comparable — same per-artifact
        # struct surface, just in one contiguous block.
        var slots = alloc(count * 8);
        var args = alloc(workers * 56);   # 7 slots: +48 = crypto bank
        var ts = alloc(workers * 8);
        var scratch_pool = alloc(count * _VSC_SIZE);
        var pi = 0;
        while (pi < count) {
            # Wire each scratch's inline vec_hdr to its inline
            # vec_data. Per-call `_verify_scratch_reset` only zeros
            # len / check_idx; this one-time wire-up happens here
            # before spawn so workers never touch shared init code.
            var s = scratch_pool + pi * _VSC_SIZE;
            store64(s + _VSC_VEC_HDR + 0, s + _VSC_VEC_DATA);
            store64(s + _VSC_VEC_HDR + 8, 0);
            store64(s + _VSC_VEC_HDR + 16, 16);
            pi = pi + 1;
        }

        var per = count / workers;
        if ((count % workers) != 0) { per = per + 1; }

        var wi = 0;
        while (wi < workers) {
            var pstart = wi * per;
            var pend = pstart + per;
            if (pend > count) { pend = count; }
            var a = args + wi * 56;
            store64(a, sv);
            store64(a + 8, artifacts);
            store64(a + 16, pstart);
            store64(a + 24, pend);
            store64(a + 32, slots);
            store64(a + 40, scratch_pool);
            store64(a + 48, wi + 1);   # crypto bank (1..workers; bank 0 = main)
            store64(ts + wi * 8, thread_create(&_batch_worker, a));
            wi = wi + 1;
        }

        wi = 0;
        while (wi < workers) {
            thread_join(load64(ts + wi * 8));
            wi = wi + 1;
        }

        # Emit audit records serially on the main thread now that
        # all workers have completed. The audit log's allocations
        # never race because we're back to a single-threaded
        # context. Matches the `sv_verify_artifact` wrapper's
        # audit-after-verify shape.
        var ai = 0;
        while (ai < count) {
            var avr = load64(slots + ai * 8);
            var apath = load64(artifacts + ai * 16);
            var aatype = load64(artifacts + ai * 16 + 8);
            var aart = vresult_artifact(avr);
            var ae_b = audit_artifact_verified(apath, aatype,
                                               artifact_trust_level(aart),
                                               vresult_passed(avr),
                                               artifact_content_hash(aart));
            alog_record(load64(sv + 48), ae_b);
            ai = ai + 1;
        }

        var presults = vec_new();
        var pri = 0;
        while (pri < count) {
            vec_push(presults, load64(slots + pri * 8));
            pri = pri + 1;
        }
        return presults;
    }

    # Serial path — taken when `count < _SIGIL_BATCH_PARALLEL_THRESHOLD`.
    var results = vec_new();
    var i = 0;
    while (i < count) {
        var path = load64(artifacts + i * 16);
        var atype = load64(artifacts + i * 16 + 8);
        var vr = sv_verify_artifact(sv, path, atype);
        vec_push(results, vr);
        i = i + 1;
    }
    return results;
}

# ================================================================
# Boot chain verification
# ================================================================

fn sv_verify_boot_chain(sv, components): i64 {
    var policy = load64(sv + 8);
    if (policy_verify_on_boot(policy) == 0) {
        return integrity_report_new();
    }

    var iv = load64(sv + 24);
    var ipol = integrity_policy_new();

    var clen = vec_len(components);
    var i = 0;
    while (i < clen) {
        var path = vec_get(components, i);
        var store = load64(sv + 32);
        # Look for artifact by path in trust store
        var keys = map_keys(store);
        var klen = vec_len(keys);
        var j = 0;
        while (j < klen) {
            var chash = vec_get(keys, j);
            var artifact = map_get(store, chash);
            if (streq(artifact_path(artifact), path) == 1) {
                ipolicy_add(ipol, path, chash);
            }
            j = j + 1;
        }
        i = i + 1;
    }

    iv_set_policy(iv, ipol);
    return iv_verify_all(iv);
}
