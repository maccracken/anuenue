    store64(_sha512_K + 288, 0x650a73548baf63de);
    store64(_sha512_K + 296, 0x766a0abb3c77b2a8);
    store64(_sha512_K + 304, 0x81c2c92e47edaee6);
    store64(_sha512_K + 312, 0x92722c851482353b);
    store64(_sha512_K + 320, 0xa2bfe8a14cf10364);
    store64(_sha512_K + 328, 0xa81a664bbc423001);
    store64(_sha512_K + 336, 0xc24b8b70d0f89791);
    store64(_sha512_K + 344, 0xc76c51a30654be30);
    store64(_sha512_K + 352, 0xd192e819d6ef5218);
    store64(_sha512_K + 360, 0xd69906245565a910);
    store64(_sha512_K + 368, 0xf40e35855771202a);
    store64(_sha512_K + 376, 0x106aa07032bbd1b8);
    store64(_sha512_K + 384, 0x19a4c116b8d2d0c8);
    store64(_sha512_K + 392, 0x1e376c085141ab53);
    store64(_sha512_K + 400, 0x2748774cdf8eeb99);
    store64(_sha512_K + 408, 0x34b0bcb5e19b48a8);
    store64(_sha512_K + 416, 0x391c0cb3c5c95a63);
    store64(_sha512_K + 424, 0x4ed8aa4ae3418acb);
    store64(_sha512_K + 432, 0x5b9cca4f7763e373);
    store64(_sha512_K + 440, 0x682e6ff3d6b2b8a3);
    store64(_sha512_K + 448, 0x748f82ee5defb2fc);
    store64(_sha512_K + 456, 0x78a5636f43172f60);
    store64(_sha512_K + 464, 0x84c87814a1f0ab72);
    store64(_sha512_K + 472, 0x8cc702081a6439ec);
    store64(_sha512_K + 480, 0x90befffa23631e28);
    store64(_sha512_K + 488, 0xa4506cebde82bde9);
    store64(_sha512_K + 496, 0xbef9a3f7b2c67915);
    store64(_sha512_K + 504, 0xc67178f2e372532b);
    store64(_sha512_K + 512, 0xca273eceea26619c);
    store64(_sha512_K + 520, 0xd186b8c721c0c207);
    store64(_sha512_K + 528, 0xeada7dd6cde0eb1e);
    store64(_sha512_K + 536, 0xf57d4f7fee6ed178);
    store64(_sha512_K + 544, 0x06f067aa72176fba);
    store64(_sha512_K + 552, 0x0a637dc5a2c898a6);
    store64(_sha512_K + 560, 0x113f9804bef90dae);
    store64(_sha512_K + 568, 0x1b710b35131c471b);
    store64(_sha512_K + 576, 0x28db77f523047d84);
    store64(_sha512_K + 584, 0x32caab7b40c72493);
    store64(_sha512_K + 592, 0x3c9ebe0a15c9bebc);
    store64(_sha512_K + 600, 0x431d67c49c100d4c);
    store64(_sha512_K + 608, 0x4cc5d4becb3e42b6);
    store64(_sha512_K + 616, 0x597f299cfc657e2a);
    store64(_sha512_K + 624, 0x5fcb6fab3ad6faec);
    store64(_sha512_K + 632, 0x6c44198c4a475817);

    _sha512_W = alloc(640);
    _sha512_inited = 1;
    return 0;
}

# ================================================================
# SHA-512 context (272 bytes)
# ================================================================
# Layout:
#   +0    h0..h7 (8 x 8 = 64 bytes) hash state
#   +64   buf    (128 bytes) partial block buffer
#   +192  buf_len (8 bytes)
#   +200  total_len (8 bytes)

fn sha512_init(): i64 {
    sha512_global_init();
    var ctx = fl_alloc(208);
    store64(ctx, 0x6a09e667f3bcc908);
    store64(ctx + 8, 0xbb67ae8584caa73b);
    store64(ctx + 16, 0x3c6ef372fe94f82b);
    store64(ctx + 24, 0xa54ff53a5f1d36f1);
    store64(ctx + 32, 0x510e527fade682d1);
    store64(ctx + 40, 0x9b05688c2b3e6c1f);
    store64(ctx + 48, 0x1f83d9abfb41bd6b);
    store64(ctx + 56, 0x5be0cd19137e2179);
    memset(ctx + 64, 0, 128);
    store64(ctx + 192, 0);
    store64(ctx + 200, 0);
    return ctx;
}

# ================================================================
# SHA-512 transform — globals for working state
# ================================================================

var _s5_a = 0;
var _s5_b = 0;
var _s5_c = 0;
var _s5_d = 0;
var _s5_e = 0;
var _s5_f = 0;
var _s5_g = 0;
var _s5_hv = 0;
var _s5_t1 = 0;
var _s5_t2 = 0;
var _s5_ctx = 0;
var _s5_i = 0;

fn sha512_transform(ctx): i64 {
    _s5_ctx = ctx;
    var buf = ctx + 64;

    # Prepare message schedule W[0..15] from block (big-endian 64-bit words)
    _s5_i = 0;
    while (_s5_i < 16) {
        var off = _s5_i * 8;
        var w = ((load8(buf + off) & 0xFF) << 56)
        | ((load8(buf + off + 1) & 0xFF) << 48)
        | ((load8(buf + off + 2) & 0xFF) << 40)
        | ((load8(buf + off + 3) & 0xFF) << 32)
        | ((load8(buf + off + 4) & 0xFF) << 24)
        | ((load8(buf + off + 5) & 0xFF) << 16)
        | ((load8(buf + off + 6) & 0xFF) << 8)
        | (load8(buf + off + 7) & 0xFF);
        store64(_sha512_W + _s5_i * 8, w);
        _s5_i = _s5_i + 1;
    }

    # Extend W[16..79]
    _s5_i = 16;
    while (_s5_i < 80) {
        var w16 = load64(_sha512_W + (_s5_i - 16) * 8);
        var w15 = load64(_sha512_W + (_s5_i - 15) * 8);
        var w7 = load64(_sha512_W + (_s5_i - 7) * 8);
        var w2 = load64(_sha512_W + (_s5_i - 2) * 8);
        var s0 = sha512_ssig0(w15);
        var s1 = sha512_ssig1(w2);
        store64(_sha512_W + _s5_i * 8, w16 + s0 + w7 + s1);
        _s5_i = _s5_i + 1;
    }

    # Initialize working variables
    _s5_a = load64(_s5_ctx);
    _s5_b = load64(_s5_ctx + 8);
    _s5_c = load64(_s5_ctx + 16);
    _s5_d = load64(_s5_ctx + 24);
    _s5_e = load64(_s5_ctx + 32);
    _s5_f = load64(_s5_ctx + 40);
    _s5_g = load64(_s5_ctx + 48);
    _s5_hv = load64(_s5_ctx + 56);

    # 80 rounds
    _s5_i = 0;
    while (_s5_i < 80) {
        _s5_t1 = _s5_hv + sha512_bsig1(_s5_e) + sha512_ch(_s5_e, _s5_f, _s5_g);
        _s5_t1 = _s5_t1 + load64(_sha512_K + _s5_i * 8) + load64(_sha512_W + _s5_i * 8);
        _s5_t2 = sha512_bsig0(_s5_a) + sha512_maj(_s5_a, _s5_b, _s5_c);

        _s5_hv = _s5_g;
        _s5_g = _s5_f;
        _s5_f = _s5_e;
        _s5_e = _s5_d + _s5_t1;
        _s5_d = _s5_c;
        _s5_c = _s5_b;
        _s5_b = _s5_a;
        _s5_a = _s5_t1 + _s5_t2;
        _s5_i = _s5_i + 1;
    }

    # Add compressed chunk to current hash value
    store64(_s5_ctx, load64(_s5_ctx) + _s5_a);
    store64(_s5_ctx + 8, load64(_s5_ctx + 8) + _s5_b);
    store64(_s5_ctx + 16, load64(_s5_ctx + 16) + _s5_c);
    store64(_s5_ctx + 24, load64(_s5_ctx + 24) + _s5_d);
    store64(_s5_ctx + 32, load64(_s5_ctx + 32) + _s5_e);
    store64(_s5_ctx + 40, load64(_s5_ctx + 40) + _s5_f);
    store64(_s5_ctx + 48, load64(_s5_ctx + 48) + _s5_g);
    store64(_s5_ctx + 56, load64(_s5_ctx + 56) + _s5_hv);
    return 0;
}

# ================================================================
# SHA-512 update
# ================================================================

fn sha512_update(ctx, data, len): i64 {
    var buf_len = load64(ctx + 192);
    var total = load64(ctx + 200);
    total = total + len;
    store64(ctx + 200, total);

    var pos = 0;

    if (buf_len > 0) {
        var need = 128 - buf_len;
        if (len < need) {
            memcpy(ctx + 64 + buf_len, data, len);
            store64(ctx + 192, buf_len + len);
            return 0;
        }
        memcpy(ctx + 64 + buf_len, data, need);
        sha512_transform(ctx);
        pos = need;
        buf_len = 0;
    }

    while (pos + 128 <= len) {
        memcpy(ctx + 64, data + pos, 128);
        sha512_transform(ctx);
        pos = pos + 128;
    }

    var remaining = len - pos;
    if (remaining > 0) {
        memcpy(ctx + 64, data + pos, remaining);
    }
    store64(ctx + 192, remaining);
    return 0;
}

# ================================================================
# SHA-512 finalize — produce 64-byte digest
# ================================================================

fn sha512_finalize(ctx, out): i64 {
    var buf_len = load64(ctx + 192);
    var total_bits = load64(ctx + 200) * 8;

    store8(ctx + 64 + buf_len, 0x80);
    buf_len = buf_len + 1;

    if (buf_len > 112) {
        memset(ctx + 64 + buf_len, 0, 128 - buf_len);
        sha512_transform(ctx);
        buf_len = 0;
    }
    memset(ctx + 64 + buf_len, 0, 112 - buf_len);

    # Append total length as 128-bit big-endian (high 64 bits = 0 for < 2^64 bits)
    memset(ctx + 64 + 112, 0, 8);
    store8(ctx + 64 + 120, (total_bits >> 56) & 0xFF);
    store8(ctx + 64 + 121, (total_bits >> 48) & 0xFF);
    store8(ctx + 64 + 122, (total_bits >> 40) & 0xFF);
    store8(ctx + 64 + 123, (total_bits >> 32) & 0xFF);
    store8(ctx + 64 + 124, (total_bits >> 24) & 0xFF);
    store8(ctx + 64 + 125, (total_bits >> 16) & 0xFF);
    store8(ctx + 64 + 126, (total_bits >> 8) & 0xFF);
    store8(ctx + 64 + 127, total_bits & 0xFF);

    sha512_transform(ctx);

    # Write 64-byte digest in big-endian from h0-h7
    var di = 0;
    while (di < 8) {
        var word = load64(ctx + di * 8);
        store8(out + di * 8, (word >> 56) & 0xFF);
        store8(out + di * 8 + 1, (word >> 48) & 0xFF);
        store8(out + di * 8 + 2, (word >> 40) & 0xFF);
        store8(out + di * 8 + 3, (word >> 32) & 0xFF);
        store8(out + di * 8 + 4, (word >> 24) & 0xFF);
        store8(out + di * 8 + 5, (word >> 16) & 0xFF);
        store8(out + di * 8 + 6, (word >> 8) & 0xFF);
        store8(out + di * 8 + 7, word & 0xFF);
        di = di + 1;
    }
    return 0;
}

# ================================================================
# Convenience — hash data in one shot
# ================================================================

fn sha512(data, len, out): i64 {
    var ctx = sha512_init();
    sha512_update(ctx, data, len);
    sha512_finalize(ctx, out);
    fl_free(ctx);
    return 0;
}

# --- bigint_ext.cyr ---

# bigint_ext.cyr — extended 256-bit arithmetic for Ed25519
# Adds: full 512-bit multiply, modular reduction for p=2^255-19,
# modular inversion, modular exponentiation, LE byte codec.
# Builds on lib/bigint.cyr

# ================================================================
# u256 <-> little-endian byte codec
# Previously inlined at 7 sites (5 decode + 2 encode loops, ~11 lines
# each) across ed25519.cyr. Safe to factor out: no nested function
# calls inside the loop body, so locals survive despite Cyrius'
# parameter-clobber rule.
# ================================================================

# Load 32 little-endian bytes from src into dst as four i64 limbs.
fn u256_load_le(dst, src): i64 {
    var i = 0;
    while (i < 4) {
        store64(dst + i * 8,
        (load8(src + i*8) & 0xFF)
        | ((load8(src + i*8 + 1) & 0xFF) << 8)
        | ((load8(src + i*8 + 2) & 0xFF) << 16)
        | ((load8(src + i*8 + 3) & 0xFF) << 24)
        | ((load8(src + i*8 + 4) & 0xFF) << 32)
        | ((load8(src + i*8 + 5) & 0xFF) << 40)
        | ((load8(src + i*8 + 6) & 0xFF) << 48)
        | ((load8(src + i*8 + 7) & 0xFF) << 56));
        i = i + 1;
    }
    return 0;
}

# Store src (four i64 limbs) as 32 little-endian bytes at dst.
fn u256_store_le(dst, src): i64 {
    var i = 0;
    while (i < 4) {
        var v = load64(src + i * 8);
        store8(dst + i*8, v & 0xFF);
        store8(dst + i*8 + 1, (v >> 8) & 0xFF);
        store8(dst + i*8 + 2, (v >> 16) & 0xFF);
        store8(dst + i*8 + 3, (v >> 24) & 0xFF);
        store8(dst + i*8 + 4, (v >> 32) & 0xFF);
        store8(dst + i*8 + 5, (v >> 40) & 0xFF);
        store8(dst + i*8 + 6, (v >> 48) & 0xFF);
        store8(dst + i*8 + 7, (v >> 56) & 0xFF);
        i = i + 1;
    }
    return 0;
}

# ================================================================
# 64×64 → 128-bit multiply (result in globals)
# ================================================================

var _m64_lo = 0;
var _m64_hi = 0;

fn _mul64_full(a, b): i64 {
    var mask32 = 0xFFFFFFFF;
    var aL = a & mask32;
    var aH = (a >> 32) & mask32;
    var bL = b & mask32;
    var bH = (b >> 32) & mask32;
    var ll = aL * bL;
    var lh = aL * bH;
    var hl = aH * bL;
    var hh = aH * bH;
    var mid = lh + hl;
    var mid_carry = 0;
    if ((mid ^ (1 << 63)) < (lh ^ (1 << 63))) { mid_carry = 1; }
    var lo = ll + (mid << 32);
    var lo_carry = 0;
    if ((lo ^ (1 << 63)) < (ll ^ (1 << 63))) { lo_carry = 1; }
    _m64_lo = lo;
    _m64_hi = hh + (mid >> 32) + (mid_carry << 32) + lo_carry;
    return 0;
}

# ================================================================
# Full 256×256 → 512-bit multiply
# out: 64 bytes (8 limbs)
# ================================================================

# Globals for mul_full inner loop (avoid local clobber across fn calls)
var _mf_s1 = 0;
var _mf_c1 = 0;
var _mf_carry = 0;
var _mf_hi = 0;

fn u256_mul_full(out, a, b): i64 {
    memset(out, 0, 64);
    var sbit = 1 << 63;
    var i = 0;
    while (i < 4) {
        _mf_carry = 0;
        var j = 0;
        while (j < 4) {
            _mul64_full(load64(a + i * 8), load64(b + j * 8));
            var k = i + j;
            var prev = load64(out + k * 8);
            _mf_hi = _m64_hi;

            # s1 = prev + _m64_lo; _mf_c1 = overflow (inlined from _uadd_overflow)
            _mf_s1 = prev + _m64_lo;
            _mf_c1 = 0;
            if ((_mf_s1 ^ sbit) < (prev ^ sbit)) { _mf_c1 = 1; }

            # s2 = s1 + carry; c2 = overflow (inlined)
            var s2 = _mf_s1 + _mf_carry;
            var c2 = 0;
            if ((s2 ^ sbit) < (_mf_s1 ^ sbit)) { c2 = 1; }

            store64(out + k * 8, s2);
            _mf_carry = _mf_hi + _mf_c1 + c2;
            j = j + 1;
        }
        if (i + 4 < 8) {
            store64(out + (i + 4) * 8, load64(out + (i + 4) * 8) + _mf_carry);
        }
        i = i + 1;
    }
    return 0;
}

# ================================================================
# Reduction mod p = 2^255 - 19
# Uses: 2^256 ≡ 38 (mod p), so for 512-bit val = aH*2^256 + aL:
#   val mod p ≡ aL + 38*aH (mod p)
# May need 1-2 further subtractions.
# ================================================================

# Global p = 2^255 - 19
var _ed_p = 0;
var _ed_p_inited = 0;
var _mod_prod = 0;
var _mod_aH = 0;
var _mod_aL = 0;
var _mod_38 = 0;
var _mod_lowp = 0;
var _mod_r = 0;
var _mod_extra = 0;

fn _init_ed_p(): i64 {
    if (_ed_p_inited == 1) { return 0; }
    _ed_p = u256_from_hex("7fffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffed");
    _mod_prod = alloc(64);
    _mod_aH = alloc(32);
    _mod_aL = alloc(32);
    _mod_38 = u256_from(38);
    _mod_lowp = alloc(32);
    _mod_r = alloc(32);
    _mod_extra = alloc(32);
    _ed_p_inited = 1;
    return 0;
}

fn u512_mod_p(out, val): i64 {
    _init_ed_p();

    store64(_mod_aH, load64(val + 32));
    store64(_mod_aH + 8, load64(val + 40));
    store64(_mod_aH + 16, load64(val + 48));
    store64(_mod_aH + 24, load64(val + 56));

    store64(_mod_aL, load64(val));
    store64(_mod_aL + 8, load64(val + 8));
    store64(_mod_aL + 16, load64(val + 16));
    store64(_mod_aL + 24, load64(val + 24));

    u256_mul_full(_mod_prod, _mod_aH, _mod_38);

    store64(_mod_lowp, load64(_mod_prod));
    store64(_mod_lowp + 8, load64(_mod_prod + 8));
    store64(_mod_lowp + 16, load64(_mod_prod + 16));
    store64(_mod_lowp + 24, load64(_mod_prod + 24));

    var carry = u256_add(_mod_r, _mod_aL, _mod_lowp);
    var overflow = carry + load64(_mod_prod + 32);

    while (overflow > 0) {
        store64(_mod_extra, overflow * 38);
        store64(_mod_extra + 8, 0);
        store64(_mod_extra + 16, 0);
        store64(_mod_extra + 24, 0);
        overflow = u256_add(_mod_r, _mod_r, _mod_extra);
    }

    while (u256_cmp(_mod_r, _ed_p) >= 0) {
        u256_sub(_mod_r, _mod_r, _ed_p);
    }

    u256_copy(out, _mod_r);
    return 0;
}

# ================================================================
# Field arithmetic mod p
# ================================================================

fn fp_add(r, a, b): i64 {
    _init_ed_p();
    u256_add(r, a, b);
    if (u256_cmp(r, _ed_p) >= 0) { u256_sub(r, r, _ed_p); }
    return 0;
}

fn fp_sub(r, a, b): i64 {
    _init_ed_p();
    var borrow = u256_sub(r, a, b);
    if (borrow > 0) { u256_add(r, r, _ed_p); }
    return 0;
}

fn fp_neg(r, a): i64 {
    _init_ed_p();
    if (u256_is_zero(a) == 1) {
        u256_copy(r, a);
        return 0;
    }
    u256_sub(r, _ed_p, a);
    return 0;
}

var _fp_mul_product = 0;

fn fp_mul(r, a, b): i64 {
    if (_fp_mul_product == 0) { _fp_mul_product = alloc(64); }
    u256_mul_full(_fp_mul_product, a, b);
    u512_mod_p(r, _fp_mul_product);
    return 0;
}

fn fp_sq(r, a): i64 {
    return fp_mul(r, a, a);
}

# ================================================================
# Modular exponentiation: r = base^exp mod p
# ================================================================

# Globals for fp_pow to survive nested calls (compiler clobber workaround)
var _fp_pow_tmp = 0;
var _fp_pow_result = 0;
var _fp_pow_base = 0;
var _fp_pow_exp = 0;
var _fp_pow_i = 0;
var _fp_pow_inited = 0;

fn fp_pow(r, base, exp): i64 {
    _init_ed_p();
    if (_fp_pow_inited == 0) {
        _fp_pow_tmp = alloc(32);
        _fp_pow_result = alloc(32);
        _fp_pow_base = alloc(32);
        _fp_pow_inited = 1;
    }
    store64(_fp_pow_result, 1);
    store64(_fp_pow_result + 8, 0);
    store64(_fp_pow_result + 16, 0);
    store64(_fp_pow_result + 24, 0);
    u256_copy(_fp_pow_base, base);
    _fp_pow_exp = exp;
    _fp_pow_i = 0;
    while (_fp_pow_i < 256) {
        var limb_idx = _fp_pow_i / 64;
        var bit_idx = _fp_pow_i % 64;
        var bit = (load64(_fp_pow_exp + limb_idx * 8) >> bit_idx) & 1;
        if (bit == 1) {
            fp_mul(_fp_pow_tmp, _fp_pow_result, _fp_pow_base);
            u256_copy(_fp_pow_result, _fp_pow_tmp);
        }
        fp_mul(_fp_pow_tmp, _fp_pow_base, _fp_pow_base);
        u256_copy(_fp_pow_base, _fp_pow_tmp);
        _fp_pow_i = _fp_pow_i + 1;
    }
    u256_copy(r, _fp_pow_result);
    return 0;
}

# ================================================================
# Modular inversion: r = a^(p-2) mod p for p = 2^255 - 19
# Bernstein's addition chain from the curve25519 reference:
# 254 squarings + 11 multiplies = 265 fp_mul calls
# (vs the generic fp_pow(p-2): ~512 fp_mul calls).
# ================================================================

var _fpi_t0 = 0;
var _fpi_z9 = 0;
var _fpi_z11 = 0;
var _fpi_z5 = 0;
var _fpi_z10 = 0;
var _fpi_z50 = 0;
var _fpi_z100 = 0;
var _fpi_a = 0;
var _fpi_r = 0;
var _fpi_buf = 0;
var _fpi_n = 0;
var _fpi_i = 0;
var _fpi_inited = 0;

fn _fpi_sq_n(buf, n): i64 {
    # In-place square `buf` n times. Params are saved to globals
    # because Cyrius clobbers locals across nested fp_sq → fp_mul calls.
    _fpi_buf = buf;
    _fpi_n = n;
    _fpi_i = 0;
    while (_fpi_i < _fpi_n) {
        fp_sq(_fpi_buf, _fpi_buf);
        _fpi_i = _fpi_i + 1;
    }
    return 0;
}

fn fp_inv(r, a): i64 {
    _init_ed_p();
    if (_fpi_inited == 0) {
        _fpi_t0 = alloc(32);
        _fpi_z9 = alloc(32);
        _fpi_z11 = alloc(32);
        _fpi_z5 = alloc(32);
        _fpi_z10 = alloc(32);
        _fpi_z50 = alloc(32);
        _fpi_z100 = alloc(32);
        _fpi_a = alloc(32);
        _fpi_inited = 1;
    }
    _fpi_r = r;
    u256_copy(_fpi_a, a);

    # z2 in _fpi_t0: t0 = a^2
    fp_sq(_fpi_t0, _fpi_a);
    # _fpi_z9 = t0^4 * a   = a^9
    fp_sq(_fpi_z9, _fpi_t0);
    fp_sq(_fpi_z9, _fpi_z9);
    fp_mul(_fpi_z9, _fpi_z9, _fpi_a);
    # _fpi_z11 = z9 * z2(=t0) = a^11
    fp_mul(_fpi_z11, _fpi_z9, _fpi_t0);
    # _fpi_z5 = z11^2 * z9  = a^(2^5 - 1) = a^31
    fp_sq(_fpi_z5, _fpi_z11);
    fp_mul(_fpi_z5, _fpi_z5, _fpi_z9);

    # _fpi_z10 = z5^(2^5) * z5 = a^(2^10 - 1)
    fp_sq(_fpi_z10, _fpi_z5);
    _fpi_sq_n(_fpi_z10, 4);
    fp_mul(_fpi_z10, _fpi_z10, _fpi_z5);

    # t0 = z10^(2^10) * z10 = a^(2^20 - 1)
    fp_sq(_fpi_t0, _fpi_z10);
    _fpi_sq_n(_fpi_t0, 9);
    fp_mul(_fpi_t0, _fpi_t0, _fpi_z10);

    # t0 = t0^(2^20) * t0 = a^(2^40 - 1)
    # Need a separate buffer for the squared copy — reuse _fpi_z9 shortly
    # via: save current t0 into z9, then continue. But z9 is still live
    # here (only z9 is needed no more — the last use was building z11).
    # Re-purpose _fpi_z9 as scratch from here on.
    u256_copy(_fpi_z9, _fpi_t0);
    _fpi_sq_n(_fpi_t0, 20);
    fp_mul(_fpi_t0, _fpi_t0, _fpi_z9);

    # t0 = t0^(2^10) * z10 = a^(2^50 - 1)
    _fpi_sq_n(_fpi_t0, 10);
    fp_mul(_fpi_z50, _fpi_t0, _fpi_z10);

    # t0 = z50^(2^50) * z50 = a^(2^100 - 1)
    fp_sq(_fpi_t0, _fpi_z50);
    _fpi_sq_n(_fpi_t0, 49);
    fp_mul(_fpi_z100, _fpi_t0, _fpi_z50);

    # t0 = z100^(2^100) * z100 = a^(2^200 - 1)
    fp_sq(_fpi_t0, _fpi_z100);
    _fpi_sq_n(_fpi_t0, 99);
    fp_mul(_fpi_t0, _fpi_t0, _fpi_z100);

    # t0 = t0^(2^50) * z50 = a^(2^250 - 1)
    _fpi_sq_n(_fpi_t0, 50);
    fp_mul(_fpi_t0, _fpi_t0, _fpi_z50);

    # r = t0^(2^5) * z11 = a^(2^255 - 21) = a^(p - 2)
    _fpi_sq_n(_fpi_t0, 5);
    fp_mul(_fpi_r, _fpi_t0, _fpi_z11);
    return 0;
}

# --- ed25519.cyr ---

# ed25519.cyr — Ed25519 signing and verification (RFC 8032)
# Built on bigint.cyr (u256) and bigint_ext.cyr (fp_* field ops)
#
# Curve: -x^2 + y^2 = 1 + d*x^2*y^2 (mod p)
# p = 2^255 - 19
# d = -121665/121666 mod p
# L = 2^252 + 27742317777372353535851937790883648493 (group order)
# B = base point (y = 4/5 mod p)
#
# Points: extended coordinates (X, Y, Z, T) where x=X/Z, y=Y/Z, T=X*Y/Z
# Each coordinate is a u256 (32 bytes), point = 128 bytes

# ================================================================
# Constants (allocated on init)
# ================================================================

var _ed_d = 0;
var _ed_2d = 0;
var _ed_B = 0;       # base point (128 bytes: X,Y,Z,T)
var _ed_B_table = 0; # fixed-base table: 64 rows × 16 pts × 128B = 128KB
var _ed_L = 0;       # group order (32 bytes)
var _ed_sqrtm1 = 0;
var _ed25519_inited = 0;

# ================================================================
# Point layout: 128 bytes = 4 x u256
# ================================================================
# +0:   X (32 bytes)
# +32:  Y (32 bytes)
# +64:  Z (32 bytes)
# +96:  T (32 bytes)

fn ge_alloc(): i64 { return alloc(128); }

fn ge_x(p): i64 { return p; }
fn ge_y(p): i64 { return p + 32; }
fn ge_z(p): i64 { return p + 64; }
fn ge_t(p): i64 { return p + 96; }

fn ge_identity(p): i64 {
    # Identity: (0, 1, 1, 0)
    var z = u256_from(0);
    var o = u256_from(1);
    u256_copy(p, z);
    u256_copy(p + 32, o);
    u256_copy(p + 64, o);
    u256_copy(p + 96, z);
    return 0;
}

fn ge_copy(dst, src): i64 {
    memcpy(dst, src, 128);
    return 0;
}

# ================================================================
# Point addition (extended coordinates)
# From "Twisted Edwards Curves Revisited" — HWCD08
# Cost: 8M + 1D (D = multiply by 2d)
# ================================================================

var _ga_t1 = 0;
var _ga_t2 = 0;
var _ga_A = 0;
var _ga_B2 = 0;
var _ga_C = 0;
var _ga_D = 0;
var _ga_E = 0;
var _ga_F = 0;
var _ga_G = 0;
var _ga_H2 = 0;
var _ga_inited = 0;

fn _ge_init_temps(): i64 {
    if (_ga_inited == 1) { return 0; }
    _ga_t1 = alloc(32); _ga_t2 = alloc(32);
    _ga_A = alloc(32); _ga_B2 = alloc(32);
    _ga_C = alloc(32); _ga_D = alloc(32);
    _ga_E = alloc(32); _ga_F = alloc(32);
    _ga_G = alloc(32); _ga_H2 = alloc(32);
    _ga_inited = 1;
    return 0;
}

fn ge_add(r, p, q): i64 {
    _ge_init_temps();
    # A = (Y1-X1)*(Y2-X2)
    fp_sub(_ga_t1, ge_y(p), ge_x(p));
    fp_sub(_ga_t2, ge_y(q), ge_x(q));
    fp_mul(_ga_A, _ga_t1, _ga_t2);

    # B = (Y1+X1)*(Y2+X2)
    fp_add(_ga_t1, ge_y(p), ge_x(p));
    fp_add(_ga_t2, ge_y(q), ge_x(q));
    fp_mul(_ga_B2, _ga_t1, _ga_t2);

    # C = T1*2d*T2
    fp_mul(_ga_C, ge_t(p), ge_t(q));
    fp_mul(_ga_C, _ga_C, _ed_2d);

    # D = Z1*2*Z2
    fp_mul(_ga_D, ge_z(p), ge_z(q));
    fp_add(_ga_D, _ga_D, _ga_D);

    # E=B-A, F=D-C, G=D+C, H=B+A
    fp_sub(_ga_E, _ga_B2, _ga_A);
    fp_sub(_ga_F, _ga_D, _ga_C);
    fp_add(_ga_G, _ga_D, _ga_C);
    fp_add(_ga_H2, _ga_B2, _ga_A);

    # X3=E*F, Y3=G*H, T3=E*H, Z3=F*G
    fp_mul(ge_x(r), _ga_E, _ga_F);
    fp_mul(ge_y(r), _ga_G, _ga_H2);
    fp_mul(ge_t(r), _ga_E, _ga_H2);
    fp_mul(ge_z(r), _ga_F, _ga_G);
    return 0;
}

# ================================================================
# Point doubling
# ================================================================

var _gd_A = 0;
var _gd_B = 0;
var _gd_C = 0;
var _gd_D = 0;
var _gd_E = 0;
var _gd_F = 0;
var _gd_G = 0;
var _gd_H = 0;
var _gd_t = 0;
var _gd_inited = 0;

fn _ge_init_dbl(): i64 {
    if (_gd_inited == 1) { return 0; }
    _gd_A = alloc(32); _gd_B = alloc(32);
    _gd_C = alloc(32); _gd_D = alloc(32);
    _gd_E = alloc(32); _gd_F = alloc(32);
    _gd_G = alloc(32); _gd_H = alloc(32);
    _gd_t = alloc(32);
    _gd_inited = 1;
    return 0;
}

fn ge_double(r, p): i64 {
    _ge_init_dbl();
    fp_sq(_gd_A, ge_x(p));
    fp_sq(_gd_B, ge_y(p));
    fp_sq(_gd_C, ge_z(p));
    fp_add(_gd_C, _gd_C, _gd_C);
    fp_neg(_gd_D, _gd_A);  # a=-1 for ed25519

    fp_add(_gd_t, ge_x(p), ge_y(p));
    fp_sq(_gd_E, _gd_t);
    fp_sub(_gd_E, _gd_E, _gd_A);
    fp_sub(_gd_E, _gd_E, _gd_B);

    fp_add(_gd_G, _gd_D, _gd_B);
    fp_sub(_gd_F, _gd_G, _gd_C);
    fp_sub(_gd_H, _gd_D, _gd_B);

    fp_mul(ge_x(r), _gd_E, _gd_F);
    fp_mul(ge_y(r), _gd_G, _gd_H);
    fp_mul(ge_t(r), _gd_E, _gd_H);
    fp_mul(ge_z(r), _gd_F, _gd_G);
    return 0;
}

# ================================================================
# Scalar multiplication: R = [s]P  (constant-time double-and-add)
# s is 32 bytes little-endian scalar.
#
# This loop MUST NOT branch on any bit of s: s is secret when called
# from ed25519_keypair / ed25519_sign (the clamped private scalar).
# Every iteration unconditionally computes both (r + q) and (2q) and
# uses a branchless select to either adopt or discard the addition.
# ================================================================

var _gsm_q = 0;
var _gsm_tmp = 0;
var _gsm_i = 0;
var _gsm_r = 0;
var _gsm_s = 0;
var _gsm_bit = 0;

# Constant-time conditional move on a 128-byte extended point.
# If bit == 1: dst := src.  If bit == 0: dst unchanged.
# Per-limb select via stdlib ct_select (lib/ct.cyr) — identical
# mask-xor arithmetic, single audit surface across the codebase.
fn ge_cmov(dst, src, bit): i64 {
    var i = 0;
    while (i < 128) {
        var d = load64(dst + i);
        var sv = load64(src + i);
        store64(dst + i, ct_select(bit, d, sv));
        i = i + 8;
    }
    return 0;
}

fn ge_scalarmult(r, s, p): i64 {
    if (_gsm_q == 0) { _gsm_q = alloc(128); _gsm_tmp = alloc(128); }
    _gsm_r = r;
    _gsm_s = s;
    ge_identity(_gsm_r);
    ge_copy(_gsm_q, p);

    _gsm_i = 0;
    while (_gsm_i < 256) {
        # Extract bit_i of s before any nested call; stash in a global
        # because locals are clobbered across ge_add / ge_cmov.
        var byte_idx = _gsm_i / 8;
        var bit_idx = _gsm_i % 8;
        _gsm_bit = (load8(_gsm_s + byte_idx) >> bit_idx) & 1;

        # Unconditional add; unconditional select.
        ge_add(_gsm_tmp, _gsm_r, _gsm_q);
        ge_cmov(_gsm_r, _gsm_tmp, _gsm_bit);

        # Unconditional double of q.
        ge_double(_gsm_tmp, _gsm_q);
        ge_copy(_gsm_q, _gsm_tmp);
        _gsm_i = _gsm_i + 1;
    }
    return 0;
}

# ================================================================
# Fixed-base scalar multiplication: R = [s]B  (uses _ed_B_table)
# 4-bit windowed comb: 64 windows × 16 precomputed points per window.
# Cost: 64 constant-time table selects + 64 ge_adds, no doublings.
# Must be constant-time — s is secret in keypair/sign.
# ================================================================

# Table select state
var _gts_dst = 0;
var _gts_row = 0;
var _gts_digit = 0;
var _gts_k = 0;

# Branchless: sets dst := row[digit] in constant time. Iterates all
# 16 entries and cmoves the one whose index equals digit. Memory
# access pattern does not depend on digit.
fn _ge_table_select(dst, row, digit): i64 {
    _gts_dst = dst;
    _gts_row = row;
    _gts_digit = digit;
    # Initialize dst to identity (entry k=0) — equivalent and simpler
    # than reading row[0], which is also identity.
    ge_identity(_gts_dst);
    _gts_k = 1;
    while (_gts_k < 16) {
        # eq = 1 iff k == digit, else 0  (branchless).
        # diff|(-diff) has its high bit set iff diff != 0.
        var diff = _gts_k ^ _gts_digit;
        var neg = 0 - diff;
        var eq = 1 - (((diff | neg) >> 63) & 1);
        ge_cmov(_gts_dst, _gts_row + _gts_k * 128, eq);
        _gts_k = _gts_k + 1;
    }
    return 0;
}

# Base scalarmult state
var _gsb_r = 0;
var _gsb_s = 0;
var _gsb_sel = 0;
var _gsb_tmp = 0;
var _gsb_i = 0;
var _gsb_digit = 0;

fn ge_scalarmult_base(r, s): i64 {
    if (_gsb_sel == 0) {
        _gsb_sel = alloc(128);
        _gsb_tmp = alloc(128);
    }
    _gsb_r = r;
    _gsb_s = s;
    ge_identity(_gsb_r);

    _gsb_i = 0;
    while (_gsb_i < 64) {
        # Public-index nibble extract: byte i/2, low or high nibble.
        var byte_idx = _gsb_i / 2;
        var b = load8(_gsb_s + byte_idx) & 0xFF;
        var d = b & 0xF;
        if ((_gsb_i & 1) == 1) { d = (b >> 4) & 0xF; }
        _gsb_digit = d;

        # Constant-time select into _gsb_sel.
        _ge_table_select(_gsb_sel, _ed_B_table + _gsb_i * 16 * 128, _gsb_digit);

        # r = r + sel  (ge_add handles r==identity and sel==identity correctly;
        # HWCD08 addition formula is complete on twisted Edwards curves).
        ge_add(_gsb_tmp, _gsb_r, _gsb_sel);
        ge_copy(_gsb_r, _gsb_tmp);
        _gsb_i = _gsb_i + 1;
    }
    return 0;
}

# ================================================================
# Build _ed_B_table at init — runs once, not perf-critical.
# Layout: table[i][k] = k * (16^i) * B. 64 rows × 16 entries × 128B.
# ================================================================

var _bt_table_i = 0;
var _bt_k = 0;
var _bt_base_i = 0;
var _bt_row = 0;

fn _build_ed_B_table(): i64 {
    _ed_B_table = alloc(131072);   # 64 * 16 * 128
    _bt_base_i = alloc(128);

    ge_copy(_bt_base_i, _ed_B);

    _bt_table_i = 0;
    while (_bt_table_i < 64) {
        _bt_row = _ed_B_table + _bt_table_i * 16 * 128;
        ge_identity(_bt_row);                              # k=0 → identity
        ge_copy(_bt_row + 128, _bt_base_i);                # k=1 → base_i
        _bt_k = 2;
        while (_bt_k < 16) {
            # row[k] = row[k-1] + base_i
            ge_add(_bt_row + _bt_k * 128,
            _bt_row + (_bt_k - 1) * 128,
            _bt_base_i);
            _bt_k = _bt_k + 1;
        }
        if (_bt_table_i < 63) {
            # base_{i+1} = 16 * base_i → four in-place doublings
            ge_double(_bt_base_i, _bt_base_i);
            ge_double(_bt_base_i, _bt_base_i);
            ge_double(_bt_base_i, _bt_base_i);
            ge_double(_bt_base_i, _bt_base_i);
        }
        _bt_table_i = _bt_table_i + 1;
    }
    return 0;
}

# ================================================================
# Point compression: point -> 32 bytes
# Encode y with sign of x in high bit of last byte
# ================================================================

var _gcomp_recip = 0;
var _gcomp_x = 0;
var _gcomp_y = 0;

fn ge_to_bytes(out, p): i64 {
    if (_gcomp_recip == 0) {
        _gcomp_recip = alloc(32);
        _gcomp_x = alloc(32);
        _gcomp_y = alloc(32);
    }
    fp_inv(_gcomp_recip, ge_z(p));
    fp_mul(_gcomp_x, ge_x(p), _gcomp_recip);
    fp_mul(_gcomp_y, ge_y(p), _gcomp_recip);

    # Encode y as 32 bytes little-endian
    u256_store_le(out, _gcomp_y);

    # Set high bit to sign of x (low bit of x)
    var x_sign = u256_limb(_gcomp_x, 0) & 1;
    store8(out + 31, (load8(out + 31) & 0xFF) | (x_sign << 7));
    return 0;
}

# ================================================================
# Point decompression: 32 bytes -> point
# Recover x from y using curve equation: x^2 = (y^2-1)/(dy^2+1)
# ================================================================

var _gdc_u = 0;
var _gdc_v = 0;
var _gdc_y2 = 0;
var _gdc_one = 0;
var _gdc_v3 = 0;
var _gdc_v7 = 0;
var _gdc_uv3 = 0;
var _gdc_uv7 = 0;
var _gdc_pow = 0;
var _gdc_x = 0;
var _gdc_check = 0;
var _gdc_vx2 = 0;
var _gdc_y = 0;
var _gdc_s_copy = 0;
var _gdc_x_sign = 0;
var _gdc_p_out = 0;
var _gdc_exp = 0;
var _gdc_inited = 0;

fn ge_from_bytes(p, s): i64 {
    ed25519_init();
    if (_gdc_inited == 0) {
        _gdc_u = alloc(32); _gdc_v = alloc(32); _gdc_y2 = alloc(32);
        _gdc_one = u256_from(1); _gdc_v3 = alloc(32); _gdc_v7 = alloc(32);
        _gdc_uv3 = alloc(32); _gdc_uv7 = alloc(32); _gdc_pow = alloc(32);
        _gdc_x = alloc(32); _gdc_check = alloc(32); _gdc_vx2 = alloc(32);
        _gdc_y = alloc(32); _gdc_s_copy = alloc(32);
        _gdc_exp = u256_from_hex("0ffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffd");
        _gdc_inited = 1;
    }
    _gdc_p_out = p;

    # Decode y from bytes, clear sign bit
    _gdc_x_sign = (load8(s + 31) >> 7) & 1;
    memcpy(_gdc_s_copy, s, 32);
    store8(_gdc_s_copy + 31, load8(_gdc_s_copy + 31) & 0x7F);

    # Load y as u256 from little-endian bytes
    u256_load_le(_gdc_y, _gdc_s_copy);

    # u = y^2 - 1
    fp_sq(_gdc_y2, _gdc_y);
    fp_sub(_gdc_u, _gdc_y2, _gdc_one);

    # v = d*y^2 + 1
    fp_mul(_gdc_v, _ed_d, _gdc_y2);
    fp_add(_gdc_v, _gdc_v, _gdc_one);

    # candidate = u * v^3 * (u*v^7)^((p-5)/8)
    fp_sq(_gdc_v3, _gdc_v);
    fp_mul(_gdc_v3, _gdc_v3, _gdc_v);        # v^3
    fp_sq(_gdc_v7, _gdc_v3);
    fp_mul(_gdc_v7, _gdc_v7, _gdc_v);        # v^7
    fp_mul(_gdc_uv7, _gdc_u, _gdc_v7);       # u*v^7
    fp_mul(_gdc_uv3, _gdc_u, _gdc_v3);       # u*v^3

    fp_pow(_gdc_pow, _gdc_uv7, _gdc_exp);

    # x = u*v^3 * pow
    fp_mul(_gdc_x, _gdc_uv3, _gdc_pow);

    # Verify: v*x^2 == u?
    fp_sq(_gdc_vx2, _gdc_x);
    fp_mul(_gdc_check, _gdc_v, _gdc_vx2);

    # If check != u, try x * sqrt(-1)
    if (u256_eq(_gdc_check, _gdc_u) == 0) {
        fp_mul(_gdc_x, _gdc_x, _ed_sqrtm1);
    }

    # Adjust sign
    if ((u256_limb(_gdc_x, 0) & 1) != _gdc_x_sign) {
        fp_neg(_gdc_x, _gdc_x);
    }

    # Set point: X=x, Y=y, Z=1, T=x*y
    u256_copy(ge_x(_gdc_p_out), _gdc_x);
    u256_copy(ge_y(_gdc_p_out), _gdc_y);
    var one_z = u256_from(1);
    u256_copy(ge_z(_gdc_p_out), one_z);
    fp_mul(ge_t(_gdc_p_out), _gdc_x, _gdc_y);
    return 0;
}

# ================================================================
# Ed25519 initialization
# ================================================================

fn ed25519_init(): i64 {
    if (_ed25519_inited == 1) { return 0; }
    _init_ed_p();

    # Pre-computed constants (avoids expensive fp_pow at init)

    # d = -121665/121666 mod p
    # = 0x52036cee2b6ffe738cc740797779e89800700a4d4141d8ab75eb4dca135978a3
    _ed_d = u256_from_hex("52036cee2b6ffe738cc740797779e89800700a4d4141d8ab75eb4dca135978a3");

    # 2*d
    _ed_2d = alloc(32);
    fp_add(_ed_2d, _ed_d, _ed_d);

    # sqrt(-1) mod p
    # = 0x2b8324804fc1df0b2b4d00993dfbd7a72f431806ad2fe478c4ee1b274a0ea0b0
    _ed_sqrtm1 = u256_from_hex("2b8324804fc1df0b2b4d00993dfbd7a72f431806ad2fe478c4ee1b274a0ea0b0");

    # L (group order)
    _ed_L = u256_from_hex("1000000000000000000000000000000014def9dea2f79cd65812631a5cf5d3ed");

    # Base point B: pre-computed extended coordinates
    # B.y = 4/5 mod p = 0x6666...6658
    # B.x = recovered from curve equation
    # Encoded point (compressed): 5866666666666666666666666666666666666666666666666666666666666666
    # X = 0x216936d3cd6e53fec0a4e231fdd6dc5c692cc7609525a7b2c9562d608f25d51a
    # Y = 0x6666666666666666666666666666666666666666666666666666666666666658
    _ed_B = alloc(128);
    var Bx = u256_from_hex("216936d3cd6e53fec0a4e231fdd6dc5c692cc7609525a7b2c9562d608f25d51a");
    var By = u256_from_hex("6666666666666666666666666666666666666666666666666666666666666658");
    var Bz = u256_from(1);
    var Bt = alloc(32);
    fp_mul(Bt, Bx, By);
    u256_copy(ge_x(_ed_B), Bx);
    u256_copy(ge_y(_ed_B), By);
    u256_copy(ge_z(_ed_B), Bz);
    u256_copy(ge_t(_ed_B), Bt);

    # Precomputed fixed-base table for signing/keypair/verify (2.3.0).
    _build_ed_B_table();

    _ed25519_inited = 1;
    return 0;
}

# ================================================================
# Scalar reduce: 64-byte hash -> 32-byte scalar mod L
# ================================================================

# R = 2^256 mod L — read-only constant, init-once. Safe to share
# across threads because it's never mutated after init.
var _scr_r256 = 0;
var _scr_inited = 0;

fn sc_reduce(out, s64): i64 {
    # Reduce 512-bit value mod L using: val = hi*2^256 + lo ≡ hi*R + lo (mod L)
    # where R = 2^256 mod L. Iterate until hi == 0.
    #
    # Scratch is stack-local (3.0 re-test: cycc 5.5.32 preserves
    # pointer-to-local across the nested u256_* calls in this
    # body, so the pre-3.0 globals-for-scratch workaround is no
    # longer needed here). `lo`, `hi`, `prod` live only for the
    # lifetime of the call — trivially per-thread by construction.
    if (_scr_inited == 0) {
        _scr_r256 = u256_from_hex("0ffffffffffffffffffffffffffffffec6ef5bf4737dcf70d6ec31748d98951d");
        _scr_inited = 1;
    }

    var lo[32];
    var hi[32];
    var prod[64];

    # Load 64-byte input as two u256 (little-endian).
    u256_load_le(&lo, s64);
    u256_load_le(&hi, s64 + 32);

    # Iteratively reduce: lo = lo + hi*R, split result, repeat until hi == 0
    while (u256_is_zero(&hi) == 0) {
        u256_mul_full(&prod, &hi, _scr_r256);
        # new_hi = product high 256 bits
        store64(&hi, load64(&prod + 32));
        store64(&hi + 8, load64(&prod + 40));
        store64(&hi + 16, load64(&prod + 48));
        store64(&hi + 24, load64(&prod + 56));
        # new_lo = old_lo + product_lo (carry propagates to hi)
        var carry = u256_add(&lo, &lo, &prod);
        if (carry > 0) {
            # Add carry to hi limb 0, propagate manually
            var h0 = load64(&hi) + 1;
            store64(&hi, h0);
            if (h0 == 0) {
                var h1 = load64(&hi + 8) + 1;
                store64(&hi + 8, h1);
                if (h1 == 0) {
                    var h2 = load64(&hi + 16) + 1;
                    store64(&hi + 16, h2);
                    if (h2 == 0) {
                        store64(&hi + 24, load64(&hi + 24) + 1);
                    }
                }
            }
        }
    }

    # Final reduction mod L
    while (u256_cmp(&lo, _ed_L) >= 0) {
        u256_sub(&lo, &lo, _ed_L);
    }

    u256_copy(out, &lo);
    return 0;
}

# ================================================================
# sc_muladd: out = (a * b + c) mod L
# ================================================================

var _scma_prod = 0;

fn sc_muladd(out, a, b, c): i64 {
    if (_scma_prod == 0) { _scma_prod = alloc(64); }
    u256_mul_full(_scma_prod, a, b);

    # Add c to the 512-bit product (low 256 bits, propagate carry to high)
    var carry = u256_add(_scma_prod, _scma_prod, c);
    if (carry > 0) {
        store64(_scma_prod + 32, load64(_scma_prod + 32) + carry);
    }

    sc_reduce(out, _scma_prod);
    return 0;
}

# ================================================================
# Ed25519 keypair: seed (32 bytes) -> sk (64 bytes), pk (32 bytes)
# ================================================================

var _kp_hash = 0;
var _kp_scalar = 0;

fn ed25519_keypair(seed, sk_out, pk_out): i64 {
    ed25519_init();
    if (_kp_hash == 0) { _kp_hash = alloc(64); _kp_scalar = alloc(32); }
    sha512(seed, 32, _kp_hash);

    # Clamp scalar (first 32 bytes)
    store8(_kp_hash, load8(_kp_hash) & 0xF8);
    store8(_kp_hash + 31, (load8(_kp_hash + 31) & 0x7F) | 0x40);

    # Copy scalar to dedicated heap buffer (survives nested calls)
    memcpy(_kp_scalar, _kp_hash, 32);

    # A = [a]B  (fixed-base, constant-time table lookup)
    var A = ge_alloc();
    ge_scalarmult_base(A, _kp_scalar);
    ge_to_bytes(pk_out, A);

    memcpy(sk_out, seed, 32);
    memcpy(sk_out + 32, pk_out, 32);

    # Zeroize secret scalar buffers. _kp_scalar holds the clamped
    # private scalar a; _kp_hash[0..32] is a copy of it.
    memset(_kp_hash, 0, 64);
    memset(_kp_scalar, 0, 32);
    return 0;
}

# ================================================================
# Ed25519 sign: sk (64b), msg, msg_len -> sig (64b)
# ================================================================

var _sign_az = 0;
var _sign_nhash = 0;
var _sign_hram = 0;
var _sign_sk = 0;
var _sign_msg = 0;
var _sign_msg_len = 0;
var _sign_sig_out = 0;
var _sign_r_scalar = 0;
var _sign_h_scalar = 0;
var _sign_a_scalar = 0;

fn ed25519_sign(sk, msg, msg_len, sig_out): i64 {
    ed25519_init();
    if (_sign_az == 0) {
        _sign_az = alloc(64);
        _sign_nhash = alloc(64);
        _sign_hram = alloc(64);
        _sign_r_scalar = alloc(32);
        _sign_h_scalar = alloc(32);
        _sign_a_scalar = alloc(32);
    }
    _sign_sk = sk;
    _sign_msg = msg;
    _sign_msg_len = msg_len;
    _sign_sig_out = sig_out;

    sha512(_sign_sk, 32, _sign_az);
    store8(_sign_az, load8(_sign_az) & 0xF8);
    store8(_sign_az + 31, (load8(_sign_az + 31) & 0x7F) | 0x40);

    # r = SHA-512(az[32..64] || msg) mod L
    var nctx = sha512_init();
    sha512_update(nctx, _sign_az + 32, 32);
    sha512_update(nctx, _sign_msg, _sign_msg_len);
    sha512_finalize(nctx, _sign_nhash);
    fl_free(nctx);

    sc_reduce(_sign_r_scalar, _sign_nhash);

    # R = [r]B  (fixed-base, constant-time table lookup)
    var R_point = ge_alloc();
    ge_scalarmult_base(R_point, _sign_r_scalar);
    ge_to_bytes(_sign_sig_out, R_point);

    # h = SHA-512(R || pk || msg) mod L
    var hctx = sha512_init();
    sha512_update(hctx, _sign_sig_out, 32);
    sha512_update(hctx, _sign_sk + 32, 32);
    sha512_update(hctx, _sign_msg, _sign_msg_len);
    sha512_finalize(hctx, _sign_hram);
    fl_free(hctx);

    sc_reduce(_sign_h_scalar, _sign_hram);

    # Load a from az[0..32] as u256
    u256_load_le(_sign_a_scalar, _sign_az);

    # S = (r + h*a) mod L
    var S_result = alloc(32);
    sc_muladd(S_result, _sign_h_scalar, _sign_a_scalar, _sign_r_scalar);

    # Write S as little-endian bytes to sig_out+32
    u256_store_le(_sign_sig_out + 32, S_result);

    # Zeroize all secret/derived material. _sign_az holds H(sk)[0..64]
    # (the clamped scalar a and nonce seed). _sign_r_scalar is the
    # per-signature nonce; _sign_a_scalar is the long-term scalar a
    # re-loaded as u256. Leaking any one recovers the signing secret.
    memset(_sign_az, 0, 64);
    memset(_sign_nhash, 0, 64);
    memset(_sign_r_scalar, 0, 32);
    memset(_sign_a_scalar, 0, 32);
    return 0;
}

# ================================================================
# Ed25519 verify: pk (32b), msg, msg_len, sig (64b) -> 0/1
# ================================================================

var _ver_pk = 0;
var _ver_msg = 0;
var _ver_msg_len = 0;
var _ver_sig = 0;
var _ver_hram = 0;
var _ver_h_scalar = 0;
var _ver_S_scalar = 0;
var _ver_R_bytes = 0;

fn ed25519_verify(pk, msg, msg_len, sig): i64 {
    ed25519_init();
    if (_ver_hram == 0) {
        _ver_hram = alloc(64);
        _ver_h_scalar = alloc(32);
        _ver_S_scalar = alloc(32);
        _ver_R_bytes = alloc(32);
    }
    _ver_pk = pk;
    _ver_msg = msg;
    _ver_msg_len = msg_len;
    _ver_sig = sig;

    var A = ge_alloc();
    ge_from_bytes(A, _ver_pk);

    # h = SHA-512(R || pk || msg) mod L
    var hctx = sha512_init();
    sha512_update(hctx, _ver_sig, 32);
    sha512_update(hctx, _ver_pk, 32);
    sha512_update(hctx, _ver_msg, _ver_msg_len);
    sha512_finalize(hctx, _ver_hram);
    fl_free(hctx);

    sc_reduce(_ver_h_scalar, _ver_hram);

    # Load S from sig[32..64] as scalar
    u256_load_le(_ver_S_scalar, _ver_sig + 32);

    # RFC 8032 §5.1.7 / §8.4: reject non-canonical S (S must be < L).
    # Prevents signature malleability — the same (pk, msg) must have
    # exactly one valid signature encoding.
    if (u256_cmp(_ver_S_scalar, _ed_L) >= 0) { return 0; }

    # [S]B  (fixed-base; S is public, but base table wins on speed anyway)
    var SB = ge_alloc();
    ge_scalarmult_base(SB, _ver_S_scalar);

    # [h]A
    var hA = ge_alloc();
    ge_scalarmult(hA, _ver_h_scalar, A);

    # R_check = [S]B - [h]A (negate hA: negate X and T)
    fp_neg(ge_x(hA), ge_x(hA));
    fp_neg(ge_t(hA), ge_t(hA));

    var R_check = ge_alloc();
    ge_add(R_check, SB, hA);

    ge_to_bytes(_ver_R_bytes, R_check);

    return ct_eq_bytes_lens(_ver_R_bytes, 32, _ver_sig, 32);
}

# ================================================================
# Generate random keypair
# ================================================================

fn ed25519_generate_keypair(sk_out, pk_out): i64 {
    # The prior implementation had two silent-failure paths:
    #   * no check of file_open's return value — fd=-1 would then
    #     be passed to file_read, leaving the stack-allocated seed
    #     with whatever bytes were already there.
    #   * single unchecked file_read — a short read (say 16 bytes)
    #     left the upper half of the seed uninitialised.
    # Either would derive an Ed25519 key from partial / zero / stale
    # entropy. This loop mirrors the /dev/urandom handling in
    # trust.cyr's `generate_keypair`: bail on open failure, accumulate
    # until 32 bytes, zeroise on any failure path.
    #
    # Returns 1 on success, 0 on entropy failure. Callers that ignore
    # the return value retain the previous "always 0" ABI, but keys
    # produced in that case are all-zero (sk_out / pk_out are set from
    # a zeroed seed) so any verify against them will fail deterministically
    # rather than silently accepting a garbage key.
    # `secret var` clears seed on every return path (Cyrius 5.3.5+).
    # Init memset retained because file_read into a partial buffer
    # on the error path below might leave upper bytes stale.
    secret var seed[32];
    memset(&seed, 0, 32);
    var fd = file_open("/dev/urandom", 0, 0);
    if (fd < 0) {
        memset(sk_out, 0, 64);
        memset(pk_out, 0, 32);
        return 0;
    }
    var got = 0;
    while (got < 32) {
        var n = file_read(fd, (&seed) + got, 32 - got);
        if (n <= 0) {
            file_close(fd);
            memset(sk_out, 0, 64);
            memset(pk_out, 0, 32);
            return 0;
        }
        got = got + n;
    }
    file_close(fd);
    ed25519_keypair(&seed, sk_out, pk_out);
    return 1;
}

# --- mldsa_params.cyr ---

# mldsa_params.cyr — ML-DSA parameters (FIPS 204, August 2024)
#
# Module-lattice-based digital signature — the post-quantum signing
# half of sigil 3.0. Keccak / SHAKE plumbing comes from Cyrius
# stdlib (`lib/keccak.cyr`, since 5.4.15); ML-DSA rides on top.
#
# Reference: NIST FIPS 204 final, August 13, 2024.
# Canonical impl: github.com/pq-crystals/dilithium (ref/).
#
# Only ML-DSA-65 (NIST security category 3) is parameterised here.
# ML-DSA-44 and ML-DSA-87 can be layered later without disturbing
# these constants — hence the MLDSA_ vs MLDSA65_ prefix split.
#
# Constants shadow the pq-crystals ref/params.h names so any
# cross-reference against that source reads identically.

# ================================================================
# Universal ML-DSA parameters (shared across 44/65/87)
# ================================================================
# Spec FIPS 204 §4 Table 1. These are independent of the security
# category — every ML-DSA instance uses the same ring Z_q[X]/(X^n+1)
# and the same Power2Round dropped-bit count d.

var MLDSA_N = 256;                  # ring poly degree (also SHAKE sample count per poly)
var MLDSA_Q = 8380417;              # prime modulus = 2^23 - 2^13 + 1
var MLDSA_D = 13;                   # Power2Round drops the bottom d bits of t
var MLDSA_ROOT_OF_UNITY = 1753;     # primitive 512th root of unity mod Q, Montgomery form

# Seed-level sizes
var MLDSA_SEEDBYTES = 32;           # ξ, ρ, rnd: 32-byte inputs to SHAKE
var MLDSA_CRHBYTES = 64;            # CRH output length (SHAKE-256 squeeze depth for μ, ρ')
var MLDSA_TRBYTES = 64;             # tr = SHAKE-256(pk, 64) — key-commitment hash
var MLDSA_RNDBYTES = 32;            # signing randomness (hedged mode)

# ================================================================
# ML-DSA-65 parameters (NIST security category 3)
# ================================================================
# Per spec FIPS 204 §4 Table 1, ML-DSA-65 column.

var MLDSA65_K = 6;                  # matrix rows (t, w, etc. live in R_q^k)
var MLDSA65_L = 5;                  # matrix cols (s1, y, z live in R_q^l)
var MLDSA65_ETA = 4;                # secret-key coefficient range: [-η, η]
var MLDSA65_TAU = 49;               # number of ±1 coefficients in the challenge c
var MLDSA65_BETA = 196;             # = τ * η, commitment-norm bound
var MLDSA65_GAMMA1 = 524288;        # = 1 << 19, mask range for y (§4 Table 1)
var MLDSA65_GAMMA2 = 261888;        # = (Q-1)/32, low-bits decompose radius
var MLDSA65_OMEGA = 55;             # hint-weight cap across the polynomial vector
var MLDSA65_CTILDEBYTES = 48;       # c̃ output length, 2·λ/8 bits at λ=192

# ================================================================
# Packed-poly byte sizes (ML-DSA-65, derived from the params above)
# ================================================================
# Each is bytes-per-poly (one poly = N=256 coefficients). Kept as
# literals rather than expressions because Cyrius module-scope
# var initializers are evaluated as runtime assignment, not CTFE.
# The test file asserts each derivation against the underlying
# parameters so drift is caught immediately.

var MLDSA65_POLYT1_PACKEDBYTES = 320;       # t1 bits = 23-D = 10, so 10*N/8 = 320
var MLDSA65_POLYT0_PACKEDBYTES = 416;       # t0 bits = D+1 = 13, so 13*N/8 = 416 (balanced)
var MLDSA65_POLYZ_PACKEDBYTES = 640;        # z bits = 20 (GAMMA1 = 1<<19 → log2+1), 20*N/8 = 640
var MLDSA65_POLYW1_PACKEDBYTES = 128;       # w1 bits = 4 (GAMMA2 = (Q-1)/32 branch), 4*N/8 = 128
var MLDSA65_POLYETA_PACKEDBYTES = 128;      # η=4 → 4 bits per coeff, 4*N/8 = 128
var MLDSA65_POLYVECH_PACKEDBYTES = 61;      # hint vec: OMEGA + K = 55 + 6 = 61

# ================================================================
# Public API byte sizes (ML-DSA-65)
# ================================================================
# Spec §5.1/§5.2 pk/sk encoding; §7.2 sig encoding.
#   pk = ρ ‖ t1                    = SEEDBYTES + K·POLYT1_PACKEDBYTES
#   sk = ρ ‖ K ‖ tr ‖ s1 ‖ s2 ‖ t0 = 2·SEEDBYTES + TRBYTES
#                                    + L·POLYETA_PACKEDBYTES
#                                    + K·POLYETA_PACKEDBYTES
#                                    + K·POLYT0_PACKEDBYTES
#   sig = c̃ ‖ z ‖ h               = CTILDEBYTES + L·POLYZ_PACKEDBYTES
#                                    + POLYVECH_PACKEDBYTES
# The concrete numbers for ML-DSA-65 land at:

var MLDSA65_PK_BYTES = 1952;        # = 32 + 6*320
var MLDSA65_SK_BYTES = 4032;        # = 64 + 64 + 5*128 + 6*128 + 6*416
var MLDSA65_SIG_BYTES = 3309;       # = 48 + 5*640 + 61

# --- mldsa_reduce.cyr ---

# mldsa_reduce.cyr — modular reduction primitives for ML-DSA
#
# Three operations used throughout the NTT / poly arithmetic
# layers. Bounds and formulas mirror pq-crystals/dilithium
# `ref/reduce.c`, which is the FIPS-204 reference implementation.
#
# Representation: every coefficient is a Cyrius i64 holding the
# signed 32-bit Montgomery-form value. Callers keep the value
# within the documented bounds of each helper; we do not re-check.
#
# Cyrius arithmetic notes (cycc):
#   - `>>` is LOGICAL shift right (zero-fill). Do not use for
#     arithmetic sign-extension.
#   - `/` is SIGNED 64-bit integer division (IDIV). Safe for the
#     Montgomery divide-by-2^32 step because the dividend is
#     always exactly divisible by 2^32.
#   - Integer wraparound is i64 two's-complement; subtracting a
#     larger unsigned value naturally produces a negative i64.
#
# Constants (from pq-crystals ref/reduce.h):
#   MONT  = -4186625  = 2^32  mod Q  in signed form (Montgomery R)
#   QINV  =  58728449 = Q^{-1} mod 2^32 (used in montgomery_reduce)
# Neither constant is parameter-set dependent; both hold for every
# ML-DSA variant since they derive only from (Q, N).

var MLDSA_MONT = 0 - 4186625;           # R = 2^32 mod Q, signed form
var MLDSA_QINV = 58728449;              # Q * QINV ≡ -1 (mod 2^32)

# ================================================================
# mldsa_montgomery_reduce — montgomery_reduce in FIPS 204 notation
# ================================================================
# Input:  a  with |a| ≤ Q * 2^31
# Output: r  with |r| < Q     (r ≡ a * 2^{-32} mod Q)
#
# Algorithm (C reference):
#   t = (int32_t)a * QINV;                # low 32 bits of a*QINV, signed
#   r = (a - (int64_t)t * Q) >> 32;       # arithmetic shift right by 32
# Cyrius port:
#   - Compute low 32 bits of a*QINV via i64 wraparound arithmetic,
#     then sign-extend to i64 by subtracting 2^32 when bit 31 set.
#   - The final shift is implemented as signed division by 2^32,
#     which is equivalent here because `a - t*Q` is always an
#     exact multiple of 2^32 by Montgomery construction.

fn mldsa_montgomery_reduce(a): i64 {
    # Step 1: t_low = low 32 bits of a * QINV (unsigned view).
    var t_raw = a * MLDSA_QINV;
    var t_low = t_raw & 0xFFFFFFFF;
    # Sign-extend to i64: if bit 31 is set, subtract 2^32.
    var t = t_low - ((t_low & 0x80000000) << 1);
    # Step 2: arithmetic shift right by 32 on (a − t·Q).
    # The dividend is an exact multiple of 2^32 (Montgomery
    # construction), so ASR and signed division agree. We use
    # bitwise shift + sign-fill instead of IDIV because IDIV is
    # the slowest instruction in the butterfly hot path
    # (~20 cycles on modern x86 vs ~2 for shift+or) and because
    # IDIV's timing, though bounded here, depends on the quotient
    # magnitude — not strictly constant-time.
    var diff = a - t * MLDSA_Q;
    var logical = diff >> 32;
    var sign = (diff >> 63) & 1;
    var fill = (0 - sign) << 32;
    return logical | fill;
}

# ================================================================
# mldsa_reduce32 — reduce32 in FIPS 204 notation
# ================================================================
# Input:  a  with |a| ≤ 2^31 - 2^22 - 1  (spec constraint)
# Output: r  with -6283008 ≤ r ≤ 6283008  (r ≡ a mod Q)
#
# Barrett-style nearest-multiple reduction: the approximate
# quotient t = ⌊(a + 2^22) / 2^23⌋ rounds a/Q to nearest, and
# t·Q is subtracted from a. The residual's magnitude is at most
# ⌈Q/2⌉ plus a small rounding slack, giving the 6283008 bound.
#
# The `/ 2^23` in the C reference is an **arithmetic** shift —
# rounds toward −∞ — whereas Cyrius's `/` is IDIV, which truncates
# toward zero. The two agree on non-negative dividends but disagree
# on negative ones (for a = −Q, C gives t = −1, Cyrius IDIV would
# give t = 0). Emulate arithmetic shift right by 23 as
# `(x >> 23) | ((−sign(x)) << 41)`:
#   - `x >> 23` is Cyrius's logical right shift, fills zeros.
#   - `(x >> 63) & 1` exposes the i64 sign bit via that same
#     logical shift.
#   - `0 − sign` is all-ones on negative, zero otherwise; shifted
#     left 41 it forms a mask covering the top 23 bits, which the
#     OR folds into the logical-shift result.
# No data-dependent branch; all straight-line arithmetic.

fn mldsa_reduce32(a): i64 {
    var x = a + (1 << 22);
    var logical = x >> 23;
    var sign = (x >> 63) & 1;
    var fill = (0 - sign) << 41;
    var t = logical | fill;
    return a - t * MLDSA_Q;
}

# ================================================================
# mldsa_caddq — caddq in FIPS 204 notation (conditional add Q)
# ================================================================
# Input:  a  with -Q < a < Q
# Output: r  with 0 ≤ r < Q    (r ≡ a mod Q, canonical rep)
#
# The C reference uses `a + ((a >> 31) & Q)` where the shift is
# arithmetic on a signed int32. In Cyrius (logical >>, i64), we
# read the i64 sign bit directly: `(a >> 63) & 1` is 1 for any
# negative i64, 0 otherwise. Multiply by Q to get the conditional
# addend. No data-dependent branch — the sign-bit extraction and
# multiply are straight-line arithmetic.

fn mldsa_caddq(a): i64 {
    var neg = (a >> 63) & 1;
    return a + neg * MLDSA_Q;
}

# ================================================================
# mldsa_freeze — reduce to canonical [0, Q) representation
# ================================================================
# Convenience wrapper = caddq ∘ reduce32. Used at pack boundaries
# where the coefficient must be the unique in-range representative.

fn mldsa_freeze(a): i64 {
    return mldsa_caddq(mldsa_reduce32(a));
}

# --- mldsa_ntt.cyr ---

# mldsa_ntt.cyr — forward / inverse NTT for ML-DSA
#
# Cooley-Tukey negacyclic NTT over Z_q[X] / (X^256 + 1). The full
# inner geometry matches pq-crystals/dilithium `ref/ntt.c` — same
# zetas table, same butterfly layout, same +/- Montgomery form.
#
# Outer contract:
#   mldsa_ntt(a):            in-place forward NTT, natural → bit-reversed.
#                             No reductions after add/sub — callers must
#                             ensure inputs are within a single Q.
#   mldsa_invntt_tomont(a):  in-place inverse NTT, bit-reversed → natural.
#                             Result is pre-multiplied by Montgomery R^2/N
#                             (constant f = 41978 = MONT^2 / 256).
#
# Coefficient format: each coefficient is a Cyrius i64 holding a
# signed i32-range value (Montgomery form). Poly buffer is 256·8
# = 2048 bytes; caller allocates.
#
# Zetas table: 256 i32 constants from the pq-crystals reference,
# stored here as a little-endian hex literal and decoded once into
# an `alloc`-backed buffer at first use. This pattern mirrors
# src/aes_gcm.cyr's S-box bring-up — keeps the fixup count tiny
# (one literal) and avoids 256 store-and-hope init statements.

# ================================================================
# Module state
# ================================================================

var _mldsa_zetas = 0;           # alloc'd, 256 * 8 = 2048 bytes, sign-extended i64
var _mldsa_ntt_inited = 0;

# ================================================================
# Zetas as a little-endian hex string (256 × i32 → 2048 hex chars)
# ================================================================
# Generated from pq-crystals/dilithium ref/ntt.c `zetas[N]` with:
#   python3 -c 'for v in zetas: print("%02x%02x%02x%02x" % (v&0xff,...))'
# Each run of 8 hex chars is one i32, little-endian. Rows are 8
# values wide for diffability against the C reference.

fn _mldsa_zetas_hex(): i64 {
    return "";
}

# ================================================================
# Hex helpers
# ================================================================
# Local copies so ntt.cyr does not become dependent on aes_gcm.cyr
# for the nibble decoder. Inline cost is trivial.

fn _mldsa_nibble(c): i64 {
    if (c >= 48) { if (c <= 57) { return c - 48; } }
    if (c >= 97) { if (c <= 102) { return c - 87; } }
    return 0;
}

# Read 4 bytes (8 hex chars) starting at hex_str[idx * 8], little
# endian, return as sign-extended i64.
fn _mldsa_decode_i32_le(hex_str, idx): i64 {
    var base = idx * 8;
    var b0 = (_mldsa_nibble(load8(hex_str + base + 0) & 0xFF) << 4)
    | _mldsa_nibble(load8(hex_str + base + 1) & 0xFF);
    var b1 = (_mldsa_nibble(load8(hex_str + base + 2) & 0xFF) << 4)
    | _mldsa_nibble(load8(hex_str + base + 3) & 0xFF);
    var b2 = (_mldsa_nibble(load8(hex_str + base + 4) & 0xFF) << 4)
    | _mldsa_nibble(load8(hex_str + base + 5) & 0xFF);
    var b3 = (_mldsa_nibble(load8(hex_str + base + 6) & 0xFF) << 4)
    | _mldsa_nibble(load8(hex_str + base + 7) & 0xFF);
    var u = b0 | (b1 << 8) | (b2 << 16) | (b3 << 24);
    # Sign-extend the 32-bit value to i64.
    return u - ((u & 0x80000000) << 1);
}

# ================================================================
# Init — decode the zetas hex literal once into the module buffer.
# ================================================================

fn mldsa_ntt_init(): i64 {
    if (_mldsa_ntt_inited == 1) { return 0; }
    _mldsa_zetas = alloc(256 * 8);
    var hex = _mldsa_zetas_hex();
    var i = 0;
    while (i < 256) {
        store64(_mldsa_zetas + i * 8, _mldsa_decode_i32_le(hex, i));
        i = i + 1;
    }
    _mldsa_ntt_inited = 1;
    return 0;
}

# ================================================================
# Forward NTT — Cooley-Tukey, bit-reversed output
# ================================================================
# Matches pq-crystals ntt.c layout exactly. No reductions after
# add/sub; caller ensures inputs are small enough that i32 range
# is preserved (bounded by roughly Q after each layer).

fn mldsa_ntt(a): i64 {
    mldsa_ntt_init();
    var k = 0;
    var len = 128;
    while (len > 0) {
        var start = 0;
        while (start < 256) {
            k = k + 1;
            var zeta = load64(_mldsa_zetas + k * 8);
            var j = start;
            while (j < start + len) {
                var ajl = load64(a + (j + len) * 8);
                var t = mldsa_montgomery_reduce(zeta * ajl);
                var aj = load64(a + j * 8);
                store64(a + (j + len) * 8, aj - t);
                store64(a + j * 8, aj + t);
                j = j + 1;
            }
            start = j + len;
        }
        len = len >> 1;
    }
    return 0;
}

# ================================================================
# Inverse NTT (with Montgomery-factor multiply)
# ================================================================
# Output coefficient a[i] ≡ (original a[i]) · 2^32  (mod Q). The
# post-loop multiply by f = 41978 = R^2 / N gives us N^{-1}·R^2
# in a single Montgomery reduction — folding the inverse-N and
# the Montgomery-R correction into one scan of the buffer.

fn mldsa_invntt_tomont(a): i64 {
    mldsa_ntt_init();
    var k = 256;
    var len = 1;
    while (len < 256) {
        var start = 0;
        while (start < 256) {
            k = k - 1;
            var zeta = 0 - load64(_mldsa_zetas + k * 8);
            var j = start;
            while (j < start + len) {
                var aj = load64(a + j * 8);
                var ajl = load64(a + (j + len) * 8);
                store64(a + j * 8, aj + ajl);
                var d = aj - ajl;
                store64(a + (j + len) * 8, mldsa_montgomery_reduce(zeta * d));
                j = j + 1;
            }
            start = j + len;
        }
        len = len << 1;
    }
    # Final Montgomery multiply by f = mont^2 / N = 41978.
    var f = 41978;
    var j = 0;
    while (j < 256) {
        var aj = load64(a + j * 8);
        store64(a + j * 8, mldsa_montgomery_reduce(f * aj));
        j = j + 1;
    }
    return 0;
}

# --- mldsa_poly.cyr ---

# mldsa_poly.cyr — poly + polyvec operations for ML-DSA
#
# Thin layer over the reduce + NTT primitives that expresses
# the FIPS 204 signing / verification algorithms as polynomial
# vector arithmetic. The reference is pq-crystals/dilithium
# `ref/poly.c` + `ref/polyvec.c`; API surface and data layout
# match 1:1.
#
# Buffer layout (all heap-allocated by callers):
#   poly         — 256·8 bytes, one i64 per coefficient
#   polyvecl     — L (=5) × 2048 bytes; vec[i] = base + i·2048
#   polyveck     — K (=6) × 2048 bytes; same scheme
#   matrix A     — K · L × 2048 bytes; row i at base + i · L · 2048
#
# Hot paths (`polyvecl_pointwise_acc_montgomery`,
# `polyvec_matrix_pointwise_montgomery`) promote their loop
# state to module-level globals because cycc clobbers locals
# across deeply nested call chains (the matrix product goes
# 3 levels deep into per-coefficient Montgomery reduces, same
# call-depth pattern that bit sha256 / ed25519).

# ================================================================
# Per-poly operations
# ================================================================

# c = a + b (componentwise, no modular reduction).
# Caller ensures |coeff| stays within a safe range.
fn mldsa_poly_add(c, a, b): i64 {
    var i = 0;
    while (i < 256) {
        store64(c + i * 8, load64(a + i * 8) + load64(b + i * 8));
        i = i + 1;
    }
    return 0;
}

# c = a - b (componentwise, no modular reduction).
fn mldsa_poly_sub(c, a, b): i64 {
    var i = 0;
    while (i < 256) {
        store64(c + i * 8, load64(a + i * 8) - load64(b + i * 8));
        i = i + 1;
    }
    return 0;
}

# Reduce every coefficient to [-6283008, 6283008] via reduce32.
fn mldsa_poly_reduce(a): i64 {
    var i = 0;
    while (i < 256) {
        store64(a + i * 8, mldsa_reduce32(load64(a + i * 8)));
        i = i + 1;
    }
    return 0;
}

# Bring every coefficient into canonical [0, Q) via caddq.
fn mldsa_poly_caddq(a): i64 {
    var i = 0;
    while (i < 256) {
        store64(a + i * 8, mldsa_caddq(load64(a + i * 8)));
        i = i + 1;
    }
    return 0;
}

# a ← a · 2^D  (used by verify to recover c · 2^D · t1). Assumes
# inputs fit in 2^{31-D} in absolute value — not checked.
fn mldsa_poly_shiftl(a): i64 {
    var i = 0;
    while (i < 256) {
        store64(a + i * 8, load64(a + i * 8) << MLDSA_D);
        i = i + 1;
    }
    return 0;
}

# c[i] = montgomery_reduce(a[i] · b[i]).
# Used in NTT domain: multiplies two NTT-form polys and brings
# the product back into a Montgomery-form representation of the
# same length.
fn mldsa_poly_pointwise_montgomery(c, a, b): i64 {
    var i = 0;
    while (i < 256) {
        var prod = load64(a + i * 8) * load64(b + i * 8);
        store64(c + i * 8, mldsa_montgomery_reduce(prod));
        i = i + 1;
    }
    return 0;
}

# Infinity-norm bound check: returns 1 if any |coeff| ≥ B, else 0.
# Early exit on the first violation is OK — the C ref notes the
# probability of each coefficient violating is independent of
# secret data; what must *not* leak is the sign of the violating
# coefficient, which this branchless abs() handles.
# B > (Q-1)/8 auto-fails to catch out-of-range bounds.
fn mldsa_poly_chknorm(a, B): i64 {
    if (B > (MLDSA_Q - 1) / 8) { return 1; }
    var i = 0;
    while (i < 256) {
        var c = load64(a + i * 8);
        # Branchless absolute value: sign_mask is 0 (c≥0) or −1 (c<0).
        var sign_mask = 0 - ((c >> 63) & 1);
        var abs_c = c - (sign_mask & (c + c));
        if (abs_c >= B) { return 1; }
        i = i + 1;
    }
    return 0;
}

# ================================================================
# Polyvec L (length L = 5)
# ================================================================

fn mldsa_polyvecl_add(w, u, v): i64 {
    var i = 0;
    while (i < MLDSA65_L) {
        mldsa_poly_add(w + i * 2048, u + i * 2048, v + i * 2048);
        i = i + 1;
    }
    return 0;
}

fn mldsa_polyvecl_reduce(v): i64 {
    var i = 0;
    while (i < MLDSA65_L) {
        mldsa_poly_reduce(v + i * 2048);
        i = i + 1;
    }
    return 0;
}

fn mldsa_polyvecl_ntt(v): i64 {
    var i = 0;
    while (i < MLDSA65_L) {
        mldsa_ntt(v + i * 2048);
        i = i + 1;
    }
    return 0;
}

fn mldsa_polyvecl_invntt_tomont(v): i64 {
    var i = 0;
    while (i < MLDSA65_L) {
        mldsa_invntt_tomont(v + i * 2048);
        i = i + 1;
    }
    return 0;
}

# r[i] = a · v[i] for i in 0..L (scalar-poly × vec).
fn mldsa_polyvecl_pointwise_poly_montgomery(r, a, v): i64 {
    var i = 0;
    while (i < MLDSA65_L) {
        mldsa_poly_pointwise_montgomery(r + i * 2048, a, v + i * 2048);
        i = i + 1;
    }
    return 0;
}

fn mldsa_polyvecl_chknorm(v, bound): i64 {
    var i = 0;
    while (i < MLDSA65_L) {
        if (mldsa_poly_chknorm(v + i * 2048, bound) == 1) { return 1; }
        i = i + 1;
    }
    return 0;
}

# ================================================================
# Polyvec K (length K = 6)
# ================================================================

fn mldsa_polyveck_add(w, u, v): i64 {
    var i = 0;
    while (i < MLDSA65_K) {
        mldsa_poly_add(w + i * 2048, u + i * 2048, v + i * 2048);
        i = i + 1;
    }
    return 0;
}

fn mldsa_polyveck_sub(w, u, v): i64 {
    var i = 0;
    while (i < MLDSA65_K) {
        mldsa_poly_sub(w + i * 2048, u + i * 2048, v + i * 2048);
        i = i + 1;
    }
    return 0;
}

fn mldsa_polyveck_reduce(v): i64 {
    var i = 0;
    while (i < MLDSA65_K) {
        mldsa_poly_reduce(v + i * 2048);
        i = i + 1;
    }
    return 0;
}

fn mldsa_polyveck_caddq(v): i64 {
    var i = 0;
    while (i < MLDSA65_K) {
        mldsa_poly_caddq(v + i * 2048);
        i = i + 1;
    }
    return 0;
}

fn mldsa_polyveck_shiftl(v): i64 {
    var i = 0;
    while (i < MLDSA65_K) {
        mldsa_poly_shiftl(v + i * 2048);
        i = i + 1;
    }
    return 0;
}

fn mldsa_polyveck_ntt(v): i64 {
    var i = 0;
    while (i < MLDSA65_K) {
        mldsa_ntt(v + i * 2048);
        i = i + 1;
    }
    return 0;
}

fn mldsa_polyveck_invntt_tomont(v): i64 {
    var i = 0;
    while (i < MLDSA65_K) {
        mldsa_invntt_tomont(v + i * 2048);
        i = i + 1;
    }
    return 0;
}

fn mldsa_polyveck_pointwise_poly_montgomery(r, a, v): i64 {
    var i = 0;
    while (i < MLDSA65_K) {
        mldsa_poly_pointwise_montgomery(r + i * 2048, a, v + i * 2048);
        i = i + 1;
    }
    return 0;
}

fn mldsa_polyveck_chknorm(v, bound): i64 {
    var i = 0;
    while (i < MLDSA65_K) {
        if (mldsa_poly_chknorm(v + i * 2048, bound) == 1) { return 1; }
        i = i + 1;
    }
    return 0;
}

# ================================================================
# Accumulated pointwise product: w = Σ u[i] · v[i]
# ================================================================
# Scratch buffer + loop state promoted to globals (see header
# comment). One-time alloc; reused across every acc call.

var _mldsa_pac_scratch = 0;
var _mldsa_pac_inited = 0;
var _mldsa_pac_w = 0;
var _mldsa_pac_u = 0;
var _mldsa_pac_v = 0;
var _mldsa_pac_i = 0;

fn _mldsa_pac_init(): i64 {
    if (_mldsa_pac_inited == 1) { return 0; }
    _mldsa_pac_scratch = alloc(2048);
    _mldsa_pac_inited = 1;
    return 0;
}

# w = u[0]·v[0] + u[1]·v[1] + ... + u[L-1]·v[L-1] in NTT domain.
# Each inner pointwise is a montgomery_reduce, so the sum is
# already scaled by R^{-1}.
fn mldsa_polyvecl_pointwise_acc_montgomery(w, u, v): i64 {
    _mldsa_pac_init();
    _mldsa_pac_w = w;
    _mldsa_pac_u = u;
    _mldsa_pac_v = v;
    # w = u[0] · v[0].
    mldsa_poly_pointwise_montgomery(_mldsa_pac_w, _mldsa_pac_u, _mldsa_pac_v);
    _mldsa_pac_i = 1;
    while (_mldsa_pac_i < MLDSA65_L) {
        mldsa_poly_pointwise_montgomery(
        _mldsa_pac_scratch,
        _mldsa_pac_u + _mldsa_pac_i * 2048,
        _mldsa_pac_v + _mldsa_pac_i * 2048
        );
        mldsa_poly_add(_mldsa_pac_w, _mldsa_pac_w, _mldsa_pac_scratch);
        _mldsa_pac_i = _mldsa_pac_i + 1;
    }
    return 0;
}

# ================================================================
# Matrix-vector product: t = A · v  (A is K rows × L cols)
# ================================================================
# Used during A·s1, A·y, and A·z computations in keygen / sign /
# verify. Row i of A is an L-element polyvecl at offset
# i · L · 2048 bytes from the matrix base. Each row is reduced
# against v via polyvecl_pointwise_acc_montgomery.

var _mldsa_mat_t = 0;
var _mldsa_mat_A = 0;
var _mldsa_mat_v = 0;
var _mldsa_mat_i = 0;

fn mldsa_polyvec_matrix_pointwise_montgomery(t, A, v): i64 {
    _mldsa_mat_t = t;
    _mldsa_mat_A = A;
    _mldsa_mat_v = v;
    _mldsa_mat_i = 0;
    while (_mldsa_mat_i < MLDSA65_K) {
        mldsa_polyvecl_pointwise_acc_montgomery(
        _mldsa_mat_t + _mldsa_mat_i * 2048,
        _mldsa_mat_A + _mldsa_mat_i * MLDSA65_L * 2048,
        _mldsa_mat_v
        );
        _mldsa_mat_i = _mldsa_mat_i + 1;
    }
    return 0;
}

# --- mldsa_rounding.cyr ---

# mldsa_rounding.cyr — Power2Round, Decompose, HighBits, LowBits,
# MakeHint, UseHint (FIPS 204 §8)
#
# These four primitives plus the Decompose helper make up the
# "rounding layer" that bridges the NTT world (full coefficients
# mod Q) and the signature-encoding world (a1 = high bits, a0 =
# low bits, h = hint bits).
#
# Reference: pq-crystals/dilithium `ref/rounding.c`. We keep the
# same call shapes; the only Cyrius-specific adaptation is the
# multi-return idiom — C uses an out-pointer for a0, we expose
# globals the caller can read after a call. That matches the
# sha256 / ed25519 pattern already in sigil and avoids the
# address-of-local dance for scalars.
#
# All functions operate on i64 values holding the signed-i32
# range of Z_Q coefficients. Assume inputs are standard
# representatives in [0, Q) unless noted.

# ================================================================
# Power2Round (D = 13 dropped bits)
# ================================================================
# Input:  a ∈ [0, Q)
# Output: (a1, a0) with  a = a1 · 2^D + a0  (mod Q),
#         a0 ∈ (−2^{D−1}, 2^{D−1}]
#
# Used in keygen to split t = t1·2^D + t0. t1 is published as
# part of pk (lossy, 10 bits/coeff); t0 stays private in sk
# (13 bits/coeff, balanced).

var _mldsa_p2r_a1 = 0;      # output high part
var _mldsa_p2r_a0 = 0;      # output low part (balanced)

fn mldsa_power2round(a): i64 {
    # Standard trick: add 2^{D-1}-1 before the right-shift so
    # the shift rounds to nearest instead of toward zero. Input
    # is non-negative so the logical >> matches arithmetic >>.
    var a1 = (a + (1 << (MLDSA_D - 1)) - 1) >> MLDSA_D;
    _mldsa_p2r_a1 = a1;
    _mldsa_p2r_a0 = a - (a1 << MLDSA_D);
    return a1;
}

# ================================================================
# Decompose — ML-DSA-65 branch only (GAMMA2 = (Q−1)/32)
# ================================================================
# Input:  a ∈ [0, Q)
# Output: (a1, a0) with  a = a1 · α + a0  (mod Q),  α = 2·γ2,
#         a0 ∈ (−α/2, α/2]  normally, except when a1 rolls over
#         the highest digit (a1 = (Q−1)/α = 16) we set a1 = 0
#         and a0 = a − Q ∈ [−α/2, 0).
#
# The C reference does this via Barrett-style nearest-multiple
# quotient + a sign-bit Q correction. Cyrius equivalent:
#   - the two right-shifts (>>7 and >>22) operate on non-negative
#     intermediates, so logical shift is correct.
#   - the final Q correction is `a0 -= (((Q−1)/2 − a0) >> 31) & Q`;
#     we read the i64 sign bit via `(diff >> 63) & 1` and
#     multiply by Q to pick up the branchless conditional subtract.

var _mldsa_dec_a1 = 0;      # high bits (w1 in the spec)
var _mldsa_dec_a0 = 0;      # low bits (balanced, w0)

fn mldsa_decompose(a): i64 {
    var a1 = (a + 127) >> 7;
    a1 = (a1 * 1025 + (1 << 21)) >> 22;
    a1 = a1 & 15;
    var a0 = a - a1 * 2 * MLDSA65_GAMMA2;
    # Conditional subtract Q: if a0 > (Q−1)/2, bring it into the
    # balanced negative range.
    var diff = (MLDSA_Q - 1) / 2 - a0;
    var sign = (diff >> 63) & 1;        # 1 iff diff < 0 iff a0 > (Q−1)/2
    a0 = a0 - sign * MLDSA_Q;
    _mldsa_dec_a1 = a1;
    _mldsa_dec_a0 = a0;
    return a1;
}

# Convenience accessors — HighBits / LowBits in FIPS 204 notation.
fn mldsa_high_bits(a): i64 {
    mldsa_decompose(a);
    return _mldsa_dec_a1;
}

fn mldsa_low_bits(a): i64 {
    mldsa_decompose(a);
    return _mldsa_dec_a0;
}

# ================================================================
# MakeHint — predict whether adding z flips the HighBits of r
# ================================================================
# Input:  a0 = LowBits(r+z), a1 = HighBits(r)  (per the spec)
# Output: 1 if HighBits(r+z) ≠ HighBits(r), else 0
#
# Branches are fine here — the return value IS what eventually
# ships as part of the public signature, so any control-flow
# signal is already encoded in the output. No timing surface
# beyond what the caller already publishes.

fn mldsa_make_hint(a0, a1): i64 {
    if (a0 > MLDSA65_GAMMA2) { return 1; }
    if (a0 < 0 - MLDSA65_GAMMA2) { return 1; }
    if (a0 == 0 - MLDSA65_GAMMA2) {
        if (a1 != 0) { return 1; }
    }
    return 0;
}

# ================================================================
# UseHint — recover HighBits(r + small) from (r, hint)
# ================================================================
# Input:  a (a coefficient), hint ∈ {0, 1}
# Output: corrected high-bits value
#
# Rule (GAMMA2 = (Q−1)/32 branch): call Decompose(a). If hint=0,
# return a1 verbatim. Otherwise shift a1 by ±1 modulo 16 based
# on the sign of a0. Wrap-around uses the same `& 15` mask as
# the decompose step so a1 stays in [0, 15].

fn mldsa_use_hint(a, hint): i64 {
    mldsa_decompose(a);
    var a1 = _mldsa_dec_a1;
    var a0 = _mldsa_dec_a0;
    if (hint == 0) { return a1; }
    if (a0 > 0) { return (a1 + 1) & 15; }
    return (a1 - 1) & 15;
}

# ================================================================
# Per-poly wrappers (iterate the per-coefficient primitive)
# ================================================================

# a1[i], a0[i] = power2round(a[i])
fn mldsa_poly_power2round(a1, a0, a): i64 {
    var i = 0;
    while (i < 256) {
        mldsa_power2round(load64(a + i * 8));
        store64(a1 + i * 8, _mldsa_p2r_a1);
        store64(a0 + i * 8, _mldsa_p2r_a0);
        i = i + 1;
    }
    return 0;
}

# a1[i], a0[i] = decompose(a[i])
fn mldsa_poly_decompose(a1, a0, a): i64 {
    var i = 0;
    while (i < 256) {
        mldsa_decompose(load64(a + i * 8));
        store64(a1 + i * 8, _mldsa_dec_a1);
        store64(a0 + i * 8, _mldsa_dec_a0);
        i = i + 1;
    }
    return 0;
}

# h[i] = make_hint(a0[i], a1[i]); returns total hint weight s.
fn mldsa_poly_make_hint(h, a0, a1): i64 {
    var s = 0;
    var i = 0;
    while (i < 256) {
        var bit = mldsa_make_hint(load64(a0 + i * 8), load64(a1 + i * 8));
        store64(h + i * 8, bit);
        s = s + bit;
        i = i + 1;
    }
    return s;
}

# r[i] = use_hint(a[i], h[i])
fn mldsa_poly_use_hint(r, a, h): i64 {
    var i = 0;
    while (i < 256) {
        store64(r + i * 8, mldsa_use_hint(load64(a + i * 8), load64(h + i * 8)));
        i = i + 1;
    }
    return 0;
}

# ================================================================
# Polyveck wrappers (K = 6 lanes)
# ================================================================

fn mldsa_polyveck_power2round(v1, v0, v): i64 {
    var i = 0;
    while (i < MLDSA65_K) {
        mldsa_poly_power2round(v1 + i * 2048, v0 + i * 2048, v + i * 2048);
        i = i + 1;
    }
    return 0;
}

fn mldsa_polyveck_decompose(v1, v0, v): i64 {
    var i = 0;
    while (i < MLDSA65_K) {
        mldsa_poly_decompose(v1 + i * 2048, v0 + i * 2048, v + i * 2048);
        i = i + 1;
    }
    return 0;
}

# h[i][j] = make_hint(v0[i][j], v1[i][j]); returns total weight.
fn mldsa_polyveck_make_hint(h, v0, v1): i64 {
    var s = 0;
    var i = 0;
    while (i < MLDSA65_K) {
        s = s + mldsa_poly_make_hint(h + i * 2048, v0 + i * 2048, v1 + i * 2048);
        i = i + 1;
    }
    return s;
}

fn mldsa_polyveck_use_hint(w, u, h): i64 {
    var i = 0;
    while (i < MLDSA65_K) {
        mldsa_poly_use_hint(w + i * 2048, u + i * 2048, h + i * 2048);
        i = i + 1;
    }
    return 0;
}

# --- mldsa_encode.cyr ---

# mldsa_encode.cyr — byte packing for ML-DSA keys and signatures
#
# Every byte that leaves sigil's ML-DSA surface goes through this
# module — public keys, secret keys, and signatures. Reference:
# pq-crystals/dilithium ref/poly.c (per-poly packers) +
# ref/packing.c (pk/sk/sig assembly).
#
# Bit layouts (ML-DSA-65 branches only, GAMMA1 = 2^19, GAMMA2 =
# (Q−1)/32, ETA = 4):
#
#   polyt1 : 10 bits/coeff unsigned — 4 coeffs → 5 bytes → 320 B
#   polyt0 : 13 bits/coeff balanced (2^{D-1}−c) — 8 coeffs → 13 bytes → 416 B
#   polyeta: 4 bits/coeff (η−c) — 2 coeffs → 1 byte → 128 B
#   polyz  : 20 bits/coeff (γ1−c) — 2 coeffs → 5 bytes → 640 B
#   polyw1 : 4 bits/coeff standard rep — 2 coeffs → 1 byte → 128 B
#
# All packers assume coefficients have already been reduced to
# the documented range (caller's responsibility). No modular
# reduction happens inside the packers.
#
# Cyrius note: bytes come from `load8` / go through `store8` with
# explicit `& 0xFF` masks — Cyrius's load8/store8 sign-extend to
# i64 on read and truncate on write, but intermediate arithmetic
# on i64 needs explicit masking to stay within the byte lane.

# ================================================================
# polyt1_pack / polyt1_unpack (10 bits/coeff, 320 bytes per poly)
# ================================================================

fn _mldsa_polyt1_pack(r, a): i64 {
    var i = 0;
    while (i < 256 / 4) {
        var c0 = load64(a + (4 * i + 0) * 8);
        var c1 = load64(a + (4 * i + 1) * 8);
        var c2 = load64(a + (4 * i + 2) * 8);
        var c3 = load64(a + (4 * i + 3) * 8);
        store8(r + 5 * i + 0, c0 & 0xFF);
        store8(r + 5 * i + 1, ((c0 >> 8) | (c1 << 2)) & 0xFF);
        store8(r + 5 * i + 2, ((c1 >> 6) | (c2 << 4)) & 0xFF);
        store8(r + 5 * i + 3, ((c2 >> 4) | (c3 << 6)) & 0xFF);
        store8(r + 5 * i + 4, (c3 >> 2) & 0xFF);
        i = i + 1;
    }
    return 0;
}

fn _mldsa_polyt1_unpack(r, a): i64 {
    var i = 0;
    while (i < 256 / 4) {
        var b0 = load8(a + 5 * i + 0) & 0xFF;
        var b1 = load8(a + 5 * i + 1) & 0xFF;
        var b2 = load8(a + 5 * i + 2) & 0xFF;
        var b3 = load8(a + 5 * i + 3) & 0xFF;
        var b4 = load8(a + 5 * i + 4) & 0xFF;
        store64(r + (4 * i + 0) * 8, ((b0 >> 0) | (b1 << 8)) & 0x3FF);
        store64(r + (4 * i + 1) * 8, ((b1 >> 2) | (b2 << 6)) & 0x3FF);
        store64(r + (4 * i + 2) * 8, ((b2 >> 4) | (b3 << 4)) & 0x3FF);
        store64(r + (4 * i + 3) * 8, ((b3 >> 6) | (b4 << 2)) & 0x3FF);
        i = i + 1;
    }
    return 0;
}

# ================================================================
# polyt0_pack / polyt0_unpack (13 bits/coeff balanced, 416 bytes)
# ================================================================
# Coefficients land in (−2^{D−1}, 2^{D−1}]. Packed as
# 2^{D−1} − c so the stored value is non-negative.

fn _mldsa_polyt0_pack(r, a): i64 {
    var bias = 1 << (MLDSA_D - 1);
    var i = 0;
    while (i < 256 / 8) {
        var t0 = bias - load64(a + (8 * i + 0) * 8);
        var t1 = bias - load64(a + (8 * i + 1) * 8);
        var t2 = bias - load64(a + (8 * i + 2) * 8);
        var t3 = bias - load64(a + (8 * i + 3) * 8);
        var t4 = bias - load64(a + (8 * i + 4) * 8);
        var t5 = bias - load64(a + (8 * i + 5) * 8);
        var t6 = bias - load64(a + (8 * i + 6) * 8);
        var t7 = bias - load64(a + (8 * i + 7) * 8);
        store8(r + 13 * i + 0,  t0 & 0xFF);
        store8(r + 13 * i + 1,  ((t0 >> 8) | (t1 << 5)) & 0xFF);
        store8(r + 13 * i + 2,  (t1 >> 3) & 0xFF);
        store8(r + 13 * i + 3,  ((t1 >> 11) | (t2 << 2)) & 0xFF);
        store8(r + 13 * i + 4,  ((t2 >> 6) | (t3 << 7)) & 0xFF);
        store8(r + 13 * i + 5,  (t3 >> 1) & 0xFF);
        store8(r + 13 * i + 6,  ((t3 >> 9) | (t4 << 4)) & 0xFF);
        store8(r + 13 * i + 7,  (t4 >> 4) & 0xFF);
        store8(r + 13 * i + 8,  ((t4 >> 12) | (t5 << 1)) & 0xFF);
        store8(r + 13 * i + 9,  ((t5 >> 7) | (t6 << 6)) & 0xFF);
        store8(r + 13 * i + 10, (t6 >> 2) & 0xFF);
        store8(r + 13 * i + 11, ((t6 >> 10) | (t7 << 3)) & 0xFF);
        store8(r + 13 * i + 12, (t7 >> 5) & 0xFF);
        i = i + 1;
    }
    return 0;
}

fn _mldsa_polyt0_unpack(r, a): i64 {
    var bias = 1 << (MLDSA_D - 1);
    var i = 0;
    while (i < 256 / 8) {
        var b0 = load8(a + 13 * i + 0) & 0xFF;
        var b1 = load8(a + 13 * i + 1) & 0xFF;
        var b2 = load8(a + 13 * i + 2) & 0xFF;
        var b3 = load8(a + 13 * i + 3) & 0xFF;
        var b4 = load8(a + 13 * i + 4) & 0xFF;
        var b5 = load8(a + 13 * i + 5) & 0xFF;
        var b6 = load8(a + 13 * i + 6) & 0xFF;
        var b7 = load8(a + 13 * i + 7) & 0xFF;
        var b8 = load8(a + 13 * i + 8) & 0xFF;
        var b9 = load8(a + 13 * i + 9) & 0xFF;
        var b10 = load8(a + 13 * i + 10) & 0xFF;
        var b11 = load8(a + 13 * i + 11) & 0xFF;
        var b12 = load8(a + 13 * i + 12) & 0xFF;
        var c0 = (b0 | (b1 << 8)) & 0x1FFF;
        var c1 = ((b1 >> 5) | (b2 << 3) | (b3 << 11)) & 0x1FFF;
        var c2 = ((b3 >> 2) | (b4 << 6)) & 0x1FFF;
        var c3 = ((b4 >> 7) | (b5 << 1) | (b6 << 9)) & 0x1FFF;
        var c4 = ((b6 >> 4) | (b7 << 4) | (b8 << 12)) & 0x1FFF;
        var c5 = ((b8 >> 1) | (b9 << 7)) & 0x1FFF;
        var c6 = ((b9 >> 6) | (b10 << 2) | (b11 << 10)) & 0x1FFF;
        var c7 = ((b11 >> 3) | (b12 << 5)) & 0x1FFF;
        store64(r + (8 * i + 0) * 8, bias - c0);
        store64(r + (8 * i + 1) * 8, bias - c1);
        store64(r + (8 * i + 2) * 8, bias - c2);
        store64(r + (8 * i + 3) * 8, bias - c3);
        store64(r + (8 * i + 4) * 8, bias - c4);
        store64(r + (8 * i + 5) * 8, bias - c5);
        store64(r + (8 * i + 6) * 8, bias - c6);
        store64(r + (8 * i + 7) * 8, bias - c7);
        i = i + 1;
    }
    return 0;
}

# ================================================================
# polyeta_pack / polyeta_unpack (η = 4, 4 bits/coeff, 128 bytes)
# ================================================================
# Store η − c as a 4-bit value; two coefficients per byte.

fn _mldsa_polyeta_pack(r, a): i64 {
    var i = 0;
    while (i < 256 / 2) {
        var t0 = MLDSA65_ETA - load64(a + (2 * i + 0) * 8);
        var t1 = MLDSA65_ETA - load64(a + (2 * i + 1) * 8);
        store8(r + i, (t0 | (t1 << 4)) & 0xFF);
        i = i + 1;
    }
    return 0;
}

fn _mldsa_polyeta_unpack(r, a): i64 {
    var i = 0;
    while (i < 256 / 2) {
        var b = load8(a + i) & 0xFF;
        store64(r + (2 * i + 0) * 8, MLDSA65_ETA - (b & 0x0F));
        store64(r + (2 * i + 1) * 8, MLDSA65_ETA - (b >> 4));
        i = i + 1;
    }
    return 0;
}

# ================================================================
# polyz_pack / polyz_unpack (γ1 = 2^19, 20 bits/coeff, 640 bytes)
# ================================================================

fn _mldsa_polyz_pack(r, a): i64 {
    var i = 0;
    while (i < 256 / 2) {
        var t0 = MLDSA65_GAMMA1 - load64(a + (2 * i + 0) * 8);
        var t1 = MLDSA65_GAMMA1 - load64(a + (2 * i + 1) * 8);
        store8(r + 5 * i + 0, t0 & 0xFF);
        store8(r + 5 * i + 1, (t0 >> 8) & 0xFF);
        store8(r + 5 * i + 2, ((t0 >> 16) | (t1 << 4)) & 0xFF);
        store8(r + 5 * i + 3, (t1 >> 4) & 0xFF);
        store8(r + 5 * i + 4, (t1 >> 12) & 0xFF);
        i = i + 1;
    }
    return 0;
}

fn _mldsa_polyz_unpack(r, a): i64 {
    var i = 0;
    while (i < 256 / 2) {
        var b0 = load8(a + 5 * i + 0) & 0xFF;
        var b1 = load8(a + 5 * i + 1) & 0xFF;
        var b2 = load8(a + 5 * i + 2) & 0xFF;
        var b3 = load8(a + 5 * i + 3) & 0xFF;
        var b4 = load8(a + 5 * i + 4) & 0xFF;
        var c0 = (b0 | (b1 << 8) | (b2 << 16)) & 0xFFFFF;
        var c1 = ((b2 >> 4) | (b3 << 4) | (b4 << 12)) & 0xFFFFF;
        store64(r + (2 * i + 0) * 8, MLDSA65_GAMMA1 - c0);
        store64(r + (2 * i + 1) * 8, MLDSA65_GAMMA1 - c1);
        i = i + 1;
    }
    return 0;
}

# ================================================================
# polyw1_pack (γ2 = (Q−1)/32 branch, 4 bits/coeff, 128 bytes)
# ================================================================
# No unpack — w1 only packs for the challenge-hash step. Input
# coefficients are standard representatives in [0, 15].

fn _mldsa_polyw1_pack(r, a): i64 {
    var i = 0;
    while (i < 256 / 2) {
        var c0 = load64(a + (2 * i + 0) * 8);
        var c1 = load64(a + (2 * i + 1) * 8);
        store8(r + i, (c0 | (c1 << 4)) & 0xFF);
        i = i + 1;
    }
    return 0;
}

fn mldsa_polyveck_pack_w1(r, v): i64 {
    var i = 0;
    while (i < MLDSA65_K) {
        _mldsa_polyw1_pack(r + i * MLDSA65_POLYW1_PACKEDBYTES, v + i * 2048);
        i = i + 1;
    }
    return 0;
}

# ================================================================
# pk / sk / sig assembly
# ================================================================

# pk = ρ (32 B) || t1 (K · 320 = 1920 B)
fn mldsa_pack_pk(pk, rho, t1): i64 {
    memcpy(pk, rho, MLDSA_SEEDBYTES);
    var i = 0;
    while (i < MLDSA65_K) {
        _mldsa_polyt1_pack(
        pk + MLDSA_SEEDBYTES + i * MLDSA65_POLYT1_PACKEDBYTES,
        t1 + i * 2048
        );
        i = i + 1;
    }
    return 0;
}

fn mldsa_unpack_pk(rho, t1, pk): i64 {
    memcpy(rho, pk, MLDSA_SEEDBYTES);
    var i = 0;
    while (i < MLDSA65_K) {
        _mldsa_polyt1_unpack(
        t1 + i * 2048,
        pk + MLDSA_SEEDBYTES + i * MLDSA65_POLYT1_PACKEDBYTES
        );
        i = i + 1;
    }
    return 0;
}

# sk = ρ (32) || K (32) || tr (64) || s1 (L·128) || s2 (K·128) || t0 (K·416)
fn mldsa_pack_sk(sk, rho, key, tr, t0, s1, s2): i64 {
    var off = 0;
    memcpy(sk + off, rho, MLDSA_SEEDBYTES);
    off = off + MLDSA_SEEDBYTES;
    memcpy(sk + off, key, MLDSA_SEEDBYTES);
    off = off + MLDSA_SEEDBYTES;
    memcpy(sk + off, tr, MLDSA_TRBYTES);
    off = off + MLDSA_TRBYTES;
    var i = 0;
    while (i < MLDSA65_L) {
        _mldsa_polyeta_pack(sk + off + i * MLDSA65_POLYETA_PACKEDBYTES, s1 + i * 2048);
        i = i + 1;
    }
    off = off + MLDSA65_L * MLDSA65_POLYETA_PACKEDBYTES;
    i = 0;
    while (i < MLDSA65_K) {
        _mldsa_polyeta_pack(sk + off + i * MLDSA65_POLYETA_PACKEDBYTES, s2 + i * 2048);
        i = i + 1;
    }
    off = off + MLDSA65_K * MLDSA65_POLYETA_PACKEDBYTES;
    i = 0;
    while (i < MLDSA65_K) {
        _mldsa_polyt0_pack(sk + off + i * MLDSA65_POLYT0_PACKEDBYTES, t0 + i * 2048);
        i = i + 1;
    }
    return 0;
}

fn mldsa_unpack_sk(rho, key, tr, t0, s1, s2, sk): i64 {
    var off = 0;
    memcpy(rho, sk + off, MLDSA_SEEDBYTES);
    off = off + MLDSA_SEEDBYTES;
    memcpy(key, sk + off, MLDSA_SEEDBYTES);
    off = off + MLDSA_SEEDBYTES;
    memcpy(tr, sk + off, MLDSA_TRBYTES);
    off = off + MLDSA_TRBYTES;
    var i = 0;
    while (i < MLDSA65_L) {
        _mldsa_polyeta_unpack(s1 + i * 2048, sk + off + i * MLDSA65_POLYETA_PACKEDBYTES);
        i = i + 1;
    }
    off = off + MLDSA65_L * MLDSA65_POLYETA_PACKEDBYTES;
    i = 0;
    while (i < MLDSA65_K) {
        _mldsa_polyeta_unpack(s2 + i * 2048, sk + off + i * MLDSA65_POLYETA_PACKEDBYTES);
        i = i + 1;
    }
    off = off + MLDSA65_K * MLDSA65_POLYETA_PACKEDBYTES;
    i = 0;
    while (i < MLDSA65_K) {
        _mldsa_polyt0_unpack(t0 + i * 2048, sk + off + i * MLDSA65_POLYT0_PACKEDBYTES);
        i = i + 1;
    }
    return 0;
}

# sig = c̃ (CTILDEBYTES) || z (L·POLYZ_PACKEDBYTES) || h (OMEGA+K bytes)
# Hint encoding: bytes [0, OMEGA) hold concatenated non-zero
# coefficient indices across the K hint polys; bytes [OMEGA, OMEGA+K)
# hold the cumulative count of non-zero coefficients after each
# poly i. Strong unforgeability requires strictly-increasing
# indices within each poly and zero-bytes in unused tail slots.
fn mldsa_pack_sig(sig, c, z, h): i64 {
    var off = 0;
    memcpy(sig + off, c, MLDSA65_CTILDEBYTES);
    off = off + MLDSA65_CTILDEBYTES;
    var i = 0;
    while (i < MLDSA65_L) {
        _mldsa_polyz_pack(sig + off + i * MLDSA65_POLYZ_PACKEDBYTES, z + i * 2048);
        i = i + 1;
    }
    off = off + MLDSA65_L * MLDSA65_POLYZ_PACKEDBYTES;
    # Zero the hint region (OMEGA index slots + K count slots).
    memset(sig + off, 0, MLDSA65_OMEGA + MLDSA65_K);
    var k = 0;
    i = 0;
    while (i < MLDSA65_K) {
        var j = 0;
        while (j < 256) {
            if (load64(h + i * 2048 + j * 8) != 0) {
                store8(sig + off + k, j & 0xFF);
                k = k + 1;
            }
            j = j + 1;
        }
        store8(sig + off + MLDSA65_OMEGA + i, k & 0xFF);
        i = i + 1;
    }
    return 0;
}

# Returns 0 on success, 1 on malformed signature. Zeros `h` on
# the way in so unused coefficient positions are explicitly zero.
fn mldsa_unpack_sig(c, z, h, sig): i64 {
    var off = 0;
    memcpy(c, sig + off, MLDSA65_CTILDEBYTES);
    off = off + MLDSA65_CTILDEBYTES;
    var i = 0;
    while (i < MLDSA65_L) {
        _mldsa_polyz_unpack(z + i * 2048, sig + off + i * MLDSA65_POLYZ_PACKEDBYTES);
        i = i + 1;
    }
    off = off + MLDSA65_L * MLDSA65_POLYZ_PACKEDBYTES;
    var k = 0;
    i = 0;
    while (i < MLDSA65_K) {
        # Zero the output hint poly.
        var zj = 0;
        while (zj < 256) {
            store64(h + i * 2048 + zj * 8, 0);
            zj = zj + 1;
        }
        var ki = load8(sig + off + MLDSA65_OMEGA + i) & 0xFF;
        if (ki < k) { return 1; }
        if (ki > MLDSA65_OMEGA) { return 1; }
        var j = k;
        while (j < ki) {
            # Strictly-increasing indices for strong unforgeability.
            if (j > k) {
                var idx_prev = load8(sig + off + j - 1) & 0xFF;
                var idx_curr = load8(sig + off + j) & 0xFF;
                if (idx_curr <= idx_prev) { return 1; }
            }
            var coeff_idx = load8(sig + off + j) & 0xFF;
            store64(h + i * 2048 + coeff_idx * 8, 1);
            j = j + 1;
        }
        k = ki;
        i = i + 1;
    }
    # Tail of the index region must be all zero.
    var j2 = k;
    while (j2 < MLDSA65_OMEGA) {
        if ((load8(sig + off + j2) & 0xFF) != 0) { return 1; }
        j2 = j2 + 1;
    }
    return 0;
}

# --- mldsa_sample.cyr ---

# mldsa_sample.cyr — rejection sampling + challenge expansion
#
# FIPS 204 §7: every pseudo-random poly that shows up during
# keygen / sign / verify is built here. The drivers all sit on
# top of `lib/keccak.cyr` (SHAKE-128 / SHAKE-256, landed in
# Cyrius 5.4.15). Reference: pq-crystals/dilithium ref/poly.c
# (the rej_uniform / rej_eta / poly_uniform_* / poly_challenge
# group) and ref/polyvec.c (polyvec_matrix_expand + polyvec*
# uniform wrappers).
#
# Streaming pattern: the stdlib exposes one-shot `shake128(...)`
# /`shake256(...)` wrappers plus the lower-level `_keccak_absorb`
# and `_keccak_f1600` primitives. We call those two primitives
# directly so the absorb step runs once per seed/nonce and each
# rejection-sampling block squeezes the minimum bytes it needs.
#
# Scratch: a single module-level 200-byte Keccak state buffer
# plus two squeeze buffers (one per rate) are allocated at first
# use. These are *public* across calls — the sampling driver
# resets them per operation, so any hypothetical leak would
# already be public (seed + nonce + produced output).

# ================================================================
# Module state
# ================================================================
# SHAKE-128 rate: 168 bytes. SHAKE-256 rate: 136 bytes.
# Initial-squeeze sizes (matching pq-crystals `POLY_UNIFORM_*_NBLOCKS`):
#   uniform   (A): 5 blocks × 168 = 840 bytes  (covers 256-coeff w.h.p.)
#   uniform_eta:   2 blocks × 136 = 272 bytes  (η=4 needs 227)
#   uniform_gamma1:5 blocks × 136 = 680 bytes  (exactly POLYZ_PACKEDBYTES)

var _mldsa_sample_inited = 0;
var _mldsa_sample_state = 0;        # 200 bytes, Keccak state
var _mldsa_sample_absorb = 0;       # 80 bytes, seed (<=64) + nonce (2) scratch
var _mldsa_sample_buf128 = 0;       # 5 × 168 + 2 bytes (uniform)
var _mldsa_sample_buf256 = 0;       # 5 × 136 bytes (eta + gamma1 + challenge)

fn _mldsa_sample_init(): i64 {
    if (_mldsa_sample_inited == 1) { return 0; }
    _mldsa_sample_state = alloc(200);
    _mldsa_sample_absorb = alloc(80);
    _mldsa_sample_buf128 = alloc(5 * 168 + 2);
    _mldsa_sample_buf256 = alloc(5 * 136);
    _mldsa_sample_inited = 1;
    return 0;
}

# ================================================================
# SHAKE streaming wrappers (one absorb + repeated squeeze)
# ================================================================
# Absorb = pq-crystals dilithium_shake128_stream_init: absorb seed
# then a little-endian 2-byte nonce, finalize. The shared state
# buffer is zeroed first so back-to-back sampling calls don't
# carry over residue.

fn _mldsa_shake128_stream_init(seed, seedlen, nonce): i64 {
    memset(_mldsa_sample_state, 0, 200);
    memcpy(_mldsa_sample_absorb, seed, seedlen);
    store8(_mldsa_sample_absorb + seedlen, nonce & 0xFF);
    store8(_mldsa_sample_absorb + seedlen + 1, (nonce >> 8) & 0xFF);
    _keccak_absorb(_mldsa_sample_state, _mldsa_sample_absorb, seedlen + 2, 168, 0x1F);
    return 0;
}

fn _mldsa_shake256_stream_init(seed, seedlen, nonce): i64 {
    memset(_mldsa_sample_state, 0, 200);
    memcpy(_mldsa_sample_absorb, seed, seedlen);
    store8(_mldsa_sample_absorb + seedlen, nonce & 0xFF);
    store8(_mldsa_sample_absorb + seedlen + 1, (nonce >> 8) & 0xFF);
    _keccak_absorb(_mldsa_sample_state, _mldsa_sample_absorb, seedlen + 2, 136, 0x1F);
    return 0;
}

# Squeeze `nblocks` × `rate` bytes into `out`, permuting the state
# between blocks. After the last squeeze, state is left ready for
# one more block (i.e. the f1600 call is eager).
fn _mldsa_shake_squeeze_blocks(out, nblocks, rate): i64 {
    var b = 0;
    while (b < nblocks) {
        var i = 0;
        while (i < rate) {
            store8(out + b * rate + i, load8(_mldsa_sample_state + i));
            i = i + 1;
        }
        _keccak_f1600(_mldsa_sample_state);
        b = b + 1;
    }
    return 0;
}

# ================================================================
# rej_uniform — sample coeffs in [0, Q) from random bytes
# ================================================================
# Returns number of coefficients successfully sampled (≤ len). May
# return early if buflen is exhausted. Each attempt consumes 3
# bytes; acceptance probability Q / 2^23 ≈ 0.999 so 5 blocks of
# SHAKE-128 (= 840 B) are almost always enough for 256 coeffs.

fn mldsa_rej_uniform(a, len, buf, buflen): i64 {
    var ctr = 0;
    var pos = 0;
    while (ctr < len) {
        if (pos + 3 > buflen) { return ctr; }
        var t = load8(buf + pos) & 0xFF;
        t = t | ((load8(buf + pos + 1) & 0xFF) << 8);
        t = t | ((load8(buf + pos + 2) & 0xFF) << 16);
        t = t & 0x7FFFFF;
        pos = pos + 3;
        if (t < MLDSA_Q) {
            store64(a + ctr * 8, t);
            ctr = ctr + 1;
        }
    }
    return ctr;
}

# ================================================================
# rej_eta — sample coeffs in [-ETA, ETA] for ETA = 4
# ================================================================
# Each byte yields two nibbles; each nibble in [0, 8] accepts to
# `4 - nibble`, nibbles in [9, 15] reject. Acceptance per nibble
# is 9/16. η=4 path only; η=2 rejection tables are not ML-DSA-65.

fn mldsa_rej_eta(a, len, buf, buflen): i64 {
    var ctr = 0;
    var pos = 0;
    while (ctr < len) {
        if (pos >= buflen) { return ctr; }
        var byte = load8(buf + pos) & 0xFF;
        var t0 = byte & 0x0F;
        var t1 = byte >> 4;
        pos = pos + 1;
        if (t0 < 9) {
            store64(a + ctr * 8, MLDSA65_ETA - t0);
            ctr = ctr + 1;
        }
        if (ctr < len) {
            if (t1 < 9) {
                store64(a + ctr * 8, MLDSA65_ETA - t1);
                ctr = ctr + 1;
            }
        }
    }
    return ctr;
}

# polyz_unpack lives in mldsa_encode.cyr (shared with pk/sk/sig
# packing). That module is included before this one in lib.cyr
# so `_mldsa_polyz_unpack` is in scope here.

# ================================================================
# poly_uniform — ExpandA single-poly driver (uses SHAKE-128)
# ================================================================
# Fills `a` with 256 uniformly random coefficients in [0, Q) via
# rejection sampling of a SHAKE-128(ρ ‖ nonce) stream.
# Callers for ExpandA set nonce = (row << 8) | col; nonce is an
# i64 here but only the low 16 bits matter.

# State globals: the sampling chain calls through multiple
# helpers, each with their own locals. Promote the loop state
# to module-level to survive cycc clobbering.
var _mldsa_pu_ctr = 0;
var _mldsa_pu_off = 0;
var _mldsa_pu_buflen = 0;
var _mldsa_pu_a = 0;

fn mldsa_poly_uniform(a, seed, nonce): i64 {
    _mldsa_sample_init();
    _mldsa_pu_a = a;
    _mldsa_shake128_stream_init(seed, MLDSA_SEEDBYTES, nonce);
    # Initial 5-block squeeze — enough for 256 coeffs ~99% of the time.
    _mldsa_shake_squeeze_blocks(_mldsa_sample_buf128, 5, 168);
    _mldsa_pu_buflen = 5 * 168;
    _mldsa_pu_ctr = mldsa_rej_uniform(_mldsa_pu_a, 256, _mldsa_sample_buf128, _mldsa_pu_buflen);
    # Fallback loop: carry over partial bytes, squeeze one more block.
    while (_mldsa_pu_ctr < 256) {
        _mldsa_pu_off = _mldsa_pu_buflen % 3;
        var i = 0;
        while (i < _mldsa_pu_off) {
            store8(
            _mldsa_sample_buf128 + i,
            load8(_mldsa_sample_buf128 + _mldsa_pu_buflen - _mldsa_pu_off + i)
            );
            i = i + 1;
        }
        # Squeeze one block at offset `off`.
        _mldsa_shake_squeeze_blocks(_mldsa_sample_buf128 + _mldsa_pu_off, 1, 168);
        _mldsa_pu_buflen = 168 + _mldsa_pu_off;
        _mldsa_pu_ctr = _mldsa_pu_ctr + mldsa_rej_uniform(
        _mldsa_pu_a + _mldsa_pu_ctr * 8,
        256 - _mldsa_pu_ctr,
        _mldsa_sample_buf128,
        _mldsa_pu_buflen
        );
    }
    return 0;
}

# ================================================================
# poly_uniform_eta — ExpandS single-poly driver (uses SHAKE-256)
# ================================================================
# Fills `a` with 256 coefficients in [-η, η] via rejection on a
# SHAKE-256(ρ' ‖ nonce) stream.

var _mldsa_pe_ctr = 0;
var _mldsa_pe_a = 0;

fn mldsa_poly_uniform_eta(a, seed, nonce): i64 {
    _mldsa_sample_init();
    _mldsa_pe_a = a;
    _mldsa_shake256_stream_init(seed, MLDSA_CRHBYTES, nonce);
    # η=4 needs ≈ 256·(16/9) ≈ 455 bytes → 4 blocks = 544 bytes
    # (pq-crystals picks 2 blocks then loops; we do the same with
    # a 2-block initial + 1-block fallback to stay within
    # buf256's 5-block capacity).
    _mldsa_shake_squeeze_blocks(_mldsa_sample_buf256, 2, 136);
    _mldsa_pe_ctr = mldsa_rej_eta(_mldsa_pe_a, 256, _mldsa_sample_buf256, 2 * 136);
    while (_mldsa_pe_ctr < 256) {
        _mldsa_shake_squeeze_blocks(_mldsa_sample_buf256, 1, 136);
        _mldsa_pe_ctr = _mldsa_pe_ctr + mldsa_rej_eta(
        _mldsa_pe_a + _mldsa_pe_ctr * 8,
        256 - _mldsa_pe_ctr,
        _mldsa_sample_buf256,
        136
        );
    }
    return 0;
}

# ================================================================
# poly_uniform_gamma1 — ExpandMask single-poly driver
# ================================================================
# Packs SHAKE-256(ρ' ‖ κ) into POLYZ_PACKEDBYTES = 640 bytes of
# output, then unpacks 20 bits per coefficient to produce y
# with coefficients in [1 − γ1, γ1]. No rejection; the unpack
# is exact.

fn mldsa_poly_uniform_gamma1(a, seed, nonce): i64 {
    _mldsa_sample_init();
    _mldsa_shake256_stream_init(seed, MLDSA_CRHBYTES, nonce);
    _mldsa_shake_squeeze_blocks(_mldsa_sample_buf256, 5, 136);
    _mldsa_polyz_unpack(a, _mldsa_sample_buf256);
    return 0;
}

# ================================================================
# poly_challenge — SampleInBall (τ non-zero ±1 coefficients)
# ================================================================
# c̃ (CTILDEBYTES bytes) is absorbed; first 8 output bytes become
# the 64-bit `signs` register (one bit per ±1 choice). Remaining
# bytes drive the Fisher-Yates-like swap that places TAU non-zero
# coefficients in the last TAU positions, shuffled earlier.

var _mldsa_ch_c = 0;
var _mldsa_ch_pos = 0;
var _mldsa_ch_signs = 0;
var _mldsa_ch_i = 0;

fn mldsa_poly_challenge(c, seed): i64 {
    _mldsa_sample_init();
    _mldsa_ch_c = c;
    # Absorb c̃ via the stream wrapper with nonce=0 would append two
    # extra bytes; FIPS 204 SampleInBall has no nonce. Call the
    # lower-level absorb directly with only `seed` as input.
    memset(_mldsa_sample_state, 0, 200);
    _keccak_absorb(_mldsa_sample_state, seed, MLDSA65_CTILDEBYTES, 136, 0x1F);
    _mldsa_shake_squeeze_blocks(_mldsa_sample_buf256, 1, 136);

    # Collect 64 sign bits from the first 8 bytes.
    _mldsa_ch_signs = 0;
    var si = 0;
    while (si < 8) {
        _mldsa_ch_signs = _mldsa_ch_signs | ((load8(_mldsa_sample_buf256 + si) & 0xFF) << (si * 8));
        si = si + 1;
    }
    _mldsa_ch_pos = 8;

    # Zero the output poly.
    var z = 0;
    while (z < 256) {
        store64(_mldsa_ch_c + z * 8, 0);
        z = z + 1;
    }

    # Place ±1 at TAU positions via the swap walk.
    _mldsa_ch_i = 256 - MLDSA65_TAU;
    while (_mldsa_ch_i < 256) {
        # Sample a uniform byte b ∈ [0, i] via rejection.
        var b = 0;
        var accepted = 0;
        while (accepted == 0) {
            if (_mldsa_ch_pos >= 136) {
                _mldsa_shake_squeeze_blocks(_mldsa_sample_buf256, 1, 136);
                _mldsa_ch_pos = 0;
            }
            b = load8(_mldsa_sample_buf256 + _mldsa_ch_pos) & 0xFF;
            _mldsa_ch_pos = _mldsa_ch_pos + 1;
            if (b <= _mldsa_ch_i) { accepted = 1; }
        }
        # c[i] = c[b]; c[b] = 1 - 2·(signs & 1); signs >>= 1
        store64(_mldsa_ch_c + _mldsa_ch_i * 8, load64(_mldsa_ch_c + b * 8));
        var sign_val = 1 - 2 * (_mldsa_ch_signs & 1);
        store64(_mldsa_ch_c + b * 8, sign_val);
        _mldsa_ch_signs = _mldsa_ch_signs >> 1;
        _mldsa_ch_i = _mldsa_ch_i + 1;
    }
    return 0;
}

# ================================================================
# Polyvec / matrix wrappers
# ================================================================

# ExpandA: matrix mat[i][j] = SHAKE-128(ρ ‖ (i<<8)|j) sampled into
# [0, Q). Total K·L = 30 polys.
fn mldsa_polyvec_matrix_expand(mat, rho): i64 {
    var i = 0;
    while (i < MLDSA65_K) {
        var j = 0;
        while (j < MLDSA65_L) {
            var nonce = (i << 8) | j;
            # Row i of A is at offset i * L * 2048; poly (i,j) at +j*2048.
            mldsa_poly_uniform(
            mat + (i * MLDSA65_L + j) * 2048,
            rho,
            nonce
            );
            j = j + 1;
        }
        i = i + 1;
    }
    return 0;
}

# ExpandS → s1 (L polys, nonces 0..L-1)
fn mldsa_polyvecl_uniform_eta(v, seed, nonce_base): i64 {
    var i = 0;
    while (i < MLDSA65_L) {
        mldsa_poly_uniform_eta(v + i * 2048, seed, nonce_base + i);
        i = i + 1;
    }
    return 0;
}

# ExpandS → s2 (K polys, nonces L..L+K-1)
fn mldsa_polyveck_uniform_eta(v, seed, nonce_base): i64 {
    var i = 0;
    while (i < MLDSA65_K) {
        mldsa_poly_uniform_eta(v + i * 2048, seed, nonce_base + i);
        i = i + 1;
    }
    return 0;
}

# ExpandMask: sign-time mask y (L polys), nonces L·κ + ℓ.
fn mldsa_polyvecl_uniform_gamma1(v, seed, nonce_base): i64 {
    var i = 0;
    while (i < MLDSA65_L) {
        mldsa_poly_uniform_gamma1(v + i * 2048, seed, nonce_base + i);
        i = i + 1;
    }
    return 0;
}

# --- mldsa.cyr ---

# mldsa.cyr — ML-DSA-65 keygen / sign / verify (FIPS 204)
#
# The capstone that ties together params, reduce, ntt, poly,
# rounding, sample, and encode into the three public operations
# sigil ships: keypair generation, signature production, and
# signature verification. Reference: pq-crystals/dilithium
# `ref/sign.c`, crypto_sign_keypair / crypto_sign_signature_internal
# / crypto_sign_verify_internal. No randomized-sign mode — sigil
# pins rnd = 0^32 (the FIPS 204 deterministic profile); the
# context prefix is fixed to the empty `(0, 0)` prefix.
#
# Memory: every polyvec / matrix buffer is allocated once at first
# use into module-level globals. Total workspace is ~200 KB; the
# trust boundary is not on the memory-footprint hot path. Globals
# are reused across calls, so callers must complete one operation
# before starting the next (single-threaded). No operation leaves
# secret material in the workspace longer than its own lifetime —
# subsequent calls overwrite the relevant regions.

# ================================================================
# Workspace
# ================================================================

var _mldsa_ws_inited = 0;
var _mldsa_ws_mat = 0;          # K * L * 2048
var _mldsa_ws_s1 = 0;           # L * 2048
var _mldsa_ws_s1hat = 0;        # L * 2048
var _mldsa_ws_s2 = 0;           # K * 2048
var _mldsa_ws_t0 = 0;           # K * 2048
var _mldsa_ws_t1 = 0;           # K * 2048
var _mldsa_ws_y = 0;            # L * 2048
var _mldsa_ws_z = 0;            # L * 2048
var _mldsa_ws_w0 = 0;           # K * 2048
var _mldsa_ws_w1 = 0;           # K * 2048
var _mldsa_ws_h = 0;            # K * 2048
var _mldsa_ws_cp = 0;           # 1 poly
var _mldsa_ws_seedbuf = 0;      # 256 bytes (covers 2·SEED + TR + 2·CRH)
var _mldsa_ws_w1_bytes = 0;     # K · POLYW1_PACKEDBYTES = 768 bytes
var _mldsa_ws_rho = 0;          # 32 bytes
var _mldsa_ws_tr = 0;           # 64 bytes
var _mldsa_ws_mu = 0;           # 64 bytes
var _mldsa_ws_rhoprime = 0;     # 64 bytes
var _mldsa_ws_key = 0;          # 32 bytes
var _mldsa_ws_ctilde = 0;       # CTILDEBYTES = 48
var _mldsa_ws_ctilde2 = 0;      # CTILDEBYTES (verify's recomputed c̃)

# Standalone SHAKE-256 state for the multi-absorb hashes (mu,
# rhoprime, challenge seed). Distinct from the sampling module's
# state so rejection-sampling and hash-absorb don't race.
var _mldsa_sv_state = 0;        # 200 bytes
var _mldsa_sv_pos = 0;

fn _mldsa_ws_init(): i64 {
    if (_mldsa_ws_inited == 1) { return 0; }
    _mldsa_ws_mat = alloc(MLDSA65_K * MLDSA65_L * 256 * 8);
    _mldsa_ws_s1 = alloc(MLDSA65_L * 256 * 8);
    _mldsa_ws_s1hat = alloc(MLDSA65_L * 256 * 8);
    _mldsa_ws_s2 = alloc(MLDSA65_K * 256 * 8);
    _mldsa_ws_t0 = alloc(MLDSA65_K * 256 * 8);
    _mldsa_ws_t1 = alloc(MLDSA65_K * 256 * 8);
    _mldsa_ws_y = alloc(MLDSA65_L * 256 * 8);
    _mldsa_ws_z = alloc(MLDSA65_L * 256 * 8);
    _mldsa_ws_w0 = alloc(MLDSA65_K * 256 * 8);
    _mldsa_ws_w1 = alloc(MLDSA65_K * 256 * 8);
    _mldsa_ws_h = alloc(MLDSA65_K * 256 * 8);
    _mldsa_ws_cp = alloc(256 * 8);
    _mldsa_ws_seedbuf = alloc(256);
    _mldsa_ws_w1_bytes = alloc(MLDSA65_K * MLDSA65_POLYW1_PACKEDBYTES);
    _mldsa_ws_rho = alloc(MLDSA_SEEDBYTES);
    _mldsa_ws_tr = alloc(MLDSA_TRBYTES);
    _mldsa_ws_mu = alloc(MLDSA_CRHBYTES);
    _mldsa_ws_rhoprime = alloc(MLDSA_CRHBYTES);
    _mldsa_ws_key = alloc(MLDSA_SEEDBYTES);
    _mldsa_ws_ctilde = alloc(MLDSA65_CTILDEBYTES);
    _mldsa_ws_ctilde2 = alloc(MLDSA65_CTILDEBYTES);
    _mldsa_sv_state = alloc(200);
    _mldsa_ws_inited = 1;
    return 0;
}

# ================================================================
# Incremental SHAKE-256 (used for mu, rhoprime, and challenge seed)
# ================================================================
# The Cyrius stdlib `shake256` is a one-shot hash-then-squeeze. The
# ML-DSA keygen / sign / verify flows do multi-absorb: `mu =
# SHAKE256(tr ‖ pre ‖ msg)` takes three chunks, `rhoprime` takes
# three, the challenge seed takes two. We keep these tight by
# exposing an init/absorb/finalize/squeeze chain on the
# stdlib-internal `_keccak_f1600` primitive.

fn _mldsa_sv_init(): i64 {
    memset(_mldsa_sv_state, 0, 200);
    _mldsa_sv_pos = 0;
    return 0;
}

fn _mldsa_sv_absorb(data, datalen): i64 {
    var i = 0;
    while (i < datalen) {
        store8(
        _mldsa_sv_state + _mldsa_sv_pos,
        load8(_mldsa_sv_state + _mldsa_sv_pos) ^ load8(data + i)
        );
        _mldsa_sv_pos = _mldsa_sv_pos + 1;
        i = i + 1;
        if (_mldsa_sv_pos == 136) {
            _keccak_f1600(_mldsa_sv_state);
            _mldsa_sv_pos = 0;
        }
    }
    return 0;
}

fn _mldsa_sv_finalize(): i64 {
    store8(
    _mldsa_sv_state + _mldsa_sv_pos,
    load8(_mldsa_sv_state + _mldsa_sv_pos) ^ 0x1F
    );
    store8(_mldsa_sv_state + 135, load8(_mldsa_sv_state + 135) ^ 0x80);
    _keccak_f1600(_mldsa_sv_state);
    _mldsa_sv_pos = 0;
    return 0;
}

fn _mldsa_sv_squeeze(out, outlen): i64 {
    var out_pos = 0;
    while (out_pos < outlen) {
        if (_mldsa_sv_pos == 136) {
            _keccak_f1600(_mldsa_sv_state);
            _mldsa_sv_pos = 0;
        }
        var remain = 136 - _mldsa_sv_pos;
        var take = outlen - out_pos;
        if (take > remain) { take = remain; }
        var j = 0;
        while (j < take) {
            store8(out + out_pos + j, load8(_mldsa_sv_state + _mldsa_sv_pos + j));
            j = j + 1;
        }
        _mldsa_sv_pos = _mldsa_sv_pos + take;
        out_pos = out_pos + take;
    }
    return 0;
}

# ================================================================
# Keypair generation — deterministic from a 32-byte seed
# ================================================================
# seed: caller-provided 32 bytes (use mldsa65_keypair for the
# /dev/urandom-driven convenience wrapper below). Output: pk
# (1952 B), sk (4032 B) buffers pre-allocated by caller.
#
# Steps (FIPS 204 Algorithm 1):
#   1. Expand seed into (rho, rhoprime, key) via SHAKE-256 over
#      seed ‖ K ‖ L (34 bytes in, 128 bytes out).
#   2. Sample matrix A from rho via ExpandA.
#   3. Sample s1 (L polys) + s2 (K polys) from rhoprime via
#      ExpandS (nonces 0..L-1 for s1, L..L+K-1 for s2).
#   4. Compute t = NTT^{-1}(A · NTT(s1)) + s2.
#   5. Split t = t1·2^D + t0 via Power2Round.
#   6. tr = SHAKE-256(pk, 64 bytes).
#   7. Pack pk = rho ‖ t1, sk = rho ‖ key ‖ tr ‖ s1 ‖ s2 ‖ t0.

fn mldsa65_keypair_from_seed(seed, pk, sk): i64 {
    _mldsa_ws_init();

    # Expand seed into (rho, rhoprime, key). Input = seed ‖ K ‖ L.
    memcpy(_mldsa_ws_seedbuf, seed, MLDSA_SEEDBYTES);
    store8(_mldsa_ws_seedbuf + MLDSA_SEEDBYTES + 0, MLDSA65_K);
    store8(_mldsa_ws_seedbuf + MLDSA_SEEDBYTES + 1, MLDSA65_L);
    # Output: 2·SEEDBYTES + CRHBYTES = 128 bytes, in-place back
    # into seedbuf. Layout: rho (32) ‖ rhoprime (64) ‖ key (32).
    shake256(_mldsa_ws_seedbuf, MLDSA_SEEDBYTES + 2, _mldsa_ws_seedbuf, 2 * MLDSA_SEEDBYTES + MLDSA_CRHBYTES);
    memcpy(_mldsa_ws_rho, _mldsa_ws_seedbuf, MLDSA_SEEDBYTES);
    memcpy(_mldsa_ws_rhoprime, _mldsa_ws_seedbuf + MLDSA_SEEDBYTES, MLDSA_CRHBYTES);
    memcpy(_mldsa_ws_key, _mldsa_ws_seedbuf + MLDSA_SEEDBYTES + MLDSA_CRHBYTES, MLDSA_SEEDBYTES);

    # ExpandA, ExpandS.
    mldsa_polyvec_matrix_expand(_mldsa_ws_mat, _mldsa_ws_rho);
    mldsa_polyvecl_uniform_eta(_mldsa_ws_s1, _mldsa_ws_rhoprime, 0);
    mldsa_polyveck_uniform_eta(_mldsa_ws_s2, _mldsa_ws_rhoprime, MLDSA65_L);

    # t1 = NTT^{-1}(A · NTT(s1)) + s2. We stage NTT(s1) in s1hat
    # so the original s1 (needed for sk packing) is preserved.
    var i = 0;
    while (i < MLDSA65_L * 256) {
        store64(_mldsa_ws_s1hat + i * 8, load64(_mldsa_ws_s1 + i * 8));
        i = i + 1;
    }
    mldsa_polyvecl_ntt(_mldsa_ws_s1hat);
    mldsa_polyvec_matrix_pointwise_montgomery(_mldsa_ws_t1, _mldsa_ws_mat, _mldsa_ws_s1hat);
    mldsa_polyveck_reduce(_mldsa_ws_t1);
    mldsa_polyveck_invntt_tomont(_mldsa_ws_t1);
    mldsa_polyveck_add(_mldsa_ws_t1, _mldsa_ws_t1, _mldsa_ws_s2);

    # Split t1 into (t1_high, t0) via Power2Round.
    mldsa_polyveck_caddq(_mldsa_ws_t1);
    mldsa_polyveck_power2round(_mldsa_ws_t1, _mldsa_ws_t0, _mldsa_ws_t1);

    # Assemble pk, then tr = SHAKE-256(pk, 64).
    mldsa_pack_pk(pk, _mldsa_ws_rho, _mldsa_ws_t1);
    shake256(pk, MLDSA65_PK_BYTES, _mldsa_ws_tr, MLDSA_TRBYTES);

    # Assemble sk.
    mldsa_pack_sk(sk, _mldsa_ws_rho, _mldsa_ws_key, _mldsa_ws_tr,
    _mldsa_ws_t0, _mldsa_ws_s1, _mldsa_ws_s2);
    return 0;
}

# Convenience: generate keypair from /dev/urandom. Returns 1 on
# success, 0 if entropy gather fails (partial reads, EOF, etc.)
# — matches ed25519_keypair_from_random's ABI.
fn mldsa65_keypair(pk, sk): i64 {
    secret var seed[32];
    memset(&seed, 0, MLDSA_SEEDBYTES);
    var fd = file_open("/dev/urandom", 0, 0);
    if (fd < 0) { return 0; }
    var got = 0;
    while (got < MLDSA_SEEDBYTES) {
        var n = file_read(fd, (&seed) + got, MLDSA_SEEDBYTES - got);
        if (n <= 0) {
            file_close(fd);
            return 0;
        }
        got = got + n;
    }
    file_close(fd);
    mldsa65_keypair_from_seed(&seed, pk, sk);
    return 1;
}

# ================================================================
# Sign — deterministic (rnd = 0, no context prefix)
# ================================================================
# Produces a 3309-byte signature over `msg` using `sk`.
# The rejection loop iterates until every norm and hint-weight
# check passes; average 4–5 iterations per signature.
#
# Steps:
#   1. unpack_sk.
#   2. mu = SHAKE256(tr ‖ pre ‖ msg), where pre = (0, 0).
#   3. rhoprime = SHAKE256(key ‖ rnd ‖ mu) with rnd = 0^32.
#   4. Expand A; NTT(s1), NTT(s2), NTT(t0).
#   5. Loop: sample y, compute w = A·y; w1 = HighBits(w);
#      c̃ = SHAKE256(mu ‖ pack_w1(w1)); c = SampleInBall(c̃).
#      z = y + c·s1; chknorm(z, γ1 − β); compute w0 − c·s2,
#      chknorm, compute c·t0, chknorm; make hints,
#      chknorm(h, ω); if all checks pass, pack_sig.

# Loop state promoted to globals. Nested calls descend multiple
# layers into montgomery_reduce / SHAKE; locals get clobbered.
var _mldsa_sign_nonce = 0;
var _mldsa_sign_sig = 0;
var _mldsa_sign_sk = 0;

fn mldsa65_sign(sig, msg, msglen, sk): i64 {
    _mldsa_ws_init();
    _mldsa_sign_sig = sig;
    _mldsa_sign_sk = sk;

    # 1. Unpack sk.
    mldsa_unpack_sk(_mldsa_ws_rho, _mldsa_ws_key, _mldsa_ws_tr,
    _mldsa_ws_t0, _mldsa_ws_s1, _mldsa_ws_s2, _mldsa_sign_sk);

    # 2. mu = SHAKE256(tr ‖ 0x00 0x00 ‖ msg).
    _mldsa_sv_init();
    _mldsa_sv_absorb(_mldsa_ws_tr, MLDSA_TRBYTES);
    # pre = (0x00, 0x00) — empty context prefix.
    store8(_mldsa_ws_seedbuf + 0, 0);
    store8(_mldsa_ws_seedbuf + 1, 0);
    _mldsa_sv_absorb(_mldsa_ws_seedbuf, 2);
    _mldsa_sv_absorb(msg, msglen);
    _mldsa_sv_finalize();
    _mldsa_sv_squeeze(_mldsa_ws_mu, MLDSA_CRHBYTES);

    # 3. rhoprime = SHAKE256(key ‖ rnd=0^32 ‖ mu).
    _mldsa_sv_init();
    _mldsa_sv_absorb(_mldsa_ws_key, MLDSA_SEEDBYTES);
    # rnd bytes pinned to zero (deterministic profile).
    memset(_mldsa_ws_seedbuf, 0, MLDSA_RNDBYTES);
    _mldsa_sv_absorb(_mldsa_ws_seedbuf, MLDSA_RNDBYTES);
    _mldsa_sv_absorb(_mldsa_ws_mu, MLDSA_CRHBYTES);
    _mldsa_sv_finalize();
    _mldsa_sv_squeeze(_mldsa_ws_rhoprime, MLDSA_CRHBYTES);

    # 4. Expand matrix and NTT-transform secret vectors.
    mldsa_polyvec_matrix_expand(_mldsa_ws_mat, _mldsa_ws_rho);
    mldsa_polyvecl_ntt(_mldsa_ws_s1);
    mldsa_polyveck_ntt(_mldsa_ws_s2);
    mldsa_polyveck_ntt(_mldsa_ws_t0);

    # 5. Rejection loop.
    _mldsa_sign_nonce = 0;
    var done = 0;
    while (done == 0) {
        # Sample y.
        mldsa_polyvecl_uniform_gamma1(_mldsa_ws_y, _mldsa_ws_rhoprime, _mldsa_sign_nonce);
        _mldsa_sign_nonce = _mldsa_sign_nonce + 1;

        # w = A · NTT(y); z buffer used as staging for NTT(y).
        var i = 0;
        while (i < MLDSA65_L * 256) {
            store64(_mldsa_ws_z + i * 8, load64(_mldsa_ws_y + i * 8));
            i = i + 1;
        }
        mldsa_polyvecl_ntt(_mldsa_ws_z);
        mldsa_polyvec_matrix_pointwise_montgomery(_mldsa_ws_w1, _mldsa_ws_mat, _mldsa_ws_z);
        mldsa_polyveck_reduce(_mldsa_ws_w1);
        mldsa_polyveck_invntt_tomont(_mldsa_ws_w1);

        # Decompose w into (w1, w0).
        mldsa_polyveck_caddq(_mldsa_ws_w1);
        mldsa_polyveck_decompose(_mldsa_ws_w1, _mldsa_ws_w0, _mldsa_ws_w1);
        mldsa_polyveck_pack_w1(_mldsa_ws_w1_bytes, _mldsa_ws_w1);

        # c̃ = SHAKE256(mu ‖ w1_bytes), then c = SampleInBall(c̃).
        _mldsa_sv_init();
        _mldsa_sv_absorb(_mldsa_ws_mu, MLDSA_CRHBYTES);
        _mldsa_sv_absorb(_mldsa_ws_w1_bytes, MLDSA65_K * MLDSA65_POLYW1_PACKEDBYTES);
        _mldsa_sv_finalize();
        _mldsa_sv_squeeze(_mldsa_ws_ctilde, MLDSA65_CTILDEBYTES);
        mldsa_poly_challenge(_mldsa_ws_cp, _mldsa_ws_ctilde);
        mldsa_ntt(_mldsa_ws_cp);

        # z = c · s1 (in NTT domain, then inverse) + y.
        mldsa_polyvecl_pointwise_poly_montgomery(_mldsa_ws_z, _mldsa_ws_cp, _mldsa_ws_s1);
        mldsa_polyvecl_invntt_tomont(_mldsa_ws_z);
        mldsa_polyvecl_add(_mldsa_ws_z, _mldsa_ws_z, _mldsa_ws_y);
        mldsa_polyvecl_reduce(_mldsa_ws_z);
        if (mldsa_polyvecl_chknorm(_mldsa_ws_z, MLDSA65_GAMMA1 - MLDSA65_BETA) == 1) {
            # Rejected: z norm too large. Loop.
        } else {
            # h = c · s2, then w0 = w0 − h; reject if |w0| ≥ γ2 − β.
            mldsa_polyveck_pointwise_poly_montgomery(_mldsa_ws_h, _mldsa_ws_cp, _mldsa_ws_s2);
            mldsa_polyveck_invntt_tomont(_mldsa_ws_h);
            mldsa_polyveck_sub(_mldsa_ws_w0, _mldsa_ws_w0, _mldsa_ws_h);
            mldsa_polyveck_reduce(_mldsa_ws_w0);
            if (mldsa_polyveck_chknorm(_mldsa_ws_w0, MLDSA65_GAMMA2 - MLDSA65_BETA) == 1) {
                # Rejected. Loop.
            } else {
                # h = c · t0; reject if |h| ≥ γ2.
                mldsa_polyveck_pointwise_poly_montgomery(_mldsa_ws_h, _mldsa_ws_cp, _mldsa_ws_t0);
                mldsa_polyveck_invntt_tomont(_mldsa_ws_h);
                mldsa_polyveck_reduce(_mldsa_ws_h);
                if (mldsa_polyveck_chknorm(_mldsa_ws_h, MLDSA65_GAMMA2) == 1) {
                    # Rejected. Loop.
                } else {
                    # Compute hint = make_hint(w0 + c·t0, w1); reject
                    # if weight > ω.
                    mldsa_polyveck_add(_mldsa_ws_w0, _mldsa_ws_w0, _mldsa_ws_h);
                    var weight = mldsa_polyveck_make_hint(_mldsa_ws_h, _mldsa_ws_w0, _mldsa_ws_w1);
                    if (weight > MLDSA65_OMEGA) {
                        # Rejected. Loop.
                    } else {
                        done = 1;
                    }
                }
            }
        }
    }

    # Pack signature: c̃ ‖ z ‖ h.
    mldsa_pack_sig(_mldsa_sign_sig, _mldsa_ws_ctilde, _mldsa_ws_z, _mldsa_ws_h);
    return 0;
}

# ================================================================
# Verify — returns 0 on valid signature, 1 otherwise
# ================================================================
# The sign/verify break points line up with pq-crystals'
# `crypto_sign_verify_internal` (int returning 0/−1 from the C
# ref; we flip to 0/1 to match sigil's other boolean returns).

fn mldsa65_verify(sig, msg, msglen, pk): i64 {
    _mldsa_ws_init();

    # Unpack pk and sig. A malformed sig fails early.
    mldsa_unpack_pk(_mldsa_ws_rho, _mldsa_ws_t1, pk);
    if (mldsa_unpack_sig(_mldsa_ws_ctilde, _mldsa_ws_z, _mldsa_ws_h, sig) == 1) { return 1; }
    # z-norm check: must be strictly < γ1 − β.
    if (mldsa_polyvecl_chknorm(_mldsa_ws_z, MLDSA65_GAMMA1 - MLDSA65_BETA) == 1) { return 1; }

    # Compute mu = SHAKE256( SHAKE256(pk, 64) ‖ pre ‖ msg ).
    shake256(pk, MLDSA65_PK_BYTES, _mldsa_ws_mu, MLDSA_TRBYTES);
    _mldsa_sv_init();
    _mldsa_sv_absorb(_mldsa_ws_mu, MLDSA_TRBYTES);
    store8(_mldsa_ws_seedbuf + 0, 0);
    store8(_mldsa_ws_seedbuf + 1, 0);
    _mldsa_sv_absorb(_mldsa_ws_seedbuf, 2);
    _mldsa_sv_absorb(msg, msglen);
    _mldsa_sv_finalize();
    _mldsa_sv_squeeze(_mldsa_ws_mu, MLDSA_CRHBYTES);

    # c_ntt = NTT(SampleInBall(c̃)).
    mldsa_poly_challenge(_mldsa_ws_cp, _mldsa_ws_ctilde);

    # A · z (in NTT domain).
    mldsa_polyvec_matrix_expand(_mldsa_ws_mat, _mldsa_ws_rho);
    mldsa_polyvecl_ntt(_mldsa_ws_z);
    mldsa_polyvec_matrix_pointwise_montgomery(_mldsa_ws_w1, _mldsa_ws_mat, _mldsa_ws_z);

    # c · 2^D · t1: shift t1 left by D, NTT, then pointwise with c_ntt.
    mldsa_ntt(_mldsa_ws_cp);
    mldsa_polyveck_shiftl(_mldsa_ws_t1);
    mldsa_polyveck_ntt(_mldsa_ws_t1);
    mldsa_polyveck_pointwise_poly_montgomery(_mldsa_ws_t1, _mldsa_ws_cp, _mldsa_ws_t1);

    # w = (A·z) − c·2^D·t1, inverse-NTT.
    mldsa_polyveck_sub(_mldsa_ws_w1, _mldsa_ws_w1, _mldsa_ws_t1);
    mldsa_polyveck_reduce(_mldsa_ws_w1);
    mldsa_polyveck_invntt_tomont(_mldsa_ws_w1);

    # Reconstruct w1 using the hint.
    mldsa_polyveck_caddq(_mldsa_ws_w1);
    mldsa_polyveck_use_hint(_mldsa_ws_w1, _mldsa_ws_w1, _mldsa_ws_h);
    mldsa_polyveck_pack_w1(_mldsa_ws_w1_bytes, _mldsa_ws_w1);

    # Recompute challenge seed c̃' and compare.
    _mldsa_sv_init();
    _mldsa_sv_absorb(_mldsa_ws_mu, MLDSA_CRHBYTES);
    _mldsa_sv_absorb(_mldsa_ws_w1_bytes, MLDSA65_K * MLDSA65_POLYW1_PACKEDBYTES);
    _mldsa_sv_finalize();
    _mldsa_sv_squeeze(_mldsa_ws_ctilde2, MLDSA65_CTILDEBYTES);

    # Constant-time equality: if any byte differs, reject.
    var diff = 0;
    var i = 0;
    while (i < MLDSA65_CTILDEBYTES) {
        diff = diff | ((load8(_mldsa_ws_ctilde + i) & 0xFF) ^ (load8(_mldsa_ws_ctilde2 + i) & 0xFF));
        i = i + 1;
    }
    if (diff != 0) { return 1; }
    return 0;
}

# ================================================================
# Hybrid Ed25519 + ML-DSA-65 verification primitive
# ================================================================
# Gate a message against one, the other, or both algorithms
# according to `required_alg`:
#
#   SIG_ALG_ED25519    — verify ed25519 only; `mldsa_*` may be 0.
#   SIG_ALG_ML_DSA_65  — verify ml-dsa only; `ed_*` may be 0.
#   SIG_ALG_HYBRID     — both must pass (AND).
#
# Ed25519 convention: sig is 64 bytes, pk is 32 bytes.
# ML-DSA-65 convention: sig is MLDSA65_SIG_BYTES, pk is
# MLDSA65_PK_BYTES.
#
# Returns 1 if the requirement is satisfied (all required
# algorithms verify), 0 otherwise. This is the raw crypto gate —
# higher-level verifier logic (trust store, revocation, key pins)
# lives in src/verify.cyr and calls this entry point once it has
# established that the artifact is present and the signer keys
# are known.
fn sigil_verify_hybrid(msg, msg_len, ed_sig, ed_pk, mldsa_sig, mldsa_pk, required_alg): i64 {
    if (required_alg == SIG_ALG_ED25519) {
        return ed25519_verify(ed_pk, msg, msg_len, ed_sig);
    }
    if (required_alg == SIG_ALG_ML_DSA_65) {
        if (mldsa65_verify(mldsa_sig, msg, msg_len, mldsa_pk) == 0) { return 1; }
        return 0;
    }
    if (required_alg == SIG_ALG_HYBRID) {
        if (ed25519_verify(ed_pk, msg, msg_len, ed_sig) != 1) { return 0; }
        if (mldsa65_verify(mldsa_sig, msg, msg_len, mldsa_pk) != 0) { return 0; }
        return 1;
    }
    # Unknown algorithm: fail closed.
    return 0;
}

# --- trust.cyr ---

# trust.cyr — signing, verification, key management
# Ed25519 (RFC 8032) for asymmetric signing, HMAC-SHA256 for symmetric.

# ================================================================
# KeyRole
# ================================================================

enum KeyRole {
    KEY_ROLE_ROOT = 0;
    KEY_ROLE_INTERMEDIATE = 1;
    KEY_ROLE_PUBLISHER = 2;
}

fn key_role_name(role): i64 {
    if (role == KEY_ROLE_ROOT) { return "Root"; }
    if (role == KEY_ROLE_INTERMEDIATE) { return "Intermediate"; }
    if (role == KEY_ROLE_PUBLISHER) { return "Publisher"; }
    return "unknown";
}

# ================================================================
# KeyVersion (96 bytes)
# ================================================================
# Layout:
#   +0   key_id          (C-string ptr)
#   +8   valid_from      (epoch seconds)
#   +16  valid_until     (epoch seconds, 0 = no expiry)
#   +24  public_key_hex  (C-string ptr, 64-char hex)
#   +32  role            (i64 KEY_ROLE_*)
#   +40  issued_by       (C-string ptr, 0 = self-signed)
#   +48  issuer_sig      (ptr to raw bytes, 0 = none)
#   +56  issuer_sig_len  (i64)
#   +64  pub_name        (C-string ptr, 0 = none)
#   +72  pub_contact     (C-string ptr, 0 = none)
#   +80  secret_key      (ptr to 32 raw bytes, 0 = none, for HMAC signing)
#   +88  allowed_types   (vec of ARTIFACT_* i64s, 0 = all types allowed)

fn key_version_new(key_id, public_key_hex): i64 {
    var kv = fl_alloc(96);
    store64(kv, key_id);
    store64(kv + 8, clock_epoch_secs());
    store64(kv + 16, 0);
    store64(kv + 24, public_key_hex);
    store64(kv + 32, KEY_ROLE_PUBLISHER);
    store64(kv + 40, 0);
    store64(kv + 48, 0);
    store64(kv + 56, 0);
    store64(kv + 64, 0);
    store64(kv + 72, 0);
    store64(kv + 80, 0);
    store64(kv + 88, 0);
    return kv;
}

fn kv_key_id(kv): i64 { return load64(kv); }
fn kv_valid_from(kv): i64 { return load64(kv + 8); }
fn kv_valid_until(kv): i64 { return load64(kv + 16); }
fn kv_public_key_hex(kv): i64 { return load64(kv + 24); }
fn kv_role(kv): i64 { return load64(kv + 32); }
fn kv_issued_by(kv): i64 { return load64(kv + 40); }
fn kv_pub_name(kv): i64 { return load64(kv + 64); }
fn kv_pub_contact(kv): i64 { return load64(kv + 72); }
fn kv_secret_key(kv): i64 { return load64(kv + 80); }

fn kv_set_valid_from(kv, v): i64 { store64(kv + 8, v); return kv; }
fn kv_set_valid_until(kv, v): i64 { store64(kv + 16, v); return kv; }
fn kv_set_role(kv, r): i64 { store64(kv + 32, r); return kv; }
fn kv_set_issued_by(kv, v): i64 { store64(kv + 40, v); return kv; }
fn kv_set_pub_name(kv, v): i64 { store64(kv + 64, v); return kv; }
fn kv_set_pub_contact(kv, v): i64 { store64(kv + 72, v); return kv; }
fn kv_set_secret_key(kv, sk): i64 { store64(kv + 80, sk); return kv; }

# Allowed-artifact-type restriction. An unset (0) list means "this key
# is authorized for every ArtifactType" — the Rust `KeyMetadata`
# default. A non-empty list restricts the key to signing only those
# artifact types; any other type fails verification with a dedicated
# "allowed_type" check, independent of the signature itself.
fn kv_allowed_types(kv): i64 { return load64(kv + 88); }

fn kv_add_allowed_type(kv, artifact_type): i64 {
    var v = load64(kv + 88);
    if (v == 0) { v = vec_new(); store64(kv + 88, v); }
    vec_push(v, artifact_type);
    return kv;
}

fn kv_clear_allowed_types(kv): i64 { store64(kv + 88, 0); return kv; }

# Is this key authorized to sign artifacts of `artifact_type`?
# Unrestricted key (no allowed_types list or empty list) → 1.
fn kv_is_type_allowed(kv, artifact_type): i64 {
    var v = load64(kv + 88);
    if (v == 0) { return 1; }
    var n = vec_len(v);
    if (n == 0) { return 1; }
    var i = 0;
    while (i < n) {
        if (vec_get(v, i) == artifact_type) { return 1; }
        i = i + 1;
    }
    return 0;
}

fn kv_is_valid_at(kv, when): i64 {
    if (when < load64(kv + 8)) { return 0; }
    var until = load64(kv + 16);
    if (until != 0) {
        if (when > until) { return 0; }
    }
    return 1;
}

# ================================================================
# PublisherKeyring (16 bytes)
# ================================================================
# Layout:
#   +0   keys_map   (hashmap: key_id -> vec of KeyVersion)
#   +8   keys_dir   (C-string ptr)

fn keyring_new(keys_dir): i64 {
    var kr = fl_alloc(16);
    store64(kr, map_new());
    store64(kr + 8, keys_dir);
    return kr;
}

fn keyring_add_key(kr, kv): i64 {
    var m = load64(kr);
    var kid = kv_key_id(kv);
    var existing = map_get(m, kid);
    if (existing == 0) {
        var v = vec_new();
        vec_push(v, kv);
        map_set(m, kid, v);
    } else {
        vec_push(existing, kv);
    }
    return kr;
}

fn keyring_get_current(kr, key_id): i64 {
    var m = load64(kr);
    var versions = map_get(m, key_id);
    if (versions == 0) { return 0; }
    var now = clock_epoch_secs();
    var vlen = vec_len(versions);
    # Return last valid key
    var i = vlen - 1;
    while (i >= 0) {
        var kv = vec_get(versions, i);
        if (kv_is_valid_at(kv, now) == 1) { return kv; }
        i = i - 1;
    }
    return 0;
}

fn keyring_get_all_versions(kr, key_id): i64 {
    var m = load64(kr);
    var versions = map_get(m, key_id);
    return versions;
}

fn keyring_len(kr): i64 {
    var m = load64(kr);
    return map_count(m);
}

fn keyring_find_by_role(kr, role): i64 {
    var result = vec_new();
    var m = load64(kr);
    var keys = map_keys(m);
    var klen = vec_len(keys);
    var i = 0;
    while (i < klen) {
        var kid = vec_get(keys, i);
        var versions = map_get(m, kid);
        var vlen = vec_len(versions);
        var j = 0;
        while (j < vlen) {
            var kv = vec_get(versions, j);
            if (kv_role(kv) == role) {
                vec_push(result, kv);
            }
            j = j + 1;
        }
        i = i + 1;
    }
    return result;
}

fn keyring_is_empty(kr): i64 {
    if (keyring_len(kr) == 0) { return 1; }
    return 0;
}

# Get key valid at a specific time
fn keyring_get_key_valid_at(kr, key_id, when): i64 {
    var m = load64(kr);
    var versions = map_get(m, key_id);
    if (versions == 0) { return 0; }
    var vlen = vec_len(versions);
    var i = vlen - 1;
    while (i >= 0) {
        var kv = vec_get(versions, i);
        if (kv_is_valid_at(kv, when) == 1) { return kv; }
        i = i - 1;
    }
    return 0;
}

# Get all key IDs in the keyring
fn keyring_key_ids(kr): i64 {
    var m = load64(kr);
    return map_keys(m);
}

# Find keys by publisher name (case-sensitive substring match)
fn keyring_find_by_publisher(kr, name): i64 {
    var result = vec_new();
    var m = load64(kr);
    var keys = map_keys(m);
    var klen = vec_len(keys);
    var nlen = strlen(name);
    var i = 0;
    while (i < klen) {
        var kid = vec_get(keys, i);
        var versions = map_get(m, kid);
        var vlen = vec_len(versions);
        var j = 0;
        while (j < vlen) {
            var kv = vec_get(versions, j);
            var pname = kv_pub_name(kv);
            if (pname != 0) {
                # Simple substring search
                var plen = strlen(pname);
                var k = 0;
                while (k + nlen <= plen) {
                    if (memeq(pname + k, name, nlen) == 1) {
                        vec_push(result, kv);
                        k = plen;  # break
                    }
                    k = k + 1;
                }
            }
            j = j + 1;
        }
        i = i + 1;
    }
    return result;
}

# Rotate key: create new version with overlap period
fn keyring_rotate_key(kr, key_id, new_pk_hex, overlap_until): i64 {
    var new_kv = key_version_new(key_id, new_pk_hex);
    # Set the old key's valid_until to overlap_until
    var m = load64(kr);
    var versions = map_get(m, key_id);
    if (versions != 0) {
        var vlen = vec_len(versions);
        if (vlen > 0) {
            var old_kv = vec_get(versions, vlen - 1);
            kv_set_valid_until(old_kv, overlap_until);
        }
    }
    keyring_add_key(kr, new_kv);
    return new_kv;
}

# Get trust chain from key to root (following issued_by links)
fn keyring_get_chain(kr, key_id): i64 {
    var chain = vec_new();
    var current_id = key_id;
    var max_depth = 10;
    var depth = 0;
    while (current_id != 0) {
        if (depth >= max_depth) { return chain; }
        var kv = keyring_get_current(kr, current_id);
        if (kv == 0) { return chain; }
        vec_push(chain, kv);
        current_id = kv_issued_by(kv);
        if (current_id == 0) { return chain; }
        # Check for self-signed (root)
        if (streq(current_id, key_id) == 1) { return chain; }
        depth = depth + 1;
    }
    return chain;
}

# Validate chain: verify each key was issued by its parent
fn keyring_validate_chain(kr, key_id): i64 {
    var chain = keyring_get_chain(kr, key_id);
    var clen = vec_len(chain);
    if (clen == 0) { return 0; }
    # Last key in chain should be root
    var root = vec_get(chain, clen - 1);
    if (kv_role(root) != KEY_ROLE_ROOT) { return 0; }
    return 1;
}

# Validate key_id as a safe filename:
#   - non-empty, max 64 chars
#   - only [A-Za-z0-9_-] (no '/', '.', or control bytes)
# Returns 1 if safe, 0 otherwise. Prevents path traversal in keyring_save.
fn _is_safe_key_id(kid): i64 {
    if (kid == 0) { return 0; }
    var klen = strlen(kid);
    if (klen == 0) { return 0; }
    if (klen > 64) { return 0; }
    var i = 0;
    while (i < klen) {
        var c = load8(kid + i) & 0xFF;
        var ok = 0;
        if (c >= 48) { if (c <= 57) { ok = 1; } }       # 0-9
        if (c >= 65) { if (c <= 90) { ok = 1; } }       # A-Z
        if (c >= 97) { if (c <= 122) { ok = 1; } }      # a-z
        if (c == 95) { ok = 1; }                        # _
        if (c == 45) { ok = 1; }                        # -
        if (ok == 0) { return 0; }
        i = i + 1;
    }
    return 1;
}

# Save keyring to JSON files in keys_dir.
# Returns count of key versions written. Skips any key_id that
# fails _is_safe_key_id or whose full path exceeds 255 bytes.
fn keyring_save(kr): i64 {
    var keys_dir = load64(kr + 8);
    if (keys_dir == 0) { return 0; }
    var m = load64(kr);
    var kids = map_keys(m);
    var klen = vec_len(kids);
    var count = 0;
    var i = 0;
    while (i < klen) {
        var kid = vec_get(kids, i);
        var versions = map_get(m, kid);
        var vlen = vec_len(versions);
        # Validate key_id — reject path traversal or oversized names
        if (_is_safe_key_id(kid) == 0) { i = i + 1; }
        else {
            var dlen = strlen(keys_dir);
            var kidlen = strlen(kid);
            # dlen + "/" + kidlen + ".json" + NUL
            var need = dlen + 1 + kidlen + 5 + 1;
            if (need > 256) { i = i + 1; }
            else {
                # Write JSON file: keys_dir/key_id.json
                var path = alloc(256);
                var pos = 0;
                memcpy(path, keys_dir, dlen);
                pos = pos + dlen;
                store8(path + pos, 47);  # /
                pos = pos + 1;
                memcpy(path + pos, kid, kidlen);
                pos = pos + kidlen;
                memcpy(path + pos, ".json", 5);
                pos = pos + 5;
                store8(path + pos, 0);

                var fd = file_open(path, 577, 420);  # O_WRONLY|O_CREAT|O_TRUNC, 0644
                if (fd >= 0) {
                    file_write(fd, "[", 1);
                    var j = 0;
                    while (j < vlen) {
                        var kv = vec_get(versions, j);
                        if (j > 0) { file_write(fd, ",", 1); }
                        file_write(fd, "{\"key_id\":\"", 11);
                        json_write_escaped(fd, kv_key_id(kv), strlen(kv_key_id(kv)));
                        file_write(fd, "\",\"public_key_hex\":\"", 20);
                        json_write_escaped(fd, kv_public_key_hex(kv), strlen(kv_public_key_hex(kv)));
                        file_write(fd, "\",\"role\":\"", 10);
                        var rn = key_role_name(kv_role(kv));
                        json_write_escaped(fd, rn, strlen(rn));
                        file_write(fd, "\"}", 2);
                        j = j + 1;
                    }
                    file_write(fd, "]", 1);
                    file_close(fd);
                    count = count + vlen;
                }
                i = i + 1;
            }
        }
    }
    return count;
}

# ================================================================
# JSON string escaping
# ================================================================
# Write `s` (length `slen`) to `fd`, escaping the minimal RFC 8259 set:
# `"`, `\`, and control bytes < 0x20. Non-ASCII bytes pass through
# verbatim (sigil stores UTF-8 path/hex content). Used by persistence
# paths to prevent JSON injection from tampered field values.
fn json_write_escaped(fd, s, slen): i64 {
    if (s == 0) { return 0; }
    var i = 0;
    var chunk_start = 0;
    while (i < slen) {
        var c = load8(s + i) & 0xFF;
        var needs_escape = 0;
        if (c == 34) { needs_escape = 1; }       # "
        elif (c == 92) { needs_escape = 1; }     # \
        elif (c < 32) { needs_escape = 1; }      # control
        if (needs_escape == 1) {
            if (i > chunk_start) {
                file_write(fd, s + chunk_start, i - chunk_start);
            }
            if (c == 34) { file_write(fd, "\\\"", 2); }
            elif (c == 92) { file_write(fd, "\\\\", 2); }
            elif (c == 8) { file_write(fd, "\\b", 2); }
            elif (c == 9) { file_write(fd, "\\t", 2); }
            elif (c == 10) { file_write(fd, "\\n", 2); }
            elif (c == 12) { file_write(fd, "\\f", 2); }
            elif (c == 13) { file_write(fd, "\\r", 2); }
            else {
                # \u00XX for other control bytes
                var hex_buf[6];
                store8(&hex_buf, 92);   # \
                store8(&hex_buf + 1, 117); # u
                store8(&hex_buf + 2, 48);  # 0
                store8(&hex_buf + 3, 48);  # 0
                var hi = (c >> 4) & 0xF;
                var lo = c & 0xF;
                if (hi < 10) { store8(&hex_buf + 4, 48 + hi); }
                else { store8(&hex_buf + 4, 87 + hi); }
                if (lo < 10) { store8(&hex_buf + 5, 48 + lo); }
                else { store8(&hex_buf + 5, 87 + lo); }
                file_write(fd, &hex_buf, 6);
            }
            chunk_start = i + 1;
        }
        i = i + 1;
    }
    if (slen > chunk_start) {
        file_write(fd, s + chunk_start, slen - chunk_start);
    }
    return 0;
}

# ================================================================
# Hash functions
# ================================================================

fn hash_data(data, len): i64 {
    return sha256_hex(data, len);
}

# Dispatch hashing by algorithm (mirrors Rust `hash_data_with`).
# HASH_ALG_SHA256 (default, 32-byte digest) or HASH_ALG_SHA512
# (64-byte digest). Unknown algorithm defaults to SHA-256 rather
# than returning 0 — a trust engine must never silently skip hashing.
fn hash_data_with(data, len, algorithm): i64 {
    if (algorithm == HASH_ALG_SHA512) { return sha512_hex(data, len); }
    return sha256_hex(data, len);
}

fn hash_file(path): i64 {
    var fd = file_open(path, 0, 0);
    if (fd < 0) { return 0; }
    var ctx = sha256_init();
    var buf[4096];
    var n = file_read(fd, &buf, 4096);
    while (n > 0) {
        sha256_update(ctx, &buf, n);
        n = file_read(fd, &buf, 4096);
    }
    file_close(fd);
    var digest[32];
    sha256_finalize(ctx, &digest);
    fl_free(ctx);
    return hex_encode(&digest, 32);
}

# File hash with algorithm selection (mirror of hash_data_with for
# on-disk content). Returns hex C-string, or 0 on file open failure.
# Unknown algorithm falls back to SHA-256 — trust engine must never
# silently skip hashing.
fn hash_file_with(path, algorithm): i64 {
    if (algorithm != HASH_ALG_SHA512) { return hash_file(path); }
    var fd = file_open(path, 0, 0);
    if (fd < 0) { return 0; }
    var ctx = sha512_init();
    var buf[4096];
    var n = file_read(fd, &buf, 4096);
    while (n > 0) {
        sha512_update(ctx, &buf, n);
        n = file_read(fd, &buf, 4096);
    }
    file_close(fd);
    var digest[64];
    sha512_finalize(ctx, &digest);
    fl_free(ctx);
    return hex_encode(&digest, 64);
}

# ================================================================
# Signing / verification (Ed25519)
# ================================================================

fn sign_data(data, len, secret_key): i64 {
    # secret_key is 64 bytes (seed || pk) from ed25519_keypair
    var sig = alloc(64);
    ed25519_sign(secret_key, data, len, sig);
    return sig;
}

fn verify_data(data, len, sig, public_key): i64 {
    # public_key is 32 bytes
    return ed25519_verify(public_key, data, len, sig);
}

# ================================================================
# Key generation (Ed25519)
# ================================================================

fn generate_keypair(sk_out, pk_out): i64 {
    # sk_out: 64 bytes (seed || pk), pk_out: 32 bytes
    # Returns key_id (C-string) on success, 0 on entropy failure.
    # `secret var` zeroizes seed on every return (Cyrius 5.3.5+).
    secret var seed[32];
    memset(&seed, 0, 32);
    var fd = file_open("/dev/urandom", 0, 0);
    if (fd < 0) { return 0; }
    var got = 0;
    while (got < 32) {
        var n = file_read(fd, (&seed) + got, 32 - got);
        if (n <= 0) {
            file_close(fd);
            return 0;
        }
        got = got + n;
    }
    file_close(fd);
    ed25519_keypair(&seed, sk_out, pk_out);

    # key_id = first 16 hex chars of public key
    var hex = hex_encode(pk_out, 32);
    var kid = alloc(17);
    memcpy(kid, hex, 16);
    store8(kid + 16, 0);
    return kid;
}


# ================================================================
# Key zeroization
# ================================================================

fn zeroize_key(key_buf, len): i64 {
    memset(key_buf, 0, len);
    return 0;
}

# --- integrity.cyr ---

# integrity.cyr — file integrity measurement and verification

# ================================================================
# MeasurementStatus
# ================================================================

enum MeasurementStatus {
    MSTATUS_PENDING = 0;
    MSTATUS_VERIFIED = 1;
    MSTATUS_MISMATCH = 2;
    MSTATUS_FILE_NOT_FOUND = 3;
    MSTATUS_ERROR = 4;
}

fn mstatus_name(s): i64 {
    if (s == MSTATUS_PENDING) { return "Pending"; }
    if (s == MSTATUS_VERIFIED) { return "Verified"; }
    if (s == MSTATUS_MISMATCH) { return "Mismatch"; }
    if (s == MSTATUS_FILE_NOT_FOUND) { return "FileNotFound"; }
    if (s == MSTATUS_ERROR) { return "Error"; }
    return "unknown";
}

# ================================================================
# IntegrityMeasurement (24 bytes)
# ================================================================
# Layout:
#   +0   path          (C-string ptr)
#   +8   expected_hash (C-string ptr)
#   +16  status        (i64 MSTATUS_*)
#
# Dropped in 2.6.0: actual_hash, measured_at, error_msg — all write-
# only. The per-verification computed hash is held in the local `h`
# variable during iv_verify_all and never re-read after the status
# decision.

fn measurement_new(path, expected_hash): i64 {
    var m = fl_alloc(24);
    store64(m, path);
    store64(m + 8, expected_hash);
    store64(m + 16, MSTATUS_PENDING);
    return m;
}

fn meas_path(m): i64 { return load64(m); }
fn meas_expected(m): i64 { return load64(m + 8); }
fn meas_status(m): i64 { return load64(m + 16); }

# ================================================================
# IntegrityPolicy (24 bytes)
# ================================================================
# Layout:
#   +0   measurements   (vec of measurement pointers)
#   +8   check_interval (seconds)
#   +16  enforce        (i64, 0 or 1)

fn integrity_policy_new(): i64 {
    var p = fl_alloc(24);
    store64(p, vec_new());
    store64(p + 8, 300);
    store64(p + 16, 0);
    return p;
}

fn ipolicy_check_interval(p): i64 { return load64(p + 8); }
fn ipolicy_enforce(p): i64 { return load64(p + 16); }

fn ipolicy_set_enforce(p, v): i64 { store64(p + 16, v); return p; }
fn ipolicy_set_interval(p, v): i64 { store64(p + 8, v); return p; }

fn ipolicy_add(p, path, expected_hash): i64 {
    var m = measurement_new(path, expected_hash);
    vec_push(load64(p), m);
    return p;
}

fn ipolicy_remove(p, path): i64 {
    var measurements = load64(p);
    var mlen = vec_len(measurements);
    var i = 0;
    while (i < mlen) {
        var m = vec_get(measurements, i);
        if (streq(load64(m), path) == 1) {
            vec_remove(measurements, i);
            return 1;
        }
        i = i + 1;
    }
    return 0;
}

# ================================================================
# IntegrityReport (32 bytes)
# ================================================================
# Layout:
#   +0   total       (i64)
#   +8   verified    (i64)
#   +16  mismatches  (vec)
#   +24  errors      (vec)
#
# Dropped in 2.6.0: checked_at — no read path. Callers can
# clock_epoch_secs() themselves at report time.

fn integrity_report_new(): i64 {
    var r = fl_alloc(32);
    store64(r, 0);
    store64(r + 8, 0);
    store64(r + 16, vec_new());
    store64(r + 24, vec_new());
    return r;
}

fn ireport_total(r): i64 { return load64(r); }
fn ireport_verified(r): i64 { return load64(r + 8); }
fn ireport_mismatches(r): i64 { return load64(r + 16); }
fn ireport_errors(r): i64 { return load64(r + 24); }

fn ireport_is_clean(r): i64 {
    if (vec_len(load64(r + 16)) == 0) {
        if (vec_len(load64(r + 24)) == 0) {
            return 1;
        }
    }
    return 0;
}

# ================================================================
# IntegrityVerifier (24 bytes)
# ================================================================
# Layout:
#   +0   policy       (IntegrityPolicy ptr)
#   +8   last_report  (IntegrityReport ptr, 0 = none)
#   +16  callback     (fn ptr, 0 = none)

fn integrity_verifier_new(policy): i64 {
    var v = fl_alloc(24);
    store64(v, policy);
    store64(v + 8, 0);
    store64(v + 16, 0);
    return v;
}

fn iv_policy(v): i64 { return load64(v); }
fn iv_last_report(v): i64 { return load64(v + 8); }

fn iv_set_callback(v, cb): i64 { store64(v + 16, cb); return v; }
fn iv_clear_callback(v): i64 { store64(v + 16, 0); return v; }

fn iv_set_policy(v, policy): i64 {
    store64(v, policy);
    store64(v + 8, 0);
    return v;
}

# Verify a single file against policy
fn iv_verify_file(v, path): i64 {
    var policy = load64(v);
    var measurements = load64(policy);
    var mlen = vec_len(measurements);
    var i = 0;
    while (i < mlen) {
        var m = vec_get(measurements, i);
        if (streq(load64(m), path) == 1) {
            var h = hash_file(path);
            if (h == 0) { return MSTATUS_FILE_NOT_FOUND; }
            var expected = load64(m + 8);
            if (ct_eq_bytes_lens(h, strlen(h), expected, strlen(expected)) == 1) {
                return MSTATUS_VERIFIED;
            }
            return MSTATUS_MISMATCH;
        }
        i = i + 1;
    }
    return MSTATUS_ERROR;
}

# Verify all files in policy
fn iv_verify_all(v): i64 {
    var policy = load64(v);
    var measurements = load64(policy);
    var mlen = vec_len(measurements);
    var report = integrity_report_new();
    store64(report, mlen);

    var verified = 0;
    var i = 0;
    while (i < mlen) {
        var m = vec_get(measurements, i);
        var path = load64(m);
        var h = hash_file(path);

        if (h == 0) {
            # File not found or error.
            var rm = measurement_new(path, load64(m + 8));
            store64(rm + 16, MSTATUS_FILE_NOT_FOUND);
            vec_push(load64(report + 24), rm);
        } else {
            var expected = load64(m + 8);
            if (ct_eq_bytes_lens(h, strlen(h), expected, strlen(expected)) == 1) {
                verified = verified + 1;
                store64(m + 16, MSTATUS_VERIFIED);
            } else {
                var rm = measurement_new(path, expected);
                store64(rm + 16, MSTATUS_MISMATCH);
                vec_push(load64(report + 16), rm);
            }
        }
        i = i + 1;
    }
    store64(report + 8, verified);
    store64(v + 8, report);
    return report;
}

# Add baseline: hash file and add to policy
fn iv_add_baseline(v, path): i64 {
    var h = hash_file(path);
    if (h == 0) { return 0; }
    var policy = load64(v);
    ipolicy_add(policy, path, h);
    store64(v + 8, 0);
    return h;
}

# Remove baseline
fn iv_remove_baseline(v, path): i64 {
    var policy = load64(v);
    var removed = ipolicy_remove(policy, path);
    if (removed == 1) { store64(v + 8, 0); }
    return removed;
}

# Get tampered files from last report
fn iv_tampered_files(v): i64 {
    var report = load64(v + 8);
    if (report == 0) { return vec_new(); }
    return load64(report + 16);
}

# ================================================================
# IntegritySnapshot — serializable baseline
# ================================================================
# Layout (8 bytes):
#   +0  entries      (vec of {path, hash} pairs)
#
# Dropped in 2.6.0: exported_at — no read path.

fn integrity_snapshot_new(): i64 {
    var s = fl_alloc(8);
    store64(s, vec_new());
    return s;
}

fn isnap_entries(s): i64 { return load64(s); }

# BaselineEntry (16 bytes): path + expected_hash
fn baseline_entry_new(path, expected_hash): i64 {
    var e = fl_alloc(16);
    store64(e, path);
    store64(e + 8, expected_hash);
    return e;
}

fn bentry_path(e): i64 { return load64(e); }
fn bentry_hash(e): i64 { return load64(e + 8); }

# Export current baseline as snapshot
fn iv_export_baseline(v): i64 {
    var policy = load64(v);
    var measurements = load64(policy);
    var snap = integrity_snapshot_new();
    var entries = load64(snap);
    var mlen = vec_len(measurements);
    var i = 0;
    while (i < mlen) {
        var m = vec_get(measurements, i);
        var be = baseline_entry_new(meas_path(m), meas_expected(m));
        vec_push(entries, be);
        i = i + 1;
    }
    return snap;
}

# Import snapshot, replacing current policy measurements
fn iv_import_baseline(v, snap): i64 {
    var policy = load64(v);
    var interval = ipolicy_check_interval(policy);
    var enforce = ipolicy_enforce(policy);

    var new_policy = integrity_policy_new();
    ipolicy_set_interval(new_policy, interval);
    ipolicy_set_enforce(new_policy, enforce);

    var entries = isnap_entries(snap);
    var elen = vec_len(entries);
    var i = 0;
    while (i < elen) {
        var be = vec_get(entries, i);
        ipolicy_add(new_policy, bentry_path(be), bentry_hash(be));
        i = i + 1;
    }
    store64(v, new_policy);
    store64(v + 8, 0);
    return elen;
}


# --- policy.cyr ---

# policy.cyr — revocation list management

# ================================================================
# RevocationEntry (48 bytes)
# ================================================================
# Layout:
#   +0   key_id        (C-string ptr, 0 = none)
#   +8   content_hash  (C-string ptr, 0 = none)
#   +16  reason        (C-string ptr)
#   +24  revoked_at    (epoch seconds)
#   +32  revoked_by    (C-string ptr)
#   +40  revoked_after (epoch seconds, 0 = unconditional)

fn revocation_entry_new(key_id, content_hash, reason, revoked_by): i64 {
    var e = fl_alloc(48);
    store64(e, key_id);
    store64(e + 8, content_hash);
    store64(e + 16, reason);
    store64(e + 24, clock_epoch_secs());
    store64(e + 32, revoked_by);
    store64(e + 40, 0);
    return e;
}

fn rev_key_id(e): i64 { return load64(e); }
fn rev_content_hash(e): i64 { return load64(e + 8); }
fn rev_reason(e): i64 { return load64(e + 16); }
fn rev_at(e): i64 { return load64(e + 24); }
fn rev_by(e): i64 { return load64(e + 32); }
fn rev_after(e): i64 { return load64(e + 40); }
fn rev_set_after(e, v): i64 { store64(e + 40, v); return e; }

# ================================================================
# RevocationList (24 bytes)
# ================================================================
# Layout:
#   +0   entries       (vec of RevocationEntry ptrs)
#   +8   revoked_keys  (hashmap key_id -> 1)
#   +16  revoked_hashes (hashmap content_hash -> 1)

fn revocation_list_new(): i64 {
    var rl = fl_alloc(24);
    store64(rl, vec_new());
    store64(rl + 8, map_new());
    store64(rl + 16, map_new());
    return rl;
}

fn rl_add(rl, entry): i64 {
    var kid = load64(entry);
    var chash = load64(entry + 8);
    if (kid == 0) {
        if (chash == 0) { return ERR_INVALID_INPUT; }
    }
    if (kid != 0) {
        map_set(load64(rl + 8), kid, 1);
    }
    if (chash != 0) {
        map_set(load64(rl + 16), chash, 1);
    }
    vec_push(load64(rl), entry);
    return ERR_NONE;
}

fn rl_is_key_revoked(rl, key_id): i64 {
    return rl_is_key_revoked_at(rl, key_id, 0);
}

fn rl_is_key_revoked_at(rl, key_id, at): i64 {
    var keys = load64(rl + 8);
    if (map_get(keys, key_id) == 0) { return 0; }
    if (at == 0) { return 1; }
    # Check entries for revoked_after semantics
    var entries = load64(rl);
    var elen = vec_len(entries);
    var i = 0;
    while (i < elen) {
        var e = vec_get(entries, i);
        var ekid = load64(e);
        if (ekid != 0) {
            if (streq(ekid, key_id) == 1) {
                var after = load64(e + 40);
                if (after == 0) { return 1; }
                if (at >= after) { return 1; }
            }
        }
        i = i + 1;
    }
    return 0;
}

fn rl_is_artifact_revoked(rl, content_hash): i64 {
    return rl_is_artifact_revoked_at(rl, content_hash, 0);
}

fn rl_is_artifact_revoked_at(rl, content_hash, at): i64 {
    var hashes = load64(rl + 16);
    if (map_get(hashes, content_hash) == 0) { return 0; }
    if (at == 0) { return 1; }
    var entries = load64(rl);
    var elen = vec_len(entries);
    var i = 0;
    while (i < elen) {
        var e = vec_get(entries, i);
        var ehash = load64(e + 8);
        if (ehash != 0) {
            if (streq(ehash, content_hash) == 1) {
                var after = load64(e + 40);
                if (after == 0) { return 1; }
                if (at >= after) { return 1; }
            }
        }
        i = i + 1;
    }
    return 0;
}

fn rl_len(rl): i64 { return vec_len(load64(rl)); }
fn rl_is_empty(rl): i64 { if (rl_len(rl) == 0) { return 1; } return 0; }

fn rl_merge(rl, other): i64 {
    var other_entries = load64(other);
    var olen = vec_len(other_entries);
    var added = 0;
    var i = 0;
    while (i < olen) {
        var e = vec_get(other_entries, i);
        # Check for duplicate
        var dup = 0;
        var our_entries = load64(rl);
        var ulen = vec_len(our_entries);
        var j = 0;
        while (j < ulen) {
            var oe = vec_get(our_entries, j);
            var kid_match = 0;
            var hash_match = 0;
            if (load64(e) == 0) { if (load64(oe) == 0) { kid_match = 1; } }
            else { if (load64(oe) != 0) { if (streq(load64(e), load64(oe)) == 1) { kid_match = 1; } } }
            if (load64(e + 8) == 0) { if (load64(oe + 8) == 0) { hash_match = 1; } }
            else { if (load64(oe + 8) != 0) { if (streq(load64(e + 8), load64(oe + 8)) == 1) { hash_match = 1; } } }
            if (kid_match == 1) { if (hash_match == 1) { dup = 1; } }
            j = j + 1;
        }
        if (dup == 0) {
            rl_add(rl, e);
            added = added + 1;
        }
        i = i + 1;
    }
    return added;
}

# ================================================================
# CRL — Certificate Revocation List (40 bytes)
# ================================================================
# Layout:
#   +0   version     (i64)
#   +8   issuer      (C-string ptr)
#   +16  issued_at   (epoch seconds)
#   +24  next_update (epoch seconds, 0 = none)
#   +32  entries     (vec of RevocationEntry ptrs)

fn crl_new(version, issuer): i64 {
    var c = fl_alloc(40);
    store64(c, version);
    store64(c + 8, issuer);
    store64(c + 16, clock_epoch_secs());
    store64(c + 24, 0);
    store64(c + 32, vec_new());
    return c;
}

fn crl_version(c): i64 { return load64(c); }
fn crl_issuer(c): i64 { return load64(c + 8); }
fn crl_issued_at(c): i64 { return load64(c + 16); }
fn crl_next_update(c): i64 { return load64(c + 24); }
fn crl_entries(c): i64 { return load64(c + 32); }

fn crl_set_next_update(c, v): i64 { store64(c + 24, v); return c; }

fn crl_add_entry(c, entry): i64 {
    vec_push(load64(c + 32), entry);
    return c;
}

fn crl_is_stale(c): i64 {
    var next = load64(c + 24);
    if (next == 0) { return 0; }
    if (clock_epoch_secs() > next) { return 1; }
    return 0;
}

fn crl_apply_to(c, rl): i64 {
    var entries = load64(c + 32);
    var elen = vec_len(entries);
    var added = 0;
    var i = 0;
    while (i < elen) {
        var e = vec_get(entries, i);
        var result = rl_add(rl, e);
        if (result == ERR_NONE) { added = added + 1; }
        i = i + 1;
    }
    return added;
}

# ================================================================
# JSON Lines serialization (RevocationEntry, RevocationList, Crl)
#
# Deliberate format choice: one JSON object per line, newline-
# separated. Cyrius' lib/json.cyr parses a single object at a time
# and has no array support, so JSONL is the cleanest round-trip
# format and matches `alog_save`.  Rust's `to_json()`
# produced a JSON array; JSONL is trivially convertible with
# `jq -s`.
#
# Null fields use JSON `null` (no quotes). Parsing treats `null`,
# empty, and missing fields as 0 (C-string null ptr).
# ================================================================

# Internal: append JSON-escaped version of a C-string to a
# str_builder. Escapes `"`, `\`, and control chars 0x00-0x1F
# per RFC 8259. Without this, a reason like `key "foo" compromised`
# would produce invalid JSON that the parser choked on.
fn _json_escape_cstr(sb, s): i64 {
    var n = strlen(s);
    var i = 0;
    while (i < n) {
        var c = load8(s + i) & 0xFF;
        if (c == 34) { str_builder_add_cstr(sb, "\\\""); }
        elif (c == 92) { str_builder_add_cstr(sb, "\\\\"); }
        elif (c == 10) { str_builder_add_cstr(sb, "\\n"); }
        elif (c == 13) { str_builder_add_cstr(sb, "\\r"); }
        elif (c == 9)  { str_builder_add_cstr(sb, "\\t"); }
        elif (c == 8)  { str_builder_add_cstr(sb, "\\b"); }
        elif (c == 12) { str_builder_add_cstr(sb, "\\f"); }
        elif (c < 32) {
            # \u00XX for any remaining control char
            str_builder_add_cstr(sb, "\\u00");
            var hi = (c >> 4) & 0xF;
            var lo = c & 0xF;
            if (hi < 10) { str_builder_add_byte(sb, 48 + hi); }
            else         { str_builder_add_byte(sb, 87 + hi); }
            if (lo < 10) { str_builder_add_byte(sb, 48 + lo); }
            else         { str_builder_add_byte(sb, 87 + lo); }
        } else {
            str_builder_add_byte(sb, c);
        }
        i = i + 1;
    }
    return 0;
}

# Internal: emit one entry as a JSONL line into a str_builder.
fn _rev_entry_to_jsonl(sb, e): i64 {
    str_builder_add_cstr(sb, "{\"key_id\":");
    if (rev_key_id(e) != 0) {
        str_builder_add_cstr(sb, "\"");
        _json_escape_cstr(sb, rev_key_id(e));
        str_builder_add_cstr(sb, "\"");
    } else {
        str_builder_add_cstr(sb, "null");
    }
    str_builder_add_cstr(sb, ",\"content_hash\":");
    if (rev_content_hash(e) != 0) {
        str_builder_add_cstr(sb, "\"");
        _json_escape_cstr(sb, rev_content_hash(e));
        str_builder_add_cstr(sb, "\"");
    } else {
        str_builder_add_cstr(sb, "null");
    }
    str_builder_add_cstr(sb, ",\"reason\":\"");
    _json_escape_cstr(sb, rev_reason(e));
    str_builder_add_cstr(sb, "\",\"revoked_at\":");
    str_builder_add_int(sb, rev_at(e));
    str_builder_add_cstr(sb, ",\"revoked_by\":\"");
    _json_escape_cstr(sb, rev_by(e));
    str_builder_add_cstr(sb, "\",\"revoked_after\":");
    str_builder_add_int(sb, rev_after(e));
    str_builder_add_cstr(sb, "}\n");
    return 0;
}

# Serialize a RevocationList to a JSONL C-string. Caller owns the
# returned pointer (alloc'd). Returns 0 on OOM (not expected).
fn rl_to_jsonl(rl): i64 {
    var sb = str_builder_new();
    var entries = load64(rl);
    var elen = vec_len(entries);
    var i = 0;
    while (i < elen) {
        _rev_entry_to_jsonl(sb, vec_get(entries, i));
        i = i + 1;
    }
    # Return C-string: copy builder's underlying buf + terminator.
    var total = load64(sb + 8);
    var out = alloc(total + 1);
    memcpy(out, load64(sb), total);
    store8(out + total, 0);
    return out;
}

# Internal: parse the quoted value at data[pos..] where pos is just
# past the opening quote. Returns end offset (just past closing
# quote). Writes a fresh C-string copy of the contents to *out_ptr.
# Sets *out_ptr to 0 and returns pos unchanged if not a quoted str.
var _rj_out_ptr = 0;

fn _rj_parse_string(data, pos, end): i64 {
    _rj_out_ptr = 0;
    if (pos >= end) { return pos; }
    if ((load8(data + pos) & 0xFF) != 34) { return pos; }
    pos = pos + 1;
    # First pass: find closing quote, handling escapes (\" and \\)
    # so an embedded quote does not end the string prematurely.
    var start = pos;
    while (pos < end) {
        var c = load8(data + pos) & 0xFF;
        if (c == 92) {
            # Escape sequence — skip the next char (it's part of the value)
            pos = pos + 2;
        } elif (c == 34) {
            break;
        } else {
            pos = pos + 1;
        }
    }
    # Second pass: copy content, unescaping \x → x for \" \\ \n \r \t \b \f.
    # \uXXXX is rejected as non-ASCII (caller's writer only emits control
    # chars as \uNNNN for bytes < 32; we decode those back to the raw byte).
    var raw_len = pos - start;
    var out = alloc(raw_len + 1);
    var w = 0;
    var r = 0;
    while (r < raw_len) {
        var c = load8(data + start + r) & 0xFF;
        if (c == 92) {
            r = r + 1;
            if (r >= raw_len) { break; }
            var ec = load8(data + start + r) & 0xFF;
            if (ec == 110) { store8(out + w, 10); }     # \n
            elif (ec == 114) { store8(out + w, 13); }   # \r
            elif (ec == 116) { store8(out + w, 9); }    # \t
            elif (ec == 98)  { store8(out + w, 8); }    # \b
            elif (ec == 102) { store8(out + w, 12); }   # \f
            elif (ec == 117) {
                # \uXXXX — read 4 hex digits, emit as byte if ≤ 0xFF
                if (r + 4 < raw_len) {
                    var v = 0;
                    var k = 1;
                    while (k <= 4) {
                        var h = load8(data + start + r + k) & 0xFF;
                        var d = 0;
                        if (h >= 48) { if (h <= 57) { d = h - 48; } }
                        if (h >= 97) { if (h <= 102) { d = h - 87; } }
                        if (h >= 65) { if (h <= 70)  { d = h - 55; } }
                        v = (v << 4) | d;
                        k = k + 1;
                    }
                    store8(out + w, v & 0xFF);
                    r = r + 4;
                }
            } else {
                # \" \\ / and any other → pass through the second char.
                store8(out + w, ec);
            }
            r = r + 1;
            w = w + 1;
        } else {
            store8(out + w, c);
            r = r + 1;
            w = w + 1;
        }
    }
    store8(out + w, 0);
    _rj_out_ptr = out;
    if (pos < end) { pos = pos + 1; }   # skip closing quote
    return pos;
}

# Parse a single JSONL entry line into a fresh RevocationEntry.
# Returns entry ptr, or 0 on malformed input.
fn _rev_entry_from_jsonl(line, llen): i64 {
    # Six fields: key_id, content_hash, reason, revoked_at,
    # revoked_by, revoked_after.  Walk the line in order, matching
    # on the known key names. Tolerant to reordering that survives a
    # round-trip from our own writer.
    var key_id = 0;
    var chash = 0;
    var reason = 0;
    var revoked_by = 0;
    var revoked_at = 0;
    var revoked_after = 0;

    var pos = 0;
    while (pos < llen) {
        var c = load8(line + pos) & 0xFF;
        if (c != 34) { pos = pos + 1; }   # scan for opening quote
        else {
            pos = _rj_parse_string(line, pos, llen);
            var k = _rj_out_ptr;
            if (k == 0) { return 0; }
            # Skip to colon
            while (pos < llen) {
                if ((load8(line + pos) & 0xFF) == 58) { pos = pos + 1; break; }
                pos = pos + 1;
            }
            # Skip whitespace after colon
            while (pos < llen) {
                var cc = load8(line + pos) & 0xFF;
                if (cc == 32) { pos = pos + 1; }
                elif (cc == 9) { pos = pos + 1; }
                else { break; }
            }
            if (pos >= llen) { return 0; }
            var vc = load8(line + pos) & 0xFF;
            if (vc == 34) {
                # Quoted string value
                pos = _rj_parse_string(line, pos, llen);
                var v = _rj_out_ptr;
                if (streq(k, "key_id") == 1) { key_id = v; }
                elif (streq(k, "content_hash") == 1) { chash = v; }
                elif (streq(k, "reason") == 1) { reason = v; }
                elif (streq(k, "revoked_by") == 1) { revoked_by = v; }
            } else {
                # Non-string value: null or integer.
                var vs = pos;
                while (pos < llen) {
                    var vcc = load8(line + pos) & 0xFF;
                    if (vcc == 44) { break; }  # ','
                    if (vcc == 125) { break; } # '}'
                    if (vcc == 32) { break; }
                    if (vcc == 10) { break; }
                    pos = pos + 1;
                }
                var vlen = pos - vs;
                if (vlen > 0) {
                    # Integer fields
                    var intv = 0;
                    # Reject "null" / "true" / "false" by checking first byte.
                    var fb = load8(line + vs) & 0xFF;
                    if (fb >= 48) {
                        if (fb <= 57) {
                            # digit — parse as int
                            var ii = 0;
                            while (ii < vlen) {
                                intv = intv * 10 + ((load8(line + vs + ii) & 0xFF) - 48);
                                ii = ii + 1;
                            }
                        }
                    }
                    if (streq(k, "revoked_at") == 1) { revoked_at = intv; }
                    elif (streq(k, "revoked_after") == 1) { revoked_after = intv; }
                }
            }
        }
    }

    if (reason == 0) { reason = ""; }
    if (revoked_by == 0) { revoked_by = ""; }
    var e = revocation_entry_new(key_id, chash, reason, revoked_by);
    store64(e + 24, revoked_at);
    store64(e + 40, revoked_after);
    return e;
}

# Load a RevocationList from JSONL content. Returns a new list or 0.
# Invalid entries in the stream are skipped rather than aborting —
# callers building a fresh list from a third-party CRL should not
# be taken down by a single malformed line, but each rejected line
# bumps the returned error count.  Well-formed output from our own
# writer always round-trips cleanly.
var _rl_load_bad = 0;

fn rl_load_bad_count(): i64 { return _rl_load_bad; }

fn rl_from_jsonl(content, content_len): i64 {
    _rl_load_bad = 0;
    var rl = revocation_list_new();
    var pos = 0;
    while (pos < content_len) {
        # Find end of line
        var start = pos;
        while (pos < content_len) {
            if ((load8(content + pos) & 0xFF) == 10) { break; }
            pos = pos + 1;
        }
        var llen = pos - start;
        if (llen > 0) {
            var e = _rev_entry_from_jsonl(content + start, llen);
            if (e == 0) { _rl_load_bad = _rl_load_bad + 1; }
            else {
                if (rl_add(rl, e) != ERR_NONE) { _rl_load_bad = _rl_load_bad + 1; }
            }
        }
        if (pos < content_len) { pos = pos + 1; }   # skip '\n'
    }
    return rl;
}

# File wrappers — idiomatic "save/load via path" shortcuts.
fn rl_save(rl, path): i64 {
    var jsonl = rl_to_jsonl(rl);
    var n = file_write_all(path, jsonl, strlen(jsonl));
    if (n < 0) { return ERR_IO; }
    return ERR_NONE;
}

fn rl_load(path): i64 {
    var buf = alloc(65536);
    var n = file_read_all(path, buf, 65536);
    if (n < 0) { return 0; }
    return rl_from_jsonl(buf, n);
}

# ================================================================
# Crl JSON Lines — first line is the header, subsequent lines are
# entries in the same format as rl_to_jsonl.
# ================================================================

fn crl_to_jsonl(c): i64 {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"version\":");
    str_builder_add_int(sb, crl_version(c));
    str_builder_add_cstr(sb, ",\"issuer\":\"");
    _json_escape_cstr(sb, crl_issuer(c));
    str_builder_add_cstr(sb, "\",\"issued_at\":");
    str_builder_add_int(sb, crl_issued_at(c));
    str_builder_add_cstr(sb, ",\"next_update\":");
    str_builder_add_int(sb, crl_next_update(c));
    str_builder_add_cstr(sb, "}\n");
    var entries = crl_entries(c);
    var elen = vec_len(entries);
    var i = 0;
    while (i < elen) {
        _rev_entry_to_jsonl(sb, vec_get(entries, i));
        i = i + 1;
    }
    var total = load64(sb + 8);
    var out = alloc(total + 1);
    memcpy(out, load64(sb), total);
    store8(out + total, 0);
    return out;
}

# Parse the CRL header line. Returns new Crl struct with the entries
# vec initialized empty. Returns 0 on failure.
fn _crl_parse_header(line, llen): i64 {
    var version = 0;
    var issuer = 0;
    var issued_at = 0;
    var next_update = 0;

    var pos = 0;
    while (pos < llen) {
        var c = load8(line + pos) & 0xFF;
        if (c != 34) { pos = pos + 1; }
        else {
            pos = _rj_parse_string(line, pos, llen);
            var k = _rj_out_ptr;
            if (k == 0) { return 0; }
            while (pos < llen) {
                if ((load8(line + pos) & 0xFF) == 58) { pos = pos + 1; break; }
                pos = pos + 1;
            }
            while (pos < llen) {
                var cc = load8(line + pos) & 0xFF;
                if (cc == 32) { pos = pos + 1; }
                elif (cc == 9) { pos = pos + 1; }
                else { break; }
            }
            if (pos >= llen) { return 0; }
            var vc = load8(line + pos) & 0xFF;
            if (vc == 34) {
                pos = _rj_parse_string(line, pos, llen);
                if (streq(k, "issuer") == 1) { issuer = _rj_out_ptr; }
            } else {
                var vs = pos;
                while (pos < llen) {
                    var vcc = load8(line + pos) & 0xFF;
                    if (vcc == 44) { break; }
                    if (vcc == 125) { break; }
                    pos = pos + 1;
                }
                var vlen = pos - vs;
                var intv = 0;
                if (vlen > 0) {
                    var fb = load8(line + vs) & 0xFF;
                    if (fb >= 48) { if (fb <= 57) {
                            var ii = 0;
                            while (ii < vlen) {
                                intv = intv * 10 + ((load8(line + vs + ii) & 0xFF) - 48);
                                ii = ii + 1;
                            }
                        } }
                }
                if (streq(k, "version") == 1) { version = intv; }
                elif (streq(k, "issued_at") == 1) { issued_at = intv; }
                elif (streq(k, "next_update") == 1) { next_update = intv; }
            }
        }
    }
    if (issuer == 0) { return 0; }
    var c = crl_new(version, issuer);
    store64(c + 16, issued_at);
    store64(c + 24, next_update);
    return c;
}

# Parse CRL from JSONL content. First line = header, subsequent
# lines = revocation entries.
fn crl_from_jsonl(content, content_len): i64 {
    # Extract first line
    var hend = 0;
    while (hend < content_len) {
        if ((load8(content + hend) & 0xFF) == 10) { break; }
        hend = hend + 1;
    }
    if (hend == 0) { return 0; }
    var c = _crl_parse_header(content, hend);
    if (c == 0) { return 0; }
    # Entries start after the header newline
    var pos = hend + 1;
    while (pos < content_len) {
        var start = pos;
        while (pos < content_len) {
            if ((load8(content + pos) & 0xFF) == 10) { break; }
            pos = pos + 1;
        }
        var llen = pos - start;
        if (llen > 0) {
            var e = _rev_entry_from_jsonl(content + start, llen);
            if (e != 0) { crl_add_entry(c, e); }
        }
        if (pos < content_len) { pos = pos + 1; }
    }
    return c;
}

fn crl_save(c, path): i64 {
    var jsonl = crl_to_jsonl(c);
    var n = file_write_all(path, jsonl, strlen(jsonl));
    if (n < 0) { return ERR_IO; }
    return ERR_NONE;
}

fn crl_load(path): i64 {
    var buf = alloc(65536);
    var n = file_read_all(path, buf, 65536);
    if (n < 0) { return 0; }
    return crl_from_jsonl(buf, n);
}

# --- audit.cyr ---

# audit.cyr — structured audit event logging

# ================================================================
# AuditEvent types
# ================================================================

enum AuditEventType {
    AUDIT_ARTIFACT_VERIFIED = 0;
    AUDIT_ARTIFACT_SIGNED = 1;
    AUDIT_REVOCATION_ADDED = 2;
    AUDIT_KEY_ROTATED = 3;
    AUDIT_CHAIN_VALIDATED = 4;
}

fn audit_event_name(t): i64 {
    if (t == AUDIT_ARTIFACT_VERIFIED) { return "artifact_verified"; }
    if (t == AUDIT_ARTIFACT_SIGNED) { return "artifact_signed"; }
    if (t == AUDIT_REVOCATION_ADDED) { return "revocation_added"; }
    if (t == AUDIT_KEY_ROTATED) { return "key_rotated"; }
    if (t == AUDIT_CHAIN_VALIDATED) { return "chain_validated"; }
    return "unknown";
}

# Inverse of audit_event_name. Returns the AUDIT_* constant for a
# known name, or -1 if the string does not match any known event.
fn audit_event_type_from_name(name): i64 {
    if (streq(name, "artifact_verified") == 1) { return AUDIT_ARTIFACT_VERIFIED; }
    if (streq(name, "artifact_signed") == 1) { return AUDIT_ARTIFACT_SIGNED; }
    if (streq(name, "revocation_added") == 1) { return AUDIT_REVOCATION_ADDED; }
    if (streq(name, "key_rotated") == 1) { return AUDIT_KEY_ROTATED; }
    if (streq(name, "chain_validated") == 1) { return AUDIT_CHAIN_VALIDATED; }
    return (0 - 1);
}

# ================================================================
# AuditEvent (64 bytes)
# ================================================================
# Generic event struct that holds all possible fields.
# Layout:
#   +0   event_type    (i64 AUDIT_*)
#   +8   path          (C-string ptr, 0 = n/a)
#   +16  artifact_type (i64, -1 = n/a)
#   +24  trust_level   (i64, -1 = n/a)
#   +32  passed        (i64, -1 = n/a)
#   +40  content_hash  (C-string ptr, 0 = n/a)
#   +48  key_id        (C-string ptr, 0 = n/a)
#   +56  timestamp     (epoch seconds)

fn audit_event_new(event_type): i64 {
    var e = fl_alloc(64);
    store64(e, event_type);
    store64(e + 8, 0);
    store64(e + 16, 0 - 1);
    store64(e + 24, 0 - 1);
    store64(e + 32, 0 - 1);
    store64(e + 40, 0);
    store64(e + 48, 0);
    store64(e + 56, clock_epoch_secs());
    return e;
}

fn ae_type(e): i64 { return load64(e); }
fn ae_path(e): i64 { return load64(e + 8); }
fn ae_artifact_type(e): i64 { return load64(e + 16); }
fn ae_trust_level(e): i64 { return load64(e + 24); }
fn ae_passed(e): i64 { return load64(e + 32); }
fn ae_content_hash(e): i64 { return load64(e + 40); }
fn ae_key_id(e): i64 { return load64(e + 48); }
fn ae_timestamp(e): i64 { return load64(e + 56); }

fn ae_set_path(e, v): i64 { store64(e + 8, v); return e; }
fn ae_set_artifact_type(e, v): i64 { store64(e + 16, v); return e; }
fn ae_set_trust_level(e, v): i64 { store64(e + 24, v); return e; }
fn ae_set_passed(e, v): i64 { store64(e + 32, v); return e; }
fn ae_set_content_hash(e, v): i64 { store64(e + 40, v); return e; }
fn ae_set_key_id(e, v): i64 { store64(e + 48, v); return e; }

# ================================================================
# Convenience constructors
# ================================================================

fn audit_artifact_verified(path, atype, tlevel, passed, chash): i64 {
    var e = audit_event_new(AUDIT_ARTIFACT_VERIFIED);
    ae_set_path(e, path);
    ae_set_artifact_type(e, atype);
    ae_set_trust_level(e, tlevel);
    ae_set_passed(e, passed);
    ae_set_content_hash(e, chash);
    return e;
}

fn audit_artifact_signed(path, atype, key_id, chash): i64 {
    var e = audit_event_new(AUDIT_ARTIFACT_SIGNED);
    ae_set_path(e, path);
    ae_set_artifact_type(e, atype);
    ae_set_key_id(e, key_id);
    ae_set_content_hash(e, chash);
    return e;
}

fn audit_revocation_added(key_id, chash, reason): i64 {
    var e = audit_event_new(AUDIT_REVOCATION_ADDED);
    ae_set_key_id(e, key_id);
    ae_set_content_hash(e, chash);
    return e;
}

fn audit_key_rotated(old_kid, new_kid): i64 {
    var e = audit_event_new(AUDIT_KEY_ROTATED);
    ae_set_key_id(e, old_kid);
    ae_set_content_hash(e, new_kid);  # reuse field for new key id
    return e;
}

# ================================================================
# AuditLog (8 bytes)
# ================================================================
# Layout:
#   +0   events  (vec of AuditEvent ptrs)

fn audit_log_new(): i64 {
    var log = fl_alloc(8);
    store64(log, vec_new());
    return log;
}

fn alog_record(log, event): i64 {
    vec_push(load64(log), event);
    return log;
}

fn alog_events(log): i64 { return load64(log); }
fn alog_len(log): i64 { return vec_len(load64(log)); }
fn alog_is_empty(log): i64 { if (alog_len(log) == 0) { return 1; } return 0; }

fn alog_clear(log): i64 {
    store64(log, vec_new());
    return log;
}

# Append audit events to file (one JSON line per event).
# Renamed from alog_append_to_file in 3.0 to match the rl_save /
# crl_save / sv_save_trust_store vocabulary. Still O_APPEND under
# the hood — the name reflects the contract (persist to disk),
# not the write mode.
fn alog_save(log, path): i64 {
    var fd = file_open(path, 1089, 420);  # O_WRONLY|O_CREAT|O_APPEND, 0644
    if (fd < 0) { return ERR_IO; }
    var events = load64(log);
    var elen = vec_len(events);
    var i = 0;
    while (i < elen) {
        var e = vec_get(events, i);
        # Simple JSON line: {"type":"...","timestamp":...}
        var line = alloc(512);
        var pos = 0;
        pos = pos + _alog_write_str(line + pos, "{\"type\":\"");
        pos = pos + _alog_write_str(line + pos, audit_event_name(ae_type(e)));
        pos = pos + _alog_write_str(line + pos, "\",\"timestamp\":");
        pos = pos + _alog_write_int(line + pos, ae_timestamp(e));
        if (ae_path(e) != 0) {
            pos = pos + _alog_write_str(line + pos, ",\"path\":\"");
            pos = pos + _alog_write_str(line + pos, ae_path(e));
            pos = pos + _alog_write_str(line + pos, "\"");
        }
        if (ae_key_id(e) != 0) {
            pos = pos + _alog_write_str(line + pos, ",\"key_id\":\"");
            pos = pos + _alog_write_str(line + pos, ae_key_id(e));
            pos = pos + _alog_write_str(line + pos, "\"");
        }
        if (ae_content_hash(e) != 0) {
            pos = pos + _alog_write_str(line + pos, ",\"content_hash\":\"");
            pos = pos + _alog_write_str(line + pos, ae_content_hash(e));
            pos = pos + _alog_write_str(line + pos, "\"");
        }
        if (ae_passed(e) != (0 - 1)) {
            pos = pos + _alog_write_str(line + pos, ",\"passed\":");
            if (ae_passed(e) == 1) { pos = pos + _alog_write_str(line + pos, "true"); }
            else { pos = pos + _alog_write_str(line + pos, "false"); }
        }
        pos = pos + _alog_write_str(line + pos, "}\n");
        store8(line + pos, 0);
        file_write(fd, line, pos);
        i = i + 1;
    }
    file_close(fd);
    return ERR_NONE;
}

fn _alog_write_str(dst, src): i64 {
    var len = strlen(src);
    memcpy(dst, src, len);
    return len;
}

# ================================================================
# alog_load(log, path) — inverse of alog_save. Renamed from
# alog_load_from_file in 3.0.
#
# Reads JSONL (one event per line) from `path`, parses each line
# as a flat JSON object, and pushes an AuditEvent into `log`. Lines
# with an unknown `type` are skipped — forensic replay must not
# abort on an unknown event that a newer writer produced.
#
# Reuses `_rj_parse_string` from policy.cyr (same compilation unit)
# for escape-aware string decoding, matching what
# `json_write_escaped` emitted on the writer side.
#
# Returns the number of events loaded, or -1 on IO failure.
# ================================================================

fn _alog_parse_one_line(log, line, llen): i64 {
    var etype = 0 - 1;
    var apath = 0;
    var kid = 0;
    var chash = 0;
    var passed = 0 - 1;
    var ts = 0;

    var pos = 0;
    while (pos < llen) {
        var c = load8(line + pos) & 0xFF;
        if (c != 34) { pos = pos + 1; }
        else {
            pos = _rj_parse_string(line, pos, llen);
            var k = _rj_out_ptr;
            if (k == 0) { break; }
            # Skip to colon
            while (pos < llen) {
                if ((load8(line + pos) & 0xFF) == 58) { pos = pos + 1; break; }
                pos = pos + 1;
            }
            # Skip whitespace
            while (pos < llen) {
                var ws = load8(line + pos) & 0xFF;
                if (ws == 32) { pos = pos + 1; }
                elif (ws == 9) { pos = pos + 1; }
                else { break; }
            }
            if (pos >= llen) { break; }
            var vc = load8(line + pos) & 0xFF;
            if (vc == 34) {
                pos = _rj_parse_string(line, pos, llen);
                var v = _rj_out_ptr;
                if (streq(k, "type") == 1) { etype = audit_event_type_from_name(v); }
                elif (streq(k, "path") == 1) { apath = v; }
                elif (streq(k, "key_id") == 1) { kid = v; }
                elif (streq(k, "content_hash") == 1) { chash = v; }
            } else {
                # Literal: true / false / number
                var vs = pos;
                while (pos < llen) {
                    var vcc = load8(line + pos) & 0xFF;
                    if (vcc == 44) { break; }
                    if (vcc == 125) { break; }
                    if (vcc == 32) { break; }
                    if (vcc == 10) { break; }
                    pos = pos + 1;
                }
                var vlen = pos - vs;
                if (vlen > 0) {
                    var fb = load8(line + vs) & 0xFF;
                    if (fb == 116) {
                        # "true"
                        if (streq(k, "passed") == 1) { passed = 1; }
                    } elif (fb == 102) {
                        # "false"
                        if (streq(k, "passed") == 1) { passed = 0; }
                    } elif (fb >= 48) {
                        if (fb <= 57) {
                            var intv = 0;
                            var ii = 0;
                            while (ii < vlen) {
                                var ch = load8(line + vs + ii) & 0xFF;
                                if (ch >= 48) { if (ch <= 57) { intv = intv * 10 + (ch - 48); } }
                                ii = ii + 1;
                            }
                            if (streq(k, "timestamp") == 1) { ts = intv; }
                        }
                    }
                }
            }
        }
    }

    if (etype < 0) { return 0; }   # unknown event type; skip

    var e = audit_event_new(etype);
    if (apath != 0) { ae_set_path(e, apath); }
    if (kid != 0) { ae_set_key_id(e, kid); }
    if (chash != 0) { ae_set_content_hash(e, chash); }
    if (passed != (0 - 1)) { ae_set_passed(e, passed); }
    store64(e + 56, ts);    # timestamp
    alog_record(log, e);
    return 1;
}

fn alog_load(log, path): i64 {
    var buf = alloc(65536);
    var n = file_read_all(path, buf, 65536);
    if (n < 0) { return (0 - 1); }
    var loaded = 0;
    var pos = 0;
    while (pos < n) {
        var start = pos;
        while (pos < n) {
            if ((load8(buf + pos) & 0xFF) == 10) { break; }
            pos = pos + 1;
        }
        var llen = pos - start;
        if (llen > 0) {
            if (_alog_parse_one_line(log, buf + start, llen) == 1) {
                loaded = loaded + 1;
            }
        }
        if (pos < n) { pos = pos + 1; }   # skip '\n'
    }
    return loaded;
}

# Global to survive nested calls
var _alog_int_buf = 0;

fn _alog_write_int(dst, val): i64 {
    if (_alog_int_buf == 0) { _alog_int_buf = alloc(24); }
    # Manual int-to-string into global buffer
    var v = val;
    var pos = 23;
    store8(_alog_int_buf + pos, 0);
    pos = pos - 1;
    if (v == 0) {
        store8(_alog_int_buf + pos, 48);
        pos = pos - 1;
    } else {
        while (v > 0) {
            store8(_alog_int_buf + pos, 48 + (v % 10));
            v = v / 10;
            pos = pos - 1;
        }
    }
    pos = pos + 1;
    var len = 23 - pos;
    memcpy(dst, _alog_int_buf + pos, len);
    return len;
}

# --- verify.cyr ---

# verify.cyr — SigilVerifier: the main trust engine
# Combines signing, keyring, integrity, revocation, key pinning, audit.

# ================================================================
# KeyPin (16 bytes)
# ================================================================
# Layout:
#   +0   key_id       (C-string ptr)
#   +8   path_prefix  (C-string ptr)

fn key_pin_new(key_id, path_prefix): i64 {
    var kp = fl_alloc(16);
    store64(kp, key_id);
    store64(kp + 8, path_prefix);
    return kp;
}

fn kpin_key_id(kp): i64 { return load64(kp); }
fn kpin_prefix(kp): i64 { return load64(kp + 8); }

# ================================================================
# ComplianceReport (56 bytes)
# ================================================================
# Layout:
#   +0   total            (i64)
#   +8   compliant_count  (i64)
#   +16  compliant        (vec)
#   +24  below_minimum    (vec)
#   +32  unsigned_list    (vec)
#   +40  revoked_list     (vec)
#   +48  pin_violations   (vec)

fn compliance_report_new(): i64 {
    var cr = fl_alloc(56);
    store64(cr, 0);
    store64(cr + 8, 0);
    store64(cr + 16, vec_new());
    store64(cr + 24, vec_new());
    store64(cr + 32, vec_new());
    store64(cr + 40, vec_new());
    store64(cr + 48, vec_new());
    return cr;
}

fn creport_total(cr): i64 { return load64(cr); }
fn creport_compliant_count(cr): i64 { return load64(cr + 8); }
fn creport_is_compliant(cr): i64 {
    if (load64(cr + 8) == load64(cr)) { return 1; }
    return 0;
}
fn creport_violation_count(cr): i64 {
    return load64(cr) - load64(cr + 8);
}

# ================================================================
# SigilVerifier (56 bytes)
# ================================================================
# Layout:
#   +0   keyring       (PublisherKeyring ptr)
#   +8   policy        (TrustPolicy ptr)
#   +16  revocations   (RevocationList ptr)
#   +24  integrity     (IntegrityVerifier ptr)
#   +32  trust_store   (hashmap: content_hash -> TrustedArtifact)
#   +40  key_pins      (vec of KeyPin)
#   +48  audit_log     (AuditLog ptr)

fn sigil_verifier_new(keyring, policy): i64 {
    var sv = fl_alloc(56);
    store64(sv, keyring);
    store64(sv + 8, policy);
    store64(sv + 16, revocation_list_new());
    store64(sv + 24, integrity_verifier_new(integrity_policy_new()));
    store64(sv + 32, map_new());
    store64(sv + 40, vec_new());
    store64(sv + 48, audit_log_new());
    return sv;
}

fn sv_keyring(sv): i64 { return load64(sv); }
fn sv_policy(sv): i64 { return load64(sv + 8); }
fn sv_revocations(sv): i64 { return load64(sv + 16); }
fn sv_integrity(sv): i64 { return load64(sv + 24); }
fn sv_trust_store(sv): i64 { return load64(sv + 32); }
fn sv_key_pins(sv): i64 { return load64(sv + 40); }
fn sv_audit_log(sv): i64 { return load64(sv + 48); }

# ================================================================
# Key pin management
# ================================================================

fn sv_add_key_pin(sv, pin): i64 {
    vec_push(load64(sv + 40), pin);
    return sv;
}

fn sv_remove_key_pins(sv, path_prefix): i64 {
    var pins = load64(sv + 40);
    var plen = vec_len(pins);
    var removed = 0;
    var i = plen - 1;
    while (i >= 0) {
        var pin = vec_get(pins, i);
        if (streq(kpin_prefix(pin), path_prefix) == 1) {
            vec_remove(pins, i);
            removed = removed + 1;
        }
        i = i - 1;
    }
    return removed;
}

# Check if key is authorized for path (no pin = any key OK)
fn _sv_key_authorized(sv, path, signer_key_id): i64 {
    var pins = load64(sv + 40);
    var plen = vec_len(pins);
    var has_matching_pin = 0;
    var path_len = 0;
    if (path != 0) { path_len = strlen(path); }
    var i = 0;
    while (i < plen) {
        var pin = vec_get(pins, i);
        var prefix = kpin_prefix(pin);
        var plen2 = strlen(prefix);
        # Guard against OOB read: memeq reads plen2 bytes from path,
        # so path must be at least that long.
        if (path_len >= plen2) {
            if (memeq(path, prefix, plen2) == 1) {
                has_matching_pin = 1;
                if (signer_key_id != 0) {
                    if (streq(kpin_key_id(pin), signer_key_id) == 1) {
                        return 1;
                    }
                }
            }
        }
        i = i + 1;
    }
    if (has_matching_pin == 0) { return 1; }
    return 0;
}

# ================================================================
# Register artifacts in trust store
# ================================================================

fn sv_register_trusted(sv, artifact): i64 {
    # Downgrade SystemCore to Verified (only register_system_core allows SystemCore)
    if (artifact_trust_level(artifact) == TRUST_SYSTEM_CORE) {
        artifact_set_trust_level(artifact, TRUST_VERIFIED);
    }
    var chash = artifact_content_hash(artifact);
    map_set(load64(sv + 32), chash, artifact);
    return sv;
}

fn sv_register_system_core(sv, artifact): i64 {
    artifact_set_trust_level(artifact, TRUST_SYSTEM_CORE);
    var chash = artifact_content_hash(artifact);
    map_set(load64(sv + 32), chash, artifact);
    return sv;
}

# ================================================================
# Sign an artifact and register it
# ================================================================

fn sv_sign_artifact(sv, path, secret_key, key_id, artifact_type): i64 {
    var chash = hash_file(path);
    if (chash == 0) { return 0; }

    var sig = sign_data(chash, strlen(chash), secret_key);
    var artifact = trusted_artifact_new(path, artifact_type, chash);
    artifact_set_signature(artifact, sig);
    artifact_set_signer(artifact, key_id);
    artifact_set_trust_level(artifact, TRUST_VERIFIED);

    map_set(load64(sv + 32), chash, artifact);

    # Audit
    var ae = audit_artifact_signed(path, artifact_type, key_id, chash);
    alog_record(load64(sv + 48), ae);

    return artifact;
}

# ================================================================
# Verify an artifact
# ================================================================

fn sv_verify_artifact(sv, path, artifact_type): i64 {
    var policy = load64(sv + 8);
    var chash = hash_file(path);
    if (chash == 0) {
        return verification_result_new(
        trusted_artifact_new(path, artifact_type, ""),
        0, clock_epoch_secs()
        );
    }

    var trust_level = TRUST_UNVERIFIED;
    var vr = verification_result_new(
    trusted_artifact_new(path, artifact_type, chash),
    1, clock_epoch_secs()
    );

    # Check: file readable
    vresult_add_check(vr, trust_check_new("file_readable", 1, "File read successfully"));

    # Check: trust store lookup
    var store = load64(sv + 32);
    var stored = map_get(store, chash);
    if (stored != 0) {
        trust_level = artifact_trust_level(stored);
        vresult_add_check(vr, trust_check_new("trust_store", 1, "Found in trust store"));
    } else {
        vresult_add_check(vr, trust_check_new("trust_store", 0, "Not in trust store"));
    }

    # Check: signature verification
    if (stored != 0) {
        var sig = artifact_signature(stored);
        var signer = artifact_signer_key_id(stored);
        if (sig != 0) {
            if (signer != 0) {
                var kr = load64(sv);
                var kv = keyring_get_current(kr, signer);
                if (kv != 0) {
                    var pk = kv_public_key_hex(kv);
                    if (pk != 0) {
                        if (strlen(pk) != 64) {
                            trust_level = TRUST_UNVERIFIED;
                            vresult_add_check(vr, trust_check_new("signature", 0, "Public key hex wrong length"));
                        } else {
                            var pk_bytes = hex_decode(pk, 64);
                            if (pk_bytes == 0) {
                                trust_level = TRUST_UNVERIFIED;
                                vresult_add_check(vr, trust_check_new("signature", 0, "Public key hex invalid"));
                            } else {
                                var valid = verify_data(chash, strlen(chash), sig, pk_bytes);
                                if (valid == 1) {
                                    if (trust_level_rank(trust_level) < trust_level_rank(TRUST_VERIFIED)) {
                                        trust_level = TRUST_VERIFIED;
                                    }
                                    vresult_add_check(vr, trust_check_new("signature", 1, "Signature valid"));
                                } else {
                                    trust_level = TRUST_UNVERIFIED;
                                    vresult_add_check(vr, trust_check_new("signature", 0, "Signature invalid"));
                                }
                            }
                        }
                    } else {
                        vresult_add_check(vr, trust_check_new("signature", 0, "No public key for verification"));
                    }
                } else {
                    vresult_add_check(vr, trust_check_new("signature", 0, "Signer key not in keyring"));
                }
            } else {
                vresult_add_check(vr, trust_check_new("signature", 0, "No signer key ID"));
            }
        } else {
            vresult_add_check(vr, trust_check_new("signature", 0, "No signature"));
        }
    } else {
        vresult_add_check(vr, trust_check_new("signature", 0, "Not in trust store"));
    }

    # Check: revocation
    var rl = load64(sv + 16);
    var key_revoked = 0;
    var hash_revoked = rl_is_artifact_revoked(rl, chash);
    if (stored != 0) {
        var signer = artifact_signer_key_id(stored);
        if (signer != 0) {
            key_revoked = rl_is_key_revoked(rl, signer);
        }
    }
    if (key_revoked == 1) {
        trust_level = TRUST_REVOKED;
        vresult_add_check(vr, trust_check_new("revocation", 0, "Signer key revoked"));
    } elif (hash_revoked == 1) {
        trust_level = TRUST_REVOKED;
        vresult_add_check(vr, trust_check_new("revocation", 0, "Content hash revoked"));
    } else {
        vresult_add_check(vr, trust_check_new("revocation", 1, "Not revoked"));
    }

    # Check: key pinning
    if (stored != 0) {
        var signer = artifact_signer_key_id(stored);
        var authorized = _sv_key_authorized(sv, path, signer);
        if (authorized == 1) {
            vresult_add_check(vr, trust_check_new("key_pin", 1, "Key authorized"));
        } else {
            vresult_add_check(vr, trust_check_new("key_pin", 0, "Key not authorized for path"));
            trust_level = TRUST_UNVERIFIED;
        }
    }

    # Check: allowed-artifact-type (Rust KeyMetadata.allowed_artifact_types).
    # If the signer key has an explicit allow-list, the artifact_type must
    # appear in it. Unrestricted keys (empty/null list) pass through.
    # Rejected here → trust_level UNVERIFIED regardless of signature.
    if (stored != 0) {
        var signer_atype = artifact_signer_key_id(stored);
        if (signer_atype != 0) {
            var kra = load64(sv);
            var kva = keyring_get_current(kra, signer_atype);
            if (kva != 0) {
                if (kv_is_type_allowed(kva, artifact_type) == 1) {
                    vresult_add_check(vr, trust_check_new("allowed_type", 1, "Key authorized for artifact type"));
                } else {
                    vresult_add_check(vr, trust_check_new("allowed_type", 0, "Key not authorized for artifact type"));
                    trust_level = TRUST_UNVERIFIED;
                }
            }
        }
    }

    # Check: policy compliance
    var min_trust = policy_min_trust(policy);
    var enforcement = policy_enforcement(policy);
    var meets_min = trust_level_ge(trust_level, min_trust);
    if (meets_min == 1) {
        vresult_add_check(vr, trust_check_new("policy", 1, "Meets minimum trust level"));
    } else {
        if (enforcement == ENFORCE_STRICT) {
            vresult_add_check(vr, trust_check_new("policy", 0, "Below minimum trust level"));
            vresult_set_passed(vr, 0);
        } elif (enforcement == ENFORCE_PERMISSIVE) {
            vresult_add_check(vr, trust_check_new("policy", 0, "Below minimum (permissive)"));
        } else {
            vresult_add_check(vr, trust_check_new("policy", 0, "Below minimum (audit only)"));
        }
    }

    # Update artifact trust level
    artifact_set_trust_level(vresult_artifact(vr), trust_level);

    # Audit
    var passed = vresult_passed(vr);
    var ae = audit_artifact_verified(path, artifact_type, trust_level, passed, chash);
    alog_record(load64(sv + 48), ae);

    return vr;
}

# ================================================================
# Convenience: verify agent binary
# ================================================================

fn sv_verify_agent(sv, path): i64 {
    var policy = load64(sv + 8);
    var vr = sv_verify_artifact(sv, path, ARTIFACT_AGENT_BINARY);

    # Additional check: unsigned agents
    if (policy_allow_unsigned(policy) == 0) {
        var checks = vresult_checks(vr);
        var clen = vec_len(checks);
        var has_sig = 0;
        var i = 0;
        while (i < clen) {
            var tc = vec_get(checks, i);
            if (streq(check_name(tc), "signature") == 1) {
                if (check_passed(tc) == 1) { has_sig = 1; }
            }
            i = i + 1;
        }
        if (has_sig == 0) {
            vresult_add_check(vr, trust_check_new("unsigned_agent", 0, "Unsigned agents not allowed"));
            vresult_set_passed(vr, 0);
        }
    }
    return vr;
}

# ================================================================
# sv_verify_package(sv, path, expected_hash)
#
# Package-specific verification path. Calls sv_verify_artifact with
# ARTIFACT_PACKAGE, then — if `expected_hash` is non-zero — layers
# a constant-time content-hash match. A hash mismatch marks the
# whole result as failed. Mirrors the Rust `verify_package(path,
# Option<expected_hash>)` signature (pass 0 as expected_hash for
# "no expected hash").
#
# The Rust version had an early-exit when policy.verify_on_install
# was false; that gate is no longer needed — verify_on_install has
# been a user-set policy knob for several releases and consumers
# (argonaut/ark) enforce it themselves before calling in.
# ================================================================

fn sv_verify_package(sv, path, expected_hash): i64 {
    var vr = sv_verify_artifact(sv, path, ARTIFACT_PACKAGE);
    if (expected_hash == 0) { return vr; }

    var artifact = vresult_artifact(vr);
    var actual = artifact_content_hash(artifact);
    var matches = 0;
    if (actual != 0) {
        if (ct_eq_bytes_lens(actual, strlen(actual), expected_hash, strlen(expected_hash)) == 1) {
            matches = 1;
        }
    }
    if (matches == 1) {
        vresult_add_check(vr, trust_check_new("expected_hash", 1, "Content hash matches expected"));
    } else {
        vresult_add_check(vr, trust_check_new("expected_hash", 0, "Hash mismatch"));
        vresult_set_passed(vr, 0);
    }
    return vr;
}

# ================================================================
# Revocation management
# ================================================================

fn sv_add_revocation(sv, entry): i64 {
    var rl = load64(sv + 16);
    var result = rl_add(rl, entry);
    if (result == ERR_NONE) {
        var ae = audit_revocation_added(rev_key_id(entry), rev_content_hash(entry), rev_reason(entry));
        alog_record(load64(sv + 48), ae);
    }
    return result;
}

fn sv_check_revocation(sv, key_id, content_hash): i64 {
    var rl = load64(sv + 16);
    if (key_id != 0) {
        if (rl_is_key_revoked(rl, key_id) == 1) { return 1; }
    }
    if (content_hash != 0) {
        if (rl_is_artifact_revoked(rl, content_hash) == 1) { return 1; }
    }
    return 0;
}

fn sv_revocation_count(sv): i64 {
    return rl_len(load64(sv + 16));
}

# ================================================================
# Trust store queries
# ================================================================

fn sv_trust_level_for(sv, content_hash): i64 {
    var store = load64(sv + 32);
    var artifact = map_get(store, content_hash);
    if (artifact == 0) { return TRUST_UNVERIFIED; }
    return artifact_trust_level(artifact);
}

fn sv_stats(sv): i64 {
    var store = load64(sv + 32);
    var s = sigil_stats_new();
    var keys = map_keys(store);
    var total = vec_len(keys);
    store64(s, total);
    var verified = 0;
    var revoked = 0;
    var i = 0;
    while (i < total) {
        var chash = vec_get(keys, i);
        var artifact = map_get(store, chash);
        var tl = artifact_trust_level(artifact);
        if (trust_level_ge(tl, TRUST_VERIFIED) == 1) { verified = verified + 1; }
        if (tl == TRUST_REVOKED) { revoked = revoked + 1; }
        i = i + 1;
    }
    store64(s + 8, verified);
    store64(s + 16, revoked);
    return s;
}

# ================================================================
# Boot chain verification
# ================================================================

# ================================================================
# Compliance report
# ================================================================

fn sv_compliance_report(sv): i64 {
    var cr = compliance_report_new();
    var store = load64(sv + 32);
    var policy = load64(sv + 8);
    var min_trust = policy_min_trust(policy);
    var keys = map_keys(store);
    var total = vec_len(keys);
    store64(cr, total);

    var compliant = 0;
    var i = 0;
    while (i < total) {
        var chash = vec_get(keys, i);
        var artifact = map_get(store, chash);
        var tl = artifact_trust_level(artifact);
        var path = artifact_path(artifact);

        if (tl == TRUST_REVOKED) {
            vec_push(load64(cr + 40), artifact);
        } elif (trust_level_ge(tl, min_trust) == 0) {
            vec_push(load64(cr + 24), artifact);
        } else {
            # Check key pin
            var signer = artifact_signer_key_id(artifact);
            if (_sv_key_authorized(sv, path, signer) == 0) {
                vec_push(load64(cr + 48), artifact);
            } else {
                if (artifact_signature(artifact) == 0) {
                    if (policy_allow_unsigned(policy) == 0) {
                        vec_push(load64(cr + 32), artifact);
                    } else {
                        vec_push(load64(cr + 16), artifact);
                        compliant = compliant + 1;
                    }
                } else {
                    vec_push(load64(cr + 16), artifact);
                    compliant = compliant + 1;
                }
            }
        }
        i = i + 1;
    }
    store64(cr + 8, compliant);
    return cr;
}

# ================================================================
# Trust store snapshot and diff
# ================================================================

# Snapshot entry (16 bytes): trust-level + path frozen at snapshot time.
# Previously the snapshot mapped chash → artifact_ptr, but since the
# same pointer was still mutable in the live store, a trust-level
# change was invisible to a subsequent diff. Snapshotting a level
# plus path byvalue gives a real before/after view.

fn _snap_entry_new(trust_level, path): i64 {
    var se = fl_alloc(16);
    store64(se, trust_level);
    store64(se + 8, path);
    return se;
}

fn snap_entry_trust_level(se): i64 { return load64(se); }
fn snap_entry_path(se): i64 { return load64(se + 8); }

fn sv_snapshot_trust_store(sv): i64 {
    var store = load64(sv + 32);
    var keys = map_keys(store);
    var snap = map_new();
    var klen = vec_len(keys);
    var i = 0;
    while (i < klen) {
        var chash = vec_get(keys, i);
        var artifact = map_get(store, chash);
        map_set(snap, chash, _snap_entry_new(
        artifact_trust_level(artifact),
        artifact_path(artifact)
        ));
        i = i + 1;
    }
    return snap;
}

# ================================================================
# ArtifactChange (32 bytes) — Rust-style diff record
# ================================================================
# Layout:
#   +0   content_hash  (C-string ptr)
#   +8   path          (C-string ptr)
#   +16  old_trust_level (i64; -1 = none / this is a newly added artifact)
#   +24  new_trust_level (i64; -1 = none / this artifact was removed)
#
# For a "changed" record, both old and new are set and differ.
# For "added", old = -1. For "removed", new = -1.

fn artifact_change_new(content_hash, path, old_tl, new_tl): i64 {
    var ac = fl_alloc(32);
    store64(ac, content_hash);
    store64(ac + 8, path);
    store64(ac + 16, old_tl);
    store64(ac + 24, new_tl);
    return ac;
}

fn ac_content_hash(ac): i64 { return load64(ac); }
fn ac_path(ac): i64 { return load64(ac + 8); }
fn ac_old_trust_level(ac): i64 { return load64(ac + 16); }
fn ac_new_trust_level(ac): i64 { return load64(ac + 24); }

# TrustStoreDiff (24 bytes): added, removed, changed (all vecs of ArtifactChange ptrs).
# BREAKING vs 2.4.x: vecs previously held raw TrustedArtifact pointers;
# they now hold ArtifactChange records so callers can see both sides
# of a trust-level transition, not just the current side.
fn trust_store_diff_new(): i64 {
    var d = fl_alloc(24);
    store64(d, vec_new());     # added   (ArtifactChange where old_tl = -1)
    store64(d + 8, vec_new()); # removed (ArtifactChange where new_tl = -1)
    store64(d + 16, vec_new()); # changed (both sides set, old != new)
    return d;
}

fn tsdiff_added(d): i64 { return load64(d); }
fn tsdiff_removed(d): i64 { return load64(d + 8); }
fn tsdiff_changed(d): i64 { return load64(d + 16); }
fn tsdiff_is_empty(d): i64 {
    if (vec_len(load64(d)) == 0) {
        if (vec_len(load64(d + 8)) == 0) {
            if (vec_len(load64(d + 16)) == 0) { return 1; }
        }
    }
    return 0;
}

fn sv_diff_trust_store(sv, old_snap): i64 {
    var diff = trust_store_diff_new();
    var store = load64(sv + 32);
    var current_keys = map_keys(store);
    var old_keys = map_keys(old_snap);

    # Find added and changed
    var cklen = vec_len(current_keys);
    var i = 0;
    while (i < cklen) {
        var chash = vec_get(current_keys, i);
        var old_snap_entry = map_get(old_snap, chash);
        var new_art = map_get(store, chash);
        if (old_snap_entry == 0) {
            var ac = artifact_change_new(
            chash,
            artifact_path(new_art),
            0 - 1,
            artifact_trust_level(new_art)
            );
            vec_push(load64(diff), ac);
        } else {
            var old_tl = snap_entry_trust_level(old_snap_entry);
            var new_tl = artifact_trust_level(new_art);
            if (old_tl != new_tl) {
                var ac = artifact_change_new(
                chash,
                artifact_path(new_art),
                old_tl,
                new_tl
                );
                vec_push(load64(diff + 16), ac);
            }
        }
        i = i + 1;
    }

    # Find removed
    var oklen = vec_len(old_keys);
    i = 0;
    while (i < oklen) {
        var chash = vec_get(old_keys, i);
        if (map_get(store, chash) == 0) {
            var old_snap_entry = map_get(old_snap, chash);
            var ac = artifact_change_new(
            chash,
            snap_entry_path(old_snap_entry),
            snap_entry_trust_level(old_snap_entry),
            0 - 1
            );
            vec_push(load64(diff + 8), ac);
        }
        i = i + 1;
    }
    return diff;
}

# ================================================================
# Trust store persistence
# ================================================================

# ================================================================
# sv_load_trust_store(sv, path) — inverse of sv_save_trust_store
#
# Reads the JSON array written by sv_save_trust_store and installs
# every {hash, path, type, trust} record into the verifier's trust
# store. Returns the number of artifacts loaded, or 0 on IO/parse
# failure.
#
# Signatures and signer_key_id are NOT persisted by the save path —
# the serialized form is an inventory of trusted artifacts, not a
# re-verifiable archive. Loaded artifacts come back with signature
# = 0, signer = 0, trust level preserved. A subsequent
# sv_verify_artifact call will treat them as present-but-unsigned.
#
# `_rj_parse_string` is reused from policy.cyr — same compilation
# unit, handles the same escape set (\" \\ \n \r \t \b \f \u00XX)
# as json_write_escaped in trust.cyr.
# ================================================================

fn sv_load_trust_store(sv, path): i64 {
    var buf = alloc(65536);
    var n = file_read_all(path, buf, 65536);
    if (n <= 0) { return 0; }
    var store = load64(sv + 32);

    var pos = 0;
    # Skip to first '{'
    while (pos < n) {
        if ((load8(buf + pos) & 0xFF) == 123) { break; }
        pos = pos + 1;
    }

    var loaded = 0;
    while (pos < n) {
        if ((load8(buf + pos) & 0xFF) != 123) { break; }
        pos = pos + 1;

        var hash = 0;
        var apath = 0;
        var atype = ARTIFACT_AGENT_BINARY;   # default; overwritten when the JSON object provides "type"
        var trust = TRUST_UNVERIFIED;

        while (pos < n) {
            var c = load8(buf + pos) & 0xFF;
            if (c == 125) { pos = pos + 1; break; }
            if (c != 34) { pos = pos + 1; }
            else {
                pos = _rj_parse_string(buf, pos, n);
                var k = _rj_out_ptr;
                if (k == 0) { break; }
                # Skip to colon
                while (pos < n) {
                    if ((load8(buf + pos) & 0xFF) == 58) { pos = pos + 1; break; }
                    pos = pos + 1;
                }
                # Skip whitespace
                while (pos < n) {
                    var ws = load8(buf + pos) & 0xFF;
                    if (ws == 32) { pos = pos + 1; }
                    elif (ws == 9) { pos = pos + 1; }
                    else { break; }
                }
                if (pos >= n) { break; }
                var vc = load8(buf + pos) & 0xFF;
                if (vc == 34) {
                    pos = _rj_parse_string(buf, pos, n);
                    var v = _rj_out_ptr;
                    if (streq(k, "hash") == 1) { hash = v; }
                    elif (streq(k, "path") == 1) { apath = v; }
                } else {
                    var vs = pos;
                    while (pos < n) {
                        var vcc = load8(buf + pos) & 0xFF;
                        if (vcc == 44) { break; }
                        if (vcc == 125) { break; }
                        if (vcc == 32) { break; }
                        pos = pos + 1;
                    }
                    var vlen = pos - vs;
                    var intv = 0;
                    var ii = 0;
                    while (ii < vlen) {
                        var ch = load8(buf + vs + ii) & 0xFF;
                        if (ch >= 48) { if (ch <= 57) { intv = intv * 10 + (ch - 48); } }
                        ii = ii + 1;
                    }
                    if (streq(k, "type") == 1) { atype = intv; }
                    elif (streq(k, "trust") == 1) { trust = intv; }
                }
            }
        }

        if (hash != 0) {
            var art = trusted_artifact_new(apath, atype, hash);
            artifact_set_trust_level(art, trust);
            map_set(store, hash, art);
            loaded = loaded + 1;
        }

        # Scan to next '{' or ']'
        while (pos < n) {
            var c2 = load8(buf + pos) & 0xFF;
            if (c2 == 123) { break; }
            if (c2 == 93) { break; }
            pos = pos + 1;
        }
        if (pos < n) {
            if ((load8(buf + pos) & 0xFF) == 93) { break; }
        }
    }
    return loaded;
}

fn sv_save_trust_store(sv, path): i64 {
    var store = load64(sv + 32);
    var keys = map_keys(store);
    var klen = vec_len(keys);
    var fd = file_open(path, 577, 420);
    if (fd < 0) { return ERR_IO; }
    file_write(fd, "[", 1);
    var i = 0;
    var nbuf[24];
    while (i < klen) {
        var chash = vec_get(keys, i);
        var art = map_get(store, chash);
        if (i > 0) { file_write(fd, ",", 1); }
        file_write(fd, "{\"hash\":\"", 9);
        json_write_escaped(fd, chash, strlen(chash));
        file_write(fd, "\",\"path\":\"", 10);
        var ap = artifact_path(art);
        json_write_escaped(fd, ap, strlen(ap));
        file_write(fd, "\",\"type\":", 9);
        # fmt_int prints to stdout — use fmt_int_buf for file output.
        memset(&nbuf, 0, 24);
        var nlen = fmt_int_buf(artifact_type(art), &nbuf);
        file_write(fd, &nbuf, nlen);
        file_write(fd, ",\"trust\":", 9);
        memset(&nbuf, 0, 24);
        nlen = fmt_int_buf(artifact_trust_level(art), &nbuf);
        file_write(fd, &nbuf, nlen);
        file_write(fd, "}", 1);
        i = i + 1;
    }
    file_write(fd, "]", 1);
    file_close(fd);
    return ERR_NONE;
}

# ================================================================
# Batch verification
# ================================================================
# `sv_verify_batch` fans out across `_SIGIL_BATCH_WORKERS` threads
# at `count >= _SIGIL_BATCH_PARALLEL_THRESHOLD`; below the
# threshold it runs serial inline. The 5.5.x-era
# `-D SIGIL_BATCH_PARALLEL` cmdline gate was dropped in 3.0 once
# cyrius 5.5.37 raised the fixup-table cap (quirk #5) — the
# parallel path is now the default and the test +bench files
# (`tests/tcyr/batch_parallel.tcyr`, `tests/bcyr/batch_parallel.bcyr`)
# exercise it without a build flag.
#
# Threading safety contract:
# - `sv_verify_artifact` calls `alloc` / `vec_push` / `map_get`,
#   which are NOT thread-safe under cyrius (CLAUDE.md quirk #7).
#   We serialise the full call via `_sigil_batch_mutex` so only
#   one worker allocates / mutates containers at a time.
# - `ed25519_verify` + SHA-256 compute themselves use stack-locals
#   and read-only globals (fixed-base comb, round-key tables), so
#   they run inside the mutex region just as a matter of code
#   structure — the actual *crypto* work can't parallelise under
#   the mutex-wrap approach. For batch sizes where the crypto
#   dominates, the win comes from pipelining file-I/O latency
#   across workers (SHA-256 streaming + file_read waits) while
#   the mutex protects the bookkeeping layer.
# - A fully-pure alloc-free verify path (the "Option 1" rewrite
#   tracked in `docs/development/roadmap.md` § Road to v3.1) lifts
#   this ceiling. Deferred to 3.1.

var _sigil_batch_mutex = 0;
var _SIGIL_BATCH_PARALLEL_THRESHOLD = 4;
var _SIGIL_BATCH_WORKERS = 4;

# Worker entry. arg is a 48-byte packed record:
#   +0   sv
#   +8   artifacts (packed path/type buffer base)
#   +16  start_idx
#   +24  end_idx
#   +32  result_slots (base of `count * 8` pointer array)
#   +40  mutex
fn _batch_worker(arg): i64 {
    var sv = load64(arg);
    var artifacts = load64(arg + 8);
    var start = load64(arg + 16);
    var end = load64(arg + 24);
    var slots = load64(arg + 32);
    var mtx = load64(arg + 40);
    var i = start;
    while (i < end) {
        var path = load64(artifacts + i * 16);
        var atype = load64(artifacts + i * 16 + 8);
        mutex_lock(mtx);
        var vr = sv_verify_artifact(sv, path, atype);
        mutex_unlock(mtx);
        store64(slots + i * 8, vr);
        i = i + 1;
    }
    return 0;
}

fn sv_verify_batch(sv, artifacts, count): i64 {
    if (count >= _SIGIL_BATCH_PARALLEL_THRESHOLD) {
        if (_sigil_batch_mutex == 0) {
            _sigil_batch_mutex = mutex_new();
        }
        var workers = _SIGIL_BATCH_WORKERS;
        if (count < workers) { workers = count; }

        # Pre-allocate everything on main thread before spawn —
        # stdlib `alloc` is not thread-safe (CLAUDE.md quirk #7).
        var slots = alloc(count * 8);
        var args = alloc(workers * 48);
        var ts = alloc(workers * 8);

        var per = count / workers;
        if ((count % workers) != 0) { per = per + 1; }

        var wi = 0;
        while (wi < workers) {
            var pstart = wi * per;
            var pend = pstart + per;
            if (pend > count) { pend = count; }
            var a = args + wi * 48;
            store64(a, sv);
            store64(a + 8, artifacts);
            store64(a + 16, pstart);
            store64(a + 24, pend);
            store64(a + 32, slots);
            store64(a + 40, _sigil_batch_mutex);
            store64(ts + wi * 8, thread_create(&_batch_worker, a));
            wi = wi + 1;
        }

        wi = 0;
        while (wi < workers) {
            thread_join(load64(ts + wi * 8));
            wi = wi + 1;
        }

        var presults = vec_new();
        var pri = 0;
        while (pri < count) {
            vec_push(presults, load64(slots + pri * 8));
            pri = pri + 1;
        }
        return presults;
    }

    # Serial path — taken when `count < _SIGIL_BATCH_PARALLEL_THRESHOLD`.
    var results = vec_new();
    var i = 0;
    while (i < count) {
        var path = load64(artifacts + i * 16);
        var atype = load64(artifacts + i * 16 + 8);
        var vr = sv_verify_artifact(sv, path, atype);
        vec_push(results, vr);
        i = i + 1;
    }
    return results;
}

# ================================================================
# Boot chain verification
# ================================================================

fn sv_verify_boot_chain(sv, components): i64 {
    var policy = load64(sv + 8);
    if (policy_verify_on_boot(policy) == 0) {
        return integrity_report_new();
    }

    var iv = load64(sv + 24);
    var ipol = integrity_policy_new();

    var clen = vec_len(components);
    var i = 0;
    while (i < clen) {
        var path = vec_get(components, i);
        var store = load64(sv + 32);
        # Look for artifact by path in trust store
        var keys = map_keys(store);
        var klen = vec_len(keys);
        var j = 0;
        while (j < klen) {
            var chash = vec_get(keys, j);
            var artifact = map_get(store, chash);
            if (streq(artifact_path(artifact), path) == 1) {
                ipolicy_add(ipol, path, chash);
            }
            j = j + 1;
        }
        i = i + 1;
    }

    iv_set_policy(iv, ipol);
    return iv_verify_all(iv);
}
