# --- url.cyr ---

# sandhi/http/url — URL parser (http:// + https://).
#
# Returns a 40-byte struct on success, 0 on malformed input. Caller
# is responsible for null-checking before dereferencing fields.
#
# Struct layout:
#   +0   scheme      (int: SANDHI_URL_HTTP | SANDHI_URL_HTTPS)
#   +8   host        (cstr — null-terminated, alloc-owned)
#   +16  port        (int: 1..65535)
#   +24  path        (cstr — includes leading '/'; always non-empty)
#   +32  query       (cstr — after '?', or 0 if none)
#
# CRLF-injection hardening: reject any URL containing control bytes
# (CR / LF / TAB / SPACE) before we allocate anything. Same posture
# as stdlib http.cyr::_http_parse_url — these bytes can smuggle extra
# request-line / header content if the URL is reflected into a wire
# request. Rejecting at the boundary (returning 0) keeps caller-side
# code simple: null-check once, dereference fields freely thereafter.

enum SandhiUrlScheme {
    SANDHI_URL_HTTP  = 0;
    SANDHI_URL_HTTPS = 1;
}

# Field offsets within the parsed URL struct.
enum SandhiUrlOff {
    SANDHI_URL_OFF_SCHEME = 0;
    SANDHI_URL_OFF_HOST   = 8;
    SANDHI_URL_OFF_PORT   = 16;
    SANDHI_URL_OFF_PATH   = 24;
    SANDHI_URL_OFF_QUERY  = 32;
}

var SANDHI_URL_STRUCT_SIZE = 40;

# Accessors. Inline-friendly — callers can load64 directly, but going
# through accessors reads better and lets us reshape the struct later.
fn sandhi_url_scheme(u): i64 { return load64(u + SANDHI_URL_OFF_SCHEME); }
fn sandhi_url_host(u): i64 { return load64(u + SANDHI_URL_OFF_HOST); }
fn sandhi_url_port(u): i64 { return load64(u + SANDHI_URL_OFF_PORT); }
fn sandhi_url_path(u): i64 { return load64(u + SANDHI_URL_OFF_PATH); }
fn sandhi_url_query(u): i64 { return load64(u + SANDHI_URL_OFF_QUERY); }

# Validate that no byte in the URL can escape the request line / header
# block. Returns 1 if safe, 0 if any disallowed byte is present.
fn _sandhi_url_safe(url): i64 {
    var i = 0;
    while (load8(url + i) != 0) {
        var c = load8(url + i);
        if (c == 13) { return 0; }  # CR
        if (c == 10) { return 0; }  # LF
        if (c == 9)  { return 0; }  # TAB
        if (c == 32) { return 0; }  # SPACE
        i = i + 1;
    }
    return 1;
}

# Lowercase-equal comparison for scheme detection ("HTTP" == "http").
# Compares up to `n` bytes; returns 1 if equal ignoring case, 0 otherwise.
fn _sandhi_url_sceq(a, b, n): i64 {
    var i = 0;
    while (i < n) {
        var ca = load8(a + i);
        var cb = load8(b + i);
        if (ca >= 65 && ca <= 90) { ca = ca + 32; }
        if (cb >= 65 && cb <= 90) { cb = cb + 32; }
        if (ca != cb) { return 0; }
        i = i + 1;
    }
    return 1;
}

# Parse a URL into the given Allocator. Returns the struct on success,
# 0 on malformed input or OOM. Every alloc on the parsed-URL hot path
# (host / path / query / struct) lands in `a`; reset_via(a) reclaims
# all of it in one shot — the per-request-arena pattern.
fn sandhi_url_parse_a(a, url): i64 {
    if (url == 0) { return 0; }
    if (_sandhi_url_safe(url) == 0) { return 0; }

    # Scheme detection. Default port follows the scheme.
    var scheme = 0;
    var default_port = 80;
    var p = 0;
    if (_sandhi_url_sceq(url, "https://", 8) == 1) {
        scheme = SANDHI_URL_HTTPS;
        default_port = 443;
        p = 8;
    } elif (_sandhi_url_sceq(url, "http://", 7) == 1) {
        scheme = SANDHI_URL_HTTP;
        default_port = 80;
        p = 7;
    } else {
        return 0;  # unsupported scheme
    }

    # Host — two flavors:
    #   1) Bracketed IPv6: `[2001:db8::1]` or `[::1]` per RFC 3986 §3.2.2.
    #      Brackets contain the literal; ':' inside brackets is part of
    #      the address, not the port separator. Brackets are stripped
    #      from the stored host (callers see "::1", not "[::1]").
    #   2) Bare hostname / IPv4: runs until ':' / '/' / '?' / end.
    if (load8(url + p) == 91) {  # '['
        var v6_start = p + 1;
        var v6_end = v6_start;
        var v6_scan = 1;
        while (v6_scan == 1) {
            var bc = load8(url + v6_end);
            if (bc == 0)  { return 0; }     # unterminated bracket
            if (bc == 93) { v6_scan = 0; }  # ']'
            else          { v6_end = v6_end + 1; }
        }
        if (v6_end == v6_start) { return 0; }  # empty []
        # finish_at() takes content-range + post-host-tail-cursor
        # separately so the v6 path can skip the trailing ']'.
        return _sandhi_url_finish_at_a(a, url, scheme, default_port, v6_start, v6_end, v6_end + 1);
    }

    var host_start = p;
    var scanning = 1;
    while (scanning == 1) {
        var c = load8(url + p);
        if (c == 0)  { scanning = 0; }
        elif (c == 58) { scanning = 0; }
        elif (c == 47) { scanning = 0; }
        elif (c == 63) { scanning = 0; }
        else { p = p + 1; }
    }
    return _sandhi_url_finish_at_a(a, url, scheme, default_port, host_start, p, p);
}

# Back-compat: parse using the process-wide default Allocator.
fn sandhi_url_parse(url): i64 {
    return sandhi_url_parse_a(default_alloc(), url);
}

# Continue parsing after the host boundary, allocating into `a`.
# host_start..host_end_excl bounds the host content; tail_start is
# where post-host parsing (port / path / query) picks up. Bare hosts
# pass host_end_excl == tail_start; bracketed-v6 passes
# tail_start == host_end_excl + 1 to skip the closing ']'. Returns
# 0 on bad input OR on allocator failure (OOM).
fn _sandhi_url_finish_at_a(a, url, scheme, default_port, host_start, host_end_excl, tail_start): i64 {
    var host_len = host_end_excl - host_start;
    if (host_len == 0) { return 0; }

    var port = default_port;
    var p = tail_start;
    if (load8(url + p) == 58) {
        p = p + 1;
        port = 0;
        var got = 0;
        # 0.9.1 P1 — explicit digit count cap. Existing post-multiply
        # check already aborts before the i64 multiply could wrap
        # (port > 65535 fires by the 5th non-leading-zero digit), but
        # bounding the input scan at 5 digits is safer and rejects
        # pathological inputs like "00000000000000080" early. Also
        # blocks attempts to use leading zeros to mask a multi-digit
        # port that any other parser might handle differently.
        var port_digits = 0;
        while (load8(url + p) >= 48 && load8(url + p) <= 57) {
            if (port_digits >= 5) { return 0; }
            port = port * 10 + (load8(url + p) - 48);
            got = 1;
            port_digits = port_digits + 1;
            p = p + 1;
            if (port > 65535) { return 0; }
        }
        if (got == 0) { return 0; }
        if (port == 0) { return 0; }
    }

    # Path + query. If delimiter is '/' → path runs to '?' or NUL. If '?' →
    # path defaults to "/" and query follows. If NUL → path "/" and no query.
    var path = "/";
    var query = 0;

    if (load8(url + p) == 47) {
        var path_start = p;
        var qmark = 0 - 1;
        var scan = 1;
        while (scan == 1) {
            var c = load8(url + p);
            if (c == 0)  { scan = 0; }
            elif (c == 63) { qmark = p; scan = 0; }
            else { p = p + 1; }
        }
        var path_end = p;
        if (qmark >= 0) { path_end = qmark; }
        var plen = path_end - path_start;
        var path_out = alloc_via(a, plen + 1);
        if (path_out == 0) { return 0; }
        memcpy(path_out, url + path_start, plen);
        store8(path_out + plen, 0);
        path = path_out;

        if (qmark >= 0) {
            var q_start = qmark + 1;
            var q_end = q_start;
            while (load8(url + q_end) != 0) { q_end = q_end + 1; }
            var qlen = q_end - q_start;
            var query_out = alloc_via(a, qlen + 1);
            if (query_out == 0) { return 0; }
            memcpy(query_out, url + q_start, qlen);
            store8(query_out + qlen, 0);
            query = query_out;
        }
    } elif (load8(url + p) == 63) {
        var qs = p + 1;
        var qe = qs;
        while (load8(url + qe) != 0) { qe = qe + 1; }
        var qlen2 = qe - qs;
        var query_out2 = alloc_via(a, qlen2 + 1);
        if (query_out2 == 0) { return 0; }
        memcpy(query_out2, url + qs, qlen2);
        store8(query_out2 + qlen2, 0);
        query = query_out2;
    }

    var host = alloc_via(a, host_len + 1);
    if (host == 0) { return 0; }
    memcpy(host, url + host_start, host_len);
    store8(host + host_len, 0);

    var result = alloc_via(a, SANDHI_URL_STRUCT_SIZE);
    if (result == 0) { return 0; }
    store64(result + SANDHI_URL_OFF_SCHEME, scheme);
    store64(result + SANDHI_URL_OFF_HOST, host);
    store64(result + SANDHI_URL_OFF_PORT, port);
    store64(result + SANDHI_URL_OFF_PATH, path);
    store64(result + SANDHI_URL_OFF_QUERY, query);
    return result;
}


# --- session_cache.cyr ---

# sandhi/tls_policy/session_cache — TLS 1.3 session-ticket / TLS 1.2
# session-ID cache, keyed by (sni_host, hook_fp).
#
# 1.3.1: composes cyrius v5.10.21's session primitives + v5.10.27's
# staged-connect API (`tls_connect_alloc` + `tls_connect_complete`)
# to enable client-side resumption. The full flow:
#
#   var ctx = tls_connect_alloc(fd, sni, hook_fp, hook_ctx);
#   var sess = sandhi_session_cache_lookup(sni, hook_fp);
#   if (sess != 0) { tls_set_session(ctx, sess); }
#   if (tls_connect_complete(ctx) == 1) {
#       var fresh = tls_get_session(ctx);
#       sandhi_session_cache_store(sni, hook_fp, fresh);
#   }
#
# Cache shape:
#   - Process-wide singleton (init on first use)
#   - Hashmap<key_cstr → SSL_SESSION*>
#   - Key: `<sni_host>|<hook_fp_hex>` — the hook pointer
#     distinguishes default-ALPN connections from policy-bound
#     connections (different hook = different SSL_CTX config =
#     incompatible session). Prevents cross-policy contamination.
#   - SSL_SESSION* entries are owned by the cache (refcount-bumped
#     by `tls_get_session`); released via `tls_session_free` on
#     replacement / cache teardown.
#   - Allocator: `default_alloc()` — sessions are process-wide
#     singletons that outlive any per-request arena (same shape
#     as the pool's `_hsv_req_buf` and the HPACK static table).
#
# Opt-in: default-OFF. Consumers call `sandhi_session_cache_enable(1)`
# once at process start. When disabled, lookup always returns 0
# and store is a no-op — zero overhead on the request path beyond
# one global-load + early-return per call.
#
# Stats: `_hit_count` / `_miss_count` increment on lookup; consumers
# can sample to evaluate cache effectiveness.
#
# Capability gate: enable is a no-op if the underlying libssl
# doesn't support session resumption (`tls_supports_session_resumption()
# == 0`). Saves consumers from setting up a cache that won't function.
#
# 1.3.2: 0-RTT (early data) wired through the staged-connect
# finalize. Cache is the substrate; 0-RTT writes the request as
# early data on resumed handshakes when the caller opts in.
#
# 1.3.3: cred-strip-aware keying. Cache key now includes a
# 64-bit FNV-1a digest over the request's cred-bearing headers
# (Authorization / Cookie / Proxy-Authorization). When the
# digest changes (auth context rotates), the key changes →
# fresh handshake. Old entry stays in cache until 1.3.4's TTL
# evicts it. Caller passes 0 for the digest when the request
# carries no cred-bearing headers (which is the common case
# for service-to-service traffic) — same key shape as 1.3.1
# / 1.3.2 in that majority path.
#
# What this slot does NOT do (deferred to follow-up patches):
#   - TTL / max-size eviction: cache grows unbounded today.
#     `last_used_ms` slot is reserved for future eviction logic.

# Cache state (singletons)
var _sandhi_session_cache_enabled    = 0;
var _sandhi_session_cache_initialized = 0;
var _sandhi_session_cache_map        = 0;   # hashmap<cstr → SSL_SESSION*>
var _sandhi_session_cache_hit_count  = 0;
var _sandhi_session_cache_miss_count = 0;

fn _sandhi_session_cache_init(): i64 {
    if (_sandhi_session_cache_initialized == 1) { return 0; }
    if (tls_supports_session_resumption() == 0) {
        # libssl missing the session-resumption symbols. Stay
        # uninitialized; lookup/store will be no-ops via the
        # enabled flag.
        _sandhi_session_cache_enabled = 0;
        _sandhi_session_cache_initialized = 1;
        return 0;
    }
    _sandhi_session_cache_map = hashmap_new_a(default_alloc());
    _sandhi_session_cache_initialized = 1;
    return 0;
}

# Toggle the cache on. Returns 1 on success, 0 if libssl doesn't
# support session resumption. Idempotent.
fn sandhi_session_cache_enable(on): i64 {
    _sandhi_session_cache_init();
    if (on == 1 && _sandhi_session_cache_map == 0) {
        # init ran but libssl didn't support — stay off
        return 0;
    }
    _sandhi_session_cache_enabled = on;
    return 1;
}

fn sandhi_session_cache_enabled(): i64 {
    return _sandhi_session_cache_enabled;
}

# Build a cache key from (sni_host, hook_fp, cred_digest) into `a`.
# The hook fp is rendered as a 16-hex-digit suffix so different hook
# surfaces (default ALPN hook vs. policy hook) don't share cache
# slots — their SSL_CTX configurations may differ, which would
# invalidate session reuse. The cred digest (1.3.3) is rendered as
# a second 16-hex-digit suffix so requests with different auth
# contexts don't share a session: when Authorization / Cookie /
# Proxy-Authorization rotate, digest changes → key changes →
# fresh handshake. Pass 0 for cred_digest when no cred-bearing
# headers are present; rendered as `|0000000000000000`, the common
# case for service-to-service traffic.
fn _sandhi_session_cache_key_a(a, sni_host, hook_fp, cred_digest): i64 {
    if (sni_host == 0) { return 0; }
    var sb = str_builder_new_a(a);
    if (sb == 0) { return 0; }
    str_builder_add_cstr_a(a, sb, sni_host);
    str_builder_add_cstr_a(a, sb, "|");
    var hex = "0123456789abcdef";
    var i = 15;
    while (i >= 0) {
        var nibble = (hook_fp >> (i * 4)) & 15;
        var ch[1];
        store8(&ch, load8(hex + nibble));
        str_builder_add_cstr_a(a, sb, &ch);
        i = i - 1;
    }
    str_builder_add_cstr_a(a, sb, "|");
    i = 15;
    while (i >= 0) {
        var nibble2 = (cred_digest >> (i * 4)) & 15;
        var ch2[1];
        store8(&ch2, load8(hex + nibble2));
        str_builder_add_cstr_a(a, sb, &ch2);
        i = i - 1;
    }
    return str_data(str_builder_build_a(a, sb));
}

# Lookup a cached session for (sni_host, hook_fp, cred_digest).
# Returns 0 on miss / disabled / cache uninitialized. The returned
# SSL_SESSION* is OWNED BY THE CACHE — caller must NOT call
# `tls_session_free` on it. Caller passes it to
# `tls_set_session(ctx, sess)` which does NOT take ownership
# (libssl bumps the refcount internally).
#
# 1.3.3: `cred_digest` is the FNV-1a 64-bit digest over the
# cred-bearing header values from this request (computed via
# `_sandhi_cred_digest_a` in client.cyr). Pass 0 when no
# cred-bearing headers are present.
fn sandhi_session_cache_lookup(sni_host, hook_fp, cred_digest): i64 {
    if (_sandhi_session_cache_enabled == 0) { return 0; }
    if (_sandhi_session_cache_map == 0) { return 0; }
    if (sni_host == 0) { return 0; }
    var key = _sandhi_session_cache_key_a(default_alloc(), sni_host, hook_fp, cred_digest);
    if (key == 0) { return 0; }
    var sess = hashmap_get(_sandhi_session_cache_map, key);
    if (sess == 0) {
        _sandhi_session_cache_miss_count = _sandhi_session_cache_miss_count + 1;
        return 0;
    }
    _sandhi_session_cache_hit_count = _sandhi_session_cache_hit_count + 1;
    return sess;
}

# Store a freshly-captured session for (sni_host, hook_fp, cred_digest).
# The session pointer must come from `tls_get_session(ctx)`
# (refcount-bumped). Cache takes ownership — replaces any prior
# entry for the same key, freeing the prior session.
#
# No-op when disabled / cache uninitialized / session is 0.
fn sandhi_session_cache_store(sni_host, hook_fp, cred_digest, session): i64 {
    if (_sandhi_session_cache_enabled == 0) { return 0; }
    if (_sandhi_session_cache_map == 0) { return 0; }
    if (sni_host == 0 || session == 0) { return 0; }
    var key = _sandhi_session_cache_key_a(default_alloc(), sni_host, hook_fp, cred_digest);
    if (key == 0) { return 0; }
    var prior = hashmap_get(_sandhi_session_cache_map, key);
    if (prior != 0) {
        tls_session_free(prior);
    }
    hashmap_set_a(default_alloc(), _sandhi_session_cache_map, key, session);
    return 0;
}

# Number of cache slots currently occupied. Useful for tests +
# observability sampling.
fn sandhi_session_cache_size(): i64 {
    if (_sandhi_session_cache_map == 0) { return 0; }
    return hashmap_len(_sandhi_session_cache_map);
}

fn sandhi_session_cache_hit_count(): i64 {
    return _sandhi_session_cache_hit_count;
}

fn sandhi_session_cache_miss_count(): i64 {
    return _sandhi_session_cache_miss_count;
}

# Reset hit/miss counters. Doesn't clear the cache itself —
# entries persist for the next round of measurements.
fn sandhi_session_cache_reset_stats(): i64 {
    _sandhi_session_cache_hit_count = 0;
    _sandhi_session_cache_miss_count = 0;
    return 0;
}

# --- conn.cyr ---

# sandhi/http/conn — unified plain-TCP + TLS connection abstraction.
#
# Tagged struct so client code can treat plain http:// and https://
# uniformly. Opens a socket via stdlib net.cyr, optionally wraps it
# in a TLS session via stdlib tls.cyr. Send/recv dispatch on the
# connection kind.
#
# Struct layout (24 bytes):
#   +0   kind     (int: SANDHI_CONN_PLAIN | SANDHI_CONN_TLS)
#   +8   fd       (int: raw socket fd)
#   +16  tls_ctx  (ptr: tls_connect ctx if kind == TLS, else 0)
#
# Ownership: sandhi_conn_open allocates the struct; sandhi_conn_close
# frees the TLS context and closes the fd. Caller does not free the
# struct itself — v1 is alloc-once, no explicit free (Cyrius mem model).

enum SandhiConnKind {
    SANDHI_CONN_PLAIN = 0;
    SANDHI_CONN_TLS   = 1;
}

enum SandhiConnOff {
    SANDHI_CONN_OFF_KIND        = 0;
    SANDHI_CONN_OFF_FD          = 8;
    SANDHI_CONN_OFF_TLS_CTX     = 16;
    # Cstr ptr to the ALPN protocol the server picked (e.g. "h2",
    # "http/1.1"), or 0 when ALPN didn't fire / handshake was plain.
    # Populated post-handshake from SSL_get0_alpn_selected; copy is
    # owned by the conn and lives until process exit (alloc-once).
    SANDHI_CONN_OFF_ALPN_DATA   = 24;
    # 1.3.2 — TLS 1.3 0-RTT acceptance status from
    # `tls_get_early_data_status`. Default 0 (TLS_EARLY_DATA_NOT_SENT)
    # for non-0-RTT conns. Exchange path reads this to decide
    # whether to skip the send step (ACCEPTED) or resend over the
    # normal stream (REJECTED / NOT_SENT).
    SANDHI_CONN_OFF_0RTT_STATUS = 32;
}

var SANDHI_CONN_STRUCT_SIZE = 40;

# ---------------------------------------------------------------
# ALPN runtime — wires the v5.6.40 stdlib hook
# (tls_connect_with_ctx_hook + tls_dlsym).
#
# Advertise list is tied to what the caller can actually speak. The
# default conn-open path is the HTTP/1.1 client, so it advertises
# `http/1.1` only — that way the server can't pick h2 and force a
# protocol mismatch. The (future) h2-aware auto-dispatcher will
# flip _sandhi_alpn_advertise_h2 to 1 around its open call so the
# advertise becomes `h2,http/1.1` when the caller is prepared to
# handle either.
#
# Whatever the server picks lands at SANDHI_CONN_OFF_ALPN_DATA on
# the conn struct. Consumers read it via
# sandhi_conn_alpn_selected / _is_h2 (defined in
# tls_policy/alpn.cyr — registered after this module so those
# accessors can refer to the offset constant defined here).
# ---------------------------------------------------------------

# RFC 7301 §3.1 wire-format ProtocolNameList:
#   "http/1.1"      → 08 'h' 't' 't' 'p' '/' '1' '.' '1'           (9 bytes)
#   "h2,http/1.1"   → 02 'h' '2' 08 'h' 't' 't' 'p' '/' '1' '.' '1' (12 bytes)
# Allocated lazily on first HTTPS connection rather than at module
# init, so plain-HTTP-only consumers don't pay the cost.
var _sandhi_alpn_h11_wire     = 0;
var _sandhi_alpn_h11_wire_len = 9;
var _sandhi_alpn_h2h11_wire   = 0;
var _sandhi_alpn_h2h11_wire_len = 12;

# Toggle: 0 = advertise http/1.1 only (safe default for the 1.1
# client path), 1 = advertise h2,http/1.1 (set by the auto-h2
# dispatcher before opening; cleared after). Single-threaded
# client model, so a module-level flag is sufficient.
var _sandhi_alpn_advertise_h2 = 0;

# 1.3.2 — TLS 1.3 0-RTT opt-in flag. Mirrors the alpn-advertise
# pattern: set to opts.allow_0rtt by the dispatch entry-points
# before any conn-open in the request flow; cleared after the
# request completes. `_sandhi_http_do_impl_a` reads this in its
# eligibility check (along with method-safety, capability,
# session-cache hit). Single-threaded client model — same
# justification as `_sandhi_alpn_advertise_h2`.
var _sandhi_allow_0rtt = 0;

# 1.3.3 — cred-digest threaded through to the session-cache key.
# Set by dispatch entry-points to FNV-1a 64-bit over the request's
# Authorization / Cookie / Proxy-Authorization values (via
# `_sandhi_cred_digest_a` in client.cyr); 0 when no cred-bearing
# headers. Read inside `_sandhi_conn_finalize_with_early_data_a`
# when calling `sandhi_session_cache_lookup` / `_store`. Same
# module-level-flag rationale as `_sandhi_allow_0rtt` —
# single-threaded client model, transient per-request state we
# don't want to thread through 8+ fn signatures.
var _sandhi_cred_digest = 0;

# Hook override mechanism. When non-zero, sandhi_conn_open_fully_timed
# uses these in place of the default ALPN hook. Set by tls_policy/
# apply.cyr around its policy-aware open so the policy hook can
# do trust-store / mTLS layering on top of the SSL_CTX. Cleared by
# the same code immediately after open returns. Single-threaded
# client model — same justification as _sandhi_alpn_advertise_h2.
var _sandhi_tls_hook_override     = 0;  # fn ptr (hook signature) or 0
var _sandhi_tls_hook_override_ctx = 0;  # opaque hook_ctx ptr or 0

# Cached libssl fn pointer, lazily resolved via tls_dlsym.
# 0 means "not yet resolved" (try again) / "symbol not found"
# (resolve_fns marks it as a permanent miss when unavailable).
# 1.3.0: `_sandhi_alpn_set_fp` retired in favour of stdlib's typed
# wrapper `tls_set_alpn` (cyrius v5.10.13). Only `SSL_get0_alpn_selected`
# remains as a direct `tls_dlsym` call — no typed wrapper exists
# for it yet. Soft-deprecated per `lib/tls.cyr`'s tls_dlsym docstring.
var _sandhi_alpn_get0_fp    = 0;   # SSL_get0_alpn_selected
# 1 once we've tried resolving. Lets us distinguish "resolved-ok"
# from "tried-and-missing" without re-entering tls_dlsym every call.
var _sandhi_alpn_resolved   = 0;

# Build the per-process ALPN wire buffers. Always allocates from
# `default_alloc()` — these are process-wide singletons read on every
# TLS handshake, so they must outlive any per-request arena.
fn _sandhi_alpn_init_wire(): i64 {
    if (_sandhi_alpn_h11_wire != 0) { return 0; }
    var ga = default_alloc();
    # http/1.1 only:  08 h t t p / 1 . 1
    var h11 = alloc_via(ga, 9);
    store8(h11 + 0, 8);
    store8(h11 + 1, 104);  # 'h'
    store8(h11 + 2, 116);  # 't'
    store8(h11 + 3, 116);  # 't'
    store8(h11 + 4, 112);  # 'p'
    store8(h11 + 5, 47);   # '/'
    store8(h11 + 6, 49);   # '1'
    store8(h11 + 7, 46);   # '.'
    store8(h11 + 8, 49);   # '1'
    _sandhi_alpn_h11_wire = h11;
    # h2,http/1.1:  02 h 2  08 h t t p / 1 . 1
    var both = alloc_via(ga, 12);
    store8(both + 0,  2);
    store8(both + 1,  104);  # 'h'
    store8(both + 2,  50);   # '2'
    store8(both + 3,  8);
    store8(both + 4,  104);  # 'h'
    store8(both + 5,  116);  # 't'
    store8(both + 6,  116);  # 't'
    store8(both + 7,  112);  # 'p'
    store8(both + 8,  47);   # '/'
    store8(both + 9,  49);   # '1'
    store8(both + 10, 46);   # '.'
    store8(both + 11, 49);   # '1'
    _sandhi_alpn_h2h11_wire = both;
    return 0;
}

fn _sandhi_alpn_resolve_fns(): i64 {
    if (_sandhi_alpn_resolved == 1) { return 0; }
    _sandhi_alpn_get0_fp = tls_dlsym("SSL_get0_alpn_selected");
    _sandhi_alpn_resolved = 1;
    return 0;
}

# Hook fired by stdlib tls_connect_with_ctx_hook on the bare SSL_CTX
# before SSL_new / SSL_connect. hook_ctx points to a pair
# { protos_ptr, protos_len } (16 bytes); ssl_ctx is the SSL_CTX*.
# Returning 0 keeps the connection going; non-zero aborts the
# handshake (stdlib frees the ctx and returns 0 from the wrapper).
#
# 1.3.0: switched from `tls_dlsym("SSL_CTX_set_alpn_protos") +
# fncall3` to stdlib's typed `tls_set_alpn` wrapper (cyrius v5.10.13).
# Removes the libssl-symbol-name binding; if the underlying TLS
# transport ever swaps, sandhi rides the contract not the symbol.
# We tolerate `tls_set_alpn` failure (returns non-zero) — connection
# without ALPN is still useful, same shape as a plain-text fallback.
fn _sandhi_alpn_hook(hook_ctx, ssl_ctx): i64 {
    var protos = load64(hook_ctx);
    var plen   = load64(hook_ctx + 8);
    tls_set_alpn(ssl_ctx, protos, plen);
    return 0;
}

# Post-handshake: extract the negotiated ALPN protocol (if any) and
# return a freshly-alloc'd NUL-terminated cstr. 0 if ALPN didn't
# select anything or the get0 symbol isn't available.
#
# `tls_ctx` is the stdlib tls_connect ctx (24-byte struct: ssl_ctx /
# ssl / sock at offsets 0/8/16). We pull the SSL handle from offset
# 8 and call SSL_get0_alpn_selected(ssl, &out, &outlen). The bytes
# at *out are owned by libssl and freed when SSL is freed, so we
# copy into our own buffer.
# Read the negotiated ALPN protocol into `a`. The two scratch cells
# (out_p / out_l) are short-lived; the returned cstr lives on the
# conn struct, so it inherits the conn's lifetime — when the conn was
# allocated from an arena, the ALPN slot lives in the same arena.
fn _sandhi_alpn_read_selected_a(a, tls_ctx): i64 {
    _sandhi_alpn_resolve_fns();
    if (_sandhi_alpn_get0_fp == 0) { return 0; }
    if (tls_ctx == 0) { return 0; }
    var ssl = load64(tls_ctx + 8);
    if (ssl == 0) { return 0; }
    var out_p = alloc_via(a, 8);
    var out_l = alloc_via(a, 8);
    if (out_p == 0 || out_l == 0) { return 0; }
    store64(out_p, 0);
    store64(out_l, 0);
    fncall3(_sandhi_alpn_get0_fp, ssl, out_p, out_l);
    var data = load64(out_p);
    var dlen = load64(out_l);
    if (dlen <= 0 || data == 0) { return 0; }
    var copy = alloc_via(a, dlen + 1);
    if (copy == 0) { return 0; }
    var i = 0;
    while (i < dlen) {
        store8(copy + i, load8(data + i));
        i = i + 1;
    }
    store8(copy + dlen, 0);
    return copy;
}

fn _sandhi_alpn_read_selected(tls_ctx): i64 {
    return _sandhi_alpn_read_selected_a(default_alloc(), tls_ctx);
}

# Linux socket option constants. stdlib `lib/net.cyr` exposes
# `SYS_SETSOCKOPT=54` + `SOL_SOCKET=1` + `SO_REUSEADDR=2`; we add the
# receive/send timeout values locally (Linux x86_64/arm64 parity —
# values are stable across both per include/uapi/asm-generic/socket.h).
var _SANDHI_SO_RCVTIMEO = 20;
var _SANDHI_SO_SNDTIMEO = 21;

# Linux errno for "would block / timed out on socket with SO_RCVTIMEO".
var _SANDHI_EAGAIN = 11;

# Non-blocking connect primitives (0.7.3). Linux x86_64 syscall
# numbers; aarch64 differs (poll is ppoll=73, getsockopt=209) — when
# aarch64 support becomes a goal it needs a cross-cutting pass across
# sandhi + stdlib anyway (SYS_SETSOCKOPT=54 in net.cyr is already
# x86_64-only). No regression.
var _SANDHI_SYS_POLL       = 7;
var _SANDHI_SYS_GETSOCKOPT = 55;
var _SANDHI_F_GETFL        = 3;
var _SANDHI_F_SETFL        = 4;
var _SANDHI_O_NONBLOCK     = 2048;   # 0x800
var _SANDHI_EINPROGRESS    = 115;
var _SANDHI_SO_ERROR       = 4;
var _SANDHI_POLLOUT        = 4;

# Return sentinels for _sandhi_conn_connect_nb (and read by the
# open path to classify failures).
var _SANDHI_CONN_NB_OK      = 0;
var _SANDHI_CONN_NB_ERR     = 0 - 1;
var _SANDHI_CONN_NB_TIMEOUT = 0 - 2;

# Classification of the last sandhi_conn_open_* attempt. Module-level
# because Cyrius doesn't expose tagged-union returns and restructuring
# the conn-struct shape would break every caller. Single-threaded
# client today (server is also single-threaded per server/mod.cyr);
# any multi-threaded client model would need this lifted to a ctx.
var _sandhi_conn_last_err = 0;

enum SandhiConnOpenErr {
    SANDHI_CONN_OPEN_OK        = 0;
    SANDHI_CONN_OPEN_CONNECT   = 1;
    SANDHI_CONN_OPEN_TIMEOUT   = 2;
    SANDHI_CONN_OPEN_TLS       = 3;
}

fn sandhi_conn_last_open_err(): i64 {
    return _sandhi_conn_last_err;
}

fn sandhi_conn_kind(c): i64 { return load64(c + SANDHI_CONN_OFF_KIND); }
fn sandhi_conn_fd(c): i64 { return load64(c + SANDHI_CONN_OFF_FD); }
fn sandhi_conn_tls_ctx(c): i64 { return load64(c + SANDHI_CONN_OFF_TLS_CTX); }

# 1.3.2 — 0-RTT acceptance status. Returns one of:
#   TLS_EARLY_DATA_NOT_SENT (0) — no 0-RTT attempted, OR conn is
#                                 plain HTTP, OR pool reuse
#   TLS_EARLY_DATA_REJECTED (1) — server rejected; exchange path
#                                 must resend via `tls_write`
#   TLS_EARLY_DATA_ACCEPTED (2) — server accepted; exchange path
#                                 skips send, jumps to recv
fn sandhi_conn_0rtt_status(c): i64 {
    if (c == 0) { return 0; }
    return load64(c + SANDHI_CONN_OFF_0RTT_STATUS);
}

# Set SO_RCVTIMEO or SO_SNDTIMEO to `ms` milliseconds. Value is a
# `struct timeval { tv_sec: i64, tv_usec: i64 }` = 16 bytes on
# x86_64 / aarch64 Linux. ms<=0 is a no-op.
fn _sandhi_conn_set_timeout_ms_a(a, fd, ms, opt): i64 {
    if (ms <= 0) { return 0; }
    var tv = alloc_via(a, 16);
    if (tv == 0) { return 0 - 1; }
    var sec = ms / 1000;
    var usec = (ms - sec * 1000) * 1000;
    store64(tv, sec);
    store64(tv + 8, usec);
    return syscall(SYS_SETSOCKOPT, fd, SOL_SOCKET, opt, tv, 16);
}

fn _sandhi_conn_set_timeout_ms(fd, ms, opt): i64 {
    return _sandhi_conn_set_timeout_ms_a(default_alloc(), fd, ms, opt);
}

# Open a connection to the given IPv4 address (network-byte-order
# uint32 from sandhi_resolve_ipv4 or a hand-built literal) and port.
# If use_tls == 1, wrap the socket via tls_connect using sni_host for
# SNI + peer verification. Returns the conn struct on success, 0 on
# any failure path (socket create, connect, TLS handshake).
#
# `addr` is the same shape net.cyr expects: a 32-bit big-endian IPv4
# address packed as an int (e.g. 127.0.0.1 → 0x0100007F on little-
# endian hosts per INADDR_LOOPBACK).
# Non-blocking connect with poll-based timeout. Puts the fd in
# O_NONBLOCK, fires connect (expects EINPROGRESS), polls for POLLOUT
# up to timeout_ms, reads SO_ERROR to distinguish connected from
# refused, then restores blocking mode. Leaves the fd in blocking
# mode on every exit path so subsequent recv/send behave normally.
#
# Returns:
#   _SANDHI_CONN_NB_OK      (0)  — connected
#   _SANDHI_CONN_NB_TIMEOUT (-2) — poll timed out waiting for completion
#   _SANDHI_CONN_NB_ERR     (-1) — any other failure (fcntl, immediate
#                                  connect err, SO_ERROR non-zero)
fn _sandhi_conn_connect_nb_a(a, fd, addr, port, timeout_ms): i64 {
    var flags = syscall(SYS_FCNTL, fd, _SANDHI_F_GETFL, 0);
    if (flags < 0) { return _SANDHI_CONN_NB_ERR; }
    syscall(SYS_FCNTL, fd, _SANDHI_F_SETFL, flags | _SANDHI_O_NONBLOCK);

    var cr = sock_connect(fd, addr, port);
    if (is_err_result(cr) == 0) {
        # Instant success (common for localhost).
        syscall(SYS_FCNTL, fd, _SANDHI_F_SETFL, flags);
        return _SANDHI_CONN_NB_OK;
    }

    var err = payload(cr);
    if (err != _SANDHI_EINPROGRESS) {
        # Real error — don't poll, just fail.
        syscall(SYS_FCNTL, fd, _SANDHI_F_SETFL, flags);
        return _SANDHI_CONN_NB_ERR;
    }

    # Poll for POLLOUT with the caller's timeout.
    # struct pollfd { fd: i32, events: i16, revents: i16 } = 8 bytes.
    var pfd = alloc_via(a, 8);
    if (pfd == 0) {
        syscall(SYS_FCNTL, fd, _SANDHI_F_SETFL, flags);
        return _SANDHI_CONN_NB_ERR;
    }
    store32(pfd, fd);
    store16(pfd + 4, _SANDHI_POLLOUT);
    store16(pfd + 6, 0);
    var nr = syscall(_SANDHI_SYS_POLL, pfd, 1, timeout_ms);
    if (nr == 0) {
        syscall(SYS_FCNTL, fd, _SANDHI_F_SETFL, flags);
        return _SANDHI_CONN_NB_TIMEOUT;
    }
    if (nr < 0) {
        syscall(SYS_FCNTL, fd, _SANDHI_F_SETFL, flags);
        return _SANDHI_CONN_NB_ERR;
    }

    var err_val = alloc_via(a, 4);
    var len_cell = alloc_via(a, 4);
    if (err_val == 0 || len_cell == 0) {
        syscall(SYS_FCNTL, fd, _SANDHI_F_SETFL, flags);
        return _SANDHI_CONN_NB_ERR;
    }
    store32(err_val, 0);
    store32(len_cell, 4);
    syscall(_SANDHI_SYS_GETSOCKOPT, fd, SOL_SOCKET, _SANDHI_SO_ERROR, err_val, len_cell);
    var so_err = load32(err_val);
    syscall(SYS_FCNTL, fd, _SANDHI_F_SETFL, flags);
    if (so_err != 0) { return _SANDHI_CONN_NB_ERR; }
    return _SANDHI_CONN_NB_OK;
}

fn _sandhi_conn_connect_nb(fd, addr, port, timeout_ms): i64 {
    return _sandhi_conn_connect_nb_a(default_alloc(), fd, addr, port, timeout_ms);
}

fn sandhi_conn_open_a(a, addr, port, use_tls, sni_host): i64 {
    return sandhi_conn_open_timed_a(a, addr, port, use_tls, sni_host, 0, 0);
}

fn sandhi_conn_open(addr, port, use_tls, sni_host): i64 {
    return sandhi_conn_open_a(default_alloc(), addr, port, use_tls, sni_host);
}

# Open a connection with per-operation timeouts. read_ms and write_ms
# apply to subsequent recv/send via SO_RCVTIMEO/SO_SNDTIMEO; 0 means
# blocking (kernel default). connect() itself is blocking (kernel
# default; can take up to ~75 s on a dropped-SYN blackhole). For a
# bounded connect, use sandhi_conn_open_fully_timed with connect_ms.
#
# On a timeout during recv/send, the underlying syscall returns
# EAGAIN (-11). sandhi_conn_recv/send convert that to -_SANDHI_EAGAIN
# so callers can distinguish "connection broke" from "deadline fired".
fn sandhi_conn_open_timed_a(a, addr, port, use_tls, sni_host, read_ms, write_ms): i64 {
    return sandhi_conn_open_fully_timed_a(a, addr, port, use_tls, sni_host, 0, read_ms, write_ms);
}

fn sandhi_conn_open_timed(addr, port, use_tls, sni_host, read_ms, write_ms): i64 {
    return sandhi_conn_open_timed_a(default_alloc(), addr, port, use_tls, sni_host, read_ms, write_ms);
}

# Open with connect + r/w timeouts (0.7.3). connect_ms=0 means blocking
# connect (pre-0.7.3 behavior). connect_ms>0 uses _sandhi_conn_connect_nb.
# On failure, `sandhi_conn_last_open_err()` returns the classification
# (SANDHI_CONN_OPEN_CONNECT / _TIMEOUT / _TLS) so callers can raise
# the right SANDHI_ERR_*.
# Build a sockaddr_in6 (28 bytes) from a 16-byte address buffer +
# port. Caller-owned alloc. Layout matches Linux uapi
# /usr/include/linux/in6.h.
fn _sandhi_conn_sockaddr_in6_a(a, addr16, port): i64 {
    var sa = alloc_via(a, 28);
    if (sa == 0) { return 0; }
    memset(sa, 0, 28);
    store16(sa + 0, 10);  # AF_INET6
    store8(sa + 2, (port >> 8) & 0xFF);
    store8(sa + 3, port & 0xFF);
    # sin6_flowinfo = 0 (already memset'd)
    var i = 0;
    while (i < 16) {
        store8(sa + 8 + i, load8(addr16 + i));
        i = i + 1;
    }
    # sin6_scope_id = 0 (already memset'd; non-zero only for link-local)
    return sa;
}

fn _sandhi_conn_sockaddr_in6(addr16, port): i64 {
    return _sandhi_conn_sockaddr_in6_a(default_alloc(), addr16, port);
}

# Open an IPv6 connection. Internal-only — sandhi's public surface
# (frozen at 0.9.2 per ADR 0005) stays IPv4-named but the http
# client tries v6 fallback through this path. `addr16` is a
# 16-byte network-byte-order AAAA address buffer (e.g. from
# sandhi_resolve_ipv6).
#
# connect_ms is honored via the same non-blocking + poll dance the
# v4 path uses; the only difference is the connect syscall takes
# a sockaddr_in6 (28 bytes) instead of sockaddr_in (16 bytes).
# Bounded connect against an arbitrary already-built sockaddr (v4
# or v6). fd is already in default blocking mode; flips to
# non-blocking, fires connect, polls POLLOUT, restores blocking.
# Returns _SANDHI_CONN_NB_OK / _TIMEOUT / _ERR matching the v4-only
# variant.
fn _sandhi_conn_connect_sa_nb_a(a, fd, sa, salen, timeout_ms): i64 {
    var flags = syscall(SYS_FCNTL, fd, _SANDHI_F_GETFL, 0);
    if (flags < 0) { return _SANDHI_CONN_NB_ERR; }
    syscall(SYS_FCNTL, fd, _SANDHI_F_SETFL, flags | _SANDHI_O_NONBLOCK);

    var rc = syscall(SYS_CONNECT, fd, sa, salen);
    if (rc == 0) {
        syscall(SYS_FCNTL, fd, _SANDHI_F_SETFL, flags);
        return _SANDHI_CONN_NB_OK;
    }
    var errno_v = 0 - rc;
    if (errno_v != _SANDHI_EINPROGRESS) {
        syscall(SYS_FCNTL, fd, _SANDHI_F_SETFL, flags);
        return _SANDHI_CONN_NB_ERR;
    }
    var pfd = alloc_via(a, 8);
    if (pfd == 0) {
        syscall(SYS_FCNTL, fd, _SANDHI_F_SETFL, flags);
        return _SANDHI_CONN_NB_ERR;
    }
    store32(pfd, fd);
    store16(pfd + 4, _SANDHI_POLLOUT);
    store16(pfd + 6, 0);
    var nr = syscall(_SANDHI_SYS_POLL, pfd, 1, timeout_ms);
    if (nr == 0) {
        syscall(SYS_FCNTL, fd, _SANDHI_F_SETFL, flags);
        return _SANDHI_CONN_NB_TIMEOUT;
    }
    if (nr < 0) {
        syscall(SYS_FCNTL, fd, _SANDHI_F_SETFL, flags);
        return _SANDHI_CONN_NB_ERR;
    }
    var err_val = alloc_via(a, 4);
    var len_cell = alloc_via(a, 4);
    if (err_val == 0 || len_cell == 0) {
        syscall(SYS_FCNTL, fd, _SANDHI_F_SETFL, flags);
        return _SANDHI_CONN_NB_ERR;
    }
    store32(err_val, 0);
    store32(len_cell, 4);
    syscall(_SANDHI_SYS_GETSOCKOPT, fd, SOL_SOCKET, _SANDHI_SO_ERROR, err_val, len_cell);
    var so_err = load32(err_val);
    syscall(SYS_FCNTL, fd, _SANDHI_F_SETFL, flags);
    if (so_err != 0) { return _SANDHI_CONN_NB_ERR; }
    return _SANDHI_CONN_NB_OK;
}

fn _sandhi_conn_connect_sa_nb(fd, sa, salen, timeout_ms): i64 {
    return _sandhi_conn_connect_sa_nb_a(default_alloc(), fd, sa, salen, timeout_ms);
}

# Post-connect plumbing: SO_RCVTIMEO/SO_SNDTIMEO, TLS handshake with
# the policy/ALPN hook, ALPN slot population, conn struct alloc.
# Shared between the v4 and v6 open paths.
# Finalize a connected fd into a sandhi_conn struct allocated from `a`.
# The conn struct's lifetime matches `a` — long-lived pool conns want
# default_alloc; per-request one-shots can use an arena. The hook ctx
# (16 bytes for the ALPN hook) and the ALPN-selected cstr also live
# in `a`. The wire literals themselves are process-wide singletons
# (see _sandhi_alpn_init_wire).
fn _sandhi_conn_finalize_with_early_data_a(a, fd, use_tls, sni_host,
read_ms, write_ms, early_data, early_data_len): i64 {
    if (read_ms > 0)  { _sandhi_conn_set_timeout_ms_a(a, fd, read_ms,  _SANDHI_SO_RCVTIMEO); }
    if (write_ms > 0) { _sandhi_conn_set_timeout_ms_a(a, fd, write_ms, _SANDHI_SO_SNDTIMEO); }

    var tls_ctx = 0;
    var kind = SANDHI_CONN_PLAIN;
    var alpn_data = 0;
    var early_data_status = 0;  # TLS_EARLY_DATA_NOT_SENT
    if (use_tls == 1) {
        if (tls_available() == 0) {
            sock_close(fd);
            _sandhi_conn_last_err = SANDHI_CONN_OPEN_TLS;
            return 0;
        }
        var hook_fp = 0;
        var hook_ctx = 0;
        if (_sandhi_tls_hook_override != 0) {
            hook_fp  = _sandhi_tls_hook_override;
            hook_ctx = _sandhi_tls_hook_override_ctx;
        } else {
            _sandhi_alpn_init_wire();
            hook_ctx = alloc_via(a, 16);
            if (hook_ctx == 0) {
                sock_close(fd);
                _sandhi_conn_last_err = SANDHI_CONN_OPEN_TLS;
                return 0;
            }
            if (_sandhi_alpn_advertise_h2 == 1) {
                store64(hook_ctx,     _sandhi_alpn_h2h11_wire);
                store64(hook_ctx + 8, _sandhi_alpn_h2h11_wire_len);
            } else {
                store64(hook_ctx,     _sandhi_alpn_h11_wire);
                store64(hook_ctx + 8, _sandhi_alpn_h11_wire_len);
            }
            hook_fp = &_sandhi_alpn_hook;
        }
        # 1.3.1 staged-connect with session-resumption hook.
        # When `sandhi_session_cache_enable(1)` is set AND the
        # cache has a session for (sni_host, hook_fp), we install
        # it pre-`SSL_connect` via `tls_set_session` to attempt
        # resumption. Post-handshake we capture a fresh session
        # via `tls_get_session` for the next request.
        # When the cache is disabled, lookup returns 0 and store
        # is a no-op — the path collapses to one-shot connect
        # with one extra global-load per call.
        tls_ctx = tls_connect_alloc(fd, sni_host, hook_fp, hook_ctx);
        if (tls_ctx == 0) {
            sock_close(fd);
            _sandhi_conn_last_err = SANDHI_CONN_OPEN_TLS;
            return 0;
        }
        var cached_sess = sandhi_session_cache_lookup(sni_host, hook_fp, _sandhi_cred_digest);
        if (cached_sess != 0) {
            tls_set_session(tls_ctx, cached_sess);
        }
        # 1.3.2 — 0-RTT write between session-set and handshake-
        # complete. Caller already gated `early_data` non-zero
        # on capability + method-safety + session-presence; here
        # we only need the per-session-size check
        # (`tls_session_get_max_early_data` against actual req
        # length). Skip 0-RTT silently if the session doesn't
        # advertise enough budget. tls_write_early_data return
        # value is informational — definitive accepted/rejected
        # signal comes post-handshake from
        # `tls_get_early_data_status`.
        if (early_data != 0 && early_data_len > 0 && cached_sess != 0) {
            var max_early = tls_session_get_max_early_data(cached_sess);
            if (max_early >= early_data_len) {
                tls_write_early_data(tls_ctx, early_data, early_data_len);
            }
        }
        if (tls_connect_complete(tls_ctx) != 1) {
            tls_close(tls_ctx);
            sock_close(fd);
            _sandhi_conn_last_err = SANDHI_CONN_OPEN_TLS;
            return 0;
        }
        # Post-handshake early-data status — drives the
        # exchange path's send-or-skip decision.
        early_data_status = tls_get_early_data_status(tls_ctx);
        # Capture session for next time. tls_get_session bumps the
        # refcount; the cache takes ownership of that ref.
        var fresh_sess = tls_get_session(tls_ctx);
        if (fresh_sess != 0) {
            sandhi_session_cache_store(sni_host, hook_fp, _sandhi_cred_digest, fresh_sess);
        }
        alpn_data = _sandhi_alpn_read_selected_a(a, tls_ctx);
        kind = SANDHI_CONN_TLS;
    }

    var conn = alloc_via(a, SANDHI_CONN_STRUCT_SIZE);
    if (conn == 0) {
        if (tls_ctx != 0) { tls_close(tls_ctx); }
        sock_close(fd);
        _sandhi_conn_last_err = SANDHI_CONN_OPEN_TLS;
        return 0;
    }
    store64(conn + SANDHI_CONN_OFF_KIND, kind);
    store64(conn + SANDHI_CONN_OFF_FD, fd);
    store64(conn + SANDHI_CONN_OFF_TLS_CTX, tls_ctx);
    store64(conn + SANDHI_CONN_OFF_ALPN_DATA, alpn_data);
    store64(conn + SANDHI_CONN_OFF_0RTT_STATUS, early_data_status);
    return conn;
}

# Back-compat wrapper — pre-1.3.2 callers don't pass early-data.
fn _sandhi_conn_finalize_a(a, fd, use_tls, sni_host, read_ms, write_ms): i64 {
    return _sandhi_conn_finalize_with_early_data_a(a, fd, use_tls, sni_host,
    read_ms, write_ms, 0, 0);
}

fn _sandhi_conn_finalize(fd, use_tls, sni_host, read_ms, write_ms): i64 {
    return _sandhi_conn_finalize_a(default_alloc(), fd, use_tls, sni_host, read_ms, write_ms);
}

# Open an IPv6 connection. Internal-only — sandhi's public surface
# (frozen at 0.9.2 per ADR 0005) stays IPv4-named but the http
# client tries v6 fallback through this path. `addr16` is a
# 16-byte network-byte-order AAAA address buffer (e.g. from
# sandhi_resolve_ipv6).
fn _sandhi_conn_open_v6_fully_timed_a(a, addr16, port, use_tls, sni_host, connect_ms, read_ms, write_ms): i64 {
    _sandhi_conn_last_err = SANDHI_CONN_OPEN_OK;
    if (addr16 == 0) {
        _sandhi_conn_last_err = SANDHI_CONN_OPEN_CONNECT;
        return 0;
    }
    var fd = syscall(SYS_SOCKET, 10, 1, 0);  # AF_INET6, SOCK_STREAM
    if (fd < 0) {
        _sandhi_conn_last_err = SANDHI_CONN_OPEN_CONNECT;
        return 0;
    }
    var sa = _sandhi_conn_sockaddr_in6_a(a, addr16, port);
    if (sa == 0) {
        sock_close(fd); _sandhi_conn_last_err = SANDHI_CONN_OPEN_CONNECT; return 0;
    }
    if (connect_ms > 0) {
        var nbr = _sandhi_conn_connect_sa_nb_a(a, fd, sa, 28, connect_ms);
        if (nbr == _SANDHI_CONN_NB_TIMEOUT) {
            sock_close(fd); _sandhi_conn_last_err = SANDHI_CONN_OPEN_TIMEOUT; return 0;
        }
        if (nbr != _SANDHI_CONN_NB_OK) {
            sock_close(fd); _sandhi_conn_last_err = SANDHI_CONN_OPEN_CONNECT; return 0;
        }
    } else {
        var rc = syscall(SYS_CONNECT, fd, sa, 28);
        if (rc < 0) {
            sock_close(fd); _sandhi_conn_last_err = SANDHI_CONN_OPEN_CONNECT; return 0;
        }
    }
    return _sandhi_conn_finalize_a(a, fd, use_tls, sni_host, read_ms, write_ms);
}

fn _sandhi_conn_open_v6_fully_timed(addr16, port, use_tls, sni_host, connect_ms, read_ms, write_ms): i64 {
    return _sandhi_conn_open_v6_fully_timed_a(
    default_alloc(), addr16, port, use_tls, sni_host,
    connect_ms, read_ms, write_ms);
}

# 1.3.2 — v6 variant of the early-data-aware open path.
fn _sandhi_conn_open_v6_fully_timed_with_early_data_a(a, addr16, port,
use_tls, sni_host, connect_ms, read_ms, write_ms, early_data, early_data_len): i64 {
    _sandhi_conn_last_err = SANDHI_CONN_OPEN_OK;
    if (addr16 == 0) {
        _sandhi_conn_last_err = SANDHI_CONN_OPEN_CONNECT;
        return 0;
    }
    var fd = syscall(SYS_SOCKET, 10, 1, 0);  # AF_INET6, SOCK_STREAM
    if (fd < 0) {
        _sandhi_conn_last_err = SANDHI_CONN_OPEN_CONNECT;
        return 0;
    }
    var sa = _sandhi_conn_sockaddr_in6_a(a, addr16, port);
    if (sa == 0) {
        sock_close(fd); _sandhi_conn_last_err = SANDHI_CONN_OPEN_CONNECT; return 0;
    }
    if (connect_ms > 0) {
        var nbr = _sandhi_conn_connect_sa_nb_a(a, fd, sa, 28, connect_ms);
        if (nbr == _SANDHI_CONN_NB_TIMEOUT) {
            sock_close(fd); _sandhi_conn_last_err = SANDHI_CONN_OPEN_TIMEOUT; return 0;
        }
        if (nbr != _SANDHI_CONN_NB_OK) {
            sock_close(fd); _sandhi_conn_last_err = SANDHI_CONN_OPEN_CONNECT; return 0;
        }
    } else {
        var rc = syscall(SYS_CONNECT, fd, sa, 28);
        if (rc < 0) {
            sock_close(fd); _sandhi_conn_last_err = SANDHI_CONN_OPEN_CONNECT; return 0;
        }
    }
    return _sandhi_conn_finalize_with_early_data_a(a, fd, use_tls, sni_host,
    read_ms, write_ms, early_data, early_data_len);
}

fn sandhi_conn_open_fully_timed_a(a, addr, port, use_tls, sni_host, connect_ms, read_ms, write_ms): i64 {
    _sandhi_conn_last_err = SANDHI_CONN_OPEN_OK;

    var sfd_r = tcp_socket();
    if (is_err_result(sfd_r) == 1) {
        _sandhi_conn_last_err = SANDHI_CONN_OPEN_CONNECT;
        return 0;
    }
    var fd = payload(sfd_r);

    if (connect_ms > 0) {
        var nbr = _sandhi_conn_connect_nb_a(a, fd, addr, port, connect_ms);
        if (nbr == _SANDHI_CONN_NB_TIMEOUT) {
            sock_close(fd);
            _sandhi_conn_last_err = SANDHI_CONN_OPEN_TIMEOUT;
            return 0;
        }
        if (nbr != _SANDHI_CONN_NB_OK) {
            sock_close(fd);
            _sandhi_conn_last_err = SANDHI_CONN_OPEN_CONNECT;
            return 0;
        }
    } else {
        var cr = sock_connect(fd, addr, port);
        if (is_err_result(cr) == 1) {
            sock_close(fd);
            _sandhi_conn_last_err = SANDHI_CONN_OPEN_CONNECT;
            return 0;
        }
    }

    return _sandhi_conn_finalize_a(a, fd, use_tls, sni_host, read_ms, write_ms);
}

fn sandhi_conn_open_fully_timed(addr, port, use_tls, sni_host, connect_ms, read_ms, write_ms): i64 {
    return sandhi_conn_open_fully_timed_a(
    default_alloc(), addr, port, use_tls, sni_host,
    connect_ms, read_ms, write_ms);
}

# 1.3.2 — open with early-data attached. Internal-only; the public
# `sandhi_conn_open_fully_timed_a` stays unchanged. Caller
# (`_sandhi_http_do_impl_a`) pre-checks 0-RTT eligibility
# (allow_0rtt opt + method safety + capability + session present);
# this fn just plumbs early_data + early_data_len through to
# `_sandhi_conn_finalize_with_early_data_a`. The actual size-fit
# check (`tls_session_get_max_early_data >= len`) happens inside
# finalize against the cached session.
fn _sandhi_conn_open_fully_timed_with_early_data_a(a, addr, port, use_tls,
sni_host, connect_ms, read_ms, write_ms, early_data, early_data_len): i64 {
    _sandhi_conn_last_err = SANDHI_CONN_OPEN_OK;

    var sfd_r = tcp_socket();
    if (is_err_result(sfd_r) == 1) {
        _sandhi_conn_last_err = SANDHI_CONN_OPEN_CONNECT;
        return 0;
    }
    var fd = payload(sfd_r);

    if (connect_ms > 0) {
        var nbr = _sandhi_conn_connect_nb_a(a, fd, addr, port, connect_ms);
        if (nbr == _SANDHI_CONN_NB_TIMEOUT) {
            sock_close(fd);
            _sandhi_conn_last_err = SANDHI_CONN_OPEN_TIMEOUT;
            return 0;
        }
        if (nbr != _SANDHI_CONN_NB_OK) {
            sock_close(fd);
            _sandhi_conn_last_err = SANDHI_CONN_OPEN_CONNECT;
            return 0;
        }
    } else {
        var cr = sock_connect(fd, addr, port);
        if (is_err_result(cr) == 1) {
            sock_close(fd);
            _sandhi_conn_last_err = SANDHI_CONN_OPEN_CONNECT;
            return 0;
        }
    }

    return _sandhi_conn_finalize_with_early_data_a(a, fd, use_tls, sni_host,
    read_ms, write_ms, early_data, early_data_len);
}

# Send `len` bytes through the connection. Returns bytes sent, 0 on
# peer-close, or a negative errno on error. Specifically returns
# `0 - _SANDHI_EAGAIN` when SO_SNDTIMEO fires — callers map to
# SANDHI_ERR_TIMEOUT. Any other negative is a CONNECT-class error.
# Full write not guaranteed — caller loops on partial.
fn sandhi_conn_send(conn, buf, len): i64 {
    if (conn == 0) { return 0 - 1; }
    if (sandhi_conn_kind(conn) == SANDHI_CONN_TLS) {
        # tls_write returns negative on error (pre-libssl-pthread-fix
        # we can't reach here anyway); passthrough keeps contract.
        return tls_write(sandhi_conn_tls_ctx(conn), buf, len);
    }
    var r = sock_send(sandhi_conn_fd(conn), buf, len);
    if (is_err_result(r) == 1) { return 0 - payload(r); }
    return payload(r);
}

# Send a full cstr. Loops on partial writes. Returns 0 on success,
# `0 - _SANDHI_EAGAIN` on send-timeout, -1 on any other failure.
fn sandhi_conn_send_all(conn, buf, len): i64 {
    var sent = 0;
    while (sent < len) {
        var n = sandhi_conn_send(conn, buf + sent, len - sent);
        if (n == 0 - _SANDHI_EAGAIN) { return 0 - _SANDHI_EAGAIN; }
        if (n <= 0) { return 0 - 1; }
        sent = sent + n;
    }
    return 0;
}

# Receive up to `max` bytes. Returns bytes read, 0 at EOF, or a
# negative errno on error. `0 - _SANDHI_EAGAIN` signals a read
# timeout (SO_RCVTIMEO fired); callers treat other negatives as
# CONNECT-class.
fn sandhi_conn_recv(conn, buf, max): i64 {
    if (conn == 0) { return 0 - 1; }
    if (sandhi_conn_kind(conn) == SANDHI_CONN_TLS) {
        var tr = tls_read(sandhi_conn_tls_ctx(conn), buf, max);
        if (tr < 0) { return 0 - 1; }
        return tr;
    }
    var r = sock_recv(sandhi_conn_fd(conn), buf, max);
    if (is_err_result(r) == 1) { return 0 - payload(r); }
    return payload(r);
}

# Drain the connection into `buf` up to `max` bytes. Reads until EOF or
# max reached. Returns total bytes read on success; `0 - _SANDHI_EAGAIN`
# if read-timeout fires; `0 - 1` for any other error. Always null-
# terminates buf at the returned length (buf must have room for max+1).
fn sandhi_conn_recv_all(conn, buf, max): i64 {
    return sandhi_conn_recv_all_deadline(conn, buf, max, 0);
}

# Same as sandhi_conn_recv_all but bounded by a monotonic deadline
# (clock_now_ms() value; 0 = no deadline). Added 0.7.3 for total_ms
# enforcement — each iteration of the read loop checks the deadline
# before the next recv and returns -_SANDHI_EAGAIN if it's passed.
# SO_RCVTIMEO still bounds individual recv calls; the deadline is
# the outer ceiling.
fn sandhi_conn_recv_all_deadline(conn, buf, max, deadline_ms): i64 {
    var have = 0;
    var going = 1;
    while (going == 1 && have < max) {
        if (deadline_ms > 0) {
            if (clock_now_ms() >= deadline_ms) {
                store8(buf + have, 0);
                return 0 - _SANDHI_EAGAIN;
            }
        }
        var n = sandhi_conn_recv(conn, buf + have, max - have);
        if (n == 0 - _SANDHI_EAGAIN) { return 0 - _SANDHI_EAGAIN; }
        if (n < 0) { return 0 - 1; }
        if (n == 0) { going = 0; }
        else { have = have + n; }
    }
    store8(buf + have, 0);
    return have;
}

# Close the connection. Shuts TLS cleanly, closes the fd. No-op on 0.
fn sandhi_conn_close(conn): i64 {
    if (conn == 0) { return 0; }
    if (sandhi_conn_kind(conn) == SANDHI_CONN_TLS) {
        tls_close(sandhi_conn_tls_ctx(conn));
    }
    sock_close(sandhi_conn_fd(conn));
    return 0;
}


# --- response.cyr ---

# sandhi/http/response — response parser (status line + headers + body).
#
# Handles the three HTTP/1.1 body framings:
#   - Content-Length: N  — N bytes of body
#   - Transfer-Encoding: chunked  — decoded chunk-by-chunk
#   - Neither  — read-to-close (Connection: close semantics)
#
# The parser works on a complete response buffer. Drainage (reading
# bytes until the buffer is complete) is the caller's concern — the
# client does that via sandhi_conn_recv_all.
#
# Struct layout (48 bytes):
#   +0   status      (int: 100..599, or 0 if unparseable)
#   +8   body_ptr    (ptr: alloc-owned; null-terminated for convenience)
#   +16  body_len    (int: decoded body length)
#   +24  headers     (ptr: sandhi_headers block, never 0 after parse)
#   +32  err_kind    (int: SandhiErrorKind — 0 on parseable status)
#   +40  err_message (cstr: optional context; 0 if none. Added in 0.7.1
#                    to mirror rpc-response shape. Callers today receive
#                    0 for every err_kind the parser raises; the slot
#                    is reserved so the 0.8.x security pass — which
#                    needs to surface "CL+TE both present" / "chunked
#                    truncated" / "redirect strip" reasons — doesn't
#                    break ABI.)
#
# NOTE (2026-04-24): the body-framing logic is split into
# `_sandhi_resp_frame` because under a heavier local count in
# `sandhi_http_response_parse`, `var headers` appeared to get zeroed
# after a downstream `sandhi_headers_get` call. At the time (sandhi
# M2 on cyrius 5.6.22) this was tracked as a compiler quirk — but
# the post-mortem at `docs/issues/archive/2026-04-24-fdlopen-getaddrinfo-blocked.md`
# (closed v5.6.29-1) identified the HTTPS-loop sibling symptom as
# "undef-fn call-sites silently patched with a placeholder disp32
# that re-enters _cyrius_init" — almost certainly the same mechanism
# underlying this one. sandhi's `[deps.stdlib]` was missing
# `dynlib`/`mmap`/`fdlopen`/`bigint`/`freelist` at the time, which
# would produce the same class of silent-stomp symptoms on calls
# transitively resolving through the missing libs. Keeping the
# split regardless — the smaller function is the better shape even
# on correctly-linked binaries.

enum SandhiRespOff {
    SANDHI_RESP_OFF_STATUS    = 0;
    SANDHI_RESP_OFF_BODY_PTR  = 8;
    SANDHI_RESP_OFF_BODY_LEN  = 16;
    SANDHI_RESP_OFF_HEADERS   = 24;
    SANDHI_RESP_OFF_ERR_KIND  = 32;
    SANDHI_RESP_OFF_ERR_MSG   = 40;
}

var SANDHI_RESP_STRUCT_SIZE = 48;

# Public accessors. Same rationale as URL accessors — lets us reshape
# the struct without churning call sites.
fn sandhi_http_status(r): i64 { return load64(r + SANDHI_RESP_OFF_STATUS); }
fn sandhi_http_body(r): i64 { return load64(r + SANDHI_RESP_OFF_BODY_PTR); }
fn sandhi_http_body_len(r): i64 { return load64(r + SANDHI_RESP_OFF_BODY_LEN); }
fn sandhi_http_headers(r): i64 { return load64(r + SANDHI_RESP_OFF_HEADERS); }
fn sandhi_http_err_kind(r): i64 { return load64(r + SANDHI_RESP_OFF_ERR_KIND); }
fn sandhi_http_err_message(r): i64 { return load64(r + SANDHI_RESP_OFF_ERR_MSG); }

# Build a response struct in one shot, allocated from `a`. Returns 0
# on OOM. This is THE central constructor — every public client verb
# eventually returns a struct built here, so threading the Allocator
# through is the foundation of the per-request-arena pattern: a
# handler can build everything (headers, body, struct) into one arena
# and reset between requests.
fn _sandhi_resp_new_a(a, status, body_ptr, body_len, headers, err_kind): i64 {
    var r = alloc_via(a, SANDHI_RESP_STRUCT_SIZE);
    if (r == 0) { return 0; }
    store64(r + SANDHI_RESP_OFF_STATUS, status);
    store64(r + SANDHI_RESP_OFF_BODY_PTR, body_ptr);
    store64(r + SANDHI_RESP_OFF_BODY_LEN, body_len);
    store64(r + SANDHI_RESP_OFF_HEADERS, headers);
    store64(r + SANDHI_RESP_OFF_ERR_KIND, err_kind);
    store64(r + SANDHI_RESP_OFF_ERR_MSG, 0);
    return r;
}

fn _sandhi_resp_new(status, body_ptr, body_len, headers, err_kind): i64 {
    return _sandhi_resp_new_a(default_alloc(), status, body_ptr, body_len, headers, err_kind);
}

# Error-response shortcut from `a`. Headers is always an empty block
# (never 0) so downstream code can iterate without null-checking.
fn _sandhi_resp_err_a(a, err_kind): i64 {
    return _sandhi_resp_new_a(a, 0, 0, 0, sandhi_headers_new_a(a), err_kind);
}

fn _sandhi_resp_err(err_kind): i64 {
    return _sandhi_resp_err_a(default_alloc(), err_kind);
}

# Error-response with a caller-supplied context message. The parser
# still uses `_sandhi_resp_err_a` for today's failure modes — this is
# the escape hatch for the 0.8.x security pass diagnostics.
fn _sandhi_resp_err_msg_a(a, err_kind, msg): i64 {
    var r = _sandhi_resp_err_a(a, err_kind);
    if (r == 0) { return 0; }
    store64(r + SANDHI_RESP_OFF_ERR_MSG, msg);
    return r;
}

fn _sandhi_resp_err_msg(err_kind, msg): i64 {
    return _sandhi_resp_err_msg_a(default_alloc(), err_kind, msg);
}

# Parse status line. Returns the int status code, or 0 on malformed.
fn _sandhi_resp_status(buf, blen): i64 {
    if (blen < 12) { return 0; }
    # "HTTP/1.x NNN ..."
    if (load8(buf) != 72)  { return 0; }  # H
    if (load8(buf + 1) != 84) { return 0; }  # T
    if (load8(buf + 2) != 84) { return 0; }  # T
    if (load8(buf + 3) != 80) { return 0; }  # P
    if (load8(buf + 4) != 47) { return 0; }  # /
    if (load8(buf + 8) != 32) { return 0; }  # SP after minor version
    var d0 = load8(buf + 9);
    var d1 = load8(buf + 10);
    var d2 = load8(buf + 11);
    if (d0 < 48 || d0 > 57) { return 0; }
    if (d1 < 48 || d1 > 57) { return 0; }
    if (d2 < 48 || d2 > 57) { return 0; }
    return (d0 - 48) * 100 + (d1 - 48) * 10 + (d2 - 48);
}

# Find the offset of the end-of-headers marker (\r\n\r\n). Returns
# (0 - 1) if not present — the buffer is incomplete.
fn _sandhi_resp_headers_end(buf, blen): i64 {
    var i = 0;
    while (i + 3 < blen) {
        if (load8(buf + i) == 13
        && load8(buf + i + 1) == 10
        && load8(buf + i + 2) == 13
        && load8(buf + i + 3) == 10) {
            return i;
        }
        i = i + 1;
    }
    # Also accept LF-only terminators (permissive parser).
    i = 0;
    while (i + 1 < blen) {
        if (load8(buf + i) == 10 && load8(buf + i + 1) == 10) { return i; }
        i = i + 1;
    }
    return 0 - 1;
}

# Offset of the first CR or LF from `start`, bounded by `end`.
fn _sandhi_resp_eol(buf, start, end): i64 {
    var i = start;
    while (i < end) {
        var c = load8(buf + i);
        if (c == 13 || c == 10) { return i; }
        i = i + 1;
    }
    return end;
}

# Parse chunk-size line (hex digits, CRLF-terminated). Returns the
# decoded size. Ignores chunk extensions (";name=value" after the hex).
# Walks `*offset_ptr` past the CRLF.
#
# 0.9.0 P0 #1 + #3 — hardened in two ways:
#   - Requires at least one hex digit (no-digit input returns the
#     `_SANDHI_RESP_CHUNK_BAD` sentinel rather than silently
#     succeeding with size=0). The streaming variant in stream.cyr
#     had this guard; the buffered variant did not, allowing a
#     malformed chunk to be misread as the terminal 0-chunk.
#   - Rejects sizes > 2^31. RFC 7230 doesn't cap chunk-size, but
#     anything that large overflows the signed-64-bit accumulator
#     long before it lands in a real response. Capping at i31 keeps
#     `off + size > blen` comparisons always-positive even if blen
#     itself approached i63.
var _SANDHI_RESP_CHUNK_BAD     = 0 - 1;
var _SANDHI_RESP_CHUNK_MAX     = 0x7FFFFFFF;
fn _sandhi_resp_chunk_size(buf, blen, offset_ptr): i64 {
    var p = load64(offset_ptr);
    var size = 0;
    var seen_digit = 0;
    var scan = 1;
    while (scan == 1 && p < blen) {
        var c = load8(buf + p);
        if (c >= 48 && c <= 57)      { size = size * 16 + (c - 48); seen_digit = 1; p = p + 1; }
        elif (c >= 97 && c <= 102)   { size = size * 16 + (c - 87); seen_digit = 1; p = p + 1; }
        elif (c >= 65 && c <= 70)    { size = size * 16 + (c - 55); seen_digit = 1; p = p + 1; }
        else { scan = 0; }
        if (size > _SANDHI_RESP_CHUNK_MAX) { return _SANDHI_RESP_CHUNK_BAD; }
    }
    if (seen_digit == 0) { return _SANDHI_RESP_CHUNK_BAD; }
    # Skip chunk extensions ";..." up to CRLF.
    while (p < blen && load8(buf + p) != 13 && load8(buf + p) != 10) {
        p = p + 1;
    }
    if (p < blen && load8(buf + p) == 13) { p = p + 1; }
    if (p < blen && load8(buf + p) == 10) { p = p + 1; }
    store64(offset_ptr, p);
    return size;
}

# Decode a chunked body starting at `start` within `buf`. Returns 0
# on success (writing body via out-params) or `0 - 1` on malformed
# input (bad chunk-size, truncated mid-chunk, or stream ending
# without the terminal 0-chunk). Out-params are also written on
# error to keep them initialized for the caller.
#
# 0.9.0 P0 #1 — previously the decoder treated ANY size==0 (including
# the no-hex-digit malformed case from chunk_size + early-stop on
# truncation) as success. This silently truncated bodies. Now we
# track `saw_terminal` and propagate `_BAD` from chunk_size, so a
# clean stream end is the only way to claim success.
fn _sandhi_resp_decode_chunked_a(a, buf, blen, start, body_out_ptr, body_len_ptr, headers): i64 {
    var cap = blen - start;
    if (cap < 1) { cap = 1; }
    var out = alloc_via(a, cap + 1);
    if (out == 0) { return 0 - 1; }
    var out_len = 0;
    var off_cell = alloc_via(a, 8);
    if (off_cell == 0) { return 0 - 1; }
    store64(off_cell, start);
    var going = 1;
    var saw_terminal = 0;
    var malformed = 0;
    while (going == 1) {
        var size = _sandhi_resp_chunk_size(buf, blen, off_cell);
        var off = load64(off_cell);
        if (size == _SANDHI_RESP_CHUNK_BAD) {
            malformed = 1;
            going = 0;
        } elif (size == 0) {
            saw_terminal = 1;
            going = 0;
        } else {
            if (off + size > blen) {
                malformed = 1;
                going = 0;
            } else {
                memcpy(out + out_len, buf + off, size);
                out_len = out_len + size;
                off = off + size;
                if (off < blen && load8(buf + off) == 13) { off = off + 1; }
                if (off < blen && load8(buf + off) == 10) { off = off + 1; }
                store64(off_cell, off);
            }
        }
    }
    store8(out + out_len, 0);
    store64(body_out_ptr, out);
    store64(body_len_ptr, out_len);
    if (malformed == 1) { return 0 - 1; }
    if (saw_terminal == 0) { return 0 - 1; }
    # RFC 7230 §4.1.2 trailer-part. The terminal 0-chunk is followed
    # by zero or more trailer header-fields and then a final empty
    # CRLF. Parse + merge allowed trailers into `headers` so they
    # surface via sandhi_http_headers; drain forbidden ones silently
    # (filtering matches the smuggling-protection list).
    if (headers != 0) {
        _sandhi_resp_merge_trailers_a(a, buf, blen, load64(off_cell), headers);
    }
    return 0;
}

fn _sandhi_resp_decode_chunked(buf, blen, start, body_out_ptr, body_len_ptr, headers): i64 {
    return _sandhi_resp_decode_chunked_a(default_alloc(), buf, blen, start, body_out_ptr, body_len_ptr, headers);
}

# Case-insensitive cstr equality. Local to response.cyr because
# client.cyr's identical helper sits later in the build order.
fn _sandhi_resp_streq_ci(a, b): i64 {
    if (a == 0 || b == 0) { return 0; }
    var i = 0;
    while (1 == 1) {
        var ca = load8(a + i);
        var cb = load8(b + i);
        if (ca >= 65 && ca <= 90) { ca = ca + 32; }
        if (cb >= 65 && cb <= 90) { cb = cb + 32; }
        if (ca != cb) { return 0; }
        if (ca == 0)  { return 1; }
        i = i + 1;
    }
    return 0;
}

# RFC 7230 §4.1.2 forbids these field names in trailers because
# either (a) they affect framing/routing/auth (would defeat the
# fact that the recipient already committed to a body framing) or
# (b) they modify the trailer parsing itself. Returns 1 if `name`
# (case-insensitive) is on the forbidden list, 0 otherwise.
fn _sandhi_resp_trailer_forbidden(name): i64 {
    if (_sandhi_resp_streq_ci(name, "Transfer-Encoding") == 1) { return 1; }
    if (_sandhi_resp_streq_ci(name, "Content-Length") == 1)    { return 1; }
    if (_sandhi_resp_streq_ci(name, "Host") == 1)              { return 1; }
    if (_sandhi_resp_streq_ci(name, "Cache-Control") == 1)     { return 1; }
    if (_sandhi_resp_streq_ci(name, "Expect") == 1)            { return 1; }
    if (_sandhi_resp_streq_ci(name, "Max-Forwards") == 1)      { return 1; }
    if (_sandhi_resp_streq_ci(name, "Pragma") == 1)            { return 1; }
    if (_sandhi_resp_streq_ci(name, "Range") == 1)             { return 1; }
    if (_sandhi_resp_streq_ci(name, "TE") == 1)                { return 1; }
    if (_sandhi_resp_streq_ci(name, "Trailer") == 1)           { return 1; }
    if (_sandhi_resp_streq_ci(name, "Authorization") == 1)     { return 1; }
    if (_sandhi_resp_streq_ci(name, "Set-Cookie") == 1)        { return 1; }
    # 0.9.9 audit additions:
    # `Connection` is connection-management metadata per RFC 7230 §6.1
    # and MUST NOT appear in trailers — letting it through would let a
    # malicious server inject `Connection: close` post-body and
    # destabilize the keep-alive state machine that the pool layer
    # relies on for put-back decisions.
    # `Cookie` and `Proxy-Authorization` are auth-bearing request
    # headers; treating them symmetrically with `Authorization` /
    # `Set-Cookie` closes the trailer-side equivalent of the redirect
    # cred-strip filter (`_sandhi_strip_sensitive_headers`).
    # `Proxy-Authenticate` rounds out the proxy-auth pair (1.1.1).
    # Originally deferred from 0.9.9 on per-program-fixup-cap grounds;
    # the cap re-baselined post-fold once consumers stopped re-
    # concatenating sandhi's `src/`.
    if (_sandhi_resp_streq_ci(name, "Connection") == 1)          { return 1; }
    if (_sandhi_resp_streq_ci(name, "Cookie") == 1)              { return 1; }
    if (_sandhi_resp_streq_ci(name, "Proxy-Authorization") == 1) { return 1; }
    if (_sandhi_resp_streq_ci(name, "Proxy-Authenticate") == 1)  { return 1; }
    return 0;
}

# Walk forward from `start` parsing trailer header-fields ("Name:
# value\r\n") until an empty line (CRLF on its own). Adds allowed
# fields to `headers` via sandhi_headers_add (preserves order; lets
# multi-value trailers like Server-Timing show up multiple times).
# Tolerant: returns silently on malformed bytes — trailer parsing
# is best-effort. The body has already been delivered correctly;
# trailer drops only affect metadata visibility.
fn _sandhi_resp_merge_trailers_a(a, buf, blen, start, headers): i64 {
    var off = start;
    var safety = 0;
    while (off < blen && safety < 256) {
        # Empty line (CRLF or LF alone) terminates the trailer block.
        if (off < blen && load8(buf + off) == 13) {
            if (off + 1 < blen && load8(buf + off + 1) == 10) { return 0; }
        }
        if (off < blen && load8(buf + off) == 10) { return 0; }
        # Find ':' separating name from value.
        var colon = off;
        while (colon < blen && load8(buf + colon) != 58
        && load8(buf + colon) != 13
        && load8(buf + colon) != 10) {
            colon = colon + 1;
        }
        if (colon >= blen || load8(buf + colon) != 58) { return 0; }
        var name_len = colon - off;
        if (name_len <= 0) { return 0; }
        var name = alloc_via(a, name_len + 1);
        if (name == 0) { return 0; }
        memcpy(name, buf + off, name_len);
        store8(name + name_len, 0);
        # Skip ':' + leading OWS on value.
        var vstart = colon + 1;
        while (vstart < blen && (load8(buf + vstart) == 32 || load8(buf + vstart) == 9)) {
            vstart = vstart + 1;
        }
        # Value runs to CR/LF.
        var vend = vstart;
        while (vend < blen && load8(buf + vend) != 13 && load8(buf + vend) != 10) {
            vend = vend + 1;
        }
        # Trim trailing OWS.
        while (vend > vstart && (load8(buf + vend - 1) == 32 || load8(buf + vend - 1) == 9)) {
            vend = vend - 1;
        }
        var val_len = vend - vstart;
        var value = alloc_via(a, val_len + 1);
        if (value == 0) { return 0; }
        if (val_len > 0) { memcpy(value, buf + vstart, val_len); }
        store8(value + val_len, 0);
        # Filter forbidden names; merge the rest.
        if (_sandhi_resp_trailer_forbidden(name) == 0) {
            sandhi_headers_add_a(a, headers, name, value);
        }
        # Consume CR/LF and advance past line terminator.
        off = vend;
        if (off < blen && load8(buf + off) == 13) { off = off + 1; }
        if (off < blen && load8(buf + off) == 10) { off = off + 1; }
        safety = safety + 1;
    }
    return 0;
}

fn _sandhi_resp_merge_trailers(buf, blen, start, headers): i64 {
    return _sandhi_resp_merge_trailers_a(default_alloc(), buf, blen, start, headers);
}

# 1 if the headers block declares Transfer-Encoding: chunked.
fn _sandhi_resp_is_chunked(headers): i64 {
    var te = sandhi_headers_get(headers, "Transfer-Encoding");
    if (te == 0) { return 0; }
    var i = 0;
    while (load8(te + i) != 0) {
        if (load8(te + i) == 99
        && load8(te + i + 1) == 104
        && load8(te + i + 2) == 117
        && load8(te + i + 3) == 110
        && load8(te + i + 4) == 107
        && load8(te + i + 5) == 101
        && load8(te + i + 6) == 100) {
            return 1;
        }
        i = i + 1;
    }
    return 0;
}

# Parse the decimal Content-Length value from a cstr. Returns 0 on
# empty, `0 - 1` on malformed.
#
# 0.9.1 P1 — strict per RFC 7230 §3.3.2: pure decimal digits only,
# leading/trailing space tolerated. Previously non-digit bytes
# (including `+`, `,`, `-`, `0x`) were silently skipped, so values
# like `"10, 20"` would parse as 1020 — different from any sane
# parser's reading. That kind of disagreement is the CL.CL leg of
# the smuggling triad (CL.TE handled in 0.9.0 P0 #2).
fn _sandhi_resp_parse_clen(v): i64 {
    if (v == 0) { return 0; }
    var i = 0;
    # Skip leading whitespace.
    while (load8(v + i) == 32 || load8(v + i) == 9) { i = i + 1; }
    if (load8(v + i) == 0) { return 0; }
    var n = 0;
    var seen_digit = 0;
    while (load8(v + i) >= 48 && load8(v + i) <= 57) {
        n = n * 10 + (load8(v + i) - 48);
        seen_digit = 1;
        i = i + 1;
    }
    if (seen_digit == 0) { return 0 - 1; }
    # Skip trailing whitespace.
    while (load8(v + i) == 32 || load8(v + i) == 9) { i = i + 1; }
    # Anything else after digits + whitespace is malformed.
    if (load8(v + i) != 0) { return 0 - 1; }
    return n;
}

# Copy `len` bytes starting at `buf+start` into a fresh null-terminated
# cstr allocated from `a`. Returns 0 on OOM.
fn _sandhi_resp_body_copy_a(a, buf, start, len): i64 {
    if (len < 0) { len = 0; }
    var out = alloc_via(a, len + 1);
    if (out == 0) { return 0; }
    if (len > 0) { memcpy(out, buf + start, len); }
    store8(out + len, 0);
    return out;
}

fn _sandhi_resp_body_copy(buf, start, len): i64 {
    return _sandhi_resp_body_copy_a(default_alloc(), buf, start, len);
}

# Figure out body framing and return the struct. Kept small because
# the original split was prompted by a silent-local-zeroing symptom
# that's since been re-attributed to sandhi's missing stdlib deps
# (see top-of-file NOTE). The small-function shape stays regardless.
#
# 0.9.0 P0 #2 — reject responses that carry both `Content-Length`
# AND `Transfer-Encoding: chunked` per RFC 7230 §3.3.3 ("the message
# is malformed and the recipient MUST treat it as such"). Two
# upstream parsers picking different framings is the classic
# CL.TE / TE.CL request/response smuggling vector. We return
# SANDHI_ERR_PROTOCOL on the response struct so callers see the
# refusal rather than a silently-truncated or silently-extended body.
# Frame the body using `a` for every per-response allocation: chunked
# scratch cells, body-copy buffers, and the response struct itself.
fn _sandhi_resp_frame_a(a, buf, blen, status, headers, body_start): i64 {
    var body_ptr = 0;
    var body_len = 0;
    var chunked = _sandhi_resp_is_chunked(headers);
    var has_clen = 0;
    if (sandhi_headers_get(headers, "Content-Length") != 0) { has_clen = 1; }

    if (chunked == 1 && has_clen == 1) {
        return _sandhi_resp_err_a(a, SANDHI_ERR_PROTOCOL);
    }

    # 0.9.1 P1 — duplicate Host / Content-Length / Transfer-Encoding
    # is a malformed-message condition per RFC 7230. CL.CL / Host.Host
    # disagreement is the smuggling vector.
    if (sandhi_headers_smuggle_dup(headers) == 1) {
        return _sandhi_resp_err_a(a, SANDHI_ERR_PROTOCOL);
    }

    if (chunked == 1) {
        var outp_cell = alloc_via(a, 8);
        var outl_cell = alloc_via(a, 8);
        if (outp_cell == 0 || outl_cell == 0) {
            return _sandhi_resp_err_a(a, SANDHI_ERR_INTERNAL);
        }
        var dr = _sandhi_resp_decode_chunked_a(a, buf, blen, body_start, outp_cell, outl_cell, headers);
        if (dr < 0) {
            return _sandhi_resp_err_a(a, SANDHI_ERR_PROTOCOL);
        }
        body_ptr = load64(outp_cell);
        body_len = load64(outl_cell);
    } else {
        var clen_v = sandhi_headers_get(headers, "Content-Length");
        if (clen_v != 0) {
            var n = _sandhi_resp_parse_clen(clen_v);
            if (n < 0) {
                return _sandhi_resp_err_a(a, SANDHI_ERR_PROTOCOL);
            }
            if (body_start + n > blen) { n = blen - body_start; }
            body_len = n;
            body_ptr = _sandhi_resp_body_copy_a(a, buf, body_start, body_len);
        } else {
            body_len = blen - body_start;
            body_ptr = _sandhi_resp_body_copy_a(a, buf, body_start, body_len);
        }
    }

    return _sandhi_resp_new_a(a, status, body_ptr, body_len, headers, SANDHI_OK);
}

fn _sandhi_resp_frame(buf, blen, status, headers, body_start): i64 {
    return _sandhi_resp_frame_a(default_alloc(), buf, blen, status, headers, body_start);
}

# Parse a complete response buffer into `a`. Headers / body / struct
# all flow through `a`; an arena reset reclaims the entire response
# in one shot. Returns a response struct (never 0 — even on parse
# failure the err-response is allocated from `a`); the caller can
# detect parse failure via sandhi_http_err_kind.
fn sandhi_http_response_parse_a(a, buf, blen): i64 {
    if (buf == 0 || blen <= 0) {
        return _sandhi_resp_err_a(a, SANDHI_ERR_PROTOCOL);
    }

    var status = _sandhi_resp_status(buf, blen);
    if (status == 0) {
        return _sandhi_resp_err_a(a, SANDHI_ERR_PROTOCOL);
    }

    var sline_end = _sandhi_resp_eol(buf, 0, blen);
    var header_start = sline_end;
    if (header_start < blen && load8(buf + header_start) == 13) { header_start = header_start + 1; }
    if (header_start < blen && load8(buf + header_start) == 10) { header_start = header_start + 1; }

    var hend = _sandhi_resp_headers_end(buf, blen);
    if (hend < 0) {
        return _sandhi_resp_err_a(a, SANDHI_ERR_PROTOCOL);
    }

    var hblock_len = hend - header_start;
    if (hblock_len < 0) { hblock_len = 0; }
    var headers = sandhi_headers_parse_a(a, buf + header_start, hblock_len);

    var body_start = hend + 4;
    if (load8(buf + hend) == 10) { body_start = hend + 2; }
    if (body_start > blen) { body_start = blen; }

    return _sandhi_resp_frame_a(a, buf, blen, status, headers, body_start);
}

fn sandhi_http_response_parse(buf, blen): i64 {
    return sandhi_http_response_parse_a(default_alloc(), buf, blen);
}


# --- resolve.cyr ---

# sandhi/net/resolve — native DNS resolver (UDP, RFC 1035).
#
# Linux-first, A-records only, single-nameserver fallback from
# /etc/resolv.conf. Written because fdlopen_getaddrinfo is blocked
# at the 5.6.22 toolchain pin (docs/issues/2026-04-24-fdlopen...).
# Retires opportunistically when fdlopen orchestration lands and
# sandhi can drop back to a thin stdlib-compose wrapper.
#
# Scope: what service consumers actually hit.
#   - UDP only (no TCP fallback for >512B responses — rare for A-only)
#   - A + AAAA records (sandhi_resolve_ipv4 / _ipv6); HTTP client
#     tries v4 first, falls back to v6 in `_sandhi_http_do_impl`
#   - First nameserver from /etc/resolv.conf (no per-query retry across
#     multiple nameservers yet — add when we see timeouts in practice)
#   - No /etc/hosts consultation; resolve_ipv4 defers to the client's
#     IP-literal path for numeric inputs before reaching here.
#
# All RFC 1035 packet building + parsing is inline — it's tight, and
# pulling in a generic DNS library would inflate the fold-into-stdlib
# surface area ADR 0002 is trying to keep small.

var _SANDHI_RESOLVE_BUF_SIZE = 512;   # RFC 1035 UDP limit
var _SANDHI_RESOLVE_TIMEOUT_MS = 2000;  # reserved; net.cyr lacks timeouts today

# Maximum compression-pointer hops when walking a wire-format name.
# RFC 1035 §4.1.4 bans forward / cyclic pointers, but malformed or
# hostile responses can have both. Bound the traversal to 32 hops —
# well above any legitimate DNS message (names are ≤255 bytes = ≤128
# labels, and compression can only point backward).
var _SANDHI_RESOLVE_MAX_PTR_HOPS = 32;

# ================================================================
# Cryptographic randomness for DNS TXID + future needs
# ================================================================

# Read 2 random bytes from /dev/urandom and return as a u16 (0..65535).
# Falls back to a deterministic-but-poor source (monotonic-clock-ns low
# bits XOR PID) if /dev/urandom isn't available — better than a fixed
# constant for anti-spoofing, worse than real entropy. Callers should
# not rely on this for cryptographic-grade randomness; it exists
# specifically to close the Kaminsky-class cache-poisoning window.
fn _sandhi_resolve_random_u16(): i64 {
    var buf[2];
    store8(&buf + 0, 0);
    store8(&buf + 1, 0);
    var fd = syscall(2, "/dev/urandom", 0, 0);  # open(path, O_RDONLY, 0)
    if (fd >= 0) {
        var n = syscall(0, fd, &buf, 2);          # read(fd, buf, 2)
        syscall(3, fd);                            # close(fd)
        if (n == 2) {
            return (load8(&buf + 0) << 8) | load8(&buf + 1);
        }
    }
    # Fallback: clock-nanos low bits. Poor but non-constant.
    var ns = clock_now_ns();
    return (ns ^ (ns >> 16)) & 0xFFFF;
}

# ================================================================
# IPv4-literal parser — also used by the HTTP client for numeric URLs.
# ================================================================

# Parse "127.0.0.1" / "1.2.3.4" into a network-byte-order uint32.
# Returns (0 - 1) on malformed input. sock_connect expects this shape.
fn sandhi_net_parse_ipv4(host): i64 {
    if (host == 0) { return 0 - 1; }
    var octets[4];
    store8(&octets + 0, 0);
    store8(&octets + 1, 0);
    store8(&octets + 2, 0);
    store8(&octets + 3, 0);
    var oi = 0;
    var got = 0;
    var cur = 0;
    var i = 0;
    while (load8(host + i) != 0) {
        var c = load8(host + i);
        if (c == 46) {
            if (got == 0) { return 0 - 1; }
            if (oi >= 3) { return 0 - 1; }
            if (cur > 255) { return 0 - 1; }
            store8(&octets + oi, cur);
            oi = oi + 1;
            cur = 0;
            got = 0;
        } elif (c >= 48 && c <= 57) {
            cur = cur * 10 + (c - 48);
            got = 1;
            if (cur > 255) { return 0 - 1; }
        } else {
            return 0 - 1;
        }
        i = i + 1;
    }
    if (got == 0) { return 0 - 1; }
    if (oi != 3) { return 0 - 1; }
    store8(&octets + 3, cur);
    var a0 = load8(&octets + 0);
    var a1 = load8(&octets + 1);
    var a2 = load8(&octets + 2);
    var a3 = load8(&octets + 3);
    return a0 | (a1 << 8) | (a2 << 16) | (a3 << 24);
}

# ================================================================
# /etc/resolv.conf parser
# ================================================================

# Return the first `nameserver A.B.C.D` entry in /etc/resolv.conf as
# an IPv4 uint32 (network-byte-order, shape matches INADDR_LOOPBACK).
# Returns (0 - 1) on any failure — caller falls back to 8.8.8.8.
# Read the first nameserver entry from /etc/resolv.conf into `a`. The
# 4 KB scratch + the parsed cstr both live in `a`; both are short-
# lived (caller only needs the returned int). Returns (0 - 1) on any
# failure so the caller can fall back to a public DNS default.
fn _sandhi_resolve_read_resolv_conf_a(a): i64 {
    var buf = alloc_via(a, 4096);
    if (buf == 0) { return 0 - 1; }
    var n = file_read_all("/etc/resolv.conf", buf, 4095);
    if (n <= 0) { return 0 - 1; }
    store8(buf + n, 0);
    var i = 0;
    while (i < n) {
        # Skip leading whitespace.
        while (i < n && (load8(buf + i) == 32 || load8(buf + i) == 9)) { i = i + 1; }
        # Comment line? Skip to newline.
        if (i < n && load8(buf + i) == 35) {
            while (i < n && load8(buf + i) != 10) { i = i + 1; }
            i = i + 1;
        } elif (i + 10 < n && memeq(buf + i, "nameserver", 10) == 1
        && (load8(buf + i + 10) == 32 || load8(buf + i + 10) == 9)) {
            # Found "nameserver" — advance past whitespace, read up to ws/EOL.
            i = i + 10;
            while (i < n && (load8(buf + i) == 32 || load8(buf + i) == 9)) { i = i + 1; }
            var ns_start = i;
            while (i < n && load8(buf + i) != 32 && load8(buf + i) != 9
            && load8(buf + i) != 13 && load8(buf + i) != 10) {
                i = i + 1;
            }
            var nlen = i - ns_start;
            var ns = alloc_via(a, nlen + 1);
            if (ns == 0) { return 0 - 1; }
            memcpy(ns, buf + ns_start, nlen);
            store8(ns + nlen, 0);
            return sandhi_net_parse_ipv4(ns);
        } else {
            # Skip to newline.
            while (i < n && load8(buf + i) != 10) { i = i + 1; }
            i = i + 1;
        }
    }
    return 0 - 1;
}

fn _sandhi_resolve_read_resolv_conf(): i64 {
    return _sandhi_resolve_read_resolv_conf_a(default_alloc());
}

# ================================================================
# DNS wire-format: query build
# ================================================================

# Encode a hostname as DNS labels: "example.com" → 07 example 03 com 00.
# Writes to `out` starting at offset 0, returns bytes written. Returns
# (0 - 1) if any label exceeds 63 bytes or total exceeds 255.
fn _sandhi_resolve_encode_labels(host, out): i64 {
    var total = 0;
    var label_start = 0;
    var p = 0;
    var wi = 1;  # +1: leaves room for the length byte of label 0
    while (load8(host + p) != 0) {
        var c = load8(host + p);
        if (c == 46) {
            var llen = p - label_start;
            if (llen == 0) { return 0 - 1; }
            if (llen > 63) { return 0 - 1; }
            store8(out + (wi - llen - 1), llen);
            label_start = p + 1;
            wi = wi + 1;
        } else {
            store8(out + wi, c);
            wi = wi + 1;
        }
        p = p + 1;
        total = wi;
    }
    # Emit last label.
    var last_len = p - label_start;
    if (last_len == 0) { return 0 - 1; }
    if (last_len > 63) { return 0 - 1; }
    store8(out + (wi - last_len - 1), last_len);
    store8(out + wi, 0);  # root terminator
    wi = wi + 1;
    if (wi > 255) { return 0 - 1; }
    return wi;
}

# Build the full DNS query packet. Writes into `out` (must hold at
# least 12 + 255 + 4 bytes). Returns packet length.
fn _sandhi_resolve_build_query(id, host, out): i64 {
    # Header
    store8(out + 0, (id >> 8) & 0xFF);
    store8(out + 1, id & 0xFF);
    store8(out + 2, 0x01);  # Flags MSB: QR=0, Opcode=0, AA=0, TC=0, RD=1
    store8(out + 3, 0x00);  # Flags LSB: all zero
    store8(out + 4, 0x00); store8(out + 5, 0x01);  # QDCOUNT = 1
    store8(out + 6, 0x00); store8(out + 7, 0x00);  # ANCOUNT
    store8(out + 8, 0x00); store8(out + 9, 0x00);  # NSCOUNT
    store8(out + 10, 0x00); store8(out + 11, 0x00);  # ARCOUNT

    # Question
    var qname_len = _sandhi_resolve_encode_labels(host, out + 12);
    if (qname_len < 0) { return 0 - 1; }
    var qi = 12 + qname_len;
    store8(out + qi + 0, 0x00); store8(out + qi + 1, 0x01);  # QTYPE = A
    store8(out + qi + 2, 0x00); store8(out + qi + 3, 0x01);  # QCLASS = IN
    return qi + 4;
}

# ================================================================
# DNS wire-format: response parse
# ================================================================

# Skip a name at offset `off` in the response. Handles both plain
# length-labeled names and pointer compression (0xC0xx). Returns
# the offset just past the name. Returns (0 - 1) on malformed.
#
# Note: this function only skips — it doesn't follow the pointer
# target. That's safe for iteration (the caller only needs the offset
# past the pointer byte), but DOES NOT validate that the pointer
# target is well-formed. Consumers that need the actual name bytes
# must use `_sandhi_resolve_name_eq` which does follow pointers with
# an explicit hop-budget guard.
fn _sandhi_resolve_skip_name(buf, blen, off): i64 {
    var p = off;
    var safety = 0;
    while (safety < 256) {
        if (p >= blen) { return 0 - 1; }
        var c = load8(buf + p);
        if (c == 0) { return p + 1; }
        if ((c & 0xC0) == 0xC0) {
            # Two-byte compression pointer — name continues elsewhere.
            if (p + 1 >= blen) { return 0 - 1; }
            return p + 2;
        }
        # Otherwise c is the label length (max 63).
        if (c > 63) { return 0 - 1; }
        p = p + 1 + c;
        safety = safety + 1;
    }
    return 0 - 1;
}

# Read one label from a wire-format name, following compression
# pointers. Returns the label length (0 at terminator) via out-param
# `label_len_cell`, and writes the label bytes into `label_buf` (must
# hold ≥63 bytes). Advances the offset via `off_cell`. Returns 0 on
# success, (0 - 1) on malformed input (bad length / out-of-bounds /
# pointer loop). `hops_cell` tracks pointer-hops across calls — pass
# the same cell to successive reads of one name so the budget is
# shared.
fn _sandhi_resolve_read_label(buf, blen, off_cell, label_buf, label_len_cell, hops_cell): i64 {
    var p = load64(off_cell);
    while (1 == 1) {
        if (p >= blen) { return 0 - 1; }
        var c = load8(buf + p);
        if (c == 0) {
            store64(label_len_cell, 0);
            store64(off_cell, p + 1);
            return 0;
        }
        if ((c & 0xC0) == 0xC0) {
            # Pointer. RFC 1035 §4.1.4: target offset = (c & 0x3F) << 8 | next byte.
            if (p + 1 >= blen) { return 0 - 1; }
            var hops = load64(hops_cell);
            if (hops >= _SANDHI_RESOLVE_MAX_PTR_HOPS) { return 0 - 1; }
            store64(hops_cell, hops + 1);
            var target = ((c & 0x3F) << 8) | load8(buf + p + 1);
            if (target >= p) { return 0 - 1; }  # RFC 1035: pointers must go backward
            if (target >= blen) { return 0 - 1; }
            p = target;
        } else {
            if (c > 63) { return 0 - 1; }
            if (p + 1 + c > blen) { return 0 - 1; }
            var i = 0;
            while (i < c) {
                store8(label_buf + i, load8(buf + p + 1 + i));
                i = i + 1;
            }
            store64(label_len_cell, c);
            store64(off_cell, p + 1 + c);
            return 0;
        }
    }
    return 0 - 1;
}

# 1 if the wire-format name at offset `off_a` matches the one at
# offset `off_b`. Both names may use compression. Case-insensitive
# ASCII comparison (DNS names are case-insensitive per RFC 1035 §2.3.3).
# Compare two compressed names byte-for-byte (case-insensitive),
# allocating the 8 transient cells + 2 64-byte label buffers from `a`.
# Heaviest alloc site in the resolver — the cells are touched per
# label per name, so they really want to live in an arena that the
# resolver caller resets after the query completes.
fn _sandhi_resolve_name_eq_a(a, buf, blen, off_a, off_b): i64 {
    var pa_cell = alloc_via(a, 8);
    var pb_cell = alloc_via(a, 8);
    var ha_cell = alloc_via(a, 8);
    var hb_cell = alloc_via(a, 8);
    var la_buf  = alloc_via(a, 64);
    var lb_buf  = alloc_via(a, 64);
    var la_cell = alloc_via(a, 8);
    var lb_cell = alloc_via(a, 8);
    if (pa_cell == 0 || pb_cell == 0 || ha_cell == 0 || hb_cell == 0
    || la_buf  == 0 || lb_buf  == 0 || la_cell == 0 || lb_cell == 0) { return 0; }
    store64(pa_cell, off_a);
    store64(pb_cell, off_b);
    store64(ha_cell, 0);
    store64(hb_cell, 0);
    while (1 == 1) {
        if (_sandhi_resolve_read_label(buf, blen, pa_cell, la_buf, la_cell, ha_cell) < 0) { return 0; }
        if (_sandhi_resolve_read_label(buf, blen, pb_cell, lb_buf, lb_cell, hb_cell) < 0) { return 0; }
        var la = load64(la_cell);
        var lb = load64(lb_cell);
        if (la != lb) { return 0; }
        if (la == 0) { return 1; }
        var i = 0;
        while (i < la) {
            var ca = load8(la_buf + i);
            var cb = load8(lb_buf + i);
            if (ca >= 65 && ca <= 90) { ca = ca + 32; }
            if (cb >= 65 && cb <= 90) { cb = cb + 32; }
            if (ca != cb) { return 0; }
            i = i + 1;
        }
    }
    return 0;
}

fn _sandhi_resolve_name_eq(buf, blen, off_a, off_b): i64 {
    return _sandhi_resolve_name_eq_a(default_alloc(), buf, blen, off_a, off_b);
}

# Parse the first A record from a DNS response packet. Returns the
# IPv4 as a network-byte-order uint32 (same shape as
# _sandhi_client_parse_ipv4), or (0 - 1) on any parse failure.
#
# `expected_id` must match the TXID we sent — guards against off-path
# cache-poisoning (Kaminsky class). Answer names are checked against
# the question name (echoed at offset 12) — guards against answer
# substitution where a crafted packet resolves a different host.
# Parse an A-record response, allocating the name-eq scratch from `a`.
fn _sandhi_resolve_parse_response_a(a, buf, blen, expected_id): i64 {
    if (blen < 12) { return 0 - 1; }
    # TXID echo check.
    var got_id = (load8(buf + 0) << 8) | load8(buf + 1);
    if (got_id != expected_id) { return 0 - 1; }
    # Answer count.
    var ancount = (load8(buf + 6) << 8) | load8(buf + 7);
    if (ancount == 0) { return 0 - 1; }
    # Response code (low 4 bits of byte 3).
    var rcode = load8(buf + 3) & 0x0F;
    if (rcode != 0) { return 0 - 1; }
    # QDCOUNT — skip the question. Also remember where qname starts
    # so we can compare answer names against it.
    var qdcount = (load8(buf + 4) << 8) | load8(buf + 5);
    if (qdcount != 1) { return 0 - 1; }  # we only ever send 1 question
    var qname_off = 12;
    var off = _sandhi_resolve_skip_name(buf, blen, qname_off);
    if (off < 0) { return 0 - 1; }
    off = off + 4;  # QTYPE + QCLASS
    # Scan answers. Loop counter is `a_idx` because `a` is the
    # Allocator parameter — the v1.1.0 migration renamed the inner
    # var to dodge the shadow.
    var a_idx = 0;
    while (a_idx < ancount) {
        var name_off = off;
        off = _sandhi_resolve_skip_name(buf, blen, off);
        if (off < 0) { return 0 - 1; }
        if (off + 10 > blen) { return 0 - 1; }
        var rtype = (load8(buf + off + 0) << 8) | load8(buf + off + 1);
        var rdlength = (load8(buf + off + 8) << 8) | load8(buf + off + 9);
        off = off + 10;
        if (rtype == 1) {
            # A record — rdlength must be 4, and the owner name must
            # match the question. (CNAME chains land here too, but
            # stdlib net.cyr's sock_connect doesn't do CNAME following
            # for us — so we only return the A record that answers
            # the question directly. CNAME support is post-v1 unless
            # a consumer needs it.)
            if (rdlength != 4) { return 0 - 1; }
            if (off + 4 > blen) { return 0 - 1; }
            if (_sandhi_resolve_name_eq_a(a, buf, blen, name_off, qname_off) == 0) {
                # Not the name we asked about — skip this RR rather than
                # trust it.
                off = off + 4;
                a_idx = a_idx + 1;
            } else {
                var a0 = load8(buf + off + 0);
                var a1 = load8(buf + off + 1);
                var a2 = load8(buf + off + 2);
                var a3 = load8(buf + off + 3);
                return a0 | (a1 << 8) | (a2 << 16) | (a3 << 24);
            }
        } else {
            off = off + rdlength;
            a_idx = a_idx + 1;
        }
    }
    return 0 - 1;
}

fn _sandhi_resolve_parse_response(buf, blen, expected_id): i64 {
    return _sandhi_resolve_parse_response_a(default_alloc(), buf, blen, expected_id);
}

# ================================================================
# Public resolver
# ================================================================

# Resolve `host` to an IPv4 address (net-byte-order uint32). Returns
# (0 - 1) on any failure. For IP-literal inputs, caller should use
# _sandhi_client_parse_ipv4 directly — this function always performs
# a DNS query.
# Build a DNS query for AAAA records (QTYPE=28, not 1). Everything else
# identical to the A-record build. Kept separate so the hot path of
# IPv4 resolution doesn't pay a branch.
fn _sandhi_resolve_build_query_aaaa(id, host, out): i64 {
    store8(out + 0, (id >> 8) & 0xFF);
    store8(out + 1, id & 0xFF);
    store8(out + 2, 0x01);
    store8(out + 3, 0x00);
    store8(out + 4, 0x00); store8(out + 5, 0x01);
    store8(out + 6, 0x00); store8(out + 7, 0x00);
    store8(out + 8, 0x00); store8(out + 9, 0x00);
    store8(out + 10, 0x00); store8(out + 11, 0x00);
    var qname_len = _sandhi_resolve_encode_labels(host, out + 12);
    if (qname_len < 0) { return 0 - 1; }
    var qi = 12 + qname_len;
    store8(out + qi + 0, 0x00); store8(out + qi + 1, 0x1C);  # QTYPE = AAAA (28)
    store8(out + qi + 2, 0x00); store8(out + qi + 3, 0x01);  # QCLASS = IN
    return qi + 4;
}

# Parse the first AAAA record from a DNS response. Returns a freshly-
# alloc'd 16-byte buffer containing the IPv6 address in network order,
# or 0 on any parse failure / missing RR. Same hardening as the A-
# record parser: TXID echo + answer-name match + compression-loop guard.
# Parse an AAAA-record response into `a`. The 16-byte AAAA buffer
# returned to the caller (and the name-eq scratch) flow through `a`.
fn _sandhi_resolve_parse_response_aaaa_a(a, buf, blen, expected_id): i64 {
    if (blen < 12) { return 0; }
    var got_id = (load8(buf + 0) << 8) | load8(buf + 1);
    if (got_id != expected_id) { return 0; }
    var ancount = (load8(buf + 6) << 8) | load8(buf + 7);
    if (ancount == 0) { return 0; }
    var rcode = load8(buf + 3) & 0x0F;
    if (rcode != 0) { return 0; }
    var qdcount = (load8(buf + 4) << 8) | load8(buf + 5);
    if (qdcount != 1) { return 0; }
    var qname_off = 12;
    var off = _sandhi_resolve_skip_name(buf, blen, qname_off);
    if (off < 0) { return 0; }
    off = off + 4;
    var a_idx = 0;
    while (a_idx < ancount) {
        var name_off = off;
        off = _sandhi_resolve_skip_name(buf, blen, off);
        if (off < 0) { return 0; }
        if (off + 10 > blen) { return 0; }
        var rtype = (load8(buf + off + 0) << 8) | load8(buf + off + 1);
        var rdlength = (load8(buf + off + 8) << 8) | load8(buf + off + 9);
        off = off + 10;
        if (rtype == 28) {
            # AAAA — rdlength must be 16.
            if (rdlength != 16) { return 0; }
            if (off + 16 > blen) { return 0; }
            if (_sandhi_resolve_name_eq_a(a, buf, blen, name_off, qname_off) == 0) {
                off = off + 16;
                a_idx = a_idx + 1;
            } else {
                var out = alloc_via(a, 16);
                if (out == 0) { return 0; }
                var i = 0;
                while (i < 16) { store8(out + i, load8(buf + off + i)); i = i + 1; }
                return out;
            }
        } else {
            off = off + rdlength;
            a_idx = a_idx + 1;
        }
    }
    return 0;
}

fn _sandhi_resolve_parse_response_aaaa(buf, blen, expected_id): i64 {
    return _sandhi_resolve_parse_response_aaaa_a(default_alloc(), buf, blen, expected_id);
}

# Resolve `host` to an IPv6 address. Returns a freshly-allocated 16-byte
# buffer (network-byte-order AAAA record bytes), or 0 on failure. Caller
# owns the alloc. Intentionally does NOT share a resolver handle with
# sandhi_resolve_ipv4 — both issue their own UDP query.
#
# Client-side integration: wired since 0.9.3.
# `_sandhi_http_do_impl` calls v4 first; on miss falls back to
# `_sandhi_client_resolve_v6` and routes through
# `_sandhi_conn_open_v6_fully_timed` (raw socket(AF_INET6) +
# connect(sockaddr_in6)). v4 + v6 are tried sequentially, not in
# parallel — Happy Eyeballs (RFC 8305) would need the connect-path
# refactor to drive two concurrent attempts; not in 0.9.x scope.
fn sandhi_resolve_ipv6_a(a, host): i64 {
    sandhi_trace_begin("sandhi.dns.v6");
    var r = _sandhi_resolve_ipv6_impl_a(a, host);
    sandhi_trace_end();
    return r;
}

fn sandhi_resolve_ipv6(host): i64 {
    return sandhi_resolve_ipv6_a(default_alloc(), host);
}

fn _sandhi_resolve_ipv6_impl_a(a, host): i64 {
    if (host == 0) { return 0; }
    var ns = _sandhi_resolve_read_resolv_conf_a(a);
    if (ns == 0 - 1) {
        ns = 8 | (8 << 8) | (8 << 16) | (8 << 24);
    }
    var txid = _sandhi_resolve_random_u16();
    var qbuf = alloc_via(a, 512);
    if (qbuf == 0) { return 0; }
    var qlen = _sandhi_resolve_build_query_aaaa(txid, host, qbuf);
    if (qlen < 0) { return 0; }

    var fd_r = udp_socket();
    if (is_err_result(fd_r) == 1) { return 0; }
    var fd = payload(fd_r);
    var cr = sock_connect(fd, ns, 53);
    if (is_err_result(cr) == 1) { sock_close(fd); return 0; }
    var sr = sock_send(fd, qbuf, qlen);
    if (is_err_result(sr) == 1) { sock_close(fd); return 0; }
    var rbuf = alloc_via(a, _SANDHI_RESOLVE_BUF_SIZE);
    if (rbuf == 0) { sock_close(fd); return 0; }
    var rr = sock_recv(fd, rbuf, _SANDHI_RESOLVE_BUF_SIZE);
    sock_close(fd);
    if (is_err_result(rr) == 1) { return 0; }
    var rlen = payload(rr);
    if (rlen <= 0) { return 0; }
    return _sandhi_resolve_parse_response_aaaa_a(a, rbuf, rlen, txid);
}

fn _sandhi_resolve_ipv6_impl(host): i64 {
    return _sandhi_resolve_ipv6_impl_a(default_alloc(), host);
}

fn sandhi_resolve_ipv4_a(a, host): i64 {
    sandhi_trace_begin("sandhi.dns.v4");
    var r = _sandhi_resolve_ipv4_impl_a(a, host);
    sandhi_trace_end();
    return r;
}

fn sandhi_resolve_ipv4(host): i64 {
    return sandhi_resolve_ipv4_a(default_alloc(), host);
}

fn _sandhi_resolve_ipv4_impl_a(a, host): i64 {
    if (host == 0) { return 0 - 1; }
    var ns = _sandhi_resolve_read_resolv_conf_a(a);
    if (ns == 0 - 1) {
        # Fall back to public DNS (Google's 8.8.8.8 = 0x08080808 LE).
        ns = 8 | (8 << 8) | (8 << 16) | (8 << 24);
    }

    # Fresh random TXID per query — closes the Kaminsky window.
    # Kernel-assigned ephemeral source port (via connect(2) on UDP
    # without explicit bind) is already random-per-socket on Linux
    # ≥ 2.6.16 and provides the source-port-randomization leg.
    var txid = _sandhi_resolve_random_u16();

    var qbuf = alloc_via(a, 512);
    if (qbuf == 0) { return 0 - 1; }
    var qlen = _sandhi_resolve_build_query(txid, host, qbuf);
    if (qlen < 0) { return 0 - 1; }

    var fd_r = udp_socket();
    if (is_err_result(fd_r) == 1) { return 0 - 1; }
    var fd = payload(fd_r);

    var cr = sock_connect(fd, ns, 53);
    if (is_err_result(cr) == 1) { sock_close(fd); return 0 - 1; }

    var sr = sock_send(fd, qbuf, qlen);
    if (is_err_result(sr) == 1) { sock_close(fd); return 0 - 1; }

    var rbuf = alloc_via(a, _SANDHI_RESOLVE_BUF_SIZE);
    if (rbuf == 0) { sock_close(fd); return 0 - 1; }
    var rr = sock_recv(fd, rbuf, _SANDHI_RESOLVE_BUF_SIZE);
    sock_close(fd);
    if (is_err_result(rr) == 1) { return 0 - 1; }
    var rlen = payload(rr);
    if (rlen <= 0) { return 0 - 1; }

    return _sandhi_resolve_parse_response_a(a, rbuf, rlen, txid);
}

fn _sandhi_resolve_ipv4_impl(host): i64 {
    return _sandhi_resolve_ipv4_impl_a(default_alloc(), host);
}


# --- client.cyr ---

# sandhi/http/client — full HTTP client.
#
# Verbs: sandhi_http_get / post / put / delete / patch / head. Each is
# a thin wrapper around `_sandhi_http_do(method, url, headers, body, body_len)`.
#
# Composes: url.cyr (parse) → resolve (IPv4 literal in v0.3.0, native DNS
# in src/net/resolve.cyr at P7) → conn.cyr (plain or TLS) → wire-format
# request build → response.cyr (parse).
#
# Layering note: this module stays small — originally prompted by a
# suspected cyrius 5.6.22 stack-slot issue, later re-attributed to
# sandhi's missing `[deps.stdlib]` entries (see
# `docs/issues/archive/2026-04-24-fdlopen-getaddrinfo-blocked.md`
# post-mortem, closed v5.6.29-1). The small-function shape stays
# because it reads better; no compiler quirk was at fault.

var _SANDHI_HTTP_RESP_BUF_SIZE = 262144;  # 256 KB — enough for most API responses

# ================================================================
# Host resolution
# ================================================================
#
# Try the numeric-literal fast path first (sandhi_net_parse_ipv4 in
# src/net/resolve.cyr); on miss, fall through to sandhi_resolve_ipv4
# which does a real UDP DNS query. Returns the address (net-byte-
# order uint32), or (0 - 1) on any failure.
# Resolve `host` via IPv4 literal then DNS, allocating any DNS scratch
# from `a`. Returns the address on hit, (0 - 1) on miss.
fn _sandhi_client_resolve_a(a, host): i64 {
    var lit = sandhi_net_parse_ipv4(host);
    if (lit != 0 - 1) { return lit; }
    return sandhi_resolve_ipv4_a(a, host);
}

fn _sandhi_client_resolve(host): i64 {
    return _sandhi_client_resolve_a(default_alloc(), host);
}

# IPv6 fallback into `a`. Returns a 16-byte AAAA buffer or 0.
fn _sandhi_client_resolve_v6_a(a, host): i64 {
    if (host == 0) { return 0; }
    return sandhi_resolve_ipv6_a(a, host);
}

fn _sandhi_client_resolve_v6(host): i64 {
    return _sandhi_client_resolve_v6_a(default_alloc(), host);
}

# ================================================================
# Request build
# ================================================================

# Combine path + query into a single cstr "path?query" (or just path).
# Caller owns the returned alloc.
fn _sandhi_client_full_path_a(a, url_struct): i64 {
    var path = sandhi_url_path(url_struct);
    var query = sandhi_url_query(url_struct);
    if (query == 0) {
        var plen = strlen(path);
        var out = alloc_via(a, plen + 1);
        if (out == 0) { return 0; }
        memcpy(out, path, plen);
        store8(out + plen, 0);
        return out;
    }
    var plen2 = strlen(path);
    var qlen = strlen(query);
    var total = plen2 + 1 + qlen;
    var out2 = alloc_via(a, total + 1);
    if (out2 == 0) { return 0; }
    memcpy(out2, path, plen2);
    store8(out2 + plen2, 63);  # '?'
    memcpy(out2 + plen2 + 1, query, qlen);
    store8(out2 + total, 0);
    return out2;
}

fn _sandhi_client_full_path(url_struct): i64 {
    return _sandhi_client_full_path_a(default_alloc(), url_struct);
}

# Build the Host header value into `a`. The str_builder used in the
# port-bearing variant is on the global bump; only the final cstr
# (dup'd into `a`) is tied to the caller's lifetime.
fn _sandhi_client_host_header_a(a, url_struct): i64 {
    var host = sandhi_url_host(url_struct);
    var port = sandhi_url_port(url_struct);
    var scheme = sandhi_url_scheme(url_struct);
    var default_port = 80;
    if (scheme == SANDHI_URL_HTTPS) { default_port = 443; }
    var hlen = strlen(host);
    if (port == default_port) {
        var out = alloc_via(a, hlen + 1);
        if (out == 0) { return 0; }
        memcpy(out, host, hlen);
        store8(out + hlen, 0);
        return out;
    }
    var sb = str_builder_new();
    str_builder_add_cstr(sb, host);
    str_builder_add_cstr(sb, ":");
    str_builder_add_int(sb, port);
    return _sandhi_json_dup_a(a, str_data(str_builder_build(sb)));
}

fn _sandhi_client_host_header(url_struct): i64 {
    return _sandhi_client_host_header_a(default_alloc(), url_struct);
}

# 1.1.1 dup-prevention filter: caller-supplied `Host` / `Content-
# Length` / `Transfer-Encoding` / `Connection` in user_headers would
# emit alongside the auto-injected versions and create a dup-header
# smuggling vector on the wire (TE.CL / CL.TE / dup-Host / Connection-
# override). Symmetric to the server-side detector
# `sandhi_headers_smuggle_dup` (0.9.1). Returns 1 for any reserved
# name (case-insensitive), 0 otherwise. Uses `_sandhi_resp_streq_ci`
# from response.cyr (bundled before client.cyr); client.cyr's own
# `_sandhi_streq_ci` sits later in the file and isn't reachable from
# here under single-pass compilation.
fn _sandhi_client_user_header_is_reserved(name): i64 {
    if (_sandhi_resp_streq_ci(name, "Host") == 1)              { return 1; }
    if (_sandhi_resp_streq_ci(name, "Content-Length") == 1)    { return 1; }
    if (_sandhi_resp_streq_ci(name, "Transfer-Encoding") == 1) { return 1; }
    if (_sandhi_resp_streq_ci(name, "Connection") == 1)        { return 1; }
    return 0;
}

# Construct the wire-format request as a Str. user_headers may be 0.
# Body is sent separately — the builder emits headers + blank line only.
# `keep_alive` controls the trailing Connection header — 1 omits it
# (HTTP/1.1 default is keep-alive); 0 emits "Connection: close" so the
# peer drops the conn after the response.
#
# 1.2.0 audit: the prior `_a` wrapper called the bare `_v` impl, which
# routed every str_builder op through `default_alloc()` — `a` was
# accepted and silently dropped. The arena variant now lives in `_va`
# and threads `a` through `str_builder_new_a` / `_add_cstr_a` /
# `_add_int_a` / `_build_a`. The four-fn family (`_a` / bare / `_v` /
# `_va`) preserves every existing call shape; only the under-the-hood
# allocator changes when `a` is supplied.
fn _sandhi_client_build_request_a(a, method, full_path, host_header, user_headers, body_len): i64 {
    return _sandhi_client_build_request_va(a, method, full_path, host_header, user_headers, body_len, 0);
}

fn _sandhi_client_build_request(method, full_path, host_header, user_headers, body_len): i64 {
    return _sandhi_client_build_request_va(default_alloc(), method, full_path, host_header, user_headers, body_len, 0);
}

fn _sandhi_client_build_request_v(method, full_path, host_header, user_headers, body_len, keep_alive): i64 {
    return _sandhi_client_build_request_va(default_alloc(), method, full_path,
    host_header, user_headers, body_len, keep_alive);
}

fn _sandhi_client_build_request_va(a, method, full_path, host_header, user_headers, body_len, keep_alive): i64 {
    var sb = str_builder_new_a(a);
    # OOM on the builder header alloc → return 0 cleanly. Without
    # this guard, downstream str_builder_add_cstr_a's dereference 0
    # via _sb_grow_a (load64(sb + 8) → SIGSEGV). Matches the
    # graceful-0 OOM pattern from 1.1.0 (sandhi_url_parse_a etc.).
    if (sb == 0) { return 0; }
    str_builder_add_cstr_a(a, sb, method);
    str_builder_add_cstr_a(a, sb, " ");
    str_builder_add_cstr_a(a, sb, full_path);
    str_builder_add_cstr_a(a, sb, " HTTP/1.1\r\nHost: ");
    str_builder_add_cstr_a(a, sb, host_header);
    str_builder_add_cstr_a(a, sb, "\r\n");

    # Content-Length: present whenever a body will follow. 0 for POST
    # with no body (HTTP/1.1 convention; some servers require it).
    var add_clen = 0;
    if (body_len > 0) { add_clen = 1; }
    if (streq(method, "POST") == 1) { add_clen = 1; }
    if (streq(method, "PUT") == 1)  { add_clen = 1; }
    if (streq(method, "PATCH") == 1){ add_clen = 1; }
    if (add_clen == 1) {
        str_builder_add_cstr_a(a, sb, "Content-Length: ");
        str_builder_add_int_a(a, sb, body_len);
        str_builder_add_cstr_a(a, sb, "\r\n");
    }

    # Default User-Agent + Accept-Encoding + TE — only if caller didn't
    # set them. Some servers 403 on missing UA; explicit `identity`
    # guards against `Content-Encoding: gzip` we can't decode. `TE:
    # trailers` lets spec-compliant servers emit response trailers
    # (RFC 7230 §4.4 — "a server SHOULD NOT generate trailer fields
    # ... unless the request includes a TE header field indicating
    # 'trailers' is acceptable"); the response-side trailer parser
    # landed at 0.9.4, this signal landed at 0.9.7.
    var have_ua = 0;
    var have_ae = 0;
    var have_te = 0;
    if (user_headers != 0) {
        if (sandhi_headers_has(user_headers, "User-Agent") == 1)      { have_ua = 1; }
        if (sandhi_headers_has(user_headers, "Accept-Encoding") == 1) { have_ae = 1; }
        if (sandhi_headers_has(user_headers, "TE") == 1)              { have_te = 1; }
    }
    if (have_ua == 0) {
        str_builder_add_cstr_a(a, sb, "User-Agent: sandhi/");
        str_builder_add_cstr_a(a, sb, sandhi_version());
        str_builder_add_cstr_a(a, sb, "\r\n");
    }
    if (have_ae == 0) {
        str_builder_add_cstr_a(a, sb, "Accept-Encoding: identity\r\n");
    }
    if (have_te == 0) {
        str_builder_add_cstr_a(a, sb, "TE: trailers\r\n");
    }

    # User headers (after auto headers). Caller-supplied
    # `Host` / `Content-Length` / `Transfer-Encoding` /
    # `Connection` are filtered out via
    # `_sandhi_client_user_header_is_reserved` (1.1.2): each of
    # those is auto-injected above, so a caller-supplied second
    # copy would create a dup-header smuggling vector on the
    # wire. Symmetric to the server-side dup detector
    # `sandhi_headers_smuggle_dup` (0.9.1). All other user
    # headers pass through unchanged.
    if (user_headers != 0) {
        var ui = 0;
        var un = sandhi_headers_count(user_headers);
        while (ui < un) {
            var nm = sandhi_headers_name_at(user_headers, ui);
            if (_sandhi_client_user_header_is_reserved(nm) == 0) {
                str_builder_add_cstr_a(a, sb, nm);
                str_builder_add_cstr_a(a, sb, ": ");
                str_builder_add_cstr_a(a, sb, sandhi_headers_value_at(user_headers, ui));
                str_builder_add_cstr_a(a, sb, "\r\n");
            }
            ui = ui + 1;
        }
    }

    if (keep_alive == 1) {
        # HTTP/1.1 default — omit Connection altogether. Some old
        # proxies infer keep-alive only when "Keep-Alive" is explicit;
        # the tradeoff is wire bytes. Default behavior: omit.
        str_builder_add_cstr_a(a, sb, "\r\n");
    } else {
        str_builder_add_cstr_a(a, sb, "Connection: close\r\n\r\n");
    }
    return str_builder_build_a(a, sb);
}

# ================================================================
# Core request/response round-trip
# ================================================================

# Outer trace wrapper — opt-in span via sandhi_trace_enable(1). Span
# no-op by default; the inner does all the work either way.
fn _sandhi_http_do_a(a, method, url, user_headers, body, body_len, max_bytes,
connect_ms, read_ms, write_ms, total_ms, pool): i64 {
    sandhi_trace_begin("sandhi.http");
    var r = _sandhi_http_do_impl_a(a, method, url, user_headers, body, body_len,
    max_bytes, connect_ms, read_ms, write_ms, total_ms, pool);
    sandhi_trace_end();
    return r;
}

fn _sandhi_http_do(method, url, user_headers, body, body_len, max_bytes,
connect_ms, read_ms, write_ms, total_ms, pool): i64 {
    return _sandhi_http_do_a(default_alloc(), method, url, user_headers, body, body_len,
    max_bytes, connect_ms, read_ms, write_ms, total_ms, pool);
}

# 1.3.2 — request-method safety check for TLS 1.3 0-RTT. Per
# RFC 8446 §8, only requests that are safe to replay should be sent
# as 0-RTT (replay-attack mitigation). Safe methods per RFC 7231:
# GET, HEAD, OPTIONS, TRACE — sandhi exposes the first three. PUT
# is idempotent but not safe (changes server state), so it stays
# out per OpenSSL's recommended posture.
fn _sandhi_method_is_replay_safe(method): i64 {
    if (streq(method, "GET") == 1) { return 1; }
    if (streq(method, "HEAD") == 1) { return 1; }
    if (streq(method, "OPTIONS") == 1) { return 1; }
    return 0;
}

# 1.3.3 — FNV-1a 64-bit byte-mixer. Continues from a running hash
# `h` so the cred digest can chain multiple header values together
# in one accumulator without losing entropy across them. Same
# offset basis / prime as stdlib `hash_str` (lib/hashmap.cyr).
fn _sandhi_fnv1a_mix(h, s): i64 {
    if (s == 0) { return h; }
    var i = 0;
    while (load8(s + i) != 0) {
        h = h ^ load8(s + i);
        h = h * 0x100000001B3;
        i = i + 1;
    }
    return h;
}

# 1.3.3 — cred-strip-aware session-cache keying digest. Hashes the
# values of Authorization / Cookie / Proxy-Authorization headers
# (case-insensitive lookup via `sandhi_headers_get`) into a 64-bit
# digest. When at least one cred-bearing header is present, the
# digest folds in a per-header marker prefix ("A:" / "C:" / "P:")
# before the value bytes so a value reused across header names
# (e.g. same token in Authorization vs. Cookie) doesn't collide.
# Returns 0 when no cred-bearing headers — preserves the pre-1.3.3
# cache-key shape for the common service-to-service path.
#
# Used by `_sandhi_http_dispatch_a` / `sandhi_http_request_auto_a`
# to set the module-level `_sandhi_cred_digest` flag (defined in
# conn.cyr alongside `_sandhi_allow_0rtt`); the conn finalize reads
# the flag when calling `sandhi_session_cache_lookup` / `_store`.
# Named `_compute_` rather than just `_cred_digest` to avoid
# collision with the module-level variable of the same root.
fn _sandhi_compute_cred_digest(headers): i64 {
    if (headers == 0) { return 0; }
    var found = 0;
    var h = 0xCBF29CE484222325;  # FNV offset basis
    var v = sandhi_headers_get(headers, "Authorization");
    if (v != 0) {
        h = _sandhi_fnv1a_mix(h, "A:");
        h = _sandhi_fnv1a_mix(h, v);
        found = 1;
    }
    v = sandhi_headers_get(headers, "Cookie");
    if (v != 0) {
        h = _sandhi_fnv1a_mix(h, "C:");
        h = _sandhi_fnv1a_mix(h, v);
        found = 1;
    }
    v = sandhi_headers_get(headers, "Proxy-Authorization");
    if (v != 0) {
        h = _sandhi_fnv1a_mix(h, "P:");
        h = _sandhi_fnv1a_mix(h, v);
        found = 1;
    }
    if (found == 0) { return 0; }
    return h;
}

# Compute the effective connect_ms given a monotonic deadline.
# Returns connect_ms unchanged when deadline is disabled; otherwise
# clamps to `deadline - now`. Returns 0 if the deadline has already
# elapsed (caller treats as TIMEOUT).
fn _sandhi_http_clamp_ms(raw_ms, deadline_ms): i64 {
    if (deadline_ms <= 0) { return raw_ms; }
    var remaining = deadline_ms - clock_now_ms();
    if (remaining <= 0) { return 0 - 1; }  # sentinel: already elapsed
    if (raw_ms <= 0 || raw_ms > remaining) { return remaining; }
    return raw_ms;
}

# Keep this function compact — Cyrius 5.6.22 aliases locals on crowded
# frames. Everything meaningful lives in helpers. 1.2.0 added the `_a`
# variant that threads `a` through every per-request alloc:
# url-parse, DNS resolve (v4 + v6), conn-open (the `_a` paths exist as
# back-compat-clean leaves), request-builder, and the exchange recv
# buffer. Pool ops keep using the pool's own allocator (per
# `_sandhi_pool_alloc`) — pool entries outlive any per-request arena.
fn _sandhi_http_do_impl_a(a, method, url, user_headers, body, body_len, max_bytes,
connect_ms, read_ms, write_ms, total_ms, pool): i64 {
    sandhi_prof_reset();
    var u = sandhi_url_parse_a(a, url);
    sandhi_prof_capture(SANDHI_PROF_PHASE_URL_PARSE_END);
    if (u == 0) { return _sandhi_resp_err_a(a, SANDHI_ERR_PARSE); }

    # v4-first, v6-fallback. Most production hosts have v4 (often
    # alongside v6), so a v4 hit is the common path. v6-only hosts
    # are reached via _sandhi_client_resolve_v6 + the v6 connect
    # path in conn.cyr.
    var addr = _sandhi_client_resolve_a(a, sandhi_url_host(u));
    var addr6 = 0;
    if (addr == 0 - 1) {
        addr6 = _sandhi_client_resolve_v6_a(a, sandhi_url_host(u));
        if (addr6 == 0) {
            sandhi_prof_capture(SANDHI_PROF_PHASE_DNS_END);
            return _sandhi_resp_err_a(a, SANDHI_ERR_DISCOVERY);
        }
    }
    sandhi_prof_capture(SANDHI_PROF_PHASE_DNS_END);

    # Compute monotonic deadline if total_ms is set. Passed through to
    # exchange so the recv loop can break early. A fresh deadline
    # applies per _sandhi_http_do call; the redirect follower re-enters
    # here for each hop, so each hop gets its own `total_ms` budget.
    var deadline_ms = 0;
    if (total_ms > 0) { deadline_ms = clock_now_ms() + total_ms; }

    var use_tls = 0;
    if (sandhi_url_scheme(u) == SANDHI_URL_HTTPS) { use_tls = 1; }
    var port = sandhi_url_port(u);
    var host = sandhi_url_host(u);

    # Try the pool first when attached. A taken conn skips the connect
    # phase entirely (and its timeout). Failure on a pooled conn falls
    # back to opening a fresh one — peer may have closed since put-back.
    var keep_alive = 0;
    var conn = 0;
    if (pool != 0) {
        keep_alive = 1;
        conn = _sandhi_pool_take(pool, host, port, use_tls);
    }

    # 1.3.2 — request build moved BEFORE conn-open so the bytes are
    # available to pass as early-data when 0-RTT eligible. For the
    # non-0-RTT path this is byte-identical to the pre-1.3.2 ordering
    # (the request bytes don't depend on the connection's properties,
    # only on the URL + headers + body + keep_alive).
    var full_path = _sandhi_client_full_path_a(a, u);
    var host_hdr = _sandhi_client_host_header_a(a, u);
    var req = _sandhi_client_build_request_va(a, method, full_path, host_hdr,
    user_headers, body_len, keep_alive);
    sandhi_prof_capture(SANDHI_PROF_PHASE_REQ_BUILD_END);

    if (conn == 0) {
        var eff_connect = _sandhi_http_clamp_ms(connect_ms, deadline_ms);
        if (eff_connect == 0 - 1) { return _sandhi_resp_err_a(a, SANDHI_ERR_TIMEOUT); }
        # 1.3.2 — 0-RTT eligibility: opt-in flag set + TLS + method
        # is replay-safe + libssl exposes the full 0-RTT surface +
        # session-cache enabled (no session means no resumption).
        # The session-presence check itself happens inside
        # `_sandhi_conn_finalize_with_early_data_a` (per-cache-key
        # lookup); we just need the early_data bytes to be non-zero
        # for finalize to consider 0-RTT.
        var use_0rtt = 0;
        if (_sandhi_allow_0rtt == 1
        && use_tls == 1
        && _sandhi_method_is_replay_safe(method) == 1
        && tls_supports_early_data() == 1
        && sandhi_session_cache_enabled() == 1) {
            use_0rtt = 1;
        }
        var ed_ptr = 0;
        var ed_len = 0;
        if (use_0rtt == 1) {
            ed_ptr = str_data(req);
            ed_len = strlen(ed_ptr);
        }
        if (addr6 != 0) {
            if (use_0rtt == 1) {
                conn = _sandhi_conn_open_v6_fully_timed_with_early_data_a(a, addr6,
                port, use_tls, host, eff_connect, read_ms, write_ms, ed_ptr, ed_len);
            } else {
                conn = _sandhi_conn_open_v6_fully_timed_a(a, addr6, port, use_tls, host,
                eff_connect, read_ms, write_ms);
            }
        } else {
            if (use_0rtt == 1) {
                conn = _sandhi_conn_open_fully_timed_with_early_data_a(a, addr,
                port, use_tls, host, eff_connect, read_ms, write_ms, ed_ptr, ed_len);
            } else {
                conn = sandhi_conn_open_fully_timed_a(a, addr, port, use_tls, host,
                eff_connect, read_ms, write_ms);
            }
        }
        if (conn == 0) {
            sandhi_prof_capture(SANDHI_PROF_PHASE_CONN_OPEN_END);
            var oe = sandhi_conn_last_open_err();
            if (oe == SANDHI_CONN_OPEN_TIMEOUT) { return _sandhi_resp_err_a(a, SANDHI_ERR_TIMEOUT); }
            if (oe == SANDHI_CONN_OPEN_TLS)     { return _sandhi_resp_err_a(a, SANDHI_ERR_TLS); }
            return _sandhi_resp_err_a(a, SANDHI_ERR_CONNECT);
        }
    }
    sandhi_prof_capture(SANDHI_PROF_PHASE_CONN_OPEN_END);

    var resp = 0;
    if (keep_alive == 1) {
        resp = _sandhi_http_exchange_keepalive_a(a, conn, req, body, body_len, max_bytes,
        deadline_ms, pool, host, port, use_tls);
    } else {
        resp = _sandhi_http_exchange_a(a, conn, req, body, body_len, max_bytes, deadline_ms);
    }
    sandhi_prof_capture(SANDHI_PROF_PHASE_EXCHANGE_END);
    return resp;
}

fn _sandhi_http_do_impl(method, url, user_headers, body, body_len, max_bytes,
connect_ms, read_ms, write_ms, total_ms, pool): i64 {
    return _sandhi_http_do_impl_a(default_alloc(), method, url, user_headers, body, body_len,
    max_bytes, connect_ms, read_ms, write_ms, total_ms, pool);
}

# Send request, receive response, close connection. Extracted so the
# local count in _sandhi_http_do stays small. Returns SANDHI_ERR_TIMEOUT
# on SO_RCVTIMEO/SO_SNDTIMEO or deadline-exceeded; SANDHI_ERR_CONNECT
# for any other I/O fail. 1.2.0: `_a` threads `a` through the recv
# buffer alloc + response parse + every error-path resp construction;
# the bare version calls `_a` with default_alloc() for back-compat.
fn _sandhi_http_exchange_a(a, conn, req, body, body_len, max_bytes, deadline_ms): i64 {
    if (deadline_ms > 0 && clock_now_ms() >= deadline_ms) {
        sandhi_conn_close(conn);
        return _sandhi_resp_err_a(a, SANDHI_ERR_TIMEOUT);
    }
    var req_data = str_data(req);
    var req_len = strlen(req_data);
    # 1.3.2 — TLS 1.3 0-RTT branch. When `conn` was opened with the
    # request bytes also written as early data (eligibility gated to
    # session-resumed TLS + replay-safe methods at conn-open time),
    # the 0-RTT status decides whether to re-send the request on the
    # normal stream:
    #   ACCEPTED (2)  — server processed the early data; skip resend.
    #   REJECTED (1)  — server discarded the early data; must resend.
    #   NOT_SENT (0)  — no early data was attempted; normal path.
    # NOT_SENT also covers every plaintext / non-resumed TLS exchange,
    # so the default path stays identical to pre-1.3.2 behavior.
    var ed_status = sandhi_conn_0rtt_status(conn);
    var skip_req_send = 0;
    if (ed_status == TLS_EARLY_DATA_ACCEPTED) { skip_req_send = 1; }
    if (skip_req_send == 0) {
        var sw = sandhi_conn_send_all(conn, req_data, req_len);
        if (sw == 0 - _SANDHI_EAGAIN) {
            sandhi_conn_close(conn);
            return _sandhi_resp_err_a(a, SANDHI_ERR_TIMEOUT);
        }
        if (sw < 0) {
            sandhi_conn_close(conn);
            return _sandhi_resp_err_a(a, SANDHI_ERR_CONNECT);
        }
    }
    if (body_len > 0 && body != 0) {
        var sb = sandhi_conn_send_all(conn, body, body_len);
        if (sb == 0 - _SANDHI_EAGAIN) {
            sandhi_conn_close(conn);
            return _sandhi_resp_err_a(a, SANDHI_ERR_TIMEOUT);
        }
        if (sb < 0) {
            sandhi_conn_close(conn);
            return _sandhi_resp_err_a(a, SANDHI_ERR_CONNECT);
        }
    }
    var cap = max_bytes;
    if (cap <= 0) { cap = _SANDHI_HTTP_RESP_BUF_SIZE; }
    var rbuf = alloc_via(a, cap + 1);
    # 1.2.6 OOM guard: if the recv buffer can't be allocated, close
    # the conn and surface INTERNAL — without this, recv_all_deadline
    # would write to address 0 and SIGSEGV.
    if (rbuf == 0) {
        sandhi_conn_close(conn);
        return _sandhi_resp_err_a(a, SANDHI_ERR_INTERNAL);
    }
    var nread = sandhi_conn_recv_all_deadline(conn, rbuf, cap, deadline_ms);
    sandhi_conn_close(conn);
    sandhi_prof_record_recv(cap, nread);
    if (nread == 0 - _SANDHI_EAGAIN) { return _sandhi_resp_err_a(a, SANDHI_ERR_TIMEOUT); }
    if (nread < 0) { return _sandhi_resp_err_a(a, SANDHI_ERR_CONNECT); }
    return sandhi_http_response_parse_a(a, rbuf, nread);
}

fn _sandhi_http_exchange(conn, req, body, body_len, max_bytes, deadline_ms): i64 {
    return _sandhi_http_exchange_a(default_alloc(), conn, req, body, body_len, max_bytes, deadline_ms);
}

# Keep-alive variant — does framed recv (Content-Length or chunked
# detected from response headers) so the conn stays alive past the
# response. On success (2xx/3xx, no server-Connection-close) the conn
# is returned to the pool; otherwise it's closed. Bite 1 of 0.8.0.
# 1.2.0: `_a` threads `a` through the recv buffer + response parse +
# error-path resp construction. Pool put-back uses the pool's own
# allocator (`_sandhi_pool_alloc`) — pool entries outlive any per-
# request arena, so the put-back path is intentionally arena-skipping.
fn _sandhi_http_exchange_keepalive_a(a, conn, req, body, body_len, max_bytes,
deadline_ms, pool, host, port, use_tls): i64 {
    if (deadline_ms > 0 && clock_now_ms() >= deadline_ms) {
        sandhi_conn_close(conn);
        return _sandhi_resp_err_a(a, SANDHI_ERR_TIMEOUT);
    }
    var req_data = str_data(req);
    var req_len = strlen(req_data);
    # 1.3.2 — same 0-RTT skip-resend gate as the non-keepalive exchange.
    # See `_sandhi_http_exchange_a` for the status-value rationale.
    var ed_status = sandhi_conn_0rtt_status(conn);
    var skip_req_send = 0;
    if (ed_status == TLS_EARLY_DATA_ACCEPTED) { skip_req_send = 1; }
    if (skip_req_send == 0) {
        var sw = sandhi_conn_send_all(conn, req_data, req_len);
        if (sw == 0 - _SANDHI_EAGAIN) {
            sandhi_conn_close(conn);
            return _sandhi_resp_err_a(a, SANDHI_ERR_TIMEOUT);
        }
        if (sw < 0) {
            sandhi_conn_close(conn);
            return _sandhi_resp_err_a(a, SANDHI_ERR_CONNECT);
        }
    }
    if (body_len > 0 && body != 0) {
        var sb = sandhi_conn_send_all(conn, body, body_len);
        if (sb == 0 - _SANDHI_EAGAIN) {
            sandhi_conn_close(conn);
            return _sandhi_resp_err_a(a, SANDHI_ERR_TIMEOUT);
        }
        if (sb < 0) {
            sandhi_conn_close(conn);
            return _sandhi_resp_err_a(a, SANDHI_ERR_CONNECT);
        }
    }
    var cap = max_bytes;
    if (cap <= 0) { cap = _SANDHI_HTTP_RESP_BUF_SIZE; }
    var rbuf = alloc_via(a, cap + 1);
    # 1.2.6 OOM guard: request + body have already been sent by
    # this point, so the conn is mid-exchange. Close (don't pool-
    # put) so the next request gets a fresh handshake; the peer
    # sees an abrupt close mid-response, which is the same shape
    # as a network drop and well within the keep-alive contract.
    if (rbuf == 0) {
        sandhi_conn_close(conn);
        return _sandhi_resp_err_a(a, SANDHI_ERR_INTERNAL);
    }
    var nread = _sandhi_http_recv_framed(conn, rbuf, cap, deadline_ms);
    sandhi_prof_record_recv(cap, nread);
    if (nread == 0 - _SANDHI_EAGAIN) {
        sandhi_conn_close(conn);
        return _sandhi_resp_err_a(a, SANDHI_ERR_TIMEOUT);
    }
    if (nread < 0 && nread != 0 - 2) {
        # 0 - 2 is the must-close sentinel — we still got the response.
        sandhi_conn_close(conn);
        return _sandhi_resp_err_a(a, SANDHI_ERR_CONNECT);
    }
    var server_sent_close = 0;
    var actual_n = nread;
    if (nread == 0 - 2) {
        # Server told us close; read whatever we have, then close.
        # _sandhi_http_recv_framed null-terminates buf at the bytes
        # actually read; recompute via strlen-style scan up to cap.
        actual_n = strlen(rbuf);
        server_sent_close = 1;
    }
    var resp = sandhi_http_response_parse_a(a, rbuf, actual_n);
    var status = sandhi_http_status(resp);
    var ek = sandhi_http_err_kind(resp);
    var put_back = 0;
    if (ek == SANDHI_OK && server_sent_close == 0
    && status >= 200 && status < 400) {
        put_back = 1;
    }
    if (put_back == 1) {
        _sandhi_pool_put(pool, host, port, use_tls, conn);
    } else {
        sandhi_conn_close(conn);
    }
    return resp;
}

fn _sandhi_http_exchange_keepalive(conn, req, body, body_len, max_bytes,
deadline_ms, pool, host, port, use_tls): i64 {
    return _sandhi_http_exchange_keepalive_a(default_alloc(), conn, req, body, body_len,
    max_bytes, deadline_ms, pool, host, port, use_tls);
}

# ================================================================
# Redirect following (opt-in, bounded)
# ================================================================
#
# RFC 7231 §6.4 method rewrite semantics:
#   303 See Other            — rewrite to GET, drop body
#   301/302/307/308         — preserve method + body
#
# Location may be absolute ("https://other.example.com/x") or relative
# ("/x" — resolve against the current URL's scheme+authority).

# Options struct (64 bytes):
#   +0   follow_redirects   (int: 0 default, 1 to enable)
#   +8   max_hops           (int: default 5)
#   +16  max_response_bytes (int: default 262144 = 256 KB; applies to
#                            the buffered client's scratch buffer and
#                            to streaming's per-buffer cap)
#   +24  read_ms            (int: SO_RCVTIMEO in ms; 0 = blocking).
#                            Added 0.7.2.
#   +32  write_ms           (int: SO_SNDTIMEO in ms; 0 = blocking).
#                            Added 0.7.2.
#   +40  connect_ms         (int: non-blocking connect + poll timeout
#                            in ms; 0 = blocking connect). Added 0.7.3.
#   +48  total_ms           (int: monotonic deadline for entire
#                            request-response cycle; 0 = no deadline).
#                            Bounds connect_ms + recv loop but not
#                            redirect-follow chain (each hop gets a
#                            fresh deadline). Added 0.7.3.
#   +56  pool               (ptr: sandhi_http_pool* or 0). When
#                            attached: emit Connection: keep-alive,
#                            try-take from pool before opening new,
#                            put-back on 2xx/3xx with no
#                            server-Connection-close. Added 0.8.0
#                            (Bite 1).
enum SandhiHttpOptOff {
    SANDHI_HTTP_OPT_OFF_FOLLOW       = 0;
    SANDHI_HTTP_OPT_OFF_MAX_HOPS     = 8;
    SANDHI_HTTP_OPT_OFF_MAX_BYTES    = 16;
    SANDHI_HTTP_OPT_OFF_READ_MS      = 24;
    SANDHI_HTTP_OPT_OFF_WRITE_MS     = 32;
    SANDHI_HTTP_OPT_OFF_CONNECT_MS   = 40;
    SANDHI_HTTP_OPT_OFF_TOTAL_MS     = 48;
    SANDHI_HTTP_OPT_OFF_POOL         = 56;
    SANDHI_HTTP_OPT_OFF_ALLOW_0RTT   = 64;   # 1.3.2 — opt-in TLS 1.3 0-RTT
}

var SANDHI_HTTP_OPT_STRUCT_SIZE = 72;
var SANDHI_HTTP_DEFAULT_MAX_HOPS = 5;
var SANDHI_HTTP_DEFAULT_MAX_BYTES = 262144;

fn sandhi_http_options_new_a(a): i64 {
    var o = alloc_via(a, SANDHI_HTTP_OPT_STRUCT_SIZE);
    if (o == 0) { return 0; }
    store64(o + SANDHI_HTTP_OPT_OFF_FOLLOW, 0);
    store64(o + SANDHI_HTTP_OPT_OFF_MAX_HOPS, SANDHI_HTTP_DEFAULT_MAX_HOPS);
    store64(o + SANDHI_HTTP_OPT_OFF_MAX_BYTES, SANDHI_HTTP_DEFAULT_MAX_BYTES);
    store64(o + SANDHI_HTTP_OPT_OFF_READ_MS, 0);
    store64(o + SANDHI_HTTP_OPT_OFF_WRITE_MS, 0);
    store64(o + SANDHI_HTTP_OPT_OFF_CONNECT_MS, 0);
    store64(o + SANDHI_HTTP_OPT_OFF_TOTAL_MS, 0);
    store64(o + SANDHI_HTTP_OPT_OFF_POOL, 0);
    store64(o + SANDHI_HTTP_OPT_OFF_ALLOW_0RTT, 0);
    return o;
}

fn sandhi_http_options_new(): i64 {
    return sandhi_http_options_new_a(default_alloc());
}

fn sandhi_http_options_follow_redirects(opts, on): i64 {
    store64(opts + SANDHI_HTTP_OPT_OFF_FOLLOW, on);
    return 0;
}

fn sandhi_http_options_max_hops(opts, n): i64 {
    store64(opts + SANDHI_HTTP_OPT_OFF_MAX_HOPS, n);
    return 0;
}

fn sandhi_http_options_max_response_bytes(opts, n): i64 {
    store64(opts + SANDHI_HTTP_OPT_OFF_MAX_BYTES, n);
    return 0;
}

fn sandhi_http_options_read_ms(opts, ms): i64 {
    store64(opts + SANDHI_HTTP_OPT_OFF_READ_MS, ms);
    return 0;
}

fn sandhi_http_options_write_ms(opts, ms): i64 {
    store64(opts + SANDHI_HTTP_OPT_OFF_WRITE_MS, ms);
    return 0;
}

fn sandhi_http_options_connect_ms(opts, ms): i64 {
    store64(opts + SANDHI_HTTP_OPT_OFF_CONNECT_MS, ms);
    return 0;
}

fn sandhi_http_options_total_ms(opts, ms): i64 {
    store64(opts + SANDHI_HTTP_OPT_OFF_TOTAL_MS, ms);
    return 0;
}

fn sandhi_http_options_pool(opts, pool): i64 {
    store64(opts + SANDHI_HTTP_OPT_OFF_POOL, pool);
    return 0;
}

# 1.3.2: opt-in TLS 1.3 0-RTT (early data). Default 0 = off.
# Replay-attack surface means this MUST stay default-off; consumers
# opt in per-request when they're sending replay-safe payloads
# (GET / HEAD / OPTIONS). Sandhi enforces method-safety internally
# even when this flag is set — POST / PUT / PATCH / DELETE silently
# skip 0-RTT regardless. Also gated on
# `tls_supports_early_data()` (libssl capability) + session-cache
# hit + cached session advertising 0-RTT support
# (`tls_session_get_max_early_data >= req_len`).
fn sandhi_http_options_allow_0rtt(opts, on): i64 {
    store64(opts + SANDHI_HTTP_OPT_OFF_ALLOW_0RTT, on);
    return 0;
}

fn sandhi_http_options_get_allow_0rtt(opts): i64 {
    if (opts == 0) { return 0; }
    return load64(opts + SANDHI_HTTP_OPT_OFF_ALLOW_0RTT);
}

fn sandhi_http_options_follow(opts): i64 {
    if (opts == 0) { return 0; }
    return load64(opts + SANDHI_HTTP_OPT_OFF_FOLLOW);
}

fn sandhi_http_options_hops(opts): i64 {
    if (opts == 0) { return SANDHI_HTTP_DEFAULT_MAX_HOPS; }
    return load64(opts + SANDHI_HTTP_OPT_OFF_MAX_HOPS);
}

fn sandhi_http_options_bytes(opts): i64 {
    if (opts == 0) { return SANDHI_HTTP_DEFAULT_MAX_BYTES; }
    return load64(opts + SANDHI_HTTP_OPT_OFF_MAX_BYTES);
}

fn sandhi_http_options_get_read_ms(opts): i64 {
    if (opts == 0) { return 0; }
    return load64(opts + SANDHI_HTTP_OPT_OFF_READ_MS);
}

fn sandhi_http_options_get_write_ms(opts): i64 {
    if (opts == 0) { return 0; }
    return load64(opts + SANDHI_HTTP_OPT_OFF_WRITE_MS);
}

fn sandhi_http_options_get_connect_ms(opts): i64 {
    if (opts == 0) { return 0; }
    return load64(opts + SANDHI_HTTP_OPT_OFF_CONNECT_MS);
}

fn sandhi_http_options_get_total_ms(opts): i64 {
    if (opts == 0) { return 0; }
    return load64(opts + SANDHI_HTTP_OPT_OFF_TOTAL_MS);
}

fn sandhi_http_options_get_pool(opts): i64 {
    if (opts == 0) { return 0; }
    return load64(opts + SANDHI_HTTP_OPT_OFF_POOL);
}

# 1 if the status code indicates a redirect we follow.
fn _sandhi_is_redirect(status): i64 {
    if (status == 301) { return 1; }
    if (status == 302) { return 1; }
    if (status == 303) { return 1; }
    if (status == 307) { return 1; }
    if (status == 308) { return 1; }
    return 0;
}

# Resolve a Location header value against a base URL. Returns an alloc'd
# cstr with a fully-qualified URL, or 0 if resolution fails.
fn _sandhi_resolve_location_a(a, base_url, location): i64 {
    if (location == 0) { return 0; }
    if (_sandhi_url_sceq(location, "http://", 7) == 1
    || _sandhi_url_sceq(location, "https://", 8) == 1) {
        var llen = strlen(location);
        var out = alloc_via(a, llen + 1);
        if (out == 0) { return 0; }
        memcpy(out, location, llen);
        store8(out + llen, 0);
        return out;
    }
    if (load8(location) != 47) { return 0; }
    var u = sandhi_url_parse_a(a, base_url);
    if (u == 0) { return 0; }
    # 1.2.8: was `str_builder_new()` (default_alloc) — partial-
    # arena leak found during the OOM audit. The fn is `_a` and
    # callers expect every alloc on `a`; the str_builder scratch
    # was bypassing that. Threaded through `_a` variants now;
    # OOM null-guard added on `str_builder_new_a`.
    var sb = str_builder_new_a(a);
    if (sb == 0) { return 0; }
    if (sandhi_url_scheme(u) == SANDHI_URL_HTTPS) {
        str_builder_add_cstr_a(a, sb, "https://");
    } else {
        str_builder_add_cstr_a(a, sb, "http://");
    }
    str_builder_add_cstr_a(a, sb, sandhi_url_host(u));
    var scheme = sandhi_url_scheme(u);
    var default_port = 80;
    if (scheme == SANDHI_URL_HTTPS) { default_port = 443; }
    if (sandhi_url_port(u) != default_port) {
        str_builder_add_cstr_a(a, sb, ":");
        str_builder_add_int_a(a, sb, sandhi_url_port(u));
    }
    str_builder_add_cstr_a(a, sb, location);
    return _sandhi_json_dup_a(a, str_data(str_builder_build_a(a, sb)));
}

fn _sandhi_resolve_location(base_url, location): i64 {
    return _sandhi_resolve_location_a(default_alloc(), base_url, location);
}

# 0.9.0 P0 #4 — case-insensitive cstr compare. Used by the redirect
# follower for header-name filtering. Inlined here rather than in
# headers.cyr because the only consumer is right below.
fn _sandhi_streq_ci(a, b): i64 {
    if (a == 0 || b == 0) { return 0; }
    var i = 0;
    while (1 == 1) {
        var ca = load8(a + i);
        var cb = load8(b + i);
        if (ca >= 65 && ca <= 90) { ca = ca + 32; }
        if (cb >= 65 && cb <= 90) { cb = cb + 32; }
        if (ca != cb) { return 0; }
        if (ca == 0)  { return 1; }
        i = i + 1;
    }
    return 0;
}

# 1 if `next_url` has the same scheme+host+port as `prev_url`. Used
# to decide whether to forward sensitive headers across a redirect.
fn _sandhi_url_same_authority(prev_url, next_url): i64 {
    var pu = sandhi_url_parse(prev_url);
    var nu = sandhi_url_parse(next_url);
    if (pu == 0 || nu == 0) { return 0; }
    if (sandhi_url_scheme(pu) != sandhi_url_scheme(nu)) { return 0; }
    if (sandhi_url_port(pu) != sandhi_url_port(nu)) { return 0; }
    if (streq(sandhi_url_host(pu), sandhi_url_host(nu)) != 1) { return 0; }
    return 1;
}

# 1 if `prev_url` was HTTPS and `next_url` is HTTP — a security
# downgrade we refuse to follow per the curl CVE-2025-0167 /
# 14524 cluster lessons.
fn _sandhi_url_is_https_downgrade(prev_url, next_url): i64 {
    var pu = sandhi_url_parse(prev_url);
    var nu = sandhi_url_parse(next_url);
    if (pu == 0 || nu == 0) { return 0; }
    if (sandhi_url_scheme(pu) == SANDHI_URL_HTTPS
    && sandhi_url_scheme(nu) == SANDHI_URL_HTTP) { return 1; }
    return 0;
}

# Return a fresh sandhi_headers struct that's a copy of `src` with
# `Authorization`, `Cookie`, and `Proxy-Authorization` stripped.
# Used when a redirect crosses authorities — the caller's secret
# wasn't intended for the new origin.
fn _sandhi_strip_sensitive_headers_a(a, src): i64 {
    if (src == 0) { return 0; }
    var out = sandhi_headers_new_a(a);
    if (out == 0) { return 0; }
    var n = sandhi_headers_count(src);
    var i = 0;
    while (i < n) {
        var name = sandhi_headers_name_at(src, i);
        var value = sandhi_headers_value_at(src, i);
        var keep = 1;
        if (_sandhi_streq_ci(name, "authorization") == 1)        { keep = 0; }
        if (_sandhi_streq_ci(name, "cookie") == 1)               { keep = 0; }
        if (_sandhi_streq_ci(name, "proxy-authorization") == 1)  { keep = 0; }
        if (keep == 1) { sandhi_headers_add_a(a, out, name, value); }
        i = i + 1;
    }
    return out;
}

fn _sandhi_strip_sensitive_headers(src): i64 {
    return _sandhi_strip_sensitive_headers_a(default_alloc(), src);
}

# Redirect-following driver. Keep compact — each iteration reassigns
# locals rather than allocating new ones, so the function stays under
# the Cyrius local-count threshold. total_ms resets per hop (each
# destination gets its own request budget); if a tighter end-to-end
# bound is needed, the caller should lower max_hops or pre-compute.
#
# 0.9.0 P0 #4 — security-aware redirect handling:
#   - Refuse https→http downgrades (return the prior response with
#     `SANDHI_ERR_TLS` rather than silently leaking creds in
#     plaintext to an attacker-controlled `Location:`).
#   - Strip `Authorization` / `Cookie` / `Proxy-Authorization` from
#     headers when the redirect crosses authorities (different
#     scheme / host / port). The caller's secret was bound to the
#     original origin; the redirect target may be hostile.
#   - Both apply per-hop, so a chain that bounces back to the
#     original authority gets the full headers again. (curl does
#     the same; matches RFC 7235 §2.2 spirit even though the spec
#     doesn't mandate.)
fn _sandhi_http_follow_a(a, method, url, headers, body, body_len, max_hops,
max_bytes, connect_ms, read_ms, write_ms, total_ms, pool): i64 {
    var m = method;
    var u = url;
    var b = body;
    var bl = body_len;
    var h = headers;
    var hops = 0;
    var r = _sandhi_http_do_a(a, m, u, h, b, bl, max_bytes,
    connect_ms, read_ms, write_ms, total_ms, pool);
    while (hops < max_hops) {
        if (_sandhi_is_redirect(sandhi_http_status(r)) == 0) { return r; }
        var loc = sandhi_headers_get(sandhi_http_headers(r), "Location");
        if (loc == 0) { return r; }
        var next = _sandhi_resolve_location_a(a, u, loc);
        if (next == 0) { return r; }

        # Refuse https→http downgrade — surface the redirect response
        # with err_kind=TLS so the caller sees the refusal rather
        # than transparently following.
        if (_sandhi_url_is_https_downgrade(u, next) == 1) {
            store64(r + SANDHI_RESP_OFF_ERR_KIND, SANDHI_ERR_TLS);
            return r;
        }

        # Strip sensitive headers if crossing authorities.
        if (_sandhi_url_same_authority(u, next) == 0) {
            h = _sandhi_strip_sensitive_headers_a(a, h);
        }

        if (sandhi_http_status(r) == 303) { m = "GET"; b = 0; bl = 0; }
        u = next;
        hops = hops + 1;
        r = _sandhi_http_do_a(a, m, u, h, b, bl, max_bytes,
        connect_ms, read_ms, write_ms, total_ms, pool);
    }
    return r;
}

fn _sandhi_http_follow(method, url, headers, body, body_len, max_hops,
max_bytes, connect_ms, read_ms, write_ms, total_ms, pool): i64 {
    return _sandhi_http_follow_a(default_alloc(), method, url, headers, body, body_len,
    max_hops, max_bytes, connect_ms, read_ms, write_ms, total_ms, pool);
}

# ================================================================
# Public verbs
# ================================================================

# Core dispatch. Opts == 0 means single request; opts with follow == 1
# engages the redirect-following driver up to max_hops. 1.2.1: both
# the no-follow and follow paths thread `a` end-to-end (the 1.2.0
# partial-arena leak on follow=1 is closed).
fn _sandhi_http_dispatch_a(a, method, url, headers, body, body_len, opts): i64 {
    var max_bytes = sandhi_http_options_bytes(opts);
    var read_ms = sandhi_http_options_get_read_ms(opts);
    var write_ms = sandhi_http_options_get_write_ms(opts);
    var connect_ms = sandhi_http_options_get_connect_ms(opts);
    var total_ms = sandhi_http_options_get_total_ms(opts);
    var pool = sandhi_http_options_get_pool(opts);
    # 1.3.2 — set the 0-RTT opt-in flag (module-level, matches the
    # `_sandhi_alpn_advertise_h2` pattern). do_impl_a reads it in
    # the eligibility check. Save + restore around the call so
    # outer-scope state isn't perturbed (relevant when this is
    # invoked recursively via redirect-follow).
    var prior_0rtt = _sandhi_allow_0rtt;
    _sandhi_allow_0rtt = sandhi_http_options_get_allow_0rtt(opts);
    # 1.3.3 — set the cred-digest flag for the duration of this
    # dispatch. Conn finalize reads it when computing the
    # session-cache key. Save + restore mirrors the 0-RTT pattern
    # so redirect-follow's cred-strip step (which mutates `headers`
    # via `_sandhi_strip_sensitive_headers_a` for cross-authority
    # hops) takes effect on the next hop's digest naturally —
    # `_sandhi_http_follow_a` recomputes through this dispatch on
    # each hop only when the user-level dispatch loops, but the
    # 1.1 follow path stays inside `_sandhi_http_do_a` per hop, so
    # cred-strip-on-redirect handling for the cache key is a
    # follow-up if a consumer ever sets cred-bearing headers AND
    # follows redirects across authorities. Today that combination
    # is rare; flagging the limitation rather than over-engineering.
    var prior_cred = _sandhi_cred_digest;
    _sandhi_cred_digest = _sandhi_compute_cred_digest(headers);
    var r = 0;
    if (sandhi_http_options_follow(opts) == 1) {
        var hops = sandhi_http_options_hops(opts);
        r = _sandhi_http_follow_a(a, method, url, headers, body, body_len, hops,
        max_bytes, connect_ms, read_ms, write_ms, total_ms, pool);
    } else {
        r = _sandhi_http_do_a(a, method, url, headers, body, body_len,
        max_bytes, connect_ms, read_ms, write_ms, total_ms, pool);
    }
    _sandhi_cred_digest = prior_cred;
    _sandhi_allow_0rtt = prior_0rtt;
    return r;
}

fn _sandhi_http_dispatch(method, url, headers, body, body_len, opts): i64 {
    return _sandhi_http_dispatch_a(default_alloc(), method, url, headers, body, body_len, opts);
}

# Simple verbs — no redirect following. Pass user_headers = 0 for none.
# 1.2.2 Batch D: every verb gains an `_a` variant that takes the
# allocator as the first arg. Internal cascade has been fully
# `_a`-threaded since 1.2.1, so the wrappers are thin — `_a` calls
# `_sandhi_http_dispatch_a(a, ...)`; bare versions stay as
# back-compat wrappers passing `default_alloc()`. Consumers wiring
# a per-request arena now have an end-to-end path:
# `sandhi_http_get_a(arena, url, headers)` allocates response +
# body + parsed headers entirely in the arena.
fn sandhi_http_get_a(a, url, user_headers): i64 {
    return _sandhi_http_dispatch_a(a, "GET", url, user_headers, 0, 0, 0);
}

fn sandhi_http_get(url, user_headers): i64 {
    return sandhi_http_get_a(default_alloc(), url, user_headers);
}

fn sandhi_http_post_a(a, url, user_headers, body, body_len): i64 {
    return _sandhi_http_dispatch_a(a, "POST", url, user_headers, body, body_len, 0);
}

fn sandhi_http_post(url, user_headers, body, body_len): i64 {
    return sandhi_http_post_a(default_alloc(), url, user_headers, body, body_len);
}

fn sandhi_http_put_a(a, url, user_headers, body, body_len): i64 {
    return _sandhi_http_dispatch_a(a, "PUT", url, user_headers, body, body_len, 0);
}

fn sandhi_http_put(url, user_headers, body, body_len): i64 {
    return sandhi_http_put_a(default_alloc(), url, user_headers, body, body_len);
}

fn sandhi_http_patch_a(a, url, user_headers, body, body_len): i64 {
    return _sandhi_http_dispatch_a(a, "PATCH", url, user_headers, body, body_len, 0);
}

fn sandhi_http_patch(url, user_headers, body, body_len): i64 {
    return sandhi_http_patch_a(default_alloc(), url, user_headers, body, body_len);
}

fn sandhi_http_delete_a(a, url, user_headers): i64 {
    return _sandhi_http_dispatch_a(a, "DELETE", url, user_headers, 0, 0, 0);
}

fn sandhi_http_delete(url, user_headers): i64 {
    return sandhi_http_delete_a(default_alloc(), url, user_headers);
}

fn sandhi_http_head_a(a, url, user_headers): i64 {
    return _sandhi_http_dispatch_a(a, "HEAD", url, user_headers, 0, 0, 0);
}

fn sandhi_http_head(url, user_headers): i64 {
    return sandhi_http_head_a(default_alloc(), url, user_headers);
}

# _opts variants — pass a sandhi_http_options_new() with
# follow_redirects enabled to opt into redirect chasing.
# 1.2.3 Batch E: each gains an `_a` variant; bare versions stay
# as back-compat wrappers passing `default_alloc()`. Underlying
# `_sandhi_http_dispatch_a` has been `_a`-threaded since 1.2.0.
fn sandhi_http_get_opts_a(a, url, user_headers, opts): i64 {
    return _sandhi_http_dispatch_a(a, "GET", url, user_headers, 0, 0, opts);
}

fn sandhi_http_get_opts(url, user_headers, opts): i64 {
    return sandhi_http_get_opts_a(default_alloc(), url, user_headers, opts);
}

fn sandhi_http_post_opts_a(a, url, user_headers, body, body_len, opts): i64 {
    return _sandhi_http_dispatch_a(a, "POST", url, user_headers, body, body_len, opts);
}

fn sandhi_http_post_opts(url, user_headers, body, body_len, opts): i64 {
    return sandhi_http_post_opts_a(default_alloc(), url, user_headers, body, body_len, opts);
}


# --- pool.cyr ---

# sandhi/http/pool — connection pool for HTTP/1.1 keep-alive (and h2
# stream-multiplex once Bite 6 lands).
#
# Why this exists: every request through `sandhi_http_get` etc.
# without a pool pays a full TCP handshake + TLS handshake. For a
# yantra/daimon RPC loop hitting the same host 100×/sec, that's
# 100× the round-trip cost it needs to be. A small pool with a
# generous idle timeout amortizes those handshakes across many
# requests at trivial memory cost.
#
# Pool struct (32 bytes):
#   +0   map               (host:port:tls cstr → vec<idle_conn>)
#   +8   max_per_host      (int: cap on idle conns per route)
#   +16  idle_timeout_ms   (int: stale-conn evict threshold)
#   +24  total_idle        (int: sum of all vec lens; observability)
#
# idle_conn struct (16 bytes):
#   +0   conn              (ptr to sandhi_conn struct)
#   +8   last_used_ms      (clock_now_ms() at put time)
#
# Lifecycle: take / put / close.
#   - take(host, port, tls) returns the freshest idle conn for the
#     route, or 0 if none. Stale conns (now - last_used >
#     idle_timeout_ms) are closed and discarded; take recurses.
#   - put(host, port, tls, conn) stores the conn for reuse. If the
#     vec is at max_per_host, the OLDEST entry is evicted (FIFO
#     across the cap; LIFO take order keeps the freshest hot).
#   - close drops every idle conn (calls sock_close + tls_close).
#
# Single-threaded today. Multi-threaded clients would need a
# per-pool mutex; flagged as a follow-up when concurrent request
# dispatch lands (no consumer asking yet).

enum SandhiPoolOff {
    SANDHI_POOL_OFF_MAP             = 0;
    SANDHI_POOL_OFF_MAX_PER_HOST    = 8;
    SANDHI_POOL_OFF_IDLE_TIMEOUT    = 16;
    SANDHI_POOL_OFF_TOTAL_IDLE      = 24;
    SANDHI_POOL_OFF_H2_MAP          = 32;   # added 0.8.0 Bite 6
    SANDHI_POOL_OFF_ALLOC           = 40;   # added 1.1.0 — Allocator handle
}

enum SandhiIdleConnOff {
    SANDHI_IDLE_OFF_CONN     = 0;
    SANDHI_IDLE_OFF_LAST_MS  = 8;
}

var SANDHI_POOL_STRUCT_SIZE      = 48;
var SANDHI_IDLE_CONN_STRUCT_SIZE = 16;
var SANDHI_POOL_DEFAULT_MAX_PER_HOST     = 8;
var SANDHI_POOL_DEFAULT_IDLE_TIMEOUT_MS  = 90000;  # 90 s — Go default

# ================================================================
# Public API
# ================================================================

# Build a connection pool whose internal allocations all flow through
# `a`. The Allocator handle lives on the pool struct so subsequent
# `_sandhi_pool_put` calls allocate idle-conn wrappers from the same
# place — important when consumers want pool churn isolated from the
# global bump (e.g., a long-lived service backed by an arena it
# periodically reset). Returns 0 on OOM.
fn sandhi_http_pool_new_a(a, max_per_host, idle_timeout_ms): i64 {
    var p = alloc_via(a, SANDHI_POOL_STRUCT_SIZE);
    if (p == 0) { return 0; }
    store64(p + SANDHI_POOL_OFF_MAP, map_new_a(a));
    var mph = max_per_host;
    if (mph <= 0) { mph = SANDHI_POOL_DEFAULT_MAX_PER_HOST; }
    var ito = idle_timeout_ms;
    if (ito <= 0) { ito = SANDHI_POOL_DEFAULT_IDLE_TIMEOUT_MS; }
    store64(p + SANDHI_POOL_OFF_MAX_PER_HOST, mph);
    store64(p + SANDHI_POOL_OFF_IDLE_TIMEOUT, ito);
    store64(p + SANDHI_POOL_OFF_TOTAL_IDLE, 0);
    # h2 multiplex (Bite 6): one h2 conn per route. h2_map keys are
    # the same "host:port:tls" cstrs the 1.1 map uses; values are
    # sandhi_h2_conn ptrs (not idle_conn wrappers — h2 is always
    # active so last_used_ms isn't meaningful).
    store64(p + SANDHI_POOL_OFF_H2_MAP, map_new_a(a));
    store64(p + SANDHI_POOL_OFF_ALLOC, a);
    return p;
}

fn sandhi_http_pool_new(max_per_host, idle_timeout_ms): i64 {
    return sandhi_http_pool_new_a(default_alloc(), max_per_host, idle_timeout_ms);
}

# Read back the Allocator stored at construction time. Returns
# default_alloc() if the pool was built before 1.1.0 (legacy callers
# can't reach this path; the slot is always written by `_new_a`).
fn _sandhi_pool_alloc(p): i64 {
    if (p == 0) { return default_alloc(); }
    var a = load64(p + SANDHI_POOL_OFF_ALLOC);
    if (a == 0) { return default_alloc(); }
    return a;
}

fn sandhi_http_pool_max_per_host(p): i64 {
    if (p == 0) { return SANDHI_POOL_DEFAULT_MAX_PER_HOST; }
    return load64(p + SANDHI_POOL_OFF_MAX_PER_HOST);
}

fn sandhi_http_pool_idle_timeout_ms(p): i64 {
    if (p == 0) { return SANDHI_POOL_DEFAULT_IDLE_TIMEOUT_MS; }
    return load64(p + SANDHI_POOL_OFF_IDLE_TIMEOUT);
}

fn sandhi_http_pool_idle_count(p): i64 {
    if (p == 0) { return 0; }
    return load64(p + SANDHI_POOL_OFF_TOTAL_IDLE);
}

# Drop every idle conn (closes fds + TLS contexts). Pool struct stays
# allocated and reusable; map is cleared.
fn sandhi_http_pool_close(p): i64 {
    if (p == 0) { return 0; }
    var m = load64(p + SANDHI_POOL_OFF_MAP);
    var keys = map_keys(m);
    var i = 0;
    var n = vec_len(keys);
    while (i < n) {
        var key = vec_get(keys, i);
        var v = map_get(m, key);
        if (v != 0) {
            var j = 0;
            var jn = vec_len(v);
            while (j < jn) {
                var ic = vec_get(v, j);
                if (ic != 0) {
                    var c = load64(ic + SANDHI_IDLE_OFF_CONN);
                    if (c != 0) { sandhi_conn_close(c); }
                }
                j = j + 1;
            }
        }
        i = i + 1;
    }
    map_clear(m);
    store64(p + SANDHI_POOL_OFF_TOTAL_IDLE, 0);
    # The h2_map is cleared but its h2-conn values are NOT walked
    # here — pool.cyr can't reference sandhi_h2_conn_underlying
    # without violating the build order (Bite 6 added the h2_map
    # field; tear-down lives in src/http/h2/pool_glue.cyr's
    # `sandhi_http_pool_close_h2_conns` so consumers that opted into
    # h2 explicitly tear those down before this generic close).
    var h2m = load64(p + SANDHI_POOL_OFF_H2_MAP);
    if (h2m != 0) { map_clear(h2m); }
    return 0;
}

# ================================================================
# Internal: route key + idle_conn helpers
# ================================================================

# Build a route key "host:port:tls" as a NUL-terminated cstr that
# map_get/map_set can use directly. tls is "0" or "1".
fn _sandhi_pool_route_key(host, port, tls): i64 {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, host);
    str_builder_add_cstr(sb, ":");
    str_builder_add_int(sb, port);
    str_builder_add_cstr(sb, ":");
    if (tls == 1) { str_builder_add_cstr(sb, "1"); }
    else          { str_builder_add_cstr(sb, "0"); }
    return str_data(str_builder_build(sb));
}

fn _sandhi_pool_idle_conn_new_a(a, conn, now_ms): i64 {
    var ic = alloc_via(a, SANDHI_IDLE_CONN_STRUCT_SIZE);
    if (ic == 0) { return 0; }
    store64(ic + SANDHI_IDLE_OFF_CONN, conn);
    store64(ic + SANDHI_IDLE_OFF_LAST_MS, now_ms);
    return ic;
}

fn _sandhi_pool_idle_conn_new(conn, now_ms): i64 {
    return _sandhi_pool_idle_conn_new_a(default_alloc(), conn, now_ms);
}

# Non-consuming peek: 1 if the route has at least one 1.1 idle conn
# that is NOT past idle_timeout_ms. Used by the h2 auto-promoter
# (`_sandhi_http_try_h2_promote`) to decide whether to attempt ALPN
# promotion or just take the existing 1.1 conn.
#
# 0.9.10 hardening: previously this peek returned 1 whenever the
# per-route vec had any entry, regardless of staleness. Two
# consequences for routes whose only entries had aged past
# idle_timeout_ms:
#   - ALPN promotion was incorrectly skipped, so h2 was never
#     attempted on a route that previously got 1.1 — even after
#     all those 1.1 conns went stale and would be discarded by
#     `_sandhi_pool_take` on the very next request.
#   - The fall-through `_sandhi_http_do` then opened a fresh
#     TLS+1.1 conn (correct), but the chance to negotiate h2 was
#     gone until something else reaped the stale entries.
# The walk is non-destructive — `_sandhi_pool_take` already does
# stale-skip on the take path, so reaping happens naturally.
fn _sandhi_pool_has_idle(pool, host, port, tls): i64 {
    if (pool == 0) { return 0; }
    var key = _sandhi_pool_route_key(host, port, tls);
    var m = load64(pool + SANDHI_POOL_OFF_MAP);
    var v = map_get(m, key);
    if (v == 0) { return 0; }
    var n = vec_len(v);
    if (n == 0) { return 0; }
    var idle_to = load64(pool + SANDHI_POOL_OFF_IDLE_TIMEOUT);
    var now = clock_now_ms();
    var i = 0;
    while (i < n) {
        var ic = vec_get(v, i);
        if (ic != 0) {
            var last = load64(ic + SANDHI_IDLE_OFF_LAST_MS);
            if (now - last <= idle_to) { return 1; }
        }
        i = i + 1;
    }
    return 0;
}

# ================================================================
# Take / put — the hot path
# ================================================================

# Fish a conn out of the pool for the given route. Returns 0 if the
# pool is empty for that route. Stale conns (idle > idle_timeout_ms)
# are closed and skipped before returning a fresh one. take is LIFO
# over the per-route vec (freshest first) — keeps the most-recently-
# used conn hot in the kernel buffer cache.
fn _sandhi_pool_take(pool, host, port, tls): i64 {
    if (pool == 0) { return 0; }
    var key = _sandhi_pool_route_key(host, port, tls);
    var m = load64(pool + SANDHI_POOL_OFF_MAP);
    var v = map_get(m, key);
    if (v == 0) { return 0; }
    var idle_to = load64(pool + SANDHI_POOL_OFF_IDLE_TIMEOUT);
    var now = clock_now_ms();
    var picked = 0;
    while (picked == 0 && vec_len(v) > 0) {
        var ic = vec_pop(v);
        if (ic == 0) { return 0; }  # defensive; vec_pop shouldn't yield 0
        var conn = load64(ic + SANDHI_IDLE_OFF_CONN);
        var last = load64(ic + SANDHI_IDLE_OFF_LAST_MS);
        store64(pool + SANDHI_POOL_OFF_TOTAL_IDLE,
        load64(pool + SANDHI_POOL_OFF_TOTAL_IDLE) - 1);
        if (now - last > idle_to) {
            # Stale — peer may have closed it. Close + try next.
            if (conn != 0) { sandhi_conn_close(conn); }
        } else {
            return conn;
        }
    }
    return 0;
}

# Return a conn to the pool. If the per-route vec is at max_per_host,
# the oldest (front of vec) is evicted to make room — bounded memory.
# Caller guarantees the conn is still usable (2xx/3xx response, no
# server-sent Connection: close).
fn _sandhi_pool_put(pool, host, port, tls, conn): i64 {
    if (pool == 0 || conn == 0) {
        if (conn != 0) { sandhi_conn_close(conn); }
        return 0;
    }
    var key = _sandhi_pool_route_key(host, port, tls);
    var m = load64(pool + SANDHI_POOL_OFF_MAP);
    var v = map_get(m, key);
    if (v == 0) {
        v = vec_new();
        map_set(m, key, v);
    }
    var cap = load64(pool + SANDHI_POOL_OFF_MAX_PER_HOST);
    if (vec_len(v) >= cap) {
        # Evict oldest (index 0). vec_remove shifts the rest.
        var oldest = vec_get(v, 0);
        if (oldest != 0) {
            var oc = load64(oldest + SANDHI_IDLE_OFF_CONN);
            if (oc != 0) { sandhi_conn_close(oc); }
        }
        vec_remove(v, 0);
        store64(pool + SANDHI_POOL_OFF_TOTAL_IDLE,
        load64(pool + SANDHI_POOL_OFF_TOTAL_IDLE) - 1);
    }
    var ic = _sandhi_pool_idle_conn_new_a(_sandhi_pool_alloc(pool), conn, clock_now_ms());
    if (ic == 0) {
        # Allocator failure on the put path — drop the conn on the floor
        # rather than leaking it. Caller treats put as fire-and-forget,
        # so there's nothing to surface; the conn close mirrors the
        # max_per_host eviction path's free-it-here semantics.
        sandhi_conn_close(conn);
        return 0;
    }
    vec_push(v, ic);
    store64(pool + SANDHI_POOL_OFF_TOTAL_IDLE,
    load64(pool + SANDHI_POOL_OFF_TOTAL_IDLE) + 1);
    return 0;
}

# ================================================================
# Framing-aware response read for keep-alive
# ================================================================
#
# When the connection is going back to the pool we cannot read-to-EOF
# (the peer is keeping the socket open for the next request). Read
# incrementally until we have a complete response per its declared
# framing — Content-Length or chunked. HTTP/1.0 / no-framing
# responses always close the connection per RFC 7230 §3.3.3 ("connection
# closed by server"); the caller treats that as no-keep-alive.
#
# Returns:
#   - bytes-read on success (≥ 0)
#   - 0 - _SANDHI_EAGAIN on read deadline
#   - 0 - 1 on protocol error or buffer exhaustion
#   - 0 - 2 if the response declares Connection: close (caller must
#         not put back into the pool; we read what we can and stop)
#
# Status: this function is the keep-alive correctness boundary.
# Trailer parsing landed at 0.9.4 in `_sandhi_resp_decode_chunked`
# (response.cyr) — RFC 7230 §4.1.2 trailers are merged into the
# response's headers map, with the §4.1.2 forbidden-name list
# filtered. The pool-side completeness check below still treats
# `0\r\n\r\n` as the simple terminator without parsing the trailer
# block; that's safe because the body itself is complete at that
# point — completeness is what gates pool put-back. Actual trailer
# bytes that follow are consumed by the response parser when the
# scratch buffer is handed to `sandhi_http_response_parse`.

fn _sandhi_pool_chunked_complete(buf, body_start, blen): i64 {
    # Walk the chunked body looking for terminal 0-chunk. Returns 1
    # if a complete chunked stream is present in [body_start, blen),
    # 0 if more bytes are needed, (0 - 1) on malformed chunk-size.
    var off = body_start;
    var going = 1;
    while (going == 1) {
        if (off >= blen) { return 0; }
        # Parse chunk-size hex digits.
        var size = 0;
        var seen = 0;
        var scan = 1;
        while (scan == 1 && off < blen) {
            var c = load8(buf + off);
            if (c >= 48 && c <= 57)      { size = size * 16 + (c - 48); seen = 1; off = off + 1; }
            elif (c >= 97 && c <= 102)   { size = size * 16 + (c - 87); seen = 1; off = off + 1; }
            elif (c >= 65 && c <= 70)    { size = size * 16 + (c - 55); seen = 1; off = off + 1; }
            else { scan = 0; }
        }
        if (seen == 0 && off >= blen) { return 0; }
        if (seen == 0) { return 0 - 1; }
        # Skip chunk-extension up to CR or LF.
        while (off < blen && load8(buf + off) != 13 && load8(buf + off) != 10) {
            off = off + 1;
        }
        if (off >= blen) { return 0; }
        # Eat CRLF.
        if (load8(buf + off) == 13) {
            if (off + 1 >= blen) { return 0; }
            off = off + 2;
        } else {
            off = off + 1;
        }
        if (size == 0) {
            # Terminal — need trailing CRLF (skipping any trailers).
            # We accept 0\r\n\r\n as "done" without parsing trailers.
            if (off + 1 >= blen) { return 0; }
            return 1;
        }
        # Skip data + trailing CRLF.
        if (off + size + 2 > blen) { return 0; }
        off = off + size + 2;
    }
    return 0;
}

# Receive a framed response into a scratch buffer that the caller
# allocated (`buf`, capacity `cap`). Returns total bytes read, or
# negative sentinel per top-of-section. `deadline_ms` (0 = none)
# bounds the total recv loop. Reads in 4 KB chunks for sane progress.
fn _sandhi_http_recv_framed(conn, buf, cap, deadline_ms): i64 {
    var have = 0;
    var headers_end = 0 - 1;
    var body_start = 0;
    var content_length = 0 - 1;  # -1 = not yet parsed
    var is_chunked = 0;
    var must_close = 0;

    var step = 4096;
    var scratch_done = 0;

    var going = 1;
    while (going == 1) {
        if (have >= cap) { return 0 - 1; }
        if (deadline_ms > 0 && clock_now_ms() >= deadline_ms) {
            return 0 - _SANDHI_EAGAIN;
        }
        var room = cap - have;
        var ask = step;
        if (ask > room) { ask = room; }
        var n = sandhi_conn_recv(conn, buf + have, ask);
        if (n == 0 - _SANDHI_EAGAIN) { return 0 - _SANDHI_EAGAIN; }
        if (n < 0) { return 0 - 1; }
        if (n == 0) {
            # EOF before framing satisfied — could be HTTP/1.0 close-
            # delimited OR a broken connection. Caller decides.
            store8(buf + have, 0);
            return have;
        }
        have = have + n;
        store8(buf + have, 0);

        if (headers_end < 0) {
            headers_end = _sandhi_resp_headers_end(buf, have);
            if (headers_end >= 0) {
                body_start = headers_end + 4;
                if (load8(buf + headers_end) == 10) { body_start = headers_end + 2; }
                if (body_start > have) { body_start = have; }
                # Parse headers to figure out framing.
                var sline_end = _sandhi_resp_eol(buf, 0, headers_end);
                var hstart = sline_end;
                if (hstart < headers_end && load8(buf + hstart) == 13) { hstart = hstart + 1; }
                if (hstart < headers_end && load8(buf + hstart) == 10) { hstart = hstart + 1; }
                var hblock_len = headers_end - hstart;
                if (hblock_len < 0) { hblock_len = 0; }
                var headers = sandhi_headers_parse(buf + hstart, hblock_len);
                if (_sandhi_resp_is_chunked(headers) == 1) {
                    is_chunked = 1;
                } else {
                    var clv = sandhi_headers_get(headers, "Content-Length");
                    if (clv != 0) {
                        content_length = _sandhi_resp_parse_clen(clv);
                    }
                }
                # Detect server-sent Connection: close.
                var conn_hdr = sandhi_headers_get(headers, "Connection");
                if (conn_hdr != 0) {
                    var i = 0;
                    var matches = 1;
                    while (i < 5 && matches == 1) {
                        var ch = load8(conn_hdr + i);
                        # case-insensitive compare to "close"
                        if (ch >= 65 && ch <= 90) { ch = ch + 32; }
                        var want = load8("close" + i);
                        if (ch != want) { matches = 0; }
                        i = i + 1;
                    }
                    if (matches == 1) { must_close = 1; }
                }
                scratch_done = 1;
            }
        }

        if (scratch_done == 1) {
            if (is_chunked == 1) {
                var done = _sandhi_pool_chunked_complete(buf, body_start, have);
                if (done == 0 - 1) { return 0 - 1; }
                if (done == 1) { going = 0; }
            } elif (content_length >= 0) {
                if (have - body_start >= content_length) { going = 0; }
            } else {
                # No framing declared — HTTP/1.0 close-delimited. Read
                # until EOF (handled by the n==0 branch above).
                must_close = 1;
            }
        }
    }
    if (must_close == 1) { return 0 - 2; }
    return have;
}


# --- huffman.cyr ---

# sandhi/http/h2/huffman — HPACK Huffman code (RFC 7541 Appendix B).
#
# HPACK strings on the wire are length-prefixed with an H bit
# indicating Huffman encoding. Real h2 servers always Huffman-encode
# response headers, so HPACK without a Huffman decoder cannot decode
# real-world traffic. This module supplies that decoder.
#
# Implementation:
#   - The 257-entry code table from RFC 7541 Appendix B is embedded
#     as a single 2570-character hex blob (one string literal = one
#     fixup). Each entry occupies 10 hex chars: 8 for the code value
#     (left-padded with zeros) + 2 for the bit length.
#   - At first use, the blob is parsed and a binary decode tree is
#     built. Each tree node is 24 bytes: { left_ptr, right_ptr,
#     symbol_or_minus_1 }. Internal nodes have symbol = -1; leaves
#     hold the symbol value 0..256.
#   - Decode walks the tree bit-by-bit. On reaching a leaf, the
#     symbol is emitted (or rejected if it's the EOS, symbol 256 —
#     EOS in payload is a decoding error per §5.2).
#   - Padding handling per §5.2: after consuming all bits, if not
#     at root, the partial path MUST be ≤ 7 bits AND consist of
#     all-1 bits (the most-significant bits of the EOS code, which
#     is 0x3FFFFFFF). Anything else is malformed.
#
# Encode landed at 0.9.8 — `sandhi_hpack_huffman_encoded_len` probes
# the encoded byte count, `sandhi_hpack_huffman_encode` packs bits
# MSB-first into a caller-supplied buffer, EOS-prefix-padding the
# final byte per §5.2. The encoder is wired into hpack.cyr's string
# emit path (`_hpack_string_encode`) which now picks Huffman when
# strictly shorter than raw and sets the H bit accordingly.
#
# Decode landed as Bite 2b of 0.8.0; encode followed at 0.9.8.

# ================================================================
# Tree node layout (24 bytes)
# ================================================================
#
#   +0   left   (ptr to child node, or 0)
#   +8   right  (ptr to child node, or 0)
#   +16  symbol (i64: 0..256 on leaf, -1 on internal node)

var _SANDHI_HPACK_HUFFMAN_INTERNAL = 0 - 1;

# Decode tree nodes are part of the lazily-initialized process-wide
# table; they must outlive any per-request arena. The `_a` variant
# exists for symmetry but `_hpack_huffman_init` always pins the tree
# to `default_alloc()` — see the comment at `_hpack_huffman_init`.
fn _hpack_huffman_node_new_a(a): i64 {
    var n = alloc_via(a, 24);
    if (n == 0) { return 0; }
    store64(n + 0, 0);
    store64(n + 8, 0);
    store64(n + 16, _SANDHI_HPACK_HUFFMAN_INTERNAL);
    return n;
}

fn _hpack_huffman_node_new(): i64 {
    return _hpack_huffman_node_new_a(default_alloc());
}

# ================================================================
# Table blob — RFC 7541 Appendix B, all 257 entries, 10 hex chars each
# ================================================================
#
# Format per entry: 8 hex chars for code (left-zero-padded to fit
# the 30-bit max) + 2 hex chars for the bit length. Symbols are
# implicit by index (0..256). Total: 257 × 10 = 2570 chars.
#
# Single literal so the per-program fixup count stays low. Each line
# below covers 16 symbols × 10 chars = 160 chars; concatenated by
# the lexer into one blob.

var _hpack_huffman_blob = "";

# ================================================================
# Init — build the tree from the blob (and the symbol→code table
# for encode, 0.9.8)
# ================================================================
#
# Encode-side table: array of 257 × 16-byte entries indexed by
# symbol (0..256). Each entry holds:
#   +0  code  (i64) — the variable-bit code, right-aligned in u64
#   +8  bits  (i64) — code length in bits (5..30)
# Allocated lazily inside `_hpack_huffman_init` from the same blob
# that builds the decode tree.

var _hpack_huffman_inited = 0;
var _hpack_huffman_root = 0;
var _hpack_huffman_codes = 0;

fn _hpack_hex_digit(c): i64 {
    if (c >= 48 && c <= 57)  { return c - 48; }   # 0-9
    if (c >= 97 && c <= 102) { return c - 87; }   # a-f
    if (c >= 65 && c <= 70)  { return c - 55; }   # A-F
    return 0 - 1;
}

fn _hpack_parse_hex(blob, off, n): i64 {
    var v = 0;
    var i = 0;
    while (i < n) {
        v = v * 16 + _hpack_hex_digit(load8(blob + off + i));
        i = i + 1;
    }
    return v;
}

# Insert (code, length, sym) into the tree. Always allocates new
# internal nodes from `default_alloc()` since they belong to the
# process-wide tree (see `_hpack_huffman_init`).
fn _hpack_huffman_add(code, length, sym): i64 {
    var node = _hpack_huffman_root;
    var bit = length - 1;
    while (bit >= 0) {
        var b = (code >> bit) & 1;
        var next = 0;
        if (b == 0) { next = load64(node + 0); }
        else        { next = load64(node + 8); }
        if (next == 0) {
            next = _hpack_huffman_node_new_a(default_alloc());
            if (b == 0) { store64(node + 0, next); }
            else        { store64(node + 8, next); }
        }
        node = next;
        bit = bit - 1;
    }
    store64(node + 16, sym);
    return 0;
}

# Build the Huffman decode tree + symbol→code table. Always allocates
# from `default_alloc()` regardless of which `_a` variant called us:
# the tree + table are process-wide singletons consulted from every
# h2 conn, so an arena-reset in one request would invalidate the
# tables for every other in-flight request. There is intentionally
# no `_init_a` variant.
fn _hpack_huffman_init(): i64 {
    if (_hpack_huffman_inited == 1) { return 0; }
    var ga = default_alloc();
    _hpack_huffman_root = _hpack_huffman_node_new_a(ga);
    _hpack_huffman_codes = alloc_via(ga, 257 * 16);
    var i = 0;
    while (i < 257) {
        var off = i * 10;
        var code   = _hpack_parse_hex(_hpack_huffman_blob, off, 8);
        var length = _hpack_parse_hex(_hpack_huffman_blob, off + 8, 2);
        _hpack_huffman_add(code, length, i);
        store64(_hpack_huffman_codes + i * 16,     code);
        store64(_hpack_huffman_codes + i * 16 + 8, length);
        i = i + 1;
    }
    _hpack_huffman_inited = 1;
    return 0;
}

fn _hpack_huffman_code_of(symbol): i64 {
    return load64(_hpack_huffman_codes + symbol * 16);
}

fn _hpack_huffman_bits_of(symbol): i64 {
    return load64(_hpack_huffman_codes + symbol * 16 + 8);
}

# ================================================================
# Decode
# ================================================================
#
# Walk the tree bit-by-bit through `nbytes` of input starting at
# `buf+start`. Returns a freshly-allocated NUL-terminated cstr, or 0
# on malformed input (EOS in payload, padding > 7 bits, padding not
# all-1s, no edge for taken bit).

# Huffman-decode a wire-encoded string into a fresh cstr allocated
# from `a`. Returns 0 on malformed input or OOM. The decoded cstr is
# the only escaping allocation; arena callers can reset_via(a) once
# the cstr is consumed.
fn sandhi_hpack_huffman_decode_a(a, buf, start, nbytes): i64 {
    _hpack_huffman_init();
    if (nbytes < 0) { return 0; }
    var out_cap = nbytes * 8 + 1;     # max ratio: shortest code is 5 bits
    if (out_cap < 1) { out_cap = 1; }
    var out = alloc_via(a, out_cap);
    if (out == 0) { return 0; }
    var out_len = 0;
    var node = _hpack_huffman_root;
    var partial_bits = 0;
    var partial_all_ones = 1;
    var byte_idx = 0;
    var bit_idx = 0;
    var bits_left = nbytes * 8;
    while (bits_left > 0) {
        var byte = load8(buf + start + byte_idx);
        var b = (byte >> (7 - bit_idx)) & 1;
        var next = 0;
        if (b == 0) { next = load64(node + 0); partial_all_ones = 0; }
        else        { next = load64(node + 8); }
        if (next == 0) { return 0; }    # bit had no edge — malformed
        node = next;
        partial_bits = partial_bits + 1;
        var sym = load64(node + 16);
        if (sym != _SANDHI_HPACK_HUFFMAN_INTERNAL) {
            if (sym == 256) { return 0; }   # EOS in payload — error
            store8(out + out_len, sym);
            out_len = out_len + 1;
            node = _hpack_huffman_root;
            partial_bits = 0;
            partial_all_ones = 1;
        }
        bit_idx = bit_idx + 1;
        if (bit_idx == 8) {
            bit_idx = 0;
            byte_idx = byte_idx + 1;
        }
        bits_left = bits_left - 1;
    }
    # Padding check: if not at root, partial path must be ≤ 7 bits
    # AND all bits must be 1 (MSBs of EOS code 0x3FFFFFFF). Otherwise
    # malformed per RFC 7541 §5.2.
    if (node != _hpack_huffman_root) {
        if (partial_bits > 7) { return 0; }
        if (partial_all_ones != 1) { return 0; }
    }
    store8(out + out_len, 0);
    return out;
}

fn sandhi_hpack_huffman_decode(buf, start, nbytes): i64 {
    return sandhi_hpack_huffman_decode_a(default_alloc(), buf, start, nbytes);
}

# ================================================================
# Encode (RFC 7541 §5.2 + Appendix B) — landed 0.9.8
# ================================================================
#
# Encoded byte count for `s`: walk each byte, sum bit-lengths, divide
# by 8 rounding up. Used by `_hpack_string_encode` in hpack.cyr to
# compare against raw size and pick the shorter representation —
# Huffman only wins on text-shaped strings (cookie blobs, JSON
# payloads, ASCII URLs); short binary tokens often round-trip larger
# under Huffman, in which case we keep the raw form.

fn sandhi_hpack_huffman_encoded_len(s): i64 {
    _hpack_huffman_init();
    if (s == 0) { return 0; }
    var n = strlen(s);
    var bits = 0;
    var i = 0;
    while (i < n) {
        var ch = load8(s + i) & 0xFF;
        bits = bits + _hpack_huffman_bits_of(ch);
        i = i + 1;
    }
    return (bits + 7) >> 3;
}

# Encode `s` into `out` starting at offset `off`. Caller has already
# emitted the H=1 length prefix and sized `out` with room for at
# least `sandhi_hpack_huffman_encoded_len(s)` bytes after `off`.
# Returns the new write offset.
#
# Bit packing is MSB-first per §5.2. The accumulator holds up to
# ~37 bits at once (max code length 30 + up to 7 leftover bits) —
# fits in i64 with room to spare. After the input is exhausted, the
# final partial byte is padded with the most-significant bits of the
# EOS code (all 1s up to 7 bits), which is the canonical pad pattern
# the decoder accepts.
fn sandhi_hpack_huffman_encode(out, off, s): i64 {
    _hpack_huffman_init();
    if (s == 0) { return off; }
    var n = strlen(s);
    var p = off;
    var acc = 0;
    var nbits = 0;
    var i = 0;
    while (i < n) {
        var ch = load8(s + i) & 0xFF;
        var code = _hpack_huffman_code_of(ch);
        var clen = _hpack_huffman_bits_of(ch);
        acc = (acc << clen) | code;
        nbits = nbits + clen;
        while (nbits >= 8) {
            nbits = nbits - 8;
            store8(out + p, (acc >> nbits) & 0xFF);
            p = p + 1;
        }
        i = i + 1;
    }
    if (nbits > 0) {
        var pad_bits = 8 - nbits;
        var pad_mask = (1 << pad_bits) - 1;
        store8(out + p, ((acc << pad_bits) | pad_mask) & 0xFF);
        p = p + 1;
    }
    return p;
}


# --- hpack.cyr ---

# sandhi/http/h2/hpack — HPACK header compression (RFC 7541).
#
# HPACK is the header-compression scheme HTTP/2 uses on every HEADERS
# and CONTINUATION frame. It combines:
#   - A static table (61 well-known headers, indexed by integer)
#   - A dynamic table (per-connection, size-limited, evicted from
#     the tail when over budget)
#   - A primitive integer encoding (variable-length, prefix-bits
#     spread across the first byte)
#   - A primitive string encoding (length-prefixed, optionally
#     Huffman-encoded — see Bite 2b)
#   - 5 header-field representations: indexed, literal-incremental,
#     literal-no-index, literal-never-index, dynamic-size-update
#
# This file implements everything except Huffman encode/decode (Bite
# 2b adds decode). Huffman-encoded strings on the wire are rejected
# with `_SANDHI_HPACK_ERR_HUFFMAN`. Encoding always emits raw strings.
#
# Conformance reference: tested against RFC 7541 Appendix C examples
# C.1 (integer), C.2 (header-field representations), C.3 (request
# sequence without Huffman), and C.5 (response sequence without
# Huffman).
#
# Bite 2 of 0.8.0.

# ================================================================
# Error sentinels
# ================================================================
var _SANDHI_HPACK_ERR_TRUNCATED   = 0 - 1;
var _SANDHI_HPACK_ERR_BAD_INDEX   = 0 - 2;
var _SANDHI_HPACK_ERR_HUFFMAN     = 0 - 3;
var _SANDHI_HPACK_ERR_MALFORMED   = 0 - 4;
var _SANDHI_HPACK_ERR_INT_OVERFLOW = 0 - 5;

# Default dynamic-table size from SETTINGS_HEADER_TABLE_SIZE — RFC
# 7540 §6.5.2 default is 4096 octets.
var SANDHI_HPACK_DEFAULT_TABLE_SIZE = 4096;

# ================================================================
# Static table — RFC 7541 Appendix A
# ================================================================
#
# Stored as two parallel vecs (names + values) of cstrs. Built once
# on first use; module-scope cache means no per-call alloc cost.
# Indices in HPACK are 1-based: hpack_static_name(1) → ":authority".

var _hpack_static_inited = 0;
var _hpack_static_names  = 0;
var _hpack_static_values = 0;

fn _hpack_static_pair(n, v): i64 {
    vec_push(_hpack_static_names, n);
    vec_push(_hpack_static_values, v);
    return 0;
}

# Split into 4 chunks so each function stays under the Cyrius
# fixup-table cap. Each chunk handles ~15 entries.
fn _hpack_static_init_a(): i64 {
    _hpack_static_pair(":authority", "");
    _hpack_static_pair(":method", "GET");
    _hpack_static_pair(":method", "POST");
    _hpack_static_pair(":path", "/");
    _hpack_static_pair(":path", "/index.html");
    _hpack_static_pair(":scheme", "http");
    _hpack_static_pair(":scheme", "https");
    _hpack_static_pair(":status", "200");
    _hpack_static_pair(":status", "204");
    _hpack_static_pair(":status", "206");
    _hpack_static_pair(":status", "304");
    _hpack_static_pair(":status", "400");
    _hpack_static_pair(":status", "404");
    _hpack_static_pair(":status", "500");
    _hpack_static_pair("accept-charset", "");
    return 0;
}

fn _hpack_static_init_b(): i64 {
    _hpack_static_pair("accept-encoding", "gzip, deflate");
    _hpack_static_pair("accept-language", "");
    _hpack_static_pair("accept-ranges", "");
    _hpack_static_pair("accept", "");
    _hpack_static_pair("access-control-allow-origin", "");
    _hpack_static_pair("age", "");
    _hpack_static_pair("allow", "");
    _hpack_static_pair("authorization", "");
    _hpack_static_pair("cache-control", "");
    _hpack_static_pair("content-disposition", "");
    _hpack_static_pair("content-encoding", "");
    _hpack_static_pair("content-language", "");
    _hpack_static_pair("content-length", "");
    _hpack_static_pair("content-location", "");
    _hpack_static_pair("content-range", "");
    return 0;
}

fn _hpack_static_init_c(): i64 {
    _hpack_static_pair("content-type", "");
    _hpack_static_pair("cookie", "");
    _hpack_static_pair("date", "");
    _hpack_static_pair("etag", "");
    _hpack_static_pair("expect", "");
    _hpack_static_pair("expires", "");
    _hpack_static_pair("from", "");
    _hpack_static_pair("host", "");
    _hpack_static_pair("if-match", "");
    _hpack_static_pair("if-modified-since", "");
    _hpack_static_pair("if-none-match", "");
    _hpack_static_pair("if-range", "");
    _hpack_static_pair("if-unmodified-since", "");
    _hpack_static_pair("last-modified", "");
    _hpack_static_pair("link", "");
    return 0;
}

fn _hpack_static_init_d(): i64 {
    _hpack_static_pair("location", "");
    _hpack_static_pair("max-forwards", "");
    _hpack_static_pair("proxy-authenticate", "");
    _hpack_static_pair("proxy-authorization", "");
    _hpack_static_pair("range", "");
    _hpack_static_pair("referer", "");
    _hpack_static_pair("refresh", "");
    _hpack_static_pair("retry-after", "");
    _hpack_static_pair("server", "");
    _hpack_static_pair("set-cookie", "");
    _hpack_static_pair("strict-transport-security", "");
    _hpack_static_pair("transfer-encoding", "");
    _hpack_static_pair("user-agent", "");
    _hpack_static_pair("vary", "");
    _hpack_static_pair("via", "");
    _hpack_static_pair("www-authenticate", "");
    return 0;
}

# Build the 61-entry static table. Always allocates from
# `default_alloc()` — the parallel name + value vecs are process-wide
# singletons consulted by every HPACK encode/decode and must outlive
# any per-request arena.
fn _hpack_static_init(): i64 {
    if (_hpack_static_inited == 1) { return 0; }
    var ga = default_alloc();
    _hpack_static_names  = vec_new_a(ga);
    _hpack_static_values = vec_new_a(ga);
    _hpack_static_init_a();
    _hpack_static_init_b();
    _hpack_static_init_c();
    _hpack_static_init_d();
    _hpack_static_inited = 1;
    return 0;
}

fn sandhi_hpack_static_size(): i64 {
    _hpack_static_init();
    return vec_len(_hpack_static_names);
}

fn sandhi_hpack_static_name(idx): i64 {
    _hpack_static_init();
    if (idx < 1 || idx > vec_len(_hpack_static_names)) { return 0; }
    return vec_get(_hpack_static_names, idx - 1);
}

fn sandhi_hpack_static_value(idx): i64 {
    _hpack_static_init();
    if (idx < 1 || idx > vec_len(_hpack_static_values)) { return 0; }
    return vec_get(_hpack_static_values, idx - 1);
}

# ================================================================
# Dynamic table (RFC 7541 §4.1, §4.2)
# ================================================================
#
# Each entry has size = strlen(name) + strlen(value) + 32 (overhead).
# Total table size = sum of all entry sizes; must stay ≤ max_size.
# When adding would exceed max_size, evict from the tail (oldest)
# until it fits. If even an empty table can't hold the new entry,
# the entry is silently dropped (RFC 7541 §4.4).
#
# Indexing: dynamic entries get indices starting at 62 (after the
# 61-entry static table). Newest entry is index 62.
#
# Struct layout (32 bytes):
#   +0   names    (vec<cstr>: most-recent at vec[0])
#   +8   values   (vec<cstr>: parallel)
#   +16  cur_size (int: bytes used)
#   +24  max_size (int: cap)

enum SandhiHpackTableOff {
    SANDHI_HPACK_TBL_OFF_NAMES    = 0;
    SANDHI_HPACK_TBL_OFF_VALUES   = 8;
    SANDHI_HPACK_TBL_OFF_CUR_SIZE = 16;
    SANDHI_HPACK_TBL_OFF_MAX_SIZE = 24;
}

var SANDHI_HPACK_TABLE_STRUCT_SIZE = 32;
var SANDHI_HPACK_ENTRY_OVERHEAD    = 32;

# Build a dynamic table from `a`. The struct + parallel name/value
# vecs all flow through `a`. Note: subsequent `_table_add` calls also
# allocate (rebuilt name/value vecs on every insert at the head); use
# the `_table_add_a` variant to keep that churn in `a` too. Returns
# 0 on OOM.
fn sandhi_hpack_table_new_a(a, max_size): i64 {
    var t = alloc_via(a, SANDHI_HPACK_TABLE_STRUCT_SIZE);
    if (t == 0) { return 0; }
    store64(t + SANDHI_HPACK_TBL_OFF_NAMES, vec_new_a(a));
    store64(t + SANDHI_HPACK_TBL_OFF_VALUES, vec_new_a(a));
    store64(t + SANDHI_HPACK_TBL_OFF_CUR_SIZE, 0);
    var ms = max_size;
    if (ms <= 0) { ms = SANDHI_HPACK_DEFAULT_TABLE_SIZE; }
    store64(t + SANDHI_HPACK_TBL_OFF_MAX_SIZE, ms);
    return t;
}

fn sandhi_hpack_table_new(max_size): i64 {
    return sandhi_hpack_table_new_a(default_alloc(), max_size);
}

fn sandhi_hpack_table_count(t): i64 {
    if (t == 0) { return 0; }
    return vec_len(load64(t + SANDHI_HPACK_TBL_OFF_NAMES));
}

fn sandhi_hpack_table_size(t): i64 {
    if (t == 0) { return 0; }
    return load64(t + SANDHI_HPACK_TBL_OFF_CUR_SIZE);
}

fn sandhi_hpack_table_max_size(t): i64 {
    if (t == 0) { return SANDHI_HPACK_DEFAULT_TABLE_SIZE; }
    return load64(t + SANDHI_HPACK_TBL_OFF_MAX_SIZE);
}

fn _hpack_entry_size(name, value): i64 {
    return strlen(name) + strlen(value) + SANDHI_HPACK_ENTRY_OVERHEAD;
}

# Drop oldest entries until cur_size + need ≤ max_size. Used by
# add() before insertion and by set_max_size() on shrink.
fn _hpack_table_evict_until_fits(t, need): i64 {
    var names = load64(t + SANDHI_HPACK_TBL_OFF_NAMES);
    var values = load64(t + SANDHI_HPACK_TBL_OFF_VALUES);
    var cur = load64(t + SANDHI_HPACK_TBL_OFF_CUR_SIZE);
    var max = load64(t + SANDHI_HPACK_TBL_OFF_MAX_SIZE);
    while (cur + need > max && vec_len(names) > 0) {
        var last_idx = vec_len(names) - 1;
        var n = vec_get(names, last_idx);
        var v = vec_get(values, last_idx);
        cur = cur - _hpack_entry_size(n, v);
        vec_remove(names, last_idx);
        vec_remove(values, last_idx);
    }
    store64(t + SANDHI_HPACK_TBL_OFF_CUR_SIZE, cur);
    return 0;
}

# Insert (name, value) at the head (newest), allocating the rebuilt
# parallel vecs from `a`. Evicts as needed. If the entry is larger
# than max_size, the table is emptied and the entry dropped
# (RFC 7541 §4.4). Returns 0 on success — silently ignores OOM on
# the rebuilt vecs since dropping the insert is the same observable
# behavior as the §4.4 over-budget drop.
fn sandhi_hpack_table_add_a(a, t, name, value): i64 {
    if (t == 0) { return 0; }
    var sz = _hpack_entry_size(name, value);
    var max = load64(t + SANDHI_HPACK_TBL_OFF_MAX_SIZE);
    if (sz > max) {
        _hpack_table_evict_until_fits(t, max + 1);
        return 0;
    }
    _hpack_table_evict_until_fits(t, sz);
    var names = load64(t + SANDHI_HPACK_TBL_OFF_NAMES);
    var values = load64(t + SANDHI_HPACK_TBL_OFF_VALUES);
    var new_names = vec_new_a(a);
    var new_values = vec_new_a(a);
    if (new_names == 0 || new_values == 0) { return 0; }
    vec_push_a(a, new_names, name);
    vec_push_a(a, new_values, value);
    var i = 0;
    var n = vec_len(names);
    while (i < n) {
        vec_push_a(a, new_names, vec_get(names, i));
        vec_push_a(a, new_values, vec_get(values, i));
        i = i + 1;
    }
    store64(t + SANDHI_HPACK_TBL_OFF_NAMES, new_names);
    store64(t + SANDHI_HPACK_TBL_OFF_VALUES, new_values);
    store64(t + SANDHI_HPACK_TBL_OFF_CUR_SIZE,
    load64(t + SANDHI_HPACK_TBL_OFF_CUR_SIZE) + sz);
    return 0;
}

fn sandhi_hpack_table_add(t, name, value): i64 {
    return sandhi_hpack_table_add_a(default_alloc(), t, name, value);
}

# Update max_size; shrink immediately if needed (peer sent a
# Dynamic-Table-Size-Update or a SETTINGS_HEADER_TABLE_SIZE change).
fn sandhi_hpack_table_set_max_size(t, max_size): i64 {
    if (t == 0) { return 0; }
    store64(t + SANDHI_HPACK_TBL_OFF_MAX_SIZE, max_size);
    _hpack_table_evict_until_fits(t, 0);
    return 0;
}

# Index lookup. Static = 1..61; dynamic = 62..(61+count).
# Returns (name, value) cstrs via out cells; -1 on bad index.
fn sandhi_hpack_lookup(t, idx, name_out, value_out): i64 {
    var static_count = sandhi_hpack_static_size();
    if (idx < 1) { return _SANDHI_HPACK_ERR_BAD_INDEX; }
    if (idx <= static_count) {
        store64(name_out,  sandhi_hpack_static_name(idx));
        store64(value_out, sandhi_hpack_static_value(idx));
        return 0;
    }
    var dyn_idx = idx - static_count - 1;  # 62 → 0
    if (t == 0) { return _SANDHI_HPACK_ERR_BAD_INDEX; }
    var names = load64(t + SANDHI_HPACK_TBL_OFF_NAMES);
    var values = load64(t + SANDHI_HPACK_TBL_OFF_VALUES);
    if (dyn_idx >= vec_len(names)) { return _SANDHI_HPACK_ERR_BAD_INDEX; }
    store64(name_out,  vec_get(names, dyn_idx));
    store64(value_out, vec_get(values, dyn_idx));
    return 0;
}

# ================================================================
# Integer encoding (RFC 7541 §5.1)
# ================================================================
#
# encode: writes prefix byte + continuation bytes into `out` starting
# at offset `off`. Returns new offset. `prefix_bits` is N (4-7);
# `prefix_high` is the high (8-N) bits already set in out[off] —
# typically the representation type marker.
#
# decode: reads prefix bits from buf[off] (already extracted by
# caller) plus continuation bytes. Returns the decoded int via
# `value_out`, updates `off_cell` to next byte; returns 0 on success
# or a negative error sentinel.

fn _hpack_int_encode(out, off, prefix_high, prefix_bits, value): i64 {
    var max_prefix = (1 << prefix_bits) - 1;
    if (value < max_prefix) {
        store8(out + off, prefix_high | value);
        return off + 1;
    }
    store8(out + off, prefix_high | max_prefix);
    var p = off + 1;
    var v = value - max_prefix;
    while (v >= 128) {
        store8(out + p, (v & 0x7F) | 0x80);
        p = p + 1;
        v = v >> 7;
    }
    store8(out + p, v);
    return p + 1;
}

fn _hpack_int_decode(buf, blen, off_cell, prefix_bits, value_out): i64 {
    var off = load64(off_cell);
    if (off >= blen) { return _SANDHI_HPACK_ERR_TRUNCATED; }
    var max_prefix = (1 << prefix_bits) - 1;
    var first = load8(buf + off) & max_prefix;
    off = off + 1;
    if (first < max_prefix) {
        store64(value_out, first);
        store64(off_cell, off);
        return 0;
    }
    var i = first;
    var m = 0;
    var going = 1;
    while (going == 1) {
        if (off >= blen) { return _SANDHI_HPACK_ERR_TRUNCATED; }
        if (m > 56) { return _SANDHI_HPACK_ERR_INT_OVERFLOW; }
        var b = load8(buf + off);
        off = off + 1;
        i = i + ((b & 0x7F) << m);
        if ((b & 0x80) == 0) { going = 0; }
        else { m = m + 7; }
    }
    store64(value_out, i);
    store64(off_cell, off);
    return 0;
}

# ================================================================
# String encoding (RFC 7541 §5.2)
# ================================================================
#
# Encode: 7-bit length prefix with the H bit (high bit of the prefix
# byte) set per representation choice. Since 0.9.8, the encoder
# probes the Huffman size first and picks Huffman when strictly
# smaller than raw. `huffman.cyr`'s `sandhi_hpack_huffman_encoded_len`
# answers the probe; `sandhi_hpack_huffman_encode` writes the bytes
# (MSB-first packing, EOS-prefix padding on the final byte).
#
# Wire-size impact: ~25-30% smaller for ASCII text headers, matching
# the canonical RFC 7541 Appendix C.4 examples. Binary / short tokens
# often round-trip larger under Huffman — we keep raw for those.

fn _hpack_string_encode(out, off, s): i64 {
    var raw_len = strlen(s);
    var huff_len = sandhi_hpack_huffman_encoded_len(s);
    if (huff_len < raw_len) {
        var ph = _hpack_int_encode(out, off, 0x80, 7, huff_len);  # H=1
        return sandhi_hpack_huffman_encode(out, ph, s);
    }
    var p = _hpack_int_encode(out, off, 0, 7, raw_len);  # H=0
    var i = 0;
    while (i < raw_len) {
        store8(out + p + i, load8(s + i));
        i = i + 1;
    }
    return p + raw_len;
}

# Decode a string into `a`. Both the transient length cell and the
# returned cstr (or Huffman-decoded cstr) live in `a`; arena reset
# after the caller has copied/consumed the string reclaims everything.
fn _hpack_string_decode_a(a, buf, blen, off_cell, out_cell): i64 {
    var off = load64(off_cell);
    if (off >= blen) { return _SANDHI_HPACK_ERR_TRUNCATED; }
    var huffman = (load8(buf + off) & 0x80) >> 7;
    var len_cell = alloc_via(a, 8);
    if (len_cell == 0) { return _SANDHI_HPACK_ERR_TRUNCATED; }
    store64(len_cell, 0);
    var ir = _hpack_int_decode(buf, blen, off_cell, 7, len_cell);
    if (ir < 0) { return ir; }
    var slen = load64(len_cell);
    var soff = load64(off_cell);
    if (soff + slen > blen) { return _SANDHI_HPACK_ERR_TRUNCATED; }
    if (huffman == 1) {
        var dec = sandhi_hpack_huffman_decode_a(a, buf, soff, slen);
        if (dec == 0) {
            store64(off_cell, soff + slen);
            return _SANDHI_HPACK_ERR_HUFFMAN;
        }
        store64(off_cell, soff + slen);
        store64(out_cell, dec);
        return 0;
    }
    var s = alloc_via(a, slen + 1);
    if (s == 0) { return _SANDHI_HPACK_ERR_TRUNCATED; }
    var i = 0;
    while (i < slen) {
        store8(s + i, load8(buf + soff + i));
        i = i + 1;
    }
    store8(s + slen, 0);
    store64(off_cell, soff + slen);
    store64(out_cell, s);
    return 0;
}

fn _hpack_string_decode(buf, blen, off_cell, out_cell): i64 {
    return _hpack_string_decode_a(default_alloc(), buf, blen, off_cell, out_cell);
}

# ================================================================
# Header field encoding (RFC 7541 §6)
# ================================================================
#
# All encoders write into a caller-allocated `out` buffer starting at
# offset `off` and return the new offset. Caller is responsible for
# sizing `out` adequately (worst case: ~5 bytes overhead per header
# + name + value bytes + Huffman-disable so always raw).

# §6.1 Indexed Header Field — single byte 1xxxxxxx (7-bit prefix).
fn sandhi_hpack_encode_indexed(out, off, idx): i64 {
    return _hpack_int_encode(out, off, 0x80, 7, idx);
}

# §6.2.1 Literal with Incremental Indexing.
# 01xxxxxx (6-bit prefix on name index; 0 = inline name).
# Caller passes name_idx=0 + name string for inline, or name_idx>0 for
# indexed-name variant.
fn sandhi_hpack_encode_literal_indexed(t, out, off, name, value): i64 {
    var p = _hpack_int_encode(out, off, 0x40, 6, 0);  # name_idx=0 (inline)
    p = _hpack_string_encode(out, p, name);
    p = _hpack_string_encode(out, p, value);
    if (t != 0) { sandhi_hpack_table_add(t, name, value); }
    return p;
}

fn sandhi_hpack_encode_literal_indexed_name(t, out, off, name_idx, name, value): i64 {
    var p = _hpack_int_encode(out, off, 0x40, 6, name_idx);
    p = _hpack_string_encode(out, p, value);
    if (t != 0) { sandhi_hpack_table_add(t, name, value); }
    return p;
}

# §6.2.2 Literal without Indexing — 0000xxxx (4-bit prefix).
fn sandhi_hpack_encode_literal_no_index(out, off, name, value): i64 {
    var p = _hpack_int_encode(out, off, 0x00, 4, 0);
    p = _hpack_string_encode(out, p, name);
    p = _hpack_string_encode(out, p, value);
    return p;
}

# §6.2.3 Literal Never Indexed — 0001xxxx (4-bit prefix).
fn sandhi_hpack_encode_literal_never(out, off, name, value): i64 {
    var p = _hpack_int_encode(out, off, 0x10, 4, 0);
    p = _hpack_string_encode(out, p, name);
    p = _hpack_string_encode(out, p, value);
    return p;
}

# §6.3 Dynamic Table Size Update — 001xxxxx (5-bit prefix).
fn sandhi_hpack_encode_table_size_update(out, off, new_max_size): i64 {
    return _hpack_int_encode(out, off, 0x20, 5, new_max_size);
}

# ================================================================
# Header field decoding (RFC 7541 §6)
# ================================================================
#
# Decode one header field starting at off_cell. On success, writes the
# decoded name + value cstrs (caller-owned) to name_out / value_out
# and updates the dynamic table when the representation requires.
# Returns 0 on success or a negative error sentinel.
#
# A "dynamic-table-size-update" representation has no associated
# header — sandhi_hpack_decode_field returns a special sentinel
# `_SANDHI_HPACK_TBL_UPDATE` (positive non-zero) and writes the new
# max size to `value_out` (re-purposed; name_out is set to 0).

var _SANDHI_HPACK_TBL_UPDATE = 1;  # not zero so caller can distinguish

# Decode one HPACK header field into `a`. Every transient cell + the
# decoded name + value cstrs live in `a`. The dynamic-table side-effect
# (incremental-indexing inserts via `_table_add_a`) also routes through
# `a` so per-request callers can wire up an arena that owns both the
# decoded headers AND the dynamic-table churn from this hop.
fn sandhi_hpack_decode_field_a(a, t, buf, blen, off_cell, name_out, value_out): i64 {
    var off = load64(off_cell);
    if (off >= blen) { return _SANDHI_HPACK_ERR_TRUNCATED; }
    var first = load8(buf + off);

    if ((first & 0x80) != 0) {
        # 1xxxxxxx — Indexed Header Field.
        var idx_cell = alloc_via(a, 8);
        if (idx_cell == 0) { return _SANDHI_HPACK_ERR_TRUNCATED; }
        var ir = _hpack_int_decode(buf, blen, off_cell, 7, idx_cell);
        if (ir < 0) { return ir; }
        var idx = load64(idx_cell);
        if (idx == 0) { return _SANDHI_HPACK_ERR_MALFORMED; }
        return sandhi_hpack_lookup(t, idx, name_out, value_out);
    }

    if ((first & 0xC0) == 0x40) {
        # 01xxxxxx — Literal with Incremental Indexing.
        var idx_cell = alloc_via(a, 8);
        if (idx_cell == 0) { return _SANDHI_HPACK_ERR_TRUNCATED; }
        var ir = _hpack_int_decode(buf, blen, off_cell, 6, idx_cell);
        if (ir < 0) { return ir; }
        var name_idx = load64(idx_cell);
        var name = 0;
        var name_held = alloc_via(a, 8);
        if (name_held == 0) { return _SANDHI_HPACK_ERR_TRUNCATED; }
        store64(name_held, 0);
        if (name_idx == 0) {
            var sr = _hpack_string_decode_a(a, buf, blen, off_cell, name_held);
            if (sr < 0) { return sr; }
            name = load64(name_held);
        } else {
            var v_unused = alloc_via(a, 8);
            if (v_unused == 0) { return _SANDHI_HPACK_ERR_TRUNCATED; }
            var lr = sandhi_hpack_lookup(t, name_idx, name_held, v_unused);
            if (lr < 0) { return lr; }
            name = load64(name_held);
        }
        var val_cell = alloc_via(a, 8);
        if (val_cell == 0) { return _SANDHI_HPACK_ERR_TRUNCATED; }
        var sr2 = _hpack_string_decode_a(a, buf, blen, off_cell, val_cell);
        if (sr2 < 0) { return sr2; }
        var value = load64(val_cell);
        store64(name_out, name);
        store64(value_out, value);
        sandhi_hpack_table_add_a(a, t, name, value);
        return 0;
    }

    if ((first & 0xE0) == 0x20) {
        # 001xxxxx — Dynamic Table Size Update.
        var sz_cell = alloc_via(a, 8);
        if (sz_cell == 0) { return _SANDHI_HPACK_ERR_TRUNCATED; }
        var ir = _hpack_int_decode(buf, blen, off_cell, 5, sz_cell);
        if (ir < 0) { return ir; }
        sandhi_hpack_table_set_max_size(t, load64(sz_cell));
        store64(name_out, 0);
        store64(value_out, load64(sz_cell));
        return _SANDHI_HPACK_TBL_UPDATE;
    }

    # 0000xxxx (no-index) or 0001xxxx (never-index) — 4-bit prefix.
    var idx_cell = alloc_via(a, 8);
    if (idx_cell == 0) { return _SANDHI_HPACK_ERR_TRUNCATED; }
    var ir = _hpack_int_decode(buf, blen, off_cell, 4, idx_cell);
    if (ir < 0) { return ir; }
    var name_idx = load64(idx_cell);
    var name = 0;
    var name_held = alloc_via(a, 8);
    if (name_held == 0) { return _SANDHI_HPACK_ERR_TRUNCATED; }
    store64(name_held, 0);
    if (name_idx == 0) {
        var sr = _hpack_string_decode_a(a, buf, blen, off_cell, name_held);
        if (sr < 0) { return sr; }
        name = load64(name_held);
    } else {
        var v_unused = alloc_via(a, 8);
        if (v_unused == 0) { return _SANDHI_HPACK_ERR_TRUNCATED; }
        var lr = sandhi_hpack_lookup(t, name_idx, name_held, v_unused);
        if (lr < 0) { return lr; }
        name = load64(name_held);
    }
    var val_cell = alloc_via(a, 8);
    if (val_cell == 0) { return _SANDHI_HPACK_ERR_TRUNCATED; }
    var sr2 = _hpack_string_decode_a(a, buf, blen, off_cell, val_cell);
    if (sr2 < 0) { return sr2; }
    store64(name_out, name);
    store64(value_out, load64(val_cell));
    return 0;
}

fn sandhi_hpack_decode_field(t, buf, blen, off_cell, name_out, value_out): i64 {
    return sandhi_hpack_decode_field_a(default_alloc(), t, buf, blen, off_cell, name_out, value_out);
}


# --- frame.cyr ---

# sandhi/http/h2/frame — HTTP/2 frame layer (RFC 7540 §4.1, §6).
#
# Every h2 message is a frame. Frames have a fixed 9-byte header
# followed by a type-specific payload. This module parses + builds
# frame headers, plus the payloads of each frame type sandhi cares
# about. HEADERS payload is opaque here (the HPACK module handles
# it; bite 5 wires them together).
#
# Frame header (9 bytes, RFC 7540 §4.1):
#   +0  length      (24 bits big-endian, payload size)
#   +3  type        (8 bits)
#   +4  flags       (8 bits)
#   +5  stream_id   (31 bits BE; high bit reserved, MUST be 0)
#
# Default max payload size = 16384 (SETTINGS_MAX_FRAME_SIZE default).
# Peer can negotiate higher via SETTINGS, capped at 16777215.
#
# Bite 3 of 0.8.0.

# ================================================================
# Constants
# ================================================================

# Frame types (§11.2)
enum SandhiH2FrameType {
    SANDHI_H2_FRAME_DATA          = 0x0;
    SANDHI_H2_FRAME_HEADERS       = 0x1;
    SANDHI_H2_FRAME_PRIORITY      = 0x2;
    SANDHI_H2_FRAME_RST_STREAM    = 0x3;
    SANDHI_H2_FRAME_SETTINGS      = 0x4;
    SANDHI_H2_FRAME_PUSH_PROMISE  = 0x5;
    SANDHI_H2_FRAME_PING          = 0x6;
    SANDHI_H2_FRAME_GOAWAY        = 0x7;
    SANDHI_H2_FRAME_WINDOW_UPDATE = 0x8;
    SANDHI_H2_FRAME_CONTINUATION  = 0x9;
}

# Frame flags (§6 — interpretation depends on frame type)
enum SandhiH2Flag {
    SANDHI_H2_FLAG_END_STREAM   = 0x1;   # DATA, HEADERS
    SANDHI_H2_FLAG_ACK          = 0x1;   # SETTINGS, PING (overlap is intentional per spec)
    SANDHI_H2_FLAG_END_HEADERS  = 0x4;   # HEADERS, CONTINUATION, PUSH_PROMISE
    SANDHI_H2_FLAG_PADDED       = 0x8;   # DATA, HEADERS, PUSH_PROMISE
    SANDHI_H2_FLAG_PRIORITY     = 0x20;  # HEADERS
}

# Error codes (§7)
enum SandhiH2Err {
    SANDHI_H2_ERR_NO_ERROR            = 0x0;
    SANDHI_H2_ERR_PROTOCOL_ERROR      = 0x1;
    SANDHI_H2_ERR_INTERNAL_ERROR      = 0x2;
    SANDHI_H2_ERR_FLOW_CONTROL_ERROR  = 0x3;
    SANDHI_H2_ERR_SETTINGS_TIMEOUT    = 0x4;
    SANDHI_H2_ERR_STREAM_CLOSED       = 0x5;
    SANDHI_H2_ERR_FRAME_SIZE_ERROR    = 0x6;
    SANDHI_H2_ERR_REFUSED_STREAM      = 0x7;
    SANDHI_H2_ERR_CANCEL              = 0x8;
    SANDHI_H2_ERR_COMPRESSION_ERROR   = 0x9;
    SANDHI_H2_ERR_CONNECT_ERROR       = 0xA;
    SANDHI_H2_ERR_ENHANCE_YOUR_CALM   = 0xB;
    SANDHI_H2_ERR_INADEQUATE_SECURITY = 0xC;
    SANDHI_H2_ERR_HTTP_1_1_REQUIRED   = 0xD;
}

# SETTINGS parameter identifiers (§6.5.2)
enum SandhiH2Setting {
    SANDHI_H2_SETTINGS_HEADER_TABLE_SIZE      = 0x1;
    SANDHI_H2_SETTINGS_ENABLE_PUSH            = 0x2;
    SANDHI_H2_SETTINGS_MAX_CONCURRENT_STREAMS = 0x3;
    SANDHI_H2_SETTINGS_INITIAL_WINDOW_SIZE    = 0x4;
    SANDHI_H2_SETTINGS_MAX_FRAME_SIZE         = 0x5;
    SANDHI_H2_SETTINGS_MAX_HEADER_LIST_SIZE   = 0x6;
}

var SANDHI_H2_FRAME_HEADER_SIZE = 9;
var SANDHI_H2_DEFAULT_MAX_FRAME = 16384;
var SANDHI_H2_MAX_FRAME_SIZE    = 16777215;  # 2^24 - 1

# Internal-error sentinels (negative)
var _SANDHI_H2_ERR_TRUNCATED  = 0 - 1;
var _SANDHI_H2_ERR_BAD_LENGTH = 0 - 2;
var _SANDHI_H2_ERR_BAD_STREAM = 0 - 3;
var _SANDHI_H2_ERR_BAD_TYPE   = 0 - 4;
var _SANDHI_H2_ERR_MALFORMED  = 0 - 5;

# ================================================================
# Frame header struct (32 bytes — 8-byte stride per field)
# ================================================================
#
#   +0   length      (int)
#   +8   type        (int)
#   +16  flags       (int)
#   +24  stream_id   (int)

enum SandhiH2HdrOff {
    SANDHI_H2_HDR_OFF_LENGTH    = 0;
    SANDHI_H2_HDR_OFF_TYPE      = 8;
    SANDHI_H2_HDR_OFF_FLAGS     = 16;
    SANDHI_H2_HDR_OFF_STREAM_ID = 24;
}

var SANDHI_H2_HDR_STRUCT_SIZE = 32;

# Allocate an h2 frame-header struct from `a`. Returns 0 on OOM.
fn sandhi_h2_hdr_new_a(a, length, type, flags, stream_id): i64 {
    var h = alloc_via(a, SANDHI_H2_HDR_STRUCT_SIZE);
    if (h == 0) { return 0; }
    store64(h + SANDHI_H2_HDR_OFF_LENGTH, length);
    store64(h + SANDHI_H2_HDR_OFF_TYPE, type);
    store64(h + SANDHI_H2_HDR_OFF_FLAGS, flags);
    store64(h + SANDHI_H2_HDR_OFF_STREAM_ID, stream_id);
    return h;
}

fn sandhi_h2_hdr_new(length, type, flags, stream_id): i64 {
    return sandhi_h2_hdr_new_a(default_alloc(), length, type, flags, stream_id);
}

fn sandhi_h2_hdr_length(h): i64 { return load64(h + SANDHI_H2_HDR_OFF_LENGTH); }
fn sandhi_h2_hdr_type(h): i64 { return load64(h + SANDHI_H2_HDR_OFF_TYPE); }
fn sandhi_h2_hdr_flags(h): i64 { return load64(h + SANDHI_H2_HDR_OFF_FLAGS); }
fn sandhi_h2_hdr_stream_id(h): i64 { return load64(h + SANDHI_H2_HDR_OFF_STREAM_ID); }

# Big-endian write helpers — h2 wire is BE end-to-end (§4.1).
fn _h2_write_u24(out, off, v): i64 {
    store8(out + off + 0, (v >> 16) & 0xFF);
    store8(out + off + 1, (v >>  8) & 0xFF);
    store8(out + off + 2,  v        & 0xFF);
    return 0;
}

fn _h2_write_u32(out, off, v): i64 {
    store8(out + off + 0, (v >> 24) & 0xFF);
    store8(out + off + 1, (v >> 16) & 0xFF);
    store8(out + off + 2, (v >>  8) & 0xFF);
    store8(out + off + 3,  v        & 0xFF);
    return 0;
}

fn _h2_read_u24(buf, off): i64 {
    return (load8(buf + off + 0) << 16)
    | (load8(buf + off + 1) <<  8)
    |  load8(buf + off + 2);
}

fn _h2_read_u32(buf, off): i64 {
    return (load8(buf + off + 0) << 24)
    | (load8(buf + off + 1) << 16)
    | (load8(buf + off + 2) <<  8)
    |  load8(buf + off + 3);
}

# Build a frame header into out[off..off+9]. Returns off+9 or
# negative sentinel on bad input (length too large, stream_id high
# bit set).
fn sandhi_h2_hdr_encode(out, off, length, type, flags, stream_id): i64 {
    if (length < 0 || length > SANDHI_H2_MAX_FRAME_SIZE) { return _SANDHI_H2_ERR_BAD_LENGTH; }
    if ((stream_id >> 31) != 0) { return _SANDHI_H2_ERR_BAD_STREAM; }
    _h2_write_u24(out, off + 0, length);
    store8(out + off + 3, type & 0xFF);
    store8(out + off + 4, flags & 0xFF);
    # Stream ID: explicitly clear reserved high bit on write per §4.1.
    _h2_write_u32(out, off + 5, stream_id & 0x7FFFFFFF);
    return off + SANDHI_H2_FRAME_HEADER_SIZE;
}

# Parse a frame header starting at buf[off], allocating the result
# from `a`. Caller must have ≥ 9 bytes available. Returns a hdr
# struct (caller owns) or 0 on truncation / over-length / OOM.
fn sandhi_h2_hdr_decode_a(a, buf, blen, off): i64 {
    if (off + SANDHI_H2_FRAME_HEADER_SIZE > blen) { return 0; }
    var length = _h2_read_u24(buf, off + 0);
    var type   = load8(buf + off + 3);
    var flags  = load8(buf + off + 4);
    # Read stream_id, mask off reserved high bit per §4.1.
    var sid_raw = _h2_read_u32(buf, off + 5);
    var stream_id = sid_raw & 0x7FFFFFFF;
    return sandhi_h2_hdr_new_a(a, length, type, flags, stream_id);
}

fn sandhi_h2_hdr_decode(buf, blen, off): i64 {
    return sandhi_h2_hdr_decode_a(default_alloc(), buf, blen, off);
}

# ================================================================
# SETTINGS frame (§6.5)
# ================================================================
#
# Payload is a sequence of (id: u16, value: u32) pairs. The ACK flag
# variant has no payload.

# Encode a single SETTINGS pair into out[off..off+6]. Returns off+6.
fn sandhi_h2_settings_pair_encode(out, off, id, value): i64 {
    store8(out + off + 0, (id >> 8) & 0xFF);
    store8(out + off + 1, id & 0xFF);
    _h2_write_u32(out, off + 2, value);
    return off + 6;
}

fn sandhi_h2_settings_pair_decode(buf, blen, off, id_out, value_out): i64 {
    if (off + 6 > blen) { return _SANDHI_H2_ERR_TRUNCATED; }
    var id = (load8(buf + off + 0) << 8) | load8(buf + off + 1);
    var v  = _h2_read_u32(buf, off + 2);
    store64(id_out, id);
    store64(value_out, v);
    return off + 6;
}

# ================================================================
# PING frame (§6.7)
# ================================================================
#
# 8 octets of opaque data. ACK flag echoes data back. Stream id MUST
# be 0 (connection-level frame).

fn sandhi_h2_ping_encode(out, off, opaque8): i64 {
    var i = 0;
    while (i < 8) {
        store8(out + off + i, load8(opaque8 + i));
        i = i + 1;
    }
    return off + 8;
}

# ================================================================
# WINDOW_UPDATE frame (§6.9)
# ================================================================
#
# Payload: 4 octets, high bit reserved + 31-bit window-size-increment.
# Increment MUST be > 0.

fn sandhi_h2_window_update_encode(out, off, increment): i64 {
    if (increment <= 0 || (increment >> 31) != 0) {
        return _SANDHI_H2_ERR_MALFORMED;
    }
    _h2_write_u32(out, off, increment & 0x7FFFFFFF);
    return off + 4;
}

fn sandhi_h2_window_update_decode(buf, blen, off): i64 {
    if (off + 4 > blen) { return _SANDHI_H2_ERR_TRUNCATED; }
    var v = _h2_read_u32(buf, off);
    return v & 0x7FFFFFFF;
}

# ================================================================
# RST_STREAM frame (§6.4)
# ================================================================
#
# Payload: 4-octet error code.

fn sandhi_h2_rst_stream_encode(out, off, error_code): i64 {
    _h2_write_u32(out, off, error_code);
    return off + 4;
}

fn sandhi_h2_rst_stream_decode(buf, blen, off): i64 {
    if (off + 4 > blen) { return _SANDHI_H2_ERR_TRUNCATED; }
    return _h2_read_u32(buf, off);
}

# ================================================================
# GOAWAY frame (§6.8)
# ================================================================
#
# Payload: last_stream_id (4) + error_code (4) + optional debug data.
# Reserved bit on last_stream_id must be 0.

fn sandhi_h2_goaway_encode(out, off, last_stream_id, error_code, debug, debug_len): i64 {
    if ((last_stream_id >> 31) != 0) { return _SANDHI_H2_ERR_BAD_STREAM; }
    _h2_write_u32(out, off + 0, last_stream_id & 0x7FFFFFFF);
    _h2_write_u32(out, off + 4, error_code);
    if (debug_len > 0 && debug != 0) {
        var i = 0;
        while (i < debug_len) {
            store8(out + off + 8 + i, load8(debug + i));
            i = i + 1;
        }
    }
    return off + 8 + debug_len;
}

fn sandhi_h2_goaway_decode(buf, blen, off, last_stream_out, error_out): i64 {
    if (off + 8 > blen) { return _SANDHI_H2_ERR_TRUNCATED; }
    var sid = _h2_read_u32(buf, off + 0) & 0x7FFFFFFF;
    var ec  = _h2_read_u32(buf, off + 4);
    store64(last_stream_out, sid);
    store64(error_out, ec);
    return 0;
}


# --- conn.cyr ---

# sandhi/http/h2/conn — HTTP/2 connection lifecycle scaffolding.
#
# This module owns the per-h2-connection state and the frame-level
# send/recv plumbing. It does NOT yet originate requests (Bite 5b)
# or interpret response stream lifecycle (Bite 5c) — those layer on
# top.
#
# Layering recap:
#   sandhi_conn        — TCP / TLS bytes (src/http/conn.cyr)
#   sandhi_h2_conn     — h2 framing + handshake state (this file)
#   sandhi_h2_stream   — per-request lifecycle (Bite 5c)
#
# h2 connection struct (80 bytes):
#   +0    conn                  (sandhi_conn ptr — owned by us once attached)
#   +8    hpack_enc_table       (sandhi_hpack_table — outbound dynamic)
#   +16   hpack_dec_table       (sandhi_hpack_table — inbound dynamic)
#   +24   next_stream_id        (int — odd, starts at 1)
#   +32   our_settings_acked    (int — 0 until peer ACKs ours)
#   +40   peer_settings_seen    (int — 0 until we receive theirs)
#   +48   peer_max_frame_size   (int — peer's MAX_FRAME_SIZE, default 16384)
#   +56   peer_max_streams      (int — peer's MAX_CONCURRENT_STREAMS, 0 = unlimited)
#   +64   peer_init_window      (int — peer's INITIAL_WINDOW_SIZE, default 65535)
#   +72   goaway_received       (int — 1 if peer sent GOAWAY)
#
# Bite 5a of 0.8.0.

enum SandhiH2ConnOff {
    SANDHI_H2_CONN_OFF_CONN          = 0;
    SANDHI_H2_CONN_OFF_HPACK_ENC     = 8;
    SANDHI_H2_CONN_OFF_HPACK_DEC     = 16;
    SANDHI_H2_CONN_OFF_NEXT_SID      = 24;
    SANDHI_H2_CONN_OFF_OUR_ACKED     = 32;
    SANDHI_H2_CONN_OFF_PEER_SEEN     = 40;
    SANDHI_H2_CONN_OFF_PEER_FRAME    = 48;
    SANDHI_H2_CONN_OFF_PEER_STREAMS  = 56;
    SANDHI_H2_CONN_OFF_PEER_WINDOW   = 64;
    SANDHI_H2_CONN_OFF_GOAWAY        = 72;
}

var SANDHI_H2_CONN_STRUCT_SIZE = 80;

# Spec defaults — RFC 7540 §6.5.2.
var _SANDHI_H2_DEFAULT_PEER_FRAME   = 16384;
var _SANDHI_H2_DEFAULT_PEER_STREAMS = 0;       # 0 = unlimited
var _SANDHI_H2_DEFAULT_PEER_WINDOW  = 65535;

# Connection preface — first 24 octets the client MUST send. RFC 7540
# §3.5. Spelled out so it stays a single literal.
var _SANDHI_H2_PREFACE = "PRI * HTTP/2.0\r\n\r\nSM\r\n\r\n";

# ================================================================
# Construction / accessors
# ================================================================

# Attach an h2 conn to an already-connected sandhi_conn. Caller has
# done TCP+TLS+ALPN already; we just wrap and initialize state.
# Allocate an h2 conn struct + its enc/dec hpack tables from `a`.
# The struct is long-lived (typically pool-cached) — pass the pool's
# stored allocator (or default_alloc for a one-shot conn). All
# subsequent table_add operations on the enc/dec tables route through
# `a` via sandhi_hpack_table_add_a (Batch 2) so the dynamic-table
# growth stays in the same allocator. Returns 0 on OOM.
fn sandhi_h2_conn_new_a(a, sandhi_conn_ptr): i64 {
    var c = alloc_via(a, SANDHI_H2_CONN_STRUCT_SIZE);
    if (c == 0) { return 0; }
    store64(c + SANDHI_H2_CONN_OFF_CONN, sandhi_conn_ptr);
    store64(c + SANDHI_H2_CONN_OFF_HPACK_ENC, sandhi_hpack_table_new_a(a, 0));
    store64(c + SANDHI_H2_CONN_OFF_HPACK_DEC, sandhi_hpack_table_new_a(a, 0));
    store64(c + SANDHI_H2_CONN_OFF_NEXT_SID, 1);
    store64(c + SANDHI_H2_CONN_OFF_OUR_ACKED, 0);
    store64(c + SANDHI_H2_CONN_OFF_PEER_SEEN, 0);
    store64(c + SANDHI_H2_CONN_OFF_PEER_FRAME,   _SANDHI_H2_DEFAULT_PEER_FRAME);
    store64(c + SANDHI_H2_CONN_OFF_PEER_STREAMS, _SANDHI_H2_DEFAULT_PEER_STREAMS);
    store64(c + SANDHI_H2_CONN_OFF_PEER_WINDOW,  _SANDHI_H2_DEFAULT_PEER_WINDOW);
    store64(c + SANDHI_H2_CONN_OFF_GOAWAY, 0);
    return c;
}

fn sandhi_h2_conn_new(sandhi_conn_ptr): i64 {
    return sandhi_h2_conn_new_a(default_alloc(), sandhi_conn_ptr);
}

fn sandhi_h2_conn_underlying(c): i64 { return load64(c + SANDHI_H2_CONN_OFF_CONN); }
fn sandhi_h2_conn_enc_table(c): i64 { return load64(c + SANDHI_H2_CONN_OFF_HPACK_ENC); }
fn sandhi_h2_conn_dec_table(c): i64 { return load64(c + SANDHI_H2_CONN_OFF_HPACK_DEC); }
fn sandhi_h2_conn_peer_max_frame(c): i64 { return load64(c + SANDHI_H2_CONN_OFF_PEER_FRAME); }
fn sandhi_h2_conn_peer_max_streams(c): i64 { return load64(c + SANDHI_H2_CONN_OFF_PEER_STREAMS); }
fn sandhi_h2_conn_peer_init_window(c): i64 { return load64(c + SANDHI_H2_CONN_OFF_PEER_WINDOW); }
fn sandhi_h2_conn_goaway_received(c): i64 { return load64(c + SANDHI_H2_CONN_OFF_GOAWAY); }

# Allocate the next odd stream-id for client-originated streams.
# Returns the allocated id; advances the counter for next call. RFC
# 7540 §5.1.1: client uses odd ids; ids monotonically increase.
fn sandhi_h2_conn_next_stream_id(c): i64 {
    var id = load64(c + SANDHI_H2_CONN_OFF_NEXT_SID);
    store64(c + SANDHI_H2_CONN_OFF_NEXT_SID, id + 2);
    return id;
}

# ================================================================
# Frame send/recv plumbing
# ================================================================
#
# Send: build header into a 9-byte buf, fire as one `send_all`, then
# fire payload (if any) as a second `send_all`. Two syscalls per
# frame is fine — frames are infrequent compared to inner-byte work.
#
# Recv: read 9 bytes into a header buf, decode to learn payload
# length, read the payload, return both.

# Send a single h2 frame, allocating the 9-byte header buf from `a`.
# Per-frame allocation; an arena reset between requests reclaims
# every header buf accumulated within the request.
fn sandhi_h2_conn_send_frame_a(a, c, type, flags, stream_id, payload, payload_len): i64 {
    if (payload_len < 0) { return _SANDHI_H2_ERR_BAD_LENGTH; }
    if (payload_len > sandhi_h2_conn_peer_max_frame(c)) {
        return _SANDHI_H2_ERR_BAD_LENGTH;
    }
    var hdr = alloc_via(a, SANDHI_H2_FRAME_HEADER_SIZE);
    if (hdr == 0) { return _SANDHI_H2_ERR_TRUNCATED; }
    var n = sandhi_h2_hdr_encode(hdr, 0, payload_len, type, flags, stream_id);
    if (n < 0) { return n; }
    var conn = sandhi_h2_conn_underlying(c);
    if (sandhi_conn_send_all(conn, hdr, SANDHI_H2_FRAME_HEADER_SIZE) < 0) {
        return _SANDHI_H2_ERR_TRUNCATED;
    }
    if (payload_len > 0 && payload != 0) {
        if (sandhi_conn_send_all(conn, payload, payload_len) < 0) {
            return _SANDHI_H2_ERR_TRUNCATED;
        }
    }
    return 0;
}

fn sandhi_h2_conn_send_frame(c, type, flags, stream_id, payload, payload_len): i64 {
    return sandhi_h2_conn_send_frame_a(default_alloc(), c, type, flags, stream_id, payload, payload_len);
}

# Read one frame header + payload. Caller passes a result struct
# (16 bytes) into which we store {hdr_ptr, payload_ptr}. Returns the
# total bytes consumed (always 9 + payload_len), or a negative
# sentinel.
#
# Result struct layout (16 bytes):
#   +0  hdr      (SandhiH2Hdr ptr)
#   +8  payload  (alloc'd buf or 0; payload_len lives on the hdr)
# Receive one h2 frame into `a`. The hdr struct (via hdr_decode_a),
# the 9-byte hbuf, and the variable-length payload buf all flow
# through `a`; the result_out cells are caller-allocated.
fn sandhi_h2_conn_recv_frame_a(a, c, result_out): i64 {
    var conn = sandhi_h2_conn_underlying(c);
    var hbuf = alloc_via(a, SANDHI_H2_FRAME_HEADER_SIZE);
    if (hbuf == 0) { return _SANDHI_H2_ERR_TRUNCATED; }
    var nread = sandhi_conn_recv_all(conn, hbuf, SANDHI_H2_FRAME_HEADER_SIZE);
    if (nread != SANDHI_H2_FRAME_HEADER_SIZE) { return _SANDHI_H2_ERR_TRUNCATED; }
    var hdr = sandhi_h2_hdr_decode_a(a, hbuf, SANDHI_H2_FRAME_HEADER_SIZE, 0);
    if (hdr == 0) { return _SANDHI_H2_ERR_MALFORMED; }
    var plen = sandhi_h2_hdr_length(hdr);
    var payload = 0;
    if (plen > 0) {
        payload = alloc_via(a, plen);
        if (payload == 0) { return _SANDHI_H2_ERR_TRUNCATED; }
        if (sandhi_conn_recv_all(conn, payload, plen) != plen) {
            return _SANDHI_H2_ERR_TRUNCATED;
        }
    }
    store64(result_out + 0, hdr);
    store64(result_out + 8, payload);
    return SANDHI_H2_FRAME_HEADER_SIZE + plen;
}

fn sandhi_h2_conn_recv_frame(c, result_out): i64 {
    return sandhi_h2_conn_recv_frame_a(default_alloc(), c, result_out);
}

# ================================================================
# Handshake — preface + SETTINGS exchange
# ================================================================
#
# Per RFC 7540 §3.5 + §6.5.3:
#   1. Client sends 24-byte preface ("PRI * HTTP/2.0\r\n\r\nSM\r\n\r\n").
#   2. Client sends a SETTINGS frame (may be empty — defaults are fine).
#   3. Server sends its SETTINGS frame.
#   4. Both sides ACK each other's SETTINGS with an empty SETTINGS+ACK.
#
# We send our preface + an empty SETTINGS, then wait for the server's
# SETTINGS, ACK it. The server will subsequently ACK ours (which we
# observe in the regular frame loop, not synchronously here).

fn sandhi_h2_conn_send_preface_and_settings_a(a, c): i64 {
    var conn = sandhi_h2_conn_underlying(c);
    if (sandhi_conn_send_all(conn, _SANDHI_H2_PREFACE, 24) < 0) {
        return _SANDHI_H2_ERR_TRUNCATED;
    }
    return sandhi_h2_conn_send_frame_a(a, c, SANDHI_H2_FRAME_SETTINGS, 0, 0, 0, 0);
}

fn sandhi_h2_conn_send_preface_and_settings(c): i64 {
    return sandhi_h2_conn_send_preface_and_settings_a(default_alloc(), c);
}

# Apply a single peer-SETTINGS pair. Updates h2 conn state per §6.5.2.
fn _h2_conn_apply_setting(c, id, value): i64 {
    if (id == SANDHI_H2_SETTINGS_MAX_FRAME_SIZE) {
        store64(c + SANDHI_H2_CONN_OFF_PEER_FRAME, value);
    } elif (id == SANDHI_H2_SETTINGS_MAX_CONCURRENT_STREAMS) {
        store64(c + SANDHI_H2_CONN_OFF_PEER_STREAMS, value);
    } elif (id == SANDHI_H2_SETTINGS_INITIAL_WINDOW_SIZE) {
        store64(c + SANDHI_H2_CONN_OFF_PEER_WINDOW, value);
    } elif (id == SANDHI_H2_SETTINGS_HEADER_TABLE_SIZE) {
        sandhi_hpack_table_set_max_size(sandhi_h2_conn_dec_table(c), value);
    }
    # ENABLE_PUSH + MAX_HEADER_LIST_SIZE: ignored for now. Bite 5c
    # may want them; layered in when needed.
    return 0;
}

# Parse a SETTINGS frame payload into pairs and apply each.
fn sandhi_h2_conn_apply_settings_payload_a(a, c, payload, payload_len): i64 {
    if (payload_len % 6 != 0) { return _SANDHI_H2_ERR_MALFORMED; }
    var off = 0;
    var id_cell = alloc_via(a, 8);
    var v_cell = alloc_via(a, 8);
    if (id_cell == 0 || v_cell == 0) { return _SANDHI_H2_ERR_MALFORMED; }
    while (off < payload_len) {
        var n = sandhi_h2_settings_pair_decode(payload, payload_len, off, id_cell, v_cell);
        if (n < 0) { return n; }
        _h2_conn_apply_setting(c, load64(id_cell), load64(v_cell));
        off = n;
    }
    store64(c + SANDHI_H2_CONN_OFF_PEER_SEEN, 1);
    return 0;
}

fn sandhi_h2_conn_apply_settings_payload(c, payload, payload_len): i64 {
    return sandhi_h2_conn_apply_settings_payload_a(default_alloc(), c, payload, payload_len);
}

fn sandhi_h2_conn_send_settings_ack_a(a, c): i64 {
    return sandhi_h2_conn_send_frame_a(a, c,
    SANDHI_H2_FRAME_SETTINGS, SANDHI_H2_FLAG_ACK, 0, 0, 0);
}

fn sandhi_h2_conn_send_settings_ack(c): i64 {
    return sandhi_h2_conn_send_settings_ack_a(default_alloc(), c);
}

# Receive the peer's first frame, allocating the result struct +
# downstream recv_frame scratch from `a`. Recurses on the legal-but-
# odd "peer-acks-before-sending" case; that recursion shares `a` so
# all the per-handshake scratch lives in one allocator.
fn sandhi_h2_conn_recv_peer_settings_a(a, c): i64 {
    var result = alloc_via(a, 16);
    if (result == 0) { return _SANDHI_H2_ERR_TRUNCATED; }
    var n = sandhi_h2_conn_recv_frame_a(a, c, result);
    if (n < 0) { return n; }
    var hdr = load64(result + 0);
    if (sandhi_h2_hdr_type(hdr) != SANDHI_H2_FRAME_SETTINGS) {
        return _SANDHI_H2_ERR_MALFORMED;
    }
    if ((sandhi_h2_hdr_flags(hdr) & SANDHI_H2_FLAG_ACK) != 0) {
        store64(c + SANDHI_H2_CONN_OFF_OUR_ACKED, 1);
        return sandhi_h2_conn_recv_peer_settings_a(a, c);
    }
    var payload = load64(result + 8);
    var ar = sandhi_h2_conn_apply_settings_payload_a(a, c, payload, sandhi_h2_hdr_length(hdr));
    if (ar < 0) { return ar; }
    return sandhi_h2_conn_send_settings_ack_a(a, c);
}

fn sandhi_h2_conn_recv_peer_settings(c): i64 {
    return sandhi_h2_conn_recv_peer_settings_a(default_alloc(), c);
}


# --- request.cyr ---

# sandhi/http/h2/request — encode + send an HTTP/2 request.
#
# Composes Bite 2 (HPACK), Bite 3 (frames), and Bite 5a (h2 conn) to
# produce + send a complete HEADERS frame for one h2 request.
#
# Wire shape (RFC 7540 §8.1.2):
#   1. Pseudo-headers in fixed order: :method, :scheme, :path,
#      :authority.
#   2. Regular headers — names MUST be lowercase per §8.1.2; we
#      lowercase on emit so callers can keep using the existing
#      mixed-case `sandhi_headers_*` API unchanged.
#   3. Empty body for GET/HEAD/DELETE: HEADERS frame with
#      END_HEADERS | END_STREAM. For request bodies: HEADERS without
#      END_STREAM, then DATA frame(s) with the body, last DATA has
#      END_STREAM.
#
# Static-table optimization: we use the obvious pre-baked indices
# for `:method GET`/`POST`, `:scheme http`/`https`, `:path /`, and
# `:authority` (name-only). Everything else emits as literal-with-
# incremental-indexing with inline name + value. That trades a few
# extra wire bytes for code simplicity; the HPACK dynamic table
# absorbs repeated headers across requests on the same connection
# anyway, so it amortizes.
#
# Bite 5b of 0.8.0.

# Static-table indices we hardcode (RFC 7541 Appendix A).
var _SANDHI_H2_REQ_IDX_AUTHORITY     = 1;
var _SANDHI_H2_REQ_IDX_METHOD_GET    = 2;
var _SANDHI_H2_REQ_IDX_METHOD_POST   = 3;
var _SANDHI_H2_REQ_IDX_PATH_ROOT     = 4;
var _SANDHI_H2_REQ_IDX_SCHEME_HTTP   = 6;
var _SANDHI_H2_REQ_IDX_SCHEME_HTTPS  = 7;

# Default HEADERS-frame buffer cap. For typical RPC requests the
# HPACK-encoded block is well under 1 KB. Caller-overridable in a
# follow-up if a consumer ships absurdly large header sets.
var _SANDHI_H2_REQ_HBUF_CAP = 8192;

# ================================================================
# Pseudo-header emit helpers
# ================================================================

fn _h2_emit_method(h2c, method, hbuf, off): i64 {
    var enc = sandhi_h2_conn_enc_table(h2c);
    if (streq(method, "GET") == 1)  {
        return sandhi_hpack_encode_indexed(hbuf, off, _SANDHI_H2_REQ_IDX_METHOD_GET);
    }
    if (streq(method, "POST") == 1) {
        return sandhi_hpack_encode_indexed(hbuf, off, _SANDHI_H2_REQ_IDX_METHOD_POST);
    }
    # PUT / DELETE / PATCH / HEAD — emit literal with name idx 2 + value.
    return sandhi_hpack_encode_literal_indexed_name(enc, hbuf, off,
    _SANDHI_H2_REQ_IDX_METHOD_GET, ":method", method);
}

fn _h2_emit_scheme(h2c, scheme, hbuf, off): i64 {
    if (streq(scheme, "https") == 1) {
        return sandhi_hpack_encode_indexed(hbuf, off, _SANDHI_H2_REQ_IDX_SCHEME_HTTPS);
    }
    if (streq(scheme, "http") == 1) {
        return sandhi_hpack_encode_indexed(hbuf, off, _SANDHI_H2_REQ_IDX_SCHEME_HTTP);
    }
    var enc = sandhi_h2_conn_enc_table(h2c);
    return sandhi_hpack_encode_literal_indexed_name(enc, hbuf, off,
    _SANDHI_H2_REQ_IDX_SCHEME_HTTP, ":scheme", scheme);
}

fn _h2_emit_path(h2c, path, hbuf, off): i64 {
    if (streq(path, "/") == 1) {
        return sandhi_hpack_encode_indexed(hbuf, off, _SANDHI_H2_REQ_IDX_PATH_ROOT);
    }
    var enc = sandhi_h2_conn_enc_table(h2c);
    return sandhi_hpack_encode_literal_indexed_name(enc, hbuf, off,
    _SANDHI_H2_REQ_IDX_PATH_ROOT, ":path", path);
}

fn _h2_emit_authority(h2c, authority, hbuf, off): i64 {
    var enc = sandhi_h2_conn_enc_table(h2c);
    return sandhi_hpack_encode_literal_indexed_name(enc, hbuf, off,
    _SANDHI_H2_REQ_IDX_AUTHORITY, ":authority", authority);
}

# Emit one user header, allocating the lowercased-name copy from `a`.
# The HPACK encoder only references the lowercased name during this
# call, so the alloc is short-lived; arena callers reset after the
# request is on the wire.
fn _h2_emit_user_header_a(a, h2c, name, value, hbuf, off): i64 {
    var nlen = strlen(name);
    var lower = alloc_via(a, nlen + 1);
    if (lower == 0) { return off; }
    var i = 0;
    while (i < nlen) {
        var ch = load8(name + i);
        if (ch >= 65 && ch <= 90) { ch = ch + 32; }
        store8(lower + i, ch);
        i = i + 1;
    }
    store8(lower + nlen, 0);
    var enc = sandhi_h2_conn_enc_table(h2c);
    return sandhi_hpack_encode_literal_indexed(enc, hbuf, off, lower, value);
}

fn _h2_emit_user_header(h2c, name, value, hbuf, off): i64 {
    return _h2_emit_user_header_a(default_alloc(), h2c, name, value, hbuf, off);
}

# ================================================================
# Build a complete header block for a request
# ================================================================
#
# Returns the byte length of the encoded block. Caller-allocated
# `hbuf` MUST hold ≥ _SANDHI_H2_REQ_HBUF_CAP bytes (encoder lacks
# overflow checking — caller's responsibility). `user_headers` may
# be 0 for "no extras." `:method`/`:scheme`/`:path`/`:authority` are
# emitted in that exact order per RFC 7540 §8.1.2.1.

fn sandhi_h2_request_encode_headers_a(a, h2c, method, scheme, path, authority,
user_headers, hbuf): i64 {
    var off = 0;
    off = _h2_emit_method(h2c, method, hbuf, off);
    off = _h2_emit_scheme(h2c, scheme, hbuf, off);
    off = _h2_emit_path(h2c, path, hbuf, off);
    off = _h2_emit_authority(h2c, authority, hbuf, off);

    var have_te = 0;
    if (user_headers != 0) {
        if (sandhi_headers_has(user_headers, "TE") == 1) { have_te = 1; }
    }
    if (have_te == 0) {
        off = _h2_emit_user_header_a(a, h2c, "te", "trailers", hbuf, off);
    }

    if (user_headers != 0) {
        var n = sandhi_headers_count(user_headers);
        var i = 0;
        while (i < n) {
            var name = sandhi_headers_name_at(user_headers, i);
            var value = sandhi_headers_value_at(user_headers, i);
            if (_h2_header_is_forbidden(name, value) == 0) {
                off = _h2_emit_user_header_a(a, h2c, name, value, hbuf, off);
            }
            i = i + 1;
        }
    }
    return off;
}

fn sandhi_h2_request_encode_headers(h2c, method, scheme, path, authority,
user_headers, hbuf): i64 {
    return sandhi_h2_request_encode_headers_a(default_alloc(), h2c, method, scheme, path, authority,
    user_headers, hbuf);
}

# 1 if (name, value) is forbidden in an h2 header block per RFC 7540
# §8.1.2.2. Case-insensitive name match. The `te` header is
# conditionally allowed: only `te: trailers` may appear; any other
# value (e.g. `te: gzip`) must be dropped — the spec says a request
# with TE != "trailers" is malformed. We drop instead of erroring so
# the request still ships.
fn _h2_header_is_forbidden(name, value): i64 {
    if (_h2_streq_ci(name, "connection") == 1)        { return 1; }
    if (_h2_streq_ci(name, "keep-alive") == 1)        { return 1; }
    if (_h2_streq_ci(name, "proxy-connection") == 1)  { return 1; }
    if (_h2_streq_ci(name, "transfer-encoding") == 1) { return 1; }
    if (_h2_streq_ci(name, "upgrade") == 1)           { return 1; }
    if (_h2_streq_ci(name, "te") == 1) {
        if (_h2_te_value_is_trailers(value) == 1) { return 0; }
        return 1;
    }
    return 0;
}

# 1 if `value` is the literal "trailers" (case-insensitive) with
# optional surrounding whitespace. NULL or any other value → 0.
# Used only by `_h2_header_is_forbidden` for the te-conditional rule.
fn _h2_te_value_is_trailers(value): i64 {
    if (value == 0) { return 0; }
    var i = 0;
    while (load8(value + i) == 32 || load8(value + i) == 9) { i = i + 1; }
    var need = "trailers";
    var j = 0;
    while (j < 8) {
        var ch = load8(value + i + j);
        if (ch >= 65 && ch <= 90) { ch = ch + 32; }
        if (ch != load8(need + j)) { return 0; }
        j = j + 1;
    }
    var k = i + 8;
    while (1 == 1) {
        var ch2 = load8(value + k);
        if (ch2 == 0) { return 1; }
        if (ch2 != 32 && ch2 != 9) { return 0; }
        k = k + 1;
    }
    return 1;
}

fn _h2_streq_ci(a, b): i64 {
    var i = 0;
    while (1 == 1) {
        var ca = load8(a + i);
        var cb = load8(b + i);
        if (ca >= 65 && ca <= 90) { ca = ca + 32; }
        if (cb >= 65 && cb <= 90) { cb = cb + 32; }
        if (ca != cb) { return 0; }
        if (ca == 0)  { return 1; }
        i = i + 1;
    }
    return 0;
}

# ================================================================
# Send a complete request
# ================================================================
#
# For body-less methods (GET/HEAD/DELETE): one HEADERS frame with
# END_HEADERS | END_STREAM. For body-bearing (POST/PUT/PATCH):
# HEADERS frame with END_HEADERS only, then a DATA frame with the
# body and END_STREAM.
#
# Returns the allocated stream-id on success (≥ 1), or a negative
# `_SANDHI_H2_ERR_*` sentinel on failure.

fn sandhi_h2_request_send_a(a, h2c, method, scheme, path, authority,
user_headers, body, body_len): i64 {
    var hbuf = alloc_via(a, _SANDHI_H2_REQ_HBUF_CAP);
    if (hbuf == 0) { return _SANDHI_H2_ERR_MALFORMED; }
    var hlen = sandhi_h2_request_encode_headers_a(a, h2c, method, scheme, path,
    authority, user_headers, hbuf);
    if (hlen <= 0) { return _SANDHI_H2_ERR_MALFORMED; }

    var stream_id = sandhi_h2_conn_next_stream_id(h2c);
    var has_body = 0;
    if (body_len > 0 && body != 0) { has_body = 1; }

    var hflags = SANDHI_H2_FLAG_END_HEADERS;
    if (has_body == 0) { hflags = hflags | SANDHI_H2_FLAG_END_STREAM; }
    var hr = sandhi_h2_conn_send_frame(h2c, SANDHI_H2_FRAME_HEADERS,
    hflags, stream_id, hbuf, hlen);
    if (hr < 0) { return hr; }

    if (has_body == 1) {
        # First cut: send the entire body in one DATA frame. If
        # body_len > peer_max_frame, we need to fragment — that's a
        # follow-up. Reject explicitly until then so we don't ship a
        # silently-truncated request.
        if (body_len > sandhi_h2_conn_peer_max_frame(h2c)) {
            return _SANDHI_H2_ERR_BAD_LENGTH;
        }
        var dr = sandhi_h2_conn_send_frame(h2c, SANDHI_H2_FRAME_DATA,
        SANDHI_H2_FLAG_END_STREAM,
        stream_id, body, body_len);
        if (dr < 0) { return dr; }
    }
    return stream_id;
}

fn sandhi_h2_request_send(h2c, method, scheme, path, authority,
user_headers, body, body_len): i64 {
    return sandhi_h2_request_send_a(default_alloc(), h2c, method, scheme, path, authority,
    user_headers, body, body_len);
}


# --- response.cyr ---

# sandhi/http/h2/response — receive + decode an HTTP/2 response.
#
# Reads frames in a loop, dispatches by type and stream-id, decodes
# the HEADERS+CONTINUATION block via HPACK once END_HEADERS is seen,
# accumulates DATA payloads until END_STREAM, then returns a
# `sandhi_response` struct (the same shape `_sandhi_http_dispatch`
# produces) so callers can stay protocol-agnostic.
#
# Connection-level frames are handled inline:
#   - SETTINGS (non-ACK): apply + ACK back.
#   - SETTINGS (ACK): record that our SETTINGS were ACK'd.
#   - PING (non-ACK): echo back with the ACK flag.
#   - GOAWAY: surface as SANDHI_ERR_REMOTE; stream is dead.
#   - PRIORITY / WINDOW_UPDATE: silently accepted (we don't enforce
#     flow control yet — peer's default window keeps responses
#     bounded; if a consumer hits a flow-controlled stall we wire
#     a real window manager in a follow-up).
#
# Stream-level frames on our stream:
#   - HEADERS: append payload to header block; on END_HEADERS,
#     decode via HPACK. END_STREAM here = empty-body response.
#   - CONTINUATION: append payload; on END_HEADERS, decode.
#   - DATA: append to body; on END_STREAM, finish.
#   - RST_STREAM: peer aborted — surface SANDHI_ERR_REMOTE with
#     the error code attached as err_message.
#
# Frames on other stream-ids are ignored — sandhi's first cut is
# single-stream-per-connection so anything else is concurrent
# stream chatter we can drop. Bite 6 (multiplex via pool) tracks
# per-stream state.
#
# Bite 5c of 0.8.0.

# Buffer caps. Generous defaults; consumers with bigger needs use
# Bite 7's options surface.
var _SANDHI_H2_HBLOCK_CAP = 16384;
var _SANDHI_H2_BODY_CAP   = 1048576;  # 1 MB

# ================================================================
# Helpers
# ================================================================

# Parse the :status pseudo-header value (cstr like "200") to an int.
# Returns 0 on malformed.
fn _h2_parse_status(s): i64 {
    if (s == 0) { return 0; }
    var n = 0;
    var i = 0;
    while (load8(s + i) != 0) {
        var c = load8(s + i);
        if (c < 48 || c > 57) { return 0; }
        n = n * 10 + (c - 48);
        i = i + 1;
    }
    return n;
}

# 1 if the header name starts with ':' (a pseudo-header).
fn _h2_is_pseudo(name): i64 {
    if (name == 0) { return 0; }
    if (load8(name) == 58) { return 1; }
    return 0;
}

# Append `n` bytes from `src` to `dst+dst_off`. Caller pre-allocated.
fn _h2_buf_append(dst, dst_off, src, n): i64 {
    var i = 0;
    while (i < n) {
        store8(dst + dst_off + i, load8(src + i));
        i = i + 1;
    }
    return dst_off + n;
}

# Decode the accumulated HEADERS block into `headers_out`, allocating
# every transient cell + decoded name/value cstr from `a`. Returns
# status (0 on bad/missing); the HPACK decode dynamic-table side
# effects also route through `a` (see hpack.cyr's decode_field_a).
fn _h2_decode_response_headers_a(a, h2c, hblock, hblock_len, headers_out): i64 {
    var dec = sandhi_h2_conn_dec_table(h2c);
    var off = alloc_via(a, 8);
    var no  = alloc_via(a, 8);
    var vo  = alloc_via(a, 8);
    if (off == 0 || no == 0 || vo == 0) { return 0; }
    store64(off, 0);
    var status = 0;
    while (load64(off) < hblock_len) {
        var r = sandhi_hpack_decode_field_a(a, dec, hblock, hblock_len, off, no, vo);
        if (r < 0) { return 0; }
        if (r == _SANDHI_HPACK_TBL_UPDATE) {
            # Dynamic-table-size-update — already applied to the
            # decode table by sandhi_hpack_decode_field_a.
        } else {
            var name = load64(no);
            var value = load64(vo);
            if (_h2_is_pseudo(name) == 1) {
                if (streq(name, ":status") == 1) {
                    status = _h2_parse_status(value);
                }
            } else {
                sandhi_headers_add_a(a, headers_out, name, value);
            }
        }
    }
    return status;
}

fn _h2_decode_response_headers(h2c, hblock, hblock_len, headers_out): i64 {
    return _h2_decode_response_headers_a(default_alloc(), h2c, hblock, hblock_len, headers_out);
}

# ================================================================
# Connection-level frame handlers
# ================================================================

# Returns 0 on success, negative on send-fail.
fn _h2_handle_settings(h2c, hdr, payload): i64 {
    var flags = sandhi_h2_hdr_flags(hdr);
    if ((flags & SANDHI_H2_FLAG_ACK) != 0) {
        # Empty ACK from peer — our SETTINGS got through. Nothing
        # else to do here; conn struct could record it but the
        # accessor isn't currently surfaced.
        return 0;
    }
    var ar = sandhi_h2_conn_apply_settings_payload(h2c, payload, sandhi_h2_hdr_length(hdr));
    if (ar < 0) { return ar; }
    return sandhi_h2_conn_send_settings_ack(h2c);
}

fn _h2_handle_ping(h2c, hdr, payload): i64 {
    var flags = sandhi_h2_hdr_flags(hdr);
    if ((flags & SANDHI_H2_FLAG_ACK) != 0) { return 0; }
    return sandhi_h2_conn_send_frame(h2c, SANDHI_H2_FRAME_PING,
    SANDHI_H2_FLAG_ACK, 0, payload, 8);
}

# ================================================================
# Public: receive a complete response on `stream_id`
# ================================================================

# Receive a complete h2 response on `stream_id`, allocating the
# header-block scratch, body buffer, per-frame result cell, decoded
# headers + body, and resp struct from `a`. The recv path is one of
# the heaviest alloc sites in the codebase (a 1 MB body buffer + per-
# frame 16-byte result cells in a tight loop) — routing through `a`
# lets a per-request arena reset reclaim everything in one shot.
fn sandhi_h2_response_recv_a(a, h2c, stream_id): i64 {
    var hblock = alloc_via(a, _SANDHI_H2_HBLOCK_CAP);
    var hblock_len = 0;
    var body = alloc_via(a, _SANDHI_H2_BODY_CAP);
    if (hblock == 0 || body == 0) { return _sandhi_resp_err_a(a, SANDHI_ERR_INTERNAL); }
    var body_len = 0;
    var headers_complete = 0;
    var stream_complete = 0;
    var fail_kind = SANDHI_OK;

    while (stream_complete == 0 && fail_kind == SANDHI_OK) {
        var result = alloc_via(a, 16);
        if (result == 0) { fail_kind = SANDHI_ERR_INTERNAL; }
        var n = sandhi_h2_conn_recv_frame(h2c, result);
        if (n < 0) { fail_kind = SANDHI_ERR_PROTOCOL; }
        else {
            var hdr = load64(result + 0);
            var payload = load64(result + 8);
            var ftype = sandhi_h2_hdr_type(hdr);
            var fflags = sandhi_h2_hdr_flags(hdr);
            var fsid = sandhi_h2_hdr_stream_id(hdr);
            var flen = sandhi_h2_hdr_length(hdr);

            if (ftype == SANDHI_H2_FRAME_SETTINGS && fsid == 0) {
                if (_h2_handle_settings(h2c, hdr, payload) < 0) {
                    fail_kind = SANDHI_ERR_CONNECT;
                }
            } elif (ftype == SANDHI_H2_FRAME_PING && fsid == 0) {
                if (_h2_handle_ping(h2c, hdr, payload) < 0) {
                    fail_kind = SANDHI_ERR_CONNECT;
                }
            } elif (ftype == SANDHI_H2_FRAME_GOAWAY && fsid == 0) {
                store64(h2c + SANDHI_H2_CONN_OFF_GOAWAY, 1);
                fail_kind = SANDHI_ERR_REMOTE;
            } elif (ftype == SANDHI_H2_FRAME_RST_STREAM && fsid == stream_id) {
                fail_kind = SANDHI_ERR_REMOTE;
            } elif (ftype == SANDHI_H2_FRAME_HEADERS && fsid == stream_id) {
                if (hblock_len + flen > _SANDHI_H2_HBLOCK_CAP) {
                    fail_kind = SANDHI_ERR_PROTOCOL;
                } else {
                    hblock_len = _h2_buf_append(hblock, hblock_len, payload, flen);
                    if ((fflags & SANDHI_H2_FLAG_END_HEADERS) != 0) {
                        headers_complete = 1;
                    }
                    if ((fflags & SANDHI_H2_FLAG_END_STREAM) != 0) {
                        stream_complete = 1;
                    }
                }
            } elif (ftype == SANDHI_H2_FRAME_CONTINUATION && fsid == stream_id) {
                if (hblock_len + flen > _SANDHI_H2_HBLOCK_CAP) {
                    fail_kind = SANDHI_ERR_PROTOCOL;
                } else {
                    hblock_len = _h2_buf_append(hblock, hblock_len, payload, flen);
                    if ((fflags & SANDHI_H2_FLAG_END_HEADERS) != 0) {
                        headers_complete = 1;
                    }
                }
            } elif (ftype == SANDHI_H2_FRAME_DATA && fsid == stream_id) {
                # PADDED flag means the first byte is a pad-length
                # and that many trailing bytes are pad. RFC 7540 §6.1.
                var data_off = 0;
                var data_len = flen;
                if ((fflags & SANDHI_H2_FLAG_PADDED) != 0) {
                    if (flen < 1) { fail_kind = SANDHI_ERR_PROTOCOL; }
                    else {
                        var pad = load8(payload);
                        if (1 + pad > flen) { fail_kind = SANDHI_ERR_PROTOCOL; }
                        else {
                            data_off = 1;
                            data_len = flen - 1 - pad;
                        }
                    }
                }
                if (fail_kind == SANDHI_OK) {
                    if (body_len + data_len > _SANDHI_H2_BODY_CAP) {
                        fail_kind = SANDHI_ERR_PROTOCOL;
                    } else {
                        body_len = _h2_buf_append(body, body_len, payload + data_off, data_len);
                        if ((fflags & SANDHI_H2_FLAG_END_STREAM) != 0) {
                            stream_complete = 1;
                        }
                    }
                }
            }
            # PRIORITY / WINDOW_UPDATE / other-stream frames: silently
            # ignored. Bite 6 changes that for multiplex.
        }
    }

    if (fail_kind != SANDHI_OK) { return _sandhi_resp_err_a(a, fail_kind); }

    # Decode the accumulated header block.
    var headers = sandhi_headers_new_a(a);
    # 1.2.8 OOM guard: `_h2_decode_response_headers_a` calls
    # `sandhi_headers_add_a(a, headers, ...)` which calls
    # `vec_push_a(a, h=null, ...)` → SIGSEGV. Bail with INTERNAL.
    if (headers == 0) { return _sandhi_resp_err_a(a, SANDHI_ERR_INTERNAL); }
    var status = _h2_decode_response_headers_a(a, h2c, hblock, hblock_len, headers);
    if (status == 0) { return _sandhi_resp_err_a(a, SANDHI_ERR_PROTOCOL); }

    # Null-terminate body for cstr-style consumers.
    if (body_len < _SANDHI_H2_BODY_CAP) {
        store8(body + body_len, 0);
    }
    return _sandhi_resp_new_a(a, status, body, body_len, headers, SANDHI_OK);
}

fn sandhi_h2_response_recv(h2c, stream_id): i64 {
    return sandhi_h2_response_recv_a(default_alloc(), h2c, stream_id);
}


# --- pool_glue.cyr ---

# sandhi/http/h2/pool_glue — h2-multiplex helpers on top of the pool.
#
# The base `src/http/pool.cyr` ships an `h2_map` field (host:port:tls
# → sandhi_h2_conn) but can't reference `sandhi_h2_conn_underlying`
# directly because pool.cyr lives earlier in the build order than
# `src/http/h2/conn.cyr`. This file lives after both and provides
# the h2-aware helpers.
#
# h2 multiplex model: ONE h2 conn per route; many concurrent streams
# per conn (peer's SETTINGS_MAX_CONCURRENT_STREAMS bounds it). The
# pool stores the conn; callers allocate streams via
# `sandhi_h2_conn_next_stream_id`. We don't track active stream
# count here yet — first cut, the server enforces the cap by
# returning REFUSED_STREAM, and the caller retries on a new conn.
#
# Bite 6 of 0.8.0.

# Take the h2 conn for a route, or 0 if none. Doesn't remove from
# the map — h2 conns are shared, not exclusive.
fn sandhi_http_pool_take_h2(pool, host, port, tls): i64 {
    if (pool == 0) { return 0; }
    var key = _sandhi_pool_route_key(host, port, tls);
    var h2m = load64(pool + SANDHI_POOL_OFF_H2_MAP);
    if (h2m == 0) { return 0; }
    var h2c = map_get(h2m, key);
    if (h2c == 0) { return 0; }
    # Skip if peer sent GOAWAY — caller will open a fresh conn.
    if (sandhi_h2_conn_goaway_received(h2c) == 1) {
        map_delete(h2m, key);
        return 0;
    }
    return h2c;
}

# Store an h2 conn for a route. Replaces any prior entry — h2 conns
# are exclusive per route in our first-cut model. Caller is
# responsible for closing the prior entry's underlying socket if
# they care about leaks (no-op today since we only call this once
# per route per process).
fn sandhi_http_pool_put_h2(pool, host, port, tls, h2c): i64 {
    if (pool == 0 || h2c == 0) { return 0; }
    var key = _sandhi_pool_route_key(host, port, tls);
    var h2m = load64(pool + SANDHI_POOL_OFF_H2_MAP);
    map_set(h2m, key, h2c);
    return 0;
}

# Tear down all stored h2 conns. Closes each one's underlying
# sandhi_conn. Consumers that called `pool_put_h2` should call this
# before `sandhi_http_pool_close` to avoid fd leaks at process exit.
# (Order matters because pool.cyr's close clears the map without
# walking values.)
fn sandhi_http_pool_close_h2_conns(pool): i64 {
    if (pool == 0) { return 0; }
    var h2m = load64(pool + SANDHI_POOL_OFF_H2_MAP);
    if (h2m == 0) { return 0; }
    var keys = map_keys(h2m);
    var i = 0;
    var n = vec_len(keys);
    while (i < n) {
        var k = vec_get(keys, i);
        var h2c = map_get(h2m, k);
        if (h2c != 0) {
            var underlying = sandhi_h2_conn_underlying(h2c);
            if (underlying != 0) { sandhi_conn_close(underlying); }
        }
        i = i + 1;
    }
    map_clear(h2m);
    return 0;
}


# --- dispatch.cyr ---

# sandhi/http/h2/dispatch — public h2 request verb.
#
# Composes Bites 5a/5b/5c into one call: send a request and wait
# for the response on the resulting stream. Returns the same
# `sandhi_response` shape as the HTTP/1.1 path so callers stay
# protocol-agnostic.
#
# This is the **manual** entry point. The library-level
# `sandhi_http_get` etc. uses the HTTP/1.1 path; the auto-h2
# dispatcher (`sandhi_http_request_auto`) opportunistically uses
# h2 when the pool already holds an h2 conn for the route.
#
# Live ALPN selection is wired since 0.9.3 — `sandhi_conn_alpn_is_h2`
# returns the real value off the conn struct. The remaining piece
# for full h2 auto-promotion (open conn → if ALPN chose h2, do the
# preface/SETTINGS exchange and cache an h2 conn in the pool) is
# additional wire-up in this file's `sandhi_http_request_auto`.
#
# Consumers that want h2 today construct the conn themselves
# (`sandhi_conn_open`, then `sandhi_h2_conn_send_preface_and_settings`
# + `_recv_peer_settings`), then call `sandhi_h2_request` per
# request. Tests in tests/h2.tcyr exercise this end-to-end against
# synthetic byte streams.

# Send a request on `h2c` and wait for the matching response.
# Returns a sandhi_response (same shape as `_sandhi_http_dispatch`
# produces; status/body/headers/err_kind/err_message accessors all
# work the same way).
#
# Method must be one of GET/POST/PUT/DELETE/PATCH/HEAD. URL is
# parsed for scheme/host/port/path. user_headers may be 0.
# Send an h2 request and recv the response into `a`. The URL parse,
# authority builder, full-path combine, request-encode scratch, and
# entire response struct/body all flow through `a` — so a per-request
# arena reset reclaims the whole exchange.
fn sandhi_h2_request_a(a, h2c, method, url, user_headers, body, body_len): i64 {
    var u = sandhi_url_parse_a(a, url);
    if (u == 0) { return _sandhi_resp_err_a(a, SANDHI_ERR_PARSE); }

    var scheme = "http";
    if (sandhi_url_scheme(u) == SANDHI_URL_HTTPS) { scheme = "https"; }
    var host = sandhi_url_host(u);
    var port = sandhi_url_port(u);
    var path = sandhi_url_path(u);

    # `:authority` per RFC 7540 §8.1.2.3 — like Host but for h2. We
    # include the port only if non-default, matching how Bite 1's
    # `_sandhi_client_host_header` handles the Host header.
    var default_port = 80;
    if (sandhi_url_scheme(u) == SANDHI_URL_HTTPS) { default_port = 443; }
    var authority = host;
    if (port != default_port) {
        var sb = str_builder_new();
        str_builder_add_cstr(sb, host);
        str_builder_add_cstr(sb, ":");
        str_builder_add_int(sb, port);
        authority = _sandhi_json_dup_a(a, str_data(str_builder_build(sb)));
    }

    # Path: encode like the 1.1 client — path + "?query" if present.
    var query = sandhi_url_query(u);
    var full_path = path;
    if (query != 0) {
        var pathlen = strlen(path);
        var qlen = strlen(query);
        var fp = alloc_via(a, pathlen + 1 + qlen + 1);
        if (fp == 0) { return _sandhi_resp_err_a(a, SANDHI_ERR_INTERNAL); }
        memcpy(fp, path, pathlen);
        store8(fp + pathlen, 63);  # '?'
        memcpy(fp + pathlen + 1, query, qlen);
        store8(fp + pathlen + 1 + qlen, 0);
        full_path = fp;
    }

    var stream_id = sandhi_h2_request_send_a(a, h2c, method, scheme, full_path,
    authority, user_headers,
    body, body_len);
    if (stream_id < 0) { return _sandhi_resp_err_a(a, SANDHI_ERR_PROTOCOL); }
    return sandhi_h2_response_recv_a(a, h2c, stream_id);
}

fn sandhi_h2_request(h2c, method, url, user_headers, body, body_len): i64 {
    return sandhi_h2_request_a(default_alloc(), h2c, method, url, user_headers, body, body_len);
}

# ================================================================
# Auto-selecting dispatch (0.8.1, redirect-following 0.9.5)
# ================================================================
#
# Per-hop choice: if the attached pool has an h2 conn for the route,
# dispatch via `sandhi_h2_request`; otherwise fall back to the
# HTTP/1.1 single-shot path (`_sandhi_http_do`).
#
# Redirect-following lives at this auto layer (not below) so h2
# selection re-evaluates on every hop. A redirect from authority A
# (no h2 in the pool) to authority B (with h2 in the pool) uses h2
# for hop 2. The 1.1 fallback path used to do its own follow inside
# `_sandhi_http_dispatch`, which would have stayed on 1.1 across the
# whole chain — handing redirect control to the auto layer fixes
# that as a side effect.
#
# Security semantics mirror `_sandhi_http_follow` in client.cyr:
#   - https→http downgrade refused (response surfaced with err=TLS)
#   - Authorization / Cookie / Proxy-Authorization stripped on
#     cross-authority hops
#   - 303 rewrites method to GET and drops the body

# ALPN-driven h2 auto-promotion (0.9.6). Called from
# `_sandhi_http_auto_once` when the pool doesn't already have an h2
# conn for the route AND the URL is HTTPS AND a pool is attached.
#
# Opens a TLS connection advertising `h2,http/1.1` (toggling
# `_sandhi_alpn_advertise_h2` for this open only); after handshake,
# inspects what the server picked:
#
#   - h2 selected → do preface + SETTINGS exchange, cache the h2
#     conn in the pool's h2_map via `sandhi_http_pool_put_h2`,
#     return the h2c. Caller dispatches via `sandhi_h2_request`.
#   - http/1.1 (or no ALPN) selected → put the bare TLS conn into
#     the pool's 1.1 slot via `_sandhi_pool_put` and return 0. The
#     1.1 path immediately below picks it up via `_sandhi_pool_take`
#     — no wasted handshake.
#   - Open failed (DNS / connect / TLS) → return 0; the 1.1 path
#     opens its own conn and reports the same error from
#     `_sandhi_http_do`'s usual classification.
#
# No-pool requests skip this path entirely. h2's preface + SETTINGS +
# ACK roundtrips don't pay back on a single request — without a pool
# to cache the conn for the next request, advertising h2 is strictly
# slower than 1.1.
fn _sandhi_http_try_h2_promote_a(a, url, opts, host, port, pool): i64 {
    var addr = _sandhi_client_resolve_a(a, host);
    var addr6 = 0;
    if (addr == 0 - 1) {
        addr6 = _sandhi_client_resolve_v6_a(a, host);
        if (addr6 == 0) { return 0; }
    }
    var connect_ms = sandhi_http_options_get_connect_ms(opts);
    var read_ms = sandhi_http_options_get_read_ms(opts);
    var write_ms = sandhi_http_options_get_write_ms(opts);

    _sandhi_alpn_advertise_h2 = 1;
    var conn = 0;
    if (addr6 != 0) {
        conn = _sandhi_conn_open_v6_fully_timed_a(a, addr6, port, 1, host,
        connect_ms, read_ms, write_ms);
    } else {
        conn = sandhi_conn_open_fully_timed_a(a, addr, port, 1, host,
        connect_ms, read_ms, write_ms);
    }
    _sandhi_alpn_advertise_h2 = 0;

    if (conn == 0) { return 0; }

    if (sandhi_conn_alpn_is_h2(conn) == 1) {
        # h2 conn lives in the pool — long-lived, uses pool's allocator
        # via sandhi_h2_conn_new (h2 allocator is conn-bound).
        var h2c = sandhi_h2_conn_new(conn);
        if (sandhi_h2_conn_send_preface_and_settings(h2c) < 0) {
            sandhi_conn_close(conn);
            return 0;
        }
        if (sandhi_h2_conn_recv_peer_settings(h2c) < 0) {
            sandhi_conn_close(conn);
            return 0;
        }
        sandhi_http_pool_put_h2(pool, host, port, 1, h2c);
        return h2c;
    }

    # 1.1 (or no ALPN) — donate the open conn to the 1.1 pool slot
    # so the immediately-following `_sandhi_http_do` reuses it.
    _sandhi_pool_put(pool, host, port, 1, conn);
    return 0;
}

fn _sandhi_http_try_h2_promote(url, opts, host, port, pool): i64 {
    return _sandhi_http_try_h2_promote_a(default_alloc(), url, opts, host, port, pool);
}

# Per-hop dispatch — try h2 from pool, then ALPN-promote (TLS+pool
# only), else 1.1 single-shot. 1.1 fallback calls `_sandhi_http_do`
# directly rather than `_sandhi_http_dispatch` so a single hop is
# single hop; the auto-level follower handles the redirect chain.
# 1.2.1: `_a` threads `a` through h2 / promote / 1.1 paths uniformly.
# h2 path uses `sandhi_h2_request_a(a, ...)` for the per-request resp;
# 1.1 path uses `_sandhi_http_do_a(a, ...)`.
fn _sandhi_http_auto_once_a(a, method, url, user_headers, body, body_len, opts): i64 {
    var pool = sandhi_http_options_get_pool(opts);
    if (pool != 0) {
        var u = sandhi_url_parse_a(a, url);
        if (u != 0) {
            var host = sandhi_url_host(u);
            var port = sandhi_url_port(u);
            var tls = 0;
            if (sandhi_url_scheme(u) == SANDHI_URL_HTTPS) { tls = 1; }
            var h2c = sandhi_http_pool_take_h2(pool, host, port, tls);
            if (h2c != 0) {
                return sandhi_h2_request_a(a, h2c, method, url, user_headers, body, body_len);
            }
            # Try ALPN promotion only when the pool has nothing for
            # this route in either map. If the 1.1 slot already has
            # an idle conn, a previous promotion attempt landed there
            # (server picked 1.1) — repeating it would burn a TLS
            # handshake every request instead of reusing the idle
            # 1.1 conn.
            if (tls == 1 && _sandhi_pool_has_idle(pool, host, port, 1) == 0) {
                var promoted = _sandhi_http_try_h2_promote_a(a, url, opts, host, port, pool);
                if (promoted != 0) {
                    return sandhi_h2_request_a(a, promoted, method, url, user_headers, body, body_len);
                }
            }
        }
    }
    var max_bytes = sandhi_http_options_bytes(opts);
    var read_ms = sandhi_http_options_get_read_ms(opts);
    var write_ms = sandhi_http_options_get_write_ms(opts);
    var connect_ms = sandhi_http_options_get_connect_ms(opts);
    var total_ms = sandhi_http_options_get_total_ms(opts);
    return _sandhi_http_do_a(a, method, url, user_headers, body, body_len,
    max_bytes, connect_ms, read_ms, write_ms, total_ms, pool);
}

fn _sandhi_http_auto_once(method, url, user_headers, body, body_len, opts): i64 {
    return _sandhi_http_auto_once_a(default_alloc(), method, url, user_headers, body, body_len, opts);
}

# Auto-path redirect driver. Same shape as `_sandhi_http_follow`:
# per-hop locals reassigned in place to keep the frame small.
fn _sandhi_http_auto_follow_a(a, method, url, user_headers, body, body_len, opts, max_hops): i64 {
    var m = method;
    var u = url;
    var b = body;
    var bl = body_len;
    var h = user_headers;
    var hops = 0;
    var r = _sandhi_http_auto_once_a(a, m, u, h, b, bl, opts);
    while (hops < max_hops) {
        if (_sandhi_is_redirect(sandhi_http_status(r)) == 0) { return r; }
        var loc = sandhi_headers_get(sandhi_http_headers(r), "Location");
        if (loc == 0) { return r; }
        var next = _sandhi_resolve_location_a(a, u, loc);
        if (next == 0) { return r; }

        if (_sandhi_url_is_https_downgrade(u, next) == 1) {
            store64(r + SANDHI_RESP_OFF_ERR_KIND, SANDHI_ERR_TLS);
            return r;
        }

        if (_sandhi_url_same_authority(u, next) == 0) {
            h = _sandhi_strip_sensitive_headers_a(a, h);
        }

        if (sandhi_http_status(r) == 303) { m = "GET"; b = 0; bl = 0; }
        u = next;
        hops = hops + 1;
        r = _sandhi_http_auto_once_a(a, m, u, h, b, bl, opts);
    }
    return r;
}

fn _sandhi_http_auto_follow(method, url, user_headers, body, body_len, opts, max_hops): i64 {
    return _sandhi_http_auto_follow_a(default_alloc(), method, url, user_headers, body, body_len, opts, max_hops);
}

fn sandhi_http_request_auto_a(a, method, url, user_headers, body, body_len, opts): i64 {
    # 1.3.2 — propagate the 0-RTT opt-in flag for the duration of
    # this dispatch. Mirrors `_sandhi_http_dispatch_a` in client.cyr;
    # the module-level `_sandhi_allow_0rtt` is read inside the 1.1
    # fallback's `_do_impl_a` eligibility check. Save+restore so
    # nested invocations (none today, but cheap insurance) don't
    # corrupt outer state. h2 path doesn't consult the flag — TLS
    # 1.3 0-RTT for h2 sits in a future milestone once the
    # CONNECTION preface vs. early-data ordering is settled.
    var prior_0rtt = _sandhi_allow_0rtt;
    _sandhi_allow_0rtt = sandhi_http_options_get_allow_0rtt(opts);
    # 1.3.3 — propagate cred-digest into the conn-finalize path so
    # the session cache distinguishes auth contexts. Same save+restore
    # shape as the 0-RTT flag. Available to the 1.1 fallback branch
    # of auto dispatch (h2 fast-path uses pool-cached conns whose
    # session was cached at finalize-time with the prior digest, so
    # the "right session for this auth context" decision happens at
    # the lookup that built the cached h2 conn — not on every reuse).
    var prior_cred = _sandhi_cred_digest;
    _sandhi_cred_digest = _sandhi_compute_cred_digest(user_headers);
    var r = 0;
    if (sandhi_http_options_follow(opts) == 1) {
        var hops = sandhi_http_options_hops(opts);
        r = _sandhi_http_auto_follow_a(a, method, url, user_headers, body, body_len, opts, hops);
    } else {
        r = _sandhi_http_auto_once_a(a, method, url, user_headers, body, body_len, opts);
    }
    _sandhi_cred_digest = prior_cred;
    _sandhi_allow_0rtt = prior_0rtt;
    return r;
}

fn sandhi_http_request_auto(method, url, user_headers, body, body_len, opts): i64 {
    return sandhi_http_request_auto_a(default_alloc(), method, url, user_headers, body, body_len, opts);
}

# Convenience verbs matching the 1.1 surface. Body-less methods drop
# body+body_len; body-bearing ones forward through.
# 1.2.3 Batch E: per-method `_auto_a` wrappers paint on
# `sandhi_http_request_auto_a` (which has been `_a`-threaded since
# 1.2.1). Bare versions stay as back-compat wrappers passing
# `default_alloc()`.
fn sandhi_http_get_auto_a(a, url, user_headers, opts): i64 {
    return sandhi_http_request_auto_a(a, "GET", url, user_headers, 0, 0, opts);
}

fn sandhi_http_get_auto(url, user_headers, opts): i64 {
    return sandhi_http_get_auto_a(default_alloc(), url, user_headers, opts);
}

fn sandhi_http_head_auto_a(a, url, user_headers, opts): i64 {
    return sandhi_http_request_auto_a(a, "HEAD", url, user_headers, 0, 0, opts);
}

fn sandhi_http_head_auto(url, user_headers, opts): i64 {
    return sandhi_http_head_auto_a(default_alloc(), url, user_headers, opts);
}

fn sandhi_http_post_auto_a(a, url, user_headers, body, body_len, opts): i64 {
    return sandhi_http_request_auto_a(a, "POST", url, user_headers, body, body_len, opts);
}

fn sandhi_http_post_auto(url, user_headers, body, body_len, opts): i64 {
    return sandhi_http_post_auto_a(default_alloc(), url, user_headers, body, body_len, opts);
}

fn sandhi_http_put_auto_a(a, url, user_headers, body, body_len, opts): i64 {
    return sandhi_http_request_auto_a(a, "PUT", url, user_headers, body, body_len, opts);
}

fn sandhi_http_put_auto(url, user_headers, body, body_len, opts): i64 {
    return sandhi_http_put_auto_a(default_alloc(), url, user_headers, body, body_len, opts);
}

fn sandhi_http_patch_auto_a(a, url, user_headers, body, body_len, opts): i64 {
    return sandhi_http_request_auto_a(a, "PATCH", url, user_headers, body, body_len, opts);
}

fn sandhi_http_patch_auto(url, user_headers, body, body_len, opts): i64 {
    return sandhi_http_patch_auto_a(default_alloc(), url, user_headers, body, body_len, opts);
}

fn sandhi_http_delete_auto_a(a, url, user_headers, opts): i64 {
    return sandhi_http_request_auto_a(a, "DELETE", url, user_headers, 0, 0, opts);
}

fn sandhi_http_delete_auto(url, user_headers, opts): i64 {
    return sandhi_http_delete_auto_a(default_alloc(), url, user_headers, opts);
}


# --- retry.cyr ---

# sandhi/http/retry — retry-with-backoff wrappers for idempotent methods.
#
# Thin composition on top of `_sandhi_http_dispatch`. Retries only on
# transient errors (CONNECT / TIMEOUT / DISCOVERY) or transient server
# responses (5xx). 4xx responses are NOT retried — caller's request is
# wrong and sending it again won't fix it.
#
# **Idempotent methods only** are exposed: GET, HEAD, PUT, DELETE. POST
# and PATCH are deliberately excluded because a retry could double-
# apply side effects — consumers that need POST-retry must opt in by
# calling `sandhi_http_post` in a loop with their own idempotency key.
#
# Backoff: exponential (backoff_ms *= 2 per attempt) capped at
# `max_backoff_ms`, with **AWS-style "full jitter"** applied since
# 0.9.3: each sleep is a uniform random value in [0, backoff_capped].
# This prevents thundering-herd alignment when many clients all
# fail at the same instant (e.g., upstream blip) and would otherwise
# all retry at exactly the same time.
#
# Retry policy struct (24 bytes):
#   +0   max_attempts       (int: default 3 — one original + two retries)
#   +8   initial_backoff_ms (int: default 50)
#   +16  max_backoff_ms     (int: default 2000)

enum SandhiRetryOff {
    SANDHI_RETRY_OFF_ATTEMPTS = 0;
    SANDHI_RETRY_OFF_INITIAL  = 8;
    SANDHI_RETRY_OFF_MAX      = 16;
}

var SANDHI_RETRY_STRUCT_SIZE = 24;
var SANDHI_RETRY_DEFAULT_ATTEMPTS = 3;
var SANDHI_RETRY_DEFAULT_INITIAL  = 50;
var SANDHI_RETRY_DEFAULT_MAX      = 2000;

# Allocate a retry-policy struct from `a`. Returns 0 on OOM.
fn sandhi_retry_new_a(a): i64 {
    var r = alloc_via(a, SANDHI_RETRY_STRUCT_SIZE);
    if (r == 0) { return 0; }
    store64(r + SANDHI_RETRY_OFF_ATTEMPTS, SANDHI_RETRY_DEFAULT_ATTEMPTS);
    store64(r + SANDHI_RETRY_OFF_INITIAL,  SANDHI_RETRY_DEFAULT_INITIAL);
    store64(r + SANDHI_RETRY_OFF_MAX,      SANDHI_RETRY_DEFAULT_MAX);
    return r;
}

fn sandhi_retry_new(): i64 {
    return sandhi_retry_new_a(default_alloc());
}

fn sandhi_retry_max_attempts(r, n): i64 {
    store64(r + SANDHI_RETRY_OFF_ATTEMPTS, n);
    return 0;
}

fn sandhi_retry_initial_backoff_ms(r, ms): i64 {
    store64(r + SANDHI_RETRY_OFF_INITIAL, ms);
    return 0;
}

fn sandhi_retry_max_backoff_ms(r, ms): i64 {
    store64(r + SANDHI_RETRY_OFF_MAX, ms);
    return 0;
}

fn _sandhi_retry_attempts(r): i64 {
    if (r == 0) { return SANDHI_RETRY_DEFAULT_ATTEMPTS; }
    return load64(r + SANDHI_RETRY_OFF_ATTEMPTS);
}

fn _sandhi_retry_initial(r): i64 {
    if (r == 0) { return SANDHI_RETRY_DEFAULT_INITIAL; }
    return load64(r + SANDHI_RETRY_OFF_INITIAL);
}

fn _sandhi_retry_max(r): i64 {
    if (r == 0) { return SANDHI_RETRY_DEFAULT_MAX; }
    return load64(r + SANDHI_RETRY_OFF_MAX);
}

# Full-jitter sleep: pick a uniform random value in [0, ceiling_ms]
# and sleep for it. Cryptographic quality not required; the only
# property we want is "different clients pick different values" so
# they don't all retry on the same millisecond. clock_now_ns() XOR
# folded into a 32-bit value is plenty.
fn _sandhi_retry_jitter_sleep(ceiling_ms): i64 {
    if (ceiling_ms <= 0) { return 0; }
    var ns = clock_now_ns();
    var mix = ns ^ (ns >> 17) ^ (ns >> 31);
    var rnd = mix & 0xFFFFFFFF;
    if (rnd < 0) { rnd = 0 - rnd; }
    var ms = rnd % (ceiling_ms + 1);
    sleep_ms(ms);
    return ms;
}

# 1 if `response` represents a transient failure worth retrying.
# Retryable: CONNECT, TIMEOUT, DISCOVERY (flaky resolver), 5xx.
# NOT retryable: PARSE, TLS, PROTOCOL, REMOTE (non-5xx), AUTH, INTERNAL, 4xx.
fn _sandhi_retry_should_retry(response): i64 {
    var ek = sandhi_http_err_kind(response);
    if (ek == SANDHI_ERR_CONNECT)   { return 1; }
    if (ek == SANDHI_ERR_TIMEOUT)   { return 1; }
    if (ek == SANDHI_ERR_DISCOVERY) { return 1; }
    var status = sandhi_http_status(response);
    if (status >= 500 && status <= 599) { return 1; }
    return 0;
}

# Core retry driver. Runs up to max_attempts total (original + retries).
# Sleeps initial_backoff_ms → 2× → 4× ... capped at max_backoff_ms
# between attempts. Returns the last response (successful or final
# failure — caller inspects err_kind / status).
#
# Each attempt routes through `sandhi_http_request_auto` since 0.9.5
# so retries inherit h2 selection: if the attached pool has an h2
# conn for the route, the retry uses h2; otherwise it falls back to
# the 1.1 path. Pre-0.9.5 retries went straight to
# `_sandhi_http_dispatch` and were 1.1-only regardless of pool state.
# 1.2.1: `_a` threads `a` through every attempt (each call to
# sandhi_http_request_auto_a routes through the auto-dispatch path
# that itself threads `a` to per-hop _do_a / sandhi_h2_request_a /
# pool_take_h2 routes uniformly). One subtle note: each attempt's
# response struct lives in `a`; if the caller plans to inspect the
# *intermediate* failed response between retries, they must save
# its data before the next attempt — sandhi may overwrite the arena
# bytes when an arena_allocator is reused. Practically retry callers
# only inspect the last response, which the back-compat shape
# already returns.
fn _sandhi_http_retry_a(a, method, url, user_headers, body, body_len, opts, retry): i64 {
    var attempts = _sandhi_retry_attempts(retry);
    var backoff = _sandhi_retry_initial(retry);
    var max_backoff = _sandhi_retry_max(retry);
    var tried = 0;
    var r = sandhi_http_request_auto_a(a, method, url, user_headers, body, body_len, opts);
    tried = 1;
    while (tried < attempts) {
        if (_sandhi_retry_should_retry(r) == 0) { return r; }
        var ceiling = backoff;
        if (ceiling > max_backoff) { ceiling = max_backoff; }
        _sandhi_retry_jitter_sleep(ceiling);
        backoff = backoff * 2;
        if (backoff > max_backoff) { backoff = max_backoff; }
        r = sandhi_http_request_auto_a(a, method, url, user_headers, body, body_len, opts);
        tried = tried + 1;
    }
    return r;
}

fn _sandhi_http_retry(method, url, user_headers, body, body_len, opts, retry): i64 {
    return _sandhi_http_retry_a(default_alloc(), method, url, user_headers, body, body_len, opts, retry);
}

# ================================================================
# Public verbs — idempotent methods only
# ================================================================

# 1.2.3 Batch E: per-method `_retry_a` wrappers paint on
# `_sandhi_http_retry_a` (which has been `_a`-threaded since
# 1.2.1). Bare versions stay as back-compat wrappers passing
# `default_alloc()`.
fn sandhi_http_get_retry_a(a, url, user_headers, opts, retry): i64 {
    return _sandhi_http_retry_a(a, "GET", url, user_headers, 0, 0, opts, retry);
}

fn sandhi_http_get_retry(url, user_headers, opts, retry): i64 {
    return sandhi_http_get_retry_a(default_alloc(), url, user_headers, opts, retry);
}

fn sandhi_http_head_retry_a(a, url, user_headers, opts, retry): i64 {
    return _sandhi_http_retry_a(a, "HEAD", url, user_headers, 0, 0, opts, retry);
}

fn sandhi_http_head_retry(url, user_headers, opts, retry): i64 {
    return sandhi_http_head_retry_a(default_alloc(), url, user_headers, opts, retry);
}

fn sandhi_http_put_retry_a(a, url, user_headers, body, body_len, opts, retry): i64 {
    return _sandhi_http_retry_a(a, "PUT", url, user_headers, body, body_len, opts, retry);
}

fn sandhi_http_put_retry(url, user_headers, body, body_len, opts, retry): i64 {
    return sandhi_http_put_retry_a(default_alloc(), url, user_headers, body, body_len, opts, retry);
}

fn sandhi_http_delete_retry_a(a, url, user_headers, opts, retry): i64 {
    return _sandhi_http_retry_a(a, "DELETE", url, user_headers, 0, 0, opts, retry);
}

fn sandhi_http_delete_retry(url, user_headers, opts, retry): i64 {
    return sandhi_http_delete_retry_a(default_alloc(), url, user_headers, opts, retry);
}


# --- sse.cyr ---

# sandhi/http/sse — Server-Sent Events parser.
#
# Implements the WHATWG SSE/EventSource parse spec at the level we
# actually need: event dispatch with name/data/id/retry fields,
# multi-line `data:` concatenation, comment skipping, flexible line
# endings (CRLF / LF / CR).
#
# Reference: https://html.spec.whatwg.org/multipage/server-sent-events.html
#
# Event struct (40 bytes):
#   +0   event_name   (cstr — "message" default, or last `event:` value)
#   +8   data         (cstr — lines concatenated with \n, no trailing \n)
#   +16  id           (cstr — last `id:` value, or 0 if unset)
#   +24  retry_ms     (int — last `retry:` value as int, or -1 if unset)
#   +32  reserved     (future use — origin, tag flags, etc.)
#
# Parser shape:
#   sandhi_sse_parse_buffer(buf, blen, remaining_out) → vec of events.
#   remaining_out receives the byte offset of the first unconsumed byte
#   so callers doing streaming reads can continue from there.

enum SandhiSseOff {
    SANDHI_SSE_OFF_EVENT  = 0;
    SANDHI_SSE_OFF_DATA   = 8;
    SANDHI_SSE_OFF_ID     = 16;
    SANDHI_SSE_OFF_RETRY  = 24;
    SANDHI_SSE_OFF_RES    = 32;
}

var SANDHI_SSE_EVENT_STRUCT_SIZE = 40;
var SANDHI_SSE_RETRY_UNSET = 0 - 1;

fn _sandhi_sse_dup_a(a, s): i64 {
    if (s == 0) { return 0; }
    var n = strlen(s);
    var out = alloc_via(a, n + 1);
    if (out == 0) { return 0; }
    memcpy(out, s, n);
    store8(out + n, 0);
    return out;
}

fn _sandhi_sse_dup(s): i64 {
    return _sandhi_sse_dup_a(default_alloc(), s);
}

fn sandhi_sse_event_new_a(a, event_name, data, id, retry_ms): i64 {
    var e = alloc_via(a, SANDHI_SSE_EVENT_STRUCT_SIZE);
    if (e == 0) { return 0; }
    store64(e + SANDHI_SSE_OFF_EVENT, event_name);
    store64(e + SANDHI_SSE_OFF_DATA, data);
    store64(e + SANDHI_SSE_OFF_ID, id);
    store64(e + SANDHI_SSE_OFF_RETRY, retry_ms);
    store64(e + SANDHI_SSE_OFF_RES, 0);
    return e;
}

fn sandhi_sse_event_new(event_name, data, id, retry_ms): i64 {
    return sandhi_sse_event_new_a(default_alloc(), event_name, data, id, retry_ms);
}

fn sandhi_sse_event_name(e): i64 { return load64(e + SANDHI_SSE_OFF_EVENT); }
fn sandhi_sse_event_data(e): i64 { return load64(e + SANDHI_SSE_OFF_DATA); }
fn sandhi_sse_event_id(e): i64 { return load64(e + SANDHI_SSE_OFF_ID); }
fn sandhi_sse_event_retry(e): i64 { return load64(e + SANDHI_SSE_OFF_RETRY); }

# ================================================================
# Internal: line-at-a-time parsing helpers
# ================================================================

# Return offset of the byte just past the next line terminator (CRLF,
# LF, or CR — WHATWG spec lets servers use any of the three). Returns
# (0 - 1) if no complete line in [start, end).
fn _sandhi_sse_next_line_end(buf, start, end): i64 {
    var i = start;
    while (i < end) {
        var c = load8(buf + i);
        if (c == 13) {
            # CR — check for trailing LF (CRLF).
            if (i + 1 < end && load8(buf + i + 1) == 10) { return i + 2; }
            return i + 1;
        }
        if (c == 10) { return i + 1; }
        i = i + 1;
    }
    return 0 - 1;
}

# 1 if line is empty (zero bytes before terminator), 0 otherwise.
fn _sandhi_sse_line_empty(buf, line_start, line_end): i64 {
    var p = line_start;
    while (p < line_end) {
        var c = load8(buf + p);
        if (c == 13 || c == 10) { return 1; }
        return 0;
    }
    return 1;  # line_start == line_end (defensive)
}

# Parse one field line into (field_name, value). Writes cstr pointers
# into out_name_ptr / out_value_ptr. Returns 0 on a valid field, 1 if
# the line is a comment (starts with ':'), 2 if malformed.
#
# Format rules (WHATWG):
#   - If line starts with ':' → comment, ignore.
#   - If line has no ':' → whole line is the field name, value is "".
#   - Otherwise: name = up-to-first-':', value = after-':'-with-optional-leading-SP-stripped.
fn _sandhi_sse_parse_field_a(a, buf, line_start, line_end, out_name_ptr, out_value_ptr): i64 {
    # Strip trailing CR/LF from line_end.
    var le = line_end;
    if (le > line_start && load8(buf + le - 1) == 10) { le = le - 1; }
    if (le > line_start && load8(buf + le - 1) == 13) { le = le - 1; }

    if (le == line_start) { return 2; }  # empty — caller shouldn't reach here

    if (load8(buf + line_start) == 58) {
        return 1;  # comment
    }

    # Find first ':'.
    var colon = line_start;
    while (colon < le && load8(buf + colon) != 58) { colon = colon + 1; }

    var name_len = colon - line_start;
    if (name_len == 0) { return 2; }
    var name = alloc_via(a, name_len + 1);
    if (name == 0) { return 2; }
    memcpy(name, buf + line_start, name_len);
    store8(name + name_len, 0);

    var vstart = colon;
    if (vstart < le && load8(buf + vstart) == 58) {
        vstart = vstart + 1;
        # Strip optional leading SPACE (only one, per spec).
        if (vstart < le && load8(buf + vstart) == 32) { vstart = vstart + 1; }
    }
    var value_len = le - vstart;
    var value = alloc_via(a, value_len + 1);
    if (value == 0) { return 2; }
    if (value_len > 0) { memcpy(value, buf + vstart, value_len); }
    store8(value + value_len, 0);

    store64(out_name_ptr, name);
    store64(out_value_ptr, value);
    return 0;
}

fn _sandhi_sse_parse_field(buf, line_start, line_end, out_name_ptr, out_value_ptr): i64 {
    return _sandhi_sse_parse_field_a(default_alloc(), buf, line_start, line_end, out_name_ptr, out_value_ptr);
}

# Append a new data-line to an existing data cstr (or build fresh).
# Caller passes current cstr (may be 0). Returns fresh cstr that's
# `current + "\n" + addition`. No trailing newline.
fn _sandhi_sse_data_append_a(a, current, addition): i64 {
    if (current == 0) { return _sandhi_sse_dup_a(a, addition); }
    var cur_len = strlen(current);
    var add_len = strlen(addition);
    var out = alloc_via(a, cur_len + 1 + add_len + 1);
    if (out == 0) { return 0; }
    memcpy(out, current, cur_len);
    store8(out + cur_len, 10);  # \n between data lines per spec
    memcpy(out + cur_len + 1, addition, add_len);
    store8(out + cur_len + 1 + add_len, 0);
    return out;
}

fn _sandhi_sse_data_append(current, addition): i64 {
    return _sandhi_sse_data_append_a(default_alloc(), current, addition);
}

# ================================================================
# Buffer parse — extract complete events
# ================================================================
#
# Returns vec of sandhi_sse_event pointers. Writes the byte offset of
# the first un-consumed byte into *remaining_out. Events are emitted
# only on complete dispatch — a blank line after one or more field
# lines. Partial events (no terminating blank line) stay in the
# remaining buffer for the next call.

# 0.9.1 P1 — SSE parse state moved off module-scope into an
# explicit ctx struct allocated per `sandhi_sse_parse` call. The
# previous module-scope vars (`_sandhi_sse_cur_event` etc.) made
# the parser non-reentrant: a callback fired during stream
# dispatch that itself parsed SSE (e.g., a chained MCP-over-SSE
# call) would clobber the outer parse's in-progress event. With
# per-call ctx, nested calls are independent.
#
# Ctx struct (40 bytes):
#   +0   cur_event   (cstr; defaults to "message" per WHATWG)
#   +8   cur_data    (cstr; null until first data field)
#   +16  cur_id      (cstr; null between explicit id sets)
#   +24  cur_retry   (int; SANDHI_SSE_RETRY_UNSET sentinel)
#   +32  has_fields  (int; 1 once any field has been observed in
#                     the current event)
enum _SandhiSseCtxOff {
    _SANDHI_SSE_CTX_OFF_EVENT      = 0;
    _SANDHI_SSE_CTX_OFF_DATA       = 8;
    _SANDHI_SSE_CTX_OFF_ID         = 16;
    _SANDHI_SSE_CTX_OFF_RETRY      = 24;
    _SANDHI_SSE_CTX_OFF_HAS_FIELDS = 32;
}

var _SANDHI_SSE_CTX_STRUCT_SIZE = 40;

fn _sandhi_sse_ctx_new_a(a): i64 {
    var c = alloc_via(a, _SANDHI_SSE_CTX_STRUCT_SIZE);
    if (c == 0) { return 0; }
    store64(c + _SANDHI_SSE_CTX_OFF_EVENT, _sandhi_sse_dup_a(a, "message"));
    store64(c + _SANDHI_SSE_CTX_OFF_DATA, 0);
    store64(c + _SANDHI_SSE_CTX_OFF_ID, 0);
    store64(c + _SANDHI_SSE_CTX_OFF_RETRY, SANDHI_SSE_RETRY_UNSET);
    store64(c + _SANDHI_SSE_CTX_OFF_HAS_FIELDS, 0);
    return c;
}

fn _sandhi_sse_ctx_new(): i64 {
    return _sandhi_sse_ctx_new_a(default_alloc());
}

fn _sandhi_sse_ctx_reset_a(a, c): i64 {
    store64(c + _SANDHI_SSE_CTX_OFF_EVENT, _sandhi_sse_dup_a(a, "message"));
    store64(c + _SANDHI_SSE_CTX_OFF_DATA, 0);
    store64(c + _SANDHI_SSE_CTX_OFF_ID, 0);
    store64(c + _SANDHI_SSE_CTX_OFF_RETRY, SANDHI_SSE_RETRY_UNSET);
    store64(c + _SANDHI_SSE_CTX_OFF_HAS_FIELDS, 0);
    return 0;
}

fn _sandhi_sse_ctx_reset(c): i64 {
    return _sandhi_sse_ctx_reset_a(default_alloc(), c);
}

# 0.9.1 P1 — 1 if the wire bytes for this line's value (after the
# colon + optional leading space, before any trailing CR/LF) contain
# any U+0000 NULL. Used by the id-field branch to honor the WHATWG
# spec rule that NUL-bearing ids must be ignored. Re-derives the
# value byte range from the same `buf, line_start, line_end` that
# `_sandhi_sse_parse_field` walks — the parsed value cstr is no
# good here because cstr operations stop at the first NUL.
fn _sandhi_sse_value_has_nul(buf, line_start, line_end): i64 {
    var le = line_end;
    if (le > line_start && load8(buf + le - 1) == 10) { le = le - 1; }
    if (le > line_start && load8(buf + le - 1) == 13) { le = le - 1; }
    var colon = line_start;
    while (colon < le && load8(buf + colon) != 58) { colon = colon + 1; }
    var vstart = colon;
    if (vstart < le && load8(buf + vstart) == 58) {
        vstart = vstart + 1;
        if (vstart < le && load8(buf + vstart) == 32) { vstart = vstart + 1; }
    }
    var i = vstart;
    while (i < le) {
        if (load8(buf + i) == 0) { return 1; }
        i = i + 1;
    }
    return 0;
}

fn _sandhi_sse_apply_line_a(a, ctx, buf, line_start, line_end): i64 {
    var name_cell = alloc_via(a, 8);
    var value_cell = alloc_via(a, 8);
    if (name_cell == 0 || value_cell == 0) { return 0; }
    store64(name_cell, 0);
    store64(value_cell, 0);
    var rc = _sandhi_sse_parse_field_a(a, buf, line_start, line_end, name_cell, value_cell);
    if (rc != 0) { return 0; }  # comment or malformed — skip
    var name = load64(name_cell);
    var value = load64(value_cell);
    store64(ctx + _SANDHI_SSE_CTX_OFF_HAS_FIELDS, 1);
    if (streq(name, "event") == 1) {
        store64(ctx + _SANDHI_SSE_CTX_OFF_EVENT, value);
    } elif (streq(name, "data") == 1) {
        var prev_data = load64(ctx + _SANDHI_SSE_CTX_OFF_DATA);
        store64(ctx + _SANDHI_SSE_CTX_OFF_DATA,
        _sandhi_sse_data_append_a(a, prev_data, value));
    } elif (streq(name, "id") == 1) {
        if (_sandhi_sse_value_has_nul(buf, line_start, line_end) == 0) {
            store64(ctx + _SANDHI_SSE_CTX_OFF_ID, value);
        }
    } elif (streq(name, "retry") == 1) {
        store64(ctx + _SANDHI_SSE_CTX_OFF_RETRY, atoi(value));
    }
    # Unknown field names: silently ignore per WHATWG.
    return 0;
}

fn _sandhi_sse_apply_line(ctx, buf, line_start, line_end): i64 {
    return _sandhi_sse_apply_line_a(default_alloc(), ctx, buf, line_start, line_end);
}

# Top-level parse into `a`. The fresh ctx struct, per-event dups,
# event vec, and event structs all flow through `a`. Re-entrant
# (a callback that itself calls sandhi_sse_parse_a runs against its
# own ctx and can't clobber an outer parse).
fn sandhi_sse_parse_a(a, buf, blen, remaining_out): i64 {
    var ctx = _sandhi_sse_ctx_new_a(a);

    var events = vec_new_a(a);
    # 1.2.8 OOM guard: subsequent `vec_push_a(a, events, ev)` calls
    # would SIGSEGV on null events; bail early so the caller gets
    # `events == 0` and can detect OOM the same way they detect any
    # other vec construction failure.
    if (events == 0) {
        store64(remaining_out, 0);
        return 0;
    }
    if (buf == 0 || blen <= 0) {
        store64(remaining_out, 0);
        return events;
    }

    var consumed = 0;
    var pos = 0;
    while (pos < blen) {
        var line_end = _sandhi_sse_next_line_end(buf, pos, blen);
        if (line_end < 0) { pos = blen; }
        else {
            if (_sandhi_sse_line_empty(buf, pos, line_end) == 1) {
                if (load64(ctx + _SANDHI_SSE_CTX_OFF_HAS_FIELDS) == 1) {
                    var d = load64(ctx + _SANDHI_SSE_CTX_OFF_DATA);
                    if (d == 0) { d = _sandhi_sse_dup_a(a, ""); }
                    var ev = sandhi_sse_event_new_a(a,
                    load64(ctx + _SANDHI_SSE_CTX_OFF_EVENT), d,
                    load64(ctx + _SANDHI_SSE_CTX_OFF_ID),
                    load64(ctx + _SANDHI_SSE_CTX_OFF_RETRY));
                    vec_push_a(a, events, ev);
                    _sandhi_sse_ctx_reset_a(a, ctx);
                }
                consumed = line_end;
            } else {
                _sandhi_sse_apply_line_a(a, ctx, buf, pos, line_end);
                consumed = line_end;
            }
            pos = line_end;
        }
    }
    store64(remaining_out, consumed);
    return events;
}

fn sandhi_sse_parse(buf, blen, remaining_out): i64 {
    return sandhi_sse_parse_a(default_alloc(), buf, blen, remaining_out);
}


# --- stream.cyr ---

# sandhi/http/stream — streaming HTTP request / SSE dispatcher.
#
# Sends an HTTP request, reads the response incrementally, feeds the
# body bytes through the SSE parser, and calls a callback per event.
# Supports both `Transfer-Encoding: chunked` and close-delimited
# bodies — both are common for SSE streams (`text/event-stream`).
#
# Callback contract:
#   fn callback(ctx, event) -> int
#     return 1 to keep consuming the stream
#     return 0 to stop the stream early (connection closed cleanly)
#
# Result struct (32 bytes):
#   +0   http_status        (int — 0 if no status line ever seen)
#   +8   events_dispatched  (int — how many events the callback got)
#   +16  err_kind           (int — SandhiErrorKind on failure, 0 on clean)
#   +24  stopped_by_cb      (int — 1 if cb returned 0, 0 if hit EOF/err)
#
# Kept under the Cyrius local-count threshold by delegating the
# per-chunk work to helper fns.

enum SandhiStreamOff {
    SANDHI_STREAM_OFF_STATUS  = 0;
    SANDHI_STREAM_OFF_EVENTS  = 8;
    SANDHI_STREAM_OFF_ERR     = 16;
    SANDHI_STREAM_OFF_STOPPED = 24;
}

var SANDHI_STREAM_RESULT_SIZE = 32;
var _SANDHI_STREAM_READ_CHUNK = 16384;
var _SANDHI_STREAM_BUF_CAP    = 262144;

fn _sandhi_stream_result_a(a, status, events, err, stopped): i64 {
    var r = alloc_via(a, SANDHI_STREAM_RESULT_SIZE);
    if (r == 0) { return 0; }
    store64(r + SANDHI_STREAM_OFF_STATUS, status);
    store64(r + SANDHI_STREAM_OFF_EVENTS, events);
    store64(r + SANDHI_STREAM_OFF_ERR, err);
    store64(r + SANDHI_STREAM_OFF_STOPPED, stopped);
    return r;
}

fn _sandhi_stream_result(status, events, err, stopped): i64 {
    return _sandhi_stream_result_a(default_alloc(), status, events, err, stopped);
}

fn sandhi_stream_status(r): i64 { return load64(r + SANDHI_STREAM_OFF_STATUS); }
fn sandhi_stream_events(r): i64 { return load64(r + SANDHI_STREAM_OFF_EVENTS); }
fn sandhi_stream_err(r): i64 { return load64(r + SANDHI_STREAM_OFF_ERR); }
fn sandhi_stream_stopped(r): i64 { return load64(r + SANDHI_STREAM_OFF_STOPPED); }

# ================================================================
# Buffer helpers
# ================================================================
#
# A stream-buffer is a cstr-shaped alloc with len + cap bookkeeping.
# Bytes are appended from the network at the tail and consumed from
# the head as SSE parses complete events.

enum SandhiStreamBufOff {
    SANDHI_SB_OFF_PTR = 0;
    SANDHI_SB_OFF_LEN = 8;
    SANDHI_SB_OFF_CAP = 16;
}

fn _sandhi_sb_new_a(a, cap): i64 {
    var sb = alloc_via(a, 24);
    if (sb == 0) { return 0; }
    var buf = alloc_via(a, cap + 1);
    if (buf == 0) { return 0; }
    store64(sb + SANDHI_SB_OFF_PTR, buf);
    store64(sb + SANDHI_SB_OFF_LEN, 0);
    store64(sb + SANDHI_SB_OFF_CAP, cap);
    return sb;
}

fn _sandhi_sb_new(cap): i64 {
    return _sandhi_sb_new_a(default_alloc(), cap);
}

fn _sandhi_sb_ptr(sb): i64 { return load64(sb + SANDHI_SB_OFF_PTR); }
fn _sandhi_sb_len(sb): i64 { return load64(sb + SANDHI_SB_OFF_LEN); }
fn _sandhi_sb_cap(sb): i64 { return load64(sb + SANDHI_SB_OFF_CAP); }

# Append `n` bytes from `src` onto the buffer. Returns 0 on success,
# -1 on overflow (caller decides whether to grow or drop).
fn _sandhi_sb_append(sb, src, n): i64 {
    var len = _sandhi_sb_len(sb);
    var cap = _sandhi_sb_cap(sb);
    if (len + n > cap) { return 0 - 1; }
    var p = _sandhi_sb_ptr(sb);
    memcpy(p + len, src, n);
    store64(sb + SANDHI_SB_OFF_LEN, len + n);
    return 0;
}

# Drop the first `n` bytes, shifting the remainder left.
fn _sandhi_sb_consume(sb, n): i64 {
    var len = _sandhi_sb_len(sb);
    if (n <= 0) { return 0; }
    if (n >= len) {
        store64(sb + SANDHI_SB_OFF_LEN, 0);
        return 0;
    }
    var p = _sandhi_sb_ptr(sb);
    memcpy(p, p + n, len - n);
    store64(sb + SANDHI_SB_OFF_LEN, len - n);
    return 0;
}

# ================================================================
# HTTP header drain (incremental)
# ================================================================

# Find `\r\n\r\n` in sb. Returns byte offset just past the marker, or
# -1 if not yet present.
fn _sandhi_stream_headers_end(sb): i64 {
    var p = _sandhi_sb_ptr(sb);
    var n = _sandhi_sb_len(sb);
    var i = 0;
    while (i + 3 < n) {
        if (load8(p + i) == 13 && load8(p + i + 1) == 10
        && load8(p + i + 2) == 13 && load8(p + i + 3) == 10) {
            return i + 4;
        }
        i = i + 1;
    }
    return 0 - 1;
}

# ================================================================
# Chunked decoder state machine
# ================================================================
#
# Chunked = {size-hex "\r\n" data-bytes "\r\n"}... "0\r\n\r\n"
# State struct (16 bytes):
#   +0   remaining_in_chunk (int — bytes left in current chunk, -1 if reading size)
#   +8   done               (int — 1 when terminal 0-length chunk seen)
enum SandhiChunkOff {
    SANDHI_CHUNK_OFF_REM  = 0;
    SANDHI_CHUNK_OFF_DONE = 8;
}

fn _sandhi_chunk_state_new_a(a): i64 {
    var c = alloc_via(a, 16);
    if (c == 0) { return 0; }
    store64(c, 0 - 1);  # reading size
    store64(c + 8, 0);
    return c;
}

fn _sandhi_chunk_state_new(): i64 {
    return _sandhi_chunk_state_new_a(default_alloc());
}

fn _sandhi_chunk_rem(c): i64 { return load64(c + SANDHI_CHUNK_OFF_REM); }
fn _sandhi_chunk_done(c): i64 { return load64(c + SANDHI_CHUNK_OFF_DONE); }

fn _sandhi_chunk_set_rem(c, v): i64 { store64(c + SANDHI_CHUNK_OFF_REM, v); return 0; }
fn _sandhi_chunk_set_done(c, v): i64 { store64(c + SANDHI_CHUNK_OFF_DONE, v); return 0; }

# Parse one hex chunk-size line out of sb starting at offset 0.
# Returns (size | (consumed_offset << 32)), or -1 if no complete line yet.
fn _sandhi_chunk_parse_size(sb): i64 {
    var p = _sandhi_sb_ptr(sb);
    var n = _sandhi_sb_len(sb);
    var size = 0;
    var seen_digit = 0;
    var i = 0;
    var scanning = 1;
    while (scanning == 1 && i < n) {
        var c = load8(p + i);
        if (c >= 48 && c <= 57)      { size = size * 16 + (c - 48); seen_digit = 1; i = i + 1; }
        elif (c >= 97 && c <= 102)   { size = size * 16 + (c - 87); seen_digit = 1; i = i + 1; }
        elif (c >= 65 && c <= 70)    { size = size * 16 + (c - 55); seen_digit = 1; i = i + 1; }
        else { scanning = 0; }
    }
    # Skip chunk extensions (";name=value" etc.) up to CRLF/LF.
    while (i < n && load8(p + i) != 13 && load8(p + i) != 10) { i = i + 1; }
    if (i >= n) { return 0 - 1; }
    if (load8(p + i) == 13) {
        i = i + 1;
        if (i >= n) { return 0 - 1; }
    }
    if (load8(p + i) != 10) { return 0 - 1; }
    i = i + 1;
    if (seen_digit == 0) { return 0 - 1; }
    return size | (i << 32);
}

# ================================================================
# Dispatch events through the callback
# ================================================================

# Dispatch a vec of events. Returns the number dispatched successfully.
# If the callback returns 0, stops and writes 1 into *stop_out.
fn _sandhi_stream_dispatch(events, cb, ctx, stop_out): i64 {
    var n = vec_len(events);
    var i = 0;
    var dispatched = 0;
    while (i < n) {
        var ev = vec_get(events, i);
        var r = fncall2(cb, ctx, ev);
        dispatched = dispatched + 1;
        if (r == 0) {
            store64(stop_out, 1);
            return dispatched;
        }
        i = i + 1;
    }
    store64(stop_out, 0);
    return dispatched;
}

# Parse any complete SSE events currently in the body-buffer, dispatch
# them, consume the parsed bytes. Updates total_events in-place.
fn _sandhi_stream_feed_sse_a(a, body_buf, cb, ctx, total_events_ptr, stop_out): i64 {
    var p = _sandhi_sb_ptr(body_buf);
    var n = _sandhi_sb_len(body_buf);
    if (n == 0) { return 0; }
    var rem_cell = alloc_via(a, 8);
    if (rem_cell == 0) { return 0; }
    store64(rem_cell, 0);
    var events = sandhi_sse_parse_a(a, p, n, rem_cell);
    var consumed = load64(rem_cell);
    _sandhi_sb_consume(body_buf, consumed);
    var dispatched = _sandhi_stream_dispatch(events, cb, ctx, stop_out);
    store64(total_events_ptr, load64(total_events_ptr) + dispatched);
    return 0;
}

fn _sandhi_stream_feed_sse(body_buf, cb, ctx, total_events_ptr, stop_out): i64 {
    return _sandhi_stream_feed_sse_a(default_alloc(), body_buf, cb, ctx, total_events_ptr, stop_out);
}

# ================================================================
# Public API
# ================================================================

# Open the TLS-or-plain connection, send the HTTP request, stream the
# response body through the SSE parser calling `cb(ctx, event)` for
# each parsed event. `method` is "GET" or "POST"; body may be 0.
#
# Returns a stream-result struct.
fn sandhi_http_stream_a(a, url, method, user_headers, body, body_len, cb, ctx): i64 {
    return sandhi_http_stream_opts_a(a, url, method, user_headers, body, body_len, cb, ctx, 0);
}

fn sandhi_http_stream(url, method, user_headers, body, body_len, cb, ctx): i64 {
    return sandhi_http_stream_a(default_alloc(), url, method, user_headers, body, body_len, cb, ctx);
}

# Opts-aware variant — honors `max_response_bytes` for the stream
# buffers (header drain, body accumulator, chunked-decode output).
fn sandhi_http_stream_opts_a(a, url, method, user_headers, body, body_len, cb, ctx, opts): i64 {
    var u = sandhi_url_parse_a(a, url);
    if (u == 0) { return _sandhi_stream_result_a(a, 0, 0, SANDHI_ERR_PARSE, 0); }

    var addr = _sandhi_client_resolve_a(a, sandhi_url_host(u));
    if (addr == 0 - 1) { return _sandhi_stream_result_a(a, 0, 0, SANDHI_ERR_DISCOVERY, 0); }

    var use_tls = 0;
    if (sandhi_url_scheme(u) == SANDHI_URL_HTTPS) { use_tls = 1; }
    var read_ms = sandhi_http_options_get_read_ms(opts);
    var write_ms = sandhi_http_options_get_write_ms(opts);
    var connect_ms = sandhi_http_options_get_connect_ms(opts);
    var total_ms = sandhi_http_options_get_total_ms(opts);
    # Compute deadline once at entry — shared with the body loop's
    # event-by-event timing. Streams are typically long-lived, so a
    # total_ms here means "the consumer wants to bail out after this
    # many ms of overall stream time", not "individual event timing".
    var deadline_ms = 0;
    if (total_ms > 0) { deadline_ms = clock_now_ms() + total_ms; }
    var eff_connect = _sandhi_http_clamp_ms(connect_ms, deadline_ms);
    if (eff_connect == 0 - 1) {
        return _sandhi_stream_result_a(a, 0, 0, SANDHI_ERR_TIMEOUT, 0);
    }
    var conn = sandhi_conn_open_fully_timed_a(a, addr, sandhi_url_port(u), use_tls, sandhi_url_host(u),
    eff_connect, read_ms, write_ms);
    if (conn == 0) {
        var oe = sandhi_conn_last_open_err();
        if (oe == SANDHI_CONN_OPEN_TIMEOUT) { return _sandhi_stream_result_a(a, 0, 0, SANDHI_ERR_TIMEOUT, 0); }
        if (oe == SANDHI_CONN_OPEN_TLS)     { return _sandhi_stream_result_a(a, 0, 0, SANDHI_ERR_TLS, 0); }
        return _sandhi_stream_result_a(a, 0, 0, SANDHI_ERR_CONNECT, 0);
    }

    var full_path = _sandhi_client_full_path_a(a, u);
    var host_hdr = _sandhi_client_host_header_a(a, u);
    var hs = user_headers;
    if (hs == 0) { hs = sandhi_headers_new_a(a); }
    if (sandhi_headers_has(hs, "Accept") == 0) {
        sandhi_headers_set_a(a, hs, "Accept", "text/event-stream");
    }
    var req = _sandhi_client_build_request_a(a, method, full_path, host_hdr, hs, body_len);

    var cap = sandhi_http_options_bytes(opts);
    return _sandhi_stream_run_a(a, conn, req, body, body_len, cb, ctx, cap, deadline_ms);
}

fn sandhi_http_stream_opts(url, method, user_headers, body, body_len, cb, ctx, opts): i64 {
    return sandhi_http_stream_opts_a(default_alloc(), url, method, user_headers, body, body_len, cb, ctx, opts);
}

# Send the request + drive the read loop. Extracted so the caller
# stays under the Cyrius local-count threshold. Maps timeout errno
# (SO_RCVTIMEO / SO_SNDTIMEO) to SANDHI_ERR_TIMEOUT; any other I/O
# fail maps to SANDHI_ERR_CONNECT. deadline_ms (0 = none) bounds the
# overall stream lifetime — body-loop checks it between event reads.
fn _sandhi_stream_run_a(a, conn, req, body, body_len, cb, ctx, cap, deadline_ms): i64 {
    var req_data = str_data(req);
    var req_len = strlen(req_data);
    var sw = sandhi_conn_send_all(conn, req_data, req_len);
    if (sw == 0 - _SANDHI_EAGAIN) {
        sandhi_conn_close(conn);
        return _sandhi_stream_result_a(a, 0, 0, SANDHI_ERR_TIMEOUT, 0);
    }
    if (sw < 0) {
        sandhi_conn_close(conn);
        return _sandhi_stream_result_a(a, 0, 0, SANDHI_ERR_CONNECT, 0);
    }
    if (body_len > 0 && body != 0) {
        var sb = sandhi_conn_send_all(conn, body, body_len);
        if (sb == 0 - _SANDHI_EAGAIN) {
            sandhi_conn_close(conn);
            return _sandhi_stream_result_a(a, 0, 0, SANDHI_ERR_TIMEOUT, 0);
        }
        if (sb < 0) {
            sandhi_conn_close(conn);
            return _sandhi_stream_result_a(a, 0, 0, SANDHI_ERR_CONNECT, 0);
        }
    }
    var out = _sandhi_stream_read_loop_a(a, conn, cb, ctx, cap, deadline_ms);
    sandhi_conn_close(conn);
    return out;
}

fn _sandhi_stream_run(conn, req, body, body_len, cb, ctx, cap, deadline_ms): i64 {
    return _sandhi_stream_run_a(default_alloc(), conn, req, body, body_len, cb, ctx, cap, deadline_ms);
}

# Read loop: drain headers, then feed body bytes through SSE parser.
# Returns stream-result. Handles chunked or close-delimited bodies.
fn _sandhi_stream_read_loop_a(a, conn, cb, ctx, cap, deadline_ms): i64 {
    var header_sb = _sandhi_sb_new_a(a, cap);
    var scratch = alloc_via(a, _SANDHI_STREAM_READ_CHUNK);
    if (header_sb == 0 || scratch == 0) {
        return _sandhi_stream_result_a(a, 0, 0, SANDHI_ERR_INTERNAL, 0);
    }

    # Drain header block.
    var header_end = 0 - 1;
    while (header_end < 0) {
        var n = sandhi_conn_recv(conn, scratch, _SANDHI_STREAM_READ_CHUNK);
        if (n == 0 - _SANDHI_EAGAIN) { return _sandhi_stream_result_a(a, 0, 0, SANDHI_ERR_TIMEOUT, 0); }
        if (n < 0) { return _sandhi_stream_result_a(a, 0, 0, SANDHI_ERR_CONNECT, 0); }
        if (n == 0) { return _sandhi_stream_result_a(a, 0, 0, SANDHI_ERR_PROTOCOL, 0); }
        if (_sandhi_sb_append(header_sb, scratch, n) < 0) {
            return _sandhi_stream_result_a(a, 0, 0, SANDHI_ERR_PROTOCOL, 0);
        }
        header_end = _sandhi_stream_headers_end(header_sb);
    }

    # Parse status + headers. Re-use response.cyr helpers.
    var hp = _sandhi_sb_ptr(header_sb);
    var status = _sandhi_resp_status(hp, header_end);
    if (status == 0) { return _sandhi_stream_result_a(a, 0, 0, SANDHI_ERR_PROTOCOL, 0); }

    var sline_end = _sandhi_resp_eol(hp, 0, header_end);
    var hstart = sline_end;
    if (hstart < header_end && load8(hp + hstart) == 13) { hstart = hstart + 1; }
    if (hstart < header_end && load8(hp + hstart) == 10) { hstart = hstart + 1; }
    var hend = _sandhi_resp_headers_end(hp, header_end);
    if (hend < 0) { hend = header_end; }
    var headers = sandhi_headers_parse_a(a, hp + hstart, hend - hstart);
    var chunked = _sandhi_resp_is_chunked(headers);

    # Body-buffer starts with whatever's past the header marker.
    var body_sb = _sandhi_sb_new_a(a, cap);
    var total = _sandhi_sb_len(header_sb);
    if (total > header_end) {
        _sandhi_sb_append(body_sb, hp + header_end, total - header_end);
    }

    return _sandhi_stream_body_loop_a(a, conn, body_sb, scratch, chunked, status, cb, ctx, cap, deadline_ms);
}

fn _sandhi_stream_read_loop(conn, cb, ctx, cap, deadline_ms): i64 {
    return _sandhi_stream_read_loop_a(default_alloc(), conn, cb, ctx, cap, deadline_ms);
}

# Body-loop: alternate "read more" + "decode + dispatch". Kept
# compact — per-iteration work lives in helpers.
fn _sandhi_stream_body_loop_a(a, conn, body_sb, scratch, chunked, status, cb, ctx, cap, deadline_ms): i64 {
    var total_events_cell = alloc_via(a, 8);
    var stop_cell = alloc_via(a, 8);
    if (total_events_cell == 0 || stop_cell == 0) {
        return _sandhi_stream_result_a(a, status, 0, SANDHI_ERR_INTERNAL, 0);
    }
    store64(total_events_cell, 0);
    store64(stop_cell, 0);
    var chunk_state = _sandhi_chunk_state_new_a(a);

    var going = 1;
    while (going == 1) {
        # Process whatever's already in body_sb.
        if (chunked == 1) {
            var decoded = _sandhi_sb_new_a(a, cap);
            _sandhi_stream_decode_chunked_into(body_sb, chunk_state, decoded);
            if (_sandhi_sb_len(decoded) > 0) {
                _sandhi_stream_feed_sse_a(a, decoded, cb, ctx, total_events_cell, stop_cell);
                if (load64(stop_cell) == 1) { going = 0; }
            }
            if (_sandhi_chunk_done(chunk_state) == 1) { going = 0; }
        } else {
            _sandhi_stream_feed_sse_a(a, body_sb, cb, ctx, total_events_cell, stop_cell);
            if (load64(stop_cell) == 1) { going = 0; }
        }

        if (going == 1) {
            if (deadline_ms > 0 && clock_now_ms() >= deadline_ms) {
                return _sandhi_stream_result_a(a, status, load64(total_events_cell), SANDHI_ERR_TIMEOUT, 0);
            }
            var n = sandhi_conn_recv(conn, scratch, _SANDHI_STREAM_READ_CHUNK);
            if (n == 0 - _SANDHI_EAGAIN) {
                return _sandhi_stream_result_a(a, status, load64(total_events_cell), SANDHI_ERR_TIMEOUT, 0);
            }
            if (n < 0) { return _sandhi_stream_result_a(a, status, load64(total_events_cell), SANDHI_ERR_CONNECT, 0); }
            if (n == 0) { going = 0; }
            else {
                if (_sandhi_sb_append(body_sb, scratch, n) < 0) {
                    return _sandhi_stream_result_a(a, status, load64(total_events_cell), SANDHI_ERR_PROTOCOL, 0);
                }
            }
        }
    }

    return _sandhi_stream_result_a(a, status, load64(total_events_cell), SANDHI_OK, load64(stop_cell));
}

fn _sandhi_stream_body_loop(conn, body_sb, scratch, chunked, status, cb, ctx, cap, deadline_ms): i64 {
    return _sandhi_stream_body_loop_a(
    default_alloc(), conn, body_sb, scratch, chunked, status,
    cb, ctx, cap, deadline_ms);
}

# Decode as many chunked frames as possible out of `in_sb` into
# `out_sb`. Advances chunk_state. Stops when a complete frame can't
# be parsed or the terminal 0-chunk is seen.
fn _sandhi_stream_decode_chunked_into(in_sb, chunk_state, out_sb): i64 {
    var going = 1;
    while (going == 1) {
        var rem = _sandhi_chunk_rem(chunk_state);
        if (_sandhi_chunk_done(chunk_state) == 1) { return 0; }
        if (rem == 0 - 1) {
            # Reading a chunk-size line.
            var sz = _sandhi_chunk_parse_size(in_sb);
            if (sz == 0 - 1) { return 0; }  # need more bytes
            var size = sz & 0xFFFFFFFF;
            var consumed = (sz >> 32) & 0xFFFFFFFF;
            _sandhi_sb_consume(in_sb, consumed);
            if (size == 0) {
                _sandhi_chunk_set_done(chunk_state, 1);
                return 0;
            }
            _sandhi_chunk_set_rem(chunk_state, size);
        } else {
            # Reading chunk body + trailing CRLF.
            var avail = _sandhi_sb_len(in_sb);
            if (avail == 0) { return 0; }
            var take = rem;
            if (take > avail) { take = avail; }
            _sandhi_sb_append(out_sb, _sandhi_sb_ptr(in_sb), take);
            _sandhi_sb_consume(in_sb, take);
            var new_rem = rem - take;
            if (new_rem > 0) {
                _sandhi_chunk_set_rem(chunk_state, new_rem);
                return 0;
            }
            # Chunk done — eat trailing CRLF if present, then loop.
            _sandhi_chunk_set_rem(chunk_state, 0 - 1);
            var after = _sandhi_sb_len(in_sb);
            if (after < 2) { return 0; }
            var pp = _sandhi_sb_ptr(in_sb);
            if (load8(pp) == 13 && load8(pp + 1) == 10) { _sandhi_sb_consume(in_sb, 2); }
            elif (load8(pp) == 10) { _sandhi_sb_consume(in_sb, 1); }
        }
    }
    return 0;
}


# --- policy.cyr ---

# sandhi/tls_policy/policy — policy struct + constructors.
#
# A TLS policy carries declarative intent that the connection layer
# applies at handshake time: pin to a specific SPKI hash, present an
# mTLS client certificate, override the system trust store.
#
# Policies are additive — `sandhi_tls_policy_combine(a, b)` merges
# two policies so callers can compose pinning + mTLS + custom CA
# without a combinatorial explosion of constructors.
#
# Struct layout (48 bytes):
#   +0   flags              (bitmask: PINNED | MTLS | CUSTOM_TRUST)
#   +8   pinned_spki_hex    (cstr — SHA-256 hex of Subject Public Key Info, or 0)
#   +16  mtls_cert_path     (cstr — PEM cert path, or 0)
#   +24  mtls_key_path      (cstr — PEM key path, or 0)
#   +32  trust_store_path   (cstr — CA bundle file, or 0 for system default)
#   +40  reserved           (future: verify callback fn ptr or flags)

enum SandhiTlsPolicyFlag {
    SANDHI_TLS_POLICY_DEFAULT      = 0;
    SANDHI_TLS_POLICY_PINNED       = 1;
    SANDHI_TLS_POLICY_MTLS         = 2;
    SANDHI_TLS_POLICY_CUSTOM_TRUST = 4;
}

enum SandhiTlsPolicyOff {
    SANDHI_TLS_POLICY_OFF_FLAGS       = 0;
    SANDHI_TLS_POLICY_OFF_PINNED      = 8;
    SANDHI_TLS_POLICY_OFF_MTLS_CERT   = 16;
    SANDHI_TLS_POLICY_OFF_MTLS_KEY    = 24;
    SANDHI_TLS_POLICY_OFF_TRUST_STORE = 32;
    SANDHI_TLS_POLICY_OFF_RESERVED    = 40;
}

var SANDHI_TLS_POLICY_STRUCT_SIZE = 48;

fn _sandhi_tls_policy_dup_a(a, s): i64 {
    if (s == 0) { return 0; }
    var n = strlen(s);
    var out = alloc_via(a, n + 1);
    if (out == 0) { return 0; }
    memcpy(out, s, n);
    store8(out + n, 0);
    return out;
}

fn _sandhi_tls_policy_dup(s): i64 {
    return _sandhi_tls_policy_dup_a(default_alloc(), s);
}

fn _sandhi_tls_policy_empty_a(a): i64 {
    var p = alloc_via(a, SANDHI_TLS_POLICY_STRUCT_SIZE);
    if (p == 0) { return 0; }
    store64(p + SANDHI_TLS_POLICY_OFF_FLAGS, 0);
    store64(p + SANDHI_TLS_POLICY_OFF_PINNED, 0);
    store64(p + SANDHI_TLS_POLICY_OFF_MTLS_CERT, 0);
    store64(p + SANDHI_TLS_POLICY_OFF_MTLS_KEY, 0);
    store64(p + SANDHI_TLS_POLICY_OFF_TRUST_STORE, 0);
    store64(p + SANDHI_TLS_POLICY_OFF_RESERVED, 0);
    return p;
}

fn _sandhi_tls_policy_empty(): i64 {
    return _sandhi_tls_policy_empty_a(default_alloc());
}

# ================================================================
# Constructors
# ================================================================

# Default policy allocated from `a`. Returns 0 on OOM.
fn sandhi_tls_policy_new_default_a(a): i64 {
    return _sandhi_tls_policy_empty_a(a);
}

fn sandhi_tls_policy_new_default(): i64 {
    return sandhi_tls_policy_new_default_a(default_alloc());
}

# Pinned policy allocated from `a`. The caller-supplied hex is dup'd
# into `a` so the policy is self-contained against arena reset.
fn sandhi_tls_policy_new_pinned_a(a, spki_hex): i64 {
    var p = _sandhi_tls_policy_empty_a(a);
    if (p == 0) { return 0; }
    store64(p + SANDHI_TLS_POLICY_OFF_FLAGS, SANDHI_TLS_POLICY_PINNED);
    store64(p + SANDHI_TLS_POLICY_OFF_PINNED, _sandhi_tls_policy_dup_a(a, spki_hex));
    return p;
}

fn sandhi_tls_policy_new_pinned(spki_hex): i64 {
    return sandhi_tls_policy_new_pinned_a(default_alloc(), spki_hex);
}

# mTLS policy allocated from `a`. Cert + key paths are dup'd into `a`.
fn sandhi_tls_policy_new_mtls_a(a, cert_path, key_path): i64 {
    var p = _sandhi_tls_policy_empty_a(a);
    if (p == 0) { return 0; }
    store64(p + SANDHI_TLS_POLICY_OFF_FLAGS, SANDHI_TLS_POLICY_MTLS);
    store64(p + SANDHI_TLS_POLICY_OFF_MTLS_CERT, _sandhi_tls_policy_dup_a(a, cert_path));
    store64(p + SANDHI_TLS_POLICY_OFF_MTLS_KEY, _sandhi_tls_policy_dup_a(a, key_path));
    return p;
}

fn sandhi_tls_policy_new_mtls(cert_path, key_path): i64 {
    return sandhi_tls_policy_new_mtls_a(default_alloc(), cert_path, key_path);
}

# Trust-store-override policy allocated from `a`.
fn sandhi_tls_policy_new_trust_store_a(a, bundle_path): i64 {
    var p = _sandhi_tls_policy_empty_a(a);
    if (p == 0) { return 0; }
    store64(p + SANDHI_TLS_POLICY_OFF_FLAGS, SANDHI_TLS_POLICY_CUSTOM_TRUST);
    store64(p + SANDHI_TLS_POLICY_OFF_TRUST_STORE, _sandhi_tls_policy_dup_a(a, bundle_path));
    return p;
}

fn sandhi_tls_policy_new_trust_store(bundle_path): i64 {
    return sandhi_tls_policy_new_trust_store_a(default_alloc(), bundle_path);
}

# ================================================================
# Combine — merge two policies into one.
# ================================================================
#
# Right-hand fields win where present; falls back to left-hand
# otherwise. Flags OR together. Lets callers build up:
#   var p = sandhi_tls_policy_combine(
#               sandhi_tls_policy_new_pinned(fp),
#               sandhi_tls_policy_new_mtls(cert, key));

# Combine two policies into a fresh struct allocated from `alloc`.
# Right-hand fields win; left-hand fills the gaps. Field cstrs are
# NOT re-dup'd — the resulting struct shares string ownership with
# its inputs (caller must keep them alive). Returns 0 on OOM.
fn sandhi_tls_policy_combine_a(alloc, a, b): i64 {
    if (a == 0) { return b; }
    if (b == 0) { return a; }
    var out = _sandhi_tls_policy_empty_a(alloc);
    if (out == 0) { return 0; }
    var fa = load64(a + SANDHI_TLS_POLICY_OFF_FLAGS);
    var fb = load64(b + SANDHI_TLS_POLICY_OFF_FLAGS);
    store64(out + SANDHI_TLS_POLICY_OFF_FLAGS, fa | fb);

    var pin_a = load64(a + SANDHI_TLS_POLICY_OFF_PINNED);
    var pin_b = load64(b + SANDHI_TLS_POLICY_OFF_PINNED);
    if (pin_b != 0) { store64(out + SANDHI_TLS_POLICY_OFF_PINNED, pin_b); }
    else            { store64(out + SANDHI_TLS_POLICY_OFF_PINNED, pin_a); }

    var cert_a = load64(a + SANDHI_TLS_POLICY_OFF_MTLS_CERT);
    var cert_b = load64(b + SANDHI_TLS_POLICY_OFF_MTLS_CERT);
    if (cert_b != 0) { store64(out + SANDHI_TLS_POLICY_OFF_MTLS_CERT, cert_b); }
    else             { store64(out + SANDHI_TLS_POLICY_OFF_MTLS_CERT, cert_a); }

    var key_a = load64(a + SANDHI_TLS_POLICY_OFF_MTLS_KEY);
    var key_b = load64(b + SANDHI_TLS_POLICY_OFF_MTLS_KEY);
    if (key_b != 0) { store64(out + SANDHI_TLS_POLICY_OFF_MTLS_KEY, key_b); }
    else            { store64(out + SANDHI_TLS_POLICY_OFF_MTLS_KEY, key_a); }

    var trust_a = load64(a + SANDHI_TLS_POLICY_OFF_TRUST_STORE);
    var trust_b = load64(b + SANDHI_TLS_POLICY_OFF_TRUST_STORE);
    if (trust_b != 0) { store64(out + SANDHI_TLS_POLICY_OFF_TRUST_STORE, trust_b); }
    else              { store64(out + SANDHI_TLS_POLICY_OFF_TRUST_STORE, trust_a); }

    return out;
}

fn sandhi_tls_policy_combine(a, b): i64 {
    return sandhi_tls_policy_combine_a(default_alloc(), a, b);
}

# ================================================================
# Accessors
# ================================================================

fn sandhi_tls_policy_flags(p): i64 {
    if (p == 0) { return 0; }
    return load64(p + SANDHI_TLS_POLICY_OFF_FLAGS);
}

fn sandhi_tls_policy_pinned_hash(p): i64 {
    if (p == 0) { return 0; }
    return load64(p + SANDHI_TLS_POLICY_OFF_PINNED);
}

fn sandhi_tls_policy_mtls_cert(p): i64 {
    if (p == 0) { return 0; }
    return load64(p + SANDHI_TLS_POLICY_OFF_MTLS_CERT);
}

fn sandhi_tls_policy_mtls_key(p): i64 {
    if (p == 0) { return 0; }
    return load64(p + SANDHI_TLS_POLICY_OFF_MTLS_KEY);
}

fn sandhi_tls_policy_trust_store(p): i64 {
    if (p == 0) { return 0; }
    return load64(p + SANDHI_TLS_POLICY_OFF_TRUST_STORE);
}

fn sandhi_tls_policy_has_flag(p, flag): i64 {
    if (p == 0) { return 0; }
    var f = load64(p + SANDHI_TLS_POLICY_OFF_FLAGS);
    if ((f & flag) == flag) { return 1; }
    return 0;
}

# --- fingerprint.cyr ---

# sandhi/tls_policy/fingerprint — SPKI hash format helpers.
#
# SPKI pinning compares a SHA-256 hash of the server's Subject Public
# Key Info (DER bytes) against a caller-supplied hex string. This
# module handles format normalization + comparison; the actual DER
# extraction from server certs lives in apply.cyr's
# `_sandhi_check_spki` (X509_get_pubkey + i2d_PUBKEY → SHA-256, all
# resolved via stdlib `tls_dlsym`). Wired since 0.9.3 via stdlib's
# v5.6.40 hook.
#
# Accepted caller formats — all of these compare equal:
#
#   "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855"
#   "E3B0C44298FC1C149AFBF4C8996FB92427AE41E4649B934CA495991B7852B855"
#   "e3:b0:c4:42:98:fc:1c:14:9a:fb:f4:c8:99:6f:b9:24:27:ae:41:e4:64:9b:93:4c:a4:95:99:1b:78:52:b8:55"
#   "e3 b0 c4 42 98 fc 1c 14 9a fb f4 c8 99 6f b9 24 27 ae 41 e4 64 9b 93 4c a4 95 99 1b 78 52 b8 55"
#
# Normalization strips ':' / ' ' / '\t' and lowercases the hex.
# Length is not enforced here — callers pinning non-SHA-256 hashes
# (e.g. SHA-1 legacy — discouraged) get their length back.

# Lowercase an ASCII byte. Non-alpha bytes pass through.
fn _sandhi_fp_to_lower(c): i64 {
    if (c >= 65) { if (c <= 90) { return c + 32; } }
    return c;
}

# 1 if the byte is a hex digit (0-9 / a-f / A-F), 0 otherwise.
fn _sandhi_fp_is_hex(c): i64 {
    if (c >= 48 && c <= 57) { return 1; }
    if (c >= 65 && c <= 70) { return 1; }
    if (c >= 97 && c <= 102) { return 1; }
    return 0;
}

# Normalize an SPKI hex string into `a`: strip delimiters (: space tab),
# lowercase. Returns a fresh cstr or 0 on null input / invalid byte / OOM.
fn sandhi_fp_normalize_a(a, hex): i64 {
    if (hex == 0) { return 0; }
    var slen = strlen(hex);
    var out = alloc_via(a, slen + 1);
    if (out == 0) { return 0; }
    var oi = 0;
    var i = 0;
    while (i < slen) {
        var c = load8(hex + i);
        if (c == 58 || c == 32 || c == 9) {
            # Delimiter — skip.
            i = i + 1;
        } elif (_sandhi_fp_is_hex(c) == 1) {
            store8(out + oi, _sandhi_fp_to_lower(c));
            oi = oi + 1;
            i = i + 1;
        } else {
            # Invalid byte — reject.
            return 0;
        }
    }
    store8(out + oi, 0);
    return out;
}

fn sandhi_fp_normalize(hex): i64 {
    return sandhi_fp_normalize_a(default_alloc(), hex);
}

# Case- and delimiter-insensitive equality. Returns 1 if the two
# strings represent the same hex fingerprint, 0 otherwise. Either
# operand being 0 returns 0 (null-safe; absent pin never matches).
#
# 0.9.1 P1 — constant-time compare. Cert-pinning is auth-adjacent
# (a MITM trying to craft a cert that matches a pin can use timing
# leaks to brute-force one byte at a time when the cost-of-attempt
# is sub-millisecond). For SHA-256 pins the search space is large
# enough that timing-side-channel doesn't matter in absolute terms,
# but the pattern matters — defensive compares should always be
# constant-time, full stop.
# Constant-time equality with normalization done in `alloc`. The two
# scratch normalized buffers don't escape, so an arena allocator with
# reset_via(a) afterwards is the natural fit.
fn sandhi_fp_eq_a(alloc, a, b): i64 {
    if (a == 0 || b == 0) { return 0; }
    var na = sandhi_fp_normalize_a(alloc, a);
    var nb = sandhi_fp_normalize_a(alloc, b);
    if (na == 0 || nb == 0) { return 0; }
    var la = strlen(na);
    var lb = strlen(nb);
    if (la != lb) { return 0; }
    var diff = 0;
    var i = 0;
    while (i < la) {
        diff = diff | (load8(na + i) ^ load8(nb + i));
        i = i + 1;
    }
    if (diff == 0) { return 1; }
    return 0;
}

fn sandhi_fp_eq(a, b): i64 {
    if (a == 0 || b == 0) { return 0; }
    var na = sandhi_fp_normalize(a);
    var nb = sandhi_fp_normalize(b);
    if (na == 0 || nb == 0) { return 0; }
    var la = strlen(na);
    var lb = strlen(nb);
    # Length mismatch is fatal (different fingerprint widths can't
    # match anyway). Surface this directly — leaks no per-byte info.
    if (la != lb) { return 0; }
    # Walk the full length regardless of mismatch position. OR every
    # XOR into a running accumulator; only inspect the accumulator
    # at the end. No early-exit on mismatch.
    var diff = 0;
    var i = 0;
    while (i < la) {
        diff = diff | (load8(na + i) ^ load8(nb + i));
        i = i + 1;
    }
    if (diff == 0) { return 1; }
    return 0;
}

# Byte length of the normalized fingerprint (2 hex chars per byte).
# Returns 0 on malformed input, 32 for SHA-256, 20 for SHA-1 (legacy).
fn sandhi_fp_byte_length(hex): i64 {
    var n = sandhi_fp_normalize(hex);
    if (n == 0) { return 0; }
    var len = strlen(n);
    if ((len & 1) != 0) { return 0; }  # odd number of nibbles — malformed
    return len / 2;
}

# Encode raw SHA-256 bytes (or any digest buffer) as lowercase hex
# allocated from `a`. Returns 0 on OOM.
fn sandhi_fp_encode_bytes_a(a, bytes, nbytes): i64 {
    var out = alloc_via(a, nbytes * 2 + 1);
    if (out == 0) { return 0; }
    var i = 0;
    while (i < nbytes) {
        var b = load8(bytes + i);
        var hi = (b >> 4) & 0xF;
        var lo = b & 0xF;
        var c1 = 48 + hi;
        if (hi >= 10) { c1 = 87 + hi; }
        var c2 = 48 + lo;
        if (lo >= 10) { c2 = 87 + lo; }
        store8(out + i * 2, c1);
        store8(out + i * 2 + 1, c2);
        i = i + 1;
    }
    store8(out + nbytes * 2, 0);
    return out;
}

fn sandhi_fp_encode_bytes(bytes, nbytes): i64 {
    return sandhi_fp_encode_bytes_a(default_alloc(), bytes, nbytes);
}

# --- apply.cyr ---

# sandhi/tls_policy/apply — wire policy into the connection layer.
#
# Public API: `sandhi_conn_open_with_policy(addr, port, use_tls,
# sni_host, policy)` — parallel to `sandhi_conn_open` but honors a
# caller-supplied TLS policy.
#
# STATUS (2026-04-25): wired since cyrius v5.6.41 (the v5.6.40
# stdlib hook + the v5.6.41 calling-convention fix). Trust store
# override, mTLS cert/key load, and SPKI pinning are all live.
#
# How it fits together:
#
#   - `_sandhi_apply_resolve_fns` lazily resolves the libssl/libcrypto
#     symbols we need via stdlib `tls_dlsym`. If any are missing, the
#     enforcement-available accessor stays at 0 and the open path
#     fails closed when policy demands enforcement.
#
#   - `_sandhi_apply_hook` is a `tls_connect_with_ctx_hook` callback
#     that runs against the raw SSL_CTX. It applies ALPN advertise
#     (mirroring the conn-level default), trust-store override, and
#     mTLS cert/key load — all `SSL_CTX_set_*` calls that have to
#     happen before SSL_new / SSL_connect.
#
#   - `_sandhi_check_spki` runs post-handshake. Pulls the peer cert
#     via SSL_get_peer_certificate, serializes the SPKI to DER via
#     X509_get_pubkey + i2d_PUBKEY, hashes with SHA-256, and compares
#     to the policy's pinned hex via the constant-time
#     `sandhi_fp_eq`. Mismatch closes the conn and fails the open
#     with err=TLS, per ADR 0004.
#
# Cached fn pointers
# ==================

# 1.3.0: `_sandhi_apply_set_alpn_fp` retired in favour of stdlib's
# typed wrapper `tls_set_alpn` (cyrius v5.10.13). The other fps stay
# tls_dlsym-resolved until typed wrappers ship for them too.
var _sandhi_apply_load_verify_fp     = 0;  # SSL_CTX_load_verify_locations
var _sandhi_apply_use_cert_fp        = 0;  # SSL_CTX_use_certificate_file
var _sandhi_apply_use_key_fp         = 0;  # SSL_CTX_use_PrivateKey_file
var _sandhi_apply_get_peer_cert_fp   = 0;  # SSL_get_peer_certificate (1.1.x) / SSL_get1_peer_certificate (3.0+)
var _sandhi_apply_get_pubkey_fp      = 0;  # X509_get_pubkey
var _sandhi_apply_i2d_pubkey_fp      = 0;  # i2d_PUBKEY
var _sandhi_apply_x509_free_fp       = 0;  # X509_free
var _sandhi_apply_evp_pkey_free_fp   = 0;  # EVP_PKEY_free
var _sandhi_apply_resolved           = 0;

# OpenSSL constants we need.
var _SANDHI_SSL_FILETYPE_PEM = 1;

fn _sandhi_apply_resolve_fns(): i64 {
    if (_sandhi_apply_resolved == 1) { return 0; }
    _sandhi_apply_load_verify_fp   = tls_dlsym("SSL_CTX_load_verify_locations");
    _sandhi_apply_use_cert_fp      = tls_dlsym("SSL_CTX_use_certificate_file");
    _sandhi_apply_use_key_fp       = tls_dlsym("SSL_CTX_use_PrivateKey_file");
    # OpenSSL 3.0 renamed SSL_get_peer_certificate to
    # SSL_get1_peer_certificate; the old name remained as a macro
    # forwarding to the new one. The macro means symbol-by-name
    # may resolve only the new spelling on some installs. Try the
    # new name first, fall back to the legacy.
    _sandhi_apply_get_peer_cert_fp = tls_dlsym("SSL_get1_peer_certificate");
    if (_sandhi_apply_get_peer_cert_fp == 0) {
        _sandhi_apply_get_peer_cert_fp = tls_dlsym("SSL_get_peer_certificate");
    }
    _sandhi_apply_get_pubkey_fp    = tls_dlsym("X509_get_pubkey");
    _sandhi_apply_i2d_pubkey_fp    = tls_dlsym("i2d_PUBKEY");
    _sandhi_apply_x509_free_fp     = tls_dlsym("X509_free");
    _sandhi_apply_evp_pkey_free_fp = tls_dlsym("EVP_PKEY_free");
    _sandhi_apply_resolved = 1;
    return 0;
}

# Returns 1 if every fn ptr we need for policy enforcement (mTLS,
# trust store, SPKI pinning) is resolved. Anything missing → 0,
# and the fail-closed gate in sandhi_conn_open_with_policy refuses
# to open enforcement-demanding policies.
fn sandhi_tls_policy_enforcement_available(): i64 {
    _sandhi_apply_resolve_fns();
    # ALPN gate: previously checked the fp cache; now we trust
    # stdlib's `tls_set_alpn` to be present whenever `tls_available()`
    # is true. The wrapper is a no-op if the underlying symbol is
    # missing (returns -1; we ignore the return for non-fatal alpn).
    if (tls_available() == 0)                  { return 0; }
    if (_sandhi_apply_load_verify_fp == 0)     { return 0; }
    if (_sandhi_apply_use_cert_fp == 0)        { return 0; }
    if (_sandhi_apply_use_key_fp == 0)         { return 0; }
    if (_sandhi_apply_get_peer_cert_fp == 0)   { return 0; }
    if (_sandhi_apply_get_pubkey_fp == 0)      { return 0; }
    if (_sandhi_apply_i2d_pubkey_fp == 0)      { return 0; }
    if (_sandhi_apply_x509_free_fp == 0)       { return 0; }
    if (_sandhi_apply_evp_pkey_free_fp == 0)   { return 0; }
    return 1;
}

# ================================================================
# Hook context layout (24 bytes):
#   +0   protos_ptr     (cstr — ALPN advertise wire bytes)
#   +8   protos_len     (int  — length of the wire bytes)
#   +16  policy_ptr     (sandhi_tls_policy* — for trust/mTLS lookup)
# ================================================================

fn _sandhi_apply_hook(hook_ctx, ssl_ctx): i64 {
    _sandhi_apply_resolve_fns();
    if (hook_ctx == 0 || ssl_ctx == 0) { return 0; }

    # ALPN advertise — non-fatal if missing, same shape as the
    # plain ALPN hook in conn.cyr. 1.3.0: switched from the
    # `_sandhi_apply_set_alpn_fp` cache to stdlib's typed
    # `tls_set_alpn` wrapper (cyrius v5.10.13). The wrapper itself
    # null-checks the underlying symbol resolution.
    var protos = load64(hook_ctx);
    var plen   = load64(hook_ctx + 8);
    if (protos != 0 && plen > 0) {
        tls_set_alpn(ssl_ctx, protos, plen);
    }

    var policy = load64(hook_ctx + 16);
    if (policy == 0) { return 0; }

    # Custom trust store: SSL_CTX_load_verify_locations(ctx, file, dir).
    # We always pass file=path, dir=0 — sandhi's policy is per-file,
    # not per-directory.
    var trust = sandhi_tls_policy_trust_store(policy);
    if (trust != 0) {
        if (_sandhi_apply_load_verify_fp == 0) { return 1; }
        var rc = fncall3(_sandhi_apply_load_verify_fp, ssl_ctx, trust, 0);
        if (rc != 1) { return 1; }
    }

    # mTLS: SSL_CTX_use_certificate_file + SSL_CTX_use_PrivateKey_file.
    # Both expect SSL_FILETYPE_PEM (1). Order matters — load the cert
    # before the key so libssl can verify they match.
    var cert = sandhi_tls_policy_mtls_cert(policy);
    var key  = sandhi_tls_policy_mtls_key(policy);
    if (cert != 0) {
        if (_sandhi_apply_use_cert_fp == 0) { return 1; }
        var rc2 = fncall3(_sandhi_apply_use_cert_fp, ssl_ctx, cert, _SANDHI_SSL_FILETYPE_PEM);
        if (rc2 != 1) { return 1; }
    }
    if (key != 0) {
        if (_sandhi_apply_use_key_fp == 0) { return 1; }
        var rc3 = fncall3(_sandhi_apply_use_key_fp, ssl_ctx, key, _SANDHI_SSL_FILETYPE_PEM);
        if (rc3 != 1) { return 1; }
    }

    return 0;
}

# Post-handshake SPKI check, allocating all scratch (DER buffer,
# pointer cell, digest, hex string) from `a`. Returns 1 on match,
# 0 on any failure (cert missing, pubkey extraction failure, hash
# mismatch, OOM). Frees the X509 + EVP_PKEY it pulls. None of the
# allocs escape; an arena reset after this call reclaims everything.
fn _sandhi_check_spki_a(a, tls_ctx, expected_hex): i64 {
    _sandhi_apply_resolve_fns();
    if (tls_ctx == 0 || expected_hex == 0) { return 0; }
    if (_sandhi_apply_get_peer_cert_fp == 0)   { return 0; }
    if (_sandhi_apply_get_pubkey_fp == 0)      { return 0; }
    if (_sandhi_apply_i2d_pubkey_fp == 0)      { return 0; }
    if (_sandhi_apply_x509_free_fp == 0)       { return 0; }
    if (_sandhi_apply_evp_pkey_free_fp == 0)   { return 0; }

    var ssl = load64(tls_ctx + 8);
    if (ssl == 0) { return 0; }

    var x509 = fncall1(_sandhi_apply_get_peer_cert_fp, ssl);
    if (x509 == 0) { return 0; }

    var pkey = fncall1(_sandhi_apply_get_pubkey_fp, x509);
    if (pkey == 0) {
        fncall1(_sandhi_apply_x509_free_fp, x509);
        return 0;
    }

    # i2d_PUBKEY(pkey, NULL) returns required buffer size.
    # Then i2d_PUBKEY(pkey, &buf) writes DER and advances *buf.
    var size = fncall2(_sandhi_apply_i2d_pubkey_fp, pkey, 0);
    if (size <= 0) {
        fncall1(_sandhi_apply_evp_pkey_free_fp, pkey);
        fncall1(_sandhi_apply_x509_free_fp, x509);
        return 0;
    }
    var der = alloc_via(a, size);
    var p_cell = alloc_via(a, 8);
    if (der == 0 || p_cell == 0) {
        fncall1(_sandhi_apply_evp_pkey_free_fp, pkey);
        fncall1(_sandhi_apply_x509_free_fp, x509);
        return 0;
    }
    store64(p_cell, der);
    var written = fncall2(_sandhi_apply_i2d_pubkey_fp, pkey, p_cell);
    fncall1(_sandhi_apply_evp_pkey_free_fp, pkey);
    fncall1(_sandhi_apply_x509_free_fp, x509);
    if (written <= 0) { return 0; }

    # SHA-256 the SPKI DER, hex-encode, constant-time compare. The hex
    # encoding + compare-time normalize buffers all flow through `a`.
    var digest = alloc_via(a, 32);
    if (digest == 0) { return 0; }
    sha256(der, written, digest);
    var actual_hex = sandhi_fp_encode_bytes_a(a, digest, 32);
    if (actual_hex == 0) { return 0; }
    if (sandhi_fp_eq_a(a, actual_hex, expected_hex) == 1) { return 1; }
    return 0;
}

fn _sandhi_check_spki(tls_ctx, expected_hex): i64 {
    return _sandhi_check_spki_a(default_alloc(), tls_ctx, expected_hex);
}

# Apply the given policy while opening a connection. `addr` + `port`
# + `use_tls` + `sni_host` match `sandhi_conn_open`. `policy` may be
# 0 — equivalent to `sandhi_tls_policy_new_default()`.
#
# Returns the conn struct on success, or 0 on failure.
#
# 0.9.0 P0 #5 — fail-closed when policy demands enforcement we
# can't deliver. If the caller built a `_pinned()` / `_mtls()` /
# `_trust_store()` policy AND `enforcement_available()` is 0, we
# refuse the connection rather than silently downgrade to the
# default verify path. Callers wanting "best effort" behavior pass
# `sandhi_tls_policy_new_default()` explicitly (no enforcement
# requirements).
# Open a TLS-policy-driven connection, allocating the per-connection
# scratch (hook ctx struct + post-handshake SPKI check buffers) from
# `a`. The conn struct itself is owned by the connection layer (Batch
# 5 routes that through an Allocator); only the hook ctx + SPKI scratch
# land in `a` here.
#
# Returns the conn struct on success or 0 on failure / OOM.
fn sandhi_conn_open_with_policy_a(a, addr, port, use_tls, sni_host, policy): i64 {
    if (use_tls == 0) {
        return sandhi_conn_open(addr, port, 0, sni_host);
    }

    # Read policy fields. NULL policy is the default — no enforcement
    # requirements, plain conn-open path.
    if (policy == 0) {
        return sandhi_conn_open(addr, port, 1, sni_host);
    }

    var pinned      = sandhi_tls_policy_pinned_hash(policy);
    var mtls_cert   = sandhi_tls_policy_mtls_cert(policy);
    var trust_store = sandhi_tls_policy_trust_store(policy);
    var demands_enforcement = 0;
    if (pinned != 0)      { demands_enforcement = 1; }
    if (mtls_cert != 0)   { demands_enforcement = 1; }
    if (trust_store != 0) { demands_enforcement = 1; }

    if (demands_enforcement == 1
    && sandhi_tls_policy_enforcement_available() == 0) {
        _sandhi_conn_last_err = SANDHI_CONN_OPEN_TLS;
        return 0;
    }

    if (demands_enforcement == 0) {
        # Default policy — same as plain open.
        return sandhi_conn_open(addr, port, 1, sni_host);
    }

    # Build the policy hook ctx and route the open through
    # conn.cyr's override mechanism.
    _sandhi_alpn_init_wire();
    var protos = _sandhi_alpn_h11_wire;
    var plen   = _sandhi_alpn_h11_wire_len;
    if (_sandhi_alpn_advertise_h2 == 1) {
        protos = _sandhi_alpn_h2h11_wire;
        plen   = _sandhi_alpn_h2h11_wire_len;
    }
    var hook_ctx = alloc_via(a, 24);
    if (hook_ctx == 0) {
        _sandhi_conn_last_err = SANDHI_CONN_OPEN_TLS;
        return 0;
    }
    store64(hook_ctx,      protos);
    store64(hook_ctx + 8,  plen);
    store64(hook_ctx + 16, policy);

    _sandhi_tls_hook_override     = &_sandhi_apply_hook;
    _sandhi_tls_hook_override_ctx = hook_ctx;
    var conn = sandhi_conn_open(addr, port, 1, sni_host);
    _sandhi_tls_hook_override     = 0;
    _sandhi_tls_hook_override_ctx = 0;

    if (conn == 0) {
        # last-err was set by sandhi_conn_open_fully_timed.
        return 0;
    }

    # Post-handshake SPKI check.
    if (pinned != 0) {
        var tls_ctx = sandhi_conn_tls_ctx(conn);
        if (_sandhi_check_spki_a(a, tls_ctx, pinned) == 0) {
            sandhi_conn_close(conn);
            _sandhi_conn_last_err = SANDHI_CONN_OPEN_TLS;
            return 0;
        }
    }

    return conn;
}

fn sandhi_conn_open_with_policy(addr, port, use_tls, sni_host, policy): i64 {
    return sandhi_conn_open_with_policy_a(default_alloc(), addr, port, use_tls, sni_host, policy);
}


# --- alpn.cyr ---

# sandhi/tls_policy/alpn — ALPN (RFC 7301) wire format + selection.
#
# ALPN lets the client and server agree on which app-layer protocol
# to speak over a single TLS connection. For h2-over-TLS the client
# advertises `h2` (HTTP/2) ahead of `http/1.1`, the server picks
# one, and both sides know what to speak after the handshake.
#
# Wire format (RFC 7301 §3.1, ProtocolNameList in TLS extension 0x10):
#   each protocol = 1-byte length-prefix + bytes (no NUL-term).
#   list = concatenation of those entries.
# Example for "h2, http/1.1":
#   02 'h' '2' 08 'h' 't' 't' 'p' '/' '1' '.' '1'   (13 bytes)
#
# STATUS: wired end-to-end since cyrius v5.6.41 (the v5.6.40 stdlib
# hook + the v5.6.41 calling-convention fix together). HTTPS
# connections opened via `sandhi_conn_open*` advertise
# `h2,http/1.1` and store whatever the server picks at
# `SANDHI_CONN_OFF_ALPN_DATA`. The runtime lives in
# `src/http/conn.cyr` (cached fn pointers, hook callback,
# post-handshake read); this file's accessors just load the slot.

# Default ALPN proto list — h2 preferred, http/1.1 fallback. Most
# h2-capable servers honor this preference.
var SANDHI_ALPN_DEFAULT = "h2,http/1.1";

# Encode a comma-separated proto list into the RFC 7301 wire format.
# Writes into `out` (caller-owned, must hold ≥ list_len + N protos).
# Returns the number of bytes written, or `0 - 1` on overflow.
#
# Example: "h2,http/1.1" → 13 bytes.
fn sandhi_alpn_encode_protos(protos_csv, out, out_cap): i64 {
    if (protos_csv == 0) { return 0; }
    var p = 0;        # input cursor
    var w = 0;        # output cursor
    var seg_start = 0;
    var slen = strlen(protos_csv);
    while (p <= slen) {
        var c = 0;
        if (p < slen) { c = load8(protos_csv + p); }
        else          { c = 0; }  # treat NUL as a separator to flush trailer
        if (c == 44 || (p == slen && c == 0)) {
            # Comma or end — emit segment [seg_start, p).
            var seg_len = p - seg_start;
            if (seg_len > 0) {
                if (seg_len > 255) { return 0 - 1; }
                if (w + 1 + seg_len > out_cap) { return 0 - 1; }
                store8(out + w, seg_len);
                w = w + 1;
                var i = 0;
                while (i < seg_len) {
                    store8(out + w + i, load8(protos_csv + seg_start + i));
                    i = i + 1;
                }
                w = w + seg_len;
            }
            seg_start = p + 1;
        }
        p = p + 1;
    }
    return w;
}

# ================================================================
# Selection accessors
# ================================================================

# Returns the negotiated ALPN protocol as a NUL-terminated cstr
# ("h2", "http/1.1", or 0 if ALPN didn't fire). The cstr is owned
# by the conn — do not free, do not retain past `sandhi_conn_close`.
fn sandhi_conn_alpn_selected(conn): i64 {
    if (conn == 0) { return 0; }
    return load64(conn + SANDHI_CONN_OFF_ALPN_DATA);
}

# 1 if h2 was negotiated, 0 otherwise.
fn sandhi_conn_alpn_is_h2(conn): i64 {
    var sel = sandhi_conn_alpn_selected(conn);
    if (sel == 0) { return 0; }
    if (strlen(sel) != 2) { return 0; }
    if (load8(sel + 0) == 104 && load8(sel + 1) == 50) { return 1; }  # 'h' '2'
    return 0;
}


# --- mod.cyr ---

# sandhi/tls_policy — TLS trust + cert-pinning policy layer.
#
# Composes:
#   tls_policy/policy      — policy struct + constructors + combine
#   tls_policy/fingerprint — SPKI hex format helpers (normalize, compare)
#   tls_policy/apply       — wire policy into sandhi_conn_open
#
# Today this wraps stdlib `lib/tls.cyr` (which is FFI-to-libssl).
# When Cyrius v5.9.x native TLS lands, the surface here does not
# change — only the transport underneath apply.cyr swaps out. Per
# ADR 0001, that's the whole point of composing rather than
# reimplementing.
#
# Typical usage:
#
#   var p = sandhi_tls_policy_new_pinned("e3b0c442:98fc1c14:...");
#   var q = sandhi_tls_policy_new_mtls("client.pem", "client.key");
#   var combined = sandhi_tls_policy_combine(p, q);
#   var conn = sandhi_conn_open_with_policy(addr, 443, 1, "example.com", combined);
#
# Live enforcement wired since 0.9.3 (cyrius v5.6.41) — pinning
# / mTLS / trust-store overrides apply through stdlib's
# `tls_connect_with_ctx_hook`, post-handshake SPKI extraction
# verifies pins via `i2d_PUBKEY` + SHA-256 in constant time.


# --- json.cyr ---

# sandhi/rpc/json — minimal nested JSON build + extract for RPC use.
#
# Stdlib `lib/json.cyr` is flat-only and always quotes values, which
# doesn't fit real WebDriver / MCP / Appium wire formats (nested
# objects, numeric fields, booleans). This module adds just what
# sandhi::rpc needs — builder with typed values + nested-object
# support, plus a dotted-path extractor for pulling fields out of
# responses.
#
# Deliberately small. Not a full JSON library; consumers that need
# full parsing are still free to use stdlib json.cyr or their own
# layer. Fold-into-stdlib wants the sandhi public surface tight.

# ================================================================
# Builder
# ================================================================
#
# Usage:
#   var o = sandhi_json_obj_new();
#   sandhi_json_add_string(o, "browserName", "firefox");
#   sandhi_json_add_int(o, "w3c", 1);
#   var nested = sandhi_json_obj_new();
#   sandhi_json_add_string(nested, "platform", "linux");
#   sandhi_json_add_object(o, "capabilities", nested);
#   var wire = sandhi_json_build(o);  # cstr

# Entry is {key_cstr, value_cstr, kind} — 24 bytes.
# kind: 0=string (quote+escape), 1=raw (already JSON — ints, objects, booleans, null).
enum SandhiJsonKind {
    SANDHI_JSON_STRING = 0;
    SANDHI_JSON_RAW    = 1;
}

fn _sandhi_json_entry_new_a(a, key, value, kind): i64 {
    var e = alloc_via(a, 24);
    if (e == 0) { return 0; }
    store64(e, key);
    store64(e + 8, value);
    store64(e + 16, kind);
    return e;
}

fn _sandhi_json_entry_new(key, value, kind): i64 {
    return _sandhi_json_entry_new_a(default_alloc(), key, value, kind);
}

# Build a fresh empty object backed by `a`. Returns 0 on OOM.
fn sandhi_json_obj_new_a(a): i64 {
    return vec_new_a(a);
}

fn sandhi_json_obj_new(): i64 {
    return sandhi_json_obj_new_a(default_alloc());
}

# Copy a cstr into a fresh alloc owned by `a`. Returns 0 on null
# input or OOM.
fn _sandhi_json_dup_a(a, s): i64 {
    if (s == 0) { return 0; }
    var n = strlen(s);
    var out = alloc_via(a, n + 1);
    if (out == 0) { return 0; }
    memcpy(out, s, n);
    store8(out + n, 0);
    return out;
}

fn _sandhi_json_dup(s): i64 {
    return _sandhi_json_dup_a(default_alloc(), s);
}

# Append a string field to `o`, allocating the dup'd key + value into `a`.
fn sandhi_json_add_string_a(a, o, key, value): i64 {
    vec_push_a(a, o, _sandhi_json_entry_new_a(a,
    _sandhi_json_dup_a(a, key),
    _sandhi_json_dup_a(a, value),
    SANDHI_JSON_STRING));
    return 0;
}

fn sandhi_json_add_string(o, key, value): i64 {
    return sandhi_json_add_string_a(default_alloc(), o, key, value);
}

fn sandhi_json_add_int_a(a, o, key, value): i64 {
    var tmp[24];
    var n = fmt_int_buf(value, &tmp);
    var out = alloc_via(a, n + 1);
    if (out == 0) { return 0; }
    memcpy(out, &tmp, n);
    store8(out + n, 0);
    vec_push_a(a, o, _sandhi_json_entry_new_a(a,
    _sandhi_json_dup_a(a, key),
    out,
    SANDHI_JSON_RAW));
    return 0;
}

fn sandhi_json_add_int(o, key, value): i64 {
    return sandhi_json_add_int_a(default_alloc(), o, key, value);
}

fn sandhi_json_add_bool_a(a, o, key, value): i64 {
    var raw = "false";
    if (value == 1) { raw = "true"; }
    vec_push_a(a, o, _sandhi_json_entry_new_a(a,
    _sandhi_json_dup_a(a, key),
    _sandhi_json_dup_a(a, raw),
    SANDHI_JSON_RAW));
    return 0;
}

fn sandhi_json_add_bool(o, key, value): i64 {
    return sandhi_json_add_bool_a(default_alloc(), o, key, value);
}

fn sandhi_json_add_null_a(a, o, key): i64 {
    vec_push_a(a, o, _sandhi_json_entry_new_a(a,
    _sandhi_json_dup_a(a, key),
    _sandhi_json_dup_a(a, "null"),
    SANDHI_JSON_RAW));
    return 0;
}

fn sandhi_json_add_null(o, key): i64 {
    return sandhi_json_add_null_a(default_alloc(), o, key);
}

# Embed a child object as a nested value, allocating into `a`. The
# child is serialized into `a` here — caller's handle on the child
# stays valid for the lifetime of `a`.
fn sandhi_json_add_object_a(a, o, key, child): i64 {
    var rendered = sandhi_json_build_a(a, child);
    vec_push_a(a, o, _sandhi_json_entry_new_a(a,
    _sandhi_json_dup_a(a, key),
    rendered,
    SANDHI_JSON_RAW));
    return 0;
}

fn sandhi_json_add_object(o, key, child): i64 {
    return sandhi_json_add_object_a(default_alloc(), o, key, child);
}

# Embed a pre-built raw JSON fragment, dup'd into `a`.
fn sandhi_json_add_raw_a(a, o, key, raw_cstr): i64 {
    vec_push_a(a, o, _sandhi_json_entry_new_a(a,
    _sandhi_json_dup_a(a, key),
    _sandhi_json_dup_a(a, raw_cstr),
    SANDHI_JSON_RAW));
    return 0;
}

fn sandhi_json_add_raw(o, key, raw_cstr): i64 {
    return sandhi_json_add_raw_a(default_alloc(), o, key, raw_cstr);
}

# Escape a string for JSON, allocating the result into `a`. The
# str_builder scratch still flows through the global bump (str_builder
# lacks `_a` variants in the pinned stdlib); only the final cstr lands
# in `a`. Returns 0 on OOM.
fn sandhi_json_escape_a(a, s): i64 {
    if (s == 0) {
        var nul = alloc_via(a, 5);
        if (nul == 0) { return 0; }
        memcpy(nul, "\"\"", 2);
        store8(nul + 2, 0);
        return nul;
    }
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "\"");
    var i = 0;
    while (load8(s + i) != 0) {
        var c = load8(s + i);
        if (c == 34) { str_builder_add_cstr(sb, "\\\""); }
        elif (c == 92) { str_builder_add_cstr(sb, "\\\\"); }
        elif (c == 8)  { str_builder_add_cstr(sb, "\\b"); }
        elif (c == 9)  { str_builder_add_cstr(sb, "\\t"); }
        elif (c == 10) { str_builder_add_cstr(sb, "\\n"); }
        elif (c == 12) { str_builder_add_cstr(sb, "\\f"); }
        elif (c == 13) { str_builder_add_cstr(sb, "\\r"); }
        elif (c < 32) {
            # Generic \u00XX escape for other control bytes (RFC 8259).
            str_builder_add_cstr(sb, "\\u00");
            var hi = (c >> 4) & 0xF;
            var lo = c & 0xF;
            var h1 = 48 + hi;
            if (hi >= 10) { h1 = 87 + hi; }
            var h2 = 48 + lo;
            if (lo >= 10) { h2 = 87 + lo; }
            str_builder_add_byte(sb, h1);
            str_builder_add_byte(sb, h2);
        }
        else { str_builder_add_byte(sb, c); }
        i = i + 1;
    }
    str_builder_add_cstr(sb, "\"");
    return str_data(str_builder_build(sb));
}

fn sandhi_json_escape(s): i64 {
    return sandhi_json_escape_a(default_alloc(), s);
}

# Render the object as a cstr allocated from `a`. Per-entry escape
# scratch also flows through `a`; the str_builder used for assembly
# remains on the global bump (see comment on sandhi_json_escape_a).
fn sandhi_json_build_a(a, o): i64 {
    if (o == 0) { return _sandhi_json_dup_a(a, "{}"); }
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{");
    var n = vec_len(o);
    var i = 0;
    while (i < n) {
        if (i > 0) { str_builder_add_cstr(sb, ","); }
        var e = vec_get(o, i);
        var ekey = load64(e);
        var eval = load64(e + 8);
        var ekind = load64(e + 16);
        var escaped_key = sandhi_json_escape_a(a, ekey);
        str_builder_add_cstr(sb, escaped_key);
        str_builder_add_cstr(sb, ":");
        if (ekind == SANDHI_JSON_STRING) {
            var escaped_val = sandhi_json_escape_a(a, eval);
            str_builder_add_cstr(sb, escaped_val);
        } else {
            str_builder_add_cstr(sb, eval);
        }
        i = i + 1;
    }
    str_builder_add_cstr(sb, "}");
    var built = str_data(str_builder_build(sb));
    # str_builder_build's output lives on the global bump; dup into
    # `a` so the returned cstr matches the caller's lifetime contract
    # (arena reset must reclaim it). Cheap — JSON bodies are small.
    return _sandhi_json_dup_a(a, built);
}

fn sandhi_json_build(o): i64 {
    return sandhi_json_build_a(default_alloc(), o);
}

# ================================================================
# Extract — dotted-path navigation.
# ================================================================
#
# Usage: sandhi_json_get_string(body, "value.sessionId") → cstr or 0.
#
# Supports nested object paths only — arrays and escape-sequences in
# values are handled by the caller if needed. Good enough for the
# WebDriver / MCP response shapes we actually see.

# Internal: find the next "key":"... after `start` and return offset
# of the value's opening quote or opening brace. Matches key as
# substring, relies on proper JSON lack-of-colons-in-keys. `key_len`
# is strlen(key).
fn _sandhi_json_find_key(body, blen, start, key, key_len): i64 {
    var i = start;
    while (i + key_len + 3 < blen) {
        if (load8(body + i) == 34) {
            # At a quote — check if it starts the target key.
            if (memeq(body + i + 1, key, key_len) == 1
            && load8(body + i + 1 + key_len) == 34) {
                # Skip "key"
                var p = i + 2 + key_len;
                # Skip whitespace + colon.
                while (p < blen && load8(body + p) == 32) { p = p + 1; }
                if (p < blen && load8(body + p) == 58) {
                    p = p + 1;
                    while (p < blen && load8(body + p) == 32) { p = p + 1; }
                    return p;
                }
            }
        }
        i = i + 1;
    }
    return 0 - 1;
}

# Skip past balanced braces starting at `start` (buf[start] == '{').
# Returns the offset just past the matching '}'.
fn _sandhi_json_skip_object(body, blen, start): i64 {
    if (start >= blen || load8(body + start) != 123) { return 0 - 1; }
    var depth = 1;
    var p = start + 1;
    var in_string = 0;
    var prev_backslash = 0;
    while (p < blen && depth > 0) {
        var c = load8(body + p);
        if (in_string == 1) {
            if (c == 92 && prev_backslash == 0) { prev_backslash = 1; }
            else {
                if (c == 34 && prev_backslash == 0) { in_string = 0; }
                prev_backslash = 0;
            }
        } else {
            if (c == 34) { in_string = 1; }
            elif (c == 123) { depth = depth + 1; }
            elif (c == 125) { depth = depth - 1; }
        }
        p = p + 1;
    }
    return p;
}

# Walk a dotted path, allocating per-segment scratch in `a`. The
# segments are transient — arena reset after this returns reclaims
# them. Returns (off << 32) | len encoding a value range, or 0 - 1.
fn _sandhi_json_path_range_a(a, body, blen, path): i64 {
    var scope_start = 0;
    var scope_end = blen;
    var pi = 0;
    var plen = strlen(path);
    while (pi < plen) {
        var seg_end = pi;
        while (seg_end < plen && load8(path + seg_end) != 46) { seg_end = seg_end + 1; }
        var seg_len = seg_end - pi;
        if (seg_len == 0) { return 0 - 1; }
        var seg = alloc_via(a, seg_len + 1);
        if (seg == 0) { return 0 - 1; }
        memcpy(seg, path + pi, seg_len);
        store8(seg + seg_len, 0);

        var vpos = _sandhi_json_find_key(body, scope_end, scope_start, seg, seg_len);
        if (vpos < 0) { return 0 - 1; }

        if (seg_end >= plen) {
            return _sandhi_json_value_range(body, blen, vpos);
        }
        if (load8(body + vpos) != 123) { return 0 - 1; }
        scope_start = vpos + 1;
        scope_end = _sandhi_json_skip_object(body, blen, vpos);
        if (scope_end < 0) { return 0 - 1; }
        pi = seg_end + 1;
    }
    return 0 - 1;
}

fn _sandhi_json_path_range(body, blen, path): i64 {
    return _sandhi_json_path_range_a(default_alloc(), body, blen, path);
}

# Given an offset at the start of a JSON value (quote, brace, digit,
# or literal), return (off << 32) | len covering the value bytes.
# For strings the range excludes the surrounding quotes.
fn _sandhi_json_value_range(body, blen, start): i64 {
    if (start >= blen) { return 0 - 1; }
    var c = load8(body + start);
    if (c == 34) {
        # String — scan until unescaped closing quote.
        var p = start + 1;
        var prev = 0;
        while (p < blen) {
            var cc = load8(body + p);
            if (cc == 34 && prev != 92) {
                var off = start + 1;
                var len = p - off;
                return (off << 32) | len;
            }
            if (cc == 92 && prev == 92) { prev = 0; }
            else { prev = cc; }
            p = p + 1;
        }
        return 0 - 1;
    }
    if (c == 123) {
        # Object — include the braces.
        var endp = _sandhi_json_skip_object(body, blen, start);
        if (endp < 0) { return 0 - 1; }
        var lenO = endp - start;
        return (start << 32) | lenO;
    }
    # Numeric / true / false / null — until ',' '}' ']' or whitespace.
    var ps = start;
    var pe = start;
    while (pe < blen) {
        var ce = load8(body + pe);
        if (ce == 44 || ce == 125 || ce == 93 || ce == 32 || ce == 10 || ce == 13 || ce == 9) {
            var lenN = pe - ps;
            return (ps << 32) | lenN;
        }
        pe = pe + 1;
    }
    var lenT = pe - ps;
    return (ps << 32) | lenT;
}

# Extract a string at the dotted path, allocating the returned cstr
# from `a`. Returns 0 if not found or on OOM.
fn sandhi_json_get_string_a(a, body, path): i64 {
    if (body == 0 || path == 0) { return 0; }
    var blen = strlen(body);
    var r = _sandhi_json_path_range_a(a, body, blen, path);
    if (r == 0 - 1) { return 0; }
    var off = r >> 32;
    var len = r & 0xFFFFFFFF;
    var out = alloc_via(a, len + 1);
    if (out == 0) { return 0; }
    memcpy(out, body + off, len);
    store8(out + len, 0);
    return out;
}

fn sandhi_json_get_string(body, path): i64 {
    return sandhi_json_get_string_a(default_alloc(), body, path);
}

# Extract an integer at the dotted path. Returns 0 if absent or
# non-numeric; caller should pre-check with sandhi_json_has_path
# if zero vs absent needs to be distinguished. The transient string
# the int is parsed from lives in `a`.
fn sandhi_json_get_int_a(a, body, path): i64 {
    var v = sandhi_json_get_string_a(a, body, path);
    if (v == 0) { return 0; }
    return atoi(v);
}

fn sandhi_json_get_int(body, path): i64 {
    return sandhi_json_get_int_a(default_alloc(), body, path);
}

# 1 if the path exists, 0 otherwise. Path scratch lives in `a`.
# Local len var is `body_len` rather than `blen` (which is what the
# sibling `sandhi_json_get_string_a` uses) to dodge the cyrius 5.8.36
# linter's "global var init refs N declared at line M" false-positive
# triggered when two functions in the same file have a same-named
# local `var blen = strlen(body)` at the head.
fn sandhi_json_has_path_a(a, body, path): i64 {
    if (body == 0 || path == 0) { return 0; }
    var body_len = strlen(body);
    if (_sandhi_json_path_range_a(a, body, body_len, path) == 0 - 1) { return 0; }
    return 1;
}

fn sandhi_json_has_path(body, path): i64 {
    return sandhi_json_has_path_a(default_alloc(), body, path);
}


# --- dispatch.cyr ---

# sandhi/rpc/dispatch — JSON-over-HTTP request/response core.
#
# Takes a URL + HTTP method + JSON body, sends via sandhi_http_*,
# parses the response body for a dialect-specific error envelope,
# and returns a unified rpc-response struct.
#
# The dialect enum picks the error extractor. Adding a new dialect
# is a two-line change to `_sandhi_rpc_err_extract`.

enum SandhiRpcDialect {
    SANDHI_RPC_DIALECT_GENERIC   = 0;  # plain JSON; error = non-2xx status
    SANDHI_RPC_DIALECT_WEBDRIVER = 1;  # W3C: {"value":{"error":"...","message":"..."}}
    SANDHI_RPC_DIALECT_JSONRPC   = 2;  # JSON-RPC 2.0: {"error":{"code":N,"message":"..."}}
}

# Response struct (40 bytes):
#   +0   http_status  (int: 0 on network error, 100..599 otherwise)
#   +8   body_ptr     (ptr: cstr of response body, 0 on network error)
#   +16  body_len     (int)
#   +24  err_kind     (int: SandhiErrorKind — 0 on success, REMOTE on dialect err, etc.)
#   +32  err_message  (ptr: cstr, 0 if no error or network error)
enum SandhiRpcRespOff {
    SANDHI_RPC_OFF_STATUS  = 0;
    SANDHI_RPC_OFF_BODY    = 8;
    SANDHI_RPC_OFF_BLEN    = 16;
    SANDHI_RPC_OFF_ERR     = 24;
    SANDHI_RPC_OFF_ERR_MSG = 32;
}

var SANDHI_RPC_RESP_SIZE = 40;

fn sandhi_rpc_http_status(r): i64 { return load64(r + SANDHI_RPC_OFF_STATUS); }
fn sandhi_rpc_body(r): i64 { return load64(r + SANDHI_RPC_OFF_BODY); }
fn sandhi_rpc_body_len(r): i64 { return load64(r + SANDHI_RPC_OFF_BLEN); }
fn sandhi_rpc_err_kind(r): i64 { return load64(r + SANDHI_RPC_OFF_ERR); }
fn sandhi_rpc_err_message(r): i64 { return load64(r + SANDHI_RPC_OFF_ERR_MSG); }

# 1 if the rpc call succeeded at the dialect level (no error envelope
# extracted and HTTP 2xx). Handy for early returns.
fn sandhi_rpc_ok(r): i64 {
    if (sandhi_rpc_err_kind(r) != SANDHI_OK) { return 0; }
    var s = sandhi_rpc_http_status(r);
    if (s < 200 || s >= 300) { return 0; }
    return 1;
}

fn _sandhi_rpc_resp_new_a(a, status, body, blen, err_kind, err_msg): i64 {
    var r = alloc_via(a, SANDHI_RPC_RESP_SIZE);
    if (r == 0) { return 0; }
    store64(r + SANDHI_RPC_OFF_STATUS, status);
    store64(r + SANDHI_RPC_OFF_BODY, body);
    store64(r + SANDHI_RPC_OFF_BLEN, blen);
    store64(r + SANDHI_RPC_OFF_ERR, err_kind);
    store64(r + SANDHI_RPC_OFF_ERR_MSG, err_msg);
    return r;
}

fn _sandhi_rpc_resp_new(status, body, blen, err_kind, err_msg): i64 {
    return _sandhi_rpc_resp_new_a(default_alloc(), status, body, blen, err_kind, err_msg);
}

# Extract the dialect-specific error envelope. Returns the message
# cstr if an error envelope was present, or 0 otherwise. Leaves the
# caller to set err_kind based on context.
# Extract the dialect-specific error envelope into `a`. JSON path
# scratch + the returned message both flow through `a`.
fn _sandhi_rpc_err_extract_a(a, body, dialect): i64 {
    if (body == 0) { return 0; }
    if (dialect == SANDHI_RPC_DIALECT_WEBDRIVER) {
        if (sandhi_json_has_path_a(a, body, "value.error") == 1) {
            var m = sandhi_json_get_string_a(a, body, "value.message");
            if (m == 0) { m = sandhi_json_get_string_a(a, body, "value.error"); }
            return m;
        }
        return 0;
    }
    if (dialect == SANDHI_RPC_DIALECT_JSONRPC) {
        if (sandhi_json_has_path_a(a, body, "error.code") == 1) {
            var m2 = sandhi_json_get_string_a(a, body, "error.message");
            if (m2 == 0) { m2 = _sandhi_rpc_dup_a(a, "rpc error"); }
            return m2;
        }
        return 0;
    }
    return 0;
}

fn _sandhi_rpc_err_extract(body, dialect): i64 {
    return _sandhi_rpc_err_extract_a(default_alloc(), body, dialect);
}

fn _sandhi_rpc_dup_a(a, s): i64 {
    if (s == 0) { return 0; }
    var n = strlen(s);
    var out = alloc_via(a, n + 1);
    if (out == 0) { return 0; }
    memcpy(out, s, n);
    store8(out + n, 0);
    return out;
}

fn _sandhi_rpc_dup(s): i64 {
    return _sandhi_rpc_dup_a(default_alloc(), s);
}

# Pick the HTTP verb for the request shape. WebDriver / MCP / Appium
# all use POST or GET or DELETE; the dispatcher stays method-agnostic.
# `http_method` is a cstr: "GET" / "POST" / "DELETE" / "PUT" / "PATCH".
fn _sandhi_rpc_http_send(url, http_method, body_json, headers): i64 {
    var body_len = 0;
    if (body_json != 0) { body_len = strlen(body_json); }
    if (streq(http_method, "GET") == 1) {
        return sandhi_http_get(url, headers);
    }
    if (streq(http_method, "DELETE") == 1) {
        return sandhi_http_delete(url, headers);
    }
    if (streq(http_method, "PUT") == 1) {
        return sandhi_http_put(url, headers, body_json, body_len);
    }
    if (streq(http_method, "PATCH") == 1) {
        return sandhi_http_patch(url, headers, body_json, body_len);
    }
    # Default to POST.
    return sandhi_http_post(url, headers, body_json, body_len);
}

# Core RPC call backed by `a`. Header block, error envelope, and
# resp struct all flow through `a`. The HTTP response struct itself
# is owned by the http client (Batch 4 / 6 routes those through an
# Allocator); we wrap its body pointer here without re-dup'ing.
fn sandhi_rpc_call_a(a, url, http_method, body_json, dialect): i64 {
    sandhi_trace_begin("sandhi.rpc");
    var r = _sandhi_rpc_call_impl_a(a, url, http_method, body_json, dialect);
    sandhi_trace_end();
    return r;
}

fn sandhi_rpc_call(url, http_method, body_json, dialect): i64 {
    return sandhi_rpc_call_a(default_alloc(), url, http_method, body_json, dialect);
}

fn _sandhi_rpc_call_impl_a(a, url, http_method, body_json, dialect): i64 {
    var headers = sandhi_headers_new_a(a);
    if (headers == 0) { return _sandhi_rpc_resp_new_a(a, 0, 0, 0, SANDHI_ERR_INTERNAL, 0); }
    if (body_json != 0) {
        sandhi_headers_set_a(a, headers, "Content-Type", "application/json");
    }
    sandhi_headers_set_a(a, headers, "Accept", "application/json");
    var hr = _sandhi_rpc_http_send(url, http_method, body_json, headers);
    return _sandhi_rpc_wrap_a(a, hr, dialect);
}

fn _sandhi_rpc_call_impl(url, http_method, body_json, dialect): i64 {
    return _sandhi_rpc_call_impl_a(default_alloc(), url, http_method, body_json, dialect);
}

# Variant that accepts caller-supplied headers (for auth, session
# cookies, etc.). Content-Type / Accept still auto-injected when absent.
# Header mutations land in `a`; the user_headers block itself is the
# caller's responsibility.
fn sandhi_rpc_call_with_headers_a(a, url, http_method, body_json, user_headers, dialect): i64 {
    sandhi_trace_begin("sandhi.rpc");
    var r = _sandhi_rpc_call_with_headers_impl_a(a, url, http_method, body_json, user_headers, dialect);
    sandhi_trace_end();
    return r;
}

fn sandhi_rpc_call_with_headers(url, http_method, body_json, user_headers, dialect): i64 {
    return sandhi_rpc_call_with_headers_a(default_alloc(), url, http_method, body_json, user_headers, dialect);
}

fn _sandhi_rpc_call_with_headers_impl_a(a, url, http_method, body_json, user_headers, dialect): i64 {
    var headers = user_headers;
    if (headers == 0) {
        headers = sandhi_headers_new_a(a);
        if (headers == 0) { return _sandhi_rpc_resp_new_a(a, 0, 0, 0, SANDHI_ERR_INTERNAL, 0); }
    }
    if (body_json != 0 && sandhi_headers_has(headers, "Content-Type") == 0) {
        sandhi_headers_set_a(a, headers, "Content-Type", "application/json");
    }
    if (sandhi_headers_has(headers, "Accept") == 0) {
        sandhi_headers_set_a(a, headers, "Accept", "application/json");
    }
    var hr = _sandhi_rpc_http_send(url, http_method, body_json, headers);
    return _sandhi_rpc_wrap_a(a, hr, dialect);
}

fn _sandhi_rpc_call_with_headers_impl(url, http_method, body_json, user_headers, dialect): i64 {
    return _sandhi_rpc_call_with_headers_impl_a(default_alloc(), url, http_method, body_json, user_headers, dialect);
}

# Wrap an HTTP response into an rpc-response, allocating the wrapper
# and the extracted err message into `a`. The HTTP response's body
# pointer is shared (not dup'd) — caller manages its lifetime.
fn _sandhi_rpc_wrap_a(a, hr, dialect): i64 {
    var ek = sandhi_http_err_kind(hr);
    if (ek != SANDHI_OK) {
        return _sandhi_rpc_resp_new_a(a, 0, 0, 0, ek, 0);
    }
    var status = sandhi_http_status(hr);
    var body = sandhi_http_body(hr);
    var blen = sandhi_http_body_len(hr);

    var env_msg = _sandhi_rpc_err_extract_a(a, body, dialect);
    if (env_msg != 0) {
        return _sandhi_rpc_resp_new_a(a, status, body, blen, SANDHI_ERR_REMOTE, env_msg);
    }
    if (status >= 400) {
        return _sandhi_rpc_resp_new_a(a, status, body, blen, SANDHI_ERR_REMOTE, 0);
    }
    return _sandhi_rpc_resp_new_a(a, status, body, blen, SANDHI_OK, 0);
}

fn _sandhi_rpc_wrap(hr, dialect): i64 {
    return _sandhi_rpc_wrap_a(default_alloc(), hr, dialect);
}


# --- webdriver.cyr ---

# sandhi/rpc/webdriver — W3C WebDriver dialect.
#
# Reference: https://www.w3.org/TR/webdriver2/
#
# WebDriver is REST-like, not JSON-RPC 2.0. Requests are HTTP
# method+path against a base URL (typically http://127.0.0.1:PORT).
# Responses envelope the result in {"value": ...}; errors envelope
# in {"value": {"error": "<tag>", "message": "..."}}.
#
# Scope: the verb set yantra M2 needs to drive a session end-to-end.
# Extensions can land as separate patches when additional consumers
# ask; one dialect file stays small per CLAUDE.md.

# ================================================================
# URL building helpers
# ================================================================

# Join base URL and a path. Handles trailing-slash presence or absence
# on base. Path must start with '/'.
# Join base + path into `a`. Returns 0 on OOM.
fn _sandhi_wd_join_a(a, base, path): i64 {
    var blen = strlen(base);
    var plen = strlen(path);
    var has_trailing = 0;
    if (blen > 0 && load8(base + blen - 1) == 47) { has_trailing = 1; }
    var total = blen + plen;
    if (has_trailing == 1) { total = blen + plen - 1; }
    var out = alloc_via(a, total + 1);
    if (out == 0) { return 0; }
    memcpy(out, base, blen);
    var at = blen;
    if (has_trailing == 1) { at = blen - 1; }
    memcpy(out + at, path, plen);
    store8(out + at + plen, 0);
    return out;
}

fn _sandhi_wd_join(base, path): i64 {
    return _sandhi_wd_join_a(default_alloc(), base, path);
}

# Build base + "/session/{id}" + suffix into `a`. The trim-copy of the
# base lives in `a`; the str_builder scratch still uses the global bump,
# but the final cstr is dup'd into `a` so arena reset reclaims it.
fn _sandhi_wd_session_url_a(a, base, session_id, suffix): i64 {
    var sb = str_builder_new();
    var blen = strlen(base);
    var has_trailing = 0;
    if (blen > 0 && load8(base + blen - 1) == 47) { has_trailing = 1; }
    if (has_trailing == 1) {
        var trimmed = alloc_via(a, blen);
        if (trimmed == 0) { return 0; }
        memcpy(trimmed, base, blen - 1);
        store8(trimmed + blen - 1, 0);
        str_builder_add_cstr(sb, trimmed);
    } else {
        str_builder_add_cstr(sb, base);
    }
    str_builder_add_cstr(sb, "/session/");
    str_builder_add_cstr(sb, session_id);
    if (suffix != 0 && strlen(suffix) > 0) {
        str_builder_add_cstr(sb, suffix);
    }
    return _sandhi_json_dup_a(a, str_data(str_builder_build(sb)));
}

fn _sandhi_wd_session_url(base, session_id, suffix): i64 {
    return _sandhi_wd_session_url_a(default_alloc(), base, session_id, suffix);
}

# ================================================================
# Session lifecycle
# ================================================================

# POST /session — start a new WebDriver session against `base_url`.
# `capabilities_json` is a cstr of the full request body (not just the
# `capabilities` subtree — caller can build nested via rpc/json).
# If caller passes 0, a minimal `{"capabilities":{"alwaysMatch":{}}}`
# is used, letting the driver pick defaults.
#
# Returns an rpc-response. Session ID is available via
# sandhi_wd_extract_session_id on success.
# 1.2.4 Batch F: each verb gains an `_a` variant; bare versions
# stay as back-compat wrappers passing `default_alloc()`. Each
# `_a` threads `a` through the URL builder, the JSON body
# builder, and `sandhi_rpc_call_a` (paired since 1.1.0).
fn sandhi_wd_new_session_a(a, base_url, capabilities_json): i64 {
    var url = _sandhi_wd_join_a(a, base_url, "/session");
    var body = capabilities_json;
    if (body == 0) {
        body = "{\"capabilities\":{\"alwaysMatch\":{}}}";
    }
    return sandhi_rpc_call_a(a, url, "POST", body, SANDHI_RPC_DIALECT_WEBDRIVER);
}

fn sandhi_wd_new_session(base_url, capabilities_json): i64 {
    return sandhi_wd_new_session_a(default_alloc(), base_url, capabilities_json);
}

# Pull the session ID out of a new_session response body.
# W3C: {"value":{"sessionId":"<id>","capabilities":{...}}}.
# Returns alloc'd cstr or 0 if absent.
fn sandhi_wd_extract_session_id_a(a, resp): i64 {
    var body = sandhi_rpc_body(resp);
    if (body == 0) { return 0; }
    # Try W3C shape first, then pre-W3C fallback for older drivers.
    var sid = sandhi_json_get_string_a(a, body, "value.sessionId");
    if (sid != 0) { return sid; }
    return sandhi_json_get_string_a(a, body, "sessionId");
}

fn sandhi_wd_extract_session_id(resp): i64 {
    return sandhi_wd_extract_session_id_a(default_alloc(), resp);
}

