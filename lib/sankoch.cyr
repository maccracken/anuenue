# sankoch — types and constants
# Shared types, error codes, format identifiers.

# Compression formats
enum Format {
    FORMAT_LZ4 = 1;       # Raw LZ4 block format (no frame envelope)
    FORMAT_DEFLATE = 2;
    FORMAT_ZLIB = 3;
    FORMAT_GZIP = 4;
    FORMAT_LZ4F = 5;      # LZ4 frame format (magic + header + blocks + trailer)
    FORMAT_XZ = 6;        # .xz container (LZMA2) — de/compress (2.4.0 / 2.4.1)
    FORMAT_BZIP2 = 7;     # .bz2 (BWT + Huffman) — decode only (2.4.2)
}

# Error codes
enum Error {
    OK = 0;
    ERR_INVALID_INPUT = 1;
    ERR_BUFFER_TOO_SMALL = 2;
    ERR_CORRUPT_DATA = 3;
    ERR_UNSUPPORTED_FORMAT = 4;
    ERR_CHECKSUM_MISMATCH = 5;
    ERR_OUTPUT_LIMIT = 6;
    ERR_INVALID_BLOCK_TYPE = 7;
    ERR_INVALID_HUFFMAN = 8;
    ERR_MATCH_OUT_OF_RANGE = 9;
    ERR_OOM = 10;             # allocation failure (2.3.7: lazy-global / arena allocs)
}

# Limits and magic bytes
enum Limits {
    LZ4_MAX_BLOCK_SIZE = 4194304;       # 4MB
    DEFLATE_WINDOW_SIZE = 32768;        # 32KB sliding window
    DEFLATE_MAX_MATCH = 258;
    DEFLATE_MIN_MATCH = 3;
    GZIP_MAGIC_0 = 31;                 # 0x1f
    GZIP_MAGIC_1 = 139;                # 0x8b
    ZLIB_MAX_WBITS = 15;
    DECOMPRESS_MAX_OUTPUT = 16777216;  # 16MB hard ceiling for decompression
}

# --- xxhash32.cyr ---

# sankoch — xxHash32 batch (kernel-safe subset)
# Used by LZ4 frame format for header and content checksums.
# Pure-compute: no alloc, no syscalls, no mutex. Lives in its own
# module so the `[lib.core]` distlib profile (kernel-safe LZ4
# decompress) can pull it in without dragging the alloc-using
# incremental state APIs from src/checksum.cyr.

enum XXH32 {
    XXH32_PRIME1 = 2654435761;   # 0x9E3779B1
    XXH32_PRIME2 = 2246822519;   # 0x85EBCA77
    XXH32_PRIME3 = 3266489917;   # 0xC2B2AE3D
    XXH32_PRIME4 = 668265263;    # 0x27D4EB2F
    XXH32_PRIME5 = 374761393;    # 0x165667B1
}

fn _xxh32_rotl(v, n): i64 {
    var v32 = v & 4294967295;
    return ((v32 << n) | (v32 >> (32 - n))) & 4294967295;
}

# One stripe-accumulator round: acc = rotl32((acc + input*PRIME2), 13) * PRIME1
fn _xxh32_round(acc, input): i64 {
    var m = 4294967295;
    acc = (acc + (input * XXH32_PRIME2) & m) & m;
    acc = _xxh32_rotl(acc, 13);
    acc = (acc * XXH32_PRIME1) & m;
    return acc;
}

# Compute xxHash32 of data[0..len) with seed 0. Matches reference xxHash32:
# https://github.com/Cyan4973/xxHash/blob/dev/doc/xxhash_spec.md
# For inputs >= 16 bytes, uses 4 parallel stripe accumulators; shorter inputs
# skip straight to the tail. The 4-byte tail uses PRIME4 in both paths.
fn xxhash32(data, len): i64 {
    var m = 4294967295;
    var h = 0;
    var i = 0;

    if (len >= 16) {
        var v1 = (XXH32_PRIME1 + XXH32_PRIME2) & m;   # seed=0 + PRIME1 + PRIME2
        var v2 = XXH32_PRIME2;                         # seed=0 + PRIME2
        var v3 = 0;                                    # seed=0 + 0
        var v4 = (0 - XXH32_PRIME1) & m;               # seed=0 - PRIME1 (32-bit two's complement)

        var stripe_end = len - 16;
        while (i <= stripe_end) {
            var k1 = load8(data + i) | (load8(data + i + 1) << 8) |
            (load8(data + i + 2) << 16) | (load8(data + i + 3) << 24);
            var k2 = load8(data + i + 4) | (load8(data + i + 5) << 8) |
            (load8(data + i + 6) << 16) | (load8(data + i + 7) << 24);
            var k3 = load8(data + i + 8) | (load8(data + i + 9) << 8) |
            (load8(data + i + 10) << 16) | (load8(data + i + 11) << 24);
            var k4 = load8(data + i + 12) | (load8(data + i + 13) << 8) |
            (load8(data + i + 14) << 16) | (load8(data + i + 15) << 24);
            v1 = _xxh32_round(v1, k1 & m);
            v2 = _xxh32_round(v2, k2 & m);
            v3 = _xxh32_round(v3, k3 & m);
            v4 = _xxh32_round(v4, k4 & m);
            i = i + 16;
        }

        h = (_xxh32_rotl(v1, 1) + _xxh32_rotl(v2, 7) +
        _xxh32_rotl(v3, 12) + _xxh32_rotl(v4, 18)) & m;
    } else {
        h = XXH32_PRIME5;
    }

    h = (h + len) & m;

    # 4-byte tail (reference uses PRIME4 here, not PRIME2)
    while (i + 4 <= len) {
        var k = load8(data + i) | (load8(data + i + 1) << 8) |
        (load8(data + i + 2) << 16) | (load8(data + i + 3) << 24);
        k = k & m;
        h = (h + (k * XXH32_PRIME3) & m) & m;
        h = (_xxh32_rotl(h, 17) * XXH32_PRIME4) & m;
        i = i + 4;
    }

    # Byte tail
    while (i < len) {
        h = (h + (load8(data + i) * XXH32_PRIME5) & m) & m;
        h = (_xxh32_rotl(h, 11) * XXH32_PRIME1) & m;
        i = i + 1;
    }

    # Avalanche
    h = h ^ (h >> 15);
    h = (h * XXH32_PRIME2) & m;
    h = h ^ (h >> 13);
    h = (h * XXH32_PRIME3) & m;
    h = h ^ (h >> 16);
    return h;
}

# --- checksum.cyr ---

# sankoch — checksum algorithms
# Adler-32 (RFC 1950), CRC-32 (RFC 1952), xxHash32 (for LZ4 frame format).
# Inline implementations — too small to warrant a sigil dependency.
#
# Adler-32 uses scalar optimizations for the inner loop (both batch
# `adler32` and incremental `adler32_update`):
# - Deferred modulo: % 65521 every NMAX (5552) bytes instead of every byte
# - 16-byte unrolled inner loop accumulating s2 in closed form
# - Scalar fallback for the tail
# CRC-32 uses a slice-by-8 table (2.3.4): 8 bytes folded per iteration
# via one little-endian load64 + eight parallel table lookups (~2×
# the old serial byte-at-a-time table). Pure integer, portable across
# x86_64 + aarch64. True SIMD (SSE2/AVX2 for Adler, PCLMULQDQ for
# CRC-32) is feasible on 5.5.22+ (raw `asm` blocks are exposed) but
# stays deferred — it is x86-only (the aarch64 cross-build gate would
# need a PMULL path or a scalar fallback) and the slice-by-8 + scalar
# unrolls already put checksums off the hot path for today's consumers.

enum Checksum {
    ADLER_MOD = 65521;   # largest prime < 2^16
    ADLER_NMAX = 5552;   # max bytes before s1 can overflow 32 bits: 255*5552 < 2^32
}

# Adler-32: two running sums mod 65521 (largest prime < 2^16).
# Source: RFC 1950, Section 2.2
#
# Optimization: defer the expensive modulo operation.
# Within a block of NMAX bytes, s1 stays < 65521 + 255*5552 < 2^32
# and s2 stays < 65521*5553 + ... < 2^32, so no overflow in 64-bit.
fn adler32(data, len): i64 {
    var s1 = 1;
    var s2 = 0;
    var off = 0;

    while (off < len) {
        # Process up to NMAX bytes before taking modulo
        var block = len - off;
        if (block > ADLER_NMAX) { block = ADLER_NMAX; }
        var end = off + block;

        # Unrolled inner loop: process 16 bytes per iteration
        while (off + 16 <= end) {
            # s2 accumulates 16 copies of s1 plus weighted byte sums
            # s2 += 16*s1 + 16*b0 + 15*b1 + 14*b2 + ... + 1*b15
            var b0 = load8(data + off);
            var b1 = load8(data + off + 1);
            var b2 = load8(data + off + 2);
            var b3 = load8(data + off + 3);
            var b4 = load8(data + off + 4);
            var b5 = load8(data + off + 5);
            var b6 = load8(data + off + 6);
            var b7 = load8(data + off + 7);
            var b8 = load8(data + off + 8);
            var b9 = load8(data + off + 9);
            var b10 = load8(data + off + 10);
            var b11 = load8(data + off + 11);
            var b12 = load8(data + off + 12);
            var b13 = load8(data + off + 13);
            var b14 = load8(data + off + 14);
            var b15 = load8(data + off + 15);

            s2 = s2 + (s1 * 16);
            s2 = s2 + (b0 * 16) + (b1 * 15) + (b2 * 14) + (b3 * 13);
            s2 = s2 + (b4 * 12) + (b5 * 11) + (b6 * 10) + (b7 * 9);
            s2 = s2 + (b8 * 8) + (b9 * 7) + (b10 * 6) + (b11 * 5);
            s2 = s2 + (b12 * 4) + (b13 * 3) + (b14 * 2) + b15;

            s1 = s1 + b0 + b1 + b2 + b3 + b4 + b5 + b6 + b7;
            s1 = s1 + b8 + b9 + b10 + b11 + b12 + b13 + b14 + b15;

            off = off + 16;
        }

        # Scalar tail for remaining bytes in this block
        while (off < end) {
            s1 = s1 + load8(data + off);
            s2 = s2 + s1;
            off = off + 1;
        }

        # Deferred modulo — once per NMAX block
        s1 = s1 % ADLER_MOD;
        s2 = s2 % ADLER_MOD;
    }

    return (s2 * 65536) + s1;  # (s2 << 16) | s1
}

# Incremental Adler-32 API — used by zlib streaming.
#
# Layout (24 bytes):
#   +0:  s1 (running, modulo deferred within NMAX window)
#   +8:  s2 (running, modulo deferred within NMAX window)
#   +16: n_since_mod (bytes processed since last modulo reduction)

fn adler32_init(): i64 {
    var st = _sankoch_alloc(24);
    if (st == 0) { return 0; }   # 2.2.1: caller checks for alloc failure
    store64(st, 1);        # s1 = 1
    store64(st + 8, 0);    # s2 = 0
    store64(st + 16, 0);
    return st;
}

fn adler32_update(st, data, len): i64 {
    if (len <= 0) { return 0; }
    var s1 = load64(st);
    var s2 = load64(st + 8);
    var n = load64(st + 16);
    var off = 0;
    while (off < len) {
        var block = ADLER_NMAX - n;
        if (block > len - off) { block = len - off; }
        var end = off + block;

        # 16-byte unroll — mirrors the closed-form inner loop in
        # batch adler32(). Safe within a block because block <=
        # ADLER_NMAX - n <= NMAX, so s1/s2 cannot overflow i64.
        while (off + 16 <= end) {
            var b0 = load8(data + off);
            var b1 = load8(data + off + 1);
            var b2 = load8(data + off + 2);
            var b3 = load8(data + off + 3);
            var b4 = load8(data + off + 4);
            var b5 = load8(data + off + 5);
            var b6 = load8(data + off + 6);
            var b7 = load8(data + off + 7);
            var b8 = load8(data + off + 8);
            var b9 = load8(data + off + 9);
            var b10 = load8(data + off + 10);
            var b11 = load8(data + off + 11);
            var b12 = load8(data + off + 12);
            var b13 = load8(data + off + 13);
            var b14 = load8(data + off + 14);
            var b15 = load8(data + off + 15);

            s2 = s2 + (s1 * 16);
            s2 = s2 + (b0 * 16) + (b1 * 15) + (b2 * 14) + (b3 * 13);
            s2 = s2 + (b4 * 12) + (b5 * 11) + (b6 * 10) + (b7 * 9);
            s2 = s2 + (b8 * 8) + (b9 * 7) + (b10 * 6) + (b11 * 5);
            s2 = s2 + (b12 * 4) + (b13 * 3) + (b14 * 2) + b15;

            s1 = s1 + b0 + b1 + b2 + b3 + b4 + b5 + b6 + b7;
            s1 = s1 + b8 + b9 + b10 + b11 + b12 + b13 + b14 + b15;

            off = off + 16;
        }

        # Scalar tail for remaining bytes in this block
        while (off < end) {
            s1 = s1 + load8(data + off);
            s2 = s2 + s1;
            off = off + 1;
        }
        n = n + block;
        if (n >= ADLER_NMAX) {
            s1 = s1 % ADLER_MOD;
            s2 = s2 % ADLER_MOD;
            n = 0;
        }
    }
    store64(st, s1);
    store64(st + 8, s2);
    store64(st + 16, n);
    return 0;
}

fn adler32_final(st): i64 {
    var s1 = load64(st) % ADLER_MOD;
    var s2 = load64(st + 8) % ADLER_MOD;
    return (s2 * 65536) + s1;
}

# CRC-32: table-driven, polynomial 0xEDB88320 (reflected).
# Source: RFC 1952, Section 8
# Table must be initialized once via crc32_init_table().
var crc32_table = 0;  # heap-allocated: slice-by-8 table, 8 × 256 entries × 8 bytes

# Initialize the slice-by-8 CRC-32 lookup table (must be called before
# crc32). 2.3.4: grew from a single 256-entry table to eight slices so
# the hot loop folds 8 bytes per iteration (Kadatch & Jenkins). Slice 0
# is the classic reflected-0xEDB88320 table (also used by the scalar
# tail); slices 1..7 are derived. Same CRC output — wire-identical.
fn crc32_init_table(): i64 {
    if (crc32_table == 0) {
        crc32_table = _sankoch_alloc(16384);   # 8 × 256 × 8
        if (crc32_table == 0) { return 0 - ERR_OOM; }
    }
    # Slice 0: standard reflected CRC-32 table.
    var i = 0;
    while (i < 256) {
        var c = i;
        var j = 0;
        while (j < 8) {
            if (c & 1) {
                # 0xEDB88320 = 3988292384
                c = (c >> 1) ^ 3988292384;
            } else {
                c = c >> 1;
            }
            j = j + 1;
        }
        store64(crc32_table + i * 8, c);
        i = i + 1;
    }
    # Slices 1..7: table[k][n] = (table[k-1][n] >> 8) ^ table[0][table[k-1][n] & 0xFF].
    var k = 1;
    while (k < 8) {
        var n = 0;
        while (n < 256) {
            var prev = load64(crc32_table + ((k - 1) * 256 + n) * 8);
            var v = (prev >> 8) ^ load64(crc32_table + (prev & 255) * 8);
            store64(crc32_table + (k * 256 + n) * 8, v);
            n = n + 1;
        }
        k = k + 1;
    }
    return 0;
}

# Slice-by-8 core: fold `len` bytes of `data` into the running (pre-
# inversion) CRC and return it. One load64 per 8 bytes — both x86_64 and
# aarch64 are little-endian, so the low/high 32-bit halves of the word
# are exactly the reference's load32_le(buf) / load32_le(buf+4). Assumes
# crc32_init_table() has populated crc32_table. Shared by batch + stream.
fn _crc32_fold(crc, data, len): i64 {
    var t0 = crc32_table;
    var t1 = crc32_table + 2048;
    var t2 = crc32_table + 4096;
    var t3 = crc32_table + 6144;
    var t4 = crc32_table + 8192;
    var t5 = crc32_table + 10240;
    var t6 = crc32_table + 12288;
    var t7 = crc32_table + 14336;
    var i = 0;
    while (i + 8 <= len) {
        var w = load64(data + i);
        var lo = (crc ^ w) & 4294967295;        # crc XOR low 4 bytes (LE)
        var hi = (w >> 32) & 4294967295;        # high 4 bytes (LE)
        crc = load64(t7 + (lo & 255) * 8)
        ^ load64(t6 + ((lo >> 8) & 255) * 8)
        ^ load64(t5 + ((lo >> 16) & 255) * 8)
        ^ load64(t4 + ((lo >> 24) & 255) * 8)
        ^ load64(t3 + (hi & 255) * 8)
        ^ load64(t2 + ((hi >> 8) & 255) * 8)
        ^ load64(t1 + ((hi >> 16) & 255) * 8)
        ^ load64(t0 + ((hi >> 24) & 255) * 8);
        i = i + 8;
    }
    while (i < len) {
        var index = (crc ^ load8(data + i)) & 255;
        crc = (crc >> 8) ^ load64(t0 + index * 8);
        i = i + 1;
    }
    return crc;
}

# Compute CRC-32 of data[0..len). Call crc32_init_table() first.
fn crc32(data, len): i64 {
    # CRC starts inverted; fold via slice-by-8, then final inversion.
    return (_crc32_fold(4294967295, data, len) ^ 4294967295) & 4294967295;
}

# Incremental CRC-32 API — used by gzip streaming. State is a single
# u64 holding the running (not-yet-inverted) CRC. init sets 0xFFFFFFFF,
# update folds bytes through the same table used by batch crc32, final
# inverts and masks.
#
# Layout (8 bytes):
#   +0: running CRC (pre-inversion)

fn crc32_init(): i64 {
    if (crc32_init_table() < 0) { return 0; }   # 2.3.7: table OOM → null state
    var st = _sankoch_alloc(8);
    if (st == 0) { return 0; }   # 2.2.1: caller checks for alloc failure
    store64(st, 4294967295);   # 0xFFFFFFFF
    return st;
}

fn crc32_update(st, data, len): i64 {
    if (len <= 0) { return 0; }
    store64(st, _crc32_fold(load64(st), data, len));
    return 0;
}

fn crc32_final(st): i64 {
    return (load64(st) ^ 4294967295) & 4294967295;
}

# CRC-64/XZ: table-driven, polynomial 0x42F0E1EBA9EA3693, reflected
# (init = xorout = 0xFFFFFFFFFFFFFFFF, refin = refout = true). The xz
# container (2.4.0) uses this for the block "check" field and the index
# field when the stream's check-type byte is 0x04. The reflected poly is
# 0xC96C5795D7870F42. Cyrius `>>` is a logical shift on i64, so the full
# 64-bit reflected values fold correctly with no sign-extension hazard.
# Byte-at-a-time (256-entry table) — the check field covers uncompressed
# data, but xz decode is not on any consumer's hot path, so the simpler
# table is the right tradeoff over slice-by-8.
# Source: spec "The .xz File Format" §2.1.1.2 / §3.1.2; the poly is
# ECMA-182 (CRC-64/XZ a.k.a. CRC-64/GO-ECMA).
var crc64_table = 0;   # heap-allocated: 256 entries × 8 bytes

fn crc64_init_table(): i64 {
    if (crc64_table == 0) {
        crc64_table = _sankoch_alloc(2048);   # 256 × 8
        if (crc64_table == 0) { return 0 - ERR_OOM; }
    }
    var i = 0;
    while (i < 256) {
        var c = i;
        var j = 0;
        while (j < 8) {
            if (c & 1) {
                c = (c >> 1) ^ 0xC96C5795D7870F42;
            } else {
                c = c >> 1;
            }
            j = j + 1;
        }
        store64(crc64_table + i * 8, c);
        i = i + 1;
    }
    return 0;
}

# Fold `len` bytes into the running (pre-final-XOR) CRC-64. Assumes
# crc64_init_table() has populated crc64_table. Shared by batch + stream.
fn _crc64_fold(crc, data, len): i64 {
    var t = crc64_table;
    var i = 0;
    while (i < len) {
        var index = (crc ^ load8(data + i)) & 255;
        crc = (crc >> 8) ^ load64(t + index * 8);
        i = i + 1;
    }
    return crc;
}

# Compute CRC-64/XZ of data[0..len). Call crc64_init_table() first.
fn crc64(data, len): i64 {
    return _crc64_fold(0xFFFFFFFFFFFFFFFF, data, len) ^ 0xFFFFFFFFFFFFFFFF;
}

# Incremental CRC-64 API — symmetric with the CRC-32 state APIs. State is
# a single u64 holding the running (pre-final-XOR) CRC.
#   +0: running CRC (pre-final XOR)
fn crc64_init(): i64 {
    if (crc64_init_table() < 0) { return 0; }   # table OOM → null state
    var st = _sankoch_alloc(8);
    if (st == 0) { return 0; }
    store64(st, 0xFFFFFFFFFFFFFFFF);
    return st;
}

fn crc64_update(st, data, len): i64 {
    if (len <= 0) { return 0; }
    store64(st, _crc64_fold(load64(st), data, len));
    return 0;
}

fn crc64_final(st): i64 {
    return load64(st) ^ 0xFFFFFFFFFFFFFFFF;
}

# CRC-32/BZIP2: table-driven, polynomial 0x04C11DB7, NON-reflected
# (MSB-first), init = xorout = 0xFFFFFFFF. This is a different CRC from
# the RFC-1952 CRC-32 above (which is the reflected 0xEDB88320 variant):
# bzip2 processes bits most-significant-first and does not reflect the
# result. The .bz2 format (2.4.2) uses it for the per-block and combined
# stream check fields. Check value for "123456789" is 0xFC891918.
var crc32bz_table = 0;   # heap-allocated: 256 entries × 8 bytes

fn crc32_bzip2_init_table(): i64 {
    if (crc32bz_table == 0) {
        crc32bz_table = _sankoch_alloc(2048);   # 256 × 8
        if (crc32bz_table == 0) { return 0 - ERR_OOM; }
    }
    var i = 0;
    while (i < 256) {
        var c = (i << 24) & 0xFFFFFFFF;
        var j = 0;
        while (j < 8) {
            if ((c & 0x80000000) != 0) {
                c = ((c << 1) ^ 0x04C11DB7) & 0xFFFFFFFF;
            } else {
                c = (c << 1) & 0xFFFFFFFF;
            }
            j = j + 1;
        }
        store64(crc32bz_table + i * 8, c);
        i = i + 1;
    }
    return 0;
}

# Compute CRC-32/BZIP2 of data[0..len). Call crc32_bzip2_init_table()
# first. MSB-first fold: crc = (crc << 8) ^ table[(crc>>24 ^ byte) & 0xFF].
fn crc32_bzip2(data, len): i64 {
    var crc = 0xFFFFFFFF;
    var i = 0;
    while (i < len) {
        var idx = ((crc >> 24) ^ load8(data + i)) & 255;
        crc = ((crc << 8) & 0xFFFFFFFF) ^ load64(crc32bz_table + idx * 8);
        i = i + 1;
    }
    return (crc ^ 0xFFFFFFFF) & 0xFFFFFFFF;
}

# xxHash32 batch + helpers (`xxhash32`, `_xxh32_round`, `_xxh32_rotl`,
# `XXH32` enum) live in src/xxhash32.cyr — that file is part of the
# `[lib.core]` kernel-safe distlib profile. The incremental state APIs
# below stay here because they alloc.

# Incremental xxHash32 API — used by LZ4F content-checksum streaming.
# State layout (64 bytes):
#   +0:  v1 (stripe accumulator)
#   +8:  v2
#   +16: v3
#   +24: v4
#   +32..48: partial-stripe buffer (16 bytes, byte-addressable)
#   +48: buf_len (0..15)
#   +56: total_len (cumulative bytes seen)
# Stripe accumulators are kept valid from init so the update path can
# flush a completed 16-byte buffer without branching on "first stripe".
# Final distinguishes short path (total_len < 16) from long path by
# checking total_len itself.

fn xxhash32_init(): i64 {
    var m = 4294967295;
    var st = _sankoch_alloc(64);
    if (st == 0) { return 0; }   # 2.2.1: caller checks for alloc failure
    store64(st, (XXH32_PRIME1 + XXH32_PRIME2) & m);   # v1
    store64(st + 8, XXH32_PRIME2);                     # v2
    store64(st + 16, 0);                               # v3
    store64(st + 24, (0 - XXH32_PRIME1) & m);          # v4
    store64(st + 48, 0);                               # buf_len
    store64(st + 56, 0);                               # total_len
    return st;
}

# Process one 16-byte stripe at data_ptr into the state's v1..v4.
fn _xxh32_stripe_into(st, data_ptr): i64 {
    var m = 4294967295;
    var k1 = load8(data_ptr) | (load8(data_ptr + 1) << 8) |
    (load8(data_ptr + 2) << 16) | (load8(data_ptr + 3) << 24);
    var k2 = load8(data_ptr + 4) | (load8(data_ptr + 5) << 8) |
    (load8(data_ptr + 6) << 16) | (load8(data_ptr + 7) << 24);
    var k3 = load8(data_ptr + 8) | (load8(data_ptr + 9) << 8) |
    (load8(data_ptr + 10) << 16) | (load8(data_ptr + 11) << 24);
    var k4 = load8(data_ptr + 12) | (load8(data_ptr + 13) << 8) |
    (load8(data_ptr + 14) << 16) | (load8(data_ptr + 15) << 24);
    store64(st, _xxh32_round(load64(st), k1 & m));
    store64(st + 8, _xxh32_round(load64(st + 8), k2 & m));
    store64(st + 16, _xxh32_round(load64(st + 16), k3 & m));
    store64(st + 24, _xxh32_round(load64(st + 24), k4 & m));
    return 0;
}

fn xxhash32_update(st, data, len): i64 {
    if (len <= 0) { return 0; }
    store64(st + 56, load64(st + 56) + len);
    var buf = st + 32;
    var buf_len = load64(st + 48);
    var off = 0;

    # Fill the partial buffer first.
    if (buf_len > 0) {
        var need = 16 - buf_len;
        var take = need;
        if (take > len) { take = len; }
        var i = 0;
        while (i < take) {
            store8(buf + buf_len + i, load8(data + i));
            i = i + 1;
        }
        buf_len = buf_len + take;
        off = take;
        if (buf_len == 16) {
            _xxh32_stripe_into(st, buf);
            buf_len = 0;
        }
    }

    # Process full 16-byte stripes directly from the input.
    while (off + 16 <= len) {
        _xxh32_stripe_into(st, data + off);
        off = off + 16;
    }

    # Save tail into the partial buffer.
    var tail = len - off;
    if (tail > 0) {
        var i = 0;
        while (i < tail) {
            store8(buf + i, load8(data + off + i));
            i = i + 1;
        }
        buf_len = tail;
    }
    store64(st + 48, buf_len);
    return 0;
}

fn xxhash32_final(st): i64 {
    var m = 4294967295;
    var total = load64(st + 56);
    var buf_len = load64(st + 48);
    var buf = st + 32;

    var h = 0;
    if (total >= 16) {
        h = (_xxh32_rotl(load64(st), 1) +
        _xxh32_rotl(load64(st + 8), 7) +
        _xxh32_rotl(load64(st + 16), 12) +
        _xxh32_rotl(load64(st + 24), 18)) & m;
    } else {
        h = XXH32_PRIME5;
    }
    h = (h + total) & m;

    # 4-byte tail
    var i = 0;
    while (i + 4 <= buf_len) {
        var k = load8(buf + i) | (load8(buf + i + 1) << 8) |
        (load8(buf + i + 2) << 16) | (load8(buf + i + 3) << 24);
        k = k & m;
        h = (h + (k * XXH32_PRIME3) & m) & m;
        h = (_xxh32_rotl(h, 17) * XXH32_PRIME4) & m;
        i = i + 4;
    }

    # Byte tail
    while (i < buf_len) {
        h = (h + (load8(buf + i) * XXH32_PRIME5) & m) & m;
        h = (_xxh32_rotl(h, 11) * XXH32_PRIME1) & m;
        i = i + 1;
    }

    # Avalanche
    h = h ^ (h >> 15);
    h = (h * XXH32_PRIME2) & m;
    h = h ^ (h >> 13);
    h = (h * XXH32_PRIME3) & m;
    h = h ^ (h >> 16);
    return h;
}

# --- bitreader.cyr ---

# sankoch — bit-stream reader
# Lifted from shravan/main.cyr:1244-1283, generalized for DEFLATE.
#
# DEFLATE reads bits LSB-first (least significant bit first) within each byte.
# This is the opposite of audio codecs (AAC, FLAC) which read MSB-first.
#
# Layout (32 bytes):
#   +0:  data pointer
#   +8:  byte position
#   +16: bit position (0-7, counts from LSB)
#   +24: data length in bytes

# Each br_init allocates a fresh 32-byte context on the heap.
# No shared static state — safe for repeat and nested calls.
fn br_init(data, len): i64 {
    var br = _sankoch_alloc(32);
    if (br == 0) { return 0; }   # 2.3.7: OOM → null; callers check
    store64(br, data);
    store64(br + 8, 0);
    store64(br + 16, 0);
    store64(br + 24, len);
    return br;
}

# Read n bits LSB-first. Returns the value, or negative error.
# Bits are consumed from the least significant bit of each byte upward.
fn br_read(br, n): i64 {
    if (n == 0) { return 0; }
    if (n > 32) { return 0 - ERR_INVALID_INPUT; }
    var data = load64(br);
    var bpos = load64(br + 8);
    var bbit = load64(br + 16);
    var dlen = load64(br + 24);

    var result = 0;
    var shift = 0;  # where to place next bits in result

    while (shift < n) {
        if (bpos >= dlen) { return 0 - ERR_CORRUPT_DATA; }
        var avail = 8 - bbit;
        var need = n - shift;
        var take = need;
        if (take > avail) { take = avail; }

        # Extract 'take' bits starting from bit position 'bbit' in current byte
        var byte = load8(data + bpos);
        var bits = (byte >> bbit) & ((1 << take) - 1);
        result = result | (bits << shift);

        shift = shift + take;
        bbit = bbit + take;
        if (bbit >= 8) {
            bbit = 0;
            bpos = bpos + 1;
        }
    }

    store64(br + 8, bpos);
    store64(br + 16, bbit);
    return result;
}

# Read a single bit.
fn br_read_bit(br): i64 {
    return br_read(br, 1);
}

# Align to the next byte boundary (skip remaining bits in current byte).
fn br_align(br): i64 {
    var bbit = load64(br + 16);
    if (bbit > 0) {
        store64(br + 16, 0);
        store64(br + 8, load64(br + 8) + 1);
    }
    return 0;
}

# Return current byte position.
fn br_byte_pos(br): i64 {
    return load64(br + 8);
}

# Return how many bytes remain.
fn br_remaining(br): i64 {
    var dlen = load64(br + 24);
    var bpos = load64(br + 8);
    var bbit = load64(br + 16);
    var rem = dlen - bpos;
    if (bbit > 0) { rem = rem - 1; }
    if (rem < 0) { rem = 0; }
    return rem;
}

# Return total bytes consumed (rounds up to include any partial byte).
fn br_bytes_consumed(br): i64 {
    var bpos = load64(br + 8);
    var bbit = load64(br + 16);
    if (bbit > 0) { return bpos + 1; }
    return bpos;
}

# --- bitwriter.cyr ---

# sankoch — bit-stream writer (LSB-first)
# Lifted from shravan/flac.cyr:1007-1057, adapted for DEFLATE.
#
# DEFLATE writes bits LSB-first within each byte.
# FLAC writes MSB-first — the bit packing logic is inverted here.
#
# Writes directly into a caller-provided output buffer (no alloc).
#
# Layout (40 bytes):
#   +0:  buffer pointer
#   +8:  buffer capacity
#   +16: bytes written (complete bytes)
#   +24: current partial byte
#   +32: bit position in partial byte (0-7, from LSB)

# Each bw_init allocates a fresh 40-byte context on the heap.
# Returns 0 on alloc failure (2.2.1) — callers must check before use.
fn bw_init(buf, cap): i64 {
    var bw = _sankoch_alloc(40);
    if (bw == 0) { return 0; }
    store64(bw, buf);
    store64(bw + 8, cap);
    store64(bw + 16, 0);
    store64(bw + 24, 0);
    store64(bw + 32, 0);
    return bw;
}

# Write n bits LSB-first. value's low n bits are written.
# Returns 0 on success, negative error on overflow.
fn bw_write(bw, value, n): i64 {
    if (n == 0) { return 0; }
    if (n > 32) { return 0 - ERR_INVALID_INPUT; }
    var buf = load64(bw);
    var cap = load64(bw + 8);
    var blen = load64(bw + 16);
    var cur = load64(bw + 24);
    var bpos = load64(bw + 32);

    var remaining = n;
    var val = value;

    while (remaining > 0) {
        var avail = 8 - bpos;
        var take = remaining;
        if (take > avail) { take = avail; }

        # Place 'take' low bits of val into cur, starting at bit bpos
        var mask = (1 << take) - 1;
        cur = cur | ((val & mask) << bpos);
        val = val >> take;
        remaining = remaining - take;
        bpos = bpos + take;

        if (bpos >= 8) {
            if (blen >= cap) { return 0 - ERR_BUFFER_TOO_SMALL; }
            store8(buf + blen, cur & 255);
            blen = blen + 1;
            cur = 0;
            bpos = 0;
        }
    }

    store64(bw + 16, blen);
    store64(bw + 24, cur);
    store64(bw + 32, bpos);
    return 0;
}

# Write a single bit.
fn bw_write_bit(bw, b): i64 {
    return bw_write(bw, b, 1);
}

# Write n bits MSB-first (needed for Huffman codes in DEFLATE).
# The code is stored with bit 0 being the first transmitted bit (MSB of the code).
fn bw_write_bits_msb(bw, value, n): i64 {
    # Reverse bits then write LSB-first
    var rev = 0;
    var v = value;
    var i = 0;
    while (i < n) {
        rev = (rev << 1) | (v & 1);
        v = v >> 1;
        i = i + 1;
    }
    return bw_write(bw, rev, n);
}

# Align to byte boundary, padding with zero bits.
fn bw_align(bw): i64 {
    var bpos = load64(bw + 32);
    if (bpos > 0) {
        var buf = load64(bw);
        var blen = load64(bw + 16);
        var cap = load64(bw + 8);
        var cur = load64(bw + 24);
        if (blen >= cap) { return 0 - ERR_BUFFER_TOO_SMALL; }
        store8(buf + blen, cur & 255);
        store64(bw + 16, blen + 1);
        store64(bw + 24, 0);
        store64(bw + 32, 0);
    }
    return 0;
}

# Flush partial byte and return total bytes written.
fn bw_finish(bw): i64 {
    bw_align(bw);
    return load64(bw + 16);
}

# Return bytes written so far (not counting partial byte).
fn bw_len(bw): i64 {
    return load64(bw + 16);
}

# Write a raw byte directly (must be byte-aligned).
fn bw_write_byte(bw, byte): i64 {
    var buf = load64(bw);
    var cap = load64(bw + 8);
    var blen = load64(bw + 16);
    if (blen >= cap) { return 0 - ERR_BUFFER_TOO_SMALL; }
    store8(buf + blen, byte & 255);
    store64(bw + 16, blen + 1);
    return 0;
}

# Write a 16-bit value little-endian (must be byte-aligned).
fn bw_write_u16le(bw, val): i64 {
    var rc = bw_write_byte(bw, val & 255);
    if (rc < 0) { return rc; }
    return bw_write_byte(bw, (val >> 8) & 255);
}

# Write a 32-bit value little-endian (must be byte-aligned).
fn bw_write_u32le(bw, val): i64 {
    var rc = bw_write_byte(bw, val & 255);
    if (rc < 0) { return rc; }
    rc = bw_write_byte(bw, (val >> 8) & 255);
    if (rc < 0) { return rc; }
    rc = bw_write_byte(bw, (val >> 16) & 255);
    if (rc < 0) { return rc; }
    return bw_write_byte(bw, (val >> 24) & 255);
}

# --- huffman.cyr ---

# sankoch — Huffman coding for DEFLATE
# Lifted structure from shravan/aac.cyr:843-873, replaced AAC codebooks
# with DEFLATE canonical Huffman.
#
# DEFLATE uses canonical Huffman codes:
#   1. Code lengths are transmitted (or fixed by spec)
#   2. Codes are assigned by the canonical algorithm (RFC 1951 Section 3.2.2)
#   3. Bits are read LSB-first
#
# Decode strategy: table-based for codes up to 9 bits (covers most cases),
# fallback to bit-by-bit for longer codes.

# Maximum code length in DEFLATE is 15 bits.
# We use a primary lookup table of 512 entries (9-bit index).
# Each entry: symbol in low 16 bits, length in bits 16-20.

enum Huffman {
    HUFF_TABLE_BITS = 9;
    HUFF_TABLE_SIZE = 512;
    HUFF_MAX_BITS = 15;
    HUFF_FAST_SHIFT = 16;
}

# All large tables are heap-allocated on first use.
# Literal/length table (up to 286 symbols)
var _huff_litlen_fast = 0;   # 512 entries * 8 bytes
var _huff_litlen_lens = 0;   # 286 entries * 8 bytes
var _huff_litlen_codes = 0;  # 286 entries * 8 bytes
var _huff_litlen_count = 0;

# Distance table (up to 30 symbols)
var _huff_dist_fast = 0;
var _huff_dist_lens = 0;
var _huff_dist_codes = 0;
var _huff_dist_count = 0;

# Code-length alphabet table (up to 19 symbols)
var _huff_cl_fast = 0;
var _huff_cl_lens = 0;
var _huff_cl_codes = 0;
var _huff_cl_count = 0;

var _huff_tables_allocd = 0;

fn _huff_alloc_tables(): i64 {
    if (_huff_tables_allocd == 1) { return 0; }
    _huff_litlen_fast = _sankoch_alloc(4096);
    if (_huff_litlen_fast == 0) { return 0 - ERR_OOM; }
    _huff_litlen_lens = _sankoch_alloc(2304);   # 288 * 8
    if (_huff_litlen_lens == 0) { return 0 - ERR_OOM; }
    _huff_litlen_codes = _sankoch_alloc(2304);  # 288 * 8
    if (_huff_litlen_codes == 0) { return 0 - ERR_OOM; }
    _huff_dist_fast = _sankoch_alloc(4096);
    if (_huff_dist_fast == 0) { return 0 - ERR_OOM; }
    _huff_dist_lens = _sankoch_alloc(256);      # 32 * 8
    if (_huff_dist_lens == 0) { return 0 - ERR_OOM; }
    _huff_dist_codes = _sankoch_alloc(256);     # 32 * 8
    if (_huff_dist_codes == 0) { return 0 - ERR_OOM; }
    _huff_cl_fast = _sankoch_alloc(4096);
    if (_huff_cl_fast == 0) { return 0 - ERR_OOM; }
    _huff_cl_lens = _sankoch_alloc(152);
    if (_huff_cl_lens == 0) { return 0 - ERR_OOM; }
    _huff_cl_codes = _sankoch_alloc(152);
    if (_huff_cl_codes == 0) { return 0 - ERR_OOM; }
    _huff_tables_allocd = 1;
    return 0;
}

# Build canonical Huffman codes from an array of code lengths.
fn _huff_build(lengths, num_symbols, out_codes, out_fast): i64 {
    # Step 1: Count codes of each length
    var bl_count[128];  # 16 entries * 8 bytes
    var i = 0;
    while (i < 16) {
        store64(&bl_count + i * 8, 0);
        i = i + 1;
    }
    i = 0;
    while (i < num_symbols) {
        var len = load64(lengths + i * 8);
        if (len > 0 && len <= HUFF_MAX_BITS) {
            store64(&bl_count + len * 8,
            load64(&bl_count + len * 8) + 1);
        }
        i = i + 1;
    }

    # Validate: tree must not be oversubscribed
    var check_sum = 0;
    var b = 1;
    while (b <= HUFF_MAX_BITS) {
        check_sum = check_sum +
        (load64(&bl_count + b * 8) << (HUFF_MAX_BITS - b));
        b = b + 1;
    }
    if (check_sum > (1 << HUFF_MAX_BITS)) {
        return 0 - ERR_INVALID_HUFFMAN;
    }

    # Step 2: smallest code for each length
    var next_code[128];
    store64(&next_code, 0);
    store64(&next_code + 8, 0);
    var code = 0;
    var bits = 1;
    while (bits <= HUFF_MAX_BITS) {
        code = (code + load64(&bl_count + (bits - 1) * 8)) << 1;
        store64(&next_code + bits * 8, code);
        bits = bits + 1;
    }

    # Step 3: assign codes
    i = 0;
    while (i < num_symbols) {
        var len = load64(lengths + i * 8);
        if (len > 0) {
            store64(out_codes + i * 8,
            load64(&next_code + len * 8));
            store64(&next_code + len * 8,
            load64(&next_code + len * 8) + 1);
        } else {
            store64(out_codes + i * 8, 0);
        }
        i = i + 1;
    }

    # Step 4: build fast lookup table (9-bit, LSB-first)
    i = 0;
    while (i < HUFF_TABLE_SIZE) {
        store64(out_fast + i * 8, 0);
        i = i + 1;
    }
    i = 0;
    while (i < num_symbols) {
        var len = load64(lengths + i * 8);
        if (len > 0 && len <= HUFF_TABLE_BITS) {
            var c = load64(out_codes + i * 8);
            var rev = 0;
            var bb = 0;
            while (bb < len) {
                rev = (rev << 1) | (c & 1);
                c = c >> 1;
                bb = bb + 1;
            }
            var step = 1 << len;
            var idx = rev;
            while (idx < HUFF_TABLE_SIZE) {
                store64(out_fast + idx * 8,
                (len << HUFF_FAST_SHIFT) | i);
                idx = idx + step;
            }
        }
        i = i + 1;
    }
    return 0;
}

# Build canonical Huffman codes for ENCODING — codes are stored in
# pre-reversed (LSB-first) bit order so the symbol-emit hot path can
# call bw_write directly without a per-symbol bit-reversal loop.
#
# The decoder builds via _huff_build (above) which stores unreversed
# canonical codes; the slow-path comparison in _huff_decode depends on
# that. This helper is encoder-only — used by the dynamic-Huffman path
# in deflate.cyr.
fn huff_build_enc_codes(lengths, num_symbols, out_codes_rev): i64 {
    var bl_count[128];  # 128 bytes = 16 i64 entries — covers HUFF_MAX_BITS
    var i = 0;
    while (i < 16) {
        store64(&bl_count + i * 8, 0);
        i = i + 1;
    }
    i = 0;
    while (i < num_symbols) {
        var len = load64(lengths + i * 8);
        if (len > 0 && len <= HUFF_MAX_BITS) {
            store64(&bl_count + len * 8,
            load64(&bl_count + len * 8) + 1);
        }
        i = i + 1;
    }

    var next_code[128];
    store64(&next_code, 0);
    store64(&next_code + 8, 0);
    var code = 0;
    var bits = 1;
    while (bits <= HUFF_MAX_BITS) {
        code = (code + load64(&bl_count + (bits - 1) * 8)) << 1;
        store64(&next_code + bits * 8, code);
        bits = bits + 1;
    }

    i = 0;
    while (i < num_symbols) {
        var len = load64(lengths + i * 8);
        if (len > 0) {
            var c = load64(&next_code + len * 8);
            store64(&next_code + len * 8, c + 1);
            var rev = 0;
            var b = 0;
            while (b < len) {
                rev = (rev << 1) | (c & 1);
                c = c >> 1;
                b = b + 1;
            }
            store64(out_codes_rev + i * 8, rev);
        } else {
            store64(out_codes_rev + i * 8, 0);
        }
        i = i + 1;
    }
    return 0;
}

# Decode one symbol using fast table + slow fallback.
fn _huff_decode(br, fast, lengths, codes, num_symbols): i64 {
    var data = load64(br);
    var bpos = load64(br + 8);
    var bbit = load64(br + 16);
    var dlen = load64(br + 24);

    # Peek up to 9 bits
    var peek = 0;
    var got = 0;
    var save_bpos = bpos;
    var save_bbit = bbit;
    while (got < HUFF_TABLE_BITS) {
        if (bpos >= dlen) { break; }
        var byte = load8(data + bpos);
        var bit = (byte >> bbit) & 1;
        peek = peek | (bit << got);
        got = got + 1;
        bbit = bbit + 1;
        if (bbit >= 8) { bbit = 0; bpos = bpos + 1; }
    }

    var entry = load64(fast + peek * 8);
    var elen = entry >> HUFF_FAST_SHIFT;
    if (elen > 0 && elen <= got) {
        var consume = elen;
        bpos = save_bpos;
        bbit = save_bbit + consume;
        while (bbit >= 8) { bbit = bbit - 8; bpos = bpos + 1; }
        store64(br + 8, bpos);
        store64(br + 16, bbit);
        return entry & 65535;
    }

    # Slow path: bit-by-bit
    store64(br + 8, save_bpos);
    store64(br + 16, save_bbit);
    var acc = 0;
    var bits_read = 0;
    while (bits_read < HUFF_MAX_BITS) {
        var bit = br_read_bit(br);
        if (bit < 0) { return bit; }
        acc = (acc << 1) | bit;
        bits_read = bits_read + 1;
        var i = 0;
        while (i < num_symbols) {
            if (load64(lengths + i * 8) == bits_read) {
                if (load64(codes + i * 8) == acc) {
                    return i;
                }
            }
            i = i + 1;
        }
    }
    return 0 - ERR_INVALID_HUFFMAN;
}

# Decode one literal/length symbol from the bitstream.
fn huff_decode_litlen(br): i64 {
    return _huff_decode(br, _huff_litlen_fast, _huff_litlen_lens,
    _huff_litlen_codes, _huff_litlen_count);
}

# Decode one distance symbol from the bitstream.
fn huff_decode_dist(br): i64 {
    return _huff_decode(br, _huff_dist_fast, _huff_dist_lens,
    _huff_dist_codes, _huff_dist_count);
}

# Decode one code-length symbol from the bitstream.
fn huff_decode_cl(br): i64 {
    return _huff_decode(br, _huff_cl_fast, _huff_cl_lens,
    _huff_cl_codes, _huff_cl_count);
}

# Build the literal/length Huffman table from code lengths.
fn huff_build_litlen(lengths, count): i64 {
    _huff_alloc_tables();
    _huff_litlen_count = count;
    # Dynamic tables overwrite fixed — force rebuild on next huff_build_fixed()
    _huff_fixed_built = 0;
    var i = 0;
    while (i < count) {
        store64(_huff_litlen_lens + i * 8,
        load64(lengths + i * 8));
        i = i + 1;
    }
    return _huff_build(_huff_litlen_lens, count,
    _huff_litlen_codes, _huff_litlen_fast);
}

# Build the distance Huffman table from code lengths.
fn huff_build_dist(lengths, count): i64 {
    _huff_alloc_tables();
    _huff_dist_count = count;
    var i = 0;
    while (i < count) {
        store64(_huff_dist_lens + i * 8,
        load64(lengths + i * 8));
        i = i + 1;
    }
    return _huff_build(_huff_dist_lens, count,
    _huff_dist_codes, _huff_dist_fast);
}

# Build the code-length Huffman table from code lengths.
fn huff_build_cl(lengths, count): i64 {
    _huff_alloc_tables();
    _huff_cl_count = count;
    var i = 0;
    while (i < count) {
        store64(_huff_cl_lens + i * 8,
        load64(lengths + i * 8));
        i = i + 1;
    }
    return _huff_build(_huff_cl_lens, count,
    _huff_cl_codes, _huff_cl_fast);
}

# ================================================================
# Fixed Huffman tables (RFC 1951, Section 3.2.6)
# ================================================================

var _huff_fixed_built = 0;
var _huff_fixed_litlen_lens = 0;

# Build the fixed Huffman tables defined in RFC 1951 Section 3.2.6.
fn huff_build_fixed(): i64 {
    if (_huff_fixed_built == 1) { return 0; }
    if (_huff_fixed_litlen_lens == 0) {
        _huff_fixed_litlen_lens = _sankoch_alloc(2304);
        if (_huff_fixed_litlen_lens == 0) { return 0 - ERR_OOM; }
    }
    var i = 0;
    while (i <= 143) {
        store64(_huff_fixed_litlen_lens + i * 8, 8);
        i = i + 1;
    }
    while (i <= 255) {
        store64(_huff_fixed_litlen_lens + i * 8, 9);
        i = i + 1;
    }
    while (i <= 279) {
        store64(_huff_fixed_litlen_lens + i * 8, 7);
        i = i + 1;
    }
    while (i <= 287) {
        store64(_huff_fixed_litlen_lens + i * 8, 8);
        i = i + 1;
    }
    huff_build_litlen(_huff_fixed_litlen_lens, 288);

    var dist_lens[256];  # 32 * 8 — small, stays on stack
    i = 0;
    while (i < 32) {
        store64(&dist_lens + i * 8, 5);
        i = i + 1;
    }
    huff_build_dist(&dist_lens, 32);
    _huff_fixed_built = 1;
    return 0;
}

# ================================================================
# Optimal Huffman tree from frequencies
# ================================================================

# Pre-allocated workspace for huff_compute_lengths (allocated once)
var _hcl_ws = 0;

# Compute optimal Huffman code lengths from symbol frequencies, capping any
# code length at `max_bits`. Set max_bits=15 for the literal/length and
# distance alphabets, max_bits=7 for the code-length (meta) alphabet.
#
# When the natural Huffman tree's depth exceeds max_bits, this function
# applies zlib's iterative redistribution (`gen_bitlen` from trees.c) to
# bring every length under the cap while preserving the Kraft inequality
# Σ 2^(-len_i) = 1. Symbol-to-length assignment is then redone in
# descending frequency order so the most frequent symbols get the shortest
# codes — preserving optimality up to the cap.
# Pre-allocate the optimal-length workspace (2.3.7) so the deep
# huff_compute_lengths() calls on the dynamic encode path never alloc.
# Returns 0, or 0 - ERR_OOM on allocation failure.
fn _huff_ensure_hcl_ws(): i64 {
    if (_hcl_ws == 0) {
        _hcl_ws = _sankoch_alloc(33600);
        if (_hcl_ws == 0) { return 0 - ERR_OOM; }
    }
    return 0;
}

fn huff_compute_lengths(freqs, num_symbols, out_lens, min_codes, max_bits): i64 {
    var count = 0;
    var i = 0;
    while (i < num_symbols) {
        if (load64(freqs + i * 8) > 0) { count = count + 1; }
        i = i + 1;
    }

    if (count == 0) {
        i = 0;
        while (i < num_symbols) {
            if (i < min_codes) { store64(out_lens + i * 8, 1); }
            else { store64(out_lens + i * 8, 0); }
            i = i + 1;
        }
        return 0;
    }
    if (count == 1) {
        i = 0;
        var found = 0;
        while (i < num_symbols) {
            if (load64(freqs + i * 8) > 0 && found == 0) {
                store64(out_lens + i * 8, 1);
                found = 1;
            } else {
                store64(out_lens + i * 8, 0);
            }
            i = i + 1;
        }
        # Need at least 2 codes
        i = 0;
        while (i < num_symbols) {
            if (load64(out_lens + i * 8) == 0) {
                store64(out_lens + i * 8, 1);
                break;
            }
            i = i + 1;
        }
        return 0;
    }

    # Workspace — allocated once, reused across calls.
    # 7 arrays, each 600 entries * 8 bytes = 4800 bytes. Total = 33600.
    if (_hcl_ws == 0) {
        _hcl_ws = _sankoch_alloc(33600);
        if (_hcl_ws == 0) { return 0 - ERR_OOM; }
    }
    var sorted_sym = _hcl_ws;
    var sorted_freq = _hcl_ws + 4800;
    var n = 0;
    i = 0;
    while (i < num_symbols) {
        var f = load64(freqs + i * 8);
        if (f > 0) {
            store64(sorted_sym + n * 8, i);
            store64(sorted_freq + n * 8, f);
            n = n + 1;
        }
        i = i + 1;
    }

    # Insertion sort by frequency
    i = 1;
    while (i < n) {
        var key_f = load64(sorted_freq + i * 8);
        var key_s = load64(sorted_sym + i * 8);
        var j = i - 1;
        while (j >= 0 && load64(sorted_freq + j * 8) > key_f) {
            store64(sorted_freq + (j + 1) * 8,
            load64(sorted_freq + j * 8));
            store64(sorted_sym + (j + 1) * 8,
            load64(sorted_sym + j * 8));
            j = j - 1;
        }
        store64(sorted_freq + (j + 1) * 8, key_f);
        store64(sorted_sym + (j + 1) * 8, key_s);
        i = i + 1;
    }

    # Two-queue Huffman tree build (reuse workspace)
    var q2_freq = _hcl_ws + 9600;
    var q2_left = _hcl_ws + 14400;
    var q2_right = _hcl_ws + 19200;
    var q1_head = 0;
    var q2_head = 0;
    var q2_tail = 0;
    var _pick_source = 0;

    while (1) {
        var remaining = (n - q1_head) + (q2_tail - q2_head);
        if (remaining < 2) { break; }

        # Pick first minimum
        var f1 = 0;
        var n1 = 0;
        var q1a = (q1_head < n);
        var q2a = (q2_head < q2_tail);
        var pq1 = 0;
        if (q1a == 1) {
            if (q2a == 0) { pq1 = 1; }
            else {
                if (load64(sorted_freq + q1_head * 8) <=
                load64(q2_freq + q2_head * 8)) { pq1 = 1; }
            }
        }
        if (pq1 == 1) {
            f1 = load64(sorted_freq + q1_head * 8);
            n1 = q1_head;
            q1_head = q1_head + 1;
        } else {
            f1 = load64(q2_freq + q2_head * 8);
            n1 = q2_head + n;
            q2_head = q2_head + 1;
        }

        # Pick second minimum
        var f2 = 0;
        var n2 = 0;
        q1a = (q1_head < n);
        q2a = (q2_head < q2_tail);
        pq1 = 0;
        if (q1a == 1) {
            if (q2a == 0) { pq1 = 1; }
            else {
                if (load64(sorted_freq + q1_head * 8) <=
                load64(q2_freq + q2_head * 8)) { pq1 = 1; }
            }
        }
        if (pq1 == 1) {
            f2 = load64(sorted_freq + q1_head * 8);
            n2 = q1_head;
            q1_head = q1_head + 1;
        } else {
            f2 = load64(q2_freq + q2_head * 8);
            n2 = q2_head + n;
            q2_head = q2_head + 1;
        }

        store64(q2_freq + q2_tail * 8, f1 + f2);
        store64(q2_left + q2_tail * 8, n1);
        store64(q2_right + q2_tail * 8, n2);
        q2_tail = q2_tail + 1;
    }

    # Extract depths via DFS
    i = 0;
    while (i < num_symbols) { store64(out_lens + i * 8, 0); i = i + 1; }

    var stack_node = _hcl_ws + 24000;
    var stack_depth = _hcl_ws + 28800;
    var sp = 0;
    if (q2_tail > 0) {
        store64(stack_node, q2_tail - 1 + n);
        store64(stack_depth, 0);
        sp = 1;
    }

    while (sp > 0) {
        sp = sp - 1;
        var node = load64(stack_node + sp * 8);
        var depth = load64(stack_depth + sp * 8);
        if (node < n) {
            var sym = load64(sorted_sym + node * 8);
            var d = depth;
            # n>=2 here, so the root is always internal — the children of
            # the root are pushed at depth 1 minimum, never at depth 0.
            # Clamp d at 31 only as a redistribution-friendly ceiling for
            # adversarial inputs (Fibonacci-like frequencies); the actual
            # cap to max_bits is enforced by _huff_redistribute below.
            if (d > 31) { d = 31; }
            store64(out_lens + sym * 8, d);
        } else {
            var idx = node - n;
            store64(stack_node + sp * 8,
            load64(q2_left + idx * 8));
            store64(stack_depth + sp * 8, depth + 1);
            sp = sp + 1;
            store64(stack_node + sp * 8,
            load64(q2_right + idx * 8));
            store64(stack_depth + sp * 8, depth + 1);
            sp = sp + 1;
        }
    }

    return _huff_redistribute(out_lens, num_symbols, sorted_sym, n, max_bits);
}

# Cap every code length in `out_lens` at `max_bits` while keeping
# Σ 2^(-len_i) = 1. Each iteration extends one shorter leaf by one bit
# (its slot splits into two at length+1) and removes one leaf from
# max_bits — net Kraft change is exactly -2^(15-max_bits) per iteration.
# Termination is Kraft-sum-based, not overflow-count-based: zlib's
# `overflow -= 2` shortcut from `gen_bitlen` is correct only when every
# overflow leaf came from depth max_bits+1, which silently miscounts
# iterations when the natural Huffman tree had any leaf at depth
# max_bits+2 or deeper (the partial-fix bug shipped in 2.0.2 — it
# under-iterated for those cases and left the cl tree over-subscribed).
# Looping until Kraft equals 2^15 is unconditionally correct: each step
# removes a known fixed amount, and starting from a complete natural
# Huffman tree the post-clip Kraft is always a multiple of that amount.
# Final symbol→length assignment walks the frequency-sorted symbol list
# (most frequent first), placing each symbol at the shortest still-
# available bit length so optimality up to the cap is preserved.
fn _huff_redistribute(out_lens, num_symbols, sorted_sym, n, max_bits): i64 {
    # bl_count covers natural depths 0..31 (DFS clamp ceiling).
    var bl_count[256];
    var L = 0;
    while (L < 32) { store64(&bl_count + L * 8, 0); L = L + 1; }

    var max_seen = 0;
    var i = 0;
    while (i < num_symbols) {
        var v = load64(out_lens + i * 8);
        if (v > 0) {
            store64(&bl_count + v * 8,
            load64(&bl_count + v * 8) + 1);
            if (v > max_seen) { max_seen = v; }
        }
        i = i + 1;
    }

    if (max_seen <= max_bits) { return 0; }

    # Move every leaf at L > max_bits down to max_bits.
    L = max_bits + 1;
    while (L <= max_seen) {
        store64(&bl_count + max_bits * 8,
        load64(&bl_count + max_bits * 8) +
        load64(&bl_count + L * 8));
        store64(&bl_count + L * 8, 0);
        L = L + 1;
    }

    # Compute current Kraft sum in units of 2^15 (full tree = 2^15).
    var kraft = 0;
    L = 1;
    while (L <= max_bits) {
        kraft = kraft + (load64(&bl_count + L * 8) << (15 - L));
        L = L + 1;
    }
    var kraft_target = 1 << 15;
    var step = 1 << (15 - max_bits);

    while (kraft > kraft_target) {
        # Find the shortest non-empty length below max_bits to extend.
        var bits = max_bits - 1;
        while (bits > 0 && load64(&bl_count + bits * 8) == 0) {
            bits = bits - 1;
        }
        if (bits == 0) { break; }   # safety — shouldn't reach here for n>=2
        store64(&bl_count + bits * 8,
        load64(&bl_count + bits * 8) - 1);
        store64(&bl_count + (bits + 1) * 8,
        load64(&bl_count + (bits + 1) * 8) + 2);
        store64(&bl_count + max_bits * 8,
        load64(&bl_count + max_bits * 8) - 1);
        kraft = kraft - step;
    }

    # Reassign lengths to symbols: most-frequent → shortest. sorted_sym is
    # ascending by frequency (insertion-sort earlier), so walk it from the
    # high end down. Filling a short slot first means a high-frequency
    # symbol lands there.
    var k = n - 1;
    L = 1;
    while (L <= max_bits) {
        var slots = load64(&bl_count + L * 8);
        while (slots > 0 && k >= 0) {
            var sym = load64(sorted_sym + k * 8);
            store64(out_lens + sym * 8, L);
            k = k - 1;
            slots = slots - 1;
        }
        L = L + 1;
    }
    return 0;
}

# --- lz77.cyr ---

# sankoch — LZ77 sliding window match-finder for DEFLATE
#
# DEFLATE uses a 32KB sliding window with:
#   - Minimum match length: 3
#   - Maximum match length: 258
#   - Maximum distance: 32768
#   - Hash on 3-byte sequences
#
# Strategy: hash table with chaining for collision resolution.
# Greedy matching — take the longest match at each position.

enum LZ77 {
    LZ77_HASH_BITS = 15;
    LZ77_HASH_SIZE = 32768;
    LZ77_HASH_MASK = 32767;
    LZ77_WINDOW = 32768;
    LZ77_MIN_MATCH = 3;
    LZ77_MAX_MATCH = 258;
    LZ77_MAX_CHAIN = 64;  # default chain depth
}

# Compression levels:
#   1 (fast)    — chain depth 4, skip hash insertion on match interiors
#   6 (default) — chain depth 64
#   9 (best)    — chain depth 256
var _lz77_chain_depth = 64;

# Hash table: maps hash → most recent ABSOLUTE position (heap-allocated, 256KB each)
var _lz77_head = 0;
# Chain: prev[abs_pos & WINDOW-1] = previous absolute position with same hash
var _lz77_prev = 0;

# Absolute byte offset of window[0] in the streaming input. Bumped by
# `lz77_rebase(delta)` on each window slide. Batch compress never
# advances this — abs_pos == win_pos in batch mode, so the hash table
# just stores byte offsets within the source buffer (same as pre-2.x).
#
# Why absolute positions: streaming used to walk the entire 65,536-entry
# hash table on every slide and subtract delta from each entry — ~22%
# of streaming compress time. With absolute positions, slide is O(1)
# (just bump window_base); stale entries are naturally rejected by the
# `chain < _lz77_window_base` check inside _lz77_find_match without
# touching the table.
var _lz77_window_base = 0;

# Hash 3 bytes into a 15-bit index. Position argument is window-relative
# (offset into the src buffer the encoder passes in).
fn _lz77_hash3(src, win_pos): i64 {
    var v = load8(src + win_pos);
    v = v ^ (load8(src + win_pos + 1) << 5);
    v = v ^ (load8(src + win_pos + 2) << 10);
    return v & LZ77_HASH_MASK;
}

# Insert window-relative position into hash chain. The hash table stores
# the corresponding ABSOLUTE position (win_pos + _lz77_window_base) so
# entries survive window slides without rebasing.
fn _lz77_insert(src, win_pos): i64 {
    var abs_pos = win_pos + _lz77_window_base;
    var h = _lz77_hash3(src, win_pos);
    var prev = load64(_lz77_head + h * 8);
    store64(_lz77_prev + (abs_pos & LZ77_HASH_MASK) * 8, prev);
    store64(_lz77_head + h * 8, abs_pos);
    return 0;
}

# Find the longest match at window-relative position win_pos.
# src_len is the window-relative end-of-data offset.
# Returns match length in low 16 bits, distance in bits 16-31.
# Returns 0 if no match found (length < 3).
#
# Hash table stores absolute positions; this function converts back to
# window-relative for byte access via `_lz77_window_base`. Stale entries
# from before the current window are rejected via two checks:
#   (a) chain < 0       — sentinel for empty slot
#   (b) chain < base    — entry from before the most recent slide;
#                          chain - base would be negative, byte load UB
# Once both pass, dist = abs_pos - chain is bounded by WINDOW.
fn _lz77_find_match(src, src_len, win_pos): i64 {
    if (win_pos + LZ77_MIN_MATCH > src_len) { return 0; }

    var base = _lz77_window_base;
    var abs_pos = win_pos + base;

    var h = _lz77_hash3(src, win_pos);
    var chain = load64(_lz77_head + h * 8);

    var best_len = 0;
    var best_dist = 0;
    var max_len = src_len - win_pos;
    if (max_len > LZ77_MAX_MATCH) { max_len = LZ77_MAX_MATCH; }

    var depth = 0;
    while (depth < _lz77_chain_depth) {
        if (chain < 0) { break; }       # sentinel
        if (chain < base) { break; }    # entry from before this window slide
        var dist = abs_pos - chain;
        if (dist <= 0 || dist > LZ77_WINDOW) { break; }

        var chain_off = chain - base;   # window-relative offset for byte access

        # Quick check: compare first and last+1 byte of best match
        if (load8(src + chain_off) == load8(src + win_pos)) {
            if (best_len < 3 || load8(src + chain_off + best_len) == load8(src + win_pos + best_len)) {
                # Count full match length. 8-byte chunks via load64; tail
                # is byte-at-a-time. Boundary safety: load64 only fires
                # while mlen+8 <= max_len, and max_len = min(LZ77_MAX_MATCH,
                # src_len - win_pos), with chain_off < win_pos < src_len.
                var mlen = 0;
                while (mlen + 8 <= max_len) {
                    var a = load64(src + chain_off + mlen);
                    var b = load64(src + win_pos + mlen);
                    if (a != b) { break; }
                    mlen = mlen + 8;
                }
                while (mlen < max_len) {
                    if (load8(src + chain_off + mlen) != load8(src + win_pos + mlen)) { break; }
                    mlen = mlen + 1;
                }
                if (mlen >= LZ77_MIN_MATCH && mlen > best_len) {
                    best_len = mlen;
                    best_dist = dist;
                    if (best_len >= max_len) { break; }
                }
            }
        }

        chain = load64(_lz77_prev + (chain & LZ77_HASH_MASK) * 8);
        depth = depth + 1;
    }

    if (best_len < LZ77_MIN_MATCH) { return 0; }
    return best_len | (best_dist << 16);
}

# Set compression level (1=fast, 6=default, 9=best).
fn lz77_set_level(level): i64 {
    if (level <= 1) {
        _lz77_chain_depth = 4;
    } elif (level <= 3) {
        _lz77_chain_depth = 16;
    } elif (level <= 6) {
        _lz77_chain_depth = 64;
    } elif (level <= 8) {
        _lz77_chain_depth = 128;
    } else {
        _lz77_chain_depth = 256;
    }
    return 0;
}

# Advance the absolute window base by `delta`. O(1) — no table walk.
# Called by the streaming encoder after it slides the window buffer
# (memcpys the last DENC_SLIDE_RETAIN bytes to position 0). Hash table
# entries pointing to absolute positions older than the new base are
# rejected lazily inside _lz77_find_match via the `chain < base` check.
fn lz77_rebase(delta): i64 {
    _lz77_window_base = _lz77_window_base + delta;
    return 0;
}

# Initialize hash tables (heap-allocate + clear to -1) and reset the
# absolute window base. Called at the start of every batch compress and
# every streaming encoder init, so the window_base for batch is always 0
# (abs_pos == win_pos in batch mode — no behavior change vs pre-2.x).
fn lz77_init(): i64 {
    if (_lz77_head == 0) {
        _lz77_head = _sankoch_alloc(262144);
        if (_lz77_head == 0) { return 0 - ERR_OOM; }
        _lz77_prev = _sankoch_alloc(262144);
        if (_lz77_prev == 0) { return 0 - ERR_OOM; }
    }
    var i = 0;
    while (i < LZ77_HASH_SIZE) {
        store64(_lz77_head + i * 8, 0 - 1);
        store64(_lz77_prev + i * 8, 0 - 1);
        i = i + 1;
    }
    _lz77_window_base = 0;
    return 0;
}

# --- lz4_decode.cyr ---

# sankoch — LZ4 decompress (block + frame), kernel-safe subset
#
# Pure-compute: no alloc, no syscalls, no mutex. Lives in its own
# module so the `[lib.core]` distlib profile (sankoch-core.cyr) can
# pull it in alongside types.cyr + xxhash32.cyr without dragging the
# alloc-using LZ4 encoder in src/lz4.cyr.
#
# Constants for the LZ4 frame format (magic, version, block-max) live
# here so both the decoder (this file) and the encoder (lz4.cyr,
# included later in the chain) can see them. LZ4F_BLOCK_MAX is
# encode-side state but lives with the rest of the enum for
# coherence — the kernel-safe profile carries it as inert data.

enum LZ4F {
    LZ4F_MAGIC = 407708164;   # 0x184D2204 — bytes [04 22 4D 18] read as LE u32
    LZ4F_VERSION = 1;
    LZ4F_BLOCK_MAX = 65536;   # Matches BD byte (0x40 → block max size 64KB)
}

# Decompress an LZ4 block.
# src: pointer to compressed data
# src_len: length of compressed data
# dst: pointer to output buffer
# dst_cap: capacity of output buffer
# Returns: decompressed length, or negative error code
fn lz4_decompress(src, src_len, dst, dst_cap): i64 {
    var sp = 0;   # source position
    var dp = 0;   # destination position

    while (sp < src_len) {
        # Read token
        var token = load8(src + sp);
        sp = sp + 1;

        # Literal length (high nibble)
        var lit_len = (token >> 4) & 15;
        if (lit_len == 15) {
            var extra = 255;
            while (extra == 255) {
                if (sp >= src_len) { return 0 - ERR_CORRUPT_DATA; }
                extra = load8(src + sp);
                sp = sp + 1;
                lit_len = lit_len + extra;
            }
        }

        # Copy literals
        if (dp + lit_len > dst_cap) { return 0 - ERR_BUFFER_TOO_SMALL; }
        if (dp + lit_len > DECOMPRESS_MAX_OUTPUT) { return 0 - ERR_OUTPUT_LIMIT; }
        if (sp + lit_len > src_len) { return 0 - ERR_CORRUPT_DATA; }
        var i = 0;
        while (i < lit_len) {
            store8(dst + dp, load8(src + sp));
            sp = sp + 1;
            dp = dp + 1;
            i = i + 1;
        }

        # End of block — last sequence has no match
        if (sp >= src_len) {
            return dp;
        }

        # Match offset (2 bytes, little-endian)
        if (sp + 2 > src_len) { return 0 - ERR_CORRUPT_DATA; }
        var offset = load8(src + sp) + (load8(src + sp + 1) * 256);
        sp = sp + 2;

        if (offset == 0) { return 0 - ERR_CORRUPT_DATA; }
        if (offset > dp) { return 0 - ERR_MATCH_OUT_OF_RANGE; }

        # Match length (low nibble + 4 minimum)
        var match_len = (token & 15) + 4;
        if (match_len == 19) {
            # 15 + 4 = 19 means extended match length
            var extra = 255;
            while (extra == 255) {
                if (sp >= src_len) { return 0 - ERR_CORRUPT_DATA; }
                extra = load8(src + sp);
                sp = sp + 1;
                match_len = match_len + extra;
            }
        }

        # Copy match (byte-by-byte for overlapping matches)
        if (dp + match_len > dst_cap) { return 0 - ERR_BUFFER_TOO_SMALL; }
        if (dp + match_len > DECOMPRESS_MAX_OUTPUT) { return 0 - ERR_OUTPUT_LIMIT; }
        var match_pos = dp - offset;
        i = 0;
        while (i < match_len) {
            store8(dst + dp, load8(dst + match_pos));
            dp = dp + 1;
            match_pos = match_pos + 1;
            i = i + 1;
        }
    }

    return dp;
}

# Decompress an LZ4 frame.
fn lz4f_decompress(src, src_len, dst, dst_cap): i64 {
    if (src_len < 11) { return 0 - ERR_INVALID_INPUT; }

    var sp = 0;

    # Verify magic
    var magic = load8(src) | (load8(src + 1) << 8) |
    (load8(src + 2) << 16) | (load8(src + 3) << 24);
    if (magic != LZ4F_MAGIC) { return 0 - ERR_CORRUPT_DATA; }
    sp = 4;

    var flg = load8(src + sp);
    var version = (flg >> 6) & 3;
    if (version != LZ4F_VERSION) { return 0 - ERR_UNSUPPORTED_FORMAT; }
    var has_content_checksum = (flg >> 2) & 1;
    var has_content_size = (flg >> 3) & 1;
    var has_dict_id = flg & 1;
    var has_block_checksum = (flg >> 4) & 1;
    sp = sp + 1;

    sp = sp + 1;  # skip BD

    if (has_content_size == 1) { sp = sp + 8; }
    if (has_dict_id == 1) { sp = sp + 4; }
    sp = sp + 1;  # skip HC

    if (sp > src_len) { return 0 - ERR_CORRUPT_DATA; }

    # Read data blocks
    var total = 0;
    while (sp + 4 <= src_len) {
        var block_size = load8(src + sp) | (load8(src + sp + 1) << 8) |
        (load8(src + sp + 2) << 16) | (load8(src + sp + 3) << 24);
        sp = sp + 4;

        if (block_size == 0) { break; }

        var is_uncompressed = (block_size >> 31) & 1;
        block_size = block_size & 2147483647;

        if (sp + block_size > src_len) { return 0 - ERR_CORRUPT_DATA; }
        var data_start = sp;

        if (is_uncompressed == 1) {
            if (total + block_size > dst_cap) { return 0 - ERR_BUFFER_TOO_SMALL; }
            var i = 0;
            while (i < block_size) {
                store8(dst + total + i, load8(src + sp + i));
                i = i + 1;
            }
            total = total + block_size;
        } else {
            var dlen = lz4_decompress(src + sp, block_size, dst + total, dst_cap - total);
            if (dlen < 0) { return dlen; }
            total = total + dlen;
        }

        sp = sp + block_size;

        # Per-block checksum (FLG bit 4): 4-byte xxHash32 of on-wire block data.
        if (has_block_checksum == 1) {
            if (sp + 4 > src_len) { return 0 - ERR_CORRUPT_DATA; }
            var stored_bc = load8(src + sp) | (load8(src + sp + 1) << 8) |
            (load8(src + sp + 2) << 16) | (load8(src + sp + 3) << 24);
            var computed_bc = xxhash32(src + data_start, block_size);
            if (stored_bc != computed_bc) { return 0 - ERR_CHECKSUM_MISMATCH; }
            sp = sp + 4;
        }
    }

    # Verify content checksum if present
    if (has_content_checksum == 1 && sp + 4 <= src_len) {
        var stored_cc = load8(src + sp) | (load8(src + sp + 1) << 8) |
        (load8(src + sp + 2) << 16) | (load8(src + sp + 3) << 24);
        var computed_cc = xxhash32(dst, total);
        if (stored_cc != computed_cc) { return 0 - ERR_CHECKSUM_MISMATCH; }
    }

    return total;
}

# --- lz4.cyr ---

# sankoch — LZ4 block compression
# Spec: https://github.com/lz4/lz4/blob/dev/doc/lz4_Block_format.md
#
# LZ4 is byte-aligned (no bit-reader needed).
# Format: sequence of tokens, each = literal run + optional match copy.
#
# Token byte: high nibble = literal length, low nibble = match length - 4
# If nibble == 15, read additional bytes (each 255 = +255, first <255 = final add)
# Literals follow the token, then 2-byte little-endian match offset, then next token.

# Hash table size for match-finder: 4096 entries (12-bit hash).
# Each entry stores a source position (i64). Initialized to -1 (no match).
var _lz4_htab = 0;  # heap-allocated: 4096 * 8 bytes
enum LZ4 {
    LZ4_HTAB_SIZE = 4096;
    LZ4_HTAB_MASK = 4095;
    LZ4_MIN_MATCH = 4;
    LZ4_MAX_OFFSET = 65535;
}

# Hash 4 bytes at ptr into a 12-bit index.
fn _lz4_hash4(src, pos): i64 {
    var v = load8(src + pos);
    v = v + (load8(src + pos + 1) * 256);
    v = v + (load8(src + pos + 2) * 65536);
    v = v + (load8(src + pos + 3) * 16777216);
    # Knuth multiplicative hash, take top 12 bits of low 32
    v = (v * 2654435761) & 4294967295;
    return (v >> 20) & LZ4_HTAB_MASK;
}

# Count how many bytes match starting at positions a and b in src,
# up to max_len bytes.
fn _lz4_match_len(src, a, b, max_len): i64 {
    var i = 0;
    while (i < max_len) {
        if (load8(src + a + i) != load8(src + b + i)) {
            return i;
        }
        i = i + 1;
    }
    return max_len;
}

# Write an extended length (the part beyond 15) to dst.
# Returns new dp, or negative error.
fn _lz4_write_ext_len(dst, dp, dst_cap, length): i64 {
    var rem = length;
    while (rem >= 255) {
        if (dp >= dst_cap) { return 0 - ERR_BUFFER_TOO_SMALL; }
        store8(dst + dp, 255);
        dp = dp + 1;
        rem = rem - 255;
    }
    if (dp >= dst_cap) { return 0 - ERR_BUFFER_TOO_SMALL; }
    store8(dst + dp, rem);
    dp = dp + 1;
    return dp;
}

# Emit a literal run from src[lit_start..lit_start+lit_len]
# followed by a match (offset, match_len) to dst.
# If match_len == 0, this is the final sequence (no match part).
# Returns new dp, or negative error.
fn _lz4_emit(src, dst, dp, dst_cap, lit_start, lit_len, offset, match_len): i64 {
    # Token byte
    var lit_nibble = lit_len;
    if (lit_nibble > 15) { lit_nibble = 15; }
    var match_nibble = 0;
    if (match_len > 0) {
        match_nibble = match_len - LZ4_MIN_MATCH;
        if (match_nibble > 15) { match_nibble = 15; }
    }
    if (dp >= dst_cap) { return 0 - ERR_BUFFER_TOO_SMALL; }
    store8(dst + dp, (lit_nibble * 16) + match_nibble);
    dp = dp + 1;

    # Extended literal length
    if (lit_len >= 15) {
        dp = _lz4_write_ext_len(dst, dp, dst_cap, lit_len - 15);
        if (dp < 0) { return dp; }
    }

    # Copy literals
    if (dp + lit_len > dst_cap) { return 0 - ERR_BUFFER_TOO_SMALL; }
    var i = 0;
    while (i < lit_len) {
        store8(dst + dp, load8(src + lit_start + i));
        dp = dp + 1;
        i = i + 1;
    }

    # Match: offset + optional extended match length
    if (match_len > 0) {
        if (dp + 2 > dst_cap) { return 0 - ERR_BUFFER_TOO_SMALL; }
        store8(dst + dp, offset & 255);
        store8(dst + dp + 1, (offset >> 8) & 255);
        dp = dp + 2;

        var ml_code = match_len - LZ4_MIN_MATCH;
        if (ml_code >= 15) {
            dp = _lz4_write_ext_len(dst, dp, dst_cap, ml_code - 15);
            if (dp < 0) { return dp; }
        }
    }

    return dp;
}

# `lz4_decompress` (block decode) lives in src/lz4_decode.cyr — that
# file is part of the `[lib.core]` kernel-safe distlib profile. The
# encoder below is heap-using and stays in this file. The include
# chain in src/lib.cyr orders lz4_decode.cyr before lz4.cyr so the
# encoder's LZ4F frame-emit path can call lz4_decompress through the
# normal symbol-resolution flow.

# Compress data in LZ4 block format.
# Uses a hash table on 4-byte sequences to find matches.
# Greedy: takes the first match found (no optimal parsing).
fn lz4_compress(src, src_len, dst, dst_cap): i64 {
    _sankoch_lock();
    var r = _lz4_compress_inner(src, src_len, dst, dst_cap);
    _sankoch_unlock();
    return r;
}

# Internal unlocked entry. Callers must already hold _sankoch_mtx.
fn _lz4_compress_inner(src, src_len, dst, dst_cap): i64 {
    if (src_len == 0) {
        return 0;
    }

    # Need at least 4 bytes to hash — short inputs go store-only
    if (src_len < LZ4_MIN_MATCH) {
        return _lz4_emit(src, dst, 0, dst_cap, 0, src_len, 0, 0);
    }

    # Heap-allocate hash table on first use, then clear
    if (_lz4_htab == 0) {
        _lz4_htab = _sankoch_alloc(32768);
        if (_lz4_htab == 0) { return 0 - ERR_OOM; }
    }
    var i = 0;
    while (i < LZ4_HTAB_SIZE) {
        store64(_lz4_htab + i * 8, 0 - 1);  # -1 = no entry
        i = i + 1;
    }

    var sp = 0;        # current source position
    var dp = 0;        # current dest position
    var anchor = 0;    # start of pending literals
    var skip = 0;      # acceleration: skip counter for incompressible regions

    # LZ4 spec: last 5 bytes must be literals (match search limit).
    # Also: last match must start >= 12 bytes before end (MFLIMIT).
    var match_limit = src_len - 5;
    if (match_limit < 0) { match_limit = 0; }
    var mf_limit = src_len - 12;
    if (mf_limit < 0) { mf_limit = 0; }

    while (sp + LZ4_MIN_MATCH <= match_limit) {
        var h = _lz4_hash4(src, sp);
        var ref = load64(_lz4_htab + h * 8);

        # Update hash table with current position
        store64(_lz4_htab + h * 8, sp);

        # Check for a valid match (enforce MFLIMIT: match start < src_len - 12)
        if (ref >= 0 && sp <= mf_limit) {
            var off = sp - ref;
            if (off > 0 && off <= LZ4_MAX_OFFSET) {
                # Verify the 4-byte match
                if (load8(src + ref) == load8(src + sp)) {
                    if (load8(src + ref + 1) == load8(src + sp + 1)) {
                        if (load8(src + ref + 2) == load8(src + sp + 2)) {
                            if (load8(src + ref + 3) == load8(src + sp + 3)) {
                                # Match confirmed — extend it
                                # Clamp match so last 5 bytes remain as literals
                                var max_ext = match_limit - sp;
                                if (max_ext > src_len - sp) { max_ext = src_len - sp; }
                                var mlen = _lz4_match_len(src, ref, sp, max_ext);

                                # Emit literals [anchor..sp) + match
                                var lit_len = sp - anchor;
                                dp = _lz4_emit(src, dst, dp, dst_cap, anchor, lit_len, off, mlen);
                                if (dp < 0) { return dp; }

                                # Advance past the match
                                sp = sp + mlen;
                                anchor = sp;

                                # Hash the position after match
                                if (sp + LZ4_MIN_MATCH <= match_limit) {
                                    var hh = _lz4_hash4(src, sp);
                                    store64(_lz4_htab + hh * 8, sp);
                                }
                                skip = 0;  # reset acceleration
                                continue;
                            }
                        }
                    }
                }
            }
        }

        # Acceleration: skip ahead on misses (incompressible data traversal)
        skip = skip + 1;
        sp = sp + 1 + (skip >> 6);
    }

    # Emit remaining literals as the last sequence (no match)
    var lit_len = src_len - anchor;
    if (lit_len > 0) {
        dp = _lz4_emit(src, dst, dp, dst_cap, anchor, lit_len, 0, 0);
        if (dp < 0) { return dp; }
    }

    return dp;
}

# ================================================================
# LZ4 Frame format (LZ4F)
# Spec: https://github.com/lz4/lz4/blob/dev/doc/lz4_Frame_format.md
#
# Frame: magic(4) + FLG(1) + BD(1) + [content_size(8)] + HC(1)
#        + data_block(s) + end_mark(4) + [content_checksum(4)]
#
# We emit: block-independent, no block checksum, with content checksum,
# no content size, no dictionary ID. Inputs over 64KB are chunked into
# multiple 64KB blocks per the BD byte (block max size = 64KB).
# ================================================================

# `enum LZ4F` (LZ4F_MAGIC, LZ4F_VERSION, LZ4F_BLOCK_MAX) lives in
# src/lz4_decode.cyr alongside the decoder. Encoder uses LZ4F_BLOCK_MAX
# for chunk sizing; both halves see the constants through the include
# chain.

# Compress data into an LZ4 frame.
fn lz4f_compress(src, src_len, dst, dst_cap): i64 {
    _sankoch_lock();
    var r = _lz4f_compress_inner(src, src_len, dst, dst_cap);
    _sankoch_unlock();
    return r;
}

# Internal unlocked entry. Callers must already hold _sankoch_mtx.
fn _lz4f_compress_inner(src, src_len, dst, dst_cap): i64 {
    # Frame overhead: 7 (header) + 4 (block size) + 4 (end mark) + 4 (content checksum) = 19
    if (dst_cap < 19) { return 0 - ERR_BUFFER_TOO_SMALL; }

    var dp = 0;

    # Magic number (4 bytes, little-endian: 0x04224D18)
    store8(dst + dp, 4); store8(dst + dp + 1, 34);
    store8(dst + dp + 2, 77); store8(dst + dp + 3, 24);
    dp = dp + 4;

    # FLG byte: version=01, B.indep=1, B.checksum=0, C.size=0, C.checksum=1
    # = 0b01_1_0_0_1_0_0 = 0x64
    store8(dst + dp, 100);  # 0x64
    dp = dp + 1;

    # BD byte: block max size = 4 (64KB)
    # = 0b0_100_0000 = 0x40
    store8(dst + dp, 64);   # 0x40
    dp = dp + 1;

    # Header checksum: xxHash32 of FLG+BD, take bits 8-15
    var hc_buf[2];
    store8(&hc_buf, 100); store8(&hc_buf + 1, 64);
    var hc = (xxhash32(&hc_buf, 2) >> 8) & 255;
    store8(dst + dp, hc);
    dp = dp + 1;

    # Compress the block (skip for empty input — go straight to end mark)
    if (src_len == 0) {
        # End mark
        store8(dst + dp, 0); store8(dst + dp + 1, 0);
        store8(dst + dp + 2, 0); store8(dst + dp + 3, 0);
        dp = dp + 4;
        # Content checksum of empty = xxhash32(src, 0)
        var cc = xxhash32(src, 0);
        store8(dst + dp, cc & 255);
        store8(dst + dp + 1, (cc >> 8) & 255);
        store8(dst + dp + 2, (cc >> 16) & 255);
        store8(dst + dp + 3, (cc >> 24) & 255);
        dp = dp + 4;
        return dp;
    }

    # Chunk the input into ≤64KB blocks per the BD byte. Each block is
    # compressed independently (B.Indep=1 in FLG) — lz4_compress clears
    # its hash table every call, so matches do not cross block bounds.
    var sp = 0;
    while (sp < src_len) {
        var this_chunk = src_len - sp;
        if (this_chunk > LZ4F_BLOCK_MAX) { this_chunk = LZ4F_BLOCK_MAX; }

        # Reserve: this block's size header (4) + trailing end mark (4)
        # + content checksum (4). Subsequent blocks reuse the same margin.
        var block_start = dp + 4;
        var block_cap = dst_cap - dp - 4 - 4 - 4;
        if (block_cap < 0) { return 0 - ERR_BUFFER_TOO_SMALL; }

        var block_len = _lz4_compress_inner(src + sp, this_chunk, dst + block_start, block_cap);
        if (block_len < 0) { return block_len; }

        if (block_len >= this_chunk) {
            # Incompressible chunk — emit as uncompressed block (MSB=1)
            if (dp + 4 + this_chunk + 4 + 4 > dst_cap) { return 0 - ERR_BUFFER_TOO_SMALL; }
            var usize = this_chunk | 2147483648;
            store8(dst + dp, usize & 255);
            store8(dst + dp + 1, (usize >> 8) & 255);
            store8(dst + dp + 2, (usize >> 16) & 255);
            store8(dst + dp + 3, (usize >> 24) & 255);
            dp = dp + 4;
            var i = 0;
            while (i < this_chunk) { store8(dst + dp + i, load8(src + sp + i)); i = i + 1; }
            dp = dp + this_chunk;
        } else {
            store8(dst + dp, block_len & 255);
            store8(dst + dp + 1, (block_len >> 8) & 255);
            store8(dst + dp + 2, (block_len >> 16) & 255);
            store8(dst + dp + 3, (block_len >> 24) & 255);
            dp = dp + 4 + block_len;
        }

        sp = sp + this_chunk;
    }

    # End mark (4 zero bytes)
    store8(dst + dp, 0); store8(dst + dp + 1, 0);
    store8(dst + dp + 2, 0); store8(dst + dp + 3, 0);
    dp = dp + 4;

    # Content checksum (xxHash32, little-endian)
    var cc = xxhash32(src, src_len);
    store8(dst + dp, cc & 255);
    store8(dst + dp + 1, (cc >> 8) & 255);
    store8(dst + dp + 2, (cc >> 16) & 255);
    store8(dst + dp + 3, (cc >> 24) & 255);
    dp = dp + 4;

    return dp;
}

# Streaming LZ4F encoder (v1.7.0; configurable block-max + per-block
# checksum at 2.3.3). Accumulates input into a block_max-sized buffer,
# emits one LZ4 block per full buffer (B.Indep=1 — each block compresses
# independently, so buffering to the block boundary is correct). Content
# checksum accumulates incrementally across writes.
#
# Layout (80 bytes):
#   +0:  dst pointer
#   +8:  dst_cap
#   +16: dp (next write offset in dst)
#   +24: block_buf pointer (block_max bytes)
#   +32: block_buf_len (0..block_max)
#   +40: cc_state (xxhash32 incremental state ptr)
#   +48: err (sticky; negative poisons the encoder)
#   +56: block_max (bytes; 64K/256K/1M/4M per BD block-max ID)
#   +64: block_checksum (1 = emit per-block xxHash32 after each block)

fn _lz4f_enc_err(ctx): i64 { return load64(ctx + 48); }

# Map a BD block-max ID (4..7) to its block size in bytes.
# 4 → 64K, 5 → 256K, 6 → 1M, 7 → 4M (each step ×4).
fn _lz4f_block_max_size(id): i64 {
    return 65536 << (2 * (id - 4));
}

# Compress ctx.block_buf[0..block_buf_len] as one LZ4 block into dst,
# writing the 4-byte size header + payload. Updates dp. Returns 0 or
# negative error (stored into ctx.err and returned).
fn _lz4f_enc_emit_block(ctx): i64 {
    var dst = load64(ctx);
    var dst_cap = load64(ctx + 8);
    var dp = load64(ctx + 16);
    var block_buf = load64(ctx + 24);
    var block_buf_len = load64(ctx + 32);
    var bc = load64(ctx + 64);          # 1 = append per-block checksum
    var bc_bytes = bc * 4;

    # Reserve room for: this block size header (4) + optional block
    # checksum + end mark (4) + content checksum (4).
    var block_cap = dst_cap - dp - 4 - bc_bytes - 4 - 4;
    if (block_cap < 0) {
        store64(ctx + 48, 0 - ERR_BUFFER_TOO_SMALL);
        return 0 - ERR_BUFFER_TOO_SMALL;
    }

    var block_len = _lz4_compress_inner(block_buf, block_buf_len, dst + dp + 4, block_cap);
    if (block_len < 0) {
        store64(ctx + 48, block_len);
        return block_len;
    }

    # `data_off` / `data_len` track this block's on-wire payload (the
    # bytes the per-block checksum, if any, is computed over).
    var data_off = dp + 4;
    var data_len = 0;
    if (block_len >= block_buf_len) {
        # Incompressible — emit as uncompressed block (MSB=1).
        if (dp + 4 + block_buf_len + bc_bytes + 4 + 4 > dst_cap) {
            store64(ctx + 48, 0 - ERR_BUFFER_TOO_SMALL);
            return 0 - ERR_BUFFER_TOO_SMALL;
        }
        var usize = block_buf_len | 2147483648;
        store8(dst + dp, usize & 255);
        store8(dst + dp + 1, (usize >> 8) & 255);
        store8(dst + dp + 2, (usize >> 16) & 255);
        store8(dst + dp + 3, (usize >> 24) & 255);
        dp = dp + 4;
        var i = 0;
        while (i < block_buf_len) {
            store8(dst + dp + i, load8(block_buf + i));
            i = i + 1;
        }
        dp = dp + block_buf_len;
        data_len = block_buf_len;
    } else {
        store8(dst + dp, block_len & 255);
        store8(dst + dp + 1, (block_len >> 8) & 255);
        store8(dst + dp + 2, (block_len >> 16) & 255);
        store8(dst + dp + 3, (block_len >> 24) & 255);
        dp = dp + 4 + block_len;
        data_len = block_len;
    }

    # Per-block checksum: xxHash32 of the on-wire block data, LE.
    if (bc == 1) {
        var bcs = xxhash32(dst + data_off, data_len);
        store8(dst + dp, bcs & 255);
        store8(dst + dp + 1, (bcs >> 8) & 255);
        store8(dst + dp + 2, (bcs >> 16) & 255);
        store8(dst + dp + 3, (bcs >> 24) & 255);
        dp = dp + 4;
    }

    store64(ctx + 16, dp);
    store64(ctx + 32, 0);
    return 0;
}

# Default streaming encoder: 64K blocks, no per-block checksum.
# Wire-identical to the pre-2.3.3 emitter (FLG 0x64, BD 0x40).
fn lz4f_enc_init(dst, dst_cap): i64 {
    return lz4f_enc_init_ex(dst, dst_cap, 4, 0);
}

# Configurable streaming encoder (2.3.3). block_max_id selects the BD
# block-max: 4=64K, 5=256K, 6=1M, 7=4M. block_checksum != 0 sets FLG
# bit 4 and appends a per-block xxHash32 after each block's on-wire data.
fn lz4f_enc_init_ex(dst, dst_cap, block_max_id, block_checksum): i64 {
    if (block_max_id < 4 || block_max_id > 7) { return 0; }
    if (dst_cap < 19) { return 0; }   # 7 hdr + 4 end + 4 cc + 4 min block
    _sankoch_lock();

    var block_max = _lz4f_block_max_size(block_max_id);
    var bc = 0;
    if (block_checksum != 0) { bc = 1; }

    # FLG: version=01, B.indep=1, B.checksum=bc, C.size=0, C.checksum=1.
    var flg = 100;                     # 0x64
    if (bc == 1) { flg = flg | 16; }   # set bit 4 (block checksum)
    # BD: block-max ID in bits 4-6 (id << 4).
    var bd = block_max_id * 16;

    # Frame header (7 bytes): magic 0x184D2204 LE + FLG + BD + HC.
    store8(dst, 4); store8(dst + 1, 34); store8(dst + 2, 77); store8(dst + 3, 24);
    store8(dst + 4, flg);
    store8(dst + 5, bd);
    var hc_buf[2];
    store8(&hc_buf, flg); store8(&hc_buf + 1, bd);
    var hc = (xxhash32(&hc_buf, 2) >> 8) & 255;
    store8(dst + 6, hc);

    # 2.2.1: defensive alloc-failure handling (INFO-01). Release the
    # mutex and return 0 if any of the three allocs OOMs, so the
    # caller doesn't trip on a NULL ctx with the lock held.
    var ctx = _sankoch_alloc(80);
    if (ctx == 0) { _sankoch_unlock(); return 0; }
    var block_buf = _sankoch_alloc(block_max);
    if (block_buf == 0) { _sankoch_unlock(); return 0; }
    var xxh_st = xxhash32_init();
    if (xxh_st == 0) { _sankoch_unlock(); return 0; }
    store64(ctx, dst);
    store64(ctx + 8, dst_cap);
    store64(ctx + 16, 7);              # dp past header
    store64(ctx + 24, block_buf);
    store64(ctx + 32, 0);              # block_buf_len
    store64(ctx + 40, xxh_st);
    store64(ctx + 48, 0);
    store64(ctx + 56, block_max);
    store64(ctx + 64, bc);
    return ctx;
}

fn lz4f_enc_write(ctx, input, in_len): i64 {
    if (_lz4f_enc_err(ctx) < 0) { return _lz4f_enc_err(ctx); }
    if (in_len <= 0) { return 0; }

    xxhash32_update(load64(ctx + 40), input, in_len);

    var block_max = load64(ctx + 56);
    var block_buf = load64(ctx + 24);
    var block_buf_len = load64(ctx + 32);
    var off = 0;
    while (off < in_len) {
        var room = block_max - block_buf_len;
        var take = in_len - off;
        if (take > room) { take = room; }
        var i = 0;
        while (i < take) {
            store8(block_buf + block_buf_len + i, load8(input + off + i));
            i = i + 1;
        }
        block_buf_len = block_buf_len + take;
        off = off + take;
        if (block_buf_len == block_max) {
            store64(ctx + 32, block_buf_len);
            var rc = _lz4f_enc_emit_block(ctx);
            if (rc < 0) { return rc; }
            block_buf_len = 0;
        }
    }
    store64(ctx + 32, block_buf_len);
    return 0;
}

fn lz4f_enc_finish(ctx): i64 {
    if (_lz4f_enc_err(ctx) < 0) {
        _sankoch_unlock();
        return _lz4f_enc_err(ctx);
    }

    # Flush any pending partial block.
    if (load64(ctx + 32) > 0) {
        var rc = _lz4f_enc_emit_block(ctx);
        if (rc < 0) { _sankoch_unlock(); return rc; }
    }

    var dst = load64(ctx);
    var dst_cap = load64(ctx + 8);
    var dp = load64(ctx + 16);

    if (dp + 8 > dst_cap) { _sankoch_unlock(); return 0 - ERR_BUFFER_TOO_SMALL; }

    # End mark (4 zero bytes)
    store8(dst + dp, 0); store8(dst + dp + 1, 0);
    store8(dst + dp + 2, 0); store8(dst + dp + 3, 0);
    dp = dp + 4;

    # Content checksum LE
    var cc = xxhash32_final(load64(ctx + 40));
    store8(dst + dp, cc & 255);
    store8(dst + dp + 1, (cc >> 8) & 255);
    store8(dst + dp + 2, (cc >> 16) & 255);
    store8(dst + dp + 3, (cc >> 24) & 255);
    dp = dp + 4;

    _sankoch_unlock();
    return dp;
}

# `lz4f_decompress` (batch frame decode) lives in src/lz4_decode.cyr —
# see the note at the top of this file. The streaming counterpart
# `lz4f_dec_init / write / finish` lives below; it sits in lz4.cyr
# (full profile) because the block-buffering + incremental xxHash32
# need alloc, which the kernel-safe [lib.core] decode subset excludes.

# Streaming LZ4F decoder (bite-5 of the 2.3.0 arc).
#
# LZ4F frame format (RFC-equivalent: github.com/lz4/lz4 frame doc):
#   magic (4 bytes LE = 0x184D2204) | FLG (1) | BD (1) | optional
#   content_size (8, if FLG.bit3) | optional dict_id (4, if FLG.bit0)
#   | HC (1) | blocks... | end_mark (4 zeros) | optional content
#   checksum (4, if FLG.bit2)
#
# Each block:
#   block_size (4 LE; bit 31 = uncompressed flag) | block_data
#   (block_size bytes; LZ4 block or raw) | optional block_checksum
#   (4 LE if FLG.bit4 — NOT supported in bite-5).
#
# Scope (configurable block-max + per-block checksum landed at 2.3.3):
#   - Block-max ID (BD bits 4-6) 4..7 supported: 64K/256K/1M/4M. The
#     block buffer is sized from the parsed ID (default 64K alloc at
#     init; grown in the BD state if the frame declares larger).
#   - Per-block checksum (FLG bit 4) validated: a 4-byte xxHash32 of
#     each block's on-wire data, consumed in LDEC_STATE_BLOCK_CHECKSUM.
#   - Single-frame only; concatenated frames (RFC-equivalent multi-frame
#     streams) are NOT supported in the streaming path. Batch
#     `lz4f_decompress` doesn't support them either (single frame).
#
# ctx layout (13 i64 slots = 104 bytes):
#   +0   state            — LDEC_STATE_*
#   +8   dst              — output buffer pointer (caller-owned)
#   +16  dp               — bytes emitted so far
#   +24  dst_cap          — output buffer capacity
#   +32  flg              — parsed FLG byte
#   +40  idx              — multipurpose cursor (header bytes, optional-field
#                            counter, block-data bytes accumulated, trailer bytes)
#   +48  acc              — multipurpose accumulator (block_size LE bytes,
#                            content-checksum / block-checksum LE bytes)
#   +56  block_buf        — heap, block_max bytes
#   +64  block_size       — parsed block size (with uncompressed bit cleared)
#   +72  block_uncomp     — 1 if current block is uncompressed
#   +80  xxh_state        — incremental xxhash32 state ptr (0 if no content cksum)
#   +88  err              — sticky error; 0 = OK
#   +96  block_max        — per-frame block-max in bytes (from BD bits 4-6)

enum Lz4fDec {
    LDEC_CTX_SIZE = 104;
    LDEC_STATE_MAGIC = 0;            # 4-byte magic
    LDEC_STATE_FLG = 1;              # 1 byte
    LDEC_STATE_BD = 2;               # 1 byte
    LDEC_STATE_CONTENT_SIZE = 3;     # 8 bytes (skipped), only if FLG.bit3
    LDEC_STATE_DICT_ID = 4;          # 4 bytes (skipped), only if FLG.bit0
    LDEC_STATE_HC = 5;               # 1 byte (not validated, mirroring batch)
    LDEC_STATE_BLOCK_SIZE = 6;       # 4 bytes
    LDEC_STATE_BLOCK_DATA = 7;       # block_size bytes accumulated into block_buf
    LDEC_STATE_CONTENT_CHECKSUM = 8; # 4 bytes, validated against incremental xxh
    LDEC_STATE_DONE = 9;
    LDEC_STATE_BLOCK_CHECKSUM = 10;  # 4 bytes, validated against xxh of block data (FLG bit 4)
}

fn _ldec_poison(ctx, code): i64 {
    store64(ctx + 88, code);
    return code;
}

# Emit the fully-buffered block (block_buf[0..block_size]) into dst:
# raw-copy if uncompressed, else LZ4-decode. Updates the incremental
# content checksum on the emitted bytes and advances dp. Returns 0 on
# success or a negative (already-poisoned) error code.
fn _ldec_emit_block(ctx): i64 {
    var bsv = load64(ctx + 64);
    var dst_b = load64(ctx + 8);
    var dp_b = load64(ctx + 16);
    var dst_cap_b = load64(ctx + 24);
    var emitted = 0;
    if (load64(ctx + 72) == 1) {
        # Uncompressed block — raw copy.
        if (dp_b + bsv > dst_cap_b) {
            return _ldec_poison(ctx, 0 - ERR_BUFFER_TOO_SMALL);
        }
        if (dp_b + bsv > DECOMPRESS_MAX_OUTPUT) {
            return _ldec_poison(ctx, 0 - ERR_OUTPUT_LIMIT);
        }
        var bbuf2 = load64(ctx + 56);
        var ci = 0;
        while (ci < bsv) {
            store8(dst_b + dp_b + ci, load8(bbuf2 + ci));
            ci = ci + 1;
        }
        emitted = bsv;
    } else {
        var dlen = lz4_decompress(load64(ctx + 56), bsv,
        dst_b + dp_b, dst_cap_b - dp_b);
        if (dlen < 0) { return _ldec_poison(ctx, dlen); }
        emitted = dlen;
    }
    # Update incremental content checksum on the newly-emitted bytes.
    if ((load64(ctx + 32) >> 2) & 1) {
        xxhash32_update(load64(ctx + 80), dst_b + dp_b, emitted);
    }
    store64(ctx + 16, dp_b + emitted);
    return 0;
}

# After HC (and any optional fields), or after a non-zero block's data
# decompresses to dst, transition to LDEC_STATE_BLOCK_SIZE. Reset idx
# and acc so the 4-byte block-size accumulator starts fresh.
fn _ldec_to_block_size(ctx): i64 {
    store64(ctx + 40, 0);
    store64(ctx + 48, 0);
    store64(ctx + 0, LDEC_STATE_BLOCK_SIZE);
    return 0;
}

# Advance to the next post-BD state per FLG bits in on-wire order:
# content_size (bit 3) → dict_id (bit 0) → HC. `done_mask` records
# which optional sections have already been consumed.
fn _ldec_after_bd(ctx, done_mask): i64 {
    var flg = load64(ctx + 32);
    if ((flg & 8) != 0 && (done_mask & 8) == 0) {
        store64(ctx + 40, 0);
        store64(ctx + 0, LDEC_STATE_CONTENT_SIZE);
    } elif ((flg & 1) != 0 && (done_mask & 1) == 0) {
        store64(ctx + 40, 0);
        store64(ctx + 0, LDEC_STATE_DICT_ID);
    } else {
        store64(ctx + 40, 0);
        store64(ctx + 0, LDEC_STATE_HC);
    }
    return 0;
}

fn lz4f_dec_init(dst, dst_cap): i64 {
    if (dst_cap < 0) { return 0; }
    if (dst_cap > 0 && dst == 0) { return 0; }
    _sankoch_lock();
    var ctx = _sankoch_alloc(LDEC_CTX_SIZE);
    if (ctx == 0) { _sankoch_unlock(); return 0; }
    var block_buf = _sankoch_alloc(LZ4F_BLOCK_MAX);
    if (block_buf == 0) { _sankoch_unlock(); return 0; }
    var xxh_st = xxhash32_init();
    if (xxh_st == 0) { _sankoch_unlock(); return 0; }

    store64(ctx + 0, LDEC_STATE_MAGIC);
    store64(ctx + 8, dst);
    store64(ctx + 16, 0);
    store64(ctx + 24, dst_cap);
    store64(ctx + 32, 0);
    store64(ctx + 40, 0);
    store64(ctx + 48, 0);
    store64(ctx + 56, block_buf);
    store64(ctx + 64, 0);
    store64(ctx + 72, 0);
    store64(ctx + 80, xxh_st);
    store64(ctx + 88, 0);
    store64(ctx + 96, LZ4F_BLOCK_MAX);   # default; grown in BD if frame declares larger
    return ctx;
}

fn lz4f_dec_write(ctx, input, in_len): i64 {
    if (load64(ctx + 88) < 0) { return load64(ctx + 88); }
    if (in_len < 0) {
        return _ldec_poison(ctx, 0 - ERR_INVALID_INPUT);
    }
    if (in_len == 0) { return 0; }
    if (in_len > 0 && input == 0) {
        return _ldec_poison(ctx, 0 - ERR_INVALID_INPUT);
    }

    var cp = 0;
    while (1) {
        var state = load64(ctx + 0);
        if (state == LDEC_STATE_DONE) { return cp; }

        if (state == LDEC_STATE_MAGIC) {
            var mi = load64(ctx + 40);
            var macc = load64(ctx + 48);
            while (mi < 4 && cp < in_len) {
                macc = macc | (load8(input + cp) << (mi * 8));
                cp = cp + 1;
                mi = mi + 1;
            }
            store64(ctx + 40, mi);
            store64(ctx + 48, macc);
            if (mi < 4) { return cp; }
            if (macc != LZ4F_MAGIC) {
                return _ldec_poison(ctx, 0 - ERR_CORRUPT_DATA);
            }
            store64(ctx + 40, 0);
            store64(ctx + 48, 0);
            store64(ctx + 0, LDEC_STATE_FLG);
        } elif (state == LDEC_STATE_FLG) {
            if (cp >= in_len) { return cp; }
            var fb = load8(input + cp);
            cp = cp + 1;
            var ver = (fb >> 6) & 3;
            if (ver != LZ4F_VERSION) {
                return _ldec_poison(ctx, 0 - ERR_UNSUPPORTED_FORMAT);
            }
            # Reserved bit 1 must be 0 per spec.
            if ((fb >> 1) & 1) {
                return _ldec_poison(ctx, 0 - ERR_CORRUPT_DATA);
            }
            store64(ctx + 32, fb);
            store64(ctx + 0, LDEC_STATE_BD);
        } elif (state == LDEC_STATE_BD) {
            if (cp >= in_len) { return cp; }
            var bdb = load8(input + cp);
            cp = cp + 1;
            # Bits 4-6 = block-max ID. Only 4..7 (64K/256K/1M/4M) are
            # valid per the LZ4 frame spec; 0..3 are reserved.
            var bms = (bdb >> 4) & 7;
            if (bms < 4) {
                return _ldec_poison(ctx, 0 - ERR_CORRUPT_DATA);
            }
            # Size the block buffer to the declared block-max. Init
            # allocates 64K; grow only if the frame declares larger so
            # the common 64K path never re-allocs mid-decode.
            var bmax = _lz4f_block_max_size(bms);
            if (bmax > load64(ctx + 96)) {
                var nbuf = _sankoch_alloc(bmax);
                if (nbuf == 0) {
                    return _ldec_poison(ctx, 0 - ERR_BUFFER_TOO_SMALL);
                }
                store64(ctx + 56, nbuf);
                store64(ctx + 96, bmax);
            }
            _ldec_after_bd(ctx, 0);
        } elif (state == LDEC_STATE_CONTENT_SIZE) {
            var csi = load64(ctx + 40);
            var skip = in_len - cp;
            if (skip > 8 - csi) { skip = 8 - csi; }
            cp = cp + skip;
            csi = csi + skip;
            store64(ctx + 40, csi);
            if (csi < 8) { return cp; }
            _ldec_after_bd(ctx, 8);
        } elif (state == LDEC_STATE_DICT_ID) {
            var di = load64(ctx + 40);
            var dskip = in_len - cp;
            if (dskip > 4 - di) { dskip = 4 - di; }
            cp = cp + dskip;
            di = di + dskip;
            store64(ctx + 40, di);
            if (di < 4) { return cp; }
            _ldec_after_bd(ctx, 9);
        } elif (state == LDEC_STATE_HC) {
            if (cp >= in_len) { return cp; }
            cp = cp + 1;
            _ldec_to_block_size(ctx);
        } elif (state == LDEC_STATE_BLOCK_SIZE) {
            var bsi = load64(ctx + 40);
            var bsacc = load64(ctx + 48);
            while (bsi < 4 && cp < in_len) {
                bsacc = bsacc | (load8(input + cp) << (bsi * 8));
                cp = cp + 1;
                bsi = bsi + 1;
            }
            store64(ctx + 40, bsi);
            store64(ctx + 48, bsacc);
            if (bsi < 4) { return cp; }
            if (bsacc == 0) {
                # End-mark — frame body complete.
                if ((load64(ctx + 32) >> 2) & 1) {
                    store64(ctx + 40, 0);
                    store64(ctx + 48, 0);
                    store64(ctx + 0, LDEC_STATE_CONTENT_CHECKSUM);
                } else {
                    store64(ctx + 0, LDEC_STATE_DONE);
                    return cp;
                }
            } else {
                var uncomp = (bsacc >> 31) & 1;
                var bsv = bsacc & 2147483647;
                if (bsv > load64(ctx + 96)) {
                    return _ldec_poison(ctx, 0 - ERR_CORRUPT_DATA);
                }
                store64(ctx + 64, bsv);
                store64(ctx + 72, uncomp);
                store64(ctx + 40, 0);
                store64(ctx + 0, LDEC_STATE_BLOCK_DATA);
            }
        } elif (state == LDEC_STATE_BLOCK_DATA) {
            var bsv = load64(ctx + 64);
            var bdi = load64(ctx + 40);
            var room = bsv - bdi;
            var bavail = in_len - cp;
            var take = room;
            if (take > bavail) { take = bavail; }
            if (take > 0) {
                var bbuf = load64(ctx + 56);
                var bi = 0;
                while (bi < take) {
                    store8(bbuf + bdi + bi, load8(input + cp + bi));
                    bi = bi + 1;
                }
                cp = cp + take;
                bdi = bdi + take;
                store64(ctx + 40, bdi);
            }
            if (bdi < bsv) { return cp; }
            # Block fully buffered. If a per-block checksum follows
            # (FLG bit 4), validate it before emitting; otherwise emit now.
            if ((load64(ctx + 32) >> 4) & 1) {
                store64(ctx + 40, 0);
                store64(ctx + 48, 0);
                store64(ctx + 0, LDEC_STATE_BLOCK_CHECKSUM);
            } else {
                var rc = _ldec_emit_block(ctx);
                if (rc < 0) { return rc; }
                _ldec_to_block_size(ctx);
            }
        } elif (state == LDEC_STATE_BLOCK_CHECKSUM) {
            var xi = load64(ctx + 40);
            var xacc = load64(ctx + 48);
            while (xi < 4 && cp < in_len) {
                xacc = xacc | (load8(input + cp) << (xi * 8));
                cp = cp + 1;
                xi = xi + 1;
            }
            store64(ctx + 40, xi);
            store64(ctx + 48, xacc);
            if (xi < 4) { return cp; }
            # Validate xxHash32 of the buffered on-wire block data.
            var bsv2 = load64(ctx + 64);
            var computed_bc = xxhash32(load64(ctx + 56), bsv2);
            if (xacc != computed_bc) {
                return _ldec_poison(ctx, 0 - ERR_CHECKSUM_MISMATCH);
            }
            var rc = _ldec_emit_block(ctx);
            if (rc < 0) { return rc; }
            _ldec_to_block_size(ctx);
        } elif (state == LDEC_STATE_CONTENT_CHECKSUM) {
            var cci = load64(ctx + 40);
            var ccacc = load64(ctx + 48);
            while (cci < 4 && cp < in_len) {
                ccacc = ccacc | (load8(input + cp) << (cci * 8));
                cp = cp + 1;
                cci = cci + 1;
            }
            store64(ctx + 40, cci);
            store64(ctx + 48, ccacc);
            if (cci < 4) { return cp; }
            var computed_cc = xxhash32_final(load64(ctx + 80));
            if (ccacc != computed_cc) {
                return _ldec_poison(ctx, 0 - ERR_CHECKSUM_MISMATCH);
            }
            store64(ctx + 0, LDEC_STATE_DONE);
            return cp;
        } else {
            return _ldec_poison(ctx, 0 - ERR_INVALID_INPUT);
        }
    }
    return cp;
}

fn lz4f_dec_finish(ctx): i64 {
    var rc = 0;
    var err = load64(ctx + 88);
    if (err < 0) {
        rc = err;
    } elif (load64(ctx + 0) != LDEC_STATE_DONE) {
        rc = 0 - ERR_CORRUPT_DATA;
    } else {
        rc = load64(ctx + 16);
    }
    _sankoch_unlock();
    return rc;
}

# --- deflate.cyr ---

# sankoch — DEFLATE decompression (RFC 1951)
#
# Three block types:
#   00 — uncompressed (stored)
#   01 — fixed Huffman codes
#   10 — dynamic Huffman codes
#
# Each block has a BFINAL bit (1 = last block) and BTYPE (2 bits).
# Compressed blocks contain a stream of literal/length + distance pairs.
# Literal bytes 0-255 are emitted directly.
# Symbol 256 = end of block.
# Symbols 257-285 = length codes (with extra bits), followed by a distance code.

# Length code base values and extra bits (RFC 1951, Section 3.2.5)
# Index by (code - 257)
var _deflate_len_base[232];   # 29 * 8
var _deflate_len_extra[232];  # 29 * 8

# Distance code base values and extra bits
# Index by distance code (0-29)
var _deflate_dist_base[240];  # 30 * 8
var _deflate_dist_extra[240]; # 30 * 8

var _deflate_tables_built = 0;

fn _deflate_init_tables(): i64 {
    if (_deflate_tables_built == 1) { return 0; }

    # Length bases: codes 257-285 → lengths 3-258
    # 257: 3, 258: 4, 259: 5, 260: 6, 261: 7, 262: 8, 263: 9, 264: 10
    store64(&_deflate_len_base + 0 * 8, 3);
    store64(&_deflate_len_base + 1 * 8, 4);
    store64(&_deflate_len_base + 2 * 8, 5);
    store64(&_deflate_len_base + 3 * 8, 6);
    store64(&_deflate_len_base + 4 * 8, 7);
    store64(&_deflate_len_base + 5 * 8, 8);
    store64(&_deflate_len_base + 6 * 8, 9);
    store64(&_deflate_len_base + 7 * 8, 10);
    # 265-268: 1 extra bit
    store64(&_deflate_len_base + 8 * 8, 11);
    store64(&_deflate_len_base + 9 * 8, 13);
    store64(&_deflate_len_base + 10 * 8, 15);
    store64(&_deflate_len_base + 11 * 8, 17);
    # 269-272: 2 extra bits
    store64(&_deflate_len_base + 12 * 8, 19);
    store64(&_deflate_len_base + 13 * 8, 23);
    store64(&_deflate_len_base + 14 * 8, 27);
    store64(&_deflate_len_base + 15 * 8, 31);
    # 273-276: 3 extra bits
    store64(&_deflate_len_base + 16 * 8, 35);
    store64(&_deflate_len_base + 17 * 8, 43);
    store64(&_deflate_len_base + 18 * 8, 51);
    store64(&_deflate_len_base + 19 * 8, 59);
    # 277-280: 4 extra bits
    store64(&_deflate_len_base + 20 * 8, 67);
    store64(&_deflate_len_base + 21 * 8, 83);
    store64(&_deflate_len_base + 22 * 8, 99);
    store64(&_deflate_len_base + 23 * 8, 115);
    # 281-284: 5 extra bits
    store64(&_deflate_len_base + 24 * 8, 131);
    store64(&_deflate_len_base + 25 * 8, 163);
    store64(&_deflate_len_base + 26 * 8, 195);
    store64(&_deflate_len_base + 27 * 8, 227);
    # 285: 0 extra bits, length 258
    store64(&_deflate_len_base + 28 * 8, 258);

    # Length extra bits
    var i = 0;
    while (i < 8) {
        store64(&_deflate_len_extra + i * 8, 0);
        i = i + 1;
    }
    var eb = 1;
    while (eb <= 5) {
        var j = 0;
        while (j < 4) {
            store64(&_deflate_len_extra + i * 8, eb);
            i = i + 1;
            j = j + 1;
        }
        eb = eb + 1;
    }
    store64(&_deflate_len_extra + 28 * 8, 0);  # code 285 = 0 extra

    # Distance bases: codes 0-29 → distances 1-32768
    store64(&_deflate_dist_base + 0 * 8, 1);
    store64(&_deflate_dist_base + 1 * 8, 2);
    store64(&_deflate_dist_base + 2 * 8, 3);
    store64(&_deflate_dist_base + 3 * 8, 4);
    store64(&_deflate_dist_base + 4 * 8, 5);
    store64(&_deflate_dist_base + 5 * 8, 7);
    store64(&_deflate_dist_base + 6 * 8, 9);
    store64(&_deflate_dist_base + 7 * 8, 13);
    store64(&_deflate_dist_base + 8 * 8, 17);
    store64(&_deflate_dist_base + 9 * 8, 25);
    store64(&_deflate_dist_base + 10 * 8, 33);
    store64(&_deflate_dist_base + 11 * 8, 49);
    store64(&_deflate_dist_base + 12 * 8, 65);
    store64(&_deflate_dist_base + 13 * 8, 97);
    store64(&_deflate_dist_base + 14 * 8, 129);
    store64(&_deflate_dist_base + 15 * 8, 193);
    store64(&_deflate_dist_base + 16 * 8, 257);
    store64(&_deflate_dist_base + 17 * 8, 385);
    store64(&_deflate_dist_base + 18 * 8, 513);
    store64(&_deflate_dist_base + 19 * 8, 769);
    store64(&_deflate_dist_base + 20 * 8, 1025);
    store64(&_deflate_dist_base + 21 * 8, 1537);
    store64(&_deflate_dist_base + 22 * 8, 2049);
    store64(&_deflate_dist_base + 23 * 8, 3073);
    store64(&_deflate_dist_base + 24 * 8, 4097);
    store64(&_deflate_dist_base + 25 * 8, 6145);
    store64(&_deflate_dist_base + 26 * 8, 8193);
    store64(&_deflate_dist_base + 27 * 8, 12289);
    store64(&_deflate_dist_base + 28 * 8, 16385);
    store64(&_deflate_dist_base + 29 * 8, 24577);

    # Distance extra bits: 0,0,0,0, 1,1, 2,2, 3,3, ..., 13,13
    store64(&_deflate_dist_extra + 0 * 8, 0);
    store64(&_deflate_dist_extra + 1 * 8, 0);
    store64(&_deflate_dist_extra + 2 * 8, 0);
    store64(&_deflate_dist_extra + 3 * 8, 0);
    i = 4;
    eb = 1;
    while (i < 30) {
        store64(&_deflate_dist_extra + i * 8, eb);
        store64(&_deflate_dist_extra + (i + 1) * 8, eb);
        i = i + 2;
        eb = eb + 1;
    }

    _deflate_tables_built = 1;
    return 0;
}

# Decode a compressed block (fixed or dynamic Huffman).
# br: bitreader
# dst: output buffer
# dp: current output position
# dst_cap: output capacity
# Returns: new dp, or negative error.
fn _deflate_decode_block(br, dst, dp, dst_cap): i64 {
    while (1) {
        var sym = huff_decode_litlen(br);
        if (sym < 0) { return sym; }

        if (sym < 256) {
            # Literal byte
            if (dp >= dst_cap) { return 0 - ERR_BUFFER_TOO_SMALL; }
            if (dp >= DECOMPRESS_MAX_OUTPUT) { return 0 - ERR_OUTPUT_LIMIT; }
            store8(dst + dp, sym);
            dp = dp + 1;
        } elif (sym == 256) {
            # End of block
            return dp;
        } else {
            # Length/distance pair
            var len_idx = sym - 257;
            if (len_idx >= 29) { return 0 - ERR_CORRUPT_DATA; }

            var length = load64(&_deflate_len_base + len_idx * 8);
            var extra = load64(&_deflate_len_extra + len_idx * 8);
            if (extra > 0) {
                var eb = br_read(br, extra);
                if (eb < 0) { return eb; }
                length = length + eb;
            }

            # Decode distance
            var dist_sym = huff_decode_dist(br);
            if (dist_sym < 0) { return dist_sym; }
            if (dist_sym >= 30) { return 0 - ERR_CORRUPT_DATA; }

            var distance = load64(&_deflate_dist_base + dist_sym * 8);
            var dextra = load64(&_deflate_dist_extra + dist_sym * 8);
            if (dextra > 0) {
                var deb = br_read(br, dextra);
                if (deb < 0) { return deb; }
                distance = distance + deb;
            }

            # Copy from output window
            if (distance > dp) { return 0 - ERR_MATCH_OUT_OF_RANGE; }
            if (dp + length > dst_cap) { return 0 - ERR_BUFFER_TOO_SMALL; }
            if (dp + length > DECOMPRESS_MAX_OUTPUT) { return 0 - ERR_OUTPUT_LIMIT; }

            var src_pos = dp - distance;
            var i = 0;
            while (i < length) {
                store8(dst + dp, load8(dst + src_pos));
                dp = dp + 1;
                src_pos = src_pos + 1;
                i = i + 1;
            }
        }
    }

    return dp;
}

# Read dynamic Huffman tables from the stream (RFC 1951 Section 3.2.7).
fn _deflate_read_dynamic(br): i64 {
    var hlit = br_read(br, 5);
    if (hlit < 0) { return hlit; }
    hlit = hlit + 257;  # number of literal/length codes
    # MED-1 fix (2.1.3): RFC 1951 §3.2.7 caps HLIT count at 286 (encoded
    # field range 0..29). Encoded values 30..31 yield 287..288, which
    # the spec marks invalid; reject explicitly so we don't build a
    # 288-entry literal/length code table that the rest of the decoder
    # never expects.
    if (hlit > 286) { return 0 - ERR_CORRUPT_DATA; }

    var hdist = br_read(br, 5);
    if (hdist < 0) { return hdist; }
    # Distance count = encoded + 1, so 1..32 — all 5-bit encodings valid.
    hdist = hdist + 1;

    var hclen = br_read(br, 4);
    if (hclen < 0) { return hclen; }
    # Code-length-code count = encoded + 4, so 4..19 — all 4-bit valid.
    hclen = hclen + 4;

    # Code length alphabet order (RFC 1951 Section 3.2.7)
    # 16, 17, 18, 0, 8, 7, 9, 6, 10, 5, 11, 4, 12, 3, 13, 2, 14, 1, 15
    var cl_order[152];  # 19 * 8
    store64(&cl_order + 0 * 8, 16);
    store64(&cl_order + 1 * 8, 17);
    store64(&cl_order + 2 * 8, 18);
    store64(&cl_order + 3 * 8, 0);
    store64(&cl_order + 4 * 8, 8);
    store64(&cl_order + 5 * 8, 7);
    store64(&cl_order + 6 * 8, 9);
    store64(&cl_order + 7 * 8, 6);
    store64(&cl_order + 8 * 8, 10);
    store64(&cl_order + 9 * 8, 5);
    store64(&cl_order + 10 * 8, 11);
    store64(&cl_order + 11 * 8, 4);
    store64(&cl_order + 12 * 8, 12);
    store64(&cl_order + 13 * 8, 3);
    store64(&cl_order + 14 * 8, 13);
    store64(&cl_order + 15 * 8, 2);
    store64(&cl_order + 16 * 8, 14);
    store64(&cl_order + 17 * 8, 1);
    store64(&cl_order + 18 * 8, 15);

    # Read code length code lengths
    var cl_lens[152];  # 19 * 8
    var i = 0;
    while (i < 19) {
        store64(&cl_lens + i * 8, 0);
        i = i + 1;
    }
    i = 0;
    while (i < hclen) {
        var val = br_read(br, 3);
        if (val < 0) { return val; }
        var idx = load64(&cl_order + i * 8);
        store64(&cl_lens + idx * 8, val);
        i = i + 1;
    }

    # Build code-length Huffman table
    huff_build_cl(&cl_lens, 19);

    # Decode literal/length + distance code lengths
    var total = hlit + hdist;
    var all_lens[4672];  # 584 * 8 (max hlit=286 + hdist=32 = 318, but allow 320+)
    var rep = 0;
    var j = 0;
    var prev = 0;
    i = 0;
    while (i < total) {
        var sym = huff_decode_cl(br);
        if (sym < 0) { return sym; }

        if (sym <= 15) {
            # Literal code length
            store64(&all_lens + i * 8, sym);
            i = i + 1;
        } elif (sym == 16) {
            # Repeat previous 3-6 times
            if (i == 0) { return 0 - ERR_CORRUPT_DATA; }
            rep = br_read(br, 2);
            if (rep < 0) { return rep; }
            rep = rep + 3;
            prev = load64(&all_lens + (i - 1) * 8);
            j = 0;
            while (j < rep) {
                if (i >= total) { return 0 - ERR_CORRUPT_DATA; }
                store64(&all_lens + i * 8, prev);
                i = i + 1;
                j = j + 1;
            }
        } elif (sym == 17) {
            # Repeat 0 for 3-10 times
            rep = br_read(br, 3);
            if (rep < 0) { return rep; }
            rep = rep + 3;
            j = 0;
            while (j < rep) {
                if (i >= total) { return 0 - ERR_CORRUPT_DATA; }
                store64(&all_lens + i * 8, 0);
                i = i + 1;
                j = j + 1;
            }
        } elif (sym == 18) {
            # Repeat 0 for 11-138 times
            rep = br_read(br, 7);
            if (rep < 0) { return rep; }
            rep = rep + 11;
            j = 0;
            while (j < rep) {
                if (i >= total) { return 0 - ERR_CORRUPT_DATA; }
                store64(&all_lens + i * 8, 0);
                i = i + 1;
                j = j + 1;
            }
        } else {
            return 0 - ERR_INVALID_HUFFMAN;
        }
    }

    # Split into literal/length and distance tables, build both
    huff_build_litlen(&all_lens, hlit);
    huff_build_dist(&all_lens + hlit * 8, hdist);

    return 0;
}

# Bytes consumed by the last deflate_decompress call.
# Wrappers (zlib, gzip) use this to find the trailer position.
var _deflate_bytes_consumed = 0;

# Return bytes consumed by the last deflate_decompress call.
fn deflate_bytes_consumed(): i64 {
    return _deflate_bytes_consumed;
}

# Decompress a DEFLATE stream.
# src: pointer to compressed data (raw DEFLATE, no zlib/gzip wrapper)
# src_len: length of compressed data
# dst: pointer to output buffer
# dst_cap: capacity of output buffer
# Returns: decompressed length, or negative error code.
fn deflate_decompress(src, src_len, dst, dst_cap): i64 {
    _sankoch_lock();
    var r = _deflate_decompress_inner(src, src_len, dst, dst_cap);
    _sankoch_unlock();
    return r;
}

# Internal unlocked entry. Callers must already hold _sankoch_mtx.
fn _deflate_decompress_inner(src, src_len, dst, dst_cap): i64 {
    _deflate_init_tables();
    # 2.3.7: pre-build all decode tables so the in-loop lazy-init calls
    # (huff_build_*, huff_build_fixed, _ddec_alloc_dyn_ws) never alloc.
    if (_huff_alloc_tables() < 0) { return 0 - ERR_OOM; }
    if (huff_build_fixed() < 0) { return 0 - ERR_OOM; }
    if (_ddec_alloc_dyn_ws() < 0) { return 0 - ERR_OOM; }

    var br = br_init(src, src_len);
    if (br == 0) { return 0 - ERR_OOM; }
    var dp = 0;
    var bfinal = 0;

    while (bfinal == 0) {
        bfinal = br_read(br, 1);
        if (bfinal < 0) { return bfinal; }

        var btype = br_read(br, 2);
        if (btype < 0) { return btype; }

        if (btype == 0) {
            # Uncompressed block
            br_align(br);
            var len = br_read(br, 16);
            if (len < 0) { return len; }
            var nlen = br_read(br, 16);
            if (nlen < 0) { return nlen; }
            # nlen should be one's complement of len
            if ((len ^ nlen) != 65535) { return 0 - ERR_CORRUPT_DATA; }

            if (dp + len > dst_cap) { return 0 - ERR_BUFFER_TOO_SMALL; }

            # Copy raw bytes from the stream
            var data = load64(br);
            var bpos = load64(br + 8);
            # HIGH-1 fix (2.1.3): direct buffer copy bypasses br_read's
            # bpos<dlen check, so re-assert bounds against the bitreader's
            # backing length here. Malformed input with len > remaining
            # would otherwise read past src+src_len.
            if (bpos + len > load64(br + 24)) { return 0 - ERR_CORRUPT_DATA; }
            var i = 0;
            while (i < len) {
                store8(dst + dp, load8(data + bpos));
                dp = dp + 1;
                bpos = bpos + 1;
                i = i + 1;
            }
            store64(br + 8, bpos);

        } elif (btype == 1) {
            # Fixed Huffman codes
            huff_build_fixed();
            dp = _deflate_decode_block(br, dst, dp, dst_cap);
            if (dp < 0) { return dp; }

        } elif (btype == 2) {
            # Dynamic Huffman codes
            var rc = _deflate_read_dynamic(br);
            if (rc < 0) { return rc; }
            dp = _deflate_decode_block(br, dst, dp, dst_cap);
            if (dp < 0) { return dp; }

        } else {
            # btype == 3 is reserved/invalid
            return 0 - ERR_INVALID_BLOCK_TYPE;
        }
    }

    _deflate_bytes_consumed = br_bytes_consumed(br);
    return dp;
}

# Decompress a DEFLATE stream with a preset dictionary.
# The dictionary is placed at the start of the output buffer so
# back-references can reach into it. Returns only the decompressed
# byte count (excluding the dictionary prefix).
# dict_len must be <= DEFLATE_WINDOW_SIZE (32768).
fn deflate_decompress_dict(src, src_len, dst, dst_cap, dict, dict_len): i64 {
    _sankoch_lock();
    var r = _deflate_decompress_dict_inner(src, src_len, dst, dst_cap, dict, dict_len);
    _sankoch_unlock();
    return r;
}

# Internal unlocked entry. Callers must already hold _sankoch_mtx.
fn _deflate_decompress_dict_inner(src, src_len, dst, dst_cap, dict, dict_len): i64 {
    if (dict_len > DEFLATE_WINDOW_SIZE) { return 0 - ERR_INVALID_INPUT; }
    if (dict_len > dst_cap) { return 0 - ERR_BUFFER_TOO_SMALL; }

    # Copy dictionary into the start of the output buffer
    var i = 0;
    while (i < dict_len) {
        store8(dst + i, load8(dict + i));
        i = i + 1;
    }

    _deflate_init_tables();
    if (_huff_alloc_tables() < 0) { return 0 - ERR_OOM; }
    if (huff_build_fixed() < 0) { return 0 - ERR_OOM; }
    if (_ddec_alloc_dyn_ws() < 0) { return 0 - ERR_OOM; }
    var br = br_init(src, src_len);
    if (br == 0) { return 0 - ERR_OOM; }
    var dp = dict_len;
    var bfinal = 0;

    while (bfinal == 0) {
        bfinal = br_read(br, 1);
        if (bfinal < 0) { return bfinal; }

        var btype = br_read(br, 2);
        if (btype < 0) { return btype; }

        if (btype == 0) {
            br_align(br);
            var len = br_read(br, 16);
            if (len < 0) { return len; }
            var nlen = br_read(br, 16);
            if (nlen < 0) { return nlen; }
            if ((len ^ nlen) != 65535) { return 0 - ERR_CORRUPT_DATA; }
            if (dp + len > dst_cap) { return 0 - ERR_BUFFER_TOO_SMALL; }

            var data = load64(br);
            var bpos = load64(br + 8);
            # HIGH-1 fix (2.1.3): same bounds re-assert as the non-dict
            # path above (see comment there).
            if (bpos + len > load64(br + 24)) { return 0 - ERR_CORRUPT_DATA; }
            i = 0;
            while (i < len) {
                store8(dst + dp, load8(data + bpos));
                dp = dp + 1;
                bpos = bpos + 1;
                i = i + 1;
            }
            store64(br + 8, bpos);

        } elif (btype == 1) {
            huff_build_fixed();
            dp = _deflate_decode_block(br, dst, dp, dst_cap);
            if (dp < 0) { return dp; }

        } elif (btype == 2) {
            var rc = _deflate_read_dynamic(br);
            if (rc < 0) { return rc; }
            dp = _deflate_decode_block(br, dst, dp, dst_cap);
            if (dp < 0) { return dp; }

        } else {
            return 0 - ERR_INVALID_BLOCK_TYPE;
        }
    }

    _deflate_bytes_consumed = br_bytes_consumed(br);

    # Move decompressed output to start of buffer (over the dictionary prefix)
    var dlen = dp - dict_len;
    i = 0;
    while (i < dlen) {
        store8(dst + i, load8(dst + dict_len + i));
        i = i + 1;
    }
    return dlen;
}

# ================================================================
# DEFLATE streaming decompression (2.3.0 — bite 1: stored blocks)
# ================================================================
#
# Public API mirrors the encoder side: `deflate_dec_init(dst, dst_cap)`
# returns a ctx; `deflate_dec_write(ctx, input, in_len)` feeds compressed
# bytes incrementally; `deflate_dec_finish(ctx)` returns total emitted
# bytes (matches `deflate_decompress`'s return). Mutex held from
# dec_init to dec_finish — single-threaded contract identical to
# enc_init/finish.
#
# Chunk-boundary suspension uses a hold/bits accumulator (the zlib /
# libdeflate / miniz pattern). Bytes from each `write` chunk feed into
# a 64-bit `hold` register one at a time as needed. When the chunk
# runs out before enough bits are available for the current state-
# machine step, the decoder saves its position and returns 0; the next
# `write` resumes from the same point.
#
# Bite 1 supports BTYPE=00 (stored) blocks only. BTYPE=01 (fixed
# Huffman) and BTYPE=10 (dynamic Huffman) return ERR_UNSUPPORTED_FORMAT
# and land in bites 2 and 3 of the 2.3.0 arc.

enum DeflateDec {
    DDEC_CTX_SIZE = 176;           # 22 i64 slots (+160 dict scratch, +168 dict_len at 2.3.6)

    # State-machine cursor (stored in ctx + 24).
    DDEC_STATE_HEADER = 0;         # need BFINAL (1) + BTYPE (2)
    DDEC_STATE_STORED_LEN = 1;     # byte-aligned; need LEN (16)
    DDEC_STATE_STORED_NLEN = 2;    # need NLEN (16) + XOR validate
    DDEC_STATE_STORED_DATA = 3;    # raw byte copy from chunk to dst
    DDEC_STATE_DONE = 4;           # BFINAL=1 block completed
    # Bite-2: fixed-Huffman block decode states.
    DDEC_STATE_DECODE_SYM = 5;     # decode next litlen symbol
    DDEC_STATE_LEN_EXTRA = 6;      # consuming length extra bits
    DDEC_STATE_DECODE_DIST = 7;    # decode dist symbol
    DDEC_STATE_DIST_EXTRA = 8;     # consuming dist extra bits + match-copy
    # Bite-3: dynamic-Huffman header parse states.
    DDEC_STATE_DYN_HLIT = 9;       # need 5 bits — HLIT
    DDEC_STATE_DYN_HDIST = 10;     # need 5 bits — HDIST
    DDEC_STATE_DYN_HCLEN = 11;     # need 4 bits — HCLEN
    DDEC_STATE_DYN_CL_LENS = 12;   # reading hclen × 3-bit cl_len values
    DDEC_STATE_DYN_AL_SYM = 13;    # decode next cl symbol in all_lens loop
    DDEC_STATE_DYN_AL_EXTRA = 14;  # read extras for repeat-16/17/18 + emit

    # Sentinel returned by _ddec_decode_huff when the bridge ran out
    # of bits before a Huffman symbol could be matched. Stored as the
    # positive magnitude; helper returns `0 - DDEC_NEED_MORE` to keep
    # the sign convention consistent with ERR_* codes. Magnitude is
    # well outside the 1..9 ERR_* range so it cannot collide.
    DDEC_NEED_MORE = 1024;
}

# Bite-3: dynamic-Huffman parse workspaces. Lazy-allocated globals
# (mutex-serialized just like the encoder's `_dh_ws` / `_dyn_*` slabs).
# These persist across `dec_write` calls because the dynamic-header
# parse can suspend at any chunk boundary inside the CL_LENS / AL_SYM
# / AL_EXTRA loops, and the partially-filled tables must survive until
# the next write resumes the state machine.
var _ddec_cl_order = 0;            # 19 i64 — RFC 1951 §3.2.7 permutation
var _ddec_cl_lens = 0;             # 19 i64 — code-length-code lengths
var _ddec_all_lens = 0;            # 584 i64 — litlen+dist code lengths

fn _ddec_alloc_dyn_ws(): i64 {
    if (_ddec_cl_lens == 0) {
        _ddec_cl_lens = _sankoch_alloc(152);
        if (_ddec_cl_lens == 0) { return 0 - ERR_OOM; }
    }
    if (_ddec_all_lens == 0) {
        _ddec_all_lens = _sankoch_alloc(4672);
        if (_ddec_all_lens == 0) { return 0 - ERR_OOM; }
    }
    if (_ddec_cl_order == 0) {
        _ddec_cl_order = _sankoch_alloc(152);
        if (_ddec_cl_order == 0) { return 0 - ERR_OOM; }
        store64(_ddec_cl_order +  0 * 8, 16);
        store64(_ddec_cl_order +  1 * 8, 17);
        store64(_ddec_cl_order +  2 * 8, 18);
        store64(_ddec_cl_order +  3 * 8,  0);
        store64(_ddec_cl_order +  4 * 8,  8);
        store64(_ddec_cl_order +  5 * 8,  7);
        store64(_ddec_cl_order +  6 * 8,  9);
        store64(_ddec_cl_order +  7 * 8,  6);
        store64(_ddec_cl_order +  8 * 8, 10);
        store64(_ddec_cl_order +  9 * 8,  5);
        store64(_ddec_cl_order + 10 * 8, 11);
        store64(_ddec_cl_order + 11 * 8,  4);
        store64(_ddec_cl_order + 12 * 8, 12);
        store64(_ddec_cl_order + 13 * 8,  3);
        store64(_ddec_cl_order + 14 * 8, 13);
        store64(_ddec_cl_order + 15 * 8,  2);
        store64(_ddec_cl_order + 16 * 8, 14);
        store64(_ddec_cl_order + 17 * 8,  1);
        store64(_ddec_cl_order + 18 * 8, 15);
    }
    return 0;
}

# ctx layout (all 8-byte slots):
#   +0   dst                 — output buffer pointer (caller-owned)
#   +8   dp                  — bytes emitted so far
#   +16  dst_cap             — output buffer capacity
#   +24  state               — DDEC_STATE_*
#   +32  hold                — bit accumulator (LSB-first)
#   +40  bits                — valid bits in hold (0..64)
#   +48  bfinal              — set on current block's BFINAL bit
#   +56  btype               — current block's BTYPE
#   +64  stored_len          — parsed LEN (retained for NLEN check)
#   +72  stored_remaining    — bytes left to copy in current stored block
#   +80  err                 — sticky error; 0 = no error
#   +88  cur_length          — bite-2: length being computed mid-symbol
#   +96  cur_distance        — bite-2: distance being computed mid-symbol
#   +104 cur_extra_count     — bite-2: extra bits to read in the next EXTRA state
#   +112 dyn_hlit            — bite-3: parsed HLIT + 257 (#litlen codes)
#   +120 dyn_hdist           — bite-3: parsed HDIST + 1 (#dist codes)
#   +128 dyn_hclen           — bite-3: parsed HCLEN + 4 (#cl-len codes)
#   +136 dyn_idx             — bite-3: doubles as cl_idx during CL_LENS and al_idx during AL_*
#   +144 dyn_prev            — bite-3: last code length emitted into all_lens (for repeat-16)
#   +152 dyn_rep_sym         — bite-3: pending cl symbol awaiting extras (16, 17, or 18)
#   +160 dict_scratch        — 2.3.6: heap copy of the preset dict (0 if none)
#   +168 dict_len            — 2.3.6: preset-dict length (0 = no dict; fast match-copy path)

fn _ddec_state(ctx): i64 { return load64(ctx + 24); }
fn _ddec_err(ctx): i64 { return load64(ctx + 80); }
fn _ddec_dp(ctx): i64 { return load64(ctx + 8); }

# Bridge-decode one Huffman symbol from ctx.hold. Drains the accumulator
# into a 4-byte stack buffer, points a stack-allocated 32-byte br struct
# at it, and calls the existing `_huff_decode` — no per-call alloc.
# Returns: a non-negative symbol on success (with ctx.hold/bits advanced
# by the consumed-bit count); `0 - DDEC_NEED_MORE` if the bridge ran
# out of bits before a code could be matched (ctx.hold/bits unchanged,
# caller waits for the next dec_write); or a real negative error
# (e.g. -ERR_INVALID_HUFFMAN) when the slow path exhausted HUFF_MAX_BITS
# without a match.
fn _ddec_decode_huff(ctx, fast, lengths, codes, num_symbols): i64 {
    var bits = load64(ctx + 40);
    if (bits == 0) { return 0 - DDEC_NEED_MORE; }

    var hold = load64(ctx + 32);
    var bridge_buf[4];
    store8(&bridge_buf + 0, hold & 255);
    store8(&bridge_buf + 1, (hold >> 8) & 255);
    store8(&bridge_buf + 2, (hold >> 16) & 255);
    store8(&bridge_buf + 3, (hold >> 24) & 255);
    var bridge_dlen = (bits + 7) >> 3;

    # Stack-allocated br: mimics br_init without alloc.
    var bridge_br[32];
    store64(&bridge_br + 0, &bridge_buf);
    store64(&bridge_br + 8, 0);
    store64(&bridge_br + 16, 0);
    store64(&bridge_br + 24, bridge_dlen);

    var sym = _huff_decode(&bridge_br, fast, lengths, codes, num_symbols);
    var br_bpos = load64(&bridge_br + 8);
    var br_bbit = load64(&bridge_br + 16);
    var consumed = br_bpos * 8 + br_bbit;

    if (sym < 0) {
        # Bridge exhausted before a match? Treat as need-more (atomic
        # rollback — caller's ctx.hold/bits remain unchanged, so the
        # next write resumes the attempt with more bits filled).
        if (consumed >= bits) { return 0 - DDEC_NEED_MORE; }
        return sym;
    }

    # A successful return may still be a phantom match — the bridge
    # buffer is byte-granular, so when bits < 8 the high pad bits of
    # the partial byte are zeros that the fast table or slow path can
    # accidentally walk into and "decode" a code shorter than expected.
    # Reject any decode that consumed past the valid bit count; the
    # caller will retry with more input.
    if (consumed > bits) { return 0 - DDEC_NEED_MORE; }

    store64(ctx + 32, hold >> consumed);
    store64(ctx + 40, bits - consumed);
    return sym;
}

# Poison ctx with a sticky error. State-machine drivers call this then
# return; subsequent dec_write calls short-circuit.
fn _ddec_poison(ctx, code): i64 {
    store64(ctx + 80, code);
    return code;
}

# Pull bytes from chunk[cp..end) into ctx.hold one at a time until
# ctx.bits >= n or the chunk is exhausted. Returns the updated cp;
# caller must re-check ctx.bits >= n to know whether the fill
# succeeded (false = chunk exhausted, wait for next write).
fn _ddec_fill(ctx, chunk, cp, end, n): i64 {
    while (load64(ctx + 40) < n) {
        if (cp >= end) { return cp; }
        var b = load8(chunk + cp);
        var hold = load64(ctx + 32);
        var bits = load64(ctx + 40);
        store64(ctx + 32, hold | (b << bits));
        store64(ctx + 40, bits + 8);
        cp = cp + 1;
    }
    return cp;
}

# Consume n bits from hold. Caller MUST ensure ctx.bits >= n via
# _ddec_fill first. Returns the consumed value.
fn _ddec_consume_bits(ctx, n): i64 {
    var hold = load64(ctx + 32);
    var bits = load64(ctx + 40);
    var mask = (1 << n) - 1;
    var v = hold & mask;
    store64(ctx + 32, hold >> n);
    store64(ctx + 40, bits - n);
    return v;
}

# Byte-align the accumulator (drop unused bits of the current byte).
# Called after the 3-bit block header before reading byte-aligned
# fields like the stored-block LEN.
fn _ddec_align(ctx): i64 {
    var bits = load64(ctx + 40);
    var drop = bits & 7;
    if (drop > 0) {
        var hold = load64(ctx + 32);
        store64(ctx + 32, hold >> drop);
        store64(ctx + 40, bits - drop);
    }
    return 0;
}

# Start a streaming DEFLATE decoder writing into dst[0..dst_cap).
# Returns a ctx pointer or 0 on alloc failure / invalid args.
# Takes _sankoch_mtx; released only on dec_finish or init alloc-fail.
fn deflate_dec_init(dst, dst_cap): i64 {
    if (dst_cap < 0) { return 0; }
    if (dst_cap > 0 && dst == 0) { return 0; }
    _sankoch_lock();
    var ctx = _sankoch_alloc(DDEC_CTX_SIZE);
    if (ctx == 0) { _sankoch_unlock(); return 0; }

    store64(ctx + 0, dst);
    store64(ctx + 8, 0);
    store64(ctx + 16, dst_cap);
    store64(ctx + 24, DDEC_STATE_HEADER);
    store64(ctx + 32, 0);
    store64(ctx + 40, 0);
    store64(ctx + 48, 0);
    store64(ctx + 56, 0);
    store64(ctx + 64, 0);
    store64(ctx + 72, 0);
    store64(ctx + 80, 0);
    store64(ctx + 88, 0);
    store64(ctx + 96, 0);
    store64(ctx + 104, 0);
    store64(ctx + 112, 0);
    store64(ctx + 120, 0);
    store64(ctx + 128, 0);
    store64(ctx + 136, 0);
    store64(ctx + 144, 0);
    store64(ctx + 152, 0);
    store64(ctx + 160, 0);   # dict scratch (none)
    store64(ctx + 168, 0);   # dict_len (0 → fast match-copy path)

    _deflate_init_tables();
    # 2.3.7: pre-build decode tables so the hot dec_write loop never
    # allocs; release the lock + return null on OOM.
    if (_huff_alloc_tables() < 0) { _sankoch_unlock(); return 0; }
    if (huff_build_fixed() < 0) { _sankoch_unlock(); return 0; }
    if (_ddec_alloc_dyn_ws() < 0) { _sankoch_unlock(); return 0; }
    return ctx;
}

# Start a streaming DEFLATE decoder pre-warmed with a preset dictionary
# (2.3.6 — used by FDICT zlib streaming). The dict is copied into a
# scratch buffer kept beside the ctx; the match-copy reads it for
# back-references that reach before the stream's own output (negative
# logical offset), so the decoded output still lands cleanly at dst[0]
# (unlike the batch path, which stages the dict in dst and shifts after).
# dict_len == 0 is exactly deflate_dec_init. Holds the mutex on success.
fn deflate_dec_init_dict(dst, dst_cap, dict, dict_len): i64 {
    if (dict_len < 0) { return 0; }
    if (dict_len > DEFLATE_WINDOW_SIZE) { return 0; }
    if (dict_len > 0 && dict == 0) { return 0; }

    var ctx = deflate_dec_init(dst, dst_cap);
    if (ctx == 0) { return 0; }
    if (dict_len > 0) {
        var scratch = _sankoch_alloc(dict_len);
        if (scratch == 0) { _sankoch_unlock(); return 0; }
        var i = 0;
        while (i < dict_len) {
            store8(scratch + i, load8(dict + i));
            i = i + 1;
        }
        store64(ctx + 160, scratch);
        store64(ctx + 168, dict_len);
    }
    return ctx;
}

# Reset a streaming DEFLATE decoder to start a fresh stream while
# KEEPING the output buffer and current write offset (dst / dp / dst_cap
# at +0/+8/+16). Used by the gzip streaming decoder for concatenated
# members (2.3.5): each member is an independent DEFLATE stream, but its
# decoded bytes append after the previous member's. Back-references in
# the new member can only reach its own already-emitted bytes (a valid
# DEFLATE distance never exceeds bytes-output-so-far in its stream), so
# the contiguous dst is safe. Does NOT touch the mutex — the caller
# still holds it across the whole multi-member decode.
fn deflate_dec_reset(ctx): i64 {
    store64(ctx + 24, DDEC_STATE_HEADER);
    store64(ctx + 32, 0);    # hold
    store64(ctx + 40, 0);    # bits
    store64(ctx + 48, 0);    # bfinal
    store64(ctx + 56, 0);    # btype
    store64(ctx + 64, 0);    # stored_len
    store64(ctx + 72, 0);    # stored_remaining
    store64(ctx + 80, 0);    # err
    store64(ctx + 88, 0);    # cur_length
    store64(ctx + 96, 0);    # cur_distance
    store64(ctx + 104, 0);   # cur_extra_count
    store64(ctx + 112, 0);   # dyn_hlit
    store64(ctx + 120, 0);   # dyn_hdist
    store64(ctx + 128, 0);   # dyn_hclen
    store64(ctx + 136, 0);   # dyn_idx
    store64(ctx + 144, 0);   # dyn_prev
    store64(ctx + 152, 0);   # dyn_rep_sym
    store64(ctx + 160, 0);   # dict scratch (a reset member carries no dict)
    store64(ctx + 168, 0);   # dict_len
    return 0;
}

# Feed `in_len` compressed bytes from input. Drives the state machine
# forward as far as the chunk allows; emits decoded bytes into the
# caller's dst buffer as they become available. Returns the number of
# input bytes consumed (0..in_len) on success, or a negative error on
# malformed input. Errors are sticky on the ctx — further calls
# short-circuit. When the BFINAL=1 EOB transitions the ctx into
# `DDEC_STATE_DONE`, callers can detect "stream completed mid-chunk"
# by checking `consumed < in_len`; bite-4's zlib/gzip wrappers rely
# on this to know where the trailer begins inside the same chunk.
fn deflate_dec_write(ctx, input, in_len): i64 {
    if (_ddec_err(ctx) < 0) { return _ddec_err(ctx); }
    if (in_len < 0) { return _ddec_poison(ctx, 0 - ERR_INVALID_INPUT); }
    if (in_len == 0) { return 0; }
    if (in_len > 0 && input == 0) {
        return _ddec_poison(ctx, 0 - ERR_INVALID_INPUT);
    }

    var cp = 0;
    var end = in_len;

    while (1) {
        var state = _ddec_state(ctx);

        if (state == DDEC_STATE_DONE) { return cp; }

        if (state == DDEC_STATE_HEADER) {
            cp = _ddec_fill(ctx, input, cp, end, 3);
            if (load64(ctx + 40) < 3) { return cp; }
            var hdr = _ddec_consume_bits(ctx, 3);
            store64(ctx + 48, hdr & 1);
            var btype = (hdr >> 1) & 3;
            store64(ctx + 56, btype);
            if (btype == 0) {
                _ddec_align(ctx);
                store64(ctx + 24, DDEC_STATE_STORED_LEN);
            } elif (btype == 1) {
                huff_build_fixed();
                store64(ctx + 24, DDEC_STATE_DECODE_SYM);
            } elif (btype == 2) {
                _ddec_alloc_dyn_ws();
                store64(ctx + 24, DDEC_STATE_DYN_HLIT);
            } else {
                return _ddec_poison(ctx, 0 - ERR_INVALID_BLOCK_TYPE);
            }
        } elif (state == DDEC_STATE_STORED_LEN) {
            cp = _ddec_fill(ctx, input, cp, end, 16);
            if (load64(ctx + 40) < 16) { return cp; }
            var len_val = _ddec_consume_bits(ctx, 16);
            store64(ctx + 64, len_val);
            store64(ctx + 72, len_val);
            store64(ctx + 24, DDEC_STATE_STORED_NLEN);
        } elif (state == DDEC_STATE_STORED_NLEN) {
            cp = _ddec_fill(ctx, input, cp, end, 16);
            if (load64(ctx + 40) < 16) { return cp; }
            var nlen = _ddec_consume_bits(ctx, 16);
            var stored = load64(ctx + 64);
            if ((stored ^ nlen) != 65535) {
                return _ddec_poison(ctx, 0 - ERR_CORRUPT_DATA);
            }
            var dp_now = load64(ctx + 8);
            if (dp_now + stored > load64(ctx + 16)) {
                return _ddec_poison(ctx, 0 - ERR_BUFFER_TOO_SMALL);
            }
            if (dp_now + stored > DECOMPRESS_MAX_OUTPUT) {
                return _ddec_poison(ctx, 0 - ERR_OUTPUT_LIMIT);
            }
            store64(ctx + 24, DDEC_STATE_STORED_DATA);
        } elif (state == DDEC_STATE_STORED_DATA) {
            # Stored blocks are byte-aligned after the 3-bit header was
            # aligned in STATE_HEADER; the two 16-bit LEN/NLEN reads
            # consume full bytes, so ctx.bits == 0 here and we copy
            # bytes directly from chunk to dst.
            var remaining = load64(ctx + 72);
            var avail = end - cp;
            var take = remaining;
            if (take > avail) { take = avail; }
            if (take > 0) {
                var dst_p = load64(ctx + 0);
                var dp_w = load64(ctx + 8);
                var i = 0;
                while (i < take) {
                    store8(dst_p + dp_w + i, load8(input + cp + i));
                    i = i + 1;
                }
                cp = cp + take;
                store64(ctx + 8, dp_w + take);
                store64(ctx + 72, remaining - take);
            }
            if (load64(ctx + 72) == 0) {
                if (load64(ctx + 48) == 1) {
                    store64(ctx + 24, DDEC_STATE_DONE);
                    return cp;
                } else {
                    store64(ctx + 24, DDEC_STATE_HEADER);
                }
            } else {
                return cp;
            }
        } elif (state == DDEC_STATE_DECODE_SYM) {
            # Pull enough bits to attempt a fast-table decode. Fixed
            # litlen codes are 7-9 bits; the helper handles short bridges
            # gracefully so we don't stall at the very end of a chunk.
            cp = _ddec_fill(ctx, input, cp, end, 9);
            var sym = _ddec_decode_huff(ctx, _huff_litlen_fast,
            _huff_litlen_lens, _huff_litlen_codes, _huff_litlen_count);
            if (sym == 0 - DDEC_NEED_MORE) { return cp; }
            if (sym < 0) { return _ddec_poison(ctx, sym); }

            if (sym < 256) {
                # Literal byte: emit directly.
                var dp_lit = load64(ctx + 8);
                if (dp_lit >= load64(ctx + 16)) {
                    return _ddec_poison(ctx, 0 - ERR_BUFFER_TOO_SMALL);
                }
                if (dp_lit >= DECOMPRESS_MAX_OUTPUT) {
                    return _ddec_poison(ctx, 0 - ERR_OUTPUT_LIMIT);
                }
                store8(load64(ctx + 0) + dp_lit, sym);
                store64(ctx + 8, dp_lit + 1);
            } elif (sym == 256) {
                # End of block.
                if (load64(ctx + 48) == 1) {
                    store64(ctx + 24, DDEC_STATE_DONE);
                    return cp;
                } else {
                    store64(ctx + 24, DDEC_STATE_HEADER);
                }
            } else {
                # Length code (sym is 257..285).
                var len_idx = sym - 257;
                if (len_idx >= 29) {
                    return _ddec_poison(ctx, 0 - ERR_CORRUPT_DATA);
                }
                store64(ctx + 88,
                load64(&_deflate_len_base + len_idx * 8));
                store64(ctx + 104,
                load64(&_deflate_len_extra + len_idx * 8));
                store64(ctx + 24, DDEC_STATE_LEN_EXTRA);
            }
        } elif (state == DDEC_STATE_LEN_EXTRA) {
            var extra_lc = load64(ctx + 104);
            if (extra_lc > 0) {
                cp = _ddec_fill(ctx, input, cp, end, extra_lc);
                if (load64(ctx + 40) < extra_lc) { return cp; }
                var eb = _ddec_consume_bits(ctx, extra_lc);
                store64(ctx + 88, load64(ctx + 88) + eb);
            }
            store64(ctx + 24, DDEC_STATE_DECODE_DIST);
        } elif (state == DDEC_STATE_DECODE_DIST) {
            # Fixed distance table: all 30 codes are exactly 5 bits, but
            # we still pull 9 to share the litlen fill threshold and let
            # the bridge consume only what the fast table prescribes.
            cp = _ddec_fill(ctx, input, cp, end, 9);
            var dsym = _ddec_decode_huff(ctx, _huff_dist_fast,
            _huff_dist_lens, _huff_dist_codes, _huff_dist_count);
            if (dsym == 0 - DDEC_NEED_MORE) { return cp; }
            if (dsym < 0) { return _ddec_poison(ctx, dsym); }
            if (dsym >= 30) {
                return _ddec_poison(ctx, 0 - ERR_CORRUPT_DATA);
            }
            store64(ctx + 96,
            load64(&_deflate_dist_base + dsym * 8));
            store64(ctx + 104,
            load64(&_deflate_dist_extra + dsym * 8));
            store64(ctx + 24, DDEC_STATE_DIST_EXTRA);
        } elif (state == DDEC_STATE_DIST_EXTRA) {
            var extra_dc = load64(ctx + 104);
            if (extra_dc > 0) {
                cp = _ddec_fill(ctx, input, cp, end, extra_dc);
                if (load64(ctx + 40) < extra_dc) { return cp; }
                var deb = _ddec_consume_bits(ctx, extra_dc);
                store64(ctx + 96, load64(ctx + 96) + deb);
            }
            # Match-copy: read `length_v` bytes starting `distance` back
            # from the current output position. The byte-at-a-time loop
            # is REQUIRED for correctness because matches can overlap
            # their own write region (distance < length — used for RLE,
            # e.g. distance=1 to repeat the previous byte).
            var length_v = load64(ctx + 88);
            var distance = load64(ctx + 96);
            var dp_match = load64(ctx + 8);
            var mc_dict_len = load64(ctx + 168);
            # A back-reference may reach into the preset dict (2.3.6):
            # the valid history is dp_match + dict_len, not just dp_match.
            if (distance > dp_match + mc_dict_len) {
                return _ddec_poison(ctx, 0 - ERR_MATCH_OUT_OF_RANGE);
            }
            if (dp_match + length_v > load64(ctx + 16)) {
                return _ddec_poison(ctx, 0 - ERR_BUFFER_TOO_SMALL);
            }
            if (dp_match + length_v > DECOMPRESS_MAX_OUTPUT) {
                return _ddec_poison(ctx, 0 - ERR_OUTPUT_LIMIT);
            }
            var dst_match = load64(ctx + 0);
            var src_match = dp_match - distance;
            var i_match = 0;
            if (mc_dict_len == 0) {
                # Fast path — no preset dict, source is always in dst.
                while (i_match < length_v) {
                    store8(dst_match + dp_match + i_match,
                    load8(dst_match + src_match + i_match));
                    i_match = i_match + 1;
                }
            } else {
                # Dict-aware: logical space is [dict][dst output]. A
                # negative source offset reads the dict scratch; once it
                # crosses 0 the bytes come from dst (including those just
                # written this loop, so self-overlapping matches work).
                var mc_dict_p = load64(ctx + 160);
                while (i_match < length_v) {
                    var spos = src_match + i_match;
                    var bval = 0;
                    if (spos < 0) {
                        bval = load8(mc_dict_p + mc_dict_len + spos);
                    } else {
                        bval = load8(dst_match + spos);
                    }
                    store8(dst_match + dp_match + i_match, bval);
                    i_match = i_match + 1;
                }
            }
            store64(ctx + 8, dp_match + length_v);
            store64(ctx + 24, DDEC_STATE_DECODE_SYM);
        } elif (state == DDEC_STATE_DYN_HLIT) {
            cp = _ddec_fill(ctx, input, cp, end, 5);
            if (load64(ctx + 40) < 5) { return cp; }
            var hlit_raw = _ddec_consume_bits(ctx, 5) + 257;
            # MED-01 fix (2.1.3): RFC 1951 §3.2.7 caps HLIT count at 286.
            if (hlit_raw > 286) {
                return _ddec_poison(ctx, 0 - ERR_CORRUPT_DATA);
            }
            store64(ctx + 112, hlit_raw);
            store64(ctx + 24, DDEC_STATE_DYN_HDIST);
        } elif (state == DDEC_STATE_DYN_HDIST) {
            cp = _ddec_fill(ctx, input, cp, end, 5);
            if (load64(ctx + 40) < 5) { return cp; }
            var hdist_raw = _ddec_consume_bits(ctx, 5) + 1;
            store64(ctx + 120, hdist_raw);
            store64(ctx + 24, DDEC_STATE_DYN_HCLEN);
        } elif (state == DDEC_STATE_DYN_HCLEN) {
            cp = _ddec_fill(ctx, input, cp, end, 4);
            if (load64(ctx + 40) < 4) { return cp; }
            var hclen_raw = _ddec_consume_bits(ctx, 4) + 4;
            store64(ctx + 128, hclen_raw);
            # Zero-init cl_lens — the cl_order permutation writes a
            # subset; positions outside that subset must stay 0.
            var zero_i = 0;
            while (zero_i < 19) {
                store64(_ddec_cl_lens + zero_i * 8, 0);
                zero_i = zero_i + 1;
            }
            store64(ctx + 136, 0);
            store64(ctx + 24, DDEC_STATE_DYN_CL_LENS);
        } elif (state == DDEC_STATE_DYN_CL_LENS) {
            # Read `hclen` 3-bit values, scattering into cl_lens[]
            # via the cl_order permutation. Persist dyn_idx after every
            # successful step so a chunk boundary anywhere in the
            # hclen-element loop resumes cleanly.
            var hclen_loop = load64(ctx + 128);
            var cl_pos = load64(ctx + 136);
            while (cl_pos < hclen_loop) {
                cp = _ddec_fill(ctx, input, cp, end, 3);
                if (load64(ctx + 40) < 3) {
                    store64(ctx + 136, cl_pos);
                    return cp;
                }
                var cl_val = _ddec_consume_bits(ctx, 3);
                var cl_perm = load64(_ddec_cl_order + cl_pos * 8);
                store64(_ddec_cl_lens + cl_perm * 8, cl_val);
                cl_pos = cl_pos + 1;
            }
            store64(ctx + 136, cl_pos);
            huff_build_cl(_ddec_cl_lens, 19);
            # Hand off to the all_lens loop. dyn_idx resets to 0 so it
            # can be reused as the all_lens write cursor; dyn_prev = 0
            # is the spec default for the "no prior length" case (so
            # repeat-16 as the very first cl symbol is correctly rejected
            # by the AL_EXTRA arm's al_idx == 0 guard).
            store64(ctx + 136, 0);
            store64(ctx + 144, 0);
            store64(ctx + 24, DDEC_STATE_DYN_AL_SYM);
        } elif (state == DDEC_STATE_DYN_AL_SYM) {
            var total_codes = load64(ctx + 112) + load64(ctx + 120);
            var al_pos = load64(ctx + 136);
            if (al_pos >= total_codes) {
                # all_lens fully populated — split into litlen + dist
                # tables and transition into the symbol-decode loop.
                huff_build_litlen(_ddec_all_lens, load64(ctx + 112));
                huff_build_dist(_ddec_all_lens
                + load64(ctx + 112) * 8, load64(ctx + 120));
                store64(ctx + 24, DDEC_STATE_DECODE_SYM);
            } else {
                cp = _ddec_fill(ctx, input, cp, end, 9);
                var cl_sym = _ddec_decode_huff(ctx, _huff_cl_fast,
                _huff_cl_lens, _huff_cl_codes, _huff_cl_count);
                if (cl_sym == 0 - DDEC_NEED_MORE) { return cp; }
                if (cl_sym < 0) { return _ddec_poison(ctx, cl_sym); }
                if (cl_sym <= 15) {
                    store64(_ddec_all_lens + al_pos * 8, cl_sym);
                    store64(ctx + 144, cl_sym);
                    store64(ctx + 136, al_pos + 1);
                } elif (cl_sym == 16) {
                    # Repeat-previous-3-6 — reject if no prior length.
                    if (al_pos == 0) {
                        return _ddec_poison(ctx, 0 - ERR_CORRUPT_DATA);
                    }
                    store64(ctx + 152, cl_sym);
                    store64(ctx + 24, DDEC_STATE_DYN_AL_EXTRA);
                } elif (cl_sym <= 18) {
                    store64(ctx + 152, cl_sym);
                    store64(ctx + 24, DDEC_STATE_DYN_AL_EXTRA);
                } else {
                    return _ddec_poison(ctx, 0 - ERR_INVALID_HUFFMAN);
                }
            }
        } elif (state == DDEC_STATE_DYN_AL_EXTRA) {
            var rep_sym = load64(ctx + 152);
            var rep_bits = 0;
            var rep_base = 0;
            if (rep_sym == 16) { rep_bits = 2; rep_base = 3; }
            elif (rep_sym == 17) { rep_bits = 3; rep_base = 3; }
            else { rep_bits = 7; rep_base = 11; }
            cp = _ddec_fill(ctx, input, cp, end, rep_bits);
            if (load64(ctx + 40) < rep_bits) { return cp; }
            var rep_count = _ddec_consume_bits(ctx, rep_bits) + rep_base;
            var val_write = 0;
            if (rep_sym == 16) {
                val_write = load64(ctx + 144);
            }
            var total_x = load64(ctx + 112) + load64(ctx + 120);
            var al_pos_w = load64(ctx + 136);
            var j_rep = 0;
            while (j_rep < rep_count) {
                if (al_pos_w >= total_x) {
                    return _ddec_poison(ctx, 0 - ERR_CORRUPT_DATA);
                }
                store64(_ddec_all_lens + al_pos_w * 8, val_write);
                al_pos_w = al_pos_w + 1;
                j_rep = j_rep + 1;
            }
            store64(ctx + 136, al_pos_w);
            store64(ctx + 144, val_write);
            store64(ctx + 24, DDEC_STATE_DYN_AL_SYM);
        } else {
            return _ddec_poison(ctx, 0 - ERR_INVALID_INPUT);
        }
    }

    return cp;
}

# Finalize the streaming decoder. Returns total bytes emitted into dst
# on success, or negative error. Releases _sankoch_mtx unconditionally.
# If the stream wasn't completed (BFINAL=1 block not yet reached),
# returns -ERR_CORRUPT_DATA (caller fed an incomplete stream).
fn deflate_dec_finish(ctx): i64 {
    var rc = 0;
    if (_ddec_err(ctx) < 0) {
        rc = _ddec_err(ctx);
    } elif (_ddec_state(ctx) != DDEC_STATE_DONE) {
        rc = 0 - ERR_CORRUPT_DATA;
    } else {
        rc = _ddec_dp(ctx);
    }
    _sankoch_unlock();
    return rc;
}

# ================================================================
# DEFLATE compression (Phase 3)
# ================================================================
#
# Uses fixed Huffman codes for simplicity and reasonable compression.
# The LZ77 match-finder handles finding back-references.

# Fixed Huffman code table for literals/lengths (pre-reversed for LSB-first output).
# We compute these once and cache them.
var _deflate_enc_fixed_built = 0;
var _deflate_enc_lit_codes = 0;  # heap: 288 * 8
var _deflate_enc_lit_lens = 0;   # heap: 288 * 8

fn _deflate_build_enc_fixed(): i64 {
    if (_deflate_enc_fixed_built == 1) { return 0; }
    if (_deflate_enc_lit_codes == 0) {
        _deflate_enc_lit_codes = _sankoch_alloc(2304);
        if (_deflate_enc_lit_codes == 0) { return 0 - ERR_OOM; }
        _deflate_enc_lit_lens = _sankoch_alloc(2304);
        if (_deflate_enc_lit_lens == 0) { return 0 - ERR_OOM; }
    }
    var i = 0;
    while (i <= 143) {
        store64(_deflate_enc_lit_lens +i * 8, 8);
        i = i + 1;
    }
    while (i <= 255) {
        store64(_deflate_enc_lit_lens +i * 8, 9);
        i = i + 1;
    }
    while (i <= 279) {
        store64(_deflate_enc_lit_lens +i * 8, 7);
        i = i + 1;
    }
    while (i <= 287) {
        store64(_deflate_enc_lit_lens +i * 8, 8);
        i = i + 1;
    }

    # Build canonical codes (same algorithm as _huff_build step 1-3)
    var bl_count[128];
    i = 0;
    while (i < 16) { store64(&bl_count + i * 8, 0); i = i + 1; }
    i = 0;
    while (i < 288) {
        var len = load64(_deflate_enc_lit_lens +i * 8);
        store64(&bl_count + len * 8, load64(&bl_count + len * 8) + 1);
        i = i + 1;
    }

    var next_code[128];
    store64(&next_code, 0);
    store64(&next_code + 8, 0);
    var code = 0;
    var bits = 1;
    while (bits <= 15) {
        code = (code + load64(&bl_count + (bits - 1) * 8)) << 1;
        store64(&next_code + bits * 8, code);
        bits = bits + 1;
    }

    i = 0;
    while (i < 288) {
        var len = load64(_deflate_enc_lit_lens +i * 8);
        if (len > 0) {
            var c = load64(&next_code + len * 8);
            store64(&next_code + len * 8, c + 1);
            # Reverse bits for LSB-first output
            var rev = 0;
            var b = 0;
            var tmp = c;
            while (b < len) {
                rev = (rev << 1) | (tmp & 1);
                tmp = tmp >> 1;
                b = b + 1;
            }
            store64(_deflate_enc_lit_codes +i * 8, rev);
        } else {
            store64(_deflate_enc_lit_codes +i * 8, 0);
        }
        i = i + 1;
    }

    _deflate_enc_fixed_built = 1;
    return 0;
}

# Fixed distance codes: all 5 bits, codes 0-29.
var _deflate_enc_dist_codes = 0;  # heap: 30 * 8

fn _deflate_build_enc_dist(): i64 {
    if (_deflate_enc_dist_codes == 0) {
        _deflate_enc_dist_codes = _sankoch_alloc(240);
        if (_deflate_enc_dist_codes == 0) { return 0 - ERR_OOM; }
    }
    var i = 0;
    while (i < 30) {
        # Reverse 5 bits of i
        var rev = 0;
        var v = i;
        var b = 0;
        while (b < 5) {
            rev = (rev << 1) | (v & 1);
            v = v >> 1;
            b = b + 1;
        }
        store64(_deflate_enc_dist_codes +i * 8, rev);
        i = i + 1;
    }
    return 0;
}

# Direct lookup table: length (3-258) → code index (0-28).
# 256 entries covers lengths 3-258 (index by length - 3).
var _deflate_len_lookup = 0;  # heap: 256 * 8
var _deflate_len_lookup_built = 0;

fn _deflate_build_len_lookup(): i64 {
    if (_deflate_len_lookup_built == 1) { return 0; }
    if (_deflate_len_lookup == 0) {
        _deflate_len_lookup = _sankoch_alloc(2048);
        if (_deflate_len_lookup == 0) { return 0 - ERR_OOM; }
    }
    _deflate_init_tables();
    # Length-code bases are monotonically increasing, so walk both arrays
    # in lockstep: ~285 comparisons instead of 256 × 29 = ~7424.
    var code = 0;
    var len = 3;
    while (len <= 258) {
        while (code < 28 && len >= load64(&_deflate_len_base + (code + 1) * 8)) {
            code = code + 1;
        }
        store64(_deflate_len_lookup + (len - 3) * 8, code);
        len = len + 1;
    }
    _deflate_len_lookup_built = 1;
    return 0;
}

# Direct lookup table: distance (1-32768) → code index (0-29).
# Too large for a flat table, so use a tiered approach:
# distances 1-256 → flat table, distances 257+ → binary search on 15 entries.
var _deflate_dist_lookup = 0;  # heap: 256 * 8
var _deflate_dist_lookup_built = 0;

fn _deflate_build_dist_lookup(): i64 {
    if (_deflate_dist_lookup_built == 1) { return 0; }
    if (_deflate_dist_lookup == 0) {
        _deflate_dist_lookup = _sankoch_alloc(2048);
        if (_deflate_dist_lookup == 0) { return 0 - ERR_OOM; }
    }
    _deflate_init_tables();
    # Distance-code bases are monotonically increasing. For d ≤ 256 the
    # highest reachable code is 15 (base[16]=257), so the code pointer
    # never advances past that within this loop.
    var code = 0;
    var d = 1;
    while (d <= 256) {
        while (code < 29 && d >= load64(&_deflate_dist_base + (code + 1) * 8)) {
            code = code + 1;
        }
        store64(_deflate_dist_lookup + (d - 1) * 8, code);
        d = d + 1;
    }
    _deflate_dist_lookup_built = 1;
    return 0;
}

fn _deflate_len_code(length): i64 {
    _deflate_build_len_lookup();
    return load64(_deflate_len_lookup +(length - 3) * 8);
}

fn _deflate_dist_code(dist): i64 {
    if (dist <= 256) {
        _deflate_build_dist_lookup();
        return load64(_deflate_dist_lookup +(dist - 1) * 8);
    }
    # Distances > 256: binary search on the upper 15 codes (15-29)
    _deflate_init_tables();
    var lo = 14;
    var hi = 29;
    while (lo < hi) {
        var mid = (lo + hi + 1) >> 1;
        if (dist >= load64(&_deflate_dist_base + mid * 8)) {
            lo = mid;
        } else {
            hi = mid - 1;
        }
    }
    return lo;
}

# Write a literal byte using fixed Huffman codes.
fn _deflate_write_literal(bw, byte): i64 {
    var code = load64(_deflate_enc_lit_codes +byte * 8);
    var len = load64(_deflate_enc_lit_lens +byte * 8);
    return bw_write(bw, code, len);
}

# Write end-of-block symbol (256).
fn _deflate_write_eob(bw): i64 {
    var code = load64(_deflate_enc_lit_codes +256 * 8);
    var len = load64(_deflate_enc_lit_lens +256 * 8);
    return bw_write(bw, code, len);
}

# Write a length/distance pair using fixed Huffman codes.
fn _deflate_write_match(bw, length, distance): i64 {
    # Encode length
    var li = _deflate_len_code(length);
    var sym = li + 257;
    var code = load64(_deflate_enc_lit_codes +sym * 8);
    var clen = load64(_deflate_enc_lit_lens +sym * 8);
    var rc = bw_write(bw, code, clen);
    if (rc < 0) { return rc; }

    # Extra bits for length
    var extra = load64(&_deflate_len_extra + li * 8);
    if (extra > 0) {
        var base = load64(&_deflate_len_base + li * 8);
        rc = bw_write(bw, length - base, extra);
        if (rc < 0) { return rc; }
    }

    # Encode distance (fixed: 5 bits, reversed)
    var di = _deflate_dist_code(distance);
    var dcode = load64(_deflate_enc_dist_codes +di * 8);
    rc = bw_write(bw, dcode, 5);
    if (rc < 0) { return rc; }

    # Extra bits for distance
    var dextra = load64(&_deflate_dist_extra + di * 8);
    if (dextra > 0) {
        var dbase = load64(&_deflate_dist_base + di * 8);
        rc = bw_write(bw, distance - dbase, dextra);
        if (rc < 0) { return rc; }
    }

    return 0;
}

# ================================================================
# Dynamic Huffman block encoding
# ================================================================

# Symbol buffer for two-pass encoding.
# Each entry: low 16 bits = symbol (literal 0-255, or length code 257-285, or 256=EOB)
# For length/distance pairs: stored as two consecutive entries:
#   entry 1: length symbol (257-285) | (extra_bits << 16) | (extra_val << 24)
#   entry 2: distance symbol (0-29) | (extra_bits << 16) | (extra_val << 24)
# We pack: symbol in bits 0-15, extra_count in bits 16-19, extra_value in bits 20-51

var _dyn_sym_buf = 0;      # heap-allocated symbol buffer
var _dyn_sym_count = 0;
enum DynEnc {
    DYN_SYM_MAX = 16384;  # max symbols we buffer
}

fn _dyn_pack(sym, extra_bits, extra_val): i64 {
    return (sym & 65535) | ((extra_bits & 15) << 16) | ((extra_val & 4294967295) << 20);
}

fn _dyn_sym(packed): i64 { return packed & 65535; }
fn _dyn_extra_bits(packed): i64 { return (packed >> 16) & 15; }
fn _dyn_extra_val(packed): i64 { return (packed >> 20) & 4294967295; }

# Write the dynamic Huffman block header (RFC 1951 Section 3.2.7).
# lit_lens: code lengths for literal/length alphabet (hlit entries)
# dist_lens: code lengths for distance alphabet (hdist entries)
# hlit: number of literal/length codes (257-286)
# hdist: number of distance codes (1-32)
# Pre-allocated workspace for dynamic header writing
var _dh_ws = 0;

fn _deflate_write_dynamic_header(bw, lit_lens, hlit, dist_lens, hdist): i64 {
    # Heap workspace: all_lens(2560) + cl_syms(2560) + cl_extra(2560) + cl_ebits(2560)
    #   + cl_freqs(152) + cl_lens_opt(152) + cl_codes_opt(152) + cl_order(152) = 10848
    if (_dh_ws == 0) {
        _dh_ws = _sankoch_alloc(10848);
        if (_dh_ws == 0) { return 0 - ERR_OOM; }
    }
    var all_lens = _dh_ws;
    var total = hlit + hdist;
    var i = 0;
    while (i < hlit) {
        store64(all_lens + i * 8, load64(lit_lens + i * 8));
        i = i + 1;
    }
    i = 0;
    while (i < hdist) {
        store64(all_lens + (hlit + i) * 8, load64(dist_lens + i * 8));
        i = i + 1;
    }

    # RLE-encode the combined lengths into a symbol stream
    # Symbols: 0-15 = literal length, 16 = repeat prev, 17 = repeat 0 short, 18 = repeat 0 long
    var cl_syms = _dh_ws + 2560;
    var cl_extra = _dh_ws + 5120;
    var cl_ebits = _dh_ws + 7680;
    var cl_count = 0;

    i = 0;
    while (i < total) {
        var val = load64(all_lens + i * 8);

        # Count run of same value
        var run = 1;
        while (i + run < total && load64(all_lens + (i + run) * 8) == val) {
            run = run + 1;
        }

        if (val == 0) {
            while (run > 0) {
                if (run >= 11) {
                    var r = run;
                    if (r > 138) { r = 138; }
                    store64(cl_syms + cl_count * 8, 18);
                    store64(cl_extra + cl_count * 8, r - 11);
                    store64(cl_ebits + cl_count * 8, 7);
                    cl_count = cl_count + 1;
                    run = run - r;
                    i = i + r;
                } elif (run >= 3) {
                    var r = run;
                    if (r > 10) { r = 10; }
                    store64(cl_syms + cl_count * 8, 17);
                    store64(cl_extra + cl_count * 8, r - 3);
                    store64(cl_ebits + cl_count * 8, 3);
                    cl_count = cl_count + 1;
                    run = run - r;
                    i = i + r;
                } else {
                    store64(cl_syms + cl_count * 8, 0);
                    store64(cl_extra + cl_count * 8, 0);
                    store64(cl_ebits + cl_count * 8, 0);
                    cl_count = cl_count + 1;
                    run = run - 1;
                    i = i + 1;
                }
            }
        } else {
            # Emit the value itself first
            store64(cl_syms + cl_count * 8, val);
            store64(cl_extra + cl_count * 8, 0);
            store64(cl_ebits + cl_count * 8, 0);
            cl_count = cl_count + 1;
            run = run - 1;
            i = i + 1;

            # Repeat with code 16
            while (run > 0) {
                if (run >= 3) {
                    var r = run;
                    if (r > 6) { r = 6; }
                    store64(cl_syms + cl_count * 8, 16);
                    store64(cl_extra + cl_count * 8, r - 3);
                    store64(cl_ebits + cl_count * 8, 2);
                    cl_count = cl_count + 1;
                    run = run - r;
                    i = i + r;
                } else {
                    store64(cl_syms + cl_count * 8, val);
                    store64(cl_extra + cl_count * 8, 0);
                    store64(cl_ebits + cl_count * 8, 0);
                    cl_count = cl_count + 1;
                    run = run - 1;
                    i = i + 1;
                }
            }
        }
    }

    # Count frequencies of code-length symbols (0-18)
    # Use heap workspace at offset 10240 for cl_freqs/cl_lens_opt/cl_codes_opt/cl_order
    var cl_freqs = _dh_ws + 10240;
    var cl_lens_opt = _dh_ws + 10240 + 152;
    var cl_codes_opt = _dh_ws + 10240 + 304;
    var cl_order = _dh_ws + 10240 + 456;
    i = 0;
    while (i < 19) { store64(cl_freqs + i * 8, 0); i = i + 1; }
    i = 0;
    while (i < cl_count) {
        var s = load64(cl_syms + i * 8);
        store64(cl_freqs + s * 8, load64(cl_freqs + s * 8) + 1);
        i = i + 1;
    }

    # Build code-length Huffman tree. Max code length is 7 bits per
    # RFC 1951 §3.2.7 (header writes each cl_len in a 3-bit field, so any
    # length above 7 would alias to a different value on the decoder side).
    huff_compute_lengths(cl_freqs, 19, cl_lens_opt, 2, 7);

    # Build pre-reversed encoder codes for the code-length alphabet —
    # codes are LSB-first so the symbol-emit loop can call bw_write
    # directly without a per-symbol reversal.
    huff_build_enc_codes(cl_lens_opt, 19, cl_codes_opt);

    # Determine HCLEN: how many code-length codes to transmit
    # Order: 16, 17, 18, 0, 8, 7, 9, 6, 10, 5, 11, 4, 12, 3, 13, 2, 14, 1, 15
    store64(cl_order + 0 * 8, 16); store64(cl_order + 1 * 8, 17);
    store64(cl_order + 2 * 8, 18); store64(cl_order + 3 * 8, 0);
    store64(cl_order + 4 * 8, 8);  store64(cl_order + 5 * 8, 7);
    store64(cl_order + 6 * 8, 9);  store64(cl_order + 7 * 8, 6);
    store64(cl_order + 8 * 8, 10); store64(cl_order + 9 * 8, 5);
    store64(cl_order + 10 * 8, 11); store64(cl_order + 11 * 8, 4);
    store64(cl_order + 12 * 8, 12); store64(cl_order + 13 * 8, 3);
    store64(cl_order + 14 * 8, 13); store64(cl_order + 15 * 8, 2);
    store64(cl_order + 16 * 8, 14); store64(cl_order + 17 * 8, 1);
    store64(cl_order + 18 * 8, 15);

    var hclen = 19;
    while (hclen > 4) {
        var idx = load64(cl_order + (hclen - 1) * 8);
        if (load64(cl_lens_opt + idx * 8) != 0) { break; }
        hclen = hclen - 1;
    }

    # Write header fields
    var rc = bw_write(bw, hlit - 257, 5);
    if (rc < 0) { return rc; }
    rc = bw_write(bw, hdist - 1, 5);
    if (rc < 0) { return rc; }
    rc = bw_write(bw, hclen - 4, 4);
    if (rc < 0) { return rc; }

    # Write code-length code lengths (3 bits each, in spec order)
    i = 0;
    while (i < hclen) {
        var idx = load64(cl_order + i * 8);
        rc = bw_write(bw, load64(cl_lens_opt + idx * 8), 3);
        if (rc < 0) { return rc; }
        i = i + 1;
    }

    # Write the RLE-encoded code lengths using the code-length Huffman codes.
    # cl_codes_opt holds pre-reversed codes (huff_build_enc_codes), so the
    # symbol-emit hot loop is a single bw_write per symbol — no per-symbol
    # bit reversal.
    i = 0;
    while (i < cl_count) {
        var s = load64(cl_syms + i * 8);
        var clen = load64(cl_lens_opt + s * 8);
        var code = load64(cl_codes_opt + s * 8);
        rc = bw_write(bw, code, clen);
        if (rc < 0) { return rc; }

        # Write extra bits if any
        var eb = load64(cl_ebits + i * 8);
        if (eb > 0) {
            rc = bw_write(bw, load64(cl_extra + i * 8), eb);
            if (rc < 0) { return rc; }
        }
        i = i + 1;
    }

    return 0;
}

# Encode buffered symbols using given code tables.
fn _deflate_write_syms_dynamic(bw, lit_lens, lit_codes, dist_lens, dist_codes): i64 {
    # lit_codes / dist_codes hold pre-reversed (LSB-first) codes built
    # by huff_build_enc_codes — emit is a single bw_write per code.
    var i = 0;
    while (i < _dyn_sym_count) {
        var packed = load64(_dyn_sym_buf + i * 8);
        var sym = _dyn_sym(packed);

        if (sym < 256 || sym == 256) {
            # Literal or EOB — use litlen codes
            var clen = load64(lit_lens + sym * 8);
            var code = load64(lit_codes + sym * 8);
            var rc = bw_write(bw, code, clen);
            if (rc < 0) { return rc; }
            i = i + 1;
        } else {
            # Length symbol (257-285) + extra, followed by distance symbol + extra
            var clen = load64(lit_lens + sym * 8);
            var code = load64(lit_codes + sym * 8);
            var rc = bw_write(bw, code, clen);
            if (rc < 0) { return rc; }
            # Length extra bits
            var eb = _dyn_extra_bits(packed);
            if (eb > 0) {
                rc = bw_write(bw, _dyn_extra_val(packed), eb);
                if (rc < 0) { return rc; }
            }

            # Distance symbol is next entry
            i = i + 1;
            packed = load64(_dyn_sym_buf + i * 8);
            var dsym = _dyn_sym(packed);
            clen = load64(dist_lens + dsym * 8);
            code = load64(dist_codes + dsym * 8);
            rc = bw_write(bw, code, clen);
            if (rc < 0) { return rc; }
            eb = _dyn_extra_bits(packed);
            if (eb > 0) {
                rc = bw_write(bw, _dyn_extra_val(packed), eb);
                if (rc < 0) { return rc; }
            }
            i = i + 1;
        }
    }
    return 0;
}

# Outer chunk size. Caps the range a single invocation of the per-block
# compressor sees; the dynamic path further subdivides adaptively based
# on symbol-buffer fill (see _deflate_compress_dynamic_block). 1MB keeps
# the fixed-Huffman path efficient (single tree per 1MB segment) without
# pathological memory pressure on large inputs.
enum DeflateBlock {
    DEFLATE_BLOCK_SIZE = 1048576;  # 1MB — outer chunker step
}

# Compress data into a raw DEFLATE stream.
fn deflate_compress(src, src_len, dst, dst_cap): i64 {
    _sankoch_lock();
    var r = _deflate_compress_level_inner(src, src_len, dst, dst_cap, 1);
    _sankoch_unlock();
    return r;
}

# Compress with explicit level (1=fast, 6=default, 9=best).
# Levels 1-3 use fixed Huffman, levels 4-9 use dynamic Huffman.
# Inputs larger than 32K are split into multiple blocks.
fn deflate_compress_level(src, src_len, dst, dst_cap, level): i64 {
    _sankoch_lock();
    var r = _deflate_compress_level_inner(src, src_len, dst, dst_cap, level);
    _sankoch_unlock();
    return r;
}

# Internal unlocked entry. Callers must already hold _sankoch_mtx.
fn _deflate_compress_level_inner(src, src_len, dst, dst_cap, level): i64 {
    _deflate_init_tables();
    lz77_set_level(level);
    if (lz77_init() < 0) { return 0 - ERR_OOM; }

    var bw = bw_init(dst, dst_cap);
    if (bw == 0) { return 0 - ERR_OOM; }
    var sp = 0;

    while (sp < src_len || sp == 0) {
        var block_end = sp + DEFLATE_BLOCK_SIZE;
        if (block_end > src_len) { block_end = src_len; }
        var bfinal = 0;
        if (block_end >= src_len) { bfinal = 1; }

        var rc = 0;
        if (level >= 4) {
            rc = _deflate_compress_dynamic_block(bw, src, src_len, sp, block_end, bfinal);
        } else {
            rc = _deflate_compress_fixed_block(bw, src, src_len, sp, block_end, bfinal);
        }
        if (rc < 0) { return rc; }
        sp = block_end;
        if (bfinal == 1) { break; }
    }

    return bw_finish(bw);
}

# Emit one fixed Huffman block covering src[sp_start..sp_end).
# LZ77 match-finder operates on the full src (back-refs can span blocks).
fn _deflate_compress_fixed_block(bw, src, src_len, sp_start, sp_end, bfinal): i64 {
    if (_deflate_build_enc_fixed() < 0) { return 0 - ERR_OOM; }
    if (_deflate_build_enc_dist() < 0) { return 0 - ERR_OOM; }
    # Pre-build the len/dist lookups so the hot `_deflate_len_code` /
    # `_deflate_dist_code` calls during symbol writing never alloc.
    if (_deflate_build_len_lookup() < 0) { return 0 - ERR_OOM; }
    if (_deflate_build_dist_lookup() < 0) { return 0 - ERR_OOM; }

    var rc = bw_write(bw, bfinal, 1);
    if (rc < 0) { return rc; }
    rc = bw_write(bw, 1, 2);      # BTYPE = 01
    if (rc < 0) { return rc; }

    var sp = sp_start;
    var prev_match = 0;
    var prev_dist = 0;
    var use_lazy = (_lz77_chain_depth >= 16);

    while (sp < sp_end) {
        var mresult = 0;
        if (sp + LZ77_MIN_MATCH <= src_len) {
            mresult = _lz77_find_match(src, src_len, sp);
            _lz77_insert(src, sp);
        }

        var cur_len = 0;
        var cur_dist = 0;
        if (mresult > 0) {
            cur_len = mresult & 65535;
            cur_dist = mresult >> 16;
        }

        if (prev_match > 0) {
            if (use_lazy == 1 && cur_len > prev_match) {
                rc = _deflate_write_literal(bw, load8(src + sp - 1));
                if (rc < 0) { return rc; }
                prev_match = cur_len;
                prev_dist = cur_dist;
                sp = sp + 1;
                continue;
            }
            rc = _deflate_write_match(bw, prev_match, prev_dist);
            if (rc < 0) { return rc; }
            var k = 1;
            while (k < prev_match) {
                if (sp - 1 + k + LZ77_MIN_MATCH <= src_len) {
                    _lz77_insert(src, sp - 1 + k);
                }
                k = k + 1;
            }
            sp = sp - 1 + prev_match;
            prev_match = 0;
            continue;
        }

        if (cur_len > 0) {
            if (use_lazy == 1) {
                prev_match = cur_len;
                prev_dist = cur_dist;
                sp = sp + 1;
                continue;
            }
            rc = _deflate_write_match(bw, cur_len, cur_dist);
            if (rc < 0) { return rc; }
            var k = 1;
            while (k < cur_len) {
                if (sp + k + LZ77_MIN_MATCH <= src_len) {
                    _lz77_insert(src, sp + k);
                }
                k = k + 1;
            }
            sp = sp + cur_len;
            continue;
        }

        rc = _deflate_write_literal(bw, load8(src + sp));
        if (rc < 0) { return rc; }
        sp = sp + 1;
    }

    if (prev_match > 0) {
        rc = _deflate_write_match(bw, prev_match, prev_dist);
        if (rc < 0) { return rc; }
    }

    rc = _deflate_write_eob(bw);
    if (rc < 0) { return rc; }
    return 0;
}

# Dynamic Huffman compression (better ratio, levels 4-9).
# Two-pass: 1) collect LZ77 symbols, 2) build optimal trees, 3) encode.
# Pre-allocated workspace for dynamic compress
var _dyn_lit_freq = 0;
var _dyn_dist_freq = 0;
var _dyn_opt_lit_lens = 0;
var _dyn_opt_dist_lens = 0;
var _dyn_opt_lit_codes = 0;
var _dyn_opt_dist_codes = 0;
var _dyn_lit_fast_tmp = 0;
var _dyn_dist_fast_tmp = 0;

fn _deflate_alloc_dynamic_ws(): i64 {
    if (_dyn_sym_buf == 0) {
        _dyn_sym_buf = _sankoch_alloc(DYN_SYM_MAX * 8);
        if (_dyn_sym_buf == 0) { return 0 - ERR_OOM; }
    }
    # This block allocs 8 slabs under one guard (_dyn_lit_freq). On any
    # mid-block OOM, zero the guard so a later retry re-enters and
    # re-allocs the whole set instead of skipping it with null ptrs.
    if (_dyn_lit_freq == 0) {
        _dyn_lit_freq = _sankoch_alloc(2304);
        if (_dyn_lit_freq == 0) { return 0 - ERR_OOM; }
        _dyn_dist_freq = _sankoch_alloc(240);
        if (_dyn_dist_freq == 0) { _dyn_lit_freq = 0; return 0 - ERR_OOM; }
        _dyn_opt_lit_lens = _sankoch_alloc(2304);
        if (_dyn_opt_lit_lens == 0) { _dyn_lit_freq = 0; return 0 - ERR_OOM; }
        _dyn_opt_dist_lens = _sankoch_alloc(240);
        if (_dyn_opt_dist_lens == 0) { _dyn_lit_freq = 0; return 0 - ERR_OOM; }
        _dyn_opt_lit_codes = _sankoch_alloc(2304);
        if (_dyn_opt_lit_codes == 0) { _dyn_lit_freq = 0; return 0 - ERR_OOM; }
        _dyn_opt_dist_codes = _sankoch_alloc(240);
        if (_dyn_opt_dist_codes == 0) { _dyn_lit_freq = 0; return 0 - ERR_OOM; }
        _dyn_lit_fast_tmp = _sankoch_alloc(4096);
        if (_dyn_lit_fast_tmp == 0) { _dyn_lit_freq = 0; return 0 - ERR_OOM; }
        _dyn_dist_fast_tmp = _sankoch_alloc(4096);
        if (_dyn_dist_fast_tmp == 0) { _dyn_lit_freq = 0; return 0 - ERR_OOM; }
    }
    return 0;
}

# Clear dynamic-path per-sub-block state: symbol count + freq tables.
# Must be called before collecting symbols for a fresh sub-block.
fn _dyn_reset(): i64 {
    _dyn_sym_count = 0;
    var i = 0;
    while (i < 288) { store64(_dyn_lit_freq + i * 8, 0); i = i + 1; }
    i = 0;
    while (i < 30) { store64(_dyn_dist_freq + i * 8, 0); i = i + 1; }
    return 0;
}

# Process one LZ77 step at position sp in src: try to find a match; if
# found emit a (length, distance) pair and advance sp past the match,
# otherwise emit the literal at src[sp] and advance by 1. Updates
# _dyn_sym_buf, _dyn_sym_count, and the freq tables. Returns new sp.
#
# Caller must ensure _dyn_sym_count + 2 <= DYN_SYM_MAX before calling
# (a single step writes at most 2 symbol slots — length + distance for
# a match, or 1 for a literal).
fn _dyn_collect_at(src, src_len, sp): i64 {
    if (sp + LZ77_MIN_MATCH <= src_len) {
        var mresult = _lz77_find_match(src, src_len, sp);
        _lz77_insert(src, sp);

        if (mresult > 0) {
            var mlen = mresult & 65535;
            var mdist = mresult >> 16;

            if (mlen >= LZ77_MIN_MATCH) {
                var li = _deflate_len_code(mlen);
                var lsym = li + 257;
                var lextra = load64(&_deflate_len_extra + li * 8);
                var lbase = load64(&_deflate_len_base + li * 8);
                store64(_dyn_sym_buf + _dyn_sym_count * 8,
                _dyn_pack(lsym, lextra, mlen - lbase));
                _dyn_sym_count = _dyn_sym_count + 1;
                store64(_dyn_lit_freq + lsym * 8, load64(_dyn_lit_freq + lsym * 8) + 1);

                var di = _deflate_dist_code(mdist);
                var dextra = load64(&_deflate_dist_extra + di * 8);
                var dbase = load64(&_deflate_dist_base + di * 8);
                store64(_dyn_sym_buf + _dyn_sym_count * 8,
                _dyn_pack(di, dextra, mdist - dbase));
                _dyn_sym_count = _dyn_sym_count + 1;
                store64(_dyn_dist_freq + di * 8, load64(_dyn_dist_freq + di * 8) + 1);

                var k = 1;
                while (k < mlen) {
                    if (sp + k + LZ77_MIN_MATCH <= src_len) {
                        _lz77_insert(src, sp + k);
                    }
                    k = k + 1;
                }
                return sp + mlen;
            }
        }
    }

    var byte = load8(src + sp);
    store64(_dyn_sym_buf + _dyn_sym_count * 8, _dyn_pack(byte, 0, 0));
    _dyn_sym_count = _dyn_sym_count + 1;
    store64(_dyn_lit_freq + byte * 8, load64(_dyn_lit_freq + byte * 8) + 1);
    return sp + 1;
}

# Build Huffman trees from the current freq tables and emit one dynamic
# sub-block (BFINAL=bfinal, BTYPE=10) carrying the buffered symbols.
# Appends the EOB symbol before emitting. Returns 0 or negative error.
fn _dyn_flush_subblock(bw, bfinal): i64 {
    # Append EOB
    store64(_dyn_sym_buf + _dyn_sym_count * 8, _dyn_pack(256, 0, 0));
    _dyn_sym_count = _dyn_sym_count + 1;
    store64(_dyn_lit_freq + 256 * 8, load64(_dyn_lit_freq + 256 * 8) + 1);

    # Build optimal trees for this sub-block's freqs
    huff_compute_lengths(_dyn_lit_freq, 286, _dyn_opt_lit_lens, 257, 15);
    var hlit = 286;
    while (hlit > 257 && load64(_dyn_opt_lit_lens + (hlit - 1) * 8) == 0) {
        hlit = hlit - 1;
    }

    var has_dist = 0;
    var i = 0;
    while (i < 30) {
        if (load64(_dyn_dist_freq + i * 8) > 0) { has_dist = 1; }
        i = i + 1;
    }
    if (has_dist == 0) { store64(_dyn_dist_freq, 1); }
    huff_compute_lengths(_dyn_dist_freq, 30, _dyn_opt_dist_lens, 1, 15);

    var hdist = 30;
    while (hdist > 1 && load64(_dyn_opt_dist_lens + (hdist - 1) * 8) == 0) {
        hdist = hdist - 1;
    }

    # Pre-reversed encoder codes — emit-time loop in _deflate_write_syms_dynamic
    # is one bw_write per symbol with no per-symbol bit reversal.
    huff_build_enc_codes(_dyn_opt_lit_lens, hlit, _dyn_opt_lit_codes);
    huff_build_enc_codes(_dyn_opt_dist_lens, hdist, _dyn_opt_dist_codes);

    # Emit sub-block
    var rc = bw_write(bw, bfinal, 1);
    if (rc < 0) { return rc; }
    rc = bw_write(bw, 2, 2);      # BTYPE = 10 (dynamic)
    if (rc < 0) { return rc; }

    rc = _deflate_write_dynamic_header(bw, _dyn_opt_lit_lens, hlit,
    _dyn_opt_dist_lens, hdist);
    if (rc < 0) { return rc; }

    return _deflate_write_syms_dynamic(bw, _dyn_opt_lit_lens, _dyn_opt_lit_codes,
    _dyn_opt_dist_lens, _dyn_opt_dist_codes);
}

# Emit one or more dynamic Huffman sub-blocks covering src[sp_start..sp_end).
#
# Adaptive block splitting: collection stops when the shared symbol buffer
# is nearly full, and a fresh sub-block begins — each sub-block ships its
# own optimal Huffman tree tuned to its own symbol frequencies. Keeps
# low-locality inputs (>~16K LZ77 symbols per chunk) on the dynamic path
# instead of falling back to the universal fixed tree.
#
# BFINAL only fires on the very last sub-block, and only if the caller
# requested it.
fn _deflate_compress_dynamic_block(bw, src, src_len, sp_start, sp_end, bfinal): i64 {
    if (_deflate_alloc_dynamic_ws() < 0) { return 0 - ERR_OOM; }
    # Pre-build the len/dist lookups (hot `_deflate_len_code` /
    # `_deflate_dist_code` during symbol writing must never alloc) and the
    # optimal-Huffman workspace (deep `huff_compute_lengths` calls).
    if (_deflate_build_len_lookup() < 0) { return 0 - ERR_OOM; }
    if (_deflate_build_dist_lookup() < 0) { return 0 - ERR_OOM; }
    if (_huff_ensure_hcl_ws() < 0) { return 0 - ERR_OOM; }

    var sp = sp_start;
    while (1) {
        _dyn_reset();

        # Collect symbols into the buffer. Leave 3 slots of slack so one
        # more step (2 slots for a match) plus the EOB (1 slot) always fit.
        while (sp < sp_end && _dyn_sym_count < DYN_SYM_MAX - 3) {
            sp = _dyn_collect_at(src, src_len, sp);
        }

        # BFINAL only on the last sub-block, and only if caller requested.
        var sub_bfinal = 0;
        var done = 0;
        if (sp >= sp_end) {
            done = 1;
            if (bfinal == 1) { sub_bfinal = 1; }
        }

        var rc = _dyn_flush_subblock(bw, sub_bfinal);
        if (rc < 0) { return rc; }
        if (done == 1) { return 0; }
    }
    return 0;
}

# ================================================================
# Incremental DEFLATE encoder (v1.7.0)
# ================================================================
#
# Usage:
#   var ctx = deflate_enc_init(level, dst, dst_cap);
#   deflate_enc_write(ctx, chunk1, len1);
#   deflate_enc_write(ctx, chunk2, len2);
#   ...
#   var total = deflate_enc_finish(ctx);
#
# The encoder owns a 64KB sliding window. Input is copied into the
# window on every enc_write; the LZ77 match-finder consumes bytes up
# to `wptr - LZ77_MAX_MATCH` so full matches can be found across
# write calls. When wptr reaches WINDOW_CAP, the last 32KB slides to
# the front and LZ77 hash tables are rebased accordingly.
#
# BFINAL choreography: enc_write always emits sub-blocks with
# BFINAL=0. enc_finish emits a final sub-block with BFINAL=1 (dynamic
# path) or a trivial 5-byte BFINAL=1 stored block (fixed path) to
# mark end-of-stream.
#
# Fixed path (levels 1-3): one continuous BFINAL=0 fixed block carries
# the whole stream's symbols, followed by a BFINAL=1 stored-LEN=0
# trailer on finish. Lazy matching from the batch fixed path is
# disabled here — streaming fixed is strictly greedy.
#
# Dynamic path (levels 4-9): adaptive sub-block flushing from 1.5.0
# applies — sub-blocks flush when _dyn_sym_count fills, each carrying
# its own optimal Huffman tree.
#
# Thread-safety: enc_init takes _sankoch_mtx; enc_finish releases it.
# A live encoder blocks other compress/decompress calls on the same
# thread (single-threaded contract) or serializes concurrent encoders
# (multi-threaded).

enum DeflateEnc {
    DENC_WINDOW_CAP = 65536;   # 64 KB — 32 KB lookback + 32 KB new
    DENC_SLIDE_RETAIN = 32768; # Bytes retained after each slide
    DENC_LOOKAHEAD = 258;      # Must equal LZ77_MAX_MATCH
    DENC_CTX_SIZE = 96;        # Byte size of ctx header (layout below)

    # ctx state
    DENC_STATE_INIT = 0;
    DENC_STATE_WRITING = 1;
    DENC_STATE_DONE = 2;
}

# ctx layout (all 8-byte slots):
#   +0   level
#   +8   state
#   +16  err                 — sticky error; 0 if OK
#   +24  bw                  — bitwriter context ptr
#   +32  total_in            — cumulative bytes written by caller
#   +40  window              — heap buffer, DENC_WINDOW_CAP bytes
#   +48  wptr                — next write offset within window
#   +56  cptr                — match-finder consume offset
#   +64  fixed_header_written — 1 after the streaming fixed block header is emitted
#   +72  is_dynamic          — 1 if level >= 4 (dynamic path), else 0

fn _denc_err(ctx): i64 { return load64(ctx + 16); }
fn _denc_bw(ctx): i64 { return load64(ctx + 24); }
fn _denc_window(ctx): i64 { return load64(ctx + 40); }
fn _denc_wptr(ctx): i64 { return load64(ctx + 48); }
fn _denc_cptr(ctx): i64 { return load64(ctx + 56); }
fn _denc_is_dynamic(ctx): i64 { return load64(ctx + 72); }

# Start a new streaming DEFLATE encoder. Takes _sankoch_mtx for the
# encoder's lifetime; returns ctx pointer, or 0 on allocation failure.
fn deflate_enc_init(level, dst, dst_cap): i64 {
    return deflate_enc_init_dict(level, dst, dst_cap, 0, 0);
}

# Start a streaming DEFLATE encoder with a preset dictionary preloaded
# into the LZ77 sliding window. Mirrors `deflate_decompress_dict` on
# the encode side: matches against `dict[0..dict_len)` will be emitted
# as length/distance back-references whose distance reaches into the
# dictionary territory. The dictionary itself is NOT emitted in the
# stream — the decoder must apply the same dictionary via
# `deflate_decompress_dict` (or `zlib_decompress_dict` if wrapped in a
# zlib stream with FDICT set; the zlib path also verifies DICTID).
#
# Constraints (returns 0 on violation, no lock taken):
#   - dict_len < 0                       — invalid
#   - dict_len > DEFLATE_WINDOW_SIZE     — exceeds 32K window
#   - dict_len > 0 && dict == 0          — null pointer with non-zero len
#
# dict_len == 0 is equivalent to `deflate_enc_init` (no preload).
fn deflate_enc_init_dict(level, dst, dst_cap, dict, dict_len): i64 {
    if (dict_len < 0) { return 0; }
    if (dict_len > DEFLATE_WINDOW_SIZE) { return 0; }
    if (dict_len > 0 && dict == 0) { return 0; }

    _sankoch_lock();
    # 2.2.1: defensive alloc-failure handling (INFO-01). Each
    # constructor below returns 0 on OOM; we release the mutex and
    # propagate 0 upward so the caller doesn't trip on a NULL ctx
    # while the lock is held. Lazy-global allocs reachable from
    # `_deflate_init_tables` / `lz77_init` / `_deflate_alloc_dynamic_ws`
    # are NOT covered here — those paths still abort on OOM. Tracked
    # as a future hardening item; the 2.2.1 audit appendix lists the
    # specific sites.
    var ctx = _sankoch_alloc(DENC_CTX_SIZE);
    if (ctx == 0) { _sankoch_unlock(); return 0; }
    var window = _sankoch_alloc(DENC_WINDOW_CAP);
    if (window == 0) { _sankoch_unlock(); return 0; }
    var bw = bw_init(dst, dst_cap);
    if (bw == 0) { _sankoch_unlock(); return 0; }

    store64(ctx, level);
    store64(ctx + 8, DENC_STATE_INIT);
    store64(ctx + 16, 0);
    store64(ctx + 24, bw);
    store64(ctx + 32, 0);
    store64(ctx + 40, window);
    store64(ctx + 48, 0);
    store64(ctx + 56, 0);
    store64(ctx + 64, 0);
    if (level >= 4) { store64(ctx + 72, 1); } else { store64(ctx + 72, 0); }

    _deflate_init_tables();
    lz77_set_level(level);
    if (lz77_init() < 0) { _sankoch_unlock(); return 0; }
    # Pre-build the len/dist lookups so the streaming symbol emitters
    # never alloc on the hot path.
    if (_deflate_build_len_lookup() < 0) { _sankoch_unlock(); return 0; }
    if (_deflate_build_dist_lookup() < 0) { _sankoch_unlock(); return 0; }
    if (level >= 4) {
        if (_deflate_alloc_dynamic_ws() < 0) { _sankoch_unlock(); return 0; }
        if (_huff_ensure_hcl_ws() < 0) { _sankoch_unlock(); return 0; }
        _dyn_reset();
    } else {
        if (_deflate_build_enc_fixed() < 0) { _sankoch_unlock(); return 0; }
        if (_deflate_build_enc_dist() < 0) { _sankoch_unlock(); return 0; }
    }

    # Preload the dictionary at the start of the window. wptr and cptr
    # both advance past `dict_len` so subsequent `enc_write` traffic
    # only emits symbols for caller-supplied input — never for the
    # dictionary bytes themselves. Every 3-byte position in the dict
    # is hash-seeded so matches inside future input can reach into
    # dictionary territory. Distances stay correct because LZ77's
    # absolute-position bookkeeping treats the dict prefix as part of
    # the same coordinate space; the existing `chain < base` slide
    # check naturally evicts dict entries once they fall out of the
    # 32K back-reference range.
    if (dict_len > 0) {
        var i = 0;
        while (i < dict_len) {
            store8(window + i, load8(dict + i));
            i = i + 1;
        }
        store64(ctx + 48, dict_len);
        store64(ctx + 56, dict_len);
        var j = 0;
        while (j + LZ77_MIN_MATCH <= dict_len) {
            _lz77_insert(window, j);
            j = j + 1;
        }
    }

    return ctx;
}

# Append `in_len` bytes from `input` to the encoder's window, processing
# them through LZ77 and emitting sub-blocks as the symbol buffer fills.
# Keeps the last DENC_LOOKAHEAD bytes unconsumed so matches can extend
# into subsequent writes. Returns 0 or negative error (ctx poisoned).
fn deflate_enc_write(ctx, input, in_len): i64 {
    if (_denc_err(ctx) < 0) { return _denc_err(ctx); }
    if (in_len <= 0) { return 0; }

    var window = _denc_window(ctx);
    var bw = _denc_bw(ctx);
    var is_dyn = _denc_is_dynamic(ctx);
    var wptr = _denc_wptr(ctx);
    var cptr = _denc_cptr(ctx);

    store64(ctx + 8, DENC_STATE_WRITING);
    store64(ctx + 32, load64(ctx + 32) + in_len);

    var in_pos = 0;
    while (in_pos < in_len) {
        # If the window is too full to hold more input, slide the last
        # DENC_SLIDE_RETAIN bytes down and rebase LZ77 hash tables.
        if (wptr + (in_len - in_pos) > DENC_WINDOW_CAP) {
            # Before sliding, ensure cptr has consumed as much as it
            # reasonably can — up to wptr - LOOKAHEAD.
            var process_end = wptr;
            if (process_end > DENC_LOOKAHEAD) { process_end = wptr - DENC_LOOKAHEAD; }
            else { process_end = 0; }
            var rc = _denc_consume(ctx, cptr, process_end);
            if (rc < 0) { return rc; }
            cptr = load64(ctx + 56);

            var delta = wptr - DENC_SLIDE_RETAIN;
            if (delta < 0) { delta = 0; }
            if (delta > 0) {
                var i = 0;
                while (i < DENC_SLIDE_RETAIN) {
                    store8(window + i, load8(window + delta + i));
                    i = i + 1;
                }
                wptr = DENC_SLIDE_RETAIN;
                cptr = cptr - delta;
                if (cptr < 0) { cptr = 0; }
                store64(ctx + 48, wptr);
                store64(ctx + 56, cptr);
                lz77_rebase(delta);
            }
        }

        # Copy a chunk of input into the window.
        var room = DENC_WINDOW_CAP - wptr;
        var take = in_len - in_pos;
        if (take > room) { take = room; }
        var i = 0;
        while (i < take) {
            store8(window + wptr + i, load8(input + in_pos + i));
            i = i + 1;
        }
        wptr = wptr + take;
        in_pos = in_pos + take;
        store64(ctx + 48, wptr);

        # Process bytes through LZ77 up to wptr - LOOKAHEAD.
        var process_end = wptr;
        if (process_end > DENC_LOOKAHEAD) { process_end = wptr - DENC_LOOKAHEAD; }
        else { process_end = 0; }
        var rc = _denc_consume(ctx, cptr, process_end);
        if (rc < 0) { return rc; }
        cptr = load64(ctx + 56);
    }
    return 0;
}

# Helper: consume window[cptr..end) through the active path, emitting
# sub-blocks (dynamic) or literals/matches (fixed) as they're produced.
# Updates ctx.cptr. Returns 0 or negative error (stored into ctx.err).
fn _denc_consume(ctx, cptr, end): i64 {
    if (cptr >= end) { return 0; }
    var window = _denc_window(ctx);
    var wptr = _denc_wptr(ctx);
    var bw = _denc_bw(ctx);
    var is_dyn = _denc_is_dynamic(ctx);

    if (is_dyn == 1) {
        while (cptr < end) {
            if (_dyn_sym_count >= DYN_SYM_MAX - 3) {
                var rc = _dyn_flush_subblock(bw, 0);
                if (rc < 0) { store64(ctx + 16, rc); return rc; }
                _dyn_reset();
            }
            cptr = _dyn_collect_at(window, wptr, cptr);
        }
    } else {
        # Fixed path: emit the block header once; then emit literals /
        # matches directly through the bitwriter.
        if (load64(ctx + 64) == 0) {
            var rc = bw_write(bw, 0, 1);      # BFINAL=0
            if (rc < 0) { store64(ctx + 16, rc); return rc; }
            rc = bw_write(bw, 1, 2);          # BTYPE=01 (fixed)
            if (rc < 0) { store64(ctx + 16, rc); return rc; }
            store64(ctx + 64, 1);
        }
        while (cptr < end) {
            var mresult = 0;
            if (cptr + LZ77_MIN_MATCH <= wptr) {
                mresult = _lz77_find_match(window, wptr, cptr);
                _lz77_insert(window, cptr);
            }
            if (mresult > 0) {
                var mlen = mresult & 65535;
                var mdist = mresult >> 16;
                if (mlen >= LZ77_MIN_MATCH) {
                    var rc = _deflate_write_match(bw, mlen, mdist);
                    if (rc < 0) { store64(ctx + 16, rc); return rc; }
                    var k = 1;
                    while (k < mlen) {
                        if (cptr + k + LZ77_MIN_MATCH <= wptr) {
                            _lz77_insert(window, cptr + k);
                        }
                        k = k + 1;
                    }
                    cptr = cptr + mlen;
                    continue;
                }
            }
            var rc = _deflate_write_literal(bw, load8(window + cptr));
            if (rc < 0) { store64(ctx + 16, rc); return rc; }
            cptr = cptr + 1;
        }
    }
    store64(ctx + 56, cptr);
    return 0;
}

# Flush remaining buffered input, emit end-of-stream marker, release
# _sankoch_mtx, and return total bytes written to dst (or neg error).
fn deflate_enc_finish(ctx): i64 {
    if (_denc_err(ctx) < 0) {
        _sankoch_unlock();
        return _denc_err(ctx);
    }
    var bw = _denc_bw(ctx);
    var window = _denc_window(ctx);
    var wptr = _denc_wptr(ctx);
    var cptr = _denc_cptr(ctx);
    var is_dyn = _denc_is_dynamic(ctx);

    # Consume remaining window bytes (no lookahead reservation).
    var rc = _denc_consume(ctx, cptr, wptr);
    if (rc < 0) {
        _sankoch_unlock();
        return rc;
    }

    if (is_dyn == 1) {
        # Dynamic: last sub-block is BFINAL=1. If the symbol buffer is
        # empty (total_in was a multiple of whatever flushed the last
        # sub-block), emit an empty-body BFINAL=1 sub-block (just EOB).
        rc = _dyn_flush_subblock(bw, 1);
        if (rc < 0) { _sankoch_unlock(); return rc; }
    } else {
        # Fixed: close the BFINAL=0 block with EOB, then append a
        # trivial BFINAL=1 stored block with LEN=0 as the trailer.
        if (load64(ctx + 64) == 0) {
            # No data was ever written; emit a single empty BFINAL=1
            # stored block. bfinal=1, btype=00, pad, LEN=0, NLEN=0xFFFF.
            rc = bw_write(bw, 1, 1);        # BFINAL=1
            if (rc < 0) { _sankoch_unlock(); return rc; }
            rc = bw_write(bw, 0, 2);        # BTYPE=00 stored
            if (rc < 0) { _sankoch_unlock(); return rc; }
        } else {
            # Close the open fixed block with EOB.
            rc = _deflate_write_eob(bw);
            if (rc < 0) { _sankoch_unlock(); return rc; }

            # BFINAL=1 stored-LEN=0 trailer.
            rc = bw_write(bw, 1, 1);        # BFINAL=1
            if (rc < 0) { _sankoch_unlock(); return rc; }
            rc = bw_write(bw, 0, 2);        # BTYPE=00
            if (rc < 0) { _sankoch_unlock(); return rc; }
        }
        bw_align(bw);                        # pad to byte
        # LEN = 0 (LE u16), NLEN = 0xFFFF (LE u16)
        rc = bw_write_byte(bw, 0); if (rc < 0) { _sankoch_unlock(); return rc; }
        rc = bw_write_byte(bw, 0); if (rc < 0) { _sankoch_unlock(); return rc; }
        rc = bw_write_byte(bw, 255); if (rc < 0) { _sankoch_unlock(); return rc; }
        rc = bw_write_byte(bw, 255); if (rc < 0) { _sankoch_unlock(); return rc; }
    }

    store64(ctx + 8, DENC_STATE_DONE);
    var total = bw_finish(bw);
    _sankoch_unlock();
    return total;
}

# --- zlib.cyr ---

# sankoch — zlib wrapper (RFC 1950)
#
# zlib = 2-byte header + DEFLATE stream + 4-byte Adler-32 checksum.
#
# Header (2 bytes):
#   CMF byte: bits 0-3 = CM (compression method, must be 8 = deflate)
#             bits 4-7 = CINFO (window size = 2^(CINFO+8), max 15 = 32K)
#   FLG byte: bits 0-4 = FCHECK (makes CMF*256+FLG divisible by 31)
#             bit 5    = FDICT (preset dictionary)
#             bits 6-7 = FLEVEL (compression level hint, informational only)
#
# Trailer: 4-byte big-endian Adler-32 of uncompressed data.
#
# This is what git objects use.

# Decompress a zlib stream (no preset dictionary).
fn zlib_decompress(src, src_len, dst, dst_cap): i64 {
    _sankoch_lock();
    var r = _zlib_decompress_dict_inner(src, src_len, dst, dst_cap, 0, 0);
    _sankoch_unlock();
    return r;
}

# Decompress a zlib stream with an optional preset dictionary.
# If the stream has FDICT=1, dict/dict_len must provide the dictionary
# whose Adler-32 matches the stream's DICTID. Pass dict=0, dict_len=0
# for streams without FDICT.
fn zlib_decompress_dict(src, src_len, dst, dst_cap, dict, dict_len): i64 {
    _sankoch_lock();
    var r = _zlib_decompress_dict_inner(src, src_len, dst, dst_cap, dict, dict_len);
    _sankoch_unlock();
    return r;
}

# Internal unlocked entry. Callers must already hold _sankoch_mtx.
fn _zlib_decompress_dict_inner(src, src_len, dst, dst_cap, dict, dict_len): i64 {
    if (src_len < 6) { return 0 - ERR_INVALID_INPUT; }

    # Parse header
    var cmf = load8(src);
    var flg = load8(src + 1);

    # Verify checksum: (CMF*256 + FLG) % 31 == 0
    if (((cmf * 256 + flg) % 31) != 0) { return 0 - ERR_CORRUPT_DATA; }

    # CM must be 8 (deflate)
    if ((cmf & 15) != 8) { return 0 - ERR_UNSUPPORTED_FORMAT; }

    # LOW-1 fix (2.1.3): RFC 1950 §2.2 — CINFO (high 4 bits of CMF) is
    # log2(window) - 8. Values > 7 (window > 32K) are not allowed in
    # this version of the spec; reject explicitly. We only support
    # CINFO ≤ 7 — DEFLATE's window is fixed at 32K (DEFLATE_WINDOW_SIZE).
    if (((cmf >> 4) & 15) > 7) { return 0 - ERR_UNSUPPORTED_FORMAT; }

    var hdr_len = 2;

    # Handle FDICT (preset dictionary)
    if ((flg & 32) != 0) {
        if (hdr_len + 4 > src_len) { return 0 - ERR_CORRUPT_DATA; }
        if (dict == 0 || dict_len == 0) { return 0 - ERR_INVALID_INPUT; }
        # Verify dictionary ID (Adler-32 of the dictionary, big-endian)
        var stored_dict_id = (load8(src + 2) << 24) | (load8(src + 3) << 16) |
        (load8(src + 4) << 8) | load8(src + 5);
        var computed_dict_id = adler32(dict, dict_len);
        if (stored_dict_id != computed_dict_id) { return 0 - ERR_CHECKSUM_MISMATCH; }
        hdr_len = 6;
    }

    # Decompress DEFLATE payload
    var deflate_src = src + hdr_len;
    var deflate_len = src_len - hdr_len;
    var dlen = 0;
    if (dict_len > 0) {
        dlen = _deflate_decompress_dict_inner(deflate_src, deflate_len, dst, dst_cap, dict, dict_len);
    } else {
        dlen = _deflate_decompress_inner(deflate_src, deflate_len, dst, dst_cap);
    }
    if (dlen < 0) { return dlen; }

    # Trailer: 4-byte big-endian Adler-32
    var consumed = deflate_bytes_consumed();
    var trailer = deflate_src + consumed;
    if (hdr_len + consumed + 4 > src_len) { return 0 - ERR_CORRUPT_DATA; }
    var stored_adler = (load8(trailer) << 24) | (load8(trailer + 1) << 16) |
    (load8(trailer + 2) << 8) | load8(trailer + 3);
    var computed_adler = adler32(dst, dlen);
    if (stored_adler != computed_adler) { return 0 - ERR_CHECKSUM_MISMATCH; }

    return dlen;
}

# Compress data into a zlib stream.
fn zlib_compress(src, src_len, dst, dst_cap): i64 {
    _sankoch_lock();
    var r = _zlib_compress_level_inner(src, src_len, dst, dst_cap, 6);
    _sankoch_unlock();
    return r;
}

# Streaming zlib encoder (v1.7.0; preset-dictionary support v2.2.0).
# Wraps deflate_enc_* with the 2-byte zlib header (or 6-byte
# header + DICTID for FDICT streams) and a trailing big-endian
# Adler-32 of the uncompressed input.
#
# Layout (32 bytes):
#   +0:  inner deflate_enc ctx pointer
#   +8:  adler32 incremental state pointer
#   +16: dst pointer (for appending the Adler-32 trailer)
#   +24: header_len — 2 (no FDICT) or 6 (FDICT, includes DICTID).
#        Determines where the trailer starts on finish.
fn zlib_enc_init(level, dst, dst_cap): i64 {
    return zlib_enc_init_dict(level, dst, dst_cap, 0, 0);
}

# Streaming zlib encoder with a preset dictionary. Sets FDICT in the
# zlib header, emits the 4-byte big-endian DICTID (Adler-32 of the
# dictionary), and preloads the underlying DEFLATE encoder's window
# with the dict bytes. Decoder must invoke `zlib_decompress_dict`
# with the same dictionary; DICTID mismatch is rejected with
# ERR_CHECKSUM_MISMATCH.
#
# Returns 0 on dict-validation failure or alloc failure (mirrors
# `zlib_enc_init` posture). dict_len == 0 is equivalent to the
# non-dict path (no FDICT in the header).
fn zlib_enc_init_dict(level, dst, dst_cap, dict, dict_len): i64 {
    if (dict_len < 0) { return 0; }
    if (dict_len > DEFLATE_WINDOW_SIZE) { return 0; }
    if (dict_len > 0 && dict == 0) { return 0; }

    var hdr_len = 2;
    if (dict_len > 0) { hdr_len = 6; }
    if (dst_cap < hdr_len + 4) { return 0; }   # hdr + 4-byte trailer

    if (dict_len > 0) {
        # CMF=0x78 (CM=8, CINFO=7 → 32K window), FLG=0x20 (FDICT=1,
        # FCHECK=0). Verify: (0x78*256 + 0x20) = 30752, 30752 % 31 == 0.
        store8(dst, 120);
        store8(dst + 1, 32);
        # 4-byte big-endian DICTID = Adler-32 of the dictionary.
        var did = adler32(dict, dict_len);
        store8(dst + 2, (did >> 24) & 255);
        store8(dst + 3, (did >> 16) & 255);
        store8(dst + 4, (did >> 8) & 255);
        store8(dst + 5, did & 255);
    } else {
        # CMF=0x78, FLG=0x01 — (0x78*256 + 1) % 31 == 0.
        store8(dst, 120);
        store8(dst + 1, 1);
    }

    var inner = deflate_enc_init_dict(level, dst + hdr_len, dst_cap - hdr_len - 4, dict, dict_len);
    # If `inner == 0`, deflate_enc_init_dict either rejected args
    # (no lock taken) or hit OOM (lock already released by its
    # 2.2.1 defensive path). Either way, propagate cleanly.
    if (inner == 0) { return 0; }

    # 2.2.1: at this point the lock IS held (taken inside
    # deflate_enc_init_dict). Any failure below must release it.
    var ctx = _sankoch_alloc(32);
    if (ctx == 0) { _sankoch_unlock(); return 0; }
    var adler_st = adler32_init();
    if (adler_st == 0) { _sankoch_unlock(); return 0; }
    store64(ctx, inner);
    store64(ctx + 8, adler_st);
    store64(ctx + 16, dst);
    store64(ctx + 24, hdr_len);
    return ctx;
}

fn zlib_enc_write(ctx, input, in_len): i64 {
    if (in_len <= 0) { return 0; }
    adler32_update(load64(ctx + 8), input, in_len);
    return deflate_enc_write(load64(ctx), input, in_len);
}

fn zlib_enc_finish(ctx): i64 {
    var clen = deflate_enc_finish(load64(ctx));
    if (clen < 0) { return clen; }

    var dst = load64(ctx + 16);
    var hdr_len = load64(ctx + 24);
    var a = adler32_final(load64(ctx + 8));
    var pos = hdr_len + clen;
    store8(dst + pos, (a >> 24) & 255);
    store8(dst + pos + 1, (a >> 16) & 255);
    store8(dst + pos + 2, (a >> 8) & 255);
    store8(dst + pos + 3, a & 255);
    return pos + 4;   # hdr_len + clen deflate + 4 adler32
}

# Streaming zlib decoder (bite-4 of the 2.3.0 arc).
#
# Wraps deflate_dec_* with the 2-byte zlib header parse and a trailing
# big-endian Adler-32 verification. Mutex held from `zlib_dec_init` to
# `zlib_dec_finish` (the lock is taken by the inner deflate_dec_init
# and released by deflate_dec_finish — same pattern as the encoder).
#
# FDICT (2.3.6): FDICT-bearing streams ARE supported when the caller
# provides the matching dictionary via `zlib_dec_init_dict`. The inner
# DEFLATE decoder is pre-warmed (`deflate_dec_init_dict`), the 4-byte
# DICTID is validated against `adler32(dict)`, and decode proceeds. An
# FDICT stream decoded through the no-dict `zlib_dec_init` is rejected
# with `-ERR_UNSUPPORTED_FORMAT` (no dictionary to satisfy it).
#
# ctx layout (12 i64 slots = 96 bytes):
#   +0   inner_dctx       — pointer to deflate_dec ctx (also owns dst)
#   +8   state            — ZDEC_STATE_*
#   +16  adler_state      — adler32 incremental state pointer (output only)
#   +24  hdr_idx          — bytes parsed in header (0..2) / DICTID (0..4)
#   +32  hdr_cmf          — parsed CMF byte
#   +40  hdr_flg          — parsed FLG byte
#   +48  trailer_idx      — bytes parsed in the 4-byte trailer (0..4)
#   +56  trailer_value    — big-endian Adler-32 from the trailer
#   +64  err              — sticky error; 0 = OK
#   +72  dict             — caller's preset-dict pointer (0 if none)
#   +80  dict_len         — preset-dict length (0 if none)
#   +88  dictid_acc       — big-endian DICTID accumulated from the stream

enum ZlibDec {
    ZDEC_CTX_SIZE = 96;
    ZDEC_STATE_HEADER = 0;
    ZDEC_STATE_DEFLATE = 1;
    ZDEC_STATE_TRAILER = 2;
    ZDEC_STATE_DONE = 3;
    ZDEC_STATE_DICTID = 4;     # 4-byte big-endian DICTID (FDICT streams)
}

fn _zdec_poison(ctx, code): i64 {
    store64(ctx + 64, code);
    return code;
}

# Start a streaming zlib decoder. Output written into dst[0..dst_cap).
# Takes _sankoch_mtx (via the inner deflate_dec_init); released only
# on zlib_dec_finish or on init alloc-failure.
fn zlib_dec_init(dst, dst_cap): i64 {
    return zlib_dec_init_dict(dst, dst_cap, 0, 0);
}

# Streaming zlib decoder with a preset dictionary (2.3.6). Required to
# decode FDICT streams: dict/dict_len must be the dictionary whose
# Adler-32 matches the stream's DICTID. dict_len == 0 is exactly
# `zlib_dec_init` (no dict; FDICT streams then rejected).
fn zlib_dec_init_dict(dst, dst_cap, dict, dict_len): i64 {
    if (dict_len < 0) { return 0; }
    if (dict_len > DEFLATE_WINDOW_SIZE) { return 0; }
    if (dict_len > 0 && dict == 0) { return 0; }

    var inner = deflate_dec_init_dict(dst, dst_cap, dict, dict_len);
    if (inner == 0) { return 0; }

    var ctx = _sankoch_alloc(ZDEC_CTX_SIZE);
    if (ctx == 0) { _sankoch_unlock(); return 0; }
    var adler_st = adler32_init();
    if (adler_st == 0) { _sankoch_unlock(); return 0; }

    store64(ctx + 0, inner);
    store64(ctx + 8, ZDEC_STATE_HEADER);
    store64(ctx + 16, adler_st);
    store64(ctx + 24, 0);
    store64(ctx + 32, 0);
    store64(ctx + 40, 0);
    store64(ctx + 48, 0);
    store64(ctx + 56, 0);
    store64(ctx + 64, 0);
    store64(ctx + 72, dict);
    store64(ctx + 80, dict_len);
    store64(ctx + 88, 0);
    return ctx;
}

# Feed `in_len` compressed bytes. Drives the header → DEFLATE →
# trailer state machine; emits decompressed bytes into the dst buffer
# as the inner DEFLATE decoder produces them, while incrementally
# hashing them through Adler-32. Returns bytes consumed (0..in_len)
# on success, or a sticky negative error.
fn zlib_dec_write(ctx, input, in_len): i64 {
    if (load64(ctx + 64) < 0) { return load64(ctx + 64); }
    if (in_len < 0) {
        return _zdec_poison(ctx, 0 - ERR_INVALID_INPUT);
    }
    if (in_len == 0) { return 0; }
    if (in_len > 0 && input == 0) {
        return _zdec_poison(ctx, 0 - ERR_INVALID_INPUT);
    }

    var cp = 0;
    while (1) {
        var state = load64(ctx + 8);

        if (state == ZDEC_STATE_DONE) { return cp; }

        if (state == ZDEC_STATE_HEADER) {
            var hdr_idx = load64(ctx + 24);
            while (hdr_idx < 2 && cp < in_len) {
                if (hdr_idx == 0) {
                    store64(ctx + 32, load8(input + cp));
                } else {
                    store64(ctx + 40, load8(input + cp));
                }
                cp = cp + 1;
                hdr_idx = hdr_idx + 1;
            }
            store64(ctx + 24, hdr_idx);
            if (hdr_idx < 2) { return cp; }
            # Validate the 2-byte header per RFC 1950 §2.2.
            var cmf = load64(ctx + 32);
            var flg = load64(ctx + 40);
            if (((cmf * 256 + flg) % 31) != 0) {
                return _zdec_poison(ctx, 0 - ERR_CORRUPT_DATA);
            }
            if ((cmf & 15) != 8) {
                return _zdec_poison(ctx, 0 - ERR_UNSUPPORTED_FORMAT);
            }
            # LOW-01 (2.1.3): reject CINFO > 7.
            if (((cmf >> 4) & 15) > 7) {
                return _zdec_poison(ctx, 0 - ERR_UNSUPPORTED_FORMAT);
            }
            # FDICT (2.3.6): a preset dict is required. With one, parse +
            # validate the 4-byte DICTID next; without one, reject.
            if ((flg & 32) != 0) {
                if (load64(ctx + 80) == 0) {
                    return _zdec_poison(ctx, 0 - ERR_UNSUPPORTED_FORMAT);
                }
                store64(ctx + 24, 0);   # hdr_idx reused as DICTID counter
                store64(ctx + 8, ZDEC_STATE_DICTID);
            } else {
                store64(ctx + 8, ZDEC_STATE_DEFLATE);
            }
        } elif (state == ZDEC_STATE_DICTID) {
            # 4-byte big-endian DICTID = Adler-32 of the dictionary
            # (RFC 1950 §2.2). Validate against the caller's dict.
            var did = load64(ctx + 24);
            var did_acc = load64(ctx + 88);
            while (did < 4 && cp < in_len) {
                did_acc = (did_acc << 8) | load8(input + cp);
                cp = cp + 1;
                did = did + 1;
            }
            store64(ctx + 24, did);
            store64(ctx + 88, did_acc);
            if (did < 4) { return cp; }
            var want = adler32(load64(ctx + 72), load64(ctx + 80));
            if (did_acc != want) {
                return _zdec_poison(ctx, 0 - ERR_CHECKSUM_MISMATCH);
            }
            store64(ctx + 8, ZDEC_STATE_DEFLATE);
        } elif (state == ZDEC_STATE_DEFLATE) {
            var inner = load64(ctx + 0);
            var inner_state = load64(inner + 24);
            if (inner_state == DDEC_STATE_DONE) {
                store64(ctx + 8, ZDEC_STATE_TRAILER);
            } elif (cp >= in_len) {
                return cp;
            } else {
                var dst_p = load64(inner + 0);
                var dp_before = load64(inner + 8);
                var rc = deflate_dec_write(inner, input + cp, in_len - cp);
                if (rc < 0) { return _zdec_poison(ctx, rc); }
                var dp_after = load64(inner + 8);
                if (dp_after > dp_before) {
                    adler32_update(load64(ctx + 16),
                    dst_p + dp_before, dp_after - dp_before);
                }
                cp = cp + rc;
                if (load64(inner + 24) == DDEC_STATE_DONE) {
                    # The bit accumulator's `fill` pulls full bytes from
                    # input even when only a few bits are needed, so when
                    # the inner transitioned to DONE it may have pulled
                    # one byte further than the deflate stream actually
                    # extends. The encoder's `bw_align` byte-pads the
                    # tail, so the trailer always starts at the byte
                    # boundary AFTER the consumed bits — rewind `cp` by
                    # the count of whole bytes still sitting in `hold`.
                    var overpull = load64(inner + 40) >> 3;
                    cp = cp - overpull;
                    store64(ctx + 8, ZDEC_STATE_TRAILER);
                } elif (cp >= in_len) {
                    return cp;
                }
            }
        } elif (state == ZDEC_STATE_TRAILER) {
            var trailer_idx = load64(ctx + 48);
            var trailer_val = load64(ctx + 56);
            while (trailer_idx < 4 && cp < in_len) {
                trailer_val = (trailer_val << 8) | load8(input + cp);
                cp = cp + 1;
                trailer_idx = trailer_idx + 1;
            }
            store64(ctx + 48, trailer_idx);
            store64(ctx + 56, trailer_val);
            if (trailer_idx < 4) { return cp; }
            var computed = adler32_final(load64(ctx + 16));
            if (trailer_val != computed) {
                return _zdec_poison(ctx, 0 - ERR_CHECKSUM_MISMATCH);
            }
            store64(ctx + 8, ZDEC_STATE_DONE);
            return cp;
        } else {
            return _zdec_poison(ctx, 0 - ERR_INVALID_INPUT);
        }
    }
    return cp;
}

# Finalize the streaming zlib decoder. Returns total decompressed
# bytes on success, or negative error. Releases _sankoch_mtx via
# the inner deflate_dec_finish unconditionally.
fn zlib_dec_finish(ctx): i64 {
    var inner = load64(ctx + 0);
    var inner_result = deflate_dec_finish(inner);
    var zlib_err = load64(ctx + 64);
    if (zlib_err < 0) { return zlib_err; }
    if (load64(ctx + 8) != ZDEC_STATE_DONE) {
        return 0 - ERR_CORRUPT_DATA;
    }
    return inner_result;
}

# Compress data into a zlib stream with explicit compression level.
fn zlib_compress_level(src, src_len, dst, dst_cap, level): i64 {
    _sankoch_lock();
    var r = _zlib_compress_level_inner(src, src_len, dst, dst_cap, level);
    _sankoch_unlock();
    return r;
}

# Internal unlocked entry. Callers must already hold _sankoch_mtx.
fn _zlib_compress_level_inner(src, src_len, dst, dst_cap, level): i64 {
    # Need room for: 2-byte header + DEFLATE data + 4-byte Adler-32
    if (dst_cap < 6) { return 0 - ERR_BUFFER_TOO_SMALL; }

    # Header: CMF=0x78 (CM=8 deflate, CINFO=7 → 32K window), FLG=0x01
    # Verify: (0x78 * 256 + 0x01) = 30721, 30721 % 31 = 0 ✓
    store8(dst, 120);   # 0x78
    store8(dst + 1, 1); # 0x01

    # Compress DEFLATE into dst+2
    var clen = _deflate_compress_level_inner(src, src_len, dst + 2, dst_cap - 6, level);
    if (clen < 0) { return clen; }

    # Write Adler-32 (big-endian)
    var a = adler32(src, src_len);
    var pos = 2 + clen;
    store8(dst + pos, (a >> 24) & 255);
    store8(dst + pos + 1, (a >> 16) & 255);
    store8(dst + pos + 2, (a >> 8) & 255);
    store8(dst + pos + 3, a & 255);

    return pos + 4;
}

# --- gzip.cyr ---

# sankoch — gzip wrapper (RFC 1952)
#
# gzip = 10-byte header + DEFLATE stream + 4-byte CRC-32 + 4-byte ISIZE.
#
# Header (10 bytes minimum):
#   ID1 = 0x1f, ID2 = 0x8b (magic)
#   CM = 8 (deflate)
#   FLG byte: FTEXT(0), FHCRC(1), FEXTRA(2), FNAME(3), FCOMMENT(4)
#   MTIME (4 bytes, little-endian)
#   XFL (extra flags: 2=best compression, 4=fastest)
#   OS (operating system: 255=unknown)
#
# Trailer (8 bytes):
#   CRC-32 of uncompressed data (4 bytes, little-endian)
#   ISIZE = uncompressed size mod 2^32 (4 bytes, little-endian)

# Decompress one gzip member starting at src.
# Returns decompressed length, or negative error.
# Sets _gzip_member_end to the byte offset past this member's trailer.
var _gzip_member_end = 0;

fn _gzip_decompress_member(src, src_len, dst, dst_cap): i64 {
    if (src_len < 18) { return 0 - ERR_INVALID_INPUT; }

    # Verify magic bytes
    if (load8(src) != 31 || load8(src + 1) != 139) {
        return 0 - ERR_CORRUPT_DATA;
    }

    # CM must be 8
    if (load8(src + 2) != 8) { return 0 - ERR_UNSUPPORTED_FORMAT; }

    var flg = load8(src + 3);
    # LOW-2 fix (2.1.3): RFC 1952 §2.3.1.2 — "Reserved FLG bits ... must
    # be zero. If any reserved bit is non-zero, a compliant decompressor
    # must give an error." Reserved bits are 5, 6, 7 (mask 0xE0 = 224).
    # Defined bits: FTEXT(0), FHCRC(1), FEXTRA(2), FNAME(3), FCOMMENT(4).
    if ((flg & 224) != 0) { return 0 - ERR_CORRUPT_DATA; }
    var offset = 10;

    # Skip optional FEXTRA
    if ((flg & 4) != 0) {
        if (offset + 2 > src_len) { return 0 - ERR_CORRUPT_DATA; }
        var xlen = load8(src + offset) | (load8(src + offset + 1) << 8);
        offset = offset + 2 + xlen;
        if (offset > src_len) { return 0 - ERR_CORRUPT_DATA; }
    }

    # Skip optional FNAME (null-terminated)
    var found = 0;
    if ((flg & 8) != 0) {
        found = 0;
        while (offset < src_len) {
            if (load8(src + offset) == 0) { offset = offset + 1; found = 1; break; }
            offset = offset + 1;
        }
        if (found == 0) { return 0 - ERR_CORRUPT_DATA; }
    }

    # Skip optional FCOMMENT (null-terminated)
    if ((flg & 16) != 0) {
        found = 0;
        while (offset < src_len) {
            if (load8(src + offset) == 0) { offset = offset + 1; found = 1; break; }
            offset = offset + 1;
        }
        if (found == 0) { return 0 - ERR_CORRUPT_DATA; }
    }

    # Optional FHCRC (2 bytes). RFC 1952 §2.3.1.2: the two least-
    # significant bytes of the CRC-32 of all header bytes up to (not
    # including) the FHCRC field. 2.3.5: enforce it (was skipped —
    # INFO-01). Note: this is low-16-of-CRC-32, NOT CRC-16-IBM.
    if ((flg & 2) != 0) {
        if (offset + 2 > src_len) { return 0 - ERR_CORRUPT_DATA; }
        if (crc32_init_table() < 0) { return 0 - ERR_OOM; }
        var hdr_crc = crc32(src, offset) & 65535;
        var stored_fhcrc = load8(src + offset) | (load8(src + offset + 1) << 8);
        if (stored_fhcrc != hdr_crc) { return 0 - ERR_CHECKSUM_MISMATCH; }
        offset = offset + 2;
    }

    if (offset + 8 > src_len) { return 0 - ERR_CORRUPT_DATA; }

    # DEFLATE payload starts at offset
    var deflate_len = src_len - offset;
    var dlen = _deflate_decompress_inner(src + offset, deflate_len, dst, dst_cap);
    if (dlen < 0) { return dlen; }

    # Trailer starts right after the DEFLATE stream consumed bytes
    var consumed = deflate_bytes_consumed();
    var trailer = src + offset + consumed;
    if (offset + consumed + 8 > src_len) { return 0 - ERR_CORRUPT_DATA; }

    if (crc32_init_table() < 0) { return 0 - ERR_OOM; }
    var stored_crc = load8(trailer) | (load8(trailer + 1) << 8) |
    (load8(trailer + 2) << 16) | (load8(trailer + 3) << 24);
    var computed_crc = crc32(dst, dlen);
    if (stored_crc != computed_crc) { return 0 - ERR_CHECKSUM_MISMATCH; }

    # Verify ISIZE (original size mod 2^32)
    var stored_size = load8(trailer + 4) | (load8(trailer + 5) << 8) |
    (load8(trailer + 6) << 16) | (load8(trailer + 7) << 24);
    if (stored_size != (dlen & 4294967295)) { return 0 - ERR_CHECKSUM_MISMATCH; }

    _gzip_member_end = offset + consumed + 8;
    return dlen;
}

# Decompress a gzip stream (supports concatenated members per RFC 1952).
fn gzip_decompress(src, src_len, dst, dst_cap): i64 {
    _sankoch_lock();
    var r = _gzip_decompress_inner(src, src_len, dst, dst_cap);
    _sankoch_unlock();
    return r;
}

# Internal unlocked entry. Callers must already hold _sankoch_mtx.
fn _gzip_decompress_inner(src, src_len, dst, dst_cap): i64 {
    var total = 0;
    var pos = 0;

    while (pos < src_len) {
        # Check for another gzip member (magic bytes)
        if (pos + 2 > src_len) { break; }
        if (load8(src + pos) != 31 || load8(src + pos + 1) != 139) { break; }

        var dlen = _gzip_decompress_member(src + pos, src_len - pos,
        dst + total, dst_cap - total);
        if (dlen < 0) { return dlen; }
        total = total + dlen;
        pos = pos + _gzip_member_end;
    }

    if (total == 0 && pos == 0) { return 0 - ERR_INVALID_INPUT; }
    return total;
}

# Compress data into a gzip stream.
fn gzip_compress(src, src_len, dst, dst_cap): i64 {
    _sankoch_lock();
    var r = _gzip_compress_level_inner(src, src_len, dst, dst_cap, 6);
    _sankoch_unlock();
    return r;
}

# Streaming gzip encoder (v1.7.0). Wraps deflate_enc_* with the 10-byte
# gzip header and a trailing little-endian CRC-32 + ISIZE (mod 2^32).
#
# Layout (32 bytes):
#   +0:  inner deflate_enc ctx pointer
#   +8:  crc32 incremental state pointer
#   +16: dst pointer (for appending the trailer)
#   +24: total_in (cumulative bytes written — becomes ISIZE)
fn gzip_enc_init(level, dst, dst_cap): i64 {
    return gzip_enc_init_dict(level, dst, dst_cap, 0, 0);
}

# Streaming gzip encoder with a preset dictionary preloaded into the
# inner DEFLATE encoder's LZ77 window.
#
# CAVEAT — the gzip wire format (RFC 1952) has no equivalent of zlib's
# FDICT bit. The header this writes is BYTE-FOR-BYTE identical to a
# non-dict gzip stream, but the embedded DEFLATE back-references
# expect the decoder's window to be pre-warmed with the same dict
# bytes. Standard `gunzip` cannot decode such streams; the consumer
# pair must agree out-of-band. zlib's gzip-mode (deflateInit2 with
# windowBits=31 + deflateSetDictionary, then inflateSetDictionary
# on the matching side) interoperates with this layout.
#
# CRC-32 and ISIZE in the trailer cover ONLY the caller's input
# bytes (the dict is not part of the decompressed output). Returns 0
# on dict-validation or alloc failure.
fn gzip_enc_init_dict(level, dst, dst_cap, dict, dict_len): i64 {
    if (dict_len < 0) { return 0; }
    if (dict_len > DEFLATE_WINDOW_SIZE) { return 0; }
    if (dict_len > 0 && dict == 0) { return 0; }
    if (dst_cap < 18) { return 0; }   # 10 hdr + 8 trailer minimum

    # 10-byte header — identical regardless of dict (no FDICT in spec).
    store8(dst + 0, 31);    store8(dst + 1, 139);   store8(dst + 2, 8);
    store8(dst + 3, 0);     store8(dst + 4, 0);     store8(dst + 5, 0);
    store8(dst + 6, 0);     store8(dst + 7, 0);     store8(dst + 8, 0);
    store8(dst + 9, 255);

    var inner = deflate_enc_init_dict(level, dst + 10, dst_cap - 18, dict, dict_len);
    # If `inner == 0`, deflate_enc_init_dict either rejected args or
    # hit OOM and already released the lock. Propagate cleanly.
    if (inner == 0) { return 0; }

    # 2.2.1: lock IS held here. Release on alloc failure.
    var ctx = _sankoch_alloc(32);
    if (ctx == 0) { _sankoch_unlock(); return 0; }
    var crc_st = crc32_init();
    if (crc_st == 0) { _sankoch_unlock(); return 0; }
    store64(ctx, inner);
    store64(ctx + 8, crc_st);
    store64(ctx + 16, dst);
    store64(ctx + 24, 0);
    return ctx;
}

fn gzip_enc_write(ctx, input, in_len): i64 {
    if (in_len <= 0) { return 0; }
    crc32_update(load64(ctx + 8), input, in_len);
    store64(ctx + 24, load64(ctx + 24) + in_len);
    return deflate_enc_write(load64(ctx), input, in_len);
}

fn gzip_enc_finish(ctx): i64 {
    var clen = deflate_enc_finish(load64(ctx));
    if (clen < 0) { return clen; }

    var dst = load64(ctx + 16);
    var c = crc32_final(load64(ctx + 8));
    var isize = load64(ctx + 24) & 4294967295;
    var pos = 10 + clen;

    # CRC-32 little-endian
    store8(dst + pos, c & 255);
    store8(dst + pos + 1, (c >> 8) & 255);
    store8(dst + pos + 2, (c >> 16) & 255);
    store8(dst + pos + 3, (c >> 24) & 255);
    # ISIZE little-endian
    store8(dst + pos + 4, isize & 255);
    store8(dst + pos + 5, (isize >> 8) & 255);
    store8(dst + pos + 6, (isize >> 16) & 255);
    store8(dst + pos + 7, (isize >> 24) & 255);

    return pos + 8;   # 10 hdr + clen deflate + 4 crc + 4 isize
}

# Streaming gzip decoder (bite-4 of the 2.3.0 arc).
#
# Wraps deflate_dec_* with RFC 1952 header (fixed 10 bytes + optional
# FEXTRA / FNAME / FCOMMENT / FHCRC) and 8-byte trailer (CRC-32 +
# ISIZE). Mutex held from gzip_dec_init to gzip_dec_finish via the
# inner deflate_dec_*. Preserves the LOW-02 (2.1.3) reserved-FLG-bit
# reject.
#
# Scope (2.3.5): concatenated members (RFC 1952 §2.2 — multiple gzip
# members in one stream) ARE supported. After a member's trailer
# validates, GDEC_STATE_AFTER_TRAILER peeks for the next member's magic;
# if present, the inner DEFLATE decoder and the CRC / header state are
# reset (output keeps appending in dst) and the next member decodes.
# FHCRC (header CRC16) IS validated (INFO-01 closed): header bytes fold
# into an incremental CRC-32 and the low 16 bits are checked against the
# FHCRC field (per RFC 1952 — low-16-of-CRC-32, not CRC-16-IBM).
#
# ctx layout (12 i64 slots = 96 bytes):
#   +0   inner_dctx       — pointer to deflate_dec ctx (also owns dst)
#   +8   state            — GDEC_STATE_*
#   +16  crc_state        — crc32 incremental state pointer (content CRC, per member)
#   +24  hdr_idx          — bytes parsed in the current sub-section
#   +32  flg              — parsed gzip FLG byte (retained for sub-state branching)
#   +40  var_remaining    — FEXTRA data bytes remaining / FHCRC LE accumulator
#   +48  trailer_idx      — bytes parsed in the 8-byte trailer (0..8)
#   +56  trailer_crc      — little-endian CRC-32 accumulated from trailer
#   +64  trailer_isize    — little-endian ISIZE accumulated from trailer
#   +72  err              — sticky error; 0 = OK
#   +80  hdr_crc_state    — incremental CRC-32 over header bytes (for FHCRC)
#   +88  member_start_dp  — inner dp at the current member's start (for per-member ISIZE)

enum GzipDec {
    GDEC_CTX_SIZE = 96;
    GDEC_STATE_HDR_FIXED = 0;        # 10-byte fixed header
    GDEC_STATE_HDR_FEXTRA_LEN = 1;   # 2-byte XLEN (LE)
    GDEC_STATE_HDR_FEXTRA_DATA = 2;  # XLEN bytes of FEXTRA payload
    GDEC_STATE_HDR_FNAME = 3;        # NUL-terminated filename
    GDEC_STATE_HDR_FCOMMENT = 4;     # NUL-terminated comment
    GDEC_STATE_HDR_FHCRC = 5;        # 2-byte header CRC16 (validated)
    GDEC_STATE_DEFLATE = 6;          # forward to inner DEFLATE
    GDEC_STATE_TRAILER = 7;          # 8-byte CRC-32 + ISIZE
    GDEC_STATE_DONE = 8;
    GDEC_STATE_AFTER_TRAILER = 9;    # probe for a concatenated next member
}

fn _gdec_poison(ctx, code): i64 {
    store64(ctx + 72, code);
    return code;
}

# After completing any header sub-section, pick the next state based
# on FLG bits in their on-wire order (FEXTRA, FNAME, FCOMMENT, FHCRC).
# `done_mask` marks bits already processed — pass 0 to start fresh
# after HDR_FIXED, FEXTRA_DATA_MASK after FEXTRA, etc.
fn _gdec_next_hdr_state(ctx, done_mask): i64 {
    var flg = load64(ctx + 32);
    if ((flg & 4) != 0 && (done_mask & 4) == 0) {
        store64(ctx + 24, 0);
        store64(ctx + 8, GDEC_STATE_HDR_FEXTRA_LEN);
    } elif ((flg & 8) != 0 && (done_mask & 8) == 0) {
        store64(ctx + 24, 0);
        store64(ctx + 8, GDEC_STATE_HDR_FNAME);
    } elif ((flg & 16) != 0 && (done_mask & 16) == 0) {
        store64(ctx + 24, 0);
        store64(ctx + 8, GDEC_STATE_HDR_FCOMMENT);
    } elif ((flg & 2) != 0 && (done_mask & 2) == 0) {
        store64(ctx + 24, 0);
        store64(ctx + 8, GDEC_STATE_HDR_FHCRC);
    } else {
        store64(ctx + 8, GDEC_STATE_DEFLATE);
    }
    return 0;
}

fn gzip_dec_init(dst, dst_cap): i64 {
    var inner = deflate_dec_init(dst, dst_cap);
    if (inner == 0) { return 0; }

    var ctx = _sankoch_alloc(GDEC_CTX_SIZE);
    if (ctx == 0) { _sankoch_unlock(); return 0; }
    var crc_st = crc32_init();
    if (crc_st == 0) { _sankoch_unlock(); return 0; }
    var hdr_crc_st = crc32_init();
    if (hdr_crc_st == 0) { _sankoch_unlock(); return 0; }

    store64(ctx + 0, inner);
    store64(ctx + 8, GDEC_STATE_HDR_FIXED);
    store64(ctx + 16, crc_st);
    store64(ctx + 24, 0);
    store64(ctx + 32, 0);
    store64(ctx + 40, 0);
    store64(ctx + 48, 0);
    store64(ctx + 56, 0);
    store64(ctx + 64, 0);
    store64(ctx + 72, 0);
    store64(ctx + 80, hdr_crc_st);
    store64(ctx + 88, 0);
    return ctx;
}

fn gzip_dec_write(ctx, input, in_len): i64 {
    if (load64(ctx + 72) < 0) { return load64(ctx + 72); }
    if (in_len < 0) {
        return _gdec_poison(ctx, 0 - ERR_INVALID_INPUT);
    }
    if (in_len == 0) { return 0; }
    if (in_len > 0 && input == 0) {
        return _gdec_poison(ctx, 0 - ERR_INVALID_INPUT);
    }

    var cp = 0;
    while (1) {
        var state = load64(ctx + 8);
        if (state == GDEC_STATE_DONE) { return cp; }

        if (state == GDEC_STATE_HDR_FIXED) {
            var hi = load64(ctx + 24);
            var hcf_start = cp;
            while (hi < 10 && cp < in_len) {
                var b = load8(input + cp);
                if (hi == 0 && b != GZIP_MAGIC_0) {
                    return _gdec_poison(ctx, 0 - ERR_CORRUPT_DATA);
                }
                if (hi == 1 && b != GZIP_MAGIC_1) {
                    return _gdec_poison(ctx, 0 - ERR_CORRUPT_DATA);
                }
                if (hi == 2 && b != 8) {
                    return _gdec_poison(ctx, 0 - ERR_UNSUPPORTED_FORMAT);
                }
                if (hi == 3) {
                    # LOW-02 (2.1.3): reserved FLG bits 5-7 must be zero.
                    if ((b & 224) != 0) {
                        return _gdec_poison(ctx, 0 - ERR_CORRUPT_DATA);
                    }
                    store64(ctx + 32, b);
                }
                cp = cp + 1;
                hi = hi + 1;
            }
            # Fold the header bytes consumed this pass into the FHCRC state.
            crc32_update(load64(ctx + 80), input + hcf_start, cp - hcf_start);
            store64(ctx + 24, hi);
            if (hi < 10) { return cp; }
            _gdec_next_hdr_state(ctx, 0);
        } elif (state == GDEC_STATE_HDR_FEXTRA_LEN) {
            var xi = load64(ctx + 24);
            var xlen_acc = load64(ctx + 40);
            var hce_start = cp;
            while (xi < 2 && cp < in_len) {
                xlen_acc = xlen_acc | (load8(input + cp) << (xi * 8));
                cp = cp + 1;
                xi = xi + 1;
            }
            crc32_update(load64(ctx + 80), input + hce_start, cp - hce_start);
            store64(ctx + 24, xi);
            store64(ctx + 40, xlen_acc);
            if (xi < 2) { return cp; }
            store64(ctx + 24, 0);
            store64(ctx + 8, GDEC_STATE_HDR_FEXTRA_DATA);
        } elif (state == GDEC_STATE_HDR_FEXTRA_DATA) {
            var remaining = load64(ctx + 40);
            var avail = in_len - cp;
            var skip = remaining;
            if (skip > avail) { skip = avail; }
            crc32_update(load64(ctx + 80), input + cp, skip);
            cp = cp + skip;
            store64(ctx + 40, remaining - skip);
            if (remaining - skip > 0) { return cp; }
            _gdec_next_hdr_state(ctx, 4);
        } elif (state == GDEC_STATE_HDR_FNAME) {
            # Skip bytes until NUL terminator. hdr_idx unused here —
            # the state itself is the cursor.
            var hcn_start = cp;
            var found = 0;
            while (cp < in_len) {
                var nb = load8(input + cp);
                cp = cp + 1;
                if (nb == 0) { found = 1; break; }
            }
            crc32_update(load64(ctx + 80), input + hcn_start, cp - hcn_start);
            if (found == 0) { return cp; }
            _gdec_next_hdr_state(ctx, 12);
        } elif (state == GDEC_STATE_HDR_FCOMMENT) {
            var hcc_start = cp;
            var fc_found = 0;
            while (cp < in_len) {
                var cb = load8(input + cp);
                cp = cp + 1;
                if (cb == 0) { fc_found = 1; break; }
            }
            crc32_update(load64(ctx + 80), input + hcc_start, cp - hcc_start);
            if (fc_found == 0) { return cp; }
            _gdec_next_hdr_state(ctx, 28);
        } elif (state == GDEC_STATE_HDR_FHCRC) {
            # FHCRC = low 16 bits of CRC-32 over all header bytes before
            # this field (RFC 1952 §2.3.1.2). Accumulate the 2 LE bytes
            # in +40, then validate against the folded header CRC.
            var ci = load64(ctx + 24);
            var fhcrc_acc = load64(ctx + 40);
            while (ci < 2 && cp < in_len) {
                fhcrc_acc = fhcrc_acc | (load8(input + cp) << (ci * 8));
                cp = cp + 1;
                ci = ci + 1;
            }
            store64(ctx + 24, ci);
            store64(ctx + 40, fhcrc_acc);
            if (ci < 2) { return cp; }
            var computed_fhcrc = crc32_final(load64(ctx + 80)) & 65535;
            if (fhcrc_acc != computed_fhcrc) {
                return _gdec_poison(ctx, 0 - ERR_CHECKSUM_MISMATCH);
            }
            store64(ctx + 8, GDEC_STATE_DEFLATE);
        } elif (state == GDEC_STATE_DEFLATE) {
            var inner = load64(ctx + 0);
            var inner_state = load64(inner + 24);
            if (inner_state == DDEC_STATE_DONE) {
                store64(ctx + 8, GDEC_STATE_TRAILER);
            } elif (cp >= in_len) {
                return cp;
            } else {
                var dst_p = load64(inner + 0);
                var dp_before = load64(inner + 8);
                var rc = deflate_dec_write(inner, input + cp, in_len - cp);
                if (rc < 0) { return _gdec_poison(ctx, rc); }
                var dp_after = load64(inner + 8);
                if (dp_after > dp_before) {
                    crc32_update(load64(ctx + 16),
                    dst_p + dp_before, dp_after - dp_before);
                }
                cp = cp + rc;
                if (load64(inner + 24) == DDEC_STATE_DONE) {
                    # Rewind `cp` past any over-pulled trailing byte
                    # the inner's bit accumulator still holds. See the
                    # equivalent comment in zlib_dec_write for the
                    # detailed reasoning — the encoder's `bw_align`
                    # makes this always safe to subtract.
                    var overpull = load64(inner + 40) >> 3;
                    cp = cp - overpull;
                    store64(ctx + 8, GDEC_STATE_TRAILER);
                } elif (cp >= in_len) {
                    return cp;
                }
            }
        } elif (state == GDEC_STATE_TRAILER) {
            var ti = load64(ctx + 48);
            var crc_acc = load64(ctx + 56);
            var isize_acc = load64(ctx + 64);
            while (ti < 8 && cp < in_len) {
                var tb = load8(input + cp);
                if (ti < 4) {
                    crc_acc = crc_acc | (tb << (ti * 8));
                } else {
                    isize_acc = isize_acc | (tb << ((ti - 4) * 8));
                }
                cp = cp + 1;
                ti = ti + 1;
            }
            store64(ctx + 48, ti);
            store64(ctx + 56, crc_acc);
            store64(ctx + 64, isize_acc);
            if (ti < 8) { return cp; }
            # Validate trailer. CRC and ISIZE cover THIS member only —
            # the content CRC was reset at the member start, and ISIZE is
            # checked against (inner_dp - member_start_dp).
            var computed_crc = crc32_final(load64(ctx + 16));
            if (crc_acc != computed_crc) {
                return _gdec_poison(ctx, 0 - ERR_CHECKSUM_MISMATCH);
            }
            var inner_dp = load64(load64(ctx + 0) + 8);
            var member_len = inner_dp - load64(ctx + 88);
            if ((member_len & 4294967295) != isize_acc) {
                return _gdec_poison(ctx, 0 - ERR_CHECKSUM_MISMATCH);
            }
            store64(ctx + 8, GDEC_STATE_AFTER_TRAILER);
        } elif (state == GDEC_STATE_AFTER_TRAILER) {
            # A member just completed. If another gzip member follows
            # (magic 0x1f), reset for it; otherwise the stream ends
            # (trailing non-magic bytes are ignored, mirroring batch).
            if (cp >= in_len) { return cp; }
            if (load8(input + cp) != GZIP_MAGIC_0) {
                store64(ctx + 8, GDEC_STATE_DONE);
                return cp;
            }
            # Next member: reset inner DEFLATE (keeps dst/dp), content +
            # header CRC states, and all header/trailer scratch. Record
            # the member-start output offset for the next ISIZE check.
            deflate_dec_reset(load64(ctx + 0));
            store64(load64(ctx + 16), 4294967295);   # content CRC → 0xFFFFFFFF
            store64(load64(ctx + 80), 4294967295);   # header CRC → 0xFFFFFFFF
            store64(ctx + 88, load64(load64(ctx + 0) + 8));
            store64(ctx + 24, 0);
            store64(ctx + 32, 0);
            store64(ctx + 40, 0);
            store64(ctx + 48, 0);
            store64(ctx + 56, 0);
            store64(ctx + 64, 0);
            store64(ctx + 8, GDEC_STATE_HDR_FIXED);
        } else {
            return _gdec_poison(ctx, 0 - ERR_INVALID_INPUT);
        }
    }
    return cp;
}

fn gzip_dec_finish(ctx): i64 {
    var inner = load64(ctx + 0);
    var inner_result = deflate_dec_finish(inner);
    var gzip_err = load64(ctx + 72);
    if (gzip_err < 0) { return gzip_err; }
    # AFTER_TRAILER is also an accepting state: the last member's trailer
    # validated and no further member followed (clean EOF at a boundary).
    var gstate = load64(ctx + 8);
    if (gstate != GDEC_STATE_DONE && gstate != GDEC_STATE_AFTER_TRAILER) {
        return 0 - ERR_CORRUPT_DATA;
    }
    return inner_result;
}

# Compress data into a gzip stream with explicit compression level.
fn gzip_compress_level(src, src_len, dst, dst_cap, level): i64 {
    _sankoch_lock();
    var r = _gzip_compress_level_inner(src, src_len, dst, dst_cap, level);
    _sankoch_unlock();
    return r;
}

# Internal unlocked entry. Callers must already hold _sankoch_mtx.
fn _gzip_compress_level_inner(src, src_len, dst, dst_cap, level): i64 {
    # Need: 10-byte header + DEFLATE + 8-byte trailer
    if (dst_cap < 18) { return 0 - ERR_BUFFER_TOO_SMALL; }

    # Write header
    store8(dst + 0, 31);   # ID1
    store8(dst + 1, 139);  # ID2
    store8(dst + 2, 8);    # CM = deflate
    store8(dst + 3, 0);    # FLG = no extras
    store8(dst + 4, 0);    # MTIME (4 bytes, all zero)
    store8(dst + 5, 0);
    store8(dst + 6, 0);
    store8(dst + 7, 0);
    store8(dst + 8, 0);    # XFL
    store8(dst + 9, 255);  # OS = unknown

    # Compress DEFLATE into dst+10
    var clen = _deflate_compress_level_inner(src, src_len, dst + 10, dst_cap - 18, level);
    if (clen < 0) { return clen; }

    # Write trailer: CRC-32 (little-endian) + ISIZE (little-endian)
    if (crc32_init_table() < 0) { return 0 - ERR_OOM; }
    var c = crc32(src, src_len);
    var pos = 10 + clen;
    store8(dst + pos, c & 255);
    store8(dst + pos + 1, (c >> 8) & 255);
    store8(dst + pos + 2, (c >> 16) & 255);
    store8(dst + pos + 3, (c >> 24) & 255);

    var isize = src_len & 4294967295;
    store8(dst + pos + 4, isize & 255);
    store8(dst + pos + 5, (isize >> 8) & 255);
    store8(dst + pos + 6, (isize >> 16) & 255);
    store8(dst + pos + 7, (isize >> 24) & 255);

    return pos + 8;
}

# --- xz.cyr ---

# sankoch — .xz container + LZMA2 / LZMA decode (decode-only)
#
# Decompresses the .xz stream format (the common modern source-tarball
# container). Decode only — no encoder. Added at 2.4.0 to unblock
# takumi `.tar.xz` extraction.
#
# Layout owned here:
#   - .xz container parse: stream header / block header(s) / index /
#     stream footer, with CRC-32 / CRC-64 check-field validation
#     (checksum.cyr supplies both; "none" and SHA-256 checks are parsed
#     but not verified — SHA-256 is excluded by roadmap.md § 2.4.0
#     (CRC-32 / CRC-64 only); the per-block header CRC32 still gates
#     structural integrity).
#   - LZMA2 chunk framing: control bytes, dict/state/props resets,
#     uncompressed chunks, LZMA chunks.
#   - LZMA decode: range (arithmetic) decoder + the literal/match state
#     machine with rep-distance history.
#
# References:
#   - "The .xz File Format" v1.1.0 (tukaani.org/xz/xz-file-format.txt)
#   - LZMA SDK LzmaDec.c / xz-embedded xz_dec_lzma2.c (decoder shape)
#   - The probability-model layout matches the canonical LZMA decoder.
#
# All state lives in flat globals behind `_sankoch_mtx` (taken by the
# public entry in lib.cyr), consistent with the rest of the library —
# no per-call allocation on the decode path beyond the one-time prob
# table. `>>` is a logical shift on i64 in Cyrius, so the u32 range-coder
# words and the full-width masks below are sign-extension-safe.

# Probability-model offsets, in units of one 11-bit probability (each
# stored as an i64 slot). kNumStates = 12, kNumPosBitsMax = 4 → up to 16
# pos-states. Cumulative layout — see LzmaDec.c CLzmaDec.probs.
enum XzProb {
    XZ_OFF_ISMATCH    = 0;       # 12 * 16 = 192
    XZ_OFF_ISREP      = 192;     # 12
    XZ_OFF_ISREPG0    = 204;     # 12
    XZ_OFF_ISREPG1    = 216;     # 12
    XZ_OFF_ISREPG2    = 228;     # 12
    XZ_OFF_ISREP0LONG = 240;     # 12 * 16 = 192
    XZ_OFF_POSSLOT    = 432;     # 4 * 64 = 256
    XZ_OFF_SPECPOS    = 688;     # 115
    XZ_OFF_ALIGN      = 803;     # 16
    XZ_OFF_LENCODER   = 819;     # 514
    XZ_OFF_REPLEN     = 1333;    # 514
    XZ_OFF_LITERAL    = 1847;    # 0x300 << (lc+lp), lc+lp <= 4 → max 12288
    XZ_PROBS_TOTAL    = 14135;   # 1847 + 12288
    XZ_PROB_INIT      = 1024;    # (1 << 11) / 2
}

# ---- shared cursor / range-coder / lzma state ----
var _xz_in = 0;        # base pointer of the compressed stream
var _xz_in_pos = 0;    # parse cursor (container + LZMA2 framing)
var _xz_in_end = 0;    # end of available input (stream length)
var _xz_err = 0;       # sticky corruption flag set by bounded reads

var _xz_rc_end = 0;    # range-decoder read bound (current LZMA chunk end)
var _xz_rc_code = 0;
var _xz_rc_range = 0;

var _xz_probs = 0;     # prob table base (XZ_PROBS_TOTAL i64 slots)

var _xz_state = 0;     # LZMA state 0..11
var _xz_rep0 = 0;
var _xz_rep1 = 0;
var _xz_rep2 = 0;
var _xz_rep3 = 0;
var _xz_lc = 0;
var _xz_lp = 0;
var _xz_pb = 0;
var _xz_pos_mask = 0;  # (1 << pb) - 1
var _xz_lit_mask = 0;  # (1 << lp) - 1

# Output window (== the destination buffer; whole output retained, so
# match back-references are always in range).
var _xz_dst = 0;
var _xz_dp = 0;
var _xz_dst_cap = 0;
var _xz_dict_start = 0;  # dp at the last dict reset (match floor)

# ============================================================
# Range decoder (LZMA arithmetic coder)
# ============================================================

# Read one input byte for the range coder, clamped to the chunk bound.
# Past the bound feeds 0 and trips _xz_err — never reads OOB memory.
fn _xz_rc_byte(): i64 {
    if (_xz_in_pos >= _xz_rc_end) {
        _xz_err = 1;
        return 0;
    }
    var b = load8(_xz_in + _xz_in_pos);
    _xz_in_pos = _xz_in_pos + 1;
    return b;
}

# Initialize the range coder for one LZMA chunk: first byte must be 0,
# then 4 big-endian bytes seed `code`; range = 0xFFFFFFFF.
fn _xz_rc_init(): i64 {
    if (_xz_rc_byte() != 0) { _xz_err = 1; }
    _xz_rc_code = 0;
    var i = 0;
    while (i < 4) {
        _xz_rc_code = ((_xz_rc_code << 8) | _xz_rc_byte()) & 0xFFFFFFFF;
        i = i + 1;
    }
    _xz_rc_range = 0xFFFFFFFF;
    return 0;
}

# Renormalize: if range dropped below kTopValue (1<<24), shift in a byte.
# A single shift suffices (range stays >= 1<<16 after any decode step).
fn _xz_rc_normalize(): i64 {
    if (_xz_rc_range < 16777216) {
        _xz_rc_range = (_xz_rc_range << 8) & 0xFFFFFFFF;
        _xz_rc_code = ((_xz_rc_code << 8) | _xz_rc_byte()) & 0xFFFFFFFF;
    }
    return 0;
}

# Decode one bit against the probability at slot `idx`; update the prob.
fn _xz_rc_bit(idx): i64 {
    var p = load64(_xz_probs + idx * 8);
    var bound = ((_xz_rc_range >> 11) * p) & 0xFFFFFFFF;
    var sym = 0;
    if (_xz_rc_code < bound) {
        _xz_rc_range = bound;
        p = p + ((2048 - p) >> 5);
        sym = 0;
    } else {
        _xz_rc_range = (_xz_rc_range - bound) & 0xFFFFFFFF;
        _xz_rc_code = (_xz_rc_code - bound) & 0xFFFFFFFF;
        p = p - (p >> 5);
        sym = 1;
    }
    store64(_xz_probs + idx * 8, p);
    _xz_rc_normalize();
    return sym;
}

# Bit-tree decode, MSB-first, `nbits` bits rooted at slot `base`.
fn _xz_bittree(base, nbits): i64 {
    var m = 1;
    var i = 0;
    while (i < nbits) {
        m = (m << 1) | _xz_rc_bit(base + m);
        i = i + 1;
    }
    return m - (1 << nbits);
}

# Reverse bit-tree decode, LSB-first — for SpecPos and Align slots.
fn _xz_bittree_rev(base, nbits): i64 {
    var m = 1;
    var sym = 0;
    var i = 0;
    while (i < nbits) {
        var b = _xz_rc_bit(base + m);
        m = (m << 1) | b;
        sym = sym | (b << i);
        i = i + 1;
    }
    return sym;
}

# Decode `nbits` equiprobable bits (no model) — high distance bits.
fn _xz_rc_direct(nbits): i64 {
    var res = 0;
    var i = 0;
    while (i < nbits) {
        _xz_rc_range = (_xz_rc_range >> 1) & 0xFFFFFFFF;
        var bit = 0;
        if (_xz_rc_code >= _xz_rc_range) {
            _xz_rc_code = (_xz_rc_code - _xz_rc_range) & 0xFFFFFFFF;
            bit = 1;
        }
        res = (res << 1) | bit;
        _xz_rc_normalize();
        i = i + 1;
    }
    return res;
}

# LZMA length decoder. `base` is XZ_OFF_LENCODER or XZ_OFF_REPLEN.
# Returns a 0-based length (caller adds kMatchMinLen = 2).
#   choice  @ base+0       choice2 @ base+1
#   low[posState][8]  @ base+2   + posState*8     (3-bit tree)  → 0..7
#   mid[posState][8]  @ base+130 + posState*8     (3-bit tree)  → 8..15
#   high[256]         @ base+258                  (8-bit tree)  → 16..271
fn _xz_len(base, pos_state): i64 {
    if (_xz_rc_bit(base) == 0) {
        return _xz_bittree(base + 2 + pos_state * 8, 3);
    }
    if (_xz_rc_bit(base + 1) == 0) {
        return 8 + _xz_bittree(base + 130 + pos_state * 8, 3);
    }
    return 16 + _xz_bittree(base + 258, 8);
}

# ============================================================
# LZMA core decode
# ============================================================

# Reset all probabilities to the neutral value (state reset).
fn _xz_reset_probs(): i64 {
    var i = 0;
    while (i < XZ_PROBS_TOTAL) {
        store64(_xz_probs + i * 8, XZ_PROB_INIT);
        i = i + 1;
    }
    return 0;
}

# Reset the LZMA literal/match state (state, rep distances).
fn _xz_reset_state(): i64 {
    _xz_state = 0;
    _xz_rep0 = 0;
    _xz_rep1 = 0;
    _xz_rep2 = 0;
    _xz_rep3 = 0;
    return 0;
}

# Emit one output byte, with capacity + ceiling guards.
fn _xz_put(b): i64 {
    if (_xz_dp >= _xz_dst_cap) { return 0 - ERR_BUFFER_TOO_SMALL; }
    if (_xz_dp >= DECOMPRESS_MAX_OUTPUT) { return 0 - ERR_OUTPUT_LIMIT; }
    store8(_xz_dst + _xz_dp, b & 255);
    _xz_dp = _xz_dp + 1;
    return 0;
}

# Decode one literal byte (state < 7: plain; state >= 7: match-predicted).
fn _xz_decode_literal(): i64 {
    var prev = 0;
    if (_xz_dp > _xz_dict_start) { prev = load8(_xz_dst + _xz_dp - 1); }
    var lit_state = ((_xz_dp & _xz_lit_mask) << _xz_lc) + (prev >> (8 - _xz_lc));
    var base = XZ_OFF_LITERAL + 768 * lit_state;   # 0x300 = 768
    var sym = 1;

    if (_xz_state >= 7) {
        # Match-predicted literal: track the byte at the last rep0 match.
        var match_byte = load8(_xz_dst + _xz_dp - _xz_rep0 - 1);
        while (sym < 256) {
            var match_bit = (match_byte >> 7) & 1;
            match_byte = (match_byte << 1) & 255;
            var bit = _xz_rc_bit(base + ((1 + match_bit) << 8) + sym);
            sym = (sym << 1) | bit;
            if (match_bit != bit) { break; }
        }
    }
    while (sym < 256) {
        sym = (sym << 1) | _xz_rc_bit(base + sym);
    }
    return _xz_put(sym);
}

# Copy a match of `len` bytes from distance rep0+1 back in the window.
# Byte-by-byte to honor LZ77 overlapping-copy semantics.
fn _xz_copy_match(len): i64 {
    var dist = _xz_rep0 + 1;
    if (_xz_dp - dist < _xz_dict_start) { return 0 - ERR_MATCH_OUT_OF_RANGE; }
    if (_xz_dp + len > _xz_dst_cap) { return 0 - ERR_BUFFER_TOO_SMALL; }
    if (_xz_dp + len > DECOMPRESS_MAX_OUTPUT) { return 0 - ERR_OUTPUT_LIMIT; }
    var i = 0;
    while (i < len) {
        store8(_xz_dst + _xz_dp, load8(_xz_dst + _xz_dp - dist));
        _xz_dp = _xz_dp + 1;
        i = i + 1;
    }
    return 0;
}

# Decode the match distance into rep0 (after a new-match len decode).
# `len` is the 0-based length (pre +2). Returns 0, or 1 if the end
# marker (dist == 0xFFFFFFFF) was decoded, or negative on error.
fn _xz_decode_distance(len): i64 {
    var len_state = len;
    if (len_state > 3) { len_state = 3; }
    var pos_slot = _xz_bittree(XZ_OFF_POSSLOT + len_state * 64, 6);

    if (pos_slot < 4) {
        _xz_rep0 = pos_slot;
        return 0;
    }

    var num_direct = (pos_slot >> 1) - 1;
    var dist = (2 | (pos_slot & 1)) << num_direct;
    if (pos_slot < 14) {
        dist = dist + _xz_bittree_rev(XZ_OFF_SPECPOS + dist - pos_slot, num_direct);
    } else {
        dist = dist + (_xz_rc_direct(num_direct - 4) << 4);
        dist = dist + _xz_bittree_rev(XZ_OFF_ALIGN, 4);
    }
    _xz_rep0 = dist & 0xFFFFFFFF;
    if (_xz_rep0 == 0xFFFFFFFF) { return 1; }   # end-of-stream marker
    return 0;
}

# Decode exactly `out_len` bytes of one LZMA chunk into the window.
# Range coder must already be initialized for this chunk.
fn _xz_lzma_run(out_len): i64 {
    var target = _xz_dp + out_len;
    while (_xz_dp < target) {
        if (_xz_err != 0) { return 0 - ERR_CORRUPT_DATA; }
        var pos_state = _xz_dp & _xz_pos_mask;

        if (_xz_rc_bit(XZ_OFF_ISMATCH + (_xz_state << 4) + pos_state) == 0) {
            # --- literal ---
            var lr = _xz_decode_literal();
            if (lr < 0) { return lr; }
            if (_xz_state < 4) { _xz_state = 0; }
            elif (_xz_state < 10) { _xz_state = _xz_state - 3; }
            else { _xz_state = _xz_state - 6; }
            continue;
        }

        # --- match ---
        var len = 0;
        if (_xz_rc_bit(XZ_OFF_ISREP + _xz_state) != 0) {
            # repeated match
            if (_xz_rc_bit(XZ_OFF_ISREPG0 + _xz_state) == 0) {
                if (_xz_rc_bit(XZ_OFF_ISREP0LONG + (_xz_state << 4) + pos_state) == 0) {
                    # short rep — single byte at rep0
                    if (_xz_state < 7) { _xz_state = 9; } else { _xz_state = 11; }
                    var sr = _xz_copy_match(1);
                    if (sr < 0) { return sr; }
                    continue;
                }
            } else {
                var dist = 0;
                if (_xz_rc_bit(XZ_OFF_ISREPG1 + _xz_state) == 0) {
                    dist = _xz_rep1;
                } else {
                    if (_xz_rc_bit(XZ_OFF_ISREPG2 + _xz_state) == 0) {
                        dist = _xz_rep2;
                    } else {
                        dist = _xz_rep3;
                        _xz_rep3 = _xz_rep2;
                    }
                    _xz_rep2 = _xz_rep1;
                }
                _xz_rep1 = _xz_rep0;
                _xz_rep0 = dist;
            }
            len = _xz_len(XZ_OFF_REPLEN, pos_state);
            if (_xz_state < 7) { _xz_state = 8; } else { _xz_state = 11; }
        } else {
            # new match
            _xz_rep3 = _xz_rep2;
            _xz_rep2 = _xz_rep1;
            _xz_rep1 = _xz_rep0;
            len = _xz_len(XZ_OFF_LENCODER, pos_state);
            if (_xz_state < 7) { _xz_state = 7; } else { _xz_state = 10; }
            var dr = _xz_decode_distance(len);
            if (dr < 0) { return dr; }
            if (dr == 1) {
                # end marker — only legal if the chunk produced its bytes.
                if (_xz_dp != target) { return 0 - ERR_CORRUPT_DATA; }
                return 0;
            }
        }
        var cr = _xz_copy_match(len + 2);   # kMatchMinLen
        if (cr < 0) { return cr; }
    }
    if (_xz_err != 0) { return 0 - ERR_CORRUPT_DATA; }
    return 0;
}

# ============================================================
# LZMA2 chunk framing
# ============================================================

# Apply the lc/lp/pb properties byte (d = (pb*5 + lp)*9 + lc).
fn _xz_set_props(d): i64 {
    if (d >= 225) { return 0 - ERR_CORRUPT_DATA; }
    var lc = d % 9;
    var r = (d - lc) / 9;
    var lp = r % 5;
    var pb = (r - lp) / 5;
    if (lc + lp > 4) { return 0 - ERR_CORRUPT_DATA; }
    _xz_lc = lc;
    _xz_lp = lp;
    _xz_pb = pb;
    _xz_pos_mask = (1 << pb) - 1;
    _xz_lit_mask = (1 << lp) - 1;
    return 0;
}

# Decode an LZMA2 stream occupying _xz_in[_xz_in_pos .. _xz_in_end).
# Output goes to the window (_xz_dst / _xz_dp). Returns 0 or negative.
# On return _xz_in_pos points just past the 0x00 end-control byte.
fn _xz_lzma2_run(): i64 {
    var have_props = 0;
    var need_dict_reset = 1;
    while (1) {
        if (_xz_in_pos >= _xz_in_end) { return 0 - ERR_CORRUPT_DATA; }
        var ctrl = load8(_xz_in + _xz_in_pos);
        _xz_in_pos = _xz_in_pos + 1;

        if (ctrl == 0) { return 0; }   # end of LZMA2 stream

        if (ctrl < 3) {
            # Uncompressed chunk: ctrl 1 = reset dict, 2 = no reset.
            if (ctrl == 1) {
                _xz_dict_start = _xz_dp;
                need_dict_reset = 0;
            } else {
                if (need_dict_reset != 0) { return 0 - ERR_CORRUPT_DATA; }
            }
            if (_xz_in_pos + 2 > _xz_in_end) { return 0 - ERR_CORRUPT_DATA; }
            var usize = ((load8(_xz_in + _xz_in_pos) << 8)
            | load8(_xz_in + _xz_in_pos + 1)) + 1;
            _xz_in_pos = _xz_in_pos + 2;
            if (_xz_in_pos + usize > _xz_in_end) { return 0 - ERR_CORRUPT_DATA; }
            var i = 0;
            while (i < usize) {
                var pr = _xz_put(load8(_xz_in + _xz_in_pos));
                if (pr < 0) { return pr; }
                _xz_in_pos = _xz_in_pos + 1;
                i = i + 1;
            }
            # After raw data the LZMA state is stale; the next LZMA chunk
            # is required by the format to carry a state reset.
            _xz_state = 0;
            continue;
        }

        if (ctrl < 0x80) { return 0 - ERR_CORRUPT_DATA; }

        # LZMA chunk. ctrl bits: [7]=1, [6:5]=reset mode, [4:0]=usize hi.
        if (_xz_in_pos + 4 > _xz_in_end) { return 0 - ERR_CORRUPT_DATA; }
        var unpacked = (((ctrl & 31) << 16)
        | (load8(_xz_in + _xz_in_pos) << 8)
        | load8(_xz_in + _xz_in_pos + 1)) + 1;
        var packed = ((load8(_xz_in + _xz_in_pos + 2) << 8)
        | load8(_xz_in + _xz_in_pos + 3)) + 1;
        _xz_in_pos = _xz_in_pos + 4;
        var reset = (ctrl >> 5) & 3;

        if (reset >= 2) {
            if (_xz_in_pos >= _xz_in_end) { return 0 - ERR_CORRUPT_DATA; }
            var sp = _xz_set_props(load8(_xz_in + _xz_in_pos));
            if (sp < 0) { return sp; }
            _xz_in_pos = _xz_in_pos + 1;
            have_props = 1;
        }
        if (have_props == 0) { return 0 - ERR_CORRUPT_DATA; }
        if (reset >= 1) {
            _xz_reset_probs();
            _xz_reset_state();
        }
        if (reset == 3) {
            _xz_dict_start = _xz_dp;
            need_dict_reset = 0;
        }
        if (need_dict_reset != 0) { return 0 - ERR_CORRUPT_DATA; }

        # Range-decode `unpacked` bytes from the next `packed` input bytes.
        if (_xz_in_pos + packed > _xz_in_end) { return 0 - ERR_CORRUPT_DATA; }
        var chunk_start = _xz_in_pos;
        _xz_rc_end = chunk_start + packed;
        _xz_rc_init();
        var rr = _xz_lzma_run(unpacked);
        if (rr < 0) { return rr; }
        # Advance past the whole compressed chunk regardless of exact
        # range-coder consumption.
        _xz_in_pos = chunk_start + packed;
    }
    return 0;
}

# ============================================================
# .xz container parse
# ============================================================

# Decode a multibyte (LEB128-style, 7 bits/byte) integer at _xz_in_pos,
# advancing the cursor. xz caps these at 9 bytes. Trips _xz_err on
# overrun / over-length.
fn _xz_varint(): i64 {
    var result = 0;
    var i = 0;
    while (i < 9) {
        if (_xz_in_pos >= _xz_in_end) { _xz_err = 1; return 0; }
        var b = load8(_xz_in + _xz_in_pos);
        _xz_in_pos = _xz_in_pos + 1;
        result = result | ((b & 127) << (i * 7));
        if ((b & 128) == 0) { return result; }
        i = i + 1;
    }
    _xz_err = 1;
    return 0;
}

# Read a 4-byte little-endian field at `off`.
fn _xz_le32(off): i64 {
    return load8(_xz_in + off) | (load8(_xz_in + off + 1) << 8)
    | (load8(_xz_in + off + 2) << 16) | (load8(_xz_in + off + 3) << 24);
}

# Validate the block check field over this block's output slice
# data[0..dlen). check_type: 0 none, 1 CRC32, 4 CRC64, 10 SHA-256
# (parsed, not verified). `at` points at the check field; `data` at the
# start of this block's decoded bytes. Returns the field length, or
# negative error.
fn _xz_verify_check(check_type, at, data, dlen): i64 {
    if (check_type == 0) { return 0; }
    if (check_type == 1) {
        if (crc32_init_table() < 0) { return 0 - ERR_OOM; }
        var got = crc32(data, dlen);
        var want = _xz_le32(at) & 0xFFFFFFFF;
        if (got != want) { return 0 - ERR_CHECKSUM_MISMATCH; }
        return 4;
    }
    if (check_type == 4) {
        if (crc64_init_table() < 0) { return 0 - ERR_OOM; }
        var got64 = crc64(data, dlen);
        var lo = _xz_le32(at) & 0xFFFFFFFF;
        var hi = _xz_le32(at + 4) & 0xFFFFFFFF;
        var want64 = (hi << 32) | lo;
        if (got64 != want64) { return 0 - ERR_CHECKSUM_MISMATCH; }
        return 8;
    }
    if (check_type == 10) { return 32; }   # SHA-256: skip verification
    return 0 - ERR_UNSUPPORTED_FORMAT;
}

# Parse + decode one .xz block starting at _xz_in_pos. check_type from
# the stream header. Returns decoded length (cumulative dp advance is the
# real output); sets _xz_in_pos past the block's check field.
fn _xz_decode_block(check_type): i64 {
    var block_start = _xz_in_pos;
    var hsize_byte = load8(_xz_in + _xz_in_pos);
    var header_size = (hsize_byte + 1) * 4;
    if (block_start + header_size > _xz_in_end) { return 0 - ERR_CORRUPT_DATA; }

    # Header CRC32 covers the header bytes excluding its own trailing CRC.
    if (crc32_init_table() < 0) { return 0 - ERR_OOM; }
    var hdr_crc = crc32(_xz_in + block_start, header_size - 4);
    var stored_hdr_crc = _xz_le32(block_start + header_size - 4) & 0xFFFFFFFF;
    if (hdr_crc != stored_hdr_crc) { return 0 - ERR_CHECKSUM_MISMATCH; }

    _xz_in_pos = block_start + 1;
    var flags = load8(_xz_in + _xz_in_pos);
    _xz_in_pos = _xz_in_pos + 1;
    var num_filters = (flags & 3) + 1;

    # Optional compressed / uncompressed size fields (varints, ignored —
    # we drive decode off the LZMA2 end marker and the block check).
    if ((flags & 64) != 0) { _xz_varint(); }
    if ((flags & 128) != 0) { _xz_varint(); }
    if (_xz_err != 0) { return 0 - ERR_CORRUPT_DATA; }

    # Filter flags. Only a single LZMA2 filter (ID 0x21) is supported.
    if (num_filters != 1) { return 0 - ERR_UNSUPPORTED_FORMAT; }
    var filter_id = _xz_varint();
    var prop_size = _xz_varint();
    if (_xz_err != 0) { return 0 - ERR_CORRUPT_DATA; }
    if (filter_id != 0x21) { return 0 - ERR_UNSUPPORTED_FORMAT; }
    # LZMA2 properties = 1 byte (dictionary-size code). We retain the full
    # output as the window, so the dict-size value itself is not needed.
    if (prop_size != 1) { return 0 - ERR_CORRUPT_DATA; }
    _xz_in_pos = _xz_in_pos + 1;

    # Skip header padding to the stored CRC (already validated).
    _xz_in_pos = block_start + header_size;

    # Decode the LZMA2 payload. _xz_in_end stays the stream end; the
    # framing stops at the 0x00 control byte.
    var dp_before = _xz_dp;
    var lr = _xz_lzma2_run();
    if (lr < 0) { return lr; }
    var dlen = _xz_dp - dp_before;
    var out_start = _xz_dst + dp_before;

    # Block padding: pad the compressed data (from block_start) to a
    # 4-byte boundary before the check field.
    var consumed = _xz_in_pos - block_start;
    while ((consumed & 3) != 0) {
        if (_xz_in_pos >= _xz_in_end) { return 0 - ERR_CORRUPT_DATA; }
        if (load8(_xz_in + _xz_in_pos) != 0) { return 0 - ERR_CORRUPT_DATA; }
        _xz_in_pos = _xz_in_pos + 1;
        consumed = consumed + 1;
    }

    # Check field over this block's output slice.
    var clen = _xz_verify_check(check_type, _xz_in_pos, out_start, dlen);
    if (clen < 0) { return clen; }
    if (_xz_in_pos + clen > _xz_in_end) { return 0 - ERR_CORRUPT_DATA; }
    _xz_in_pos = _xz_in_pos + clen;
    return dlen;
}

# Decode one .xz stream beginning at offset `s` in _xz_in. Appends to the
# output window (_xz_dp) and returns the absolute offset just past the
# stream footer, or a negative error. Assumes _xz_in / _xz_in_end /
# _xz_probs / _xz_dst already set up by the caller.
fn _xz_decode_stream(s): i64 {
    var src = _xz_in;
    if (s + 32 > _xz_in_end) { return 0 - ERR_INVALID_INPUT; }

    # Stream header: magic FD 37 7A 58 5A 00.
    if (load8(src + s) != 0xFD || load8(src + s + 1) != 0x37
    || load8(src + s + 2) != 0x7A || load8(src + s + 3) != 0x58
    || load8(src + s + 4) != 0x5A || load8(src + s + 5) != 0x00) {
        return 0 - ERR_CORRUPT_DATA;
    }
    # Stream flags: byte 6 reserved (0), byte 7 = check type.
    if (load8(src + s + 6) != 0) { return 0 - ERR_CORRUPT_DATA; }
    var check_type = load8(src + s + 7);
    if (check_type > 15) { return 0 - ERR_CORRUPT_DATA; }

    if (crc32_init_table() < 0) { return 0 - ERR_OOM; }
    var sf_crc = crc32(src + s + 6, 2);
    if (sf_crc != (_xz_le32(s + 8) & 0xFFFFFFFF)) { return 0 - ERR_CHECKSUM_MISMATCH; }

    # Each stream resets the dictionary floor.
    _xz_dict_start = _xz_dp;

    # Blocks until the index indicator (0x00).
    _xz_in_pos = s + 12;   # past the 12-byte stream header
    while (1) {
        if (_xz_in_pos >= _xz_in_end) { return 0 - ERR_CORRUPT_DATA; }
        if (load8(src + _xz_in_pos) == 0) { break; }   # index indicator
        var br = _xz_decode_block(check_type);
        if (br < 0) { return br; }
    }

    # Index: indicator(0) + count + records, padded to 4, then CRC32. We
    # don't re-validate the record sizes (the per-block checks and header
    # CRCs already gate integrity); we parse the index to locate the
    # stream footer and validate its CRC32.
    var index_start = _xz_in_pos;
    _xz_in_pos = _xz_in_pos + 1;   # indicator
    var num_records = _xz_varint();
    if (_xz_err != 0) { return 0 - ERR_CORRUPT_DATA; }
    var rec = 0;
    while (rec < num_records) {
        _xz_varint();   # unpadded size
        _xz_varint();   # uncompressed size
        rec = rec + 1;
    }
    if (_xz_err != 0) { return 0 - ERR_CORRUPT_DATA; }
    var idx_consumed = _xz_in_pos - index_start;
    while ((idx_consumed & 3) != 0) {
        if (_xz_in_pos >= _xz_in_end) { return 0 - ERR_CORRUPT_DATA; }
        _xz_in_pos = _xz_in_pos + 1;
        idx_consumed = idx_consumed + 1;
    }
    var index_size = idx_consumed + 4;   # + the index's own CRC32
    if (index_start + index_size > _xz_in_end) { return 0 - ERR_CORRUPT_DATA; }
    var idx_crc = crc32(src + index_start, idx_consumed);
    if (idx_crc != (_xz_le32(index_start + idx_consumed) & 0xFFFFFFFF)) {
        return 0 - ERR_CHECKSUM_MISMATCH;
    }
    _xz_in_pos = index_start + index_size;

    # Stream footer (12 bytes): CRC32 | Backward Size | Stream Flags | YZ.
    if (_xz_in_pos + 12 > _xz_in_end) { return 0 - ERR_CORRUPT_DATA; }
    var foot = _xz_in_pos;
    if (load8(src + foot + 10) != 0x59 || load8(src + foot + 11) != 0x5A) {
        return 0 - ERR_CORRUPT_DATA;
    }
    # Stream flags must match the header's.
    if (load8(src + foot + 8) != 0 || load8(src + foot + 9) != check_type) {
        return 0 - ERR_CORRUPT_DATA;
    }
    # Backward Size encodes the index size: (stored+1)*4.
    var back = _xz_le32(foot + 4) & 0xFFFFFFFF;
    if ((back + 1) * 4 != index_size) { return 0 - ERR_CORRUPT_DATA; }
    # Footer CRC32 over Backward Size + Stream Flags (bytes foot+4 .. foot+9).
    var foot_crc = crc32(src + foot + 4, 6);
    if (foot_crc != (_xz_le32(foot) & 0xFFFFFFFF)) {
        return 0 - ERR_CHECKSUM_MISMATCH;
    }

    return foot + 12;
}

# Decompress a full .xz file. Supports concatenated streams (each its own
# header/blocks/index/footer) separated by optional 4-byte-aligned zero
# Stream Padding — matching `xz -dc`. Inner entry — caller holds the lock.
fn _xz_decompress_inner(src, src_len, dst, dst_cap): i64 {
    if (src_len < 32) { return 0 - ERR_INVALID_INPUT; }

    _xz_in = src;
    _xz_in_end = src_len;
    _xz_err = 0;

    # Allocate the probability table once (reused across calls).
    if (_xz_probs == 0) {
        _xz_probs = _sankoch_alloc(XZ_PROBS_TOTAL * 8);
        if (_xz_probs == 0) { return 0 - ERR_OOM; }
    }

    # Output window — contiguous across all streams.
    _xz_dst = dst;
    _xz_dp = 0;
    _xz_dst_cap = dst_cap;
    _xz_dict_start = 0;

    var off = 0;
    while (off < src_len) {
        # Stream Padding: runs of zero bytes (multiple of 4) between or
        # after streams. Skip them; reaching EOF ends decode.
        if (load8(src + off) == 0) {
            var pad = 0;
            while (off < src_len && load8(src + off) == 0) {
                off = off + 1;
                pad = pad + 1;
            }
            if ((pad & 3) != 0) { return 0 - ERR_CORRUPT_DATA; }
            continue;
        }
        var r = _xz_decode_stream(off);
        if (r < 0) { return r; }
        off = r;
    }

    return _xz_dp;
}

# Public: decompress a .xz stream. Thread-safe wrapper.
fn xz_decompress(src, src_len, dst, dst_cap): i64 {
    if (src_len < 0 || dst_cap < 0) { return 0 - ERR_INVALID_INPUT; }
    _sankoch_lock();
    var r = _xz_decompress_inner(src, src_len, dst, dst_cap);
    _sankoch_unlock();
    return r;
}

# ============================================================
# ENCODE SIDE (2.4.1)
# ============================================================
# The encoder mirrors the decoder: the same probability model
# (`_xz_probs` + the `XZ_OFF_*` offsets) and the same literal / length /
# distance structure, run in reverse. Encode and decode never run
# concurrently (each public call resets the model under `_sankoch_mtx`),
# so the probability array is shared rather than duplicated.
#
# This block is built in bites: (1) the range encoder + bit-tree symbol
# coders [here], (2) match finder + parse + LZMA2 framing + container
# writer, (3) optimal parse. Reference shape: LZMA SDK LzmaEnc.c.

# ---- range encoder state ----
var _xze_low = 0;          # i64 — holds carry above bit 31
var _xze_range = 0;        # u32
var _xze_cache = 0;        # pending output byte
var _xze_cache_size = 0;   # run length of pending 0xFF carry bytes
var _xze_out = 0;          # output buffer base
var _xze_op = 0;           # output cursor (also the "needed size" counter)
var _xze_out_cap = 0;
var _xze_overflow = 0;     # set when op would exceed cap

# Emit one byte, guarding the capacity. `_xze_op` keeps advancing past
# the cap so the final value reports the size that would be needed.
fn _xze_emit(b): i64 {
    if (_xze_op < _xze_out_cap) {
        store8(_xze_out + _xze_op, b & 255);
    } else {
        _xze_overflow = 1;
    }
    _xze_op = _xze_op + 1;
    return 0;
}

# Carry-propagating low-byte shift. Defers a run of bytes until the carry
# out of bit 32 is known (LzmaEnc RangeEnc_ShiftLow).
fn _xze_shift_low(): i64 {
    var carry = _xze_low >> 32;
    if (carry != 0 || _xze_low < 0xFF000000) {
        var temp = _xze_cache;
        while (1) {
            _xze_emit((temp + carry) & 255);
            temp = 0xFF;
            _xze_cache_size = _xze_cache_size - 1;
            if (_xze_cache_size == 0) { break; }
        }
        _xze_cache = (_xze_low >> 24) & 255;
    }
    _xze_cache_size = _xze_cache_size + 1;
    # `(UInt32)low << 8` in the reference is 32-bit arithmetic: the top
    # byte (already captured into `cache`, or held as a 0xFF run) is
    # dropped. Truncating to 32 bits keeps `low` a 33-bit value after the
    # next `low += bound`, so the carry stays a single bit.
    _xze_low = ((_xze_low & 0xFFFFFFFF) << 8) & 0xFFFFFFFF;
    return 0;
}

# Reset the range encoder over a fresh output window.
fn _xze_rc_reset(out, cap): i64 {
    _xze_low = 0;
    _xze_range = 0xFFFFFFFF;
    _xze_cache = 0;
    _xze_cache_size = 1;
    _xze_out = out;
    _xze_op = 0;
    _xze_out_cap = cap;
    _xze_overflow = 0;
    return 0;
}

# Encode one bit against the probability at slot `idx`; update the prob.
fn _xze_encode_bit(idx, bit): i64 {
    var p = load64(_xz_probs + idx * 8);
    var bound = (_xze_range >> 11) * p;
    if (bit == 0) {
        _xze_range = bound;
        p = p + ((2048 - p) >> 5);
    } else {
        _xze_low = _xze_low + bound;
        _xze_range = _xze_range - bound;
        p = p - (p >> 5);
    }
    store64(_xz_probs + idx * 8, p);
    if (_xze_range < 16777216) {
        _xze_range = (_xze_range << 8) & 0xFFFFFFFF;
        _xze_shift_low();
    }
    return 0;
}

# Encode `nbits` equiprobable bits of `value` (MSB first), no model.
fn _xze_encode_direct(value, nbits): i64 {
    var i = nbits;
    while (i > 0) {
        i = i - 1;
        _xze_range = (_xze_range >> 1) & 0xFFFFFFFF;
        var bit = (value >> i) & 1;
        _xze_low = _xze_low + (_xze_range * bit);
        if (_xze_range < 16777216) {
            _xze_range = (_xze_range << 8) & 0xFFFFFFFF;
            _xze_shift_low();
        }
    }
    return 0;
}

# Bit-tree encode, MSB-first — mirror of `_xz_bittree`.
fn _xze_bittree(base, nbits, symbol): i64 {
    var m = 1;
    var i = nbits;
    while (i > 0) {
        i = i - 1;
        var bit = (symbol >> i) & 1;
        _xze_encode_bit(base + m, bit);
        m = (m << 1) | bit;
    }
    return 0;
}

# Reverse bit-tree encode, LSB-first — mirror of `_xz_bittree_rev`.
fn _xze_bittree_rev(base, nbits, symbol): i64 {
    var m = 1;
    var i = 0;
    while (i < nbits) {
        var bit = symbol & 1;
        symbol = symbol >> 1;
        _xze_encode_bit(base + m, bit);
        m = (m << 1) | bit;
        i = i + 1;
    }
    return 0;
}

# Flush the range encoder — 5 ShiftLow calls drain low + cache.
fn _xze_flush(): i64 {
    var i = 0;
    while (i < 5) {
        _xze_shift_low();
        i = i + 1;
    }
    return 0;
}

# ---- encoder LZMA state ----
var _xze_state = 0;
var _xze_rep0 = 0;
var _xze_rep1 = 0;
var _xze_rep2 = 0;
var _xze_rep3 = 0;
var _xze_lc = 0;
var _xze_lp = 0;
var _xze_pb = 0;
var _xze_pos_mask = 0;
var _xze_lit_mask = 0;
var _xze_tmp = 0;       # scratch buffer for one chunk's range-coded bytes

# ---- container-writer cursor ----
var _xzc_out = 0;
var _xzc_op = 0;
var _xzc_cap = 0;
var _xzc_overflow = 0;

# Encoder defaults — lc=3, lp=0, pb=2 (the LZMA / xz default), dict code
# 8 → 65536 (>= the lz77 32 KB match window), check = CRC-64 (xz default).
enum XzEnc {
    XZE_LC = 3;
    XZE_LP = 0;
    XZE_PB = 2;
    XZE_PROPS = 93;          # (pb*5 + lp)*9 + lc
    XZE_DICT_CODE = 8;       # (2|0) << (8/2 + 11) = 65536
    XZE_MAX_UNCOMP = 2000000; # per-chunk uncompressed cap (< 2^21 fmt max,
    # leaves room for one trailing match)
    XZE_COMP_SOFT = 60000;    # per-chunk compressed soft cap (keeps comp < 64KB
    # even for incompressible input)
    XZE_TMP_CAP = 70000;      # chunk scratch size
    XZE_CHECK = 4;           # stream check type: CRC-64
    XZE_MATCH_MIN = 2;       # LZMA kMatchMinLen
    XZE_MATCH_MAX = 273;     # LZMA max match length (len code 271 + 2)
    XZE_OPT_W = 4096;        # block-DP window (price snapshot refresh span)
}

# Index of the highest set bit of x (x >= 1).
fn _xze_bsr(x): i64 {
    var n = 0;
    while (x > 1) {
        x = x >> 1;
        n = n + 1;
    }
    return n;
}

# Map a distance value (back_distance - 1) to its 6-bit LZMA pos-slot.
fn _xze_pos_slot(dist): i64 {
    if (dist < 4) { return dist; }
    var n = _xze_bsr(dist);
    return (n << 1) | ((dist >> (n - 1)) & 1);
}

# ---- container output helper ----
fn _xzc_put(b): i64 {
    if (_xzc_op < _xzc_cap) {
        store8(_xzc_out + _xzc_op, b & 255);
    } else {
        _xzc_overflow = 1;
    }
    _xzc_op = _xzc_op + 1;
    return 0;
}

# Write a 4-byte little-endian value.
fn _xzc_le32(v): i64 {
    _xzc_put(v & 255);
    _xzc_put((v >> 8) & 255);
    _xzc_put((v >> 16) & 255);
    _xzc_put((v >> 24) & 255);
    return 0;
}

# Write a multibyte (LEB128) integer.
fn _xzc_varint(v): i64 {
    while (v >= 128) {
        _xzc_put((v & 127) | 128);
        v = v >> 7;
    }
    _xzc_put(v & 127);
    return 0;
}

# ============================================================
# LZMA symbol emit (mirror of the decode state machine)
# ============================================================

# Encode the literal byte at src[pos] (state < 7: plain; >= 7: matched).
fn _xze_emit_literal(src, pos): i64 {
    var prev = 0;
    if (pos > 0) { prev = load8(src + pos - 1); }
    var lit_state = ((pos & _xze_lit_mask) << _xze_lc) + (prev >> (8 - _xze_lc));
    var base = XZ_OFF_LITERAL + 768 * lit_state;
    var symbol = load8(src + pos);

    if (_xze_state < 7) {
        var ctx = 1;
        var i = 8;
        while (i > 0) {
            i = i - 1;
            var bit = (symbol >> i) & 1;
            _xze_encode_bit(base + ctx, bit);
            ctx = (ctx << 1) | bit;
        }
    } else {
        var match_byte = load8(src + pos - _xze_rep0 - 1);
        var ctx = 1;
        var matching = 1;
        var i = 8;
        while (i > 0) {
            i = i - 1;
            var sbit = (symbol >> i) & 1;
            if (matching != 0) {
                var mbit = (match_byte >> i) & 1;
                _xze_encode_bit(base + ((1 + mbit) << 8) + ctx, sbit);
                ctx = (ctx << 1) | sbit;
                if (mbit != sbit) { matching = 0; }
            } else {
                _xze_encode_bit(base + ctx, sbit);
                ctx = (ctx << 1) | sbit;
            }
        }
    }
    return 0;
}

# Encode a length (0-based: actual length - 2) at `base`.
fn _xze_emit_len(base, len0, pos_state): i64 {
    if (len0 < 8) {
        _xze_encode_bit(base, 0);
        _xze_bittree(base + 2 + pos_state * 8, 3, len0);
    } elif (len0 < 16) {
        _xze_encode_bit(base, 1);
        _xze_encode_bit(base + 1, 0);
        _xze_bittree(base + 130 + pos_state * 8, 3, len0 - 8);
    } else {
        _xze_encode_bit(base, 1);
        _xze_encode_bit(base + 1, 1);
        _xze_bittree(base + 258, 8, len0 - 16);
    }
    return 0;
}

# Encode a match distance. `len0` = length-2, `dist` = back_distance - 1.
fn _xze_emit_dist(len0, dist): i64 {
    var len_state = len0;
    if (len_state > 3) { len_state = 3; }
    var pos_slot = _xze_pos_slot(dist);
    _xze_bittree(XZ_OFF_POSSLOT + len_state * 64, 6, pos_slot);

    if (pos_slot >= 4) {
        var num_direct = (pos_slot >> 1) - 1;
        var base_val = (2 | (pos_slot & 1)) << num_direct;
        var rest = dist - base_val;
        if (pos_slot < 14) {
            _xze_bittree_rev(XZ_OFF_SPECPOS + base_val - pos_slot, num_direct, rest);
        } else {
            _xze_encode_direct(rest >> 4, num_direct - 4);
            _xze_bittree_rev(XZ_OFF_ALIGN, 4, rest & 15);
        }
    }
    return 0;
}

# Emit one literal symbol (IsMatch=0 + the literal) and advance state.
fn _xze_op_literal(src, pos, pos_state): i64 {
    _xze_encode_bit(XZ_OFF_ISMATCH + (_xze_state << 4) + pos_state, 0);
    _xze_emit_literal(src, pos);
    if (_xze_state < 4) { _xze_state = 0; }
    elif (_xze_state < 10) { _xze_state = _xze_state - 3; }
    else { _xze_state = _xze_state - 6; }
    return 0;
}

# Emit one new-match symbol (length `len`, back-distance `back`) and
# update the rep history + state.
fn _xze_op_match(pos_state, len, back): i64 {
    _xze_encode_bit(XZ_OFF_ISMATCH + (_xze_state << 4) + pos_state, 1);
    _xze_encode_bit(XZ_OFF_ISREP + _xze_state, 0);
    var len0 = len - XZE_MATCH_MIN;
    _xze_emit_len(XZ_OFF_LENCODER, len0, pos_state);
    _xze_emit_dist(len0, back - 1);
    _xze_rep3 = _xze_rep2;
    _xze_rep2 = _xze_rep1;
    _xze_rep1 = _xze_rep0;
    _xze_rep0 = back - 1;
    if (_xze_state < 7) { _xze_state = 7; } else { _xze_state = 10; }
    return 0;
}

# Emit a short-rep (single byte at rep0). reps unchanged.
fn _xze_op_shortrep(pos_state): i64 {
    _xze_encode_bit(XZ_OFF_ISMATCH + (_xze_state << 4) + pos_state, 1);
    _xze_encode_bit(XZ_OFF_ISREP + _xze_state, 1);
    _xze_encode_bit(XZ_OFF_ISREPG0 + _xze_state, 0);
    _xze_encode_bit(XZ_OFF_ISREP0LONG + (_xze_state << 4) + pos_state, 0);
    if (_xze_state < 7) { _xze_state = 9; } else { _xze_state = 11; }
    return 0;
}

# Emit a long rep match (rep index `ri`, length `len`), rotating reps to
# match the decoder's rep-cycle exactly.
fn _xze_op_rep(pos_state, ri, len): i64 {
    _xze_encode_bit(XZ_OFF_ISMATCH + (_xze_state << 4) + pos_state, 1);
    _xze_encode_bit(XZ_OFF_ISREP + _xze_state, 1);
    if (ri == 0) {
        _xze_encode_bit(XZ_OFF_ISREPG0 + _xze_state, 0);
        _xze_encode_bit(XZ_OFF_ISREP0LONG + (_xze_state << 4) + pos_state, 1);
    } else {
        _xze_encode_bit(XZ_OFF_ISREPG0 + _xze_state, 1);
        var dist = 0;
        if (ri == 1) {
            _xze_encode_bit(XZ_OFF_ISREPG1 + _xze_state, 0);
            dist = _xze_rep1;
        } else {
            _xze_encode_bit(XZ_OFF_ISREPG1 + _xze_state, 1);
            if (ri == 2) {
                _xze_encode_bit(XZ_OFF_ISREPG2 + _xze_state, 0);
                dist = _xze_rep2;
                _xze_rep2 = _xze_rep1;
            } else {
                _xze_encode_bit(XZ_OFF_ISREPG2 + _xze_state, 1);
                dist = _xze_rep3;
                _xze_rep3 = _xze_rep2;
                _xze_rep2 = _xze_rep1;
            }
        }
        _xze_rep1 = _xze_rep0;
        _xze_rep0 = dist;
    }
    _xze_emit_len(XZ_OFF_REPLEN, len - XZE_MATCH_MIN, pos_state);
    if (_xze_state < 7) { _xze_state = 8; } else { _xze_state = 11; }
    return 0;
}

# ============================================================
# Optimal parse (price tables + block DP) + LZMA2 emit
# ============================================================
# Any parse is valid (the range coder is exact), so the optimizer only
# affects ratio. A forward DP over a bounded window minimizes the modeled
# bit-price of literal / normal-match / rep-match / short-rep moves, with
# rep-distance history tracked per path. Prices come from a ProbPrices
# table (LzmaEnc-style) read against the live probability model; the model
# is a snapshot per window, refreshed every window. Reference: LZMA SDK
# LzmaEnc.c GetOptimum + the price tables.

# ProbPrices[128] — cost (in 1/16-bit units) of one modeled bit at a
# representative probability. price(prob,0)=ProbPrices[prob>>4];
# price(prob,1)=ProbPrices[(2048-prob)>>4]. A direct (equiprobable) bit
# costs exactly 16.
var _xze_prices = 0;

# Block-DP arrays (size XZE_OPT_W + 1), allocated once.
var _xze_oc = 0;    # min price to reach window offset j
var _xze_os = 0;    # LZMA state of the best path at j
var _xze_o0 = 0;    # rep0 of the best path at j
var _xze_o1 = 0;
var _xze_o2 = 0;
var _xze_o3 = 0;
var _xze_olen = 0;  # length of the op arriving at j
var _xze_okind = 0; # 0 literal, 1 normal match, 2 rep, 3 short rep
var _xze_odist = 0; # normal: back-distance; rep/short: rep index

# Match-collection scratch (increasing length, min distance each).
var _xze_ml = 0;
var _xze_md = 0;

# Length-price cache: price of each length code (len0 0..271) at each
# pos-state (0..15) for the two length coders, recomputed once per DP
# window from the prob snapshot. Index: coder*16*272 + ps*272 + len0.
# Removes the per-length price_len recompute from the DP hot loops.
var _xze_lpc = 0;

# Backtrack op stack.
var _xze_stk_len = 0;
var _xze_stk_kind = 0;
var _xze_stk_dist = 0;

# Streaming chunk-emit state (chunks span DP windows).
var _xze_epos = 0;          # source position being emitted
var _xze_chunk_start = 0;   # source pos at the current chunk's start
var _xze_first_chunk = 0;
var _xze_enc_err = 0;

# Build ProbPrices (LzmaEnc_InitPriceTables): a fixed-point -log2 of the
# bit probability, in 1/16-bit units.
fn _xze_init_prices(): i64 {
    var i = 8;
    while (i < 2048) {
        var w = i;
        var bitcount = 0;
        var j = 0;
        while (j < 4) {
            w = w * w;
            bitcount = bitcount << 1;
            while (w >= 65536) {
                w = w >> 1;
                bitcount = bitcount + 1;
            }
            j = j + 1;
        }
        # (kNumBitModelTotalBits << kCyclesBits) - 15 - bitcount = 161 - bc
        store64(_xze_prices + (i >> 4) * 8, 161 - bitcount);
        i = i + 16;
    }
    return 0;
}

# Price of encoding one bit at probability slot `idx`.
fn _xze_pb(idx, bit): i64 {
    var p = load64(_xz_probs + idx * 8);
    if (bit == 0) {
        return load64(_xze_prices + (p >> 4) * 8);
    }
    return load64(_xze_prices + ((2048 - p) >> 4) * 8);
}

# Price of a forward bit-tree symbol.
fn _xze_price_tree(base, nbits, symbol): i64 {
    var m = 1;
    var price = 0;
    var i = nbits;
    while (i > 0) {
        i = i - 1;
        var bit = (symbol >> i) & 1;
        price = price + _xze_pb(base + m, bit);
        m = (m << 1) | bit;
    }
    return price;
}

# Price of a reverse bit-tree symbol.
fn _xze_price_tree_rev(base, nbits, symbol): i64 {
    var m = 1;
    var price = 0;
    var i = 0;
    while (i < nbits) {
        var bit = symbol & 1;
        symbol = symbol >> 1;
        price = price + _xze_pb(base + m, bit);
        m = (m << 1) | bit;
        i = i + 1;
    }
    return price;
}

# Price of a length code (len0 = actual length - 2).
fn _xze_price_len(base, len0, pos_state): i64 {
    if (len0 < 8) {
        return _xze_pb(base, 0) + _xze_price_tree(base + 2 + pos_state * 8, 3, len0);
    }
    if (len0 < 16) {
        return _xze_pb(base, 1) + _xze_pb(base + 1, 0)
        + _xze_price_tree(base + 130 + pos_state * 8, 3, len0 - 8);
    }
    return _xze_pb(base, 1) + _xze_pb(base + 1, 1)
    + _xze_price_tree(base + 258, 8, len0 - 16);
}

# Price of a match distance (len0 = length-2, dist = back_distance - 1).
fn _xze_price_dist(len0, dist): i64 {
    var len_state = len0;
    if (len_state > 3) { len_state = 3; }
    var pos_slot = _xze_pos_slot(dist);
    var price = _xze_price_tree(XZ_OFF_POSSLOT + len_state * 64, 6, pos_slot);
    if (pos_slot >= 4) {
        var num_direct = (pos_slot >> 1) - 1;
        var base_val = (2 | (pos_slot & 1)) << num_direct;
        var rest = dist - base_val;
        if (pos_slot < 14) {
            price = price + _xze_price_tree_rev(XZ_OFF_SPECPOS + base_val - pos_slot, num_direct, rest);
        } else {
            price = price + (num_direct - 4) * 16
            + _xze_price_tree_rev(XZ_OFF_ALIGN, 4, rest & 15);
        }
    }
    return price;
}

# Price of a literal at src[pos] given state + rep0 (for matched literals).
fn _xze_price_literal(state, pos, src, r0): i64 {
    var prev = 0;
    if (pos > 0) { prev = load8(src + pos - 1); }
    var lit_state = ((pos & _xze_lit_mask) << _xze_lc) + (prev >> (8 - _xze_lc));
    var base = XZ_OFF_LITERAL + 768 * lit_state;
    var symbol = load8(src + pos);
    var price = 0;
    if (state < 7) {
        var ctx = 1;
        var i = 8;
        while (i > 0) {
            i = i - 1;
            var bit = (symbol >> i) & 1;
            price = price + _xze_pb(base + ctx, bit);
            ctx = (ctx << 1) | bit;
        }
    } else {
        var match_byte = load8(src + pos - r0 - 1);
        var ctx = 1;
        var matching = 1;
        var i = 8;
        while (i > 0) {
            i = i - 1;
            var sbit = (symbol >> i) & 1;
            if (matching != 0) {
                var mbit = (match_byte >> i) & 1;
                price = price + _xze_pb(base + ((1 + mbit) << 8) + ctx, sbit);
                ctx = (ctx << 1) | sbit;
                if (mbit != sbit) { matching = 0; }
            } else {
                price = price + _xze_pb(base + ctx, sbit);
                ctx = (ctx << 1) | sbit;
            }
        }
    }
    return price;
}

# Price of the rep-index selection bits for rep `ri` (long rep, len>=2),
# excluding the IsMatch/IsRep bits the caller already counted.
fn _xze_price_rep_select(state, pos_state, ri): i64 {
    if (ri == 0) {
        return _xze_pb(XZ_OFF_ISREPG0 + state, 0)
        + _xze_pb(XZ_OFF_ISREP0LONG + (state << 4) + pos_state, 1);
    }
    var p = _xze_pb(XZ_OFF_ISREPG0 + state, 1);
    if (ri == 1) {
        p = p + _xze_pb(XZ_OFF_ISREPG1 + state, 0);
    } else {
        p = p + _xze_pb(XZ_OFF_ISREPG1 + state, 1);
        if (ri == 2) {
            p = p + _xze_pb(XZ_OFF_ISREPG2 + state, 0);
        } else {
            p = p + _xze_pb(XZ_OFF_ISREPG2 + state, 1);
        }
    }
    return p;
}

# Collect matches at src[pos] from the lz77 hash chain into _xze_ml/_xze_md
# (increasing length, smallest distance for each). Returns the count.
fn _xze_get_matches(src, src_len, pos, max_avail): i64 {
    var cnt = 0;
    var maxlen = src_len - pos;
    if (maxlen > XZE_MATCH_MAX) { maxlen = XZE_MATCH_MAX; }
    if (maxlen > max_avail) { maxlen = max_avail; }
    if (maxlen < LZ77_MIN_MATCH) { return 0; }

    var h = _lz77_hash3(src, pos);
    var chain = load64(_lz77_head + h * 8);
    var best = LZ77_MIN_MATCH - 1;
    var depth = 0;
    while (depth < _lz77_chain_depth) {
        if (chain < 0) { break; }
        var dist = pos - chain;          # batch mode: window_base == 0
        if (dist <= 0 || dist > LZ77_WINDOW) { break; }
        var l = 0;
        while (l < maxlen && load8(src + chain + l) == load8(src + pos + l)) {
            l = l + 1;
        }
        if (l > best) {
            store64(_xze_ml + cnt * 8, l);
            store64(_xze_md + cnt * 8, dist);
            cnt = cnt + 1;
            best = l;
            if (l >= maxlen) { break; }
        }
        chain = load64(_lz77_prev + (chain & LZ77_HASH_MASK) * 8);
        depth = depth + 1;
    }
    return cnt;
}

# Relax window slot `idx` if `cost` improves it.
fn _xze_relax(idx, cost, st, r0, r1, r2, r3, ln, kind, di): i64 {
    if (cost < load64(_xze_oc + idx * 8)) {
        store64(_xze_oc + idx * 8, cost);
        store64(_xze_os + idx * 8, st);
        store64(_xze_o0 + idx * 8, r0);
        store64(_xze_o1 + idx * 8, r1);
        store64(_xze_o2 + idx * 8, r2);
        store64(_xze_o3 + idx * 8, r3);
        store64(_xze_olen + idx * 8, ln);
        store64(_xze_okind + idx * 8, kind);
        store64(_xze_odist + idx * 8, di);
    }
    return 0;
}

# Precompute the length-price cache from the current prob snapshot.
fn _xze_fill_len_prices(): i64 {
    var c = 0;
    while (c < 2) {
        var base = XZ_OFF_LENCODER;
        if (c == 1) { base = XZ_OFF_REPLEN; }
        var ps = 0;
        while (ps < 16) {
            var row = c * 16 * 272 + ps * 272;
            var len0 = 0;
            while (len0 < 272) {
                store64(_xze_lpc + (row + len0) * 8, _xze_price_len(base, len0, ps));
                len0 = len0 + 1;
            }
            ps = ps + 1;
        }
        c = c + 1;
    }
    return 0;
}

# Cached length price (coder 0 = LenCoder, 1 = RepLenCoder).
fn _xze_lp(coder, ps, len0): i64 {
    return load64(_xze_lpc + (coder * 16 * 272 + ps * 272 + len0) * 8);
}

# Fill the block-DP arrays for the window [base_pos, base_pos+W]. Inserts
# every scanned position into the hash chain. Uses the live probability
# model (snapshot) for prices; the path's start state is the encoder's
# current _xze_state / _xze_rep*.
fn _xze_dp_fill(src, src_len, base_pos, W): i64 {
    var INF = 1152921504606846976;   # 2^60
    _xze_fill_len_prices();
    var j = 0;
    while (j <= W) {
        store64(_xze_oc + j * 8, INF);
        j = j + 1;
    }
    store64(_xze_oc, 0);
    store64(_xze_os, _xze_state);
    store64(_xze_o0, _xze_rep0);
    store64(_xze_o1, _xze_rep1);
    store64(_xze_o2, _xze_rep2);
    store64(_xze_o3, _xze_rep3);

    j = 0;
    while (j < W) {
        var pos = base_pos + j;
        var avail = W - j;
        var mcount = _xze_get_matches(src, src_len, pos, avail);
        if (pos + LZ77_MIN_MATCH <= src_len) { _lz77_insert(src, pos); }

        var base = load64(_xze_oc + j * 8);
        if (base < INF) {
            var s = load64(_xze_os + j * 8);
            var r0 = load64(_xze_o0 + j * 8);
            var r1 = load64(_xze_o1 + j * 8);
            var r2 = load64(_xze_o2 + j * 8);
            var r3 = load64(_xze_o3 + j * 8);
            var ps = pos & _xze_pos_mask;
            var ismatch = XZ_OFF_ISMATCH + (s << 4) + ps;

            # literal
            var nst = 0;
            if (s < 4) { nst = 0; } elif (s < 10) { nst = s - 3; } else { nst = s - 6; }
            var litp = base + _xze_pb(ismatch, 0) + _xze_price_literal(s, pos, src, r0);
            _xze_relax(j + 1, litp, nst, r0, r1, r2, r3, 1, 0, 0);

            var matchp = base + _xze_pb(ismatch, 1);
            var repp = matchp + _xze_pb(XZ_OFF_ISREP + s, 1);
            var normp = matchp + _xze_pb(XZ_OFF_ISREP + s, 0);
            var rep_state = 11;
            if (s < 7) { rep_state = 8; }
            var short_state = 11;
            if (s < 7) { short_state = 9; }
            var match_state = 10;
            if (s < 7) { match_state = 7; }

            # rep matches (rep indices 0..3)
            var ri = 0;
            while (ri < 4) {
                var rd = 0;
                if (ri == 0) { rd = r0; } elif (ri == 1) { rd = r1; }
                elif (ri == 2) { rd = r2; } else { rd = r3; }
                rd = rd + 1;   # back distance
                if (pos - rd >= 0) {
                    var rmax = avail;
                    if (rmax > XZE_MATCH_MAX) { rmax = XZE_MATCH_MAX; }
                    var rl = 0;
                    while (rl < rmax && load8(src + pos + rl) == load8(src + pos - rd + rl)) {
                        rl = rl + 1;
                    }
                    # rotated rep set for this ri
                    var q0 = r0; var q1 = r1; var q2 = r2; var q3 = r3;
                    if (ri == 1) { q0 = r1; q1 = r0; }
                    elif (ri == 2) { q0 = r2; q1 = r0; q2 = r1; }
                    elif (ri == 3) { q0 = r3; q1 = r0; q2 = r1; q3 = r2; }
                    if (ri == 0 && rl >= 1) {
                        var sp = repp + _xze_pb(XZ_OFF_ISREPG0 + s, 0)
                        + _xze_pb(XZ_OFF_ISREP0LONG + (s << 4) + ps, 0);
                        _xze_relax(j + 1, sp, short_state, r0, r1, r2, r3, 1, 3, 0);
                    }
                    if (rl >= 2) {
                        var sel = repp + _xze_price_rep_select(s, ps, ri);
                        var l = 2;
                        while (l <= rl) {
                            var rp = sel + _xze_lp(1, ps, l - 2);
                            _xze_relax(j + l, rp, rep_state, q0, q1, q2, q3, l, 2, ri);
                            l = l + 1;
                        }
                    }
                }
                ri = ri + 1;
            }

            # normal matches
            var mi = 0;
            var prev_len = LZ77_MIN_MATCH - 1;
            while (mi < mcount) {
                var mlen = load64(_xze_ml + mi * 8);
                var mdist = load64(_xze_md + mi * 8);
                var l = prev_len + 1;
                while (l <= mlen) {
                    var np = normp + _xze_lp(0, ps, l - 2)
                    + _xze_price_dist(l - 2, mdist - 1);
                    _xze_relax(j + l, np, match_state, mdist - 1, r0, r1, r2, l, 1, mdist);
                    l = l + 1;
                }
                prev_len = mlen;
                mi = mi + 1;
            }
        }
        j = j + 1;
    }
    return 0;
}

# ---- streaming chunk emit ----

fn _xze_start_chunk(): i64 {
    _xze_chunk_start = _xze_epos;
    _xze_rc_reset(_xze_tmp, XZE_TMP_CAP);
    return 0;
}

fn _xze_finish_chunk(): i64 {
    _xze_flush();
    var comp = _xze_op;
    var uncomp = _xze_epos - _xze_chunk_start;
    if (_xze_overflow != 0 || comp > 65536) { _xze_enc_err = 1; return 0; }
    var reset = 0;
    if (_xze_first_chunk != 0) { reset = 3; }
    _xzc_put(128 | (reset << 5) | (((uncomp - 1) >> 16) & 31));
    _xzc_put(((uncomp - 1) >> 8) & 255);
    _xzc_put((uncomp - 1) & 255);
    _xzc_put(((comp - 1) >> 8) & 255);
    _xzc_put((comp - 1) & 255);
    if (reset >= 2) { _xzc_put(XZE_PROPS); }
    var i = 0;
    while (i < comp) {
        _xzc_put(load8(_xze_tmp + i));
        i = i + 1;
    }
    _xze_first_chunk = 0;
    return 0;
}

# Emit one op, cutting the LZMA2 chunk first if the current one is full.
fn _xze_emit_op(src, kind, ln, di): i64 {
    if ((_xze_epos - _xze_chunk_start) >= XZE_MAX_UNCOMP || _xze_op >= XZE_COMP_SOFT) {
        _xze_finish_chunk();
        _xze_start_chunk();
    }
    var ps = _xze_epos & _xze_pos_mask;
    if (kind == 0) {
        _xze_op_literal(src, _xze_epos, ps);
    } elif (kind == 1) {
        _xze_op_match(ps, ln, di);
    } elif (kind == 2) {
        _xze_op_rep(ps, di, ln);
    } else {
        _xze_op_shortrep(ps);
    }
    _xze_epos = _xze_epos + ln;
    return 0;
}

# Backtrack the DP window and emit its ops in forward order.
fn _xze_dp_emit(src, base_pos, W): i64 {
    var cnt = 0;
    var j = W;
    while (j > 0) {
        var ln = load64(_xze_olen + j * 8);
        store64(_xze_stk_len + cnt * 8, ln);
        store64(_xze_stk_kind + cnt * 8, load64(_xze_okind + j * 8));
        store64(_xze_stk_dist + cnt * 8, load64(_xze_odist + j * 8));
        cnt = cnt + 1;
        j = j - ln;
    }
    var i = cnt;
    while (i > 0) {
        i = i - 1;
        _xze_emit_op(src, load64(_xze_stk_kind + i * 8), load64(_xze_stk_len + i * 8),
        load64(_xze_stk_dist + i * 8));
    }
    return 0;
}

# Optimal-parse encode of src[0..src_len) into LZMA2 chunks. Returns the
# LZMA2 byte count (incl. 0x00 end marker), or negative error.
fn _xze_lzma2_emit(src, src_len): i64 {
    var lz2_start = _xzc_op;
    _xze_state = 0;
    _xze_rep0 = 0;
    _xze_rep1 = 0;
    _xze_rep2 = 0;
    _xze_rep3 = 0;
    _xz_reset_probs();
    _xze_init_prices();

    _xze_epos = 0;
    _xze_first_chunk = 1;
    _xze_enc_err = 0;
    _xze_start_chunk();

    var pos = 0;
    while (pos < src_len) {
        var W = src_len - pos;
        if (W > XZE_OPT_W) { W = XZE_OPT_W; }
        _xze_dp_fill(src, src_len, pos, W);
        _xze_dp_emit(src, pos, W);
        if (_xze_enc_err != 0) { return 0 - ERR_BUFFER_TOO_SMALL; }
        pos = pos + W;
    }
    _xze_finish_chunk();
    if (_xze_enc_err != 0) { return 0 - ERR_BUFFER_TOO_SMALL; }
    _xzc_put(0);   # LZMA2 end marker
    return _xzc_op - lz2_start;
}

# Compress src → .xz stream in dst. Inner entry — caller holds the lock.
fn _xz_compress_inner(src, src_len, dst, dst_cap): i64 {
    # Lazy allocations.
    if (_xz_probs == 0) {
        _xz_probs = _sankoch_alloc(XZ_PROBS_TOTAL * 8);
        if (_xz_probs == 0) { return 0 - ERR_OOM; }
    }
    if (_xze_tmp == 0) {
        _xze_tmp = _sankoch_alloc(XZE_TMP_CAP);
        if (_xze_tmp == 0) { return 0 - ERR_OOM; }
    }
    if (_xze_prices == 0) {
        # ProbPrices[128]; DP arrays sized OPT_W+1; match + op-stack scratch.
        _xze_prices = _sankoch_alloc(128 * 8);
        if (_xze_prices == 0) { return 0 - ERR_OOM; }
        var dpn = (XZE_OPT_W + 1) * 8;
        _xze_oc = _sankoch_alloc(dpn);
        _xze_os = _sankoch_alloc(dpn);
        _xze_o0 = _sankoch_alloc(dpn);
        _xze_o1 = _sankoch_alloc(dpn);
        _xze_o2 = _sankoch_alloc(dpn);
        _xze_o3 = _sankoch_alloc(dpn);
        _xze_olen = _sankoch_alloc(dpn);
        _xze_okind = _sankoch_alloc(dpn);
        _xze_odist = _sankoch_alloc(dpn);
        _xze_stk_len = _sankoch_alloc(dpn);
        _xze_stk_kind = _sankoch_alloc(dpn);
        _xze_stk_dist = _sankoch_alloc(dpn);
        _xze_ml = _sankoch_alloc((XZE_MATCH_MAX + 1) * 8);
        _xze_md = _sankoch_alloc((XZE_MATCH_MAX + 1) * 8);
        _xze_lpc = _sankoch_alloc(2 * 16 * 272 * 8);
        if (_xze_lpc == 0 || _xze_oc == 0 || _xze_os == 0 || _xze_o0 == 0 || _xze_o1 == 0
        || _xze_o2 == 0 || _xze_o3 == 0 || _xze_olen == 0 || _xze_okind == 0
        || _xze_odist == 0 || _xze_stk_len == 0 || _xze_stk_kind == 0
        || _xze_stk_dist == 0 || _xze_ml == 0 || _xze_md == 0) {
            return 0 - ERR_OOM;
        }
    }
    if (lz77_init() < 0) { return 0 - ERR_OOM; }
    lz77_set_level(9);
    if (crc32_init_table() < 0) { return 0 - ERR_OOM; }
    if (crc64_init_table() < 0) { return 0 - ERR_OOM; }

    _xze_lc = XZE_LC;
    _xze_lp = XZE_LP;
    _xze_pb = XZE_PB;
    _xze_pos_mask = (1 << XZE_PB) - 1;
    _xze_lit_mask = (1 << XZE_LP) - 1;

    _xzc_out = dst;
    _xzc_op = 0;
    _xzc_cap = dst_cap;
    _xzc_overflow = 0;

    # ---- stream header ----
    _xzc_put(0xFD); _xzc_put(0x37); _xzc_put(0x7A);
    _xzc_put(0x58); _xzc_put(0x5A); _xzc_put(0x00);
    _xzc_put(0x00); _xzc_put(XZE_CHECK);   # stream flags
    # CRC32 of the 2 stream-flags bytes (build in scratch to avoid
    # re-reading a possibly-overflowed dst).
    store8(_xze_tmp, 0x00);
    store8(_xze_tmp + 1, XZE_CHECK);
    _xzc_le32(crc32(_xze_tmp, 2));

    var block_unpadded = 0;
    if (src_len > 0) {
        # ---- block header (fixed: single LZMA2 filter, no sizes) ----
        var bh = _xzc_op;
        _xzc_put(0x02);          # header size: (2+1)*4 = 12
        _xzc_put(0x00);          # block flags: 1 filter, no comp/uncomp size
        _xzc_put(0x21);          # filter id: LZMA2
        _xzc_put(0x01);          # size of properties
        _xzc_put(XZE_DICT_CODE); # LZMA2 dict-size code
        _xzc_put(0x00); _xzc_put(0x00); _xzc_put(0x00);   # header padding
        if (_xzc_overflow != 0) { return 0 - ERR_BUFFER_TOO_SMALL; }
        _xzc_le32(crc32(dst + bh, 8));   # header CRC32

        # ---- LZMA2 payload ----
        var lz2 = _xze_lzma2_emit(src, src_len);
        if (lz2 < 0) { return lz2; }

        # ---- block padding ----
        while (((_xzc_op - bh) & 3) != 0) { _xzc_put(0); }

        # ---- check field (CRC-64 of the uncompressed data) ----
        var chk = crc64(src, src_len);
        _xzc_le32(chk & 0xFFFFFFFF);
        _xzc_le32((chk >> 32) & 0xFFFFFFFF);

        block_unpadded = 12 + lz2 + 8;
    }

    # ---- index ----
    var idx = _xzc_op;
    _xzc_put(0x00);   # index indicator
    if (src_len > 0) {
        _xzc_varint(1);
        _xzc_varint(block_unpadded);
        _xzc_varint(src_len);
    } else {
        _xzc_varint(0);
    }
    while (((_xzc_op - idx) & 3) != 0) { _xzc_put(0); }
    if (_xzc_overflow != 0) { return 0 - ERR_BUFFER_TOO_SMALL; }
    _xzc_le32(crc32(dst + idx, _xzc_op - idx));
    var index_size = _xzc_op - idx;

    # ---- stream footer ----
    var backward = index_size / 4 - 1;
    # footer CRC32 covers Backward Size (4) + Stream Flags (2).
    store8(_xze_tmp, backward & 255);
    store8(_xze_tmp + 1, (backward >> 8) & 255);
    store8(_xze_tmp + 2, (backward >> 16) & 255);
    store8(_xze_tmp + 3, (backward >> 24) & 255);
    store8(_xze_tmp + 4, 0x00);
    store8(_xze_tmp + 5, XZE_CHECK);
    _xzc_le32(crc32(_xze_tmp, 6));
    _xzc_le32(backward);
    _xzc_put(0x00); _xzc_put(XZE_CHECK);
    _xzc_put(0x59); _xzc_put(0x5A);   # footer magic "YZ"

    if (_xzc_overflow != 0) { return 0 - ERR_BUFFER_TOO_SMALL; }
    return _xzc_op;
}

# Public: compress src → .xz stream. Thread-safe wrapper.
fn xz_compress(src, src_len, dst, dst_cap): i64 {
    if (src_len < 0 || dst_cap < 0) { return 0 - ERR_INVALID_INPUT; }
    _sankoch_lock();
    var r = _xz_compress_inner(src, src_len, dst, dst_cap);
    _sankoch_unlock();
    return r;
}

# --- bzip2.cyr ---

# sankoch — bzip2 decode (.bz2 stream → original)
#
# Decode only — no encoder (the forward BWT block-sort is a separate
# 2.4.3 deliverable). Added at 2.4.2 to round out `.tar.bz2` extraction
# alongside the 2.4.0 xz decode path.
#
# bzip2 pipeline (compressed → original), decoded in reverse:
#   Huffman decode → MTF + RLE2 inverse → inverse BWT (Burrows-Wheeler)
#   → RLE1 inverse. Bits are read MSB-first (big-endian bit order),
#   unlike DEFLATE's LSB-first stream — hence a dedicated bit reader.
#
# References:
#   - bzip2 / libbzip2 1.0.8 `decompress.c` (decode reference shape)
#   - "bzip2 and libbzip2" manual (stream / block layout)
#   - The per-block + combined check uses CRC-32/BZIP2 (non-reflected),
#     supplied by checksum.cyr.
#
# All state is in flat globals behind `_sankoch_mtx` (taken by the public
# entry in lib.cyr), consistent with the rest of the library. The large
# BWT pointer table `_bz_tt` (one i64 per block byte, up to 900 K) is a
# lazily-allocated singleton reused across calls.

enum Bz2 {
    BZ_MAX_ALPHA = 258;       # 256 symbols + RUNA/RUNB collapsed + EOB
    BZ_MAX_CODE_LEN = 24;     # bzip2 caps code lengths at 20; 24 = headroom
    BZ_N_GROUPS = 6;
    BZ_G_SIZE = 50;
    BZ_MAX_SELECTORS = 18002; # 2 + 900000/50
    BZ_RUNA = 0;
    BZ_RUNB = 1;
    BZ_MAX_BLOCK = 900000;    # level 9 = 900 KB
}

# ---- MSB-first bit reader ----
var _bz_in = 0;
var _bz_in_pos = 0;
var _bz_in_end = 0;
var _bz_bit_buf = 0;     # holds the unconsumed low bits only
var _bz_bit_cnt = 0;
var _bz_err = 0;         # sticky: input exhausted / malformed

# ---- output window ----
var _bz_dst = 0;
var _bz_dp = 0;
var _bz_dst_cap = 0;

# ---- per-block working tables (lazily allocated singletons) ----
var _bz_limit = 0;       # [6][24]
var _bz_base = 0;        # [6][24]
var _bz_perm = 0;        # [6][258]
var _bz_minlens = 0;     # [6]
var _bz_len = 0;         # [6][258] code lengths
var _bz_selector = 0;    # [18002]
var _bz_selmtf = 0;      # [18002]
var _bz_inuse = 0;       # [256]
var _bz_seq = 0;         # [256] seqToUnseq
var _bz_mtf = 0;         # [256] move-to-front list of compact indices
var _bz_unzftab = 0;     # [256] per-byte frequency
var _bz_cftab = 0;       # [257] cumulative counts
var _bz_tt = 0;          # [900000] BWT vector: byte | (ptr << 8)

# ---- Huffman group cursor (drives _bz_get_mtf) ----
var _bz_nsel = 0;
var _bz_group_no = 0;
var _bz_group_pos = 0;
var _bz_gsel = 0;
var _bz_alpha = 0;

# Read `n` bits MSB-first (n <= 24). Past end-of-input feeds 0 and trips
# `_bz_err` — never reads OOB.
fn _bz_bits(n): i64 {
    while (_bz_bit_cnt < n) {
        if (_bz_in_pos >= _bz_in_end) {
            _bz_err = 1;
            return 0;
        }
        _bz_bit_buf = (_bz_bit_buf << 8) | load8(_bz_in + _bz_in_pos);
        _bz_in_pos = _bz_in_pos + 1;
        _bz_bit_cnt = _bz_bit_cnt + 8;
    }
    _bz_bit_cnt = _bz_bit_cnt - n;
    var v = (_bz_bit_buf >> _bz_bit_cnt) & ((1 << n) - 1);
    _bz_bit_buf = _bz_bit_buf & ((1 << _bz_bit_cnt) - 1);   # drop consumed bits
    return v;
}

# Read a 32-bit value (CRC fields) as two MSB-first halves.
fn _bz_bits32(): i64 {
    return ((_bz_bits(16) << 16) | _bz_bits(16)) & 0xFFFFFFFF;
}

# Build the canonical Huffman decode tables for group `t`
# (libbzip2 hbCreateDecodeTables). `_bz_len[t]` holds the code lengths.
fn _bz_make_tables(t, min_len, max_len): i64 {
    var lbase = t * BZ_MAX_CODE_LEN;
    var pbase = t * BZ_MAX_ALPHA;
    var alpha = _bz_alpha;

    var pp = 0;
    var i = min_len;
    while (i <= max_len) {
        var s = 0;
        while (s < alpha) {
            if (load64(_bz_len + (pbase + s) * 8) == i) {
                store64(_bz_perm + (pbase + pp) * 8, s);
                pp = pp + 1;
            }
            s = s + 1;
        }
        i = i + 1;
    }

    i = 0;
    while (i < BZ_MAX_CODE_LEN) {
        store64(_bz_base + (lbase + i) * 8, 0);
        store64(_bz_limit + (lbase + i) * 8, 0);
        i = i + 1;
    }
    var s = 0;
    while (s < alpha) {
        var idx = lbase + load64(_bz_len + (pbase + s) * 8) + 1;
        store64(_bz_base + idx * 8, load64(_bz_base + idx * 8) + 1);
        s = s + 1;
    }
    i = 1;
    while (i < BZ_MAX_CODE_LEN) {
        store64(_bz_base + (lbase + i) * 8,
        load64(_bz_base + (lbase + i) * 8) + load64(_bz_base + (lbase + i - 1) * 8));
        i = i + 1;
    }

    var vec = 0;
    i = min_len;
    while (i <= max_len) {
        vec = vec + (load64(_bz_base + (lbase + i + 1) * 8) - load64(_bz_base + (lbase + i) * 8));
        store64(_bz_limit + (lbase + i) * 8, vec - 1);
        vec = vec << 1;
        i = i + 1;
    }
    i = min_len + 1;
    while (i <= max_len) {
        var nb = ((load64(_bz_limit + (lbase + i - 1) * 8) + 1) << 1)
        - load64(_bz_base + (lbase + i) * 8);
        store64(_bz_base + (lbase + i) * 8, nb);
        i = i + 1;
    }
    return 0;
}

# Decode one Huffman symbol from the current 50-symbol group, advancing
# the group/selector cursor. Returns the symbol, or negative on error.
fn _bz_get_mtf(): i64 {
    if (_bz_group_pos == 0) {
        _bz_group_no = _bz_group_no + 1;
        if (_bz_group_no >= _bz_nsel) { return 0 - ERR_CORRUPT_DATA; }
        _bz_group_pos = BZ_G_SIZE;
        _bz_gsel = load64(_bz_selector + _bz_group_no * 8);
    }
    _bz_group_pos = _bz_group_pos - 1;
    var t = _bz_gsel;
    var lbase = t * BZ_MAX_CODE_LEN;
    var zn = load64(_bz_minlens + t * 8);
    var zvec = _bz_bits(zn);
    while (1) {
        if (zn > 20) { return 0 - ERR_INVALID_HUFFMAN; }
        if (zvec <= load64(_bz_limit + (lbase + zn) * 8)) { break; }
        zn = zn + 1;
        zvec = (zvec << 1) | _bz_bits(1);
    }
    var idx = zvec - load64(_bz_base + (lbase + zn) * 8);
    if (idx < 0 || idx >= _bz_alpha) { return 0 - ERR_INVALID_HUFFMAN; }
    return load64(_bz_perm + (t * BZ_MAX_ALPHA + idx) * 8);
}

# Decode one block body (after the 48-bit block magic) into the output
# window. `level` bounds the block size. Returns the block's emitted
# length, or negative error.
fn _bz_decode_block(level): i64 {
    var block_crc = _bz_bits32();
    if (_bz_bits(1) != 0) { return 0 - ERR_UNSUPPORTED_FORMAT; }   # randomized (extinct)
    var orig_ptr = _bz_bits(24);

    # ---- symbol map (which byte values are used) ----
    var in_use16 = _bz_bits(16);
    var i = 0;
    while (i < 256) { store64(_bz_inuse + i * 8, 0); i = i + 1; }
    i = 0;
    while (i < 16) {
        if (((in_use16 >> (15 - i)) & 1) != 0) {
            var bits = _bz_bits(16);
            var j = 0;
            while (j < 16) {
                if (((bits >> (15 - j)) & 1) != 0) {
                    store64(_bz_inuse + (i * 16 + j) * 8, 1);
                }
                j = j + 1;
            }
        }
        i = i + 1;
    }
    var n_in_use = 0;
    i = 0;
    while (i < 256) {
        if (load64(_bz_inuse + i * 8) != 0) {
            store64(_bz_seq + n_in_use * 8, i);
            n_in_use = n_in_use + 1;
        }
        i = i + 1;
    }
    if (n_in_use == 0) { return 0 - ERR_CORRUPT_DATA; }
    _bz_alpha = n_in_use + 2;
    var eob = n_in_use + 1;

    # ---- Huffman groups + selectors ----
    var n_groups = _bz_bits(3);
    if (n_groups < 2 || n_groups > 6) { return 0 - ERR_CORRUPT_DATA; }
    var n_sel = _bz_bits(15);
    if (n_sel < 1 || n_sel > BZ_MAX_SELECTORS) { return 0 - ERR_CORRUPT_DATA; }
    _bz_nsel = n_sel;

    i = 0;
    while (i < n_sel) {
        var v = 0;
        while (_bz_bits(1) == 1) {
            v = v + 1;
            if (v >= n_groups) { return 0 - ERR_CORRUPT_DATA; }
        }
        store64(_bz_selmtf + i * 8, v);
        i = i + 1;
    }
    # undo the MTF on the selector list
    var pos[6];
    i = 0;
    while (i < n_groups) { store64(&pos + i * 8, i); i = i + 1; }
    i = 0;
    while (i < n_sel) {
        var v = load64(_bz_selmtf + i * 8);
        var tmp = load64(&pos + v * 8);
        while (v > 0) {
            store64(&pos + v * 8, load64(&pos + (v - 1) * 8));
            v = v - 1;
        }
        store64(&pos, tmp);
        store64(_bz_selector + i * 8, tmp);
        i = i + 1;
    }

    # ---- read the per-group code-length tables ----
    var t = 0;
    while (t < n_groups) {
        var curr = _bz_bits(5);
        var s = 0;
        while (s < _bz_alpha) {
            while (1) {
                if (curr < 1 || curr > 20) { return 0 - ERR_INVALID_HUFFMAN; }
                if (_bz_bits(1) == 0) { break; }
                if (_bz_bits(1) == 0) { curr = curr + 1; } else { curr = curr - 1; }
            }
            store64(_bz_len + (t * BZ_MAX_ALPHA + s) * 8, curr);
            s = s + 1;
        }
        t = t + 1;
    }
    t = 0;
    while (t < n_groups) {
        var min_len = 32;
        var max_len = 0;
        var s = 0;
        while (s < _bz_alpha) {
            var l = load64(_bz_len + (t * BZ_MAX_ALPHA + s) * 8);
            if (l > max_len) { max_len = l; }
            if (l < min_len) { min_len = l; }
            s = s + 1;
        }
        store64(_bz_minlens + t * 8, min_len);
        _bz_make_tables(t, min_len, max_len);
        t = t + 1;
    }
    if (_bz_err != 0) { return 0 - ERR_CORRUPT_DATA; }

    # ---- main decode: Huffman → MTF + RLE2 → BWT vector tt[] ----
    i = 0;
    while (i < 256) { store64(_bz_unzftab + i * 8, 0); i = i + 1; }
    i = 0;
    while (i < n_in_use) { store64(_bz_mtf + i * 8, i); i = i + 1; }

    _bz_group_no = 0 - 1;
    _bz_group_pos = 0;
    var blockmax = level * 100000;
    var nblock = 0;

    var nextsym = _bz_get_mtf();
    if (nextsym < 0) { return nextsym; }
    while (nextsym != eob) {
        if (nextsym == BZ_RUNA || nextsym == BZ_RUNB) {
            # bijective base-2 run length of the MTF-front symbol
            var run = 0;
            var rbit = 1;
            while (nextsym == BZ_RUNA || nextsym == BZ_RUNB) {
                if (nextsym == BZ_RUNA) { run = run + rbit; } else { run = run + rbit + rbit; }
                rbit = rbit << 1;
                if (rbit > blockmax + 1) { return 0 - ERR_CORRUPT_DATA; }
                nextsym = _bz_get_mtf();
                if (nextsym < 0) { return nextsym; }
            }
            var uc = load64(_bz_seq + load64(_bz_mtf) * 8);
            store64(_bz_unzftab + uc * 8, load64(_bz_unzftab + uc * 8) + run);
            if (nblock + run > blockmax) { return 0 - ERR_CORRUPT_DATA; }
            while (run > 0) {
                store64(_bz_tt + nblock * 8, uc);
                nblock = nblock + 1;
                run = run - 1;
            }
        } else {
            # MTF index = nextsym - 1
            var nn = nextsym - 1;
            var tmp = load64(_bz_mtf + nn * 8);
            while (nn > 0) {
                store64(_bz_mtf + nn * 8, load64(_bz_mtf + (nn - 1) * 8));
                nn = nn - 1;
            }
            store64(_bz_mtf, tmp);
            var uc = load64(_bz_seq + tmp * 8);
            store64(_bz_unzftab + uc * 8, load64(_bz_unzftab + uc * 8) + 1);
            if (nblock >= blockmax) { return 0 - ERR_CORRUPT_DATA; }
            store64(_bz_tt + nblock * 8, uc);
            nblock = nblock + 1;
            nextsym = _bz_get_mtf();
            if (nextsym < 0) { return nextsym; }
        }
        if (_bz_err != 0) { return 0 - ERR_CORRUPT_DATA; }
    }
    if (orig_ptr >= nblock) { return 0 - ERR_CORRUPT_DATA; }

    # ---- inverse BWT: build the transform vector in tt[] ----
    store64(_bz_cftab, 0);
    i = 1;
    while (i <= 256) {
        store64(_bz_cftab + i * 8, load64(_bz_unzftab + (i - 1) * 8));
        i = i + 1;
    }
    i = 1;
    while (i <= 256) {
        store64(_bz_cftab + i * 8, load64(_bz_cftab + i * 8) + load64(_bz_cftab + (i - 1) * 8));
        i = i + 1;
    }
    i = 0;
    while (i < nblock) {
        var uc = load64(_bz_tt + i * 8) & 255;
        var c = load64(_bz_cftab + uc * 8);
        store64(_bz_tt + c * 8, load64(_bz_tt + c * 8) | (i << 8));
        store64(_bz_cftab + uc * 8, c + 1);
        i = i + 1;
    }

    # ---- walk the vector from orig_ptr, fused with RLE1 decode ----
    var block_start = _bz_dp;
    var t_pos = load64(_bz_tt + orig_ptr * 8) >> 8;
    var rle_last = 0 - 1;
    var rle_run = 0;
    var k = 0;
    while (k < nblock) {
        var b = load64(_bz_tt + t_pos * 8) & 255;
        t_pos = load64(_bz_tt + t_pos * 8) >> 8;
        k = k + 1;

        if (rle_run == 4) {
            # `b` is the run-length byte: emit `b` more copies of rle_last
            if (_bz_dp + b > _bz_dst_cap) { return 0 - ERR_BUFFER_TOO_SMALL; }
            if (_bz_dp + b > DECOMPRESS_MAX_OUTPUT) { return 0 - ERR_OUTPUT_LIMIT; }
            var m = 0;
            while (m < b) {
                store8(_bz_dst + _bz_dp, rle_last);
                _bz_dp = _bz_dp + 1;
                m = m + 1;
            }
            rle_run = 0;
            rle_last = 0 - 1;
        } else {
            if (_bz_dp >= _bz_dst_cap) { return 0 - ERR_BUFFER_TOO_SMALL; }
            if (_bz_dp >= DECOMPRESS_MAX_OUTPUT) { return 0 - ERR_OUTPUT_LIMIT; }
            store8(_bz_dst + _bz_dp, b);
            _bz_dp = _bz_dp + 1;
            if (b == rle_last) {
                rle_run = rle_run + 1;
            } else {
                rle_last = b;
                rle_run = 1;
            }
        }
    }

    # ---- per-block CRC over the emitted (un-RLE1) bytes ----
    if (crc32_bzip2_init_table() < 0) { return 0 - ERR_OOM; }
    var got = crc32_bzip2(_bz_dst + block_start, _bz_dp - block_start);
    if (got != block_crc) { return 0 - ERR_CHECKSUM_MISMATCH; }
    _bz_last_block_crc = block_crc;
    return _bz_dp - block_start;
}

var _bz_last_block_crc = 0;

# Allocate the bzip2 working tables once.
fn _bz_alloc_tables(): i64 {
    if (_bz_tt != 0) { return 0; }
    _bz_limit = _sankoch_alloc(BZ_N_GROUPS * BZ_MAX_CODE_LEN * 8);
    _bz_base = _sankoch_alloc(BZ_N_GROUPS * BZ_MAX_CODE_LEN * 8);
    _bz_perm = _sankoch_alloc(BZ_N_GROUPS * BZ_MAX_ALPHA * 8);
    _bz_minlens = _sankoch_alloc(BZ_N_GROUPS * 8);
    _bz_len = _sankoch_alloc(BZ_N_GROUPS * BZ_MAX_ALPHA * 8);
    _bz_selector = _sankoch_alloc(BZ_MAX_SELECTORS * 8);
    _bz_selmtf = _sankoch_alloc(BZ_MAX_SELECTORS * 8);
    _bz_inuse = _sankoch_alloc(256 * 8);
    _bz_seq = _sankoch_alloc(256 * 8);
    _bz_mtf = _sankoch_alloc(256 * 8);
    _bz_unzftab = _sankoch_alloc(256 * 8);
    _bz_cftab = _sankoch_alloc(257 * 8);
    _bz_tt = _sankoch_alloc(BZ_MAX_BLOCK * 8);
    if (_bz_limit == 0 || _bz_base == 0 || _bz_perm == 0 || _bz_minlens == 0
    || _bz_len == 0 || _bz_selector == 0 || _bz_selmtf == 0 || _bz_inuse == 0
    || _bz_seq == 0 || _bz_mtf == 0 || _bz_unzftab == 0 || _bz_cftab == 0
    || _bz_tt == 0) {
        return 0 - ERR_OOM;
    }
    return 0;
}

# Decompress a .bz2 file. Supports concatenated streams (e.g. pbzip2
# output) — each its own "BZh" header / blocks / EOS — and stops cleanly
# at the first non-header trailing byte. Inner entry — caller holds the
# lock.
fn _bz2_decompress_inner(src, src_len, dst, dst_cap): i64 {
    if (src_len < 4) { return 0 - ERR_INVALID_INPUT; }
    if (_bz_alloc_tables() < 0) { return 0 - ERR_OOM; }

    _bz_in = src;
    _bz_in_end = src_len;
    _bz_dst = dst;
    _bz_dp = 0;
    _bz_dst_cap = dst_cap;

    var off = 0;
    var streams_done = 0;
    while (off + 4 <= src_len) {
        # Stream header "BZh" + level digit '1'..'9'. After a complete
        # stream, a non-header here is trailing data — stop cleanly
        # (extract-what's-there; CRCs already gate what we returned). But
        # the very first header must be valid, else the input is corrupt.
        var level = load8(src + off + 3) - 0x30;
        var valid = 1;
        if (load8(src + off) != 0x42 || load8(src + off + 1) != 0x5A
        || load8(src + off + 2) != 0x68 || level < 1 || level > 9) {
            valid = 0;
        }
        if (valid == 0) {
            if (streams_done == 0) { return 0 - ERR_CORRUPT_DATA; }
            break;
        }

        # Reset the bit reader to the byte boundary after this header.
        _bz_in_pos = off + 4;
        _bz_bit_buf = 0;
        _bz_bit_cnt = 0;
        _bz_err = 0;

        var combined = 0;
        var saw_eos = 0;
        while (saw_eos == 0) {
            var hi = _bz_bits(24);
            var lo = _bz_bits(24);
            if (_bz_err != 0) { return 0 - ERR_CORRUPT_DATA; }

            if (hi == 0x314159 && lo == 0x265359) {
                var r = _bz_decode_block(level);
                if (r < 0) { return r; }
                # combined = rotl(combined, 1) ^ blockCRC
                combined = (((combined << 1) | (combined >> 31)) & 0xFFFFFFFF) ^ _bz_last_block_crc;
            } elif (hi == 0x177245 && lo == 0x385090) {
                var stream_crc = _bz_bits32();
                if (_bz_err != 0) { return 0 - ERR_CORRUPT_DATA; }
                if (stream_crc != combined) { return 0 - ERR_CHECKSUM_MISMATCH; }
                saw_eos = 1;
            } else {
                return 0 - ERR_CORRUPT_DATA;
            }
        }
        # Next concatenated stream starts at the next byte boundary; the
        # leftover bits in the partial byte are zero padding — discard.
        off = _bz_in_pos;
        streams_done = streams_done + 1;
    }
    if (streams_done == 0) { return 0 - ERR_INVALID_INPUT; }
    return _bz_dp;
}

# Public: decompress a .bz2 stream. Thread-safe wrapper.
fn bzip2_decompress(src, src_len, dst, dst_cap): i64 {
    if (src_len < 0 || dst_cap < 0) { return 0 - ERR_INVALID_INPUT; }
    _sankoch_lock();
    var r = _bz2_decompress_inner(src, src_len, dst, dst_cap);
    _sankoch_unlock();
    return r;
}

# ============================================================
# ENCODE SIDE (2.4.3)
# ============================================================
# Forward pipeline (original → .bz2), the inverse of the decode chain:
#   RLE1 → forward BWT (block-sort) → MTF + RLE2 → multi-table Huffman
#   → bit-packed block, wrapped in the .bz2 container.
#
# The forward BWT is the compute-heavy piece: it sorts all cyclic
# rotations of the RLE1'd block. Implemented as a prefix-doubling suffix
# sort with counting-sort rounds (O(n log n)). Reference: bzip2 / libbzip2
# `blocksort.c` (result shape) + the standard SA-IS-free doubling SA.
#
# Any valid bzip2 stream decodes via `bzip2 -d`; our table-construction
# choices only affect ratio, not correctness.

# ---- encoder working buffers (lazily allocated, sized to the max block) ----
var _bze_rle = 0;     # RLE1-encoded block bytes (the BWT input)
var _bze_ptr = 0;     # rotation order (i64[n])
var _bze_tmp = 0;     # radix-sort scratch (i64[n])
var _bze_rank = 0;    # current ranks (i64[n])
var _bze_nrank = 0;   # next ranks (i64[n])
var _bze_cnt = 0;     # counting-sort buckets (i64[n+1])
var _bze_lcol = 0;    # BWT last column (byte[n])
var _bze_mtfv = 0;    # MTF/RLE2 symbol stream (i64[n+1])

# ---- MTF / Huffman working tables (lazily allocated) ----
var _bze_efreq = 0;   # symbol frequencies (i64[258])
var _bze_hlen = 0;    # code lengths [6][258]
var _bze_hcode = 0;   # canonical codes [6][258]
var _bze_rfreq = 0;   # per-table accumulated freqs [6][258]
var _bze_sel = 0;     # selector per 50-symbol group (i64[18002])
var _bze_selmtf = 0;  # MTF-coded selectors (i64[18002])
var _bze_yy = 0;      # MTF list of compact indices (i64[256])
var _bze_unseq = 0;   # byte → compact index (i64[256])
var _bze_seq2 = 0;    # compact index → byte (i64[256])
var _bze_inuse2 = 0;  # used-byte flags (i64[256])
var _bze_heap = 0;    # hbMakeCodeLengths heap (i64[260])
var _bze_hwt = 0;     # ... weights (i64[600])
var _bze_hpar = 0;    # ... parents (i64[600])

fn _bze_alloc(): i64 {
    if (_bze_rle != 0) { return 0; }
    var nb = BZ_MAX_BLOCK + 8;
    _bze_rle = _sankoch_alloc(nb);
    _bze_ptr = _sankoch_alloc(nb * 8);
    _bze_tmp = _sankoch_alloc(nb * 8);
    _bze_rank = _sankoch_alloc(nb * 8);
    _bze_nrank = _sankoch_alloc(nb * 8);
    _bze_cnt = _sankoch_alloc(nb * 8);
    _bze_lcol = _sankoch_alloc(nb);
    _bze_mtfv = _sankoch_alloc(nb * 8);
    _bze_efreq = _sankoch_alloc(258 * 8);
    _bze_hlen = _sankoch_alloc(BZ_N_GROUPS * BZ_MAX_ALPHA * 8);
    _bze_hcode = _sankoch_alloc(BZ_N_GROUPS * BZ_MAX_ALPHA * 8);
    _bze_rfreq = _sankoch_alloc(BZ_N_GROUPS * BZ_MAX_ALPHA * 8);
    _bze_sel = _sankoch_alloc(BZ_MAX_SELECTORS * 8);
    _bze_selmtf = _sankoch_alloc(BZ_MAX_SELECTORS * 8);
    _bze_yy = _sankoch_alloc(256 * 8);
    _bze_unseq = _sankoch_alloc(256 * 8);
    _bze_seq2 = _sankoch_alloc(256 * 8);
    _bze_inuse2 = _sankoch_alloc(256 * 8);
    _bze_heap = _sankoch_alloc(264 * 8);
    _bze_hwt = _sankoch_alloc(600 * 8);
    _bze_hpar = _sankoch_alloc(600 * 8);
    if (_bze_rle == 0 || _bze_ptr == 0 || _bze_tmp == 0 || _bze_rank == 0
    || _bze_nrank == 0 || _bze_cnt == 0 || _bze_lcol == 0 || _bze_mtfv == 0
    || _bze_efreq == 0 || _bze_hlen == 0 || _bze_hcode == 0 || _bze_rfreq == 0
    || _bze_sel == 0 || _bze_selmtf == 0 || _bze_yy == 0 || _bze_unseq == 0
    || _bze_seq2 == 0 || _bze_inuse2 == 0 || _bze_heap == 0 || _bze_hwt == 0
    || _bze_hpar == 0) {
        return 0 - ERR_OOM;
    }
    return 0;
}

# Stable counting sort of `_bze_ptr[0..n)` by a key in [0, nbuckets),
# `key_of(idx)` selected by `mode`: 0 = rank[(idx+k)%n] (secondary),
# 1 = rank[idx] (primary). Reads from `src_arr`, writes to `dst_arr`.
fn _bze_csort(n, k, nbuckets, mode, src_arr, dst_arr): i64 {
    var cnt = _bze_cnt;
    var rank = _bze_rank;
    var i = 0;
    while (i < nbuckets) { store64(cnt + i * 8, 0); i = i + 1; }
    i = 0;
    while (i < n) {
        var idx = load64(src_arr + i * 8);
        var key = 0;
        if (mode == 0) { key = load64(rank + ((idx + k) % n) * 8); }
        else { key = load64(rank + idx * 8); }
        store64(cnt + key * 8, load64(cnt + key * 8) + 1);
        i = i + 1;
    }
    var sum = 0;
    i = 0;
    while (i < nbuckets) {
        var c = load64(cnt + i * 8);
        store64(cnt + i * 8, sum);
        sum = sum + c;
        i = i + 1;
    }
    i = 0;
    while (i < n) {
        var idx = load64(src_arr + i * 8);
        var key = 0;
        if (mode == 0) { key = load64(rank + ((idx + k) % n) * 8); }
        else { key = load64(rank + idx * 8); }
        var p = load64(cnt + key * 8);
        store64(dst_arr + p * 8, idx);
        store64(cnt + key * 8, p + 1);
        i = i + 1;
    }
    return 0;
}

# Forward BWT of `_bze_rle[0..n)`. Fills `_bze_lcol[0..n)` (last column),
# returns origPtr (sorted index of the rotation starting at 0).
fn _bze_bwt(n): i64 {
    if (n == 1) {
        store8(_bze_lcol, load8(_bze_rle));
        return 0;
    }
    var rle = _bze_rle;
    var ptr = _bze_ptr;
    var rank = _bze_rank;
    var nrank = _bze_nrank;
    var cnt = _bze_cnt;

    # --- initial order + dense ranks by first byte ---
    var i = 0;
    while (i <= 256) { store64(cnt + i * 8, 0); i = i + 1; }
    i = 0;
    while (i < n) { var b = load8(rle + i); store64(cnt + b * 8, load64(cnt + b * 8) + 1); i = i + 1; }
    var sum = 0;
    i = 0;
    while (i < 256) { var c = load64(cnt + i * 8); store64(cnt + i * 8, sum); sum = sum + c; i = i + 1; }
    i = 0;
    while (i < n) {
        var b = load8(rle + i);
        var p = load64(cnt + b * 8);
        store64(ptr + p * 8, i);
        store64(cnt + b * 8, p + 1);
        i = i + 1;
    }
    var r = 0;
    store64(rank + load64(ptr) * 8, 0);
    i = 1;
    while (i < n) {
        if (load8(rle + load64(ptr + i * 8)) != load8(rle + load64(ptr + (i - 1) * 8))) { r = r + 1; }
        store64(rank + load64(ptr + i * 8) * 8, r);
        i = i + 1;
    }

    # --- prefix doubling ---
    var k = 1;
    while (r < n - 1 && k < n) {
        var nb = r + 1;
        _bze_csort(n, k, nb, 0, ptr, _bze_tmp);   # by secondary key
        _bze_csort(n, k, nb, 1, _bze_tmp, ptr);   # by primary key (stable)
        # reassign dense ranks by the (rank[i], rank[(i+k)%n]) pair
        store64(nrank + load64(ptr) * 8, 0);
        var rr = 0;
        i = 1;
        while (i < n) {
            var a = load64(ptr + i * 8);
            var bb = load64(ptr + (i - 1) * 8);
            var diff = 0;
            if (load64(rank + a * 8) != load64(rank + bb * 8)) { diff = 1; }
            elif (load64(rank + ((a + k) % n) * 8) != load64(rank + ((bb + k) % n) * 8)) { diff = 1; }
            if (diff != 0) { rr = rr + 1; }
            store64(nrank + a * 8, rr);
            i = i + 1;
        }
        i = 0;
        while (i < n) { store64(rank + i * 8, load64(nrank + i * 8)); i = i + 1; }
        r = rr;
        k = k * 2;
    }

    # --- build last column + locate origPtr ---
    var orig = 0;
    i = 0;
    while (i < n) {
        var pi = load64(ptr + i * 8);
        store8(_bze_lcol + i, load8(rle + (pi + n - 1) % n));
        if (pi == 0) { orig = i; }
        i = i + 1;
    }
    return orig;
}

# ---- MSB-first bit writer ----
var _bze_out = 0;
var _bze_op = 0;
var _bze_cap = 0;
var _bze_bbuf = 0;
var _bze_bn = 0;
var _bze_oflow = 0;

fn _bze_emit_byte(b): i64 {
    if (_bze_op < _bze_cap) { store8(_bze_out + _bze_op, b & 255); } else { _bze_oflow = 1; }
    _bze_op = _bze_op + 1;
    return 0;
}

# Write the low `n` bits of `v`, most-significant-first (n <= 24).
fn _bze_put(n, v): i64 {
    _bze_bbuf = (_bze_bbuf << n) | (v & ((1 << n) - 1));
    _bze_bn = _bze_bn + n;
    while (_bze_bn >= 8) {
        _bze_bn = _bze_bn - 8;
        _bze_emit_byte((_bze_bbuf >> _bze_bn) & 255);
    }
    _bze_bbuf = _bze_bbuf & ((1 << _bze_bn) - 1);
    return 0;
}

fn _bze_put32(v): i64 {
    _bze_put(16, (v >> 16) & 0xFFFF);
    _bze_put(16, v & 0xFFFF);
    return 0;
}

# Flush the partial byte (zero-padded, MSB-aligned).
fn _bze_flush_bits(): i64 {
    if (_bze_bn > 0) {
        _bze_emit_byte((_bze_bbuf << (8 - _bze_bn)) & 255);
        _bze_bn = 0;
        _bze_bbuf = 0;
    }
    return 0;
}

# ---- Huffman: length-limited code lengths (libbzip2 hbMakeCodeLengths) ----
# Weight packs the frequency in the high bits and the tree depth in the
# low 8 bits; depths are capped at `maxlen` by halving weights and
# retrying. Writes `alpha` code lengths to `lenp` (one i64 each).
fn _bze_make_lengths(lenp, freqp, alpha, maxlen): i64 {
    var heap = _bze_heap;
    var wt = _bze_hwt;
    var par = _bze_hpar;
    var i = 0;
    while (i < alpha) {
        var f = load64(freqp + i * 8);
        if (f == 0) { f = 1; }
        store64(wt + (i + 1) * 8, f << 8);
        i = i + 1;
    }
    while (1) {
        var nNodes = alpha;
        var nHeap = 0;
        store64(heap, 0); store64(wt, 0); store64(par, 0 - 2);
        i = 1;
        while (i <= alpha) {
            store64(par + i * 8, 0 - 1);
            nHeap = nHeap + 1;
            store64(heap + nHeap * 8, i);
            var zz = nHeap;
            var tmp = load64(heap + zz * 8);
            while (load64(wt + tmp * 8) < load64(wt + load64(heap + (zz >> 1) * 8) * 8)) {
                store64(heap + zz * 8, load64(heap + (zz >> 1) * 8));
                zz = zz >> 1;
            }
            store64(heap + zz * 8, tmp);
            i = i + 1;
        }
        while (nHeap > 1) {
            var n1 = load64(heap + 8);
            store64(heap + 8, load64(heap + nHeap * 8));
            nHeap = nHeap - 1;
            var zz = 1;
            var tmp = load64(heap + zz * 8);
            while (1) {
                var yy = zz << 1;
                if (yy > nHeap) { break; }
                if (yy < nHeap) {
                    var wl = load64(wt + load64(heap + (yy + 1) * 8) * 8);
                    var wr = load64(wt + load64(heap + yy * 8) * 8);
                    if (wl < wr) { yy = yy + 1; }
                }
                if (load64(wt + tmp * 8) < load64(wt + load64(heap + yy * 8) * 8)) { break; }
                store64(heap + zz * 8, load64(heap + yy * 8));
                zz = yy;
            }
            store64(heap + zz * 8, tmp);
            var n2 = load64(heap + 8);
            store64(heap + 8, load64(heap + nHeap * 8));
            nHeap = nHeap - 1;
            zz = 1;
            tmp = load64(heap + zz * 8);
            while (1) {
                var yy = zz << 1;
                if (yy > nHeap) { break; }
                if (yy < nHeap) {
                    var wl = load64(wt + load64(heap + (yy + 1) * 8) * 8);
                    var wr = load64(wt + load64(heap + yy * 8) * 8);
                    if (wl < wr) { yy = yy + 1; }
                }
                if (load64(wt + tmp * 8) < load64(wt + load64(heap + yy * 8) * 8)) { break; }
                store64(heap + zz * 8, load64(heap + yy * 8));
                zz = yy;
            }
            store64(heap + zz * 8, tmp);
            nNodes = nNodes + 1;
            store64(par + n1 * 8, nNodes);
            store64(par + n2 * 8, nNodes);
            var w1 = load64(wt + n1 * 8);
            var w2 = load64(wt + n2 * 8);
            var d1 = w1 & 255;
            var d2 = w2 & 255;
            var dep = d1;
            if (d2 > dep) { dep = d2; }
            store64(wt + nNodes * 8, ((w1 & 0xFFFFFF00) + (w2 & 0xFFFFFF00)) | (1 + dep));
            store64(par + nNodes * 8, 0 - 1);
            nHeap = nHeap + 1;
            store64(heap + nHeap * 8, nNodes);
            zz = nHeap;
            tmp = load64(heap + zz * 8);
            while (load64(wt + tmp * 8) < load64(wt + load64(heap + (zz >> 1) * 8) * 8)) {
                store64(heap + zz * 8, load64(heap + (zz >> 1) * 8));
                zz = zz >> 1;
            }
            store64(heap + zz * 8, tmp);
        }
        var too_long = 0;
        i = 1;
        while (i <= alpha) {
            var j = 0;
            var k = i;
            while (load64(par + k * 8) >= 0) { k = load64(par + k * 8); j = j + 1; }
            store64(lenp + (i - 1) * 8, j);
            if (j > maxlen) { too_long = 1; }
            i = i + 1;
        }
        if (too_long == 0) { break; }
        i = 1;
        while (i <= alpha) {
            var j = load64(wt + i * 8) >> 8;
            j = 1 + (j / 2);
            store64(wt + i * 8, j << 8);
            i = i + 1;
        }
    }
    return 0;
}

# Assign canonical codes for lengths in `lenp` → `codep` (libbzip2 hbAssignCodes).
fn _bze_assign_codes(codep, lenp, alpha): i64 {
    var minl = 32;
    var maxl = 0;
    var i = 0;
    while (i < alpha) {
        var l = load64(lenp + i * 8);
        if (l > maxl) { maxl = l; }
        if (l < minl) { minl = l; }
        i = i + 1;
    }
    var vec = 0;
    var n = minl;
    while (n <= maxl) {
        i = 0;
        while (i < alpha) {
            if (load64(lenp + i * 8) == n) { store64(codep + i * 8, vec); vec = vec + 1; }
            i = i + 1;
        }
        vec = vec << 1;
        n = n + 1;
    }
    return 0;
}

# Generate the MTF + RLE2 symbol stream from the BWT last column
# `_bze_lcol[0..n)`. Fills `_bze_mtfv` + `_bze_efreq`, returns nMTF.
# `n_in_use` / `_bze_unseq` describe the compact alphabet; EOB = n_in_use+1.
fn _bze_gen_mtf(n, n_in_use): i64 {
    var eob = n_in_use + 1;
    var alpha = n_in_use + 2;
    var i = 0;
    while (i < alpha) { store64(_bze_efreq + i * 8, 0); i = i + 1; }
    i = 0;
    while (i < n_in_use) { store64(_bze_yy + i * 8, i); i = i + 1; }

    var wr = 0;
    var zpend = 0;
    var p = 0;
    while (p < n) {
        var sym = load64(_bze_unseq + load8(_bze_lcol + p) * 8);
        # locate sym in the MTF list, record position, move to front
        var pos = 0;
        while (load64(_bze_yy + pos * 8) != sym) { pos = pos + 1; }
        var j = pos;
        while (j > 0) { store64(_bze_yy + j * 8, load64(_bze_yy + (j - 1) * 8)); j = j - 1; }
        store64(_bze_yy, sym);

        if (pos == 0) {
            zpend = zpend + 1;
        } else {
            if (zpend > 0) {
                zpend = zpend - 1;
                while (1) {
                    if ((zpend & 1) != 0) {
                        store64(_bze_mtfv + wr * 8, BZ_RUNB); wr = wr + 1;
                        store64(_bze_efreq + BZ_RUNB * 8, load64(_bze_efreq + BZ_RUNB * 8) + 1);
                    } else {
                        store64(_bze_mtfv + wr * 8, BZ_RUNA); wr = wr + 1;
                        store64(_bze_efreq + BZ_RUNA * 8, load64(_bze_efreq + BZ_RUNA * 8) + 1);
                    }
                    if (zpend < 2) { break; }
                    zpend = (zpend - 2) / 2;
                }
                zpend = 0;
            }
            store64(_bze_mtfv + wr * 8, pos + 1); wr = wr + 1;
            store64(_bze_efreq + (pos + 1) * 8, load64(_bze_efreq + (pos + 1) * 8) + 1);
        }
        p = p + 1;
    }
    if (zpend > 0) {
        zpend = zpend - 1;
        while (1) {
            if ((zpend & 1) != 0) {
                store64(_bze_mtfv + wr * 8, BZ_RUNB); wr = wr + 1;
                store64(_bze_efreq + BZ_RUNB * 8, load64(_bze_efreq + BZ_RUNB * 8) + 1);
            } else {
                store64(_bze_mtfv + wr * 8, BZ_RUNA); wr = wr + 1;
                store64(_bze_efreq + BZ_RUNA * 8, load64(_bze_efreq + BZ_RUNA * 8) + 1);
            }
            if (zpend < 2) { break; }
            zpend = (zpend - 2) / 2;
        }
    }
    store64(_bze_mtfv + wr * 8, eob); wr = wr + 1;
    store64(_bze_efreq + eob * 8, load64(_bze_efreq + eob * 8) + 1);
    return wr;
}

# Build the multi-table Huffman, MTF the selectors, and emit the group
# count / selectors / code-length tables / coded symbols (libbzip2
# sendMTFValues). `alpha` = alphabet size, `nMTF` = symbol count.
fn _bze_send_mtf(nMTF, alpha): i64 {
    var n_groups = 6;
    if (nMTF < 200) { n_groups = 2; }
    elif (nMTF < 600) { n_groups = 3; }
    elif (nMTF < 1200) { n_groups = 4; }
    elif (nMTF < 2400) { n_groups = 5; }

    # --- initial tables: each covers a ~equal-frequency contiguous range ---
    var rem = nMTF;
    var gs = 0;
    var npart = n_groups;
    while (npart > 0) {
        var tfreq = rem / npart;
        var ge = gs - 1;
        var afreq = 0;
        while (afreq < tfreq && ge < alpha - 1) {
            ge = ge + 1;
            afreq = afreq + load64(_bze_efreq + ge * 8);
        }
        if (ge > gs && npart != n_groups && npart != 1 && (((n_groups - npart) & 1) == 1)) {
            afreq = afreq - load64(_bze_efreq + ge * 8);
            ge = ge - 1;
        }
        var toff = (npart - 1) * BZ_MAX_ALPHA;
        var s = 0;
        while (s < alpha) {
            if (s >= gs && s <= ge) { store64(_bze_hlen + (toff + s) * 8, 0); }
            else { store64(_bze_hlen + (toff + s) * 8, 15); }
            s = s + 1;
        }
        rem = rem - afreq;
        gs = ge + 1;
        npart = npart - 1;
    }

    # --- refine over BZ_N_ITERS passes ---
    var n_sel = 0;
    var cost[48];
    var iter = 0;
    while (iter < 4) {
        var t = 0;
        while (t < n_groups) {
            var s = 0;
            while (s < alpha) { store64(_bze_rfreq + (t * BZ_MAX_ALPHA + s) * 8, 0); s = s + 1; }
            t = t + 1;
        }
        n_sel = 0;
        var gpos = 0;
        while (gpos < nMTF) {
            var ge = gpos + BZ_G_SIZE;
            if (ge > nMTF) { ge = nMTF; }
            t = 0;
            while (t < n_groups) { store64(&cost + t * 8, 0); t = t + 1; }
            var i = gpos;
            while (i < ge) {
                var sym = load64(_bze_mtfv + i * 8);
                t = 0;
                while (t < n_groups) {
                    store64(&cost + t * 8, load64(&cost + t * 8) + load64(_bze_hlen + (t * BZ_MAX_ALPHA + sym) * 8));
                    t = t + 1;
                }
                i = i + 1;
            }
            var bt = 0;
            var bc = load64(&cost);
            t = 1;
            while (t < n_groups) {
                if (load64(&cost + t * 8) < bc) { bc = load64(&cost + t * 8); bt = t; }
                t = t + 1;
            }
            store64(_bze_sel + n_sel * 8, bt);
            n_sel = n_sel + 1;
            i = gpos;
            while (i < ge) {
                var sym = load64(_bze_mtfv + i * 8);
                var off = bt * BZ_MAX_ALPHA + sym;
                store64(_bze_rfreq + off * 8, load64(_bze_rfreq + off * 8) + 1);
                i = i + 1;
            }
            gpos = ge;
        }
        t = 0;
        while (t < n_groups) {
            _bze_make_lengths(_bze_hlen + t * BZ_MAX_ALPHA * 8, _bze_rfreq + t * BZ_MAX_ALPHA * 8, alpha, 20);
            t = t + 1;
        }
        iter = iter + 1;
    }

    # --- MTF-encode the selector list ---
    var selpos[48];
    var t2 = 0;
    while (t2 < n_groups) { store64(&selpos + t2 * 8, t2); t2 = t2 + 1; }
    var i2 = 0;
    while (i2 < n_sel) {
        var v = load64(_bze_sel + i2 * 8);
        var j = 0;
        while (load64(&selpos + j * 8) != v) { j = j + 1; }
        store64(_bze_selmtf + i2 * 8, j);
        var tmp = load64(&selpos + j * 8);
        while (j > 0) { store64(&selpos + j * 8, load64(&selpos + (j - 1) * 8)); j = j - 1; }
        store64(&selpos, tmp);
        i2 = i2 + 1;
    }

    # --- assign canonical codes ---
    var t3 = 0;
    while (t3 < n_groups) {
        _bze_assign_codes(_bze_hcode + t3 * BZ_MAX_ALPHA * 8, _bze_hlen + t3 * BZ_MAX_ALPHA * 8, alpha);
        t3 = t3 + 1;
    }

    # --- emit group count + selectors ---
    _bze_put(3, n_groups);
    _bze_put(15, n_sel);
    i2 = 0;
    while (i2 < n_sel) {
        var v = load64(_bze_selmtf + i2 * 8);
        while (v > 0) { _bze_put(1, 1); v = v - 1; }
        _bze_put(1, 0);
        i2 = i2 + 1;
    }

    # --- emit the per-table code lengths (delta-coded) ---
    var t4 = 0;
    while (t4 < n_groups) {
        var curr = load64(_bze_hlen + t4 * BZ_MAX_ALPHA * 8);
        _bze_put(5, curr);
        var s = 0;
        while (s < alpha) {
            var target = load64(_bze_hlen + (t4 * BZ_MAX_ALPHA + s) * 8);
            while (curr < target) { _bze_put(2, 2); curr = curr + 1; }
            while (curr > target) { _bze_put(2, 3); curr = curr - 1; }
            _bze_put(1, 0);
            s = s + 1;
        }
        t4 = t4 + 1;
    }

    # --- emit the coded symbols ---
    var gpos = 0;
    var sidx = 0;
    while (gpos < nMTF) {
        var ge = gpos + BZ_G_SIZE;
        if (ge > nMTF) { ge = nMTF; }
        var t = load64(_bze_sel + sidx * 8);
        sidx = sidx + 1;
        var i = gpos;
        while (i < ge) {
            var sym = load64(_bze_mtfv + i * 8);
            var off = t * BZ_MAX_ALPHA + sym;
            _bze_put(load64(_bze_hlen + off * 8), load64(_bze_hcode + off * 8));
            i = i + 1;
        }
        gpos = ge;
    }
    return 0;
}

# Emit one full block: magic, CRC, randomized=0, origPtr, symbol map,
# then the MTF/RLE2 + Huffman payload. `n` = RLE1 block length in _bze_rle.
fn _bze_emit_block(n, block_crc): i64 {
    var orig = _bze_bwt(n);

    # which byte values appear in the BWT output
    var i = 0;
    while (i < 256) { store64(_bze_inuse2 + i * 8, 0); i = i + 1; }
    i = 0;
    while (i < n) { store64(_bze_inuse2 + load8(_bze_lcol + i) * 8, 1); i = i + 1; }
    var n_in_use = 0;
    i = 0;
    while (i < 256) {
        if (load64(_bze_inuse2 + i * 8) != 0) {
            store64(_bze_seq2 + n_in_use * 8, i);
            store64(_bze_unseq + i * 8, n_in_use);
            n_in_use = n_in_use + 1;
        }
        i = i + 1;
    }
    var alpha = n_in_use + 2;

    # block magic + CRC + randomized + origPtr
    _bze_put(24, 0x314159);
    _bze_put(24, 0x265359);
    _bze_put32(block_crc);
    _bze_put(1, 0);
    _bze_put(24, orig);

    # symbol map: 16-bit "which group of 16" then per-present-group 16-bit
    var present[16];
    i = 0;
    while (i < 16) { store64(&present + i * 8, 0); i = i + 1; }
    i = 0;
    while (i < n_in_use) {
        var b = load64(_bze_seq2 + i * 8);
        store64(&present + (b / 16) * 8, 1);
        i = i + 1;
    }
    var bigmap = 0;
    i = 0;
    while (i < 16) {
        if (load64(&present + i * 8) != 0) { bigmap = bigmap | (1 << (15 - i)); }
        i = i + 1;
    }
    _bze_put(16, bigmap);
    i = 0;
    while (i < 16) {
        if (load64(&present + i * 8) != 0) {
            var smallmap = 0;
            var j = 0;
            while (j < 16) {
                if (load64(_bze_inuse2 + (i * 16 + j) * 8) != 0) { smallmap = smallmap | (1 << (15 - j)); }
                j = j + 1;
            }
            _bze_put(16, smallmap);
        }
        i = i + 1;
    }

    var nMTF = _bze_gen_mtf(n, n_in_use);
    _bze_send_mtf(nMTF, alpha);
    return 0;
}

# Compress src → .bz2 in dst at block-size `level` (1..9 → 100..900 KB).
# Inner entry — caller holds _sankoch_mtx.
fn _bz2_compress_inner(src, src_len, dst, dst_cap, level): i64 {
    if (level < 1) { level = 1; }
    if (level > 9) { level = 9; }
    if (_bze_alloc() < 0) { return 0 - ERR_OOM; }
    if (crc32_bzip2_init_table() < 0) { return 0 - ERR_OOM; }

    _bze_out = dst;
    _bze_op = 0;
    _bze_cap = dst_cap;
    _bze_bbuf = 0;
    _bze_bn = 0;
    _bze_oflow = 0;

    # stream header "BZh<level>"
    _bze_put(8, 0x42);
    _bze_put(8, 0x5A);
    _bze_put(8, 0x68);
    _bze_put(8, 0x30 + level);

    var blockmax = level * 100000;
    var combined = 0;
    var in_pos = 0;
    while (in_pos < src_len) {
        var block_start = in_pos;
        var rn = 0;
        while (in_pos < src_len) {
            var b = load8(src + in_pos);
            var run = 1;
            while (in_pos + run < src_len && load8(src + in_pos + run) == b && run < 255) {
                run = run + 1;
            }
            var rle_sz = run;
            if (run >= 4) { rle_sz = 5; }
            if (rn + rle_sz > blockmax) { break; }
            if (run >= 4) {
                store8(_bze_rle + rn, b);
                store8(_bze_rle + rn + 1, b);
                store8(_bze_rle + rn + 2, b);
                store8(_bze_rle + rn + 3, b);
                store8(_bze_rle + rn + 4, run - 4);
                rn = rn + 5;
            } else {
                var j = 0;
                while (j < run) { store8(_bze_rle + rn, b); rn = rn + 1; j = j + 1; }
            }
            in_pos = in_pos + run;
        }
        var block_crc = crc32_bzip2(src + block_start, in_pos - block_start);
        _bze_emit_block(rn, block_crc);
        combined = (((combined << 1) | (combined >> 31)) & 0xFFFFFFFF) ^ block_crc;
    }

    # stream footer: EOS magic + combined CRC
    _bze_put(24, 0x177245);
    _bze_put(24, 0x385090);
    _bze_put32(combined);
    _bze_flush_bits();

    if (_bze_oflow != 0) { return 0 - ERR_BUFFER_TOO_SMALL; }
    return _bze_op;
}

# Public: compress src → .bz2 stream (level = block size, default 9).
# Thread-safe wrapper.
fn bzip2_compress(src, src_len, dst, dst_cap): i64 {
    if (src_len < 0 || dst_cap < 0) { return 0 - ERR_INVALID_INPUT; }
    _sankoch_lock();
    var r = _bz2_compress_inner(src, src_len, dst, dst_cap, 9);
    _sankoch_unlock();
    return r;
}

# --- stream.cyr ---

# sankoch — streaming compression/decompression API
#
# Compression side (v1.7.0+): dispatches to the per-format incremental
# encoders (deflate_enc_*, zlib_enc_*, gzip_enc_*, lz4f_enc_*). The
# encoder emits output bytes as each stream_write chunk arrives; input
# is never fully buffered, so inputs larger than available memory work
# fine as long as dst_cap holds the compressed stream.
#
# Decompression side (two modes, both shipped):
#   - Legacy buffered (pre-1.7.0 model): `stream_decompress_init(format)`
#     accumulates compressed input in a growable buffer and calls the
#     batch decompressor at finish. Same API as before; no change.
#   - Incremental (bite-6 of 2.3.0): `stream_decompress_init_inc(format,
#     dst, dst_cap)` dispatches to the per-format streaming decoders
#     (deflate_dec_*, zlib_dec_*, gzip_dec_*, lz4f_dec_*). Output bytes
#     are emitted into dst as each stream_write chunk is consumed; no
#     input buffering. Use this when the compressed input is larger
#     than memory or arrives over a slow channel.
#
# Usage (compress):
#   var ctx = stream_compress_init(FORMAT_GZIP, 6, dst, dst_cap)
#   stream_write(ctx, chunk1, len1)
#   stream_write(ctx, chunk2, len2)
#   var total = stream_compress_finish(ctx)
#
# Usage (decompress — buffered):
#   var ctx = stream_decompress_init(FORMAT_GZIP)
#   stream_write(ctx, compressed_data, compressed_len)
#   var result_len = stream_decompress_finish(ctx, out_buf, out_cap)
#
# Usage (decompress — incremental):
#   var ctx = stream_decompress_init_inc(FORMAT_GZIP, out_buf, out_cap)
#   stream_write(ctx, chunk1, len1)   # output written into out_buf as decoded
#   stream_write(ctx, chunk2, len2)
#   var result_len = stream_decompress_finish_inc(ctx)

# Context layout (48 bytes):
#   +0:  format
#   +8:  level (compress only)
#   +16: mode (0 = compress, 1 = decompress buffered, 2 = decompress incremental)
#   +24: compress       → inner encoder ctx pointer
#        decompress buf → input buffer pointer
#        decompress inc → inner streaming decoder ctx pointer
#   +32: decompress buffered only → input buffer capacity
#   +40: decompress buffered only → input buffer bytes written

enum Stream {
    STREAM_COMPRESS = 0;
    STREAM_DECOMPRESS = 1;
    STREAM_DECOMPRESS_INC = 2;
    STREAM_INIT_CAP = 65536;   # 64 KB initial buffer (decompress buffered only)
}

# --- Compression ---

# Initialize a streaming compressor. `dst`/`dst_cap` receive compressed
# output as each stream_write chunk is processed. FORMAT_LZ4 (raw block
# format) has no streaming path — use FORMAT_LZ4F instead.
fn stream_compress_init(format, level, dst, dst_cap): i64 {
    var inner = 0;
    if (format == FORMAT_DEFLATE) {
        inner = deflate_enc_init(level, dst, dst_cap);
    } elif (format == FORMAT_ZLIB) {
        inner = zlib_enc_init(level, dst, dst_cap);
    } elif (format == FORMAT_GZIP) {
        inner = gzip_enc_init(level, dst, dst_cap);
    } elif (format == FORMAT_LZ4F) {
        inner = lz4f_enc_init(dst, dst_cap);
    } else {
        return 0;   # FORMAT_LZ4 (raw block) or unknown — unsupported
    }
    if (inner == 0) { return 0; }

    var ctx = alloc(48);
    store64(ctx, format);
    store64(ctx + 8, level);
    store64(ctx + 16, STREAM_COMPRESS);
    store64(ctx + 24, inner);
    return ctx;
}

# --- Decompression (buffered — pre-1.7.0 model) ---

fn _stream_grow(ctx): i64 {
    var buf = load64(ctx + 24);
    var cap = load64(ctx + 32);
    var new_cap = cap * 2;
    var new_buf = alloc(new_cap);
    var len = load64(ctx + 40);
    var i = 0;
    while (i < len) {
        store8(new_buf + i, load8(buf + i));
        i = i + 1;
    }
    store64(ctx + 24, new_buf);
    store64(ctx + 32, new_cap);
    return 0;
}

fn stream_decompress_init(format): i64 {
    var ctx = alloc(48);
    store64(ctx, format);
    store64(ctx + 8, 0);
    store64(ctx + 16, STREAM_DECOMPRESS);
    store64(ctx + 24, alloc(STREAM_INIT_CAP));
    store64(ctx + 32, STREAM_INIT_CAP);
    store64(ctx + 40, 0);
    return ctx;
}

# --- Decompression (incremental — bite 6 of 2.3.0) ---

# Initialize a streaming incremental decoder. Output bytes are written
# into dst[0..dst_cap) as each stream_write chunk is consumed (no input
# buffering — caller's input pointer is read directly into the inner
# decoder's hold accumulator). FORMAT_LZ4 (raw block format) has no
# streaming decoder; use FORMAT_LZ4F instead. Returns ctx pointer or 0
# on alloc failure / unsupported format.
fn stream_decompress_init_inc(format, dst, dst_cap): i64 {
    var inner = 0;
    if (format == FORMAT_DEFLATE) {
        inner = deflate_dec_init(dst, dst_cap);
    } elif (format == FORMAT_ZLIB) {
        inner = zlib_dec_init(dst, dst_cap);
    } elif (format == FORMAT_GZIP) {
        inner = gzip_dec_init(dst, dst_cap);
    } elif (format == FORMAT_LZ4F) {
        inner = lz4f_dec_init(dst, dst_cap);
    } else {
        return 0;   # FORMAT_LZ4 raw block or unknown — no streaming path
    }
    if (inner == 0) { return 0; }

    var ctx = alloc(48);
    store64(ctx, format);
    store64(ctx + 8, 0);
    store64(ctx + 16, STREAM_DECOMPRESS_INC);
    store64(ctx + 24, inner);
    store64(ctx + 32, 0);
    store64(ctx + 40, 0);
    return ctx;
}

# --- Shared write dispatch ---

fn stream_write(ctx, data, len): i64 {
    if (len <= 0) { return 0; }
    var mode = load64(ctx + 16);
    if (mode == STREAM_COMPRESS) {
        var format = load64(ctx);
        var inner = load64(ctx + 24);
        if (format == FORMAT_DEFLATE) { return deflate_enc_write(inner, data, len); }
        if (format == FORMAT_ZLIB)    { return zlib_enc_write(inner, data, len); }
        if (format == FORMAT_GZIP)    { return gzip_enc_write(inner, data, len); }
        if (format == FORMAT_LZ4F)    { return lz4f_enc_write(inner, data, len); }
        return 0 - ERR_UNSUPPORTED_FORMAT;
    }

    if (mode == STREAM_DECOMPRESS_INC) {
        var format_inc = load64(ctx);
        var inner_dec = load64(ctx + 24);
        if (format_inc == FORMAT_DEFLATE) {
            return deflate_dec_write(inner_dec, data, len);
        }
        if (format_inc == FORMAT_ZLIB)    {
            return zlib_dec_write(inner_dec, data, len);
        }
        if (format_inc == FORMAT_GZIP)    {
            return gzip_dec_write(inner_dec, data, len);
        }
        if (format_inc == FORMAT_LZ4F)    {
            return lz4f_dec_write(inner_dec, data, len);
        }
        return 0 - ERR_UNSUPPORTED_FORMAT;
    }

    # Legacy buffered decompress mode: accumulate input for a batch
    # decompress at finish.
    var written = load64(ctx + 40);
    var cap = load64(ctx + 32);
    while (written + len > cap) {
        _stream_grow(ctx);
        cap = load64(ctx + 32);
    }
    var buf = load64(ctx + 24);
    var i = 0;
    while (i < len) {
        store8(buf + written + i, load8(data + i));
        i = i + 1;
    }
    store64(ctx + 40, written + len);
    return len;
}

# Finish streaming compression. Returns total bytes written to dst,
# or negative error. Releases any mutex taken by the inner encoder.
fn stream_compress_finish(ctx): i64 {
    if (load64(ctx + 16) != STREAM_COMPRESS) { return 0 - ERR_INVALID_INPUT; }
    var format = load64(ctx);
    var inner = load64(ctx + 24);
    if (format == FORMAT_DEFLATE) { return deflate_enc_finish(inner); }
    if (format == FORMAT_ZLIB)    { return zlib_enc_finish(inner); }
    if (format == FORMAT_GZIP)    { return gzip_enc_finish(inner); }
    if (format == FORMAT_LZ4F)    { return lz4f_enc_finish(inner); }
    return 0 - ERR_UNSUPPORTED_FORMAT;
}

# Finish streaming decompression (legacy buffered mode): decompress
# all accumulated input into dst. Rejects ctxs in COMPRESS or
# DECOMPRESS_INC mode — those have their own finish functions.
fn stream_decompress_finish(ctx, dst, dst_cap): i64 {
    if (load64(ctx + 16) != STREAM_DECOMPRESS) { return 0 - ERR_INVALID_INPUT; }
    var format = load64(ctx);
    var buf = load64(ctx + 24);
    var len = load64(ctx + 40);
    return decompress(format, buf, len, dst, dst_cap);
}

# Finish streaming incremental decompression. Returns total decompressed
# bytes (matches what the per-format `*_dec_finish` would return), or
# negative error. Releases _sankoch_mtx via the inner finish.
fn stream_decompress_finish_inc(ctx): i64 {
    if (load64(ctx + 16) != STREAM_DECOMPRESS_INC) {
        return 0 - ERR_INVALID_INPUT;
    }
    var format = load64(ctx);
    var inner = load64(ctx + 24);
    if (format == FORMAT_DEFLATE) { return deflate_dec_finish(inner); }
    if (format == FORMAT_ZLIB)    { return zlib_dec_finish(inner); }
    if (format == FORMAT_GZIP)    { return gzip_dec_finish(inner); }
    if (format == FORMAT_LZ4F)    { return lz4f_dec_finish(inner); }
    return 0 - ERR_UNSUPPORTED_FORMAT;
}

# Return the number of bytes currently buffered (legacy decompress
# mode only; compress and incremental-decompress ctxs have no input
# buffer — return 0).
fn stream_buffered(ctx): i64 {
    if (load64(ctx + 16) == STREAM_DECOMPRESS) { return load64(ctx + 40); }
    return 0;
}

# Reset the legacy decompress-side input buffer. No-op on compress
# contexts (compressor state is append-only) and on incremental
# decompress contexts (the inner streaming decoder has its own state
# machine and is not resettable mid-stream).
fn stream_reset(ctx): i64 {
    if (load64(ctx + 16) == STREAM_DECOMPRESS) { store64(ctx + 40, 0); }
    return 0;
}

# --- lib.cyr ---

# sankoch — lossless compression library (Cyrius-native)
# Sanskrit: संकोच — contraction, compression.
#
# Phases: LZ4 block+frame, DEFLATE (RFC 1951) de/compress, zlib (RFC 1950),
# gzip (RFC 1952). Zero external dependencies, zero C FFI.
#
# Public API (see end of file):
#   compress(format, src, src_len, dst, dst_cap)         -> len or -err
#   compress_level(format, src, src_len, dst, dst_cap, l)-> len or -err
#   decompress(format, src, src_len, dst, dst_cap)       -> len or -err
#   detect_format(src, src_len)                          -> Format or -err
#   plus stream_*, lz4f_*, zlib_*_dict, deflate_*_dict,
#   and {deflate,zlib,gzip}_enc_init_dict (v2.2.0+)

# --- Standard library dependencies (order matters) ---
# thread.cyr supplies mutex_* for the public-API lock (Linux/macOS/Windows).
# On AGNOS the lock pair below no-ops (single-threaded userland), so sankoch
# needs no mutex there; the include stays unconditional because thread.cyr
# itself self-guards agnos (routes to thread_agnos.cyr, no clone/CLONE_VM).

# --- Sankoch domain modules (dependency order) ---
# `xxhash32.cyr` and `lz4_decode.cyr` are extracted siblings of
# `checksum.cyr` and `lz4.cyr` — alloc-free, kernel-safe. They form
# the `[lib.core]` distlib profile (sankoch-core.cyr) consumed by the
# AGNOS initrd loader. The full `[lib]` profile (this chain) includes
# them too — checksum.cyr's incremental xxhash32 state APIs reference
# the helpers in xxhash32.cyr, and lz4.cyr's encode side calls
# lz4_decompress from lz4_decode.cyr in the LZ4F frame-emit path.

# ============================================================================
# Public API — thread-safe wrappers over the format-specific routines.
# All mutable compression/decompression state (bitreader, bitwriter, hash
# tables, Huffman tables, symbol buffers) lives behind a single mutex so
# concurrent callers serialize on API entry. Lazy init on first use.
# ============================================================================

var _sankoch_mtx = 0;

fn _sankoch_lock(): i64 {
    #ifdef CYRIUS_TARGET_AGNOS
    # AGNOS userland is single-threaded — no lock needed. No-op here so sankoch
    # never references mutex_* on agnos, making it self-sufficient even for a
    # consumer that doesn't pull thread.cyr. (thread.cyr already self-guards
    # agnos as of cyrius v6.2.3 — routing to thread_agnos.cyr's no-op mutexes —
    # so this is the sankoch-layer counterpart, not a ud2 preventer.) See the
    # cyrius issue 2026-06-12-sankoch-locks-not-agnos-compatible.md.
    return 0;
    #endif
    #ifndef CYRIUS_TARGET_AGNOS
    if (_sankoch_mtx == 0) {
        _sankoch_mtx = mutex_new();
    }
    mutex_lock(_sankoch_mtx);
    return 0;
    #endif
}

fn _sankoch_unlock(): i64 {
    #ifdef CYRIUS_TARGET_AGNOS
    return 0;     # single-threaded agnos — paired no-op with _sankoch_lock
    #endif
    #ifndef CYRIUS_TARGET_AGNOS
    mutex_unlock(_sankoch_mtx);
    return 0;
    #endif
}

# `_sankoch_alloc` is the seam every alloc-bearing constructor in
# this library funnels through. In production it forwards straight
# to the stdlib `alloc(size)` call. The fault-injection counter
# below lets the tcyr suite simulate an OOM at a chosen alloc step,
# so the defensive return-0 + unlock-on-failure paths added in
# 2.2.1 actually get coverage.
#
# Counter semantics: -1 = production (never fail). Otherwise, the
# Nth subsequent `_sankoch_alloc` call (0-indexed) returns 0 once,
# and the counter resets to -1 — one-shot. Tests set the counter
# right before invoking an entry point, so unrelated allocs don't
# clear the fault before the targeted call fires.
var _sankoch_alloc_fail_at = 0 - 1;

fn _sankoch_alloc(size): i64 {
    if (_sankoch_alloc_fail_at >= 0) {
        if (_sankoch_alloc_fail_at == 0) {
            _sankoch_alloc_fail_at = 0 - 1;
            return 0;
        }
        _sankoch_alloc_fail_at = _sankoch_alloc_fail_at - 1;
    }
    return alloc(size);
}

# Test-only setter for the fault-injection counter. Public-facing
# (`_` prefix is convention for "internal but exported") because
# tests live outside src/ and need to reach in.
fn _sankoch_alloc_set_fail_at(n): i64 {
    _sankoch_alloc_fail_at = n;
    return 0;
}

# Test-only: zero every lazy-global table pointer + its "built" flag so
# the next public-API call re-allocates them from scratch. Lets the
# fault-injection suite (2.3.7) re-trigger first-call OOM at each
# lazy-init site even after earlier tests warmed the globals. All these
# live in one flat namespace after the include concatenation.
fn _sankoch_reset_tables(): i64 {
    crc32_table = 0;
    _lz77_head = 0; _lz77_prev = 0;
    _lz4_htab = 0;
    _huff_tables_allocd = 0;
    _huff_litlen_fast = 0; _huff_litlen_lens = 0; _huff_litlen_codes = 0;
    _huff_dist_fast = 0; _huff_dist_lens = 0; _huff_dist_codes = 0;
    _huff_cl_fast = 0; _huff_cl_lens = 0; _huff_cl_codes = 0;
    _huff_fixed_built = 0; _huff_fixed_litlen_lens = 0;
    _hcl_ws = 0;
    _deflate_enc_fixed_built = 0;
    _deflate_enc_lit_codes = 0; _deflate_enc_lit_lens = 0;
    _deflate_enc_dist_codes = 0;
    _deflate_len_lookup_built = 0; _deflate_len_lookup = 0;
    _deflate_dist_lookup_built = 0; _deflate_dist_lookup = 0;
    _dh_ws = 0;
    _ddec_cl_lens = 0; _ddec_all_lens = 0; _ddec_cl_order = 0;
    _dyn_sym_buf = 0;
    _dyn_lit_freq = 0; _dyn_dist_freq = 0;
    _dyn_opt_lit_lens = 0; _dyn_opt_dist_lens = 0;
    _dyn_opt_lit_codes = 0; _dyn_opt_dist_codes = 0;
    _dyn_lit_fast_tmp = 0; _dyn_dist_fast_tmp = 0;
    return 0;
}

# Compress data using the specified format at default level (6).
fn compress(format, src, src_len, dst, dst_cap): i64 {
    return compress_level(format, src, src_len, dst, dst_cap, 6);
}

# Compress with explicit level (1=fast, 6=default, 9=best).
# Level only affects DEFLATE-based formats. LZ4 ignores the level.
fn compress_level(format, src, src_len, dst, dst_cap, level): i64 {
    if (src_len < 0 || dst_cap < 0) { return 0 - ERR_INVALID_INPUT; }
    _sankoch_lock();
    var result = _compress_inner(format, src, src_len, dst, dst_cap, level);
    _sankoch_unlock();
    return result;
}

fn _compress_inner(format, src, src_len, dst, dst_cap, level): i64 {
    # We already hold _sankoch_mtx here (taken in compress_level). Dispatch
    # to the unlocked inner entries to avoid re-locking.
    if (format == FORMAT_LZ4) {
        return _lz4_compress_inner(src, src_len, dst, dst_cap);
    }
    if (format == FORMAT_DEFLATE) {
        return _deflate_compress_level_inner(src, src_len, dst, dst_cap, level);
    }
    if (format == FORMAT_ZLIB) {
        return _zlib_compress_level_inner(src, src_len, dst, dst_cap, level);
    }
    if (format == FORMAT_GZIP) {
        return _gzip_compress_level_inner(src, src_len, dst, dst_cap, level);
    }
    if (format == FORMAT_LZ4F) {
        return _lz4f_compress_inner(src, src_len, dst, dst_cap);
    }
    if (format == FORMAT_XZ) {
        # xz encode ignores the DEFLATE-style level (fixed lc/lp/pb +
        # optimal parse); the parameter is accepted for API uniformity.
        return _xz_compress_inner(src, src_len, dst, dst_cap);
    }
    if (format == FORMAT_BZIP2) {
        # bzip2 maps the level (1..9) to the block size (100..900 KB).
        return _bz2_compress_inner(src, src_len, dst, dst_cap, level);
    }
    return 0 - ERR_UNSUPPORTED_FORMAT;
}

# Decompress data using the specified format.
fn decompress(format, src, src_len, dst, dst_cap): i64 {
    if (src_len < 0 || dst_cap < 0) { return 0 - ERR_INVALID_INPUT; }
    _sankoch_lock();
    var result = _decompress_inner(format, src, src_len, dst, dst_cap);
    _sankoch_unlock();
    return result;
}

fn _decompress_inner(format, src, src_len, dst, dst_cap): i64 {
    # We already hold _sankoch_mtx here. lz4_decompress and lz4f_decompress
    # touch no shared state (no lock needed). DEFLATE-based formats dispatch
    # to their unlocked inners.
    if (format == FORMAT_LZ4) {
        return lz4_decompress(src, src_len, dst, dst_cap);
    }
    if (format == FORMAT_DEFLATE) {
        return _deflate_decompress_inner(src, src_len, dst, dst_cap);
    }
    if (format == FORMAT_ZLIB) {
        return _zlib_decompress_dict_inner(src, src_len, dst, dst_cap, 0, 0);
    }
    if (format == FORMAT_GZIP) {
        return _gzip_decompress_inner(src, src_len, dst, dst_cap);
    }
    if (format == FORMAT_LZ4F) {
        return lz4f_decompress(src, src_len, dst, dst_cap);
    }
    if (format == FORMAT_XZ) {
        return _xz_decompress_inner(src, src_len, dst, dst_cap);
    }
    if (format == FORMAT_BZIP2) {
        return _bz2_decompress_inner(src, src_len, dst, dst_cap);
    }
    return 0 - ERR_UNSUPPORTED_FORMAT;
}

# Detect compression format from magic bytes.
# Returns FORMAT_* or negative error. LZ4 + raw DEFLATE have no magic.
fn detect_format(src, src_len): i64 {
    if (src_len < 2) {
        return 0 - ERR_INVALID_INPUT;
    }
    var b0 = load8(src);
    var b1 = load8(src + 1);

    # gzip: 0x1f 0x8b
    if (b0 == GZIP_MAGIC_0) {
        if (b1 == GZIP_MAGIC_1) {
            return FORMAT_GZIP;
        }
    }

    # xz: FD 37 7A 58 5A 00 (check first 6 magic bytes when present)
    if (b0 == 0xFD) {
        if (b1 == 0x37 && src_len >= 6) {
            if (load8(src + 2) == 0x7A && load8(src + 3) == 0x58
            && load8(src + 4) == 0x5A && load8(src + 5) == 0x00) {
                return FORMAT_XZ;
            }
        }
    }

    # bzip2: "BZh" + level digit '1'..'9'
    if (b0 == 0x42) {
        if (b1 == 0x5A && src_len >= 4) {
            if (load8(src + 2) == 0x68) {
                var lvl = load8(src + 3);
                if (lvl >= 0x31 && lvl <= 0x39) {
                    return FORMAT_BZIP2;
                }
            }
        }
    }

    # zlib: CMF byte, CM=8 (deflate), (CMF*256 + FLG) % 31 == 0
    if ((b0 & 15) == 8) {
        var check = b0 * 256 + b1;
        if ((check % 31) == 0) {
            return FORMAT_ZLIB;
        }
    }

    return 0 - ERR_UNSUPPORTED_FORMAT;
}
