struct AgentInfo { id; name; agent_type; status; }
fn AgentInfo_to_json(ptr, sb) {
    # ADR-002: compact byte format for library uniformity. Custom
    # field semantics (UUID stringification + enum-name lookup +
    # null-for-0 name) prevent derive adoption for this struct.
    str_builder_add_cstr(sb, "{\"id\":\"");
    str_builder_add(sb, agent_id_to_str(load64(ptr)));
    str_builder_add_cstr(sb, "\",\"name\":");
    var name = load64(ptr + 8);
    if (name != 0) {
        str_builder_putc(sb, '"');
        str_builder_add(sb, name);
        str_builder_putc(sb, '"');
    } else {
        str_builder_add_cstr(sb, "null");
    }
    str_builder_add_cstr(sb, ",\"agent_type\":\"");
    str_builder_add_cstr(sb, agent_type_name(load64(ptr + 16)));
    str_builder_add_cstr(sb, "\",\"status\":\"");
    str_builder_add_cstr(sb, agent_status_name(load64(ptr + 24)));
    str_builder_add_cstr(sb, "\"}");
    return 0;
}
fn AgentInfo_from_json(src: Str) {
    var info = alloc(32);
    var id_str = _json_str(src, str_from("id"));
    if (id_str != 0) {
        var parsed = agent_id_from_str(id_str);
        if (is_ok(parsed) == 1) { store64(info, payload(parsed)); }
    }
    store64(info + 8, _json_str(src, str_from("name")));
    store64(info + 16, _json_int(src, str_from("agent_type_id")));
    store64(info + 24, _json_int(src, str_from("status_id")));
    return info;
}
