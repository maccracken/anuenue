fn model_capabilities_new(model_id: Str, provider) {
    # 96 → 120 bytes at v1.1.0: 3 new flags appended (video_input,
    # caching, parallel_tool_calls). Existing offsets 0..88 unchanged.
    var m = alloc(120);
    store64(m, model_id);
    store64(m + 8, model_id);  # display_name defaults to model_id
    store64(m + 16, provider);
    var i = 24;
