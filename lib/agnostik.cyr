# v1.1.1: widened to i8 (range 0..100 fits comfortably in i7).
# 40 B → 5 B per instance. Comments must live OUTSIDE the struct
# body — cyrius 5.10.14 derive codegen parses `#` inside the body
# as a field-name disruptor. Filed upstream; revisit when fixed.
#derive(Serialize)
struct InjectionScores {
    sql: i8; xss: i8; command: i8;
    path_traversal: i8; prompt_injection: i8;
}
fn injection_scores_new() {
    var s = alloc(5);
    var i = 0;
    while (i < 5) { store8(s + i, 0); i = i + 1; }
    return s;
}
fn iscore_sql(s)              { return load8(s); }
fn iscore_xss(s)              { return load8(s + 1); }
fn iscore_command(s)          { return load8(s + 2); }
fn iscore_path_traversal(s)   { return load8(s + 3); }
fn iscore_prompt_injection(s) { return load8(s + 4); }
# v1.1.1: explicit setters added so callers don't need raw store8.
fn iscore_set_sql(s, v)              { store8(s, v); return 0; }
fn iscore_set_xss(s, v)              { store8(s + 1, v); return 0; }
fn iscore_set_command(s, v)          { store8(s + 2, v); return 0; }
fn iscore_set_path_traversal(s, v)   { store8(s + 3, v); return 0; }
fn iscore_set_prompt_injection(s, v) { store8(s + 4, v); return 0; }
