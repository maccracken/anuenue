fn aentry_severity(e)        { return load64(e + 40); }
fn aentry_result(e)          { return load64(e + 48); }
fn aentry_details(e)         { return load64(e + 56); }
fn aentry_user_id(e)         { return load64(e + 64); }
fn aentry_source_ip(e)       { return load64(e + 72); }
fn aentry_target_resource(e) { return load64(e + 80); }
fn aentry_duration_ms(e)     { return load64(e + 88); }
fn aentry_tags(e)            { return load64(e + 96); }
fn aentry_integrity(e)       { return load64(e + 104); }
