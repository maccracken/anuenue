# ================================================================
# Mobile-specific commands
# ================================================================

# POST /session/{id}/execute — run mobile: command. `command` is e.g.
# "mobile: shell" for ADB shell on UiAutomator2, or "mobile: scroll"
# for gestures. `args_json` is a JSON object (cstr with braces).
fn sandhi_ap_mobile_exec_a(a, base_url, session_id, command, args_json): i64 {
    var url = _sandhi_wd_session_url_a(a, base_url, session_id, "/execute");
    var body_obj = sandhi_json_obj_new_a(a);
    if (body_obj == 0) { return _sandhi_rpc_resp_new_a(a, 0, 0, 0, SANDHI_ERR_INTERNAL, 0); }
    sandhi_json_add_string_a(a, body_obj, "script", command);
    if (args_json != 0) {
        var arr = str_builder_new_a(a);
        if (arr == 0) { return _sandhi_rpc_resp_new_a(a, 0, 0, 0, SANDHI_ERR_INTERNAL, 0); }
        str_builder_add_cstr_a(a, arr, "[");
        str_builder_add_cstr_a(a, arr, args_json);
        str_builder_add_cstr_a(a, arr, "]");
        sandhi_json_add_raw_a(a, body_obj, "args", str_data(str_builder_build_a(a, arr)));
    } else {
        sandhi_json_add_raw_a(a, body_obj, "args", "[]");
    }
    return sandhi_rpc_call_a(a, url, "POST", sandhi_json_build_a(a, body_obj), SANDHI_RPC_DIALECT_WEBDRIVER);
}

fn sandhi_ap_mobile_exec(base_url, session_id, command, args_json): i64 {
    return sandhi_ap_mobile_exec_a(default_alloc(), base_url, session_id, command, args_json);
}

