# --- error.cyr ---

# @public — stable API surface (survives the v3.0 backend swap)
# error.cyr — GPU error codes and Result type
# Ported from mabda/src/error.rs
#
# Uses tagged.cyr Result pattern: Ok(value) / Err(error_code)
# Error codes are integer constants. For errors that carry context
# (like a message pointer), use gpu_err_new(code, msg_ptr).
#
# GpuErr struct layout (16 bytes):
#   +0: code    — error code constant
#   +8: detail  — pointer to detail string (or 0)

# ================================================================
# Error code constants
# ================================================================

enum GpuErrCode {
    GPU_ERR_NONE                    = 0;
    GPU_ERR_ADAPTER_NOT_FOUND       = 1;
    GPU_ERR_DEVICE_REQUEST          = 2;
    GPU_ERR_SURFACE_CONFIG          = 3;
    GPU_ERR_SURFACE_TIMEOUT         = 4;
    GPU_ERR_SURFACE_OUTDATED        = 5;
    GPU_ERR_SURFACE_LOST            = 6;
    GPU_ERR_SHADER                  = 7;
    GPU_ERR_PIPELINE                = 8;
    GPU_ERR_TEXTURE                 = 9;
    GPU_ERR_IMAGE_DECODE            = 10;
    GPU_ERR_BUFFER                  = 11;
    GPU_ERR_READBACK_MAP            = 12;
    GPU_ERR_READBACK_CHANNEL        = 13;
    GPU_ERR_WORKGROUP_LIMIT         = 14;
    GPU_ERR_TEXTURE_DIMENSION       = 15;
    GPU_ERR_FFI_LOAD                = 16;
    GPU_ERR_FFI_SYMBOL              = 17;
    GPU_ERR_NOT_IMPLEMENTED         = 18;   #skip-lint
    GPU_ERR_FORMAT_UNSUPPORTED      = 19;   # v3.2 T.4 — format unsupported by the active adapter/backend
    GPU_ERR_TRANSFER                = 20;   # v3.2 X.3 — compute/render routed to the DMA (TRANSFER) ring
    GPU_ERR_OTHER                   = 99;
}

# ================================================================
# GpuErr struct
# ================================================================

# Create a GpuErr with code and optional detail string
fn gpu_err_new(code, detail): i64 {
    var e = alloc(16);
    store64(e, code);
    store64(e + 8, detail);
    return e;
}

# Create a GpuErr with code only (no detail)
fn gpu_err(code): i64 {
    return gpu_err_new(code, 0);
}

# Get error code
fn gpu_err_code(e): i64 {
    return load64(e);
}

# Get detail string pointer (or 0)
fn gpu_err_detail(e): i64 {
    return load64(e + 8);
}

# ================================================================
# Sakshi observability wiring (v2.4.1)
# ================================================================
#
# Default: silent. Consumers opt in via mabda_observability_enable()
# OR by configuring sakshi directly (sakshi_set_level / sakshi_output_*).
# When enabled, error.cyr / profiler.cyr / context.cyr emit structured
# events through sakshi's level + span APIs.
#
# The gating flag is independent from sakshi's own level so a consumer
# can keep mabda silent without altering global sakshi state.

var _mabda_obs_enabled = 0;

fn mabda_observability_enable(): i64 { _mabda_obs_enabled = 1; return 0; }
fn mabda_observability_disable(): i64 { _mabda_obs_enabled = 0; return 0; }
fn mabda_observability_is_enabled(): i64 { return _mabda_obs_enabled; }

# Emit a sakshi event for a GpuErr code — recoverable → SK_WARN,
# non-recoverable → SK_ERROR. No-op when observability is disabled.
fn _sk_emit_err(code): i64 {
    if (_mabda_obs_enabled == 0) { return 0; }
    var name = gpu_err_name(code);
    var nlen = strlen(name);
    if (gpu_err_is_recoverable(code) == 1) {
        sakshi_warn(name, nlen);
    } else {
        sakshi_error(name, nlen);
    }
    return 0;
}

# Internal: sakshi_info with a literal cstr — gated.
fn _sk_info_cstr(msg): i64 {
    if (_mabda_obs_enabled == 0) { return 0; }
    sakshi_info(msg, strlen(msg));
    return 0;
}

# ================================================================
# GpuResult helpers — wraps tagged.cyr
# ================================================================
# GpuResult is Ok(value) or Err(gpu_err_ptr)

fn gpu_ok(value): i64 {
    return Ok(value);
}

fn gpu_err_result(code): i64 {
    _sk_emit_err(code);
    return Err(gpu_err(code));
}

fn gpu_err_result_msg(code, msg): i64 {
    _sk_emit_err(code);
    return Err(gpu_err_new(code, msg));
}

fn gpu_result_unwrap(res): i64 {
    if (is_ok(res) == 1) { return payload(res); }
    var e = payload(res);
    var code = gpu_err_code(e);
    syscall(1, 2, "gpu error: ", 11);
    gpu_err_print_name(code);
    var detail = gpu_err_detail(e);
    if (detail != 0) {
        syscall(1, 2, ": ", 2);
        syscall(1, 2, detail, strlen(detail));
    }
    syscall(1, 2, "\n", 1);
    syscall(60, 1);
    return 0;
}

# ================================================================
# Recoverability check
# ================================================================

fn gpu_err_is_recoverable(code): i64 {
    if (code == GPU_ERR_SURFACE_TIMEOUT)  { return 1; }
    if (code == GPU_ERR_SURFACE_OUTDATED) { return 1; }
    if (code == GPU_ERR_SURFACE_CONFIG)   { return 1; }
    return 0;
}

# ================================================================
# Error name lookup
# ================================================================

fn gpu_err_name(code): i64 {
    if (code == GPU_ERR_NONE)               { return "none"; }
    if (code == GPU_ERR_ADAPTER_NOT_FOUND)  { return "adapter not found"; }
    if (code == GPU_ERR_DEVICE_REQUEST)     { return "device request failed"; }
    if (code == GPU_ERR_SURFACE_CONFIG)     { return "surface config failed"; }
    if (code == GPU_ERR_SURFACE_TIMEOUT)    { return "surface timeout"; }
    if (code == GPU_ERR_SURFACE_OUTDATED)   { return "surface outdated"; }
    if (code == GPU_ERR_SURFACE_LOST)       { return "surface lost"; }
    if (code == GPU_ERR_SHADER)             { return "shader error"; }
    if (code == GPU_ERR_PIPELINE)           { return "pipeline error"; }
    if (code == GPU_ERR_TEXTURE)            { return "texture error"; }
    if (code == GPU_ERR_IMAGE_DECODE)       { return "image decode error"; }
    if (code == GPU_ERR_BUFFER)             { return "buffer error"; }
    if (code == GPU_ERR_READBACK_MAP)       { return "readback map failed"; }
    if (code == GPU_ERR_READBACK_CHANNEL)   { return "readback channel closed"; }
    if (code == GPU_ERR_WORKGROUP_LIMIT)    { return "workgroup limit exceeded"; }
    if (code == GPU_ERR_TEXTURE_DIMENSION)  { return "texture dimension exceeded"; }
    if (code == GPU_ERR_FFI_LOAD)           { return "FFI library load failed"; }
    if (code == GPU_ERR_FFI_SYMBOL)         { return "FFI symbol not found"; }
    if (code == GPU_ERR_NOT_IMPLEMENTED)    { return "operation not implemented on this backend"; }  #skip-lint
    if (code == GPU_ERR_FORMAT_UNSUPPORTED) { return "texture format unsupported by this adapter/backend"; }
    if (code == GPU_ERR_TRANSFER)           { return "operation routed to the wrong ring (transfer/DMA mismatch)"; }
    if (code == GPU_ERR_OTHER)              { return "other error"; }
    return "unknown error";
}

fn gpu_err_print_name(code): i64 {
    var name = gpu_err_name(code);
    syscall(1, 2, name, strlen(name));
    return 0;
}

# --- color.cyr ---

# @public — stable API surface (survives the v3.0 backend swap)
# color.cyr — RGBA color type and utilities
# Ported from mabda/src/color.rs
#
# Color is the shared RGBA type for the AGNOS GPU ecosystem.
# All components stored as f64 (0.0–1.0). Converted to f32 at GPU boundary.
#
# Color struct layout (32 bytes):
#   +0:  r (f64 bit pattern)
#   +8:  g (f64 bit pattern)
#   +16: b (f64 bit pattern)
#   +24: a (f64 bit pattern)

# ================================================================
# f64 constants (bit patterns)
# ================================================================

# f64 constants — initialized at runtime via color_init()
var F64_0    = 0;
var F64_1    = 0;
var F64_255  = 0;
var F64_HALF = 0;
var F64_TWO  = 0;

# Rec. 709 luminance coefficients
var F64_LUM_R = 0;  # 0.2126
var F64_LUM_G = 0;  # 0.7152
var F64_LUM_B = 0;  # 0.0722

# Cornflower blue components
var F64_CB_R = 0;   # 0.392
var F64_CB_G = 0;   # 0.584
var F64_CB_B = 0;   # 0.929

var _color_initialized = 0;

fn color_init(): i64 {
    if (_color_initialized == 1) { return 0; }
    _color_initialized = 1;

    F64_0    = f64_from(0);
    F64_1    = f64_from(1);
    F64_255  = f64_from(255);
    F64_HALF = f64_div(f64_from(1), f64_from(2));
    F64_TWO  = f64_from(2);

    # 0.2126 = 2126 / 10000
    F64_LUM_R = f64_div(f64_from(2126), f64_from(10000));
    # 0.7152 = 7152 / 10000
    F64_LUM_G = f64_div(f64_from(7152), f64_from(10000));
    # 0.0722 = 722 / 10000
    F64_LUM_B = f64_div(f64_from(722), f64_from(10000));

    # 0.392 = 392 / 1000
    F64_CB_R = f64_div(f64_from(392), f64_from(1000));
    # 0.584 = 584 / 1000
    F64_CB_G = f64_div(f64_from(584), f64_from(1000));
    # 0.929 = 929 / 1000
    F64_CB_B = f64_div(f64_from(929), f64_from(1000));

    return 0;
}

# ================================================================
# Color constructors
# ================================================================

# Create a Color from f64 RGBA components (0.0–1.0)
fn color_new(r, g, b, a): i64 {
    var c = alloc(32);
    store64(c, r);
    store64(c + 8, g);
    store64(c + 16, b);
    store64(c + 24, a);
    return c;
}

# Create a Color from RGB with full opacity
fn color_rgb(r, g, b): i64 {
    return color_new(r, g, b, F64_1);
}

# Create a Color from 8-bit RGBA (0–255 integer values)
fn color_from_rgba8(r, g, b, a): i64 {
    var fr = f64_div(f64_from(r), F64_255);
    var fg = f64_div(f64_from(g), F64_255);
    var fb = f64_div(f64_from(b), F64_255);
    var fa = f64_div(f64_from(a), F64_255);
    return color_new(fr, fg, fb, fa);
}

# Create a Color from hex (e.g., 0xFF0000FF for opaque red)
fn color_from_hex(hex): i64 {
    var r = (hex >> 24) & 0xFF;
    var g = (hex >> 16) & 0xFF;
    var b = (hex >> 8) & 0xFF;
    var a = hex & 0xFF;
    return color_from_rgba8(r, g, b, a);
}

# ================================================================
# Color accessors
# ================================================================

fn color_r(c): i64 { return load64(c); }
fn color_g(c): i64 { return load64(c + 8); }
fn color_b(c): i64 { return load64(c + 16); }
fn color_a(c): i64 { return load64(c + 24); }

fn color_set_r(c, v): i64 { store64(c, v); return 0; }
fn color_set_g(c, v): i64 { store64(c + 8, v); return 0; }
fn color_set_b(c, v): i64 { store64(c + 16, v); return 0; }
fn color_set_a(c, v): i64 { store64(c + 24, v); return 0; }

# ================================================================
# Color math
# ================================================================

# Luminance (perceived brightness, Rec. 709)
fn color_luminance(c): i64 {
    var r = f64_mul(F64_LUM_R, color_r(c));
    var g = f64_mul(F64_LUM_G, color_g(c));
    var b = f64_mul(F64_LUM_B, color_b(c));
    return f64_add(f64_add(r, g), b);
}

# Linear interpolation between two colors
# t is clamped to [0.0, 1.0]
fn color_lerp(a, b, t): i64 {
    # Clamp t
    if (f64_lt(t, F64_0) == 1) { t = F64_0; }
    if (f64_gt(t, F64_1) == 1) { t = F64_1; }

    var r = f64_add(color_r(a), f64_mul(f64_sub(color_r(b), color_r(a)), t));
    var g = f64_add(color_g(a), f64_mul(f64_sub(color_g(b), color_g(a)), t));
    var bl = f64_add(color_b(a), f64_mul(f64_sub(color_b(b), color_b(a)), t));
    var al = f64_add(color_a(a), f64_mul(f64_sub(color_a(b), color_a(a)), t));
    return color_new(r, g, bl, al);
}

# Check if two colors are equal (exact f64 comparison)
fn color_eq(a, b): i64 {
    if (color_r(a) != color_r(b)) { return 0; }
    if (color_g(a) != color_g(b)) { return 0; }
    if (color_b(a) != color_b(b)) { return 0; }
    if (color_a(a) != color_a(b)) { return 0; }
    return 1;
}

# ================================================================
# GPU conversion — write color as 4x f32 to a buffer
# ================================================================
# wgpu expects f64 for wgpu::Color (clear colors) and f32 for vertex data. The
# f64↔f32 conversions use the Cyrius toolchain's native-float builtins (since
# 6.2.18): `f32_from` (f64→f32 bits, cvtsd2ss/fcvt) and `f32_to` (f32→f64). These
# replace the former hand-rolled x86-64 SSE2 inline-asm shims — now cross-platform
# (the builtins carry the aarch64 NEON path too). The descriptive mabda names are
# kept as the GPU-boundary idiom (see CLAUDE.md: "f32 at the GPU boundary").

# Convert an f64 bit pattern to an f32 bit pattern (in the low 32 bits).
fn f64_to_f32(val): i64 {
    return f32_from(val);
}

# Convert an f32 bit pattern (low 32 bits) to an f64 bit pattern.
fn f32_to_f64(val): i64 {
    return f32_to(val);
}

# f32 bit pattern of (double)num / (double)den (the texture-blit scale tex_dim /
# rt_dim). Now expressed in native builtins: integer → f64 → divide → f32.
# CPU-tested: 1/1=0x3F800000, 1/2=0x3F000000, 2/64=0x3D000000.
fn int_ratio_to_f32(num, den): i64 {
    return f32_from(f64_div(f64_from(num), f64_from(den)));
}

# Write color as 4x f32 (16 bytes) to destination pointer
# Used for vertex color data, uniform buffers, etc.
fn color_write_f32(c, dst): i64 {
    store32(dst, f64_to_f32(color_r(c)));
    store32(dst + 4, f64_to_f32(color_g(c)));
    store32(dst + 8, f64_to_f32(color_b(c)));
    store32(dst + 12, f64_to_f32(color_a(c)));
    return 0;
}

# Write color as 4x f64 (32 bytes) to destination pointer
# Used for wgpu::Color (clear colors in render passes)
fn color_write_f64(c, dst): i64 {
    store64(dst, color_r(c));
    store64(dst + 8, color_g(c));
    store64(dst + 16, color_b(c));
    store64(dst + 24, color_a(c));
    return 0;
}

# ================================================================
# Preset colors (allocated on first use via alloc)
# ================================================================

var _COLOR_WHITE = 0;
var _COLOR_BLACK = 0;
var _COLOR_RED = 0;
var _COLOR_GREEN = 0;
var _COLOR_BLUE = 0;
var _COLOR_TRANSPARENT = 0;
var _COLOR_CORNFLOWER_BLUE = 0;

fn COLOR_WHITE(): i64 {
    if (_COLOR_WHITE == 0) { _COLOR_WHITE = color_new(F64_1, F64_1, F64_1, F64_1); }
    return _COLOR_WHITE;
}
fn COLOR_BLACK(): i64 {
    if (_COLOR_BLACK == 0) { _COLOR_BLACK = color_new(F64_0, F64_0, F64_0, F64_1); }
    return _COLOR_BLACK;
}
fn COLOR_RED(): i64 {
    if (_COLOR_RED == 0) { _COLOR_RED = color_new(F64_1, F64_0, F64_0, F64_1); }
    return _COLOR_RED;
}
fn COLOR_GREEN(): i64 {
    if (_COLOR_GREEN == 0) { _COLOR_GREEN = color_new(F64_0, F64_1, F64_0, F64_1); }
    return _COLOR_GREEN;
}
fn COLOR_BLUE(): i64 {
    if (_COLOR_BLUE == 0) { _COLOR_BLUE = color_new(F64_0, F64_0, F64_1, F64_1); }
    return _COLOR_BLUE;
}
fn COLOR_TRANSPARENT(): i64 {
    if (_COLOR_TRANSPARENT == 0) { _COLOR_TRANSPARENT = color_new(F64_0, F64_0, F64_0, F64_0); }
    return _COLOR_TRANSPARENT;
}
fn COLOR_CORNFLOWER_BLUE(): i64 {
    if (_COLOR_CORNFLOWER_BLUE == 0) {
        _COLOR_CORNFLOWER_BLUE = color_new(F64_CB_R, F64_CB_G, F64_CB_B, F64_1);
    }
    return _COLOR_CORNFLOWER_BLUE;
}

# --- capabilities.cyr ---

# @public — stable API surface (survives the v3.0 backend swap)
# capabilities.cyr — GPU capability reporting
# Ported from mabda/src/capabilities.rs
#
# GpuCapabilities struct layout (136 bytes — grew 128 -> 136 at v3.2 F.1 for the
# shader_f64 flag; the texture-compression bitset grew it 120 -> 128 at T.4):
#   +0:  adapter_name     (str ptr)
#   +8:  backend          (str ptr)
#   +16: timestamp_query  (i64 bool)
#   +24: compute_shaders  (i64 bool)
#   +32: max_texture_dimension_2d  (i64)
#   +40: max_uniform_buffer_size   (i64)
#   +48: max_storage_buffer_size   (i64)
#   +56: max_buffer_size           (i64)
#   +64: max_bind_groups           (i64)
#   +72: max_vertex_buffers        (i64)
#   +80: max_compute_wg_x          (i64)
#   +88: max_compute_wg_y          (i64)
#   +96: max_compute_wg_z          (i64)
#   +104: max_compute_wgs_per_dim  (i64)
#   +112: multi_draw_indirect      (i64 bool)
#   +120: texture_compression      (i64 bitset: MABDA_TEXCOMP_BC/ETC2/ASTC,
#                                    defined in texture_format.cyr. 0 in a fresh
#                                    gpu_caps_new(); consumers populate it —
#                                    wgpu via gpu_caps_detect_texture_compression
#                                    (adapter), native via
#                                    gpu_caps_native_texture_compression()
#                                    (= MABDA_TEXCOMP_BC, v3.2 TS — native AMD
#                                    samples BC, no longer storage-only))
#   +128: shader_f64       (i64 bool: device+shader-path f64 (double) support; 0 in a
#                            fresh gpu_caps_new(). Populated by backend detection — wgpu via
#                            gpu_caps_wgpu_shader_f64 (the WGPUNativeFeature_ShaderF64 device
#                            bit, gated by the wgpu-compute-dispatch stub), native via
#                            gpu_caps_native_shader_f64 / the SPIR-V→GFX9 f64 emitter. v3.2 F.1)

fn gpu_caps_new(): i64 {
    var c = alloc(136);
    memset(c, 0, 136);
    store64(c + 24, 1);   # compute_shaders = true (always for wgpu)
    return c;
}

# Accessors
fn gpu_caps_adapter_name(c): i64 { return load64(c); }
fn gpu_caps_backend(c): i64 { return load64(c + 8); }
fn gpu_caps_timestamp_query(c): i64 { return load64(c + 16); }
fn gpu_caps_compute_shaders(c): i64 { return load64(c + 24); }
fn gpu_caps_max_texture_2d(c): i64 { return load64(c + 32); }
fn gpu_caps_max_uniform_buffer(c): i64 { return load64(c + 40); }
fn gpu_caps_max_storage_buffer(c): i64 { return load64(c + 48); }
fn gpu_caps_max_buffer_size(c): i64 { return load64(c + 56); }
fn gpu_caps_max_bind_groups(c): i64 { return load64(c + 64); }
fn gpu_caps_max_vertex_buffers(c): i64 { return load64(c + 72); }
fn gpu_caps_max_compute_wg_x(c): i64 { return load64(c + 80); }
fn gpu_caps_max_compute_wg_y(c): i64 { return load64(c + 88); }
fn gpu_caps_max_compute_wg_z(c): i64 { return load64(c + 96); }
fn gpu_caps_max_compute_wgs_dim(c): i64 { return load64(c + 104); }
fn gpu_caps_multi_draw_indirect(c): i64 { return load64(c + 112); }
# v3.2 T.4 — texture-compression family bitset (MABDA_TEXCOMP_* mask).
# gpu_caps_supports_format (texture_format.cyr) reads it.
fn gpu_caps_texture_compression(c): i64 { return load64(c + 120); }
# v3.2 F.1 — double-precision (f64) compute support (a device+shader-path capability;
# populated by the F.2 detection, read by the F.3 dispatch guard).
fn gpu_caps_shader_f64(c): i64 { return load64(c + 128); }

# Setters (used by from_context to populate)
fn gpu_caps_set_adapter_name(c, v): i64 { store64(c, v); return 0; }
fn gpu_caps_set_backend(c, v): i64 { store64(c + 8, v); return 0; }
fn gpu_caps_set_timestamp_query(c, v): i64 { store64(c + 16, v); return 0; }
fn gpu_caps_set_max_texture_2d(c, v): i64 { store64(c + 32, v); return 0; }
fn gpu_caps_set_max_uniform(c, v): i64 { store64(c + 40, v); return 0; }
fn gpu_caps_set_max_storage(c, v): i64 { store64(c + 48, v); return 0; }
fn gpu_caps_set_max_buffer(c, v): i64 { store64(c + 56, v); return 0; }
fn gpu_caps_set_max_bind_groups(c, v): i64 { store64(c + 64, v); return 0; }
fn gpu_caps_set_max_vertex_buf(c, v): i64 { store64(c + 72, v); return 0; }
fn gpu_caps_set_compute_wg(c, x, y, z): i64 {
    store64(c + 80, x);
    store64(c + 88, y);
    store64(c + 96, z);
    return 0;
}
fn gpu_caps_set_compute_wgs_dim(c, v): i64 { store64(c + 104, v); return 0; }
fn gpu_caps_set_multi_draw(c, v): i64 { store64(c + 112, v); return 0; }
fn gpu_caps_set_texture_compression(c, mask): i64 { store64(c + 120, mask); return 0; }
fn gpu_caps_set_shader_f64(c, v): i64 { store64(c + 128, v); return 0; }

# Validation helpers
fn gpu_caps_uniform_fits(c, size): i64 {
    if (size <= gpu_caps_max_uniform_buffer(c)) { return 1; }
    return 0;
}

fn gpu_caps_storage_fits(c, size): i64 {
    if (size <= gpu_caps_max_storage_buffer(c)) { return 1; }
    return 0;
}

# WebGPU compatibility constants
var WEBGPU_MAX_UNIFORM_BUFFER = 65536;
var WEBGPU_MAX_STORAGE_BUFFER = 134217728;
var WEBGPU_MAX_BIND_GROUPS = 4;
var WEBGPU_MAX_TEXTURE_2D = 8192;

fn webgpu_uniform_fits(size): i64 {
    if (size <= WEBGPU_MAX_UNIFORM_BUFFER) { return 1; }
    return 0;
}

# --- profiler.cyr ---

# @public — stable API surface (survives the v3.0 backend swap)
# profiler.cyr — CPU frame profiling
# Ported from mabda/src/profiler.rs
#
# FrameProfiler: EMA smoothing, frame timing, history ring buffer, pass timing
# No RAII ProfileScope — use explicit profile_begin/profile_end instead
#
# FrameProfiler struct layout (72 bytes):
#   +0:  frame_start_sec  (i64 — seconds from clock_gettime)
#   +8:  frame_start_nsec (i64 — nanoseconds)
#   +16: cpu_frame_ms     (f64)
#   +24: avg_frame_ms     (f64)
#   +32: fps              (f64)
#   +40: frame_count      (i64)
#   +48: alpha            (f64)
#   +56: history          (vec ptr — vec of f64 frame times)
#   +64: history_cap      (i64)
#
# PassTiming (24 bytes):
#   +0:  label       (str ptr)
#   +8:  label_len   (i64)
#   +16: duration_ms (f64)

# ================================================================
# Time helpers — clock_gettime(CLOCK_MONOTONIC)
# ================================================================

# SYS_clock_gettime = 228, CLOCK_MONOTONIC = 1
# Zero ts before the syscall so a kernel failure (non-zero return) produces
# a deterministic 0 timestamp rather than garbage stack data (audit MED-6).
fn _time_now_ns(): i64 {
    var ts[16];  # timespec: tv_sec(8) + tv_nsec(8)
    store64(&ts, 0);
    store64(&ts + 8, 0);
    syscall(228, 1, &ts);
    var sec = load64(&ts);
    var nsec = load64(&ts + 8);
    # Return total nanoseconds as i64 (good for ~292 years)
    return sec * 1000000000 + nsec;
}

# Convert nanosecond delta to f64 milliseconds
fn _ns_to_ms(ns): i64 {
    # ms = ns / 1_000_000
    var f_ns = f64_from(ns);
    var f_million = f64_from(1000000);
    return f64_div(f_ns, f_million);
}

# ================================================================
# FrameProfiler
# ================================================================

fn profiler_new(): i64 {
    return profiler_with_alpha_and_history(
    f64_div(f64_from(5), f64_from(100)),   # 0.05
    300
    );
}

fn profiler_with_alpha(alpha): i64 {
    return profiler_with_alpha_and_history(alpha, 300);
}

fn profiler_with_alpha_and_history(alpha, history_cap): i64 {
    var p = alloc(72);
    store64(p, 0);           # frame_start_sec
    store64(p + 8, 0);       # frame_start_nsec
    store64(p + 16, F64_0);  # cpu_frame_ms
    # avg_frame_ms = 16.67
    store64(p + 24, f64_div(f64_from(1667), f64_from(100)));
    # fps = 60.0
    store64(p + 32, f64_from(60));
    store64(p + 40, 0);      # frame_count
    # Clamp alpha to [0.001, 1.0]
    var f_min = f64_div(f64_from(1), f64_from(1000));
    if (f64_lt(alpha, f_min) == 1) { alpha = f_min; }
    if (f64_gt(alpha, F64_1) == 1) { alpha = F64_1; }
    store64(p + 48, alpha);
    store64(p + 56, vec_new());  # history vec
    store64(p + 64, history_cap);
    return p;
}

# Accessors
fn profiler_cpu_frame_ms(p): i64 { return load64(p + 16); }
fn profiler_avg_frame_ms(p): i64 { return load64(p + 24); }
fn profiler_fps(p): i64 { return load64(p + 32); }
fn profiler_frame_count(p): i64 { return load64(p + 40); }

# Sakshi span name for profiler frames (v2.4.1). Emitted between
# begin/end_frame when mabda observability is enabled — gives sakshi
# trace consumers per-frame timing for free without changing the
# profiler's existing timing math.
var _MABDA_FRAME_SPAN = "frame";

fn profiler_begin_frame(p): i64 {
    if (_mabda_obs_enabled == 1) { sakshi_span_enter(_MABDA_FRAME_SPAN, 5); }
    var now = _time_now_ns();
    store64(p, now);
    return 0;
}

fn profiler_end_frame(p): i64 {
    var start = load64(p);
    var now = _time_now_ns();
    var elapsed_ns = now - start;
    var elapsed_ms = _ns_to_ms(elapsed_ns);

    # cpu_frame_ms = elapsed
    store64(p + 16, elapsed_ms);

    # EMA: avg = avg * (1 - alpha) + elapsed * alpha
    var avg = load64(p + 24);
    var alpha = load64(p + 48);
    var one_minus_alpha = f64_sub(F64_1, alpha);
    var new_avg = f64_add(f64_mul(avg, one_minus_alpha), f64_mul(elapsed_ms, alpha));
    store64(p + 24, new_avg);

    # fps = 1000.0 / avg_frame_ms
    var f_1000 = f64_from(1000);
    if (f64_gt(new_avg, F64_0) == 1) {
        store64(p + 32, f64_div(f_1000, new_avg));
    } else {
        store64(p + 32, F64_0);
    }

    # frame_count++
    store64(p + 40, load64(p + 40) + 1);

    # Record in history ring buffer
    var history = load64(p + 56);
    var cap = load64(p + 64);
    if (vec_len(history) >= cap) {
        # Remove oldest (shift left — simple but O(n))
        _vec_shift_left(history);
    }
    vec_push(history, elapsed_ms);

    if (_mabda_obs_enabled == 1) { sakshi_span_exit(); }
    return elapsed_ms;
}

# Shift all elements left by 1, drop index 0
fn _vec_shift_left(v): i64 {
    var len = vec_len(v);
    if (len <= 1) {
        if (len == 1) { vec_pop(v); }
        return 0;
    }
    for (var i = 0; i < len - 1; i = i + 1) {
        vec_set(v, i, vec_get(v, i + 1));
    }
    vec_pop(v);
    return 0;
}

fn profiler_reset(p): i64 {
    store64(p + 16, F64_0);
    store64(p + 24, f64_div(f64_from(1667), f64_from(100)));
    store64(p + 32, f64_from(60));
    store64(p + 40, 0);
    var history = load64(p + 56);
    # Clear history
    while (vec_len(history) > 0) { vec_pop(history); }
    return 0;
}

fn profiler_worst_frame_ms(p): i64 {
    var history = load64(p + 56);
    var len = vec_len(history);
    if (len == 0) { return F64_0; }
    var worst = vec_get(history, 0);
    for (var i = 1; i < len; i = i + 1) {
        var v = vec_get(history, i);
        if (f64_gt(v, worst) == 1) { worst = v; }
    }
    return worst;
}

fn profiler_best_frame_ms(p): i64 {
    var history = load64(p + 56);
    var len = vec_len(history);
    if (len == 0) { return F64_0; }
    var best = vec_get(history, 0);
    for (var i = 1; i < len; i = i + 1) {
        var v = vec_get(history, i);
        if (f64_lt(v, best) == 1) { best = v; }
    }
    return best;
}

# ================================================================
# Explicit profiling (replaces RAII ProfileScope)
# ================================================================

# Begin timing a pass — returns timestamp (nanoseconds)
fn profile_begin(): i64 {
    return _time_now_ns();
}

# End timing a pass — returns duration in f64 milliseconds
fn profile_end(start_ns): i64 {
    var now = _time_now_ns();
    return _ns_to_ms(now - start_ns);
}

# --- resource.cyr ---

# @public — stable API surface (survives the v3.0 backend swap)
# resource.cyr — frame resource tracking
# Ported from mabda/src/resource.rs; v3 Step 4f.iii made it
# ctx-aware so cleanup can route through the Backend abstraction.
#
# FrameResources struct layout (24 bytes — grew from 16 at v3 4f.iii):
#   +0:  ctx      (GpuContext*, 8 — optional; 0 = legacy untracked-ctx)
#   +8:  buffers  (vec ptr — opaque u64 buffer handles)
#   +16: textures (vec ptr — opaque u64 texture handles)
#
# Storage is backend-agnostic: u64 handles fit both wgpu (WGPUBuffer/
# WGPUTexture) and native (KMS handles for amdgpu BOs). Cleanup is
# the part that needs backend dispatch — frame_resources_release_buffers
# routes through gpu_buffer_release(ctx, h), which goes through
# ctx->backend->buffer_release. Texture cleanup stays caller-managed
# until the texture slot lands in the Backend interface (Phase C work).
#
# Two construction paths:
#   frame_resources_new()        — legacy, no ctx; cleanup is caller's
#                                  responsibility
#   frame_resources_new_for(ctx) — v3-shape; release_buffers dispatches
#                                  through ctx->backend

fn frame_resources_new(): i64 {
    var fr = alloc(24);
    memset(fr, 0, 24);
    store64(fr,      0);             # ctx unset
    store64(fr + 8,  vec_new());     # buffers
    store64(fr + 16, vec_new());     # textures
    return fr;
}

fn frame_resources_new_for(ctx): i64 {
    var fr = alloc(24);
    memset(fr, 0, 24);
    store64(fr,      ctx);
    store64(fr + 8,  vec_new());
    store64(fr + 16, vec_new());
    return fr;
}

fn frame_resources_ctx(fr): i64 { return load64(fr); }

fn frame_resources_track_buffer(fr, buffer): i64 {
    vec_push(load64(fr + 8), buffer);
    return 0;
}

fn frame_resources_track_texture(fr, texture): i64 {
    vec_push(load64(fr + 16), texture);
    return 0;
}

fn frame_resources_buffer_count(fr): i64 {
    return vec_len(load64(fr + 8));
}

fn frame_resources_texture_count(fr): i64 {
    return vec_len(load64(fr + 16));
}

# Pop every tracked handle without releasing. Useful when the
# caller has already done backend-specific cleanup and just wants
# to reset the tracker. Identical to the v2.x behaviour; preserved
# for legacy callers that managed release manually.
fn frame_resources_clear(fr): i64 {
    var bufs = load64(fr + 8);
    while (vec_len(bufs) > 0) { vec_pop(bufs); }
    var texs = load64(fr + 16);
    while (vec_len(texs) > 0) { vec_pop(texs); }
    return 0;
}

# Pop every tracked buffer handle and dispatch
# gpu_buffer_release(ctx, h) for each. Routes through
# ctx->backend->buffer_release, so it works for both wgpu and
# native backends. Returns the number of buffers released.
#
# Requires that the FrameResources was created with
# frame_resources_new_for(ctx); on a legacy frame_resources_new()
# instance (ctx == 0) this is a no-op that returns 0 — caller is
# expected to handle release themselves in that case.
#
# Texture release is not yet dispatchable (see docs/development/roadmap.md)
# through the Backend interface (the texture slot lands in Phase C);
# textures stay tracked but caller-released until then.
fn frame_resources_release_buffers(fr): i64 {
    var ctx = load64(fr);
    if (ctx == 0) { return 0; }
    var bufs = load64(fr + 8);
    var n = vec_len(bufs);
    var i = 0;
    while (vec_len(bufs) > 0) {
        var h = vec_pop(bufs);
        gpu_buffer_release(ctx, h);
        i = i + 1;
    }
    return i;
}

# --- wgpu_types.cyr ---

# @internal — FFI / toolchain scaffolding, replaced in v3.0
# wgpu_types.cyr — wgpu-native C API constants
# Maps to webgpu.h v29.0.0.0 enums and flags
#
# In object mode, _cyrius_init() initializes all enum values.

# ================================================================
# WGPUBufferUsage (flags — combine with |)
# ================================================================
enum WGPUBufferUsage {
    WGPU_BUFFER_USAGE_NONE          = 0x0000;
    WGPU_BUFFER_USAGE_MAP_READ      = 0x0001;
    WGPU_BUFFER_USAGE_MAP_WRITE     = 0x0002;
    WGPU_BUFFER_USAGE_COPY_SRC      = 0x0004;
    WGPU_BUFFER_USAGE_COPY_DST      = 0x0008;
    WGPU_BUFFER_USAGE_INDEX         = 0x0010;
    WGPU_BUFFER_USAGE_VERTEX        = 0x0020;
    WGPU_BUFFER_USAGE_UNIFORM       = 0x0040;
    WGPU_BUFFER_USAGE_STORAGE       = 0x0080;
    WGPU_BUFFER_USAGE_INDIRECT      = 0x0100;
    WGPU_BUFFER_USAGE_QUERY_RESOLVE = 0x0200;
}

# ================================================================
# WGPUMapMode
# ================================================================
enum WGPUMapMode {
    WGPU_MAP_MODE_NONE  = 0x0000;
    WGPU_MAP_MODE_READ  = 0x0001;
    WGPU_MAP_MODE_WRITE = 0x0002;
}

# ================================================================
# WGPUPowerPreference
# ================================================================
enum WGPUPowerPreference {
    WGPU_POWER_PREFERENCE_UNDEFINED        = 0;
    WGPU_POWER_PREFERENCE_LOW_POWER        = 1;
    WGPU_POWER_PREFERENCE_HIGH_PERFORMANCE = 2;
}

# ================================================================
# WGPUCallbackMode
# ================================================================
enum WGPUCallbackMode {
    WGPU_CALLBACK_MODE_WAIT_ANY_ONLY       = 1;
    WGPU_CALLBACK_MODE_ALLOW_PROCESS_EVENTS = 2;
    WGPU_CALLBACK_MODE_ALLOW_SPONTANEOUS   = 3;
}

# ================================================================
# WGPURequestAdapterStatus / WGPURequestDeviceStatus
# ================================================================
enum WGPURequestStatus {
    WGPU_REQUEST_ADAPTER_STATUS_SUCCESS = 1;
    WGPU_REQUEST_DEVICE_STATUS_SUCCESS  = 1;
}

# ================================================================
# WGPUBufferMapAsyncStatus
# ================================================================
enum WGPUBufferMapAsyncStatus {
    WGPU_BUFFER_MAP_ASYNC_STATUS_SUCCESS = 1;
}

# ================================================================
# WGPUBufferBindingType — wgpu v29 renumbering
# `BindingNotUsed = 0` was added, shifting every subsequent value up.
# Passing `Uniform = 1` against v29 is read as `Undefined`; validation
# then rejects the descriptor (or silently treats storage as uniform).
# ================================================================
enum WGPUBufferBindingType {
    WGPU_BUFFER_BINDING_TYPE_BINDING_NOT_USED  = 0;
    WGPU_BUFFER_BINDING_TYPE_UNDEFINED         = 1;
    WGPU_BUFFER_BINDING_TYPE_UNIFORM           = 2;
    WGPU_BUFFER_BINDING_TYPE_STORAGE           = 3;
    WGPU_BUFFER_BINDING_TYPE_READ_ONLY_STORAGE = 4;
}

# ================================================================
# WGPUShaderStage (flags)
# ================================================================
enum WGPUShaderStage {
    WGPU_SHADER_STAGE_NONE     = 0x00;
    WGPU_SHADER_STAGE_VERTEX   = 0x01;
    WGPU_SHADER_STAGE_FRAGMENT = 0x02;
    WGPU_SHADER_STAGE_COMPUTE  = 0x04;
}

# ================================================================
# WGPUTextureFormat (subset — values verified against wgpu-native v29)
# ================================================================
enum WGPUTextureFormat {
    WGPU_TEXTURE_FORMAT_RGBA8_UNORM           = 0x16;  # 22
    WGPU_TEXTURE_FORMAT_RGBA8_UNORM_SRGB      = 0x17;  # 23
    WGPU_TEXTURE_FORMAT_BGRA8_UNORM           = 0x1B;  # 27
    WGPU_TEXTURE_FORMAT_BGRA8_UNORM_SRGB      = 0x1C;  # 28
    WGPU_TEXTURE_FORMAT_DEPTH24_PLUS          = 0x2E;  # 46
    WGPU_TEXTURE_FORMAT_DEPTH24_PLUS_STENCIL8 = 0x2F;  # 47
    WGPU_TEXTURE_FORMAT_DEPTH32_FLOAT         = 0x30;  # 48
    WGPU_TEXTURE_FORMAT_DEPTH32_FLOAT_STENCIL8 = 0x31; # 49
    # v3.2 T.2 — block-compressed formats. Values from
    # deps/wgpu-native/include/webgpu/webgpu.h v29 (line cited per row).
    WGPU_TEXTURE_FORMAT_BC1_RGBA_UNORM        = 0x32;  # webgpu.h:1075
    WGPU_TEXTURE_FORMAT_BC3_RGBA_UNORM        = 0x36;  # webgpu.h:1079
    WGPU_TEXTURE_FORMAT_BC4_R_UNORM           = 0x38;  # webgpu.h:1081
    WGPU_TEXTURE_FORMAT_BC5_RG_UNORM          = 0x3A;  # webgpu.h:1083
    WGPU_TEXTURE_FORMAT_BC6H_RGB_UFLOAT       = 0x3C;  # webgpu.h:1085
    WGPU_TEXTURE_FORMAT_BC7_RGBA_UNORM        = 0x3E;  # webgpu.h:1087
    WGPU_TEXTURE_FORMAT_ETC2_RGB8_UNORM       = 0x40;  # webgpu.h:1089
    WGPU_TEXTURE_FORMAT_ETC2_RGBA8_UNORM      = 0x44;  # webgpu.h:1093
    WGPU_TEXTURE_FORMAT_ASTC_4X4_UNORM        = 0x4A;  # webgpu.h:1099
    WGPU_TEXTURE_FORMAT_ASTC_6X6_UNORM        = 0x52;  # webgpu.h:1107
    WGPU_TEXTURE_FORMAT_ASTC_8X8_UNORM        = 0x58;  # webgpu.h:1113
}

# ================================================================
# WGPULoadOp / WGPUStoreOp
# ================================================================
enum WGPULoadOp {
    WGPU_LOAD_OP_UNDEFINED = 0;
    WGPU_LOAD_OP_LOAD      = 1;
    WGPU_LOAD_OP_CLEAR     = 2;
}

enum WGPUStoreOp {
    WGPU_STORE_OP_UNDEFINED = 0;
    WGPU_STORE_OP_STORE     = 1;
    WGPU_STORE_OP_DISCARD   = 2;
}

# ================================================================
# WGPUChainedStruct sType (wgpu-native v29 values)
# ================================================================
enum WGPUSType {
    WGPU_STYPE_SHADER_SOURCE_SPIRV = 0x00000001;   # webgpu.h v29 (Phase S)
    WGPU_STYPE_SHADER_SOURCE_WGSL  = 0x00000002;
}

# ================================================================
# WGPU_WHOLE_SIZE sentinel
# ================================================================
var WGPU_WHOLE_SIZE = 0 - 1;

# --- texture_format.cyr ---

# @public — texture format breadth (v3.2 Phase T)
# texture_format.cyr — mabda's backend-agnostic texture format ids +
# block geometry. Pure Cyrius: no FFI, no syscalls, no HW.
#
# This is the foundation of the v3.2.0 compressed-texture work
# (docs/proposals/v3.2-compressed-textures.md, punchlist Phase T). A
# `MABDA_TEXFMT_*` id is the format a consumer passes to the (T.5)
# `gpu_texture_create_2d(ctx, w, h, fmt)` API; T.2 maps each id to its
# v29 `WGPUTextureFormat` value; T.3 uses the block geometry here for the
# block-based size math (`ceil(w/bw)*ceil(h/bh)*block_bytes`).
#
# Block-compressed formats are addressed in fixed-size texel blocks, not
# per-texel: BC/ETC2 are 4x4 blocks; ASTC blocks vary (4x4 / 6x6 / 8x8).
# `block_bytes` is the encoded size of ONE block. Uncompressed RGBA8 is
# modeled as a 1x1 "block" of 4 bytes so the same block math covers it.

# ================================================================
# Format ids (stable ABI — consumers pass these to gpu_texture_create_2d)
# ================================================================
# RGBA8 is 0 so the uncompressed default is the zero value. The
# compressed families follow; MABDA_TEXFMT_COUNT bounds validation +
# iteration. Adding a format appends before COUNT — never renumber.
enum MabdaTexFmt {
    MABDA_TEXFMT_RGBA8       = 0;
    MABDA_TEXFMT_BC1        = 1;   # DXT1  — RGB(+1bit A), 4x4, 8 B
    MABDA_TEXFMT_BC3        = 2;   # DXT5  — RGBA,         4x4, 16 B
    MABDA_TEXFMT_BC4        = 3;   # 1-channel,            4x4, 8 B
    MABDA_TEXFMT_BC5        = 4;   # 2-channel,            4x4, 16 B
    MABDA_TEXFMT_BC6H       = 5;   # HDR RGB,              4x4, 16 B
    MABDA_TEXFMT_BC7        = 6;   # RGBA hi-q,            4x4, 16 B
    MABDA_TEXFMT_ETC2_RGB8  = 7;   # ETC2 RGB,            4x4, 8 B
    MABDA_TEXFMT_ETC2_RGBA8 = 8;   # ETC2 RGBA,           4x4, 16 B
    MABDA_TEXFMT_ASTC_4X4   = 9;   # ASTC 4x4,            4x4, 16 B
    MABDA_TEXFMT_ASTC_6X6   = 10;  # ASTC 6x6,            6x6, 16 B
    MABDA_TEXFMT_ASTC_8X8   = 11;  # ASTC 8x8,            8x8, 16 B
    MABDA_TEXFMT_COUNT      = 12;
}

# ================================================================
# Block geometry accessors
# ================================================================
# All return 0 for an out-of-range / unknown id (callers treat
# block_bytes == 0 as "invalid format"). Every compressed format mabda
# ships has a square block, so block_width == block_height; both
# accessors exist so the block math reads symmetrically and a future
# non-square format only touches one of them.

# 1 if `fmt` is a block-compressed format, 0 for RGBA8 or an invalid id.
fn mabda_texfmt_is_compressed(fmt): i64 {
    if (fmt <= MABDA_TEXFMT_RGBA8) { return 0; }   # RGBA8 (0) or negative
    if (fmt >= MABDA_TEXFMT_COUNT) { return 0; }   # out of range
    return 1;
}

# Block width in texels (1 for uncompressed; 4/6/8 for compressed).
fn mabda_texfmt_block_width(fmt): i64 {
    if (fmt == MABDA_TEXFMT_RGBA8)     { return 1; }
    if (fmt == MABDA_TEXFMT_ASTC_6X6)  { return 6; }
    if (fmt == MABDA_TEXFMT_ASTC_8X8)  { return 8; }
    if (mabda_texfmt_is_compressed(fmt) == 1) { return 4; }
    return 0;
}

# Block height in texels (square blocks today, so == block_width).
fn mabda_texfmt_block_height(fmt): i64 {
    if (fmt == MABDA_TEXFMT_RGBA8)     { return 1; }
    if (fmt == MABDA_TEXFMT_ASTC_6X6)  { return 6; }
    if (fmt == MABDA_TEXFMT_ASTC_8X8)  { return 8; }
    if (mabda_texfmt_is_compressed(fmt) == 1) { return 4; }
    return 0;
}

# Encoded bytes of ONE block (4 for RGBA8's 1x1 "block"). The 8-byte
# compressed formats are BC1, BC4, and ETC2_RGB8; every other compressed
# format is 16 bytes/block (including all ASTC, regardless of block dims).
fn mabda_texfmt_block_bytes(fmt): i64 {
    if (fmt == MABDA_TEXFMT_RGBA8)      { return 4; }
    if (fmt == MABDA_TEXFMT_BC1)        { return 8; }
    if (fmt == MABDA_TEXFMT_BC4)        { return 8; }
    if (fmt == MABDA_TEXFMT_ETC2_RGB8)  { return 8; }
    if (mabda_texfmt_is_compressed(fmt) == 1) { return 16; }
    return 0;
}

# ================================================================
# v3.2 T.2 — mabda id -> v29 WGPUTextureFormat value
# ================================================================
# The wgpu backend (T.6) hands this value to wgpu_texture_descriptor_*;
# native ignores it (it keys off the mabda id). Returns 0 for an unknown
# id — 0 is WGPUTextureFormat_Undefined in v29, so the wgpu path can treat
# a 0 result as "reject". BC6H maps to the unsigned-float variant
# (BC6HRGBUfloat); the signed BC6HRGBFloat is not exposed as a separate
# mabda id today. Each value is the constant from wgpu_types.cyr, itself
# pinned against webgpu.h v29 line-by-line.
fn mabda_texfmt_to_wgpu(fmt): i64 {
    if (fmt == MABDA_TEXFMT_RGBA8)       { return WGPU_TEXTURE_FORMAT_RGBA8_UNORM; }
    if (fmt == MABDA_TEXFMT_BC1)         { return WGPU_TEXTURE_FORMAT_BC1_RGBA_UNORM; }
    if (fmt == MABDA_TEXFMT_BC3)         { return WGPU_TEXTURE_FORMAT_BC3_RGBA_UNORM; }
    if (fmt == MABDA_TEXFMT_BC4)         { return WGPU_TEXTURE_FORMAT_BC4_R_UNORM; }
    if (fmt == MABDA_TEXFMT_BC5)         { return WGPU_TEXTURE_FORMAT_BC5_RG_UNORM; }
    if (fmt == MABDA_TEXFMT_BC6H)        { return WGPU_TEXTURE_FORMAT_BC6H_RGB_UFLOAT; }
    if (fmt == MABDA_TEXFMT_BC7)         { return WGPU_TEXTURE_FORMAT_BC7_RGBA_UNORM; }
    if (fmt == MABDA_TEXFMT_ETC2_RGB8)   { return WGPU_TEXTURE_FORMAT_ETC2_RGB8_UNORM; }
    if (fmt == MABDA_TEXFMT_ETC2_RGBA8)  { return WGPU_TEXTURE_FORMAT_ETC2_RGBA8_UNORM; }
    if (fmt == MABDA_TEXFMT_ASTC_4X4)    { return WGPU_TEXTURE_FORMAT_ASTC_4X4_UNORM; }
    if (fmt == MABDA_TEXFMT_ASTC_6X6)    { return WGPU_TEXTURE_FORMAT_ASTC_6X6_UNORM; }
    if (fmt == MABDA_TEXFMT_ASTC_8X8)    { return WGPU_TEXTURE_FORMAT_ASTC_8X8_UNORM; }
    return 0;   # WGPUTextureFormat_Undefined
}

# ================================================================
# v3.2 T.3 — block size math + the dimension/overflow bound
# ================================================================
# WebGPU spec minimum maxTextureDimension2D = 8192; larger creations are
# rejected before hitting the backend (Audit LOW-3). Lives here (the
# foundation module) so this block math and texture.cyr's
# validate_dimensions share one bound.
var MABDA_MAX_TEXTURE_DIM_2D = 8192;

# Number of blocks spanning `dim` texels for a block edge of `b`:
# ceil(dim / b) = (dim + b - 1) / b. Returns 0 for a non-positive dim or
# block edge (invalid input).
fn mabda_texfmt_blocks_for_dim(dim, b): i64 {
    if (dim <= 0) { return 0; }
    if (b <= 0)   { return 0; }
    return (dim + b - 1) / b;
}

# Total encoded bytes for a w x h texture in `fmt`:
# blocks_x * blocks_y * block_bytes. Returns 0 on invalid format,
# non-positive dims, or dims past MABDA_MAX_TEXTURE_DIM_2D.
#
# Overflow re-derivation (security checklist, not inferred): both dims are
# capped at 8192 before the multiply. The largest product is RGBA8's
# 8192*8192*4 = 268,435,456 B (256 MiB); the compressed worst case is
# 16 B/block over ceil(8192/4)^2 = 2048*2048 blocks = 67,108,864 B
# (64 MiB) — compressed is always <= the RGBA8 size for the same dims. Both
# are far under i64 max, so after the dim cap the bx*by*bytes multiply
# cannot overflow.
fn mabda_texfmt_data_size(fmt, w, h): i64 {
    var bytes = mabda_texfmt_block_bytes(fmt);
    if (bytes == 0) { return 0; }                       # invalid format
    if (w <= 0) { return 0; }
    if (h <= 0) { return 0; }
    if (w > MABDA_MAX_TEXTURE_DIM_2D) { return 0; }     # overflow guard (dim cap)
    if (h > MABDA_MAX_TEXTURE_DIM_2D) { return 0; }
    var bx = mabda_texfmt_blocks_for_dim(w, mabda_texfmt_block_width(fmt));
    var by = mabda_texfmt_blocks_for_dim(h, mabda_texfmt_block_height(fmt));
    return bx * by * bytes;
}

# ================================================================
# v3.2 T.4 — compression families + capability gating
# ================================================================
# Compressed formats group into three families that a GPU adapter
# advertises (or doesn't) as a unit. These are bit FLAGS — the caps
# bitset (gpu_caps_texture_compression, capabilities.cyr) ORs together
# the families the active adapter supports. wgpu populates it from
# WGPUFeatureName_TextureCompression{BC,ETC2,ASTC} (T.6); native leaves it
# 0 this minor (storage/readback only — sampling is Phase TS).
var MABDA_TEXCOMP_BC   = 1;
var MABDA_TEXCOMP_ETC2 = 2;
var MABDA_TEXCOMP_ASTC = 4;

# The compression family bit for `fmt`, or 0 for uncompressed / invalid.
fn mabda_texfmt_compression_family(fmt): i64 {
    if (fmt == MABDA_TEXFMT_BC1)  { return MABDA_TEXCOMP_BC; }
    if (fmt == MABDA_TEXFMT_BC3)  { return MABDA_TEXCOMP_BC; }
    if (fmt == MABDA_TEXFMT_BC4)  { return MABDA_TEXCOMP_BC; }
    if (fmt == MABDA_TEXFMT_BC5)  { return MABDA_TEXCOMP_BC; }
    if (fmt == MABDA_TEXFMT_BC6H) { return MABDA_TEXCOMP_BC; }
    if (fmt == MABDA_TEXFMT_BC7)  { return MABDA_TEXCOMP_BC; }
    if (fmt == MABDA_TEXFMT_ETC2_RGB8)  { return MABDA_TEXCOMP_ETC2; }
    if (fmt == MABDA_TEXFMT_ETC2_RGBA8) { return MABDA_TEXCOMP_ETC2; }
    if (fmt == MABDA_TEXFMT_ASTC_4X4) { return MABDA_TEXCOMP_ASTC; }
    if (fmt == MABDA_TEXFMT_ASTC_6X6) { return MABDA_TEXCOMP_ASTC; }
    if (fmt == MABDA_TEXFMT_ASTC_8X8) { return MABDA_TEXCOMP_ASTC; }
    return 0;
}

# 1 if `caps` supports creating/binding a texture of `fmt`, else 0.
# Uncompressed RGBA8 is always supported. A compressed format needs its
# family bit set in the caps compression bitset. An invalid id is never
# supported. Consumers call this BEFORE gpu_texture_create_2d to choose a
# format or report GPU_ERR_FORMAT_UNSUPPORTED themselves — the pointer-
# returning create API signals failure only via 0 (it does not return the
# code), and the wgpu create slot also rejects an adapter-unsupported family
# before reaching the FFI.
fn gpu_caps_supports_format(caps, fmt): i64 {
    if (fmt == MABDA_TEXFMT_RGBA8) { return 1; }          # uncompressed: always
    if (mabda_texfmt_is_compressed(fmt) == 0) { return 0; }   # invalid id
    var fam = mabda_texfmt_compression_family(fmt);
    if ((gpu_caps_texture_compression(caps) & fam) != 0) { return 1; }
    return 0;
}

# --- wgpu_descriptors.cyr ---

# @internal — FFI / toolchain scaffolding, replaced in v3.0
# wgpu_descriptors.cyr — C struct builders for wgpu-native v29
# All offsets verified against webgpu.h via offsetof() test program
#
# Pattern: each function allocates a zeroed struct, fills fields,
# returns pointer. Caller passes pointer to wgpu C function.

# ================================================================
# WGPUStringView (16 bytes)
#   +0:  data (char*)
#   +8:  length (size_t)
# ================================================================

# Bounded label-strlen ceiling. WebGPU has no formal limit on debug
# label length; 4 KB is generous for any realistic label and prevents
# `strlen()` from walking off the end of memory if a consumer hands
# us a non-null-terminated pointer. Audit LOW-4.
var WGPU_LABEL_MAX_BYTES = 4096;

# Bounded shader-SOURCE strlen ceiling. Distinct from the 4 KB label cap:
# real WGSL compute/render shaders routinely exceed 4 KB, so bounding the
# source NUL-scan at the label cap silently truncated them mid-token.
# 1 MiB is generous for any realistic shader while still preventing a
# runaway scan on a non-terminated pointer. Audit 2026-06-14 [HIGH-3].
var WGPU_SHADER_SOURCE_MAX_BYTES = 1048576;

# Read at most `max` bytes from `cstr`; return the index of the
# first NUL or `max`, whichever comes first. Used by the bounded
# string-view writer below.
fn _wgpu_strnlen(cstr, max): i64 {
    if (cstr == 0) { return 0; }
    var i = 0;
    while (i < max) {
        if (load8(cstr + i) == 0) { return i; }
        i = i + 1;
    }
    return max;
}

# Write a WGPUStringView at dst from a null-terminated string.
# Length is bounded by WGPU_LABEL_MAX_BYTES so corrupt / non-terminated
# input cannot cause strlen() to walk off mapped memory.
fn wgpu_string_view(dst, cstr): i64 {
    store64(dst, cstr);                                     # data pointer
    store64(dst + 8, _wgpu_strnlen(cstr, WGPU_LABEL_MAX_BYTES));
    return 0;
}

# Write a WGPUStringView with explicit length
fn wgpu_string_view_len(dst, data, len): i64 {
    store64(dst, data);
    store64(dst + 8, len);
    return 0;
}

# Null/empty string view
fn wgpu_string_view_null(dst): i64 {
    store64(dst, 0);
    store64(dst + 8, 0);
    return 0;
}

# ================================================================
# WGPUChainedStruct (16 bytes — base for sType chains)
#   +0:  next (WGPUChainedStruct*)
#   +8:  sType (WGPUSType, u32 at low bits)
# ================================================================

fn wgpu_chained_struct(dst, stype): i64 {
    store64(dst, 0);          # next = NULL
    store32(dst + 8, stype);  # sType
    return 0;
}

# ================================================================
# WGPUInstanceDescriptor (32 bytes)
#   +0:  nextInChain (8)
# ================================================================

fn wgpu_instance_descriptor(): i64 {
    var desc = alloc(32);
    memset(desc, 0, 32);
    return desc;
}

# ================================================================
# WGPURequestAdapterOptions (32 bytes)
#   +0:  nextInChain (8)
#   +12: powerPreference (u32)
#   +16: forceFallbackAdapter (u32/bool)
#   +20: backendType (u32)
#   +24: compatibleSurface (8)
# ================================================================

fn wgpu_request_adapter_options(power_pref): i64 {
    var opts = alloc(32);
    memset(opts, 0, 32);
    store32(opts + 12, power_pref);
    return opts;
}

# ================================================================
# WGPUCallbackInfo — shared layout for all callback infos (40 bytes)
#   +0:  nextInChain (8)
#   +8:  mode (u32)
#   +16: callback (fn ptr, 8)
#   +24: userdata1 (8)
#   +32: userdata2 (8)
# ================================================================

fn wgpu_callback_info(dst, mode, callback, userdata1, userdata2): i64 {
    memset(dst, 0, 40);
    store32(dst + 8, mode);
    store64(dst + 16, callback);
    store64(dst + 24, userdata1);
    store64(dst + 32, userdata2);
    return 0;
}

# ================================================================
# WGPUQueueDescriptor (24 bytes)
#   +0:  nextInChain (8)
#   +8:  label (WGPUStringView = 16)
# ================================================================

fn wgpu_queue_descriptor(dst): i64 {
    memset(dst, 0, 24);
    return 0;
}

# ================================================================
# WGPUDeviceDescriptor (144 bytes)
#   +0:   nextInChain (8)
#   +8:   label (StringView = 16)
#   +24:  requiredFeatureCount (8)
#   +32:  requiredFeatures (ptr, 8)
#   +40:  requiredLimits (ptr, 8)
#   +48:  defaultQueue (QueueDescriptor = 24)
#   +72:  deviceLostCallbackInfo (40)
#   +112: uncapturedErrorCallbackInfo (32)
# ================================================================

fn wgpu_device_descriptor(label): i64 {
    var desc = alloc(144);
    memset(desc, 0, 144);
    if (label != 0) { wgpu_string_view(desc + 8, label); }
    return desc;
}

fn wgpu_device_descriptor_set_lost_callback(desc, callback, userdata): i64 {
    # deviceLostCallbackInfo at +72
    store32(desc + 72 + 8, WGPU_CALLBACK_MODE_ALLOW_SPONTANEOUS);
    store64(desc + 72 + 16, callback);
    store64(desc + 72 + 24, userdata);
    return 0;
}

# ================================================================
# WGPUBufferDescriptor (48 bytes)
#   +0:  nextInChain (8)
#   +8:  label (StringView = 16)
#   +24: usage (u64 flags)
#   +32: size (u64)
#   +40: mappedAtCreation (u32/bool)
# ================================================================

fn wgpu_buffer_descriptor(label, usage, size, mapped): i64 {
    var desc = alloc(48);
    memset(desc, 0, 48);
    if (label != 0) { wgpu_string_view(desc + 8, label); }
    store64(desc + 24, usage);
    store64(desc + 32, size);
    store32(desc + 40, mapped);
    return desc;
}

# ================================================================
# WGPUShaderSourceWGSL (32 bytes)
#   +0:  chain (ChainedStruct = 16)
#   +16: code (StringView = 16)
# ================================================================

# Build from a NUL-terminated WGSL source string (the v2 cstr-shader
# path). Audit 2026-06-14 [HIGH-3]: bound the NUL scan at the
# shader-source cap, NOT WGPU_LABEL_MAX_BYTES — the latter truncated any
# shader >= 4 KiB. Callers that already know the exact byte length should
# use wgpu_shader_source_wgsl_len to skip the scan entirely.
fn wgpu_shader_source_wgsl(wgsl_code): i64 {
    var src = alloc(32);
    memset(src, 0, 32);
    wgpu_chained_struct(src, WGPU_STYPE_SHADER_SOURCE_WGSL);
    var len = _wgpu_strnlen(wgsl_code, WGPU_SHADER_SOURCE_MAX_BYTES);
    wgpu_string_view_len(src + 16, wgsl_code, len);
    return src;
}

# Build with an explicit byte length (the v3 gpu_shader_module_create
# path threads `n` all the way here). No NUL scan, no cap — the caller
# supplied the exact length. Audit 2026-06-14 [HIGH-3]/[MED-4].
fn wgpu_shader_source_wgsl_len(wgsl_code, n): i64 {
    var src = alloc(32);
    memset(src, 0, 32);
    wgpu_chained_struct(src, WGPU_STYPE_SHADER_SOURCE_WGSL);
    wgpu_string_view_len(src + 16, wgsl_code, n);
    return src;
}

# ================================================================
# WGPUShaderSourceSPIRV (32 bytes, wgpu-native v29) — Phase S.1
# ================================================================
# Layout verified vs deps/wgpu-native/include/webgpu/webgpu.h:
#   +0:  chain (ChainedStruct = 16; next@0 NULL, sType@8 = SPIRV)
#   +16: codeSize (u32)  -- COUNT OF u32 WORDS, NOT bytes (the #1 SPIRV
#                           integration bug; pinned by a test)
#   +20: (4 padding — `code` is 8-byte aligned)
#   +24: code (const uint32_t*, 8)
# Contrast WGSL's payload: a 16-byte StringView (data+len) at +16. Here it's
# a u32 word-count at +16 and a u32* at +24.
var MABDA_SPIRV_MAGIC         = 0x07230203;   # SPIR-V header word[0] (host LE)
var MABDA_SPIRV_MAGIC_SWAPPED = 0x03022307;   # big-endian (byte-swapped) binary
var MABDA_MAX_SPIRV_WORDS     = 16777216;     # 16 Mi words = 64 MiB runaway cap

fn wgpu_shader_source_spirv(words_ptr, word_count): i64 {
    var src = alloc(32);
    memset(src, 0, 32);
    wgpu_chained_struct(src, WGPU_STYPE_SHADER_SOURCE_SPIRV);
    store32(src + 16, word_count);   # codeSize in WORDS
    store64(src + 24, words_ptr);    # code ptr
    return src;
}

# Cheap structural validation of a SPIR-V binary BEFORE it crosses into
# wgpu-native's parser (P(-1) input-validation / buffer-safety). Returns 0 on
# ok, else a distinct nonzero code (callers treat any nonzero as reject):
#   1 too short (< 5-word/20-byte header)   2 byte length not u32-aligned
#   3 bad magic (not SPIR-V)                4 byte-swapped (big-endian binary)
#   5 id-bound (word[3]) malformed (0 or wildly large)
#   6 word count exceeds the runaway cap
# Full validation is SPIRV-Tools' job (not vendored); this catches the common
# feeds-garbage feeds before the driver. @internal
fn _spirv_validate(ptr, byte_len): i64 {
    if (byte_len < 20)        { return 1; }   # header = 5 words
    if ((byte_len & 3) != 0)  { return 2; }   # u32 word stream
    var magic = load32(ptr);                  # word[0], host-LE read
    if (magic == MABDA_SPIRV_MAGIC_SWAPPED) { return 4; }   # big-endian binary
    if (magic != MABDA_SPIRV_MAGIC)         { return 3; }   # not SPIR-V
    var bound = load32(ptr + 12);             # word[3] = id bound
    if (bound == 0)           { return 5; }
    if (bound >= 0x40000000)  { return 5; }   # loose upper guard
    if ((byte_len / 4) > MABDA_MAX_SPIRV_WORDS) { return 6; }
    return 0;
}

# ================================================================
# WGPUShaderModuleDescriptor (24 bytes)
#   +0:  nextInChain (8)
#   +8:  label (StringView = 16)
# ================================================================

fn wgpu_shader_module_descriptor(label, wgsl_source_ptr): i64 {
    var desc = alloc(24);
    memset(desc, 0, 24);
    store64(desc, wgsl_source_ptr);    # nextInChain → WGPUShaderSourceWGSL
    if (label != 0) { wgpu_string_view(desc + 8, label); }
    return desc;
}

# ================================================================
# WGPUComputeState (48 bytes)
#   +0:  nextInChain (8)
#   +8:  module (8)
#   +16: entryPoint (StringView = 16)
#   +32: constantCount (8)
#   +40: constants (ptr, 8)
# ================================================================

fn wgpu_compute_state(dst, shader_module, entry_point): i64 {
    memset(dst, 0, 48);
    store64(dst + 8, shader_module);
    wgpu_string_view(dst + 16, entry_point);
    return 0;
}

# ================================================================
# WGPUComputePipelineDescriptor (80 bytes)
#   +0:  nextInChain (8)
#   +8:  label (StringView = 16)
#   +24: layout (PipelineLayout, 8)
#   +32: compute (ComputeState = 48)
# ================================================================

fn wgpu_compute_pipeline_descriptor(label, layout, shader_module, entry_point): i64 {
    var desc = alloc(80);
    memset(desc, 0, 80);
    if (label != 0) { wgpu_string_view(desc + 8, label); }
    store64(desc + 24, layout);
    wgpu_compute_state(desc + 32, shader_module, entry_point);
    return desc;
}

# ================================================================
# WGPUBindGroupLayoutEntry (120 bytes — wgpu v29)
#   +0:  nextInChain (8)
#   +8:  binding (u32)
#   +16: visibility (u64 flags — WGPUShaderStage = WGPUFlags = u64)
#   +24: bindingArraySize (u32 — new in v29; 0 = single binding)
#   +32: buffer (WGPUBufferBindingLayout, 24 bytes):
#        +32 nextInChain (8), +40 type (u32), +44 hasDynamicOffset (u32),
#        +48 minBindingSize (u64)
#   +56: sampler (WGPUSamplerBindingLayout, 16 bytes)
#   +72: texture (WGPUTextureBindingLayout, 24 bytes)
#   +96: storageTexture (WGPUStorageTextureBindingLayout, 24 bytes)
# ================================================================

fn wgpu_bgl_entry_buffer(dst, binding, visibility, buffer_type, has_dynamic_offset, min_size): i64 {
    memset(dst, 0, 120);
    store32(dst + 8, binding);
    store64(dst + 16, visibility);
    store32(dst + 40, buffer_type);
    store32(dst + 44, has_dynamic_offset);
    store64(dst + 48, min_size);
    return 0;
}

# v3.1 [M.3(wgpu)]: WGPU enum values cited from
# deps/wgpu-native/include/webgpu/webgpu.h (v29).
var WGPU_TEXTURE_SAMPLE_TYPE_FLOAT          = 0x02;  # WGPUTextureSampleType_Float
var WGPU_STORAGE_TEXTURE_ACCESS_WRITE_ONLY  = 0x02;  # WGPUStorageTextureAccess_WriteOnly

# Sampled-texture BGL entry. Sub-struct WGPUTextureBindingLayout at +72:
# sampleType +80, viewDimension +84, multisampled +88. The mipmap read
# binding uses sampleType=Float, dimension=2D, multisampled=0.
fn wgpu_bgl_entry_texture(dst, binding, visibility, sample_type, view_dim, multisampled): i64 {
    memset(dst, 0, 120);
    store32(dst + 8, binding);
    store64(dst + 16, visibility);
    store32(dst + 80, sample_type);
    store32(dst + 84, view_dim);
    store32(dst + 88, multisampled);
    return 0;
}

# Storage-texture BGL entry. Sub-struct WGPUStorageTextureBindingLayout at
# +96: access +104, format +108, viewDimension +112. The mipmap write
# binding uses access=WriteOnly, format=RGBA8_UNORM, dimension=2D.
fn wgpu_bgl_entry_storage_texture(dst, binding, visibility, access, format, view_dim): i64 {
    memset(dst, 0, 120);
    store32(dst + 8, binding);
    store64(dst + 16, visibility);
    store32(dst + 104, access);
    store32(dst + 108, format);
    store32(dst + 112, view_dim);
    return 0;
}

# ================================================================
# WGPUBindGroupLayoutDescriptor (40 bytes)
#   +0:  nextInChain (8)
#   +8:  label (StringView = 16)
#   +24: entryCount (8)
#   +32: entries (ptr, 8)
# ================================================================

fn wgpu_bind_group_layout_descriptor(label, entries_ptr, entry_count): i64 {
    var desc = alloc(40);
    memset(desc, 0, 40);
    if (label != 0) { wgpu_string_view(desc + 8, label); }
    store64(desc + 24, entry_count);
    store64(desc + 32, entries_ptr);
    return desc;
}

# ================================================================
# WGPUPipelineLayoutDescriptor (48 bytes)
#   +0:  nextInChain (8)
#   +8:  label (StringView = 16)
#   +24: bindGroupLayoutCount (8)
#   +32: bindGroupLayouts (ptr, 8)
# ================================================================

fn wgpu_pipeline_layout_descriptor(label, layouts_ptr, layout_count): i64 {
    var desc = alloc(48);
    memset(desc, 0, 48);
    if (label != 0) { wgpu_string_view(desc + 8, label); }
    store64(desc + 24, layout_count);
    store64(desc + 32, layouts_ptr);
    return desc;
}

# ================================================================
# WGPUBindGroupEntry (56 bytes)
#   +0:  nextInChain (8)
#   +8:  binding (u32)
#   +16: buffer (8)
#   +24: offset (u64)
#   +32: size (u64)
#   +40: sampler (8)
#   +48: textureView (8)
# ================================================================

fn wgpu_bind_group_entry_buffer(dst, binding, buffer, offset, size): i64 {
    memset(dst, 0, 56);
    store32(dst + 8, binding);
    store64(dst + 16, buffer);
    store64(dst + 24, offset);
    store64(dst + 32, size);
    return 0;
}

# ================================================================
# WGPUBindGroupDescriptor (48 bytes)
#   +0:  nextInChain (8)
#   +8:  label (StringView = 16)
#   +24: layout (8)
#   +32: entryCount (8)
#   +40: entries (ptr, 8)
# ================================================================

fn wgpu_bind_group_descriptor(label, layout, entries_ptr, entry_count): i64 {
    var desc = alloc(48);
    memset(desc, 0, 48);
    if (label != 0) { wgpu_string_view(desc + 8, label); }
    store64(desc + 24, layout);
    store64(desc + 32, entry_count);
    store64(desc + 40, entries_ptr);
    return desc;
}

# ================================================================
# WGPUCommandEncoderDescriptor (24 bytes)
#   +0:  nextInChain (8)
#   +8:  label (StringView = 16)
# ================================================================

fn wgpu_command_encoder_descriptor(label): i64 {
    var desc = alloc(24);
    memset(desc, 0, 24);
    if (label != 0) { wgpu_string_view(desc + 8, label); }
    return desc;
}

# ================================================================
# WGPUTextureDescriptor (80 bytes, verified via offsetof)
#   +0:  nextInChain (8)
#   +8:  label (StringView = 16)
#   +24: usage (u64)
#   +32: dimension (u32, WGPUTextureDimension)
#   +36: size.width  (u32)
#   +40: size.height (u32)
#   +44: size.depthOrArrayLayers (u32)
#   +48: format (u32, WGPUTextureFormat)
#   +52: mipLevelCount (u32)
#   +56: sampleCount (u32)
#   +60: padding (4)
#   +64: viewFormatCount (usize)
#   +72: viewFormats (const WGPUTextureFormat*, 8)
# ================================================================

# WGPUTextureDimension constants
var WGPU_TEXTURE_DIMENSION_1D = 1;
var WGPU_TEXTURE_DIMENSION_2D = 2;
var WGPU_TEXTURE_DIMENSION_3D = 3;

# WGPUTextureUsage bits (v29)
var WGPU_TEXTURE_USAGE_COPY_SRC          = 0x01;
var WGPU_TEXTURE_USAGE_COPY_DST          = 0x02;
var WGPU_TEXTURE_USAGE_TEXTURE_BINDING   = 0x04;
var WGPU_TEXTURE_USAGE_STORAGE_BINDING   = 0x08;
var WGPU_TEXTURE_USAGE_RENDER_ATTACHMENT = 0x10;

fn wgpu_texture_descriptor(label, usage, dimension, width, height, format): i64 {
    var desc = alloc(80);
    memset(desc, 0, 80);
    if (label != 0) { wgpu_string_view(desc + 8, label); }
    store64(desc + 24, usage);
    store32(desc + 32, dimension);
    store32(desc + 36, width);
    store32(desc + 40, height);
    store32(desc + 44, 1);           # depthOrArrayLayers = 1
    store32(desc + 48, format);
    store32(desc + 52, 1);           # mipLevelCount = 1
    store32(desc + 56, 1);           # sampleCount = 1
    # viewFormatCount = 0, viewFormats = NULL — already zeroed
    return desc;
}

# v3.1 [M.6]: texture descriptor with an explicit mip-level count (the
# mipmap-generation create path). Identical to the base builder otherwise.
fn wgpu_texture_descriptor_mipped(label, usage, dimension, width, height, format, mip_count): i64 {
    var desc = wgpu_texture_descriptor(label, usage, dimension, width, height, format);
    store32(desc + 52, mip_count);   # mipLevelCount
    return desc;
}

# ================================================================
# WGPUTextureViewDescriptor (64 bytes, verified via offsetof)
#   +0:  nextInChain
#   +8:  label (StringView)
#   +24: format (u32)
#   +28: dimension (u32 WGPUTextureViewDimension)
#   +32: baseMipLevel (u32)
#   +36: mipLevelCount (u32)
#   +40: baseArrayLayer (u32)
#   +44: arrayLayerCount (u32)
#   +48: aspect (u32, WGPUTextureAspect — 0 = All)
#   +52: padding
#   +56: usage (u64) — zero means "inherit from parent texture"
# ================================================================

# WGPUTextureViewDimension
var WGPU_TEXTURE_VIEW_DIMENSION_2D = 2;

# WGPUTextureAspect::All = 0 (default)
var WGPU_TEXTURE_ASPECT_ALL = 0;

fn wgpu_texture_view_descriptor(label, format, dimension): i64 {
    var desc = alloc(64);
    memset(desc, 0, 64);
    if (label != 0) { wgpu_string_view(desc + 8, label); }
    store32(desc + 24, format);
    store32(desc + 28, dimension);
    store32(desc + 32, 0);              # baseMipLevel
    store32(desc + 36, 1);              # mipLevelCount
    store32(desc + 40, 0);              # baseArrayLayer
    store32(desc + 44, 1);              # arrayLayerCount
    store32(desc + 48, WGPU_TEXTURE_ASPECT_ALL);
    store64(desc + 56, 0);              # usage = inherit
    return desc;
}

# v3.1 [M.3(wgpu)]: single-level view at `base_mip` (mipLevelCount = 1).
# Mipmap generation creates one such view per level — the read view at
# level i-1 and the storage write view at level i.
fn wgpu_texture_view_descriptor_level(label, format, dimension, base_mip): i64 {
    var desc = wgpu_texture_view_descriptor(label, format, dimension);
    store32(desc + 32, base_mip);      # baseMipLevel
    return desc;
}

# ================================================================
# WGPUTexelCopyTextureInfo (32 bytes)
#   +0:  texture (WGPUTexture, 8)
#   +8:  mipLevel (u32)
#   +12: origin.x (u32)
#   +16: origin.y (u32)
#   +20: origin.z (u32)
#   +24: aspect (u32)
# ================================================================
fn wgpu_texel_copy_texture_info(texture, mip_level): i64 {
    var info = alloc(32);
    memset(info, 0, 32);
    store64(info + 0,  texture);
    store32(info + 8,  mip_level);
    # origin x/y/z = 0, aspect = All (0) — already zeroed
    return info;
}

# ================================================================
# WGPUTexelCopyBufferLayout (16 bytes)
#   +0:  offset (u64)
#   +8:  bytesPerRow (u32)
#   +12: rowsPerImage (u32)
# ================================================================
fn wgpu_texel_copy_buffer_layout(offset, bytes_per_row, rows_per_image): i64 {
    var layout = alloc(16);
    store64(layout + 0,  offset);
    store32(layout + 8,  bytes_per_row);
    store32(layout + 12, rows_per_image);
    return layout;
}

# ================================================================
# WGPUExtent3D (12 bytes)
#   +0: width  (u32)
#   +4: height (u32)
#   +8: depthOrArrayLayers (u32)
# ================================================================
fn wgpu_extent_3d(width, height, depth): i64 {
    var e = alloc(12);
    store32(e + 0, width);
    store32(e + 4, height);
    store32(e + 8, depth);
    return e;
}

# ================================================================
# WGPUSurfaceConfiguration (64 bytes, verified via offsetof)
#   +0:  nextInChain (8)
#   +8:  device (8)
#   +16: format (u32)
#   +20: padding
#   +24: usage (u64)
#   +32: width (u32)
#   +36: height (u32)
#   +40: viewFormatCount (usize)
#   +48: viewFormats (ptr)
#   +56: alphaMode (u32)
#   +60: presentMode (u32)
# ================================================================
fn wgpu_surface_configuration(device, format, width, height, usage, present_mode): i64 {
    var cfg = alloc(64);
    memset(cfg, 0, 64);
    store64(cfg + 8,  device);
    store32(cfg + 16, format);
    store64(cfg + 24, usage);
    store32(cfg + 32, width);
    store32(cfg + 36, height);
    # viewFormatCount = 0, viewFormats = NULL — already zeroed
    store32(cfg + 56, 0);             # alphaMode = Auto
    store32(cfg + 60, present_mode);
    return cfg;
}

# ================================================================
# WGPUQuerySetDescriptor (32 bytes, verified via offsetof() test)
#   +0:  nextInChain (8)
#   +8:  label (StringView = 16)
#   +24: type (u32 WGPUQueryType)
#   +28: count (u32)
# ================================================================

fn wgpu_query_set_descriptor(label, query_type, count): i64 {
    var desc = alloc(32);
    memset(desc, 0, 32);
    if (label != 0) { wgpu_string_view(desc + 8, label); }
    store32(desc + 24, query_type);
    store32(desc + 28, count);
    return desc;
}

# ================================================================
# WGPUComputePassDescriptor (32 bytes)
#   +0:  nextInChain (8)
#   +8:  label (StringView = 16)
#   +24: timestampWrites (ptr, 8)
# ================================================================

fn wgpu_compute_pass_descriptor(label): i64 {
    var desc = alloc(32);
    memset(desc, 0, 32);
    if (label != 0) { wgpu_string_view(desc + 8, label); }
    return desc;
}

# ================================================================
# WGPUCommandBufferDescriptor (24 bytes)
#   +0:  nextInChain (8)
#   +8:  label (StringView = 16)
# ================================================================

fn wgpu_command_buffer_descriptor(label): i64 {
    var desc = alloc(24);
    memset(desc, 0, 24);
    if (label != 0) { wgpu_string_view(desc + 8, label); }
    return desc;
}

# ================================================================
# WGPUBufferMapCallbackInfo (40 bytes)
#   +0:  nextInChain (8)
#   +8:  mode (u32)
#   +16: callback (fn ptr, 8)
#   +24: userdata1 (8)
#   +32: userdata2 (8)
# ================================================================

fn wgpu_buffer_map_callback_info(callback, userdata): i64 {
    var info = alloc(40);
    memset(info, 0, 40);
    store32(info + 8, WGPU_CALLBACK_MODE_WAIT_ANY_ONLY);
    store64(info + 16, callback);
    store64(info + 24, userdata);
    return info;
}

# ================================================================
# WGPURequestAdapterCallbackInfo (40 bytes)
# ================================================================

fn wgpu_request_adapter_callback_info(callback, userdata): i64 {
    var info = alloc(40);
    memset(info, 0, 40);
    store32(info + 8, WGPU_CALLBACK_MODE_ALLOW_SPONTANEOUS);
    store64(info + 16, callback);
    store64(info + 24, userdata);
    return info;
}

# ================================================================
# WGPURequestDeviceCallbackInfo (40 bytes)
# ================================================================

fn wgpu_request_device_callback_info(callback, userdata): i64 {
    var info = alloc(40);
    memset(info, 0, 40);
    store32(info + 8, WGPU_CALLBACK_MODE_WAIT_ANY_ONLY);
    store64(info + 16, callback);
    store64(info + 24, userdata);
    return info;
}

# --- wgpu_ffi.cyr ---

# @internal — FFI / toolchain scaffolding, replaced in v3.0
# wgpu_ffi.cyr — FFI bindings to wgpu-native v29
#
# Function pointers are received from C launcher via wgpu_ffi_init_table(ptr).
# The C main() builds a function table and passes it to the Cyrius entry point.
# All wgpu handles are opaque i64 pointers.
#
# Function table layout (matches deps/wgpu_main.c):
#   [0]  wgpuCreateInstance
#   [1]  wgpu_shim_instance_request_adapter (by-pointer callbackInfo)
#   [2]  wgpu_shim_adapter_request_device (by-pointer callbackInfo)
#   [3]  wgpuDeviceGetQueue
#   [4]  wgpuInstanceProcessEvents
#   [5]  wgpuInstanceRelease
#   [6]  wgpuAdapterRelease
#   [7]  wgpuDeviceRelease
#   [8]  wgpuDeviceCreateBuffer
#   [9]  wgpuQueueWriteBuffer
#   [10] wgpu_shim_buffer_map_async (by-pointer callbackInfo)
#   [11] wgpuBufferGetConstMappedRange
#   [12] wgpuBufferUnmap
#   [13] wgpuBufferGetSize
#   [14] wgpuBufferDestroy
#   [15] wgpuBufferRelease
#   [16] wgpuDeviceCreateShaderModule
#   [17] wgpuDeviceCreateComputePipeline
#   [18] wgpuDeviceCreateBindGroupLayout
#   [19] wgpuDeviceCreatePipelineLayout
#   [20] wgpuDeviceCreateBindGroup
#   [21] wgpuShaderModuleRelease
#   [22] wgpuComputePipelineRelease
#   [23] wgpuBindGroupRelease
#   [24] wgpuBindGroupLayoutRelease
#   [25] wgpuPipelineLayoutRelease
#   [26] wgpuDeviceCreateCommandEncoder
#   [27] wgpuCommandEncoderBeginComputePass
#   [28] wgpuCommandEncoderCopyBufferToBuffer
#   [29] wgpuCommandEncoderFinish
#   [30] wgpuComputePassEncoderSetPipeline
#   [31] wgpuComputePassEncoderSetBindGroup
#   [32] wgpuComputePassEncoderDispatchWorkgroups
#   [33] wgpuComputePassEncoderEnd
#   [34] wgpuCommandEncoderRelease
#   [35] wgpuQueueSubmit
#   [36] wgpuAdapterGetInfo
#   [37] wgpuAdapterGetLimits
#   [38] wgpuAdapterHasFeature
#   [39] wgpu_shim_device_poll
#   [40] wgpuDeviceCreateQuerySet
#   [41] wgpuQuerySetRelease
#   [42] wgpu_shim_resolve_query_set (struct-packed args)
#   [43] wgpu_shim_get_timestamp_period_bits (returns f32 as i64 bit-pattern)
#   [44] wgpuDeviceHasFeature
#   [45] wgpuDeviceCreateTexture
#   [46] wgpuTextureCreateView
#   [47] wgpuDeviceCreateSampler
#   [48] wgpu_shim_queue_write_texture (struct-packed args)
#   [49] wgpuTextureRelease
#   [50] wgpuTextureViewRelease
#   [51] wgpuSamplerRelease
#   [52] wgpuDeviceCreateRenderPipeline
#   [53] wgpuRenderPipelineRelease
#   [54] wgpuSurfaceConfigure
#   [55] wgpuSurfaceGetCurrentTexture
#   [56] wgpuSurfacePresent
#   [57] wgpuSurfaceRelease
#   [58] wgpu_shim_command_encoder_begin_render_pass (struct-packed args)
#   [59] wgpuRenderPassEncoderSetPipeline
#   [60] wgpuRenderPassEncoderSetBindGroup
#   [61] wgpuRenderPassEncoderDraw
#   [62] wgpuRenderPassEncoderEnd
#   [63] wgpuRenderPassEncoderRelease
#   [64] wgpu_shim_command_encoder_copy_texture_to_buffer (struct-packed args)
#   [65] wgpuRenderPipelineGetBindGroupLayout
#   [66] wgpu_shim_create_shader_module_spirv (raw-SPIR-V passthrough escape hatch — F.8a)

var _fn_table = 0;

fn _fp(idx): i64 { return load64(_fn_table + idx * 8); }

fn wgpu_ffi_init_table(table_ptr): i64 {
    _fn_table = table_ptr;
    return 0;
}

# ================================================================
# Instance
# ================================================================

fn wgpu_create_instance(desc): i64 { return fncall1(_fp(0), desc); }
fn wgpu_instance_process_events(inst): i64 { fncall1(_fp(4), inst); return 0; }
fn wgpu_instance_release(inst): i64 { fncall1(_fp(5), inst); return 0; }

# ================================================================
# Adapter request (sync)
# ================================================================

# Request adapter: simplified shim handles all callback setup in C
# Args: (instance, power_preference, result_ptr)
fn wgpu_request_adapter_sync(instance, power_pref): i64 {
    var result_ptr = alloc(8);
    store64(result_ptr, 0);
    fncall3(_fp(1), instance, power_pref, result_ptr);
    return load64(result_ptr);
}

# ================================================================
# Device request (sync)
# ================================================================

# Request device: simplified shim handles callback in C
# Args: (adapter, result_ptr)
fn wgpu_request_device_sync(adapter): i64 {
    var result_ptr = alloc(8);
    store64(result_ptr, 0);
    fncall2(_fp(2), adapter, result_ptr);
    return load64(result_ptr);
}

# ================================================================
# Queue
# ================================================================
fn wgpu_device_get_queue(device): i64 { return fncall1(_fp(3), device); }
# NOTE: slot 35 is a C shim that submits a single command buffer.
# Args: (queue, cmd_buffer_handle). The count/array is handled in C.
fn wgpu_queue_submit_one(queue, cmd_buf): i64 { fncall2(_fp(35), queue, cmd_buf); return 0; }
fn wgpu_queue_write_buffer(queue, buf, offset, data, size): i64 {
    fncall5(_fp(9), queue, buf, offset, data, size);
    return 0;
}

# ================================================================
# Buffer
# ================================================================
fn wgpu_device_create_buffer(device, desc): i64 { return fncall2(_fp(8), device, desc); }
fn wgpu_buffer_get_size(buf): i64 { return fncall1(_fp(13), buf); }
fn wgpu_buffer_destroy(buf): i64 { fncall1(_fp(14), buf); return 0; }
fn wgpu_buffer_unmap(buf): i64 { fncall1(_fp(12), buf); return 0; }
fn wgpu_buffer_release(buf): i64 { fncall1(_fp(15), buf); return 0; }
fn wgpu_buffer_get_const_mapped_range(buf, offset, size): i64 {
    return fncall3(_fp(11), buf, offset, size);
}

# Buffer map sync: simplified shim handles callback + poll in C. The args
# are packed into a struct so Cyrius calls via fncall2 instead of fncall6.
# WgpuMapArgs layout (32 bytes):
#   +0:  buffer (8)
#   +8:  mode (4) + padding (4)
#   +16: offset (8)
#   +24: size (8)
#   +32: status_ptr (8) — total 40 bytes
fn wgpu_buffer_map_sync(device, buffer, mode, offset, size): i64 {
    var status_ptr = alloc(8);
    store64(status_ptr, 0);
    var args = alloc(40);
    store64(args + 0,  buffer);
    store32(args + 8,  mode);
    store64(args + 16, offset);
    store64(args + 24, size);
    store64(args + 32, status_ptr);
    fncall2(_fp(10), device, args);
    return load64(status_ptr);
}

# ================================================================
# Shader / Pipeline
# ================================================================
fn wgpu_device_create_shader_module(device, desc): i64 { return fncall2(_fp(16), device, desc); }
# v3.2 F.8a — create a shader module from raw SPIR-V words via the passthrough escape hatch
# (wgpuDeviceCreateShaderModuleSpirV behind the launcher shim): raw words bypass naga, for
# SPIR-V naga cannot carry. This is NOT the f64 path (f64 uses ShaderF64 + the standard
# gpu_shader_module_create_spirv path — see gpu_caps_wgpu_shader_f64). Requires the
# SpirvShaderPassthrough device feature (gated in wgpu_shim_request_device; unsupported on
# RADV/Cezanne); word_count is byte_len / 4. Returns 0 if absent or rejected (fail-loud).
fn wgpu_device_create_shader_module_spirv_passthrough(device, words_ptr, word_count): i64 {
    return fncall3(_fp(66), device, words_ptr, word_count);
}
fn wgpu_device_create_compute_pipeline(device, desc): i64 { return fncall2(_fp(17), device, desc); }
fn wgpu_device_create_bind_group_layout(device, desc): i64 { return fncall2(_fp(18), device, desc); }
fn wgpu_device_create_pipeline_layout(device, desc): i64 { return fncall2(_fp(19), device, desc); }
fn wgpu_device_create_bind_group(device, desc): i64 { return fncall2(_fp(20), device, desc); }
# v3.2 TS.5 — fetch a render pipeline's auto-generated bind-group layout for
# group `idx` (the textured wgpu draw builds its bind group against it).
fn wgpu_render_pipeline_get_bind_group_layout(pipe, idx): i64 { return fncall2(_fp(65), pipe, idx); }
fn wgpu_shader_module_release(m): i64 { fncall1(_fp(21), m); return 0; }
fn wgpu_compute_pipeline_release(p): i64 { fncall1(_fp(22), p); return 0; }
fn wgpu_bind_group_release(bg): i64 { fncall1(_fp(23), bg); return 0; }
fn wgpu_bind_group_layout_release(bgl): i64 { fncall1(_fp(24), bgl); return 0; }
fn wgpu_pipeline_layout_release(pl): i64 { fncall1(_fp(25), pl); return 0; }

# ================================================================
# Command Encoding
# ================================================================
# NOTE: slot 26 is a C shim that takes (device, label_cstr). The `desc` arg
# is interpreted as a null-terminated label pointer. Pass 0 for no label.
fn wgpu_device_create_command_encoder(device, label): i64 { return fncall2(_fp(26), device, label); }
fn wgpu_command_encoder_begin_compute_pass(enc, desc): i64 { return fncall2(_fp(27), enc, desc); }
fn wgpu_command_encoder_copy_buffer_to_buffer(enc, src, soff, dst, doff, sz): i64 {
    # Pack args into WgpuCopyArgs struct (40 bytes: src, soff, dst, doff, size)
    var args = alloc(40);
    store64(args + 0,  src);
    store64(args + 8,  soff);
    store64(args + 16, dst);
    store64(args + 24, doff);
    store64(args + 32, sz);
    fncall2(_fp(28), enc, args);
    return 0;
}
# NOTE: slot 29 is a C shim that takes (encoder, label_cstr). Pass 0 for no label.
fn wgpu_command_encoder_finish(enc, label): i64 { return fncall2(_fp(29), enc, label); }
fn wgpu_command_encoder_release(enc): i64 { fncall1(_fp(34), enc); return 0; }
fn wgpu_compute_pass_set_pipeline(pass, pip): i64 { fncall2(_fp(30), pass, pip); return 0; }
fn wgpu_compute_pass_set_bind_group(pass, gi, bg, dc, do_ptr): i64 {
    fncall5(_fp(31), pass, gi, bg, dc, do_ptr);
    return 0;
}
fn wgpu_compute_pass_dispatch(pass, x, y, z): i64 { fncall4(_fp(32), pass, x, y, z); return 0; }
fn wgpu_compute_pass_end(pass): i64 { fncall1(_fp(33), pass); return 0; }

# ================================================================
# Adapter / Device
# ================================================================
fn wgpu_adapter_get_info(adapter, info): i64 { fncall2(_fp(36), adapter, info); return 0; }
fn wgpu_adapter_get_limits(adapter, lim): i64 { return fncall2(_fp(37), adapter, lim); }
fn wgpu_adapter_release(a): i64 { fncall1(_fp(6), a); return 0; }
fn wgpu_device_release(d): i64 { fncall1(_fp(7), d); return 0; }
fn wgpu_device_poll(device, wait): i64 { return fncall2(_fp(39), device, wait); }

# wgpuAdapterHasFeature(adapter, feature_name_u32) → WGPUBool (u32)
fn wgpu_adapter_has_feature(adapter, feature): i64 { return fncall2(_fp(38), adapter, feature); }
# wgpuDeviceHasFeature(device,  feature_name_u32) → WGPUBool (u32)
# Unlike AdapterHasFeature, this reflects the features actually ENABLED on the
# device at creation — which is what the timestamps code must check.
fn wgpu_device_has_feature(device, feature): i64 { return fncall2(_fp(44), device, feature); }

# ================================================================
# Query sets — GPU timestamp profiling
# ================================================================
fn wgpu_device_create_query_set(device, desc): i64 { return fncall2(_fp(40), device, desc); }
fn wgpu_query_set_release(qs): i64 { fncall1(_fp(41), qs); return 0; }

# ResolveQuerySet takes 6 args. Keep encoder on the left and pack the rest
# into a struct pointer — see feedback_fncall6_wgpu and the existing
# copy_buffer_to_buffer wrapper for the rationale.
#
# WgpuResolveArgs layout (40 bytes):
#   +0:  querySet     (8)
#   +8:  firstQuery   (u32)
#   +12: queryCount   (u32)
#   +16: destBuffer   (8)
#   +24: destOffset   (8)
fn wgpu_encoder_resolve_query_set(encoder, qs, first, count, dest_buf, dest_off): i64 {
    var args = alloc(40);
    store64(args + 0,  qs);
    store32(args + 8,  first);
    store32(args + 12, count);
    store64(args + 16, dest_buf);
    store64(args + 24, dest_off);
    fncall2(_fp(42), encoder, args);
    return 0;
}

# Queue timestamp period is an f32. The C shim returns the f32 bit-pattern
# as an i64 so Cyrius can consume it via a normal integer return path.
# Convert to f64 on the Cyrius side when needed.
fn wgpu_queue_get_timestamp_period_bits(queue): i64 { return fncall1(_fp(43), queue); }

# ================================================================
# Textures
# ================================================================
fn wgpu_device_create_texture(device, desc): i64 { return fncall2(_fp(45), device, desc); }
fn wgpu_texture_create_view(texture, desc): i64 { return fncall2(_fp(46), texture, desc); }
fn wgpu_device_create_sampler(device, desc): i64 { return fncall2(_fp(47), device, desc); }
fn wgpu_texture_release(texture): i64 { fncall1(_fp(49), texture); return 0; }
fn wgpu_texture_view_release(view): i64 { fncall1(_fp(50), view); return 0; }
fn wgpu_sampler_release(sampler): i64 { fncall1(_fp(51), sampler); return 0; }

# QueueWriteTexture takes 6 args; Cyrius uses struct-packing via fncall2.
# WgpuWriteTextureArgs layout (40 bytes):
#   +0:  destination (WGPUTexelCopyTextureInfo ptr)
#   +8:  data (void*)
#   +16: data_size (size_t)
#   +24: data_layout (WGPUTexelCopyBufferLayout ptr)
#   +32: write_size (WGPUExtent3D ptr)
fn wgpu_queue_write_texture(queue, destination, data, data_size, data_layout, write_size): i64 {
    var args = alloc(40);
    store64(args + 0,  destination);
    store64(args + 8,  data);
    store64(args + 16, data_size);
    store64(args + 24, data_layout);
    store64(args + 32, write_size);
    fncall2(_fp(48), queue, args);
    return 0;
}

# ================================================================
# Render pipelines
# ================================================================
fn wgpu_device_create_render_pipeline(device, desc): i64 { return fncall2(_fp(52), device, desc); }
fn wgpu_render_pipeline_release(rp): i64 { fncall1(_fp(53), rp); return 0; }

# ================================================================
# Surfaces — consumers supply the WGPUSurface handle from their
# windowing library (winit, glfw, sdl, etc). mabda only wraps the
# configure + acquire + present lifecycle once the handle exists.
# ================================================================
fn wgpu_surface_configure(surface, config): i64 {
    fncall2(_fp(54), surface, config);
    return 0;
}
fn wgpu_surface_get_current_texture(surface, out_texture): i64 {
    fncall2(_fp(55), surface, out_texture);
    return 0;
}
fn wgpu_surface_present(surface): i64 { return fncall1(_fp(56), surface); }
fn wgpu_surface_release(surface): i64 { fncall1(_fp(57), surface); return 0; }

# ================================================================
# Render pass execution (v2.4.3)
# ================================================================
# Slot 58 takes a WgpuBeginPassArgs struct pointer; slot 64 takes a
# WgpuCopyTexToBufArgs struct pointer. Both layouts are documented in
# `deps/wgpu_main.c` — Cyrius callers in `src/render_pass.cyr` /
# `src/texture.cyr` own the packing. The direct-call wrappers (59-63)
# stay under the 6-arg ceiling.

fn wgpu_command_encoder_begin_render_pass(enc, args): i64 {
    return fncall2(_fp(58), enc, args);
}
fn wgpu_render_pass_encoder_set_pipeline(pass, pip): i64 {
    fncall2(_fp(59), pass, pip);
    return 0;
}
fn wgpu_render_pass_encoder_set_bind_group(pass, group_idx, bg, dyn_count, dyn_offsets): i64 {
    fncall5(_fp(60), pass, group_idx, bg, dyn_count, dyn_offsets);
    return 0;
}
fn wgpu_render_pass_encoder_draw(pass, vert_count, inst_count, first_vert, first_inst): i64 {
    fncall5(_fp(61), pass, vert_count, inst_count, first_vert, first_inst);
    return 0;
}
fn wgpu_render_pass_encoder_end(pass): i64 { fncall1(_fp(62), pass); return 0; }
fn wgpu_render_pass_encoder_release(pass): i64 { fncall1(_fp(63), pass); return 0; }

fn wgpu_command_encoder_copy_texture_to_buffer(enc, args): i64 {
    return fncall2(_fp(64), enc, args);
}

# --- backend.cyr ---

# @internal — Backend dispatch interface (v3 Phase B5, ADR 006)
# backend.cyr — function-pointer table both backends fill, dispatched
# through ctx->backend at v3.0+.
#
# This is the @internal indirection point that lets v3.0 ship two
# backends behind the same @public surface. Public callers never
# touch this struct; they call the existing fns in buffer.cyr,
# compute.cyr, etc., which (post-refactor) dispatch through
# ctx->backend->slot via fncallN.
#
# Anchor: this layout hosts what programs/native_compute_store.cyr
# proved end-to-end on AMD Cezanne 2026-04-28 — every operation that
# flow exercised gets a slot. Texture / render pipeline / surface slots
# are deferred (docs/proposals/v3-backend-interface.md) until each has a
# working native e2e program; adding them with stub
# `return GPU_ERR_NOT_IMPLEMENTED` bodies is explicitly out of scope.   #skip-lint
#
# Backend struct layout (176 bytes — 21 fnptr slots + 1 kind value):
#
# v0 (Step 1, 88 bytes):
#   +0:  ctx_create_from_preinit  fnptr (preinit_ptr)            -> ctx
#   +8:  ctx_release              fnptr (ctx)                    -> 0
#   +16: buffer_create            fnptr (ctx, size, usage)       -> buf
#   +24: buffer_write             fnptr (ctx, buf, off, ptr, n)  -> 0|err
#   +32: buffer_read              fnptr (ctx, buf, off, ptr, n)  -> 0|err
#   +40: buffer_release           fnptr (ctx, buf)               -> 0
#   +48: shader_module_create     fnptr (ctx, bytes_ptr, n)      -> mod
#   +56: shader_module_release    fnptr (ctx, mod)               -> 0
#   +64: compute_dispatch         fnptr (ctx, mod, x, y, z, bp)  -> 0|err
#   +72: device_wait_idle         fnptr (ctx)                    -> 0
#   +80: kind                     u64   value: BACKEND_KIND_*
#
# v1 texture slots (Step 5.4, +32 bytes):
#   +88:  texture_create_2d_rgba8 fnptr (ctx, w, h)              -> tex_ptr
#   +96:  texture_write           fnptr (ctx, tex, src, n)       -> 0|err
#   +104: texture_read            fnptr (ctx, tex, dst, n)       -> 0|err
#   +112: texture_release         fnptr (ctx, tex)               -> 0
#
# v2 render slots (Step 6.8a, +56 bytes):
#   +120: render_target_create_2d_rgba8  fnptr (ctx, w, h)                 -> rt_ptr
#   +128: render_target_release          fnptr (ctx, rt)                   -> 0
#   +136: render_pipeline_create         fnptr (ctx, vs_mod, fs_mod, fmt)  -> pipe
#   +144: render_pipeline_release        fnptr (ctx, pipe)                 -> 0
#   +152: render_pass_begin              fnptr (ctx, rt, clear_color_ptr)  -> pass
#   +160: render_pass_draw               fnptr (ctx, pass, pipe, vc, ic)   -> 0|err
#   +168: render_pass_end                fnptr (ctx, pass)                 -> 0
#
# clear_color_ptr is a 32-byte block of 4 f64 RGBA (mabda Color
# shape) — WGPUColor in webgpu.h v29 is {double r,g,b,a;}, not a
# packed u32. See docs/proposals/v3-backend-interface.md v2.1.
#
# Native side: pipeline state splits into pipeline_sh_block +
# pipeline_ctx_block (built at pipeline_create) + pass_target_block
# (built at pass_begin) + per-draw tail. Single-block pipeline cache
# was an early-draft mistake; matches Mesa radv ctx_cs/cs cut.
#
# The kind field at +80 is a u64 value, not a fnptr — kind is
# invariant per backend, so storing it directly saves an indirect
# call on every kind query. All other slots are fnptr.
#
# Cyrius-fn-to-Cyrius-fn fncall through a struct slot is the
# fundamental shape this interface relies on. The v2.x codebase
# only uses fncallN against extern-C function pointers (wgpu_ffi.cyr).
# tests/tcyr/mabda.tcyr::test_backend_fncall_through_slot_smoke
# proves the shape works in Cyrius-to-Cyrius before any backend
# implementation depends on it. If that test ever fails, the entire
# backend abstraction is unviable — bail out to a different design.

# ================================================================
# Backend kind constants
# ================================================================
# Reserved up front for v4.0 (NVIDIA) and v5.0 (Intel). Adding the
# constants now means downstream code can pattern-match on every
# vendor we plan to ship without churning enum values later.

enum BackendKind {
    BACKEND_KIND_NULL    = 0;
    BACKEND_KIND_WGPU    = 1;
    BACKEND_KIND_AMD     = 2;
    BACKEND_KIND_NVIDIA  = 3;
    BACKEND_KIND_INTEL   = 4;
}

# v3.2 Phase S — shader-source kind, the explicit tag the shader-create slot
# now carries across the byte-polymorphic boundary (the bytes' meaning is no
# longer purely a function of the bound backend, since wgpu accepts both WGSL
# and SPIR-V). GFX9 is reserved up front for when Phase N gives native a real
# ISA-vs-SPIR-V choice.
enum ShaderSourceKind {
    SHADER_SRC_WGSL  = 0;   # UTF-8 text (default; today's wgpu path)
    SHADER_SRC_SPIRV = 1;   # u32-word binary, magic 0x07230203 (wgpu, Phase S)
    SHADER_SRC_GFX9  = 2;   # pre-compiled GFX9 ISA (native today)
}

# ================================================================
# Backend selector (v3 Step 4e, ADR 006) — compile-time choice
# ================================================================
# Default: BACKEND_KIND_WGPU. Consumers that want the native AMD
# path edit this constant to BACKEND_KIND_AMD before building, then
# rebuild. gpu_context_from_preinit() in src/context.cyr reads this
# and routes to gpu_context_new_native() when set to AMD. Explicit
# entry points (gpu_context_new_native) are also available for
# programs that need to opt in regardless of the global default.
#
# v3.1+ may promote this to a `cyrius.cyml` flag if consumer CI
# matrices need per-build switching without editing the source.
# Proposal: docs/proposals/v3-backend-interface.md.
var MABDA_BACKEND_KIND = BACKEND_KIND_WGPU;

# ================================================================
# Slot byte offsets
# ================================================================
# Use these constants instead of raw integers when reading / writing
# slots. The slot offsets are part of the load-bearing struct layout;
# tests/tcyr asserts each one against its expected value.

var BACKEND_SLOT_CTX_CREATE_FROM_PREINIT = 0;
var BACKEND_SLOT_CTX_RELEASE             = 8;
var BACKEND_SLOT_BUFFER_CREATE           = 16;
var BACKEND_SLOT_BUFFER_WRITE            = 24;
var BACKEND_SLOT_BUFFER_READ             = 32;
var BACKEND_SLOT_BUFFER_RELEASE          = 40;
var BACKEND_SLOT_SHADER_MODULE_CREATE    = 48;
var BACKEND_SLOT_SHADER_MODULE_RELEASE   = 56;
var BACKEND_SLOT_COMPUTE_DISPATCH        = 64;
var BACKEND_SLOT_DEVICE_WAIT_IDLE        = 72;
var BACKEND_SLOT_KIND                    = 80;

# v1 texture slots (Step 5.4) — appended after KIND. Append-after-
# kind keeps every v0 slot offset stable so existing layout tests
# pass unchanged. Per docs/proposals/v3-backend-interface.md.
var BACKEND_SLOT_TEXTURE_CREATE_2D_RGBA8 = 88;
var BACKEND_SLOT_TEXTURE_WRITE           = 96;
var BACKEND_SLOT_TEXTURE_READ            = 104;
var BACKEND_SLOT_TEXTURE_RELEASE         = 112;

# v2 render slots (Step 6.8a) — appended after the texture range.
# Same append-after-kind invariant: every v0/v1 slot offset stays
# put. Per docs/proposals/v3-backend-interface.md v2.1.
var BACKEND_SLOT_RENDER_TARGET_CREATE_2D_RGBA8 = 120;
var BACKEND_SLOT_RENDER_TARGET_RELEASE         = 128;
var BACKEND_SLOT_RENDER_PIPELINE_CREATE        = 136;
var BACKEND_SLOT_RENDER_PIPELINE_RELEASE       = 144;
var BACKEND_SLOT_RENDER_PASS_BEGIN             = 152;
var BACKEND_SLOT_RENDER_PASS_DRAW              = 160;
var BACKEND_SLOT_RENDER_PASS_END               = 168;

# v3 surface slots (Step 7.5) — appended after the render range.
# Same append-after-kind invariant: every v0/v1/v2 slot offset
# stays put. Designed for the abstraction layer that sits on top
# of Phase D's KMS primitives (7.1–7.4 + 7.4(b)) and wgpu's
# surface/swapchain machinery — both backends fill the same four
# slots, but the implementations differ widely.
#
# Slot signatures (filled in 7.6 wgpu/native wrappers):
#   surface_configure (ctx, width, height) → surface_ptr
#       wgpu : wraps wgpu_surface_configure on the consumer's
#              window surface.
#       native: opens card+render fds, runs native_kms_init +
#              native_kms_modeset_first_connected + allocates
#              two NativeKmsFb's for double-buffering.
#   surface_acquire (ctx, surface) → fb_ptr
#       wgpu : wgpu_surface_get_current_texture_view.
#       native: returns the back-buffer NativeKmsFb (the one
#              NOT currently scanning).
#   surface_present (ctx, surface) → 0|err
#       wgpu : wgpu_surface_present (queue submit + swap).
#       native: native_kms_present, then swap which FB is back.
#   surface_release (ctx, surface) → 0
#       Cleanup. Releases backend-owned resources; consumer-owned
#       window/fd lifecycle is the consumer's call (master-fd
#       release in particular needs the public-API design from
#       Step 7.7 to settle, since the logind story affects who
#       owns the master fd).
#
# All slot signatures stay within fncall ceiling (3 args max for
# the interface, which is comfortably within fncall6 limits).
var BACKEND_SLOT_SURFACE_CONFIGURE       = 176;
var BACKEND_SLOT_SURFACE_ACQUIRE         = 184;
var BACKEND_SLOT_SURFACE_PRESENT         = 192;
var BACKEND_SLOT_SURFACE_RELEASE         = 200;

# v3.1 mipmap fnptr block (M.2): create a mipped texture + generate the
# chain. Append-after-KIND policy holds — offsets 0..200 unchanged. The
# fillers and the backend_is_complete walk over this range land in M.6
# (deferred per the 6.8a / 7.5 pattern, see docs/development/3-2-punchlist.md:
# layout in tree now, completeness check when there's a real impl to check).
var BACKEND_SLOT_TEXTURE_CREATE_2D_RGBA8_MIPPED = 208;
var BACKEND_SLOT_TEXTURE_GENERATE_MIPMAPS       = 216;

# v3.1 queue fnptr block (Q.1) — multi-queue coordination. Appended
# after the mipmap range; offsets 0..216 unchanged (append-after-KIND
# policy holds). Slot signatures (filled in Q.2 wgpu / Q.3 native):
#   queue_get       (ctx, kind)               -> Queue* | 0
#       wgpu : returns a logical Queue aliasing the single WGPUQueue.
#       native: returns a logical Queue bound to the GFX / COMPUTE /
#               SDMA ring for the kind, with a persistent timeline
#               syncobj.
#   queue_barrier   (ctx, src_queue, dst_queue) -> 0|err
#       wgpu : pins submit ordering on the single queue (no overlap).
#       native: cross-ring timeline WAIT-in / SIGNAL-out (Q.4).
#   queue_wait_idle (ctx, queue)              -> 0|err
#       wgpu : device poll. native: syncobj wait on the queue's point.
# All within the fncall ceiling (3 args max). Public surface lives in
# src/queue.cyr; the backend_is_complete() walk over this range is
# deferred to Q.2 (see docs/development/3-2-punchlist.md) when the wgpu
# fillers land — mirrors the 6.8(a) / 7.5 / M.2 pattern so we don't
# falsely report every backend incomplete while the slots are still zero.
var BACKEND_SLOT_QUEUE_GET               = 224;
var BACKEND_SLOT_QUEUE_BARRIER           = 232;
var BACKEND_SLOT_QUEUE_WAIT_IDLE         = 240;

# v3.2 texfmt block (T.5) — format-parameterized 2D texture create.
# Appended after the queue range; offsets 0..240 unchanged. Slot
# signature (filled in T.6 wgpu / T.7 native):
#   texture_create_2d_fmt (ctx, w, h, fmt) -> tex_ptr | 0
# The backend_is_complete walk over this range activates in T.7 once both
# backends fill it (the M.6b / Q.3b "activate when both fill" pattern) —
# adding it now would falsely report native incomplete between T.6 and T.7.
var BACKEND_SLOT_TEXTURE_CREATE_2D_FMT   = 248;

# v3.2 buffer-copy block (X.5) — SDMA buffer→buffer transfer. Appended
# after the texfmt range; offsets 0..248 unchanged (append-after-KIND
# policy holds). Slot signature (native filler lands here in X.5, wgpu
# filler in X.6):
#   buffer_copy (ctx, queue, src_buf, dst_buf, bytes) -> 0|err
#       wgpu : copy_buffer_to_buffer on the single device queue (queue
#              arg ignored — wgpu has one queue).
#       native: native_transfer_copy_timeline on the queue's DMA ring,
#              then wait_idle (synchronous copy).
# 5 args → fncall5, within the ceiling. The backend_is_complete walk
# over this range activates in X.6 once both backends fill it (the
# M.6b / Q.3b / T.7 "activate when both fill" pattern) — adding it now
# would falsely report wgpu incomplete between X.5 and X.6.
var BACKEND_SLOT_BUFFER_COPY             = 256;

# v3.2 sampleable-texture block (TS.3) — native texture SAMPLING. Appended
# after the buffer-copy slot; offsets 0..256 unchanged. Slot signatures
# (fillers land in TS.5):
#   texture_create_2d_sampleable (ctx, w, h, fmt) -> tex_ptr | 0
#       wgpu : a TEXTURE_BINDING view; native: tiled-or-linear BO + a
#              T#/S# descriptor BO stashed on the (grown) NativeTexture.
#   texture_bind_for_sample (ctx, pass, tex, sampler) -> 0|err
#       wgpu : builds the bind group (view + WGPUSampler) on the pass;
#              native: stashes the tex's T#/S# VA on the pass struct so the
#              next render_pass_draw emits the PS USER_DATA SET_SH_REG.
# 4 args max -> within the fncall ceiling. The backend_is_complete walk over
# this range activates in TS.5 once both backends fill it (the M.6b / Q.3b /
# T.7 "activate when both fill" pattern) — adding it now would falsely report
# both backends incomplete between TS.3 and TS.5.
var BACKEND_SLOT_TEXTURE_CREATE_2D_SAMPLEABLE = 264;
var BACKEND_SLOT_TEXTURE_BIND_FOR_SAMPLE      = 272;

var BACKEND_SIZE                         = 280;

# v0 fnptr block ends at +80 (the KIND value sits there). Layout
# assertions and the v0 portion of backend_is_complete() iterate
# 0..80. Kept stable so v0 tests don't need to change.
var BACKEND_FNPTR_SLOTS_END              = 80;

# v1 texture fnptr block: 88..120. Treated as a second range by
# backend_is_complete() so the kind value at +80 isn't mistaken
# for a missing fnptr.
var BACKEND_TEXTURE_SLOTS_BEGIN          = 88;
var BACKEND_TEXTURE_SLOTS_END            = 120;

# v2 render fnptr block: 120..176. Treated as a third range by
# backend_is_complete() so kind at +80 stays unambiguous and v0/v1
# tests don't have to know about the new slots.
var BACKEND_RENDER_SLOTS_BEGIN           = 120;
var BACKEND_RENDER_SLOTS_END             = 176;

# v3 surface fnptr block: 176..208. Fourth range. Per the same pattern,
# the surface range walk is deferred (see docs/development/roadmap.md)
# until Step 7.6 lands the wgpu/native fillers — adding the range walk
# now would falsely report all backends incomplete. Mirrors the 6.8(a)
# approach: layout in tree, completeness check follows when there's a
# real impl to check.
var BACKEND_SURFACE_SLOTS_BEGIN          = 176;
var BACKEND_SURFACE_SLOTS_END            = 208;

# v3.1 mipmap fnptr block: 208..224. Fifth range. backend_is_complete()'s
# walk over it is deferred to M.6 (see docs/development/3-2-punchlist.md)
# when the wgpu/native fillers land — adding the walk now would falsely
# report every backend incomplete, since the slots are still zero. Same
# as the 6.8(a) / 7.5 pattern.
var BACKEND_MIPMAP_SLOTS_BEGIN           = 208;
var BACKEND_MIPMAP_SLOTS_END             = 224;

# v3.1 queue fnptr block: 224..248. Sixth range. backend_is_complete()'s
# walk over it is deferred to Q.2 (see docs/development/3-2-punchlist.md)
# when the wgpu/native fillers land — adding the walk now would falsely
# report every backend incomplete, since the slots are still zero. Same
# as the 6.8(a) / 7.5 / M.2 pattern.
var BACKEND_QUEUE_SLOTS_BEGIN            = 224;
var BACKEND_QUEUE_SLOTS_END              = 248;

# v3.2 texfmt fnptr block: 248..256. Seventh range. backend_is_complete()'s
# walk over it is deferred to T.7 (see docs/development/3-2-punchlist.md) when
# the native filler lands alongside T.6's wgpu filler — same "activate when
# both backends fill" pattern.
var BACKEND_TEXFMT_SLOTS_BEGIN           = 248;
var BACKEND_TEXFMT_SLOTS_END             = 256;

# v3.2 buffer-copy fnptr block: 256..264. Eighth range. backend_is_complete()'s
# walk over it is deferred to X.6 (see docs/development/3-2-punchlist.md) when
# the wgpu filler lands alongside X.5's native filler — same "activate when
# both backends fill" pattern as T.7.
var BACKEND_BUFFERCOPY_SLOTS_BEGIN       = 256;
var BACKEND_BUFFERCOPY_SLOTS_END         = 264;

# v3.2 sampleable fnptr block: 264..280. Ninth range. backend_is_complete()'s
# walk over it is deferred to TS.5 (see docs/development/3-2-punchlist.md) when
# both backends fill create_sampleable + bind_for_sample — same "activate when
# both fill" pattern as T.7 / X.6.
var BACKEND_SAMPLE_SLOTS_BEGIN           = 264;
var BACKEND_SAMPLE_SLOTS_END             = 280;

# ================================================================
# Backend struct construction
# ================================================================

# Allocate a zero-initialized Backend. Caller fills slots before
# wiring it into a GpuContext.
fn backend_new(): i64 {
    var b = alloc(BACKEND_SIZE);
    memset(b, 0, BACKEND_SIZE);
    return b;
}

# ================================================================
# Slot setters / getters
# ================================================================
# Generic slot access. Specialized wrapper calls — e.g.
# backend_compute_dispatch(b, ctx, mod, x, y, z, bp) — will land in
# subsequent steps once the wgpu and native backend implementations
# go in. Step 1 only needs the raw shape.

fn backend_set_slot(b, off, fnptr): i64 {
    store64(b + off, fnptr);
    return 0;
}

fn backend_get_slot(b, off): i64 {
    return load64(b + off);
}

fn backend_set_kind(b, kind): i64 {
    store64(b + BACKEND_SLOT_KIND, kind);
    return 0;
}

fn backend_kind(b): i64 {
    return load64(b + BACKEND_SLOT_KIND);
}

# ================================================================
# Completeness check
# ================================================================
# Returns 1 if every fnptr slot is non-zero. Does NOT check the
# kind value — kind == BACKEND_KIND_NULL is a separate condition
# that callers can check independently. Used by backend builders
# to assert post-conditions during context init.

fn backend_is_complete(b): i64 {
    var off = 0;
    while (off < BACKEND_FNPTR_SLOTS_END) {
        if (load64(b + off) == 0) { return 0; }
        off = off + 8;
    }
    var off2 = BACKEND_TEXTURE_SLOTS_BEGIN;
    while (off2 < BACKEND_TEXTURE_SLOTS_END) {
        if (load64(b + off2) == 0) { return 0; }
        off2 = off2 + 8;
    }
    # v2 render slots — Step 6.8b extended the walk now that
    # backend_wgpu_new fills the render range. backend_native_new
    # gets the same treatment in Step 6.8c (gated on 6.2 + 6.5 + 6.6).
    # Until then native callers will see is_complete = 0 and any
    # caller that asserts completeness on a native backend without
    # 6.8c needs to know it's pre-v2 territory.
    var off3 = BACKEND_RENDER_SLOTS_BEGIN;
    while (off3 < BACKEND_RENDER_SLOTS_END) {
        if (load64(b + off3) == 0) { return 0; }
        off3 = off3 + 8;
    }
    # v3 surface slots (Step 7.6) — both wgpu and native fill these
    # with stub fns initially; real implementations land in 7.7
    # alongside the public API design. The walk treats stubs as
    # filled (any non-null fnptr counts), so adding them here keeps
    # both backends "complete" while leaving the runtime behavior
    # of surface_* deliberately unimplemented.
    var off4 = BACKEND_SURFACE_SLOTS_BEGIN;
    while (off4 < BACKEND_SURFACE_SLOTS_END) {
        if (load64(b + off4) == 0) { return 0; }
        off4 = off4 + 8;
    }
    # v3.1 mipmap slots (M.6b) — both backends now fill create_mipped +
    # generate_mipmaps for real (native) or fail-loud
    # (wgpu generate returns GPU_ERR_NOT_IMPLEMENTED until wgpu compute   #skip-lint
    # lands; the slot fnptr is non-null, so completeness holds).
    var off5 = BACKEND_MIPMAP_SLOTS_BEGIN;
    while (off5 < BACKEND_MIPMAP_SLOTS_END) {
        if (load64(b + off5) == 0) { return 0; }
        off5 = off5 + 8;
    }
    # v3.1 queue slots (Q.3b) — both backends now fill the queue range
    # (wgpu: single-queue aliasing + submit-order barrier; native:
    # distinct HW rings + persistent timeline syncobjs), so the walk
    # over it is activated. wgpu fills all three; native fills all three.
    var off6 = BACKEND_QUEUE_SLOTS_BEGIN;
    while (off6 < BACKEND_QUEUE_SLOTS_END) {
        if (load64(b + off6) == 0) { return 0; }
        off6 = off6 + 8;
    }
    # v3.2 texfmt slot (T.7) — both backends fill the format-parameterized
    # create now (wgpu T.6, native T.7), so the walk over this range is
    # active.
    var off7 = BACKEND_TEXFMT_SLOTS_BEGIN;
    while (off7 < BACKEND_TEXFMT_SLOTS_END) {
        if (load64(b + off7) == 0) { return 0; }
        off7 = off7 + 8;
    }
    # v3.2 buffer-copy slot (X.6) — both backends fill the SDMA/copy slot
    # now (native X.5, wgpu X.6), so the walk over this range is active.
    var off8 = BACKEND_BUFFERCOPY_SLOTS_BEGIN;
    while (off8 < BACKEND_BUFFERCOPY_SLOTS_END) {
        if (load64(b + off8) == 0) { return 0; }
        off8 = off8 + 8;
    }
    # v3.2 sampleable-texture slots (TS.5) — both backends fill create_sampleable
    # + bind_for_sample now (native TS.5a, wgpu TS.5b), so the walk is active.
    var off9 = BACKEND_SAMPLE_SLOTS_BEGIN;
    while (off9 < BACKEND_SAMPLE_SLOTS_END) {
        if (load64(b + off9) == 0) { return 0; }
        off9 = off9 + 8;
    }
    return 1;
}

# ================================================================
# Smoke test helper
# ================================================================
# Mounted on a backend slot in tests/tcyr to prove Cyrius-fn-via-
# fnptr-via-struct-slot dispatch works. Returns sentinel + arg so
# the assertion can verify the slot's fnptr was actually called
# (and called with the right arg). Sentinel is 0xBA67E47D — chosen
# to not collide with common error codes or low addresses.

var BACKEND_SMOKE_SENTINEL = 0xBA67E47D;

fn _backend_smoke_sentinel(arg): i64 {
    return BACKEND_SMOKE_SENTINEL + arg;
}

# --- backend_wgpu.cyr ---

# @internal — wgpu Backend implementation (v3 Phase B5, ADR 006)
# backend_wgpu.cyr — fills the Backend interface (src/backend.cyr)
# with thin wrappers around the existing wgpu FFI + descriptors.
#
# Step 2 scope: land the wrapper fns + a backend_wgpu_new() builder
# that produces a complete Backend (all 10 fnptr slots set, kind =
# BACKEND_KIND_WGPU). The wrappers are not yet driven (docs/development/
# roadmap.md) by the public API in buffer.cyr / compute.cyr / etc. —
# that's Step 3's refactor.
# Until then this module is reachable only through backend_wgpu_new()
# and the layout/completeness tests in tests/tcyr.
#
# Slot signatures (from docs/proposals/v3-backend-interface.md):
#   ctx_create_from_preinit (preinit_ptr)             -> ctx
#   ctx_release             (ctx)                     -> 0
#   buffer_create           (ctx, size, usage)        -> buf
#   buffer_write            (ctx, buf, off, ptr, n)   -> 0|err
#   buffer_read             (ctx, buf, off, ptr, n)   -> 0|err
#   buffer_release          (ctx, buf)                -> 0
#   shader_module_create    (ctx, bytes_ptr, n)       -> shmod
#   shader_module_release   (ctx, shmod)              -> 0
#   compute_dispatch        (ctx, shmod, x, y, z, bp) -> 0|err  (STUB in Step 2)
#   device_wait_idle        (ctx)                     -> 0
#
# Note: Cyrius reserves `mod` as an operator-position keyword, so the
# shader-module parameter is named `shmod` here (and in the Backend
# slot type comments). The slot semantics are unchanged.

# ================================================================
# Context
# ================================================================
# Slot signature: "raw ctx pointer or 0 on failure". This wrapper
# does the wgpu-specific bookkeeping (validate preinit fields,
# allocate the 40-byte GpuContext, copy instance/adapter/device/
# queue from the C launcher's preinit struct). It does NOT call
# the public gpu_context_from_preinit — that fn now allocates a
# backend and dispatches *into* this slot, so calling it back would
# recurse forever. The +32 backend slot in the ctx struct is left
# zero; the public caller fills it after the slot returns.

fn _backend_wgpu_ctx_create_from_preinit(preinit_ptr): i64 {
    if (preinit_ptr == 0) { return 0; }
    var instance = load64(preinit_ptr);
    var adapter  = load64(preinit_ptr + 8);
    var device   = load64(preinit_ptr + 16);
    var queue    = load64(preinit_ptr + 24);
    if (instance == 0) { return 0; }
    if (adapter == 0)  { return 0; }
    if (device == 0)   { return 0; }
    var ctx = alloc(GPU_CONTEXT_SIZE);
    memset(ctx, 0, GPU_CONTEXT_SIZE);
    store64(ctx,      instance);
    store64(ctx + 8,  adapter);
    store64(ctx + 16, device);
    store64(ctx + 24, queue);
    return ctx;
}

# Slot signature: "release ctx, return 0". Releases the wgpu
# handles directly (does NOT call public gpu_context_release —
# that fn now dispatches *into* this slot). The backend ptr at
# +32 is owned by the caller; this wrapper does not touch it.

fn _backend_wgpu_ctx_release(ctx): i64 {
    if (ctx == 0) { return 0; }
    var device = load64(ctx + 16);
    var adapter = load64(ctx + 8);
    var instance = load64(ctx);
    if (device != 0)   { wgpu_device_release(device); }
    if (adapter != 0)  { wgpu_adapter_release(adapter); }
    if (instance != 0) { wgpu_instance_release(instance); }
    return 0;
}

# ================================================================
# Buffer
# ================================================================
# v0 slot signatures don't carry a label — pass NULL to the wgpu
# descriptor builder, which short-circuits the StringView write.
# Step 3 may revise the slot to take a label if profiling / debug
# tooling needs one.

fn _backend_wgpu_buffer_create(ctx, size, usage): i64 {
    var device = gpu_ctx_device(ctx);
    # v3.2 X.6 (audit 2026-06-15 MED-3): ensure every mabda-created buffer
    # can serve as a gpu_buffer_copy operand, matching native's permissive
    # LINEAR BOs (which ignore usage). WebGPU forbids MAP_READ|COPY_SRC and
    # MAP_WRITE|COPY_DST, so for mappable buffers add only the compatible
    # COPY flag; otherwise add both. Removes the prior cross-backend
    # asymmetry where a STORAGE-only buffer copied fine on native but
    # failed wgpu validation.
    var u = usage;
    if ((u & WGPU_BUFFER_USAGE_MAP_READ) != 0) {
        u = u | WGPU_BUFFER_USAGE_COPY_DST;
    } else {
        if ((u & WGPU_BUFFER_USAGE_MAP_WRITE) != 0) {
            u = u | WGPU_BUFFER_USAGE_COPY_SRC;
        } else {
            u = u | WGPU_BUFFER_USAGE_COPY_SRC | WGPU_BUFFER_USAGE_COPY_DST;
        }
    }
    var desc = wgpu_buffer_descriptor(0, u, size, 0);
    return wgpu_device_create_buffer(device, desc);
}

fn _backend_wgpu_buffer_write(ctx, buf, off, ptr, n): i64 {
    var queue = gpu_ctx_queue(ctx);
    wgpu_queue_write_buffer(queue, buf, off, ptr, n);
    return 0;
}

# Synchronous read. Stages an internal MAP_READ buffer, copies
# n bytes from buf+off into it, maps, memcpy's into the caller's
# ptr, and releases. Inlined here (rather than calling buffer.cyr's
# read_buffer_capped) so backend_wgpu.cyr stays placement-independent
# in the include chain. The 256 MB cap matches the buffer.cyr
# default — anything larger requires a bespoke streaming path.
var _BACKEND_WGPU_READ_CAP = 268435456;

fn _backend_wgpu_buffer_read(ctx, buf, off, ptr, n): i64 {
    if (n <= 0)                     { return GPU_ERR_BUFFER; }
    if (n > _BACKEND_WGPU_READ_CAP) { return GPU_ERR_BUFFER; }
    var src_size = wgpu_buffer_get_size(buf);
    if (off < 0)                    { return GPU_ERR_BUFFER; }
    if (off + n > src_size)         { return GPU_ERR_BUFFER; }
    var device = gpu_ctx_device(ctx);
    var queue  = gpu_ctx_queue(ctx);

    var staging_usage = WGPU_BUFFER_USAGE_MAP_READ | WGPU_BUFFER_USAGE_COPY_DST;
    var staging_desc = wgpu_buffer_descriptor(0, staging_usage, n, 0);
    var staging = wgpu_device_create_buffer(device, staging_desc);
    if (staging == 0) { return GPU_ERR_BUFFER; }

    var encoder = wgpu_device_create_command_encoder(device, 0);
    wgpu_command_encoder_copy_buffer_to_buffer(encoder, buf, off, staging, 0, n);
    var cmd_buf = wgpu_command_encoder_finish(encoder, 0);
    wgpu_queue_submit_one(queue, cmd_buf);

    var status = wgpu_buffer_map_sync(device, staging, WGPU_MAP_MODE_READ, 0, n);
    if (status != WGPU_BUFFER_MAP_ASYNC_STATUS_SUCCESS) {
        wgpu_buffer_release(staging);
        return GPU_ERR_READBACK_MAP;
    }
    var mapped = wgpu_buffer_get_const_mapped_range(staging, 0, n);
    if (mapped == 0) {
        wgpu_buffer_unmap(staging);
        wgpu_buffer_release(staging);
        return GPU_ERR_READBACK_MAP;
    }
    memcpy(ptr, mapped, n);
    wgpu_buffer_unmap(staging);
    wgpu_buffer_release(staging);
    return 0;
}

fn _backend_wgpu_buffer_release(ctx, buf): i64 {
    if (ctx == 0) { return 0; }
    wgpu_buffer_release(buf);
    return 0;
}

# v3.2 X.6 — buffer_copy backend slot (wgpu). Copies `bytes` from
# src_buf to dst_buf via a command-encoder copy_buffer_to_buffer on the
# single device queue, then polls until it retires so dst is readable on
# return (the v3.0 synchronous contract, matching the native filler).
# The `queue` arg is a logical Queue aliasing the one WGPUQueue — wgpu
# has a single queue, so it's accepted (non-null) but otherwise unused;
# the device queue is read from ctx. copy_buffer_to_buffer requires the
# source carry COPY_SRC usage and the dest COPY_DST — _backend_wgpu_buffer_create
# OR's both into every mabda-created buffer's usage, so any buffer from
# gpu_buffer_create is a valid operand. Bounds the copy by each buffer's
# allocated size; the public dispatchers enforce the 4-byte-multiple size.
# Returns 0|GPU_ERR_*.
fn _backend_wgpu_buffer_copy(ctx, queue, src_buf, dst_buf, bytes): i64 {
    if (ctx == 0)     { return GPU_ERR_OTHER; }
    if (queue == 0)   { return GPU_ERR_OTHER; }
    if (src_buf == 0) { return GPU_ERR_BUFFER; }
    if (dst_buf == 0) { return GPU_ERR_BUFFER; }
    if (bytes <= 0)   { return GPU_ERR_BUFFER; }
    var src_size = wgpu_buffer_get_size(src_buf);
    var dst_size = wgpu_buffer_get_size(dst_buf);
    if (bytes > src_size) { return GPU_ERR_BUFFER; }
    if (bytes > dst_size) { return GPU_ERR_BUFFER; }
    var device = gpu_ctx_device(ctx);
    var dqueue = gpu_ctx_queue(ctx);
    var encoder = wgpu_device_create_command_encoder(device, 0);
    wgpu_command_encoder_copy_buffer_to_buffer(encoder, src_buf, 0, dst_buf, 0, bytes);
    var cmd_buf = wgpu_command_encoder_finish(encoder, 0);
    wgpu_queue_submit_one(dqueue, cmd_buf);
    wgpu_device_poll(device, 1);
    return 0;
}

# v3.1 [M.4(wgpu)]: mabda-internal WGSL 2×2 box-filter downsample compute
# shader — the wgpu analog of native_gfx9_shader_downsample_2x2. Binding 0
# is a sampled view of mip level n (read via textureLoad, no sampler);
# binding 1 is a write storage view of level n+1. One invocation per dst
# texel (@workgroup_size(8,8); the generate slot dispatches
# ceil(w/8)×ceil(h/8) and the in-shader bounds check covers the remainder).
# Assembled from <120-char pieces (Cyrius has no literal concatenation and
# the line-length lint caps at 120) into a caller-owned buffer — no global
# literal, no per-call leak. WGSL is whitespace-flexible so the single
# logical line is fine. Consumed by the wgpu generate slot (M.6);
# byte-polymorphic create reads it as WGSL UTF-8.
fn _wgsl_append(dst, off, piece): i64 {
    var n = _wgpu_strnlen(piece, WGPU_SHADER_SOURCE_MAX_BYTES);
    memcpy(dst + off, piece, n);
    return off + n;
}

# Write the NUL-terminated downsample WGSL into `dst` (caller allocates
# >= 640 bytes). Returns the byte length (excluding the NUL).
fn mabda_wgsl_downsample_2x2(dst): i64 {
    var o = 0;
    o = _wgsl_append(dst, o, "@group(0) @binding(0) var src: texture_2d<f32>; ");
    o = _wgsl_append(dst, o, "@group(0) @binding(1) ");
    o = _wgsl_append(dst, o, "var dst: texture_storage_2d<rgba8unorm, write>; ");
    o = _wgsl_append(dst, o, "@compute @workgroup_size(8, 8) ");
    o = _wgsl_append(dst, o, "fn main(@builtin(global_invocation_id) gid: vec3<u32>) { ");
    o = _wgsl_append(dst, o, "let d = textureDimensions(dst); ");
    o = _wgsl_append(dst, o, "if (gid.x >= d.x || gid.y >= d.y) { return; } ");
    o = _wgsl_append(dst, o, "let s = vec2<u32>(gid.x * 2u, gid.y * 2u); ");
    o = _wgsl_append(dst, o, "let c = (textureLoad(src, s, 0) ");
    o = _wgsl_append(dst, o, "+ textureLoad(src, s + vec2<u32>(1u, 0u), 0) ");
    o = _wgsl_append(dst, o, "+ textureLoad(src, s + vec2<u32>(0u, 1u), 0) ");
    o = _wgsl_append(dst, o, "+ textureLoad(src, s + vec2<u32>(1u, 1u), 0)) * 0.25; ");
    o = _wgsl_append(dst, o, "textureStore(dst, gid.xy, c); }");
    store8(dst + o, 0);
    return o;
}

# ================================================================
# Shader module
# ================================================================
# v0 slot takes (bytes_ptr, n). For wgpu, bytes are WGSL UTF-8.
# We don't enforce null-termination — wgpu_string_view bounds
# strlen() at WGPU_LABEL_MAX_BYTES (4 KB) so non-terminated input
# fails gracefully rather than walking off mapped memory. Real
# WGSL programs can exceed that 4 KB though; this is a Step-3-era
# follow-up (see docs/development/roadmap.md) to pass an explicit
# length to wgpu_string_view_len.

# v3.2 Phase S — `kind` carries the source format (the slot widened to fncall4).
# WGSL: build a StringView source from the n bytes. SPIRV: validate the binary
# (`_spirv_validate` — magic/align/bound) then build a WGPUShaderSourceSPIRV with
# codeSize = n/4 WORDS. A failed validation or an unknown kind returns 0 (the
# fail-loud null; e.g. SPIR-V against an instance lacking the feature also nulls
# at the create call). `n` is the BYTE length for both.
fn _backend_wgpu_shader_module_create(ctx, bytes_ptr, n, kind): i64 {
    if (ctx == 0)       { return 0; }
    if (bytes_ptr == 0) { return 0; }
    if (n <= 0)         { return 0; }
    var device = gpu_ctx_device(ctx);
    var src = 0;
    if (kind == SHADER_SRC_SPIRV) {
        if (_spirv_validate(bytes_ptr, n) != 0) { return 0; }   # reject malformed
        src = wgpu_shader_source_spirv(bytes_ptr, n / 4);       # codeSize in WORDS
    } else {
        if (kind != SHADER_SRC_WGSL) { return 0; }   # native GFX9 isn't a wgpu input
        # Audit 2026-06-14 [MED-4]: thread the explicit, validated length n
        # through instead of a 4 KiB-capped NUL scan. wgpu reads exactly
        # StringView.length bytes.
        src = wgpu_shader_source_wgsl_len(bytes_ptr, n);
    }
    var desc = wgpu_shader_module_descriptor(0, src);
    return wgpu_device_create_shader_module(device, desc);
}

fn _backend_wgpu_shader_module_release(ctx, shmod): i64 {
    if (ctx == 0) { return 0; }
    wgpu_shader_module_release(shmod);
    return 0;
}

# ================================================================
# Texture slots — wgpu wrappers (Step 5.5)
# ================================================================
# Returns a 32-byte struct in the same shape src/texture.cyr uses
# elsewhere in the codebase, so the wgpu side stays consistent:
#   +0:  handle   (WGPUTexture, u64)
#   +8:  view     (WGPUTextureView, u64)
#   +16: sampler  (WGPUSampler — unused for plain write/read; kept
#                  for shape-compat with src/texture.cyr; zero here)
#   +24: width    (u32)
#   +28: height   (u32)
#
# Step 5.5 limit: width must be a multiple of 64 (so bytes_per_row =
# width*4 satisfies wgpu's COPY_BUFFER_ALIGNMENT = 256 on the read
# path). Real consumer flows already match this — render_e2e uses
# 256x256. A row-padded staging buffer for sub-64 widths is deferred (see docs/development/roadmap.md).

fn _backend_wgpu_texture_create_2d_rgba8(ctx, width, height): i64 {
    if (ctx == 0) { return 0; }
    if (width <= 0) { return 0; }
    if (height <= 0) { return 0; }
    var device = gpu_ctx_device(ctx);
    var usage = WGPU_TEXTURE_USAGE_COPY_SRC
    | WGPU_TEXTURE_USAGE_COPY_DST
    | WGPU_TEXTURE_USAGE_TEXTURE_BINDING;
    var desc = wgpu_texture_descriptor(0, usage,
    WGPU_TEXTURE_DIMENSION_2D,
    width, height,
    WGPU_TEXTURE_FORMAT_RGBA8_UNORM);
    var handle = wgpu_device_create_texture(device, desc);
    if (handle == 0) { return 0; }
    var vd = wgpu_texture_view_descriptor(0,
    WGPU_TEXTURE_FORMAT_RGBA8_UNORM,
    WGPU_TEXTURE_VIEW_DIMENSION_2D);
    var view = wgpu_texture_create_view(handle, vd);
    if (view == 0) {
        wgpu_texture_release(handle);
        return 0;
    }
    var t = alloc(32);
    memset(t, 0, 32);
    store64(t +  0, handle);
    store64(t +  8, view);
    store64(t + 16, 0);
    store32(t + 24, width);
    store32(t + 28, height);
    return t;
}

# v3.1 [M.6]: create a mipped 2D RGBA8 texture (mipLevelCount = mip_count)
# with STORAGE_BINDING so the downsample compute shader can write upper
# levels. Returns a 32-byte WgpuMippedTexture: handle@0, level-0 view@8,
# width@16(u32), height@20(u32), mip_count@24(u32). The per-level views
# the generate path binds are built lazily in the generate slot (M.6b)
# from `handle` via wgpu_texture_view_descriptor_level — no view table to
# carry here. The consumer treats the returned ptr as opaque.
fn _backend_wgpu_texture_create_2d_rgba8_mipped(ctx, width, height, mip_count): i64 {
    if (ctx == 0) { return 0; }
    if (width <= 0) { return 0; }
    if (height <= 0) { return 0; }
    if (mip_count < 1) { return 0; }
    var device = gpu_ctx_device(ctx);
    var usage = WGPU_TEXTURE_USAGE_COPY_SRC
    | WGPU_TEXTURE_USAGE_COPY_DST
    | WGPU_TEXTURE_USAGE_TEXTURE_BINDING
    | WGPU_TEXTURE_USAGE_STORAGE_BINDING;
    var desc = wgpu_texture_descriptor_mipped(0, usage,
    WGPU_TEXTURE_DIMENSION_2D, width, height,
    WGPU_TEXTURE_FORMAT_RGBA8_UNORM, mip_count);
    var handle = wgpu_device_create_texture(device, desc);
    if (handle == 0) { return 0; }
    # A full-chain view (all levels) for sampling/upload convenience.
    var vd = wgpu_texture_view_descriptor(0,
    WGPU_TEXTURE_FORMAT_RGBA8_UNORM,
    WGPU_TEXTURE_VIEW_DIMENSION_2D);
    store32(vd + 36, mip_count);   # mipLevelCount = full chain
    var view = wgpu_texture_create_view(handle, vd);
    if (view == 0) {
        wgpu_texture_release(handle);
        return 0;
    }
    var t = alloc(32);
    memset(t, 0, 32);
    store64(t +  0, handle);
    store64(t +  8, view);
    store32(t + 16, width);
    store32(t + 20, height);
    store32(t + 24, mip_count);
    return t;
}

# v3.1 [M.6b]: wgpu mipmap generation needs a real compute pipeline
# (shader module + storage-texture bind groups + per-level dispatch), but
# the wgpu COMPUTE path itself is still a v3.0 stub
# (_backend_wgpu_compute_dispatch returns GPU_ERR_OTHER). Until wgpu
# compute lands, this returns GPU_ERR_NOT_IMPLEMENTED (see docs/development/roadmap.md) —
# fail-loud, not fail-silent (the 3.0.4 LOW-3 precedent).
# The native backend is the
# working mipmap-generation path today; wgpu `create_mipped` above DOES
# work (texture allocation + STORAGE view), so a wgpu consumer can upload
# all levels manually meanwhile. Wiring this is gated on real wgpu compute
# (a v3.x item).
fn _backend_wgpu_texture_generate_mipmaps(ctx, tex): i64 {
    return GPU_ERR_NOT_IMPLEMENTED;   #skip-lint
}

# v3.2 [T.6]: format-parameterized create. Same 32-byte tex struct as the
# rgba8 path but the (previously-zero) +16 slot now stashes the MABDA_TEXFMT_*
# id so the unified write slot can compute block-aware sizes. Usage is
# TEXTURE_BINDING | COPY_DST (compressed textures cannot be COPY_SRC /
# render attachments). An adapter that lacks the format's family makes
# wgpu_device_create_texture return 0, so create fails gracefully — the
# consumer's gpu_caps_supports_format pre-check is the friendly gate.
fn _backend_wgpu_texture_create_2d_fmt(ctx, width, height, fmt): i64 {
    if (ctx == 0) { return 0; }
    if (width <= 0) { return 0; }
    if (height <= 0) { return 0; }
    # Audit 2026-06-15 LOW: cap dims independently of the public dispatcher
    # (mirrors the native sibling + the v2 audit MED-1 slot-independence rule).
    if (validate_dimensions(width, height, MABDA_MAX_TEXTURE_DIM_2D) != 0) {
        return 0;
    }
    var wfmt = mabda_texfmt_to_wgpu(fmt);
    if (wfmt == 0) { return 0; }            # unknown / Undefined
    # Audit 2026-06-15 LOW: fail loud (graceful 0) if the adapter lacks this
    # format's compression family — otherwise wgpuDeviceCreateTexture aborts
    # the process (uncaptured wgpu error) on an unsupported format. (Consumers
    # should pre-check gpu_caps_supports_format; this is the backend guard.)
    var fam = mabda_texfmt_compression_family(fmt);
    if (fam != 0) {
        var mask = gpu_caps_detect_texture_compression(gpu_ctx_adapter(ctx));
        if ((mask & fam) == 0) { return 0; }
    }
    var device = gpu_ctx_device(ctx);
    # COPY_SRC lets a consumer (and the T.8 e2e) copy the compressed blocks
    # back out for verification; COPY_DST for upload; TEXTURE_BINDING for
    # sampling. (Compressed textures cannot be render attachments.)
    var usage = WGPU_TEXTURE_USAGE_COPY_SRC | WGPU_TEXTURE_USAGE_COPY_DST
    | WGPU_TEXTURE_USAGE_TEXTURE_BINDING;
    var desc = wgpu_texture_descriptor(0, usage,
    WGPU_TEXTURE_DIMENSION_2D, width, height, wfmt);
    var handle = wgpu_device_create_texture(device, desc);
    if (handle == 0) { return 0; }
    var vd = wgpu_texture_view_descriptor(0, wfmt, WGPU_TEXTURE_VIEW_DIMENSION_2D);
    var view = wgpu_texture_create_view(handle, vd);
    if (view == 0) {
        wgpu_texture_release(handle);
        return 0;
    }
    var t = alloc(32);
    memset(t, 0, 32);
    store64(t +  0, handle);
    store64(t +  8, view);
    store64(t + 16, fmt);                   # MABDA_TEXFMT_* (0 = RGBA8)
    store32(t + 24, width);
    store32(t + 28, height);
    return t;
}

# v3.2 TS.5 — sampleable 2D texture create (wgpu). The fmt-create above
# already makes a TEXTURE_BINDING texture + a 2D view, which is exactly a
# sampleable resource on wgpu, so this is a thin alias. (The native sibling
# differs materially — it builds a tiled-or-linear BO + a T#/S# descriptor.)
fn _backend_wgpu_texture_create_2d_sampleable(ctx, width, height, fmt): i64 {
    return _backend_wgpu_texture_create_2d_fmt(ctx, width, height, fmt);
}

# v3.2 TS.5 (minimal) — bind a sampleable texture into a render pass (wgpu).
# Stashes the bound texture + sampler intent on the pass struct (bound_tex
# @+24, bound_sampler @+32); the bind-group build + render_pass_encoder
# set_bind_group + the textured pipeline are the wgpu sample render path
# (next bite). Returns 0|GPU_ERR_*.
fn _backend_wgpu_texture_bind_for_sample(ctx, pass, tex, sampler): i64 {
    if (ctx == 0)  { return GPU_ERR_OTHER; }
    if (pass == 0) { return GPU_ERR_OTHER; }
    if (tex == 0)  { return GPU_ERR_TEXTURE; }
    store64(pass + 24, tex);
    store64(pass + 32, sampler);
    return 0;
}

# v3.2 [T.6]: block-aware write. Reads the format id at tex+16 (0 = RGBA8
# for legacy textures created by the rgba8 path, whose +16 is zeroed), so
# this one slot uploads RGBA8 and block-compressed data alike: expected
# size + bytesPerRow + rowsPerImage come from the block geometry. For
# RGBA8 the math reduces to the previous width*4 / height exactly.
fn _backend_wgpu_texture_write(ctx, tex, src, n): i64 {
    if (ctx == 0) { return GPU_ERR_OTHER; }
    if (tex == 0) { return GPU_ERR_OTHER; }
    if (src == 0) { return GPU_ERR_BUFFER; }
    if (n <= 0)   { return GPU_ERR_BUFFER; }
    var handle = load64(tex +  0);
    var fmt    = load64(tex + 16);
    var width  = load32(tex + 24);
    var height = load32(tex + 28);
    var expected = mabda_texfmt_data_size(fmt, width, height);
    if (expected == 0) { return GPU_ERR_BUFFER; }   # invalid fmt/dims on the tex
    if (n != expected) { return GPU_ERR_BUFFER; }
    var queue = gpu_ctx_queue(ctx);
    var bpr = mabda_texfmt_blocks_for_dim(width, mabda_texfmt_block_width(fmt))
    * mabda_texfmt_block_bytes(fmt);                # bytes per block-row
    var rows = mabda_texfmt_blocks_for_dim(height, mabda_texfmt_block_height(fmt));
    var dst_info = wgpu_texel_copy_texture_info(handle, 0);
    var layout = wgpu_texel_copy_buffer_layout(0, bpr, rows);
    var extent = wgpu_extent_3d(width, height, 1);  # extent stays in texels
    wgpu_queue_write_texture(queue, dst_info, src, n, layout, extent);
    return 0;
}

fn _backend_wgpu_texture_read(ctx, tex, dst, n): i64 {
    if (ctx == 0) { return GPU_ERR_OTHER; }
    if (tex == 0) { return GPU_ERR_OTHER; }
    if (dst == 0) { return GPU_ERR_BUFFER; }
    if (n <= 0)   { return GPU_ERR_BUFFER; }
    var device = gpu_ctx_device(ctx);
    var queue  = gpu_ctx_queue(ctx);
    var handle = load64(tex +  0);
    var fmt    = load64(tex + 16);
    var width  = load32(tex + 24);
    var height = load32(tex + 28);
    # Audit 2026-06-15: the write slot is block-aware, but block-compressed
    # READBACK via copy_texture_to_buffer needs 256-byte-padded block rows +
    # an un-pad copy (the path below assumes texel rows). Not implemented for
    # wgpu this minor — fail loud rather than mis-validate / return wrong
    # bytes. Native compressed read works (linear memcpy); a wgpu consumer
    # reads blocks via a 256-padded copy-back, as
    # programs/compressed_texture_e2e.cyr does.
    if (mabda_texfmt_is_compressed(fmt) == 1) { return GPU_ERR_NOT_IMPLEMENTED; }   #skip-lint
    var expected = width * height * 4;
    if (n != expected) { return GPU_ERR_BUFFER; }

    # Stage the readback through a MAP_READ buffer.
    var staging_usage = WGPU_BUFFER_USAGE_MAP_READ
    | WGPU_BUFFER_USAGE_COPY_DST;
    var staging_desc = wgpu_buffer_descriptor(0, staging_usage, n, 0);
    var staging = wgpu_device_create_buffer(device, staging_desc);
    if (staging == 0) { return GPU_ERR_BUFFER; }

    # Build copy_texture_to_buffer args (72-byte struct layout —
    # see src/wgpu_ffi.cyr / programs/render_e2e.cyr for the field
    # offsets).
    var cargs = alloc(72);
    memset(cargs, 0, 72);
    store64(cargs +  0, handle);
    store32(cargs +  8, 0);   # src mip
    store32(cargs + 12, 0);   # origin x
    store32(cargs + 16, 0);   # origin y
    store32(cargs + 20, 0);   # origin z
    store32(cargs + 24, 0);   # aspect = All
    store64(cargs + 32, staging);
    store64(cargs + 40, 0);
    store32(cargs + 48, width * 4);
    store32(cargs + 52, height);
    store32(cargs + 56, width);
    store32(cargs + 60, height);
    store32(cargs + 64, 1);

    var encoder = wgpu_device_create_command_encoder(device, 0);
    wgpu_command_encoder_copy_texture_to_buffer(encoder, cargs);
    var cmd_buf = wgpu_command_encoder_finish(encoder, 0);
    wgpu_queue_submit_one(queue, cmd_buf);

    var status = wgpu_buffer_map_sync(device, staging,
    WGPU_MAP_MODE_READ, 0, n);
    if (status != WGPU_BUFFER_MAP_ASYNC_STATUS_SUCCESS) {
        wgpu_buffer_release(staging);
        return GPU_ERR_READBACK_MAP;
    }
    var mapped = wgpu_buffer_get_const_mapped_range(staging, 0, n);
    if (mapped == 0) {
        wgpu_buffer_unmap(staging);
        wgpu_buffer_release(staging);
        return GPU_ERR_READBACK_MAP;
    }
    memcpy(dst, mapped, n);
    wgpu_buffer_unmap(staging);
    wgpu_buffer_release(staging);
    return 0;
}

fn _backend_wgpu_texture_release(ctx, tex): i64 {
    if (ctx == 0) { return 0; }
    if (tex == 0) { return 0; }
    var handle = load64(tex +  0);
    var view   = load64(tex +  8);
    if (view != 0)   { wgpu_texture_view_release(view); }
    if (handle != 0) { wgpu_texture_release(handle); }
    store64(tex +  0, 0);
    store64(tex +  8, 0);
    store32(tex + 24, 0);
    store32(tex + 28, 0);
    return 0;
}

# ================================================================
# Compute dispatch — STUB for Step 2
# ================================================================
# Full assembly (compute pipeline + bind group from bindings_ptr +
# command encoder + compute pass + dispatch + submit) requires the
# bindings_ptr format to be locked in and the public compute API in
# src/compute.cyr to dispatch through this slot. Both are Step 3
# work — see docs/development/3-0-punchlist.md.
#
# Step 2 returns GPU_ERR_OTHER unconditionally. The slot is filled
# (backend_is_complete returns 1) but calling it through fncall
# until Step 3 lands is a programming error. CPU tests do not call
# this slot.

fn _backend_wgpu_compute_dispatch(ctx, shmod, x, y, z, bp): i64 {
    return GPU_ERR_OTHER;
}

# ================================================================
# Device wait
# ================================================================
# wgpu_device_poll(device, wait=1) blocks until all submitted work
# completes. Slot returns 0 on completion.

fn _backend_wgpu_device_wait_idle(ctx): i64 {
    if (ctx == 0) { return 0; }
    var device = gpu_ctx_device(ctx);
    wgpu_device_poll(device, 1);
    return 0;
}

# ================================================================
# Render slots — v2 (Step 6.8b)
# ================================================================
# 7 wrappers around the existing wgpu render helpers in
# render_target.cyr / render_pipeline.cyr / render_pass.cyr. Slot
# signatures from docs/proposals/v3-backend-interface.md v2.1.
#
# clear_color_ptr is a 32-byte block of 4 f64 RGBA — same shape as
# mabda's Color (src/color.cyr) and as WGPUColor in webgpu.h v29.
# rpb_pass_color reads it via color_r/g/b/a getters which are
# load64 at +0/+8/+16/+24, so the slot can pass the raw pointer
# straight through.
#
# Pipeline struct (16 bytes) — opaque to slot caller:
#   +0:  handle  (WGPURenderPipeline)
#   +8:  reserved
#
# Pass struct (32 bytes) — opaque to slot caller:
#   +0:  encoder (WGPUCommandEncoder)
#   +8:  pass    (WGPURenderPassEncoder)
#   +16: rt_ptr  (back-reference; the rt outlives the pass)
#   +24: reserved

fn _backend_wgpu_render_target_create_2d_rgba8(ctx, width, height): i64 {
    if (ctx == 0) { return 0; }
    if (width <= 0) { return 0; }
    if (height <= 0) { return 0; }
    var device = gpu_ctx_device(ctx);
    var usage = WGPU_TEXTURE_USAGE_RENDER_ATTACHMENT
    | WGPU_TEXTURE_USAGE_TEXTURE_BINDING
    | WGPU_TEXTURE_USAGE_COPY_SRC;
    var desc = wgpu_texture_descriptor(0, usage,
    WGPU_TEXTURE_DIMENSION_2D,
    width, height,
    WGPU_TEXTURE_FORMAT_RGBA8_UNORM);
    var handle = wgpu_device_create_texture(device, desc);
    if (handle == 0) { return 0; }
    var vd = wgpu_texture_view_descriptor(0,
    WGPU_TEXTURE_FORMAT_RGBA8_UNORM,
    WGPU_TEXTURE_VIEW_DIMENSION_2D);
    var view = wgpu_texture_create_view(handle, vd);
    if (view == 0) {
        wgpu_texture_release(handle);
        return 0;
    }
    var rt = alloc(32);
    memset(rt, 0, 32);
    store64(rt +  0, handle);
    store64(rt +  8, view);
    store64(rt + 16, 0);
    store32(rt + 24, width);
    store32(rt + 28, height);
    return rt;
}

fn _backend_wgpu_render_target_release(ctx, rt): i64 {
    if (ctx == 0) { return 0; }
    if (rt == 0) { return 0; }
    var handle = load64(rt +  0);
    var view   = load64(rt +  8);
    if (view != 0)   { wgpu_texture_view_release(view); }
    if (handle != 0) { wgpu_texture_release(handle); }
    store64(rt +  0, 0);
    store64(rt +  8, 0);
    store32(rt + 24, 0);
    store32(rt + 28, 0);
    return 0;
}

fn _backend_wgpu_render_pipeline_create(ctx, vs_mod, fs_mod, color_fmt): i64 {
    if (ctx == 0) { return 0; }
    if (vs_mod == 0) { return 0; }
    if (fs_mod == 0) { return 0; }
    var device = gpu_ctx_device(ctx);
    var fmt = color_fmt;
    if (fmt == 0) { fmt = WGPU_TEXTURE_FORMAT_RGBA8_UNORM; }

    var desc = alloc(168);
    memset(desc, 0, 168);
    wgpu_string_view_null(desc + 8);
    store64(desc + 24, 0);
    _vertex_state_init(desc + 32, vs_mod, "vs_main");
    _primitive_state_init(desc + 96, WGPU_TOPOLOGY_TRIANGLE_LIST,
    WGPU_FRONT_FACE_CCW,
    WGPU_CULL_MODE_NONE);
    store64(desc + 128, 0);
    _multisample_state_init(desc + 136, 1);
    var color_target = _color_target_state_new(fmt, 0);
    var fragment = _fragment_state_new(fs_mod, "fs_main", color_target);
    store64(desc + 160, fragment);

    var handle = wgpu_device_create_render_pipeline(device, desc);
    if (handle == 0) { return 0; }
    var pipe = alloc(16);
    memset(pipe, 0, 16);
    store64(pipe + 0, handle);
    return pipe;
}

fn _backend_wgpu_render_pipeline_release(ctx, pipe): i64 {
    if (ctx == 0) { return 0; }
    if (pipe == 0) { return 0; }
    var handle = load64(pipe + 0);
    if (handle != 0) { wgpu_render_pipeline_release(handle); }
    store64(pipe + 0, 0);
    return 0;
}

fn _backend_wgpu_render_pass_begin(ctx, rt, clear_color_ptr): i64 {
    if (ctx == 0) { return 0; }
    if (rt == 0) { return 0; }
    if (clear_color_ptr == 0) { return 0; }
    var device = gpu_ctx_device(ctx);
    var view = load64(rt + 8);
    if (view == 0) { return 0; }

    var encoder = wgpu_device_create_command_encoder(device, 0);
    if (encoder == 0) { return 0; }

    var pb = rpb_pass_new();
    rpb_pass_color(pb, view, clear_color_ptr);
    var pass = rpb_pass_begin(encoder, pb);
    if (pass == 0) {
        wgpu_command_encoder_release(encoder);
        return 0;
    }

    # 40 bytes (grew 32 → 40 at v3.2 TS.5): +24 bound_tex / +32 bound_sampler
    # for bind_for_sample; both default 0 (no texture bound).
    var p = alloc(40);
    memset(p, 0, 40);
    store64(p +  0, encoder);
    store64(p +  8, pass);
    store64(p + 16, rt);
    return p;
}

fn _backend_wgpu_render_pass_draw(ctx, pass, pipe, vc, ic): i64 {
    if (ctx == 0) { return GPU_ERR_OTHER; }
    if (pass == 0) { return GPU_ERR_OTHER; }
    if (pipe == 0) { return GPU_ERR_OTHER; }
    var pass_enc = load64(pass + 8);
    var pipe_handle = load64(pipe + 0);
    if (pass_enc == 0)    { return GPU_ERR_OTHER; }
    if (pipe_handle == 0) { return GPU_ERR_OTHER; }
    wgpu_render_pass_encoder_set_pipeline(pass_enc, pipe_handle);
    # v3.2 TS.5 — if a sampleable texture was bound (gpu_render_pass_bind_texture
    # stashed it at +24, its sampler intent at +32), build + set its bind group
    # at group 0 from the pipeline's auto-generated BGL. The bound pipeline must
    # be a textured pipeline (WGSL @group(0): texture@0, sampler@1).
    var bound_tex = load64(pass + 24);
    if (bound_tex != 0) {
        var view = load64(bound_tex + 8);   # wgpu tex struct: view @ +8
        if (view == 0) { return GPU_ERR_TEXTURE; }
        var device = gpu_ctx_device(ctx);
        var intent = load64(pass + 32);
        var sdesc = wgpu_sampler_descriptor_from_intent(
        gpu_sampler_filter(intent), gpu_sampler_addr(intent));
        var sampler = wgpu_device_create_sampler(device, sdesc);
        if (sampler == 0) { return GPU_ERR_OTHER; }
        var bgl = wgpu_render_pipeline_get_bind_group_layout(pipe_handle, 0);
        if (bgl == 0) { wgpu_sampler_release(sampler); return GPU_ERR_OTHER; }
        var bgdesc = wgpu_texture_bind_group_descriptor(bgl, view, sampler);
        var bg = wgpu_device_create_bind_group(device, bgdesc);
        if (bg == 0) {
            wgpu_bind_group_layout_release(bgl);
            wgpu_sampler_release(sampler);
            return GPU_ERR_OTHER;
        }
        wgpu_render_pass_encoder_set_bind_group(pass_enc, 0, bg, 0, 0);
        # Audit 2026-06-15 HIGH — release our refs now: wgpu-native retains its
        # own refs to the recorded bind group (and the group AddRef'd the
        # view + sampler), so dropping ours here avoids a per-draw handle leak.
        wgpu_bind_group_release(bg);
        wgpu_bind_group_layout_release(bgl);
        wgpu_sampler_release(sampler);
    }
    wgpu_render_pass_encoder_draw(pass_enc, vc, ic, 0, 0);
    return 0;
}

fn _backend_wgpu_render_pass_end(ctx, pass): i64 {
    if (ctx == 0) { return 0; }
    if (pass == 0) { return 0; }
    var encoder  = load64(pass +  0);
    var pass_enc = load64(pass +  8);
    if (pass_enc != 0) { wgpu_render_pass_encoder_end(pass_enc); }
    if (encoder != 0) {
        var queue = gpu_ctx_queue(ctx);
        var cmd_buf = wgpu_command_encoder_finish(encoder, 0);
        if (cmd_buf != 0) { wgpu_queue_submit_one(queue, cmd_buf); }
        wgpu_command_encoder_release(encoder);
    }
    if (pass_enc != 0) { wgpu_render_pass_encoder_release(pass_enc); }
    store64(pass +  0, 0);
    store64(pass +  8, 0);
    store64(pass + 16, 0);
    return 0;
}

# ----------------------------------------------------------------
# Surface slot wrappers (v3 Step 7.7)
# ----------------------------------------------------------------
# Reads the `WGPUSurface` handle from `gpu_ctx_wgpu_surface_handle(ctx)`
# (set by the public dispatcher `gpu_surface_configure_wgpu` in
# src/surface_v3.cyr before calling the slot). Delegates to the
# v2 `src/surface.cyr` `surface_state_*` API which already handles
# the wgpu surface configuration / acquire / present lifecycle.
# Caller can keep using `surface_state_*` directly if they prefer
# (v2 path stays in tree); the v3 slot path adds backend
# abstraction for consumers writing portable code.
fn _backend_wgpu_surface_configure(ctx, width, height): i64 {
    if (ctx == 0)         { return 0; }
    if (width <= 0)       { return 0; }
    if (height <= 0)      { return 0; }
    var wgpu_surface = gpu_ctx_wgpu_surface_handle(ctx);
    if (wgpu_surface == 0) { return 0; }   # consumer didn't pre-stash
    var device = gpu_ctx_device(ctx);
    if (device == 0)       { return 0; }
    return surface_state_new(wgpu_surface, device,
    WGPU_TEXTURE_FORMAT_RGBA8_UNORM,
    width, height, PRESENT_VSYNC);
}

# `surface_state_acquire` returns a Result<texture_handle>; the slot
# protocol returns the texture handle directly (or 0 on error) so
# the caller can pass it forward without unwrapping a Result.
fn _backend_wgpu_surface_acquire(ctx, surface): i64 {
    if (ctx == 0)     { return 0; }
    if (surface == 0) { return 0; }
    var res = surface_state_acquire(surface);
    if (is_err_result(res) == 1) { return 0; }
    return payload(res);
}

fn _backend_wgpu_surface_present(ctx, surface): i64 {
    if (ctx == 0)     { return GPU_ERR_OTHER; }
    if (surface == 0) { return GPU_ERR_OTHER; }
    return surface_state_submit_present(surface);
}

fn _backend_wgpu_surface_release(ctx, surface): i64 {
    if (ctx == 0)     { return 0; }
    if (surface == 0) { return 0; }
    return surface_state_release(surface);
}

# ================================================================
# Queue slot wrappers — v3.1 (Q.2)
# ================================================================
# WebGPU exposes a SINGLE device queue. The logical multi-queue
# abstraction therefore degrades on wgpu: all three logical queues
# (GRAPHICS / COMPUTE / TRANSFER) alias that one WGPUQueue, there is
# NO real cross-queue overlap, and ordering is the WebGPU submit-order
# guarantee rather than timeline syncobjs. Consumers that need genuine
# GFX/COMPUTE concurrency use the native AMD backend (Q.3). This is the
# documented wgpu limitation, mirroring how wgpu compute_dispatch is a
# stub today — see docs/proposals/v3.1-multiqueue.md § "wgpu backend".

# Acquire the logical queue for `kind`. Idempotent: caches one Queue
# per kind on the ctx and returns the cached pointer on re-get. The
# Queue's ring_handle carries the single WGPUQueue so queue_wait_idle
# can poll; timeline_syncobj stays 0 (wgpu has no timeline path here).
fn _backend_wgpu_queue_get(ctx, kind): i64 {
    if (ctx == 0) { return 0; }
    var cached = gpu_ctx_queue_slot(ctx, kind);
    if (cached != 0) { return cached; }
    var q = queue_new(kind);
    if (q == 0) { return 0; }
    queue_set_ring(q, gpu_ctx_queue(ctx));   # alias the one WGPUQueue
    gpu_ctx_set_queue_slot(ctx, kind, q);
    return q;
}

# Order dst_queue after src_queue. On the single WGPUQueue this is a
# documented no-op: work submitted before this call already orders
# before work submitted after (WebGPU queue-order guarantee), so no
# cross-ring fence is needed. The slot exists so portable consumer
# code can call gpu_queue_barrier unconditionally.
fn _backend_wgpu_queue_barrier(ctx, src_queue, dst_queue): i64 {
    if (ctx == 0)        { return GPU_ERR_OTHER; }
    if (src_queue == 0)  { return GPU_ERR_OTHER; }
    if (dst_queue == 0)  { return GPU_ERR_OTHER; }
    return 0;
}

# Block until work on `queue` retires. With one underlying queue this
# is the same device poll as device_wait_idle. (HW-gated: the poll is
# only exercised against a real wgpu device; CPU tests cover the
# null-guard paths.)
fn _backend_wgpu_queue_wait_idle(ctx, queue): i64 {
    if (ctx == 0)    { return GPU_ERR_OTHER; }
    if (queue == 0)  { return GPU_ERR_OTHER; }
    var device = gpu_ctx_device(ctx);
    wgpu_device_poll(device, 1);
    return 0;
}

# ================================================================
# Texture-compression capability detection (v3.2 T.4)
# ================================================================
# WGPUFeatureName_TextureCompression{BC,ETC2,ASTC} values from webgpu.h
# v29 (lines 645/647/648). gpu_caps_detect_texture_compression queries the
# adapter for each family and ORs the MABDA_TEXCOMP_* bits the consumer
# stores via gpu_caps_set_texture_compression. (HW path — needs a real
# adapter; the bit math is CPU-tested via gpu_caps_supports_format.)
var WGPU_FEATURE_TEXTURE_COMPRESSION_BC   = 0x4;
var WGPU_FEATURE_TEXTURE_COMPRESSION_ETC2 = 0x6;
var WGPU_FEATURE_TEXTURE_COMPRESSION_ASTC = 0x7;
# wgpu-native vendor features (wgpu.h). v3.2 F.8 corrected the F.2 premise: f64 does NOT
# require SpirvShaderPassthrough. wgpu-native exposes a real WGPUNativeFeature_ShaderF64
# (0x0003001D) and naga's SPIR-V frontend accepts f64 once it is enabled — HW-verified on
# Cezanne (see programs/f64_compute_e2e.cyr). So f64 SPIR-V rides the ordinary
# gpu_shader_module_create_spirv path; passthrough is a SEPARATE general raw-SPIR-V escape
# hatch (naga-bypass), kept for shaders naga cannot carry, and is unsupported on RADV/Cezanne.
var WGPU_NATIVE_FEATURE_SPIRV_SHADER_PASSTHROUGH = 0x00030017;
var WGPU_NATIVE_FEATURE_SHADER_F64               = 0x0003001D;

# v3.2 F.8a — is the raw-SPIR-V passthrough escape hatch available on this device? (Enabled at
# device creation, gated by the adapter; the launcher requests it where supported.) This is the
# gate for wgpu_device_create_shader_module_spirv_passthrough — NOT the f64 gate (see
# gpu_wgpu_shader_f64_supported). Device, not adapter (the gpu_timestamps_supported precedent).
fn gpu_wgpu_spirv_passthrough_supported(device): i64 {
    if (device == 0) { return 0; }
    return wgpu_device_has_feature(device, WGPU_NATIVE_FEATURE_SPIRV_SHADER_PASSTHROUGH);
}

# v3.2 F.8b — the AUTHORITATIVE wgpu f64 device signal: WGPUNativeFeature_ShaderF64 enabled
# (requested at device creation, gated by the adapter's Vulkan shaderFloat64). This is the
# real feature bit the F.2 design wrongly assumed did not exist — no SPIR-V probe needed.
fn gpu_wgpu_shader_f64_supported(device): i64 {
    if (device == 0) { return 0; }
    return wgpu_device_has_feature(device, WGPU_NATIVE_FEATURE_SHADER_F64);
}

# v3.2 F.8b — wgpu compute dispatch is a v3.0 stub (`_backend_wgpu_compute_dispatch`
# returns GPU_ERR_OTHER). f64 (like any compute) cannot run END-TO-END on wgpu until that
# lands, so `gpu_caps_wgpu_shader_f64` reports 0 regardless of the (real, HW-proven) f64
# module-create half. Flip to 1 only when wgpu compute dispatch is implemented.
var MABDA_WGPU_COMPUTE = 0;

# v3.2 F.8b — a minimal f64 compute SPIR-V module (`OpCapability Float64` + `OpTypeFloat 64`
# + an f64 `OpFMul`). programs/f64_compute_e2e.cyr feeds it to the ordinary
# gpu_shader_module_create_spirv path to HW-prove naga accepts f64 once ShaderF64 is enabled.
# Hand-authored in SPIR-V assembly, `spirv-as --target-env spv1.0`, `spirv-val`-clean — 55
# words (the provenance oracle, the wgpu sibling of the GFX9 llvm-mc oracle). Disassembly:
#   OpCapability Shader / OpCapability Float64 / OpMemoryModel Logical GLSL450
#   OpEntryPoint GLCompute %1 "main" / OpExecutionMode %1 LocalSize 1 1 1
#   %2=OpTypeVoid %3=OpTypeFunction %2 %4=OpTypeFloat 64 %5=OpConstant %4 2 %6=OpConstant %4 3
#   %1=OpFunction / %7=OpLabel / %8=OpFMul %4 %5 %6 / OpReturn / OpFunctionEnd
# Writes 220 bytes (55 u32 words) at `buf`; returns the byte length.
fn _wgpu_f64_probe_spirv(buf): i64 {
    store32(buf + 0, 0x07230203);
    store32(buf + 4, 0x00010000);
    store32(buf + 8, 0x00070000);
    store32(buf + 12, 0x00000009);
    store32(buf + 16, 0x00000000);
    store32(buf + 20, 0x00020011);
    store32(buf + 24, 0x00000001);
    store32(buf + 28, 0x00020011);
    store32(buf + 32, 0x0000000A);
    store32(buf + 36, 0x0003000E);
    store32(buf + 40, 0x00000000);
    store32(buf + 44, 0x00000001);
    store32(buf + 48, 0x0005000F);
    store32(buf + 52, 0x00000005);
    store32(buf + 56, 0x00000001);
    store32(buf + 60, 0x6E69616D);
    store32(buf + 64, 0x00000000);
    store32(buf + 68, 0x00060010);
    store32(buf + 72, 0x00000001);
    store32(buf + 76, 0x00000011);
    store32(buf + 80, 0x00000001);
    store32(buf + 84, 0x00000001);
    store32(buf + 88, 0x00000001);
    store32(buf + 92, 0x00020013);
    store32(buf + 96, 0x00000002);
    store32(buf + 100, 0x00030021);
    store32(buf + 104, 0x00000003);
    store32(buf + 108, 0x00000002);
    store32(buf + 112, 0x00030016);
    store32(buf + 116, 0x00000004);
    store32(buf + 120, 0x00000040);
    store32(buf + 124, 0x0005002B);
    store32(buf + 128, 0x00000004);
    store32(buf + 132, 0x00000005);
    store32(buf + 136, 0x00000000);
    store32(buf + 140, 0x40000000);
    store32(buf + 144, 0x0005002B);
    store32(buf + 148, 0x00000004);
    store32(buf + 152, 0x00000006);
    store32(buf + 156, 0x00000000);
    store32(buf + 160, 0x40080000);
    store32(buf + 164, 0x00050036);
    store32(buf + 168, 0x00000002);
    store32(buf + 172, 0x00000001);
    store32(buf + 176, 0x00000000);
    store32(buf + 180, 0x00000003);
    store32(buf + 184, 0x000200F8);
    store32(buf + 188, 0x00000007);
    store32(buf + 192, 0x00050085);
    store32(buf + 196, 0x00000004);
    store32(buf + 200, 0x00000008);
    store32(buf + 204, 0x00000005);
    store32(buf + 208, 0x00000006);
    store32(buf + 212, 0x000100FD);
    store32(buf + 216, 0x00010038);
    return 220;
}

# v3.2 F.8b — the honest wgpu f64 capability (the consumer's end-to-end gate). wgpu f64 needs
# BOTH halves: (1) the device's f64 support — WGPUNativeFeature_ShaderF64 enabled, with which an
# f64 SPIR-V module creates through the ordinary gpu_shader_module_create_spirv path; REAL and
# HW-proven on Cezanne by programs/f64_compute_e2e.cyr. (2) wgpu compute *dispatch* to actually
# run the kernel — a v3.0 stub (`_backend_wgpu_compute_dispatch` → GPU_ERR_OTHER). Per the
# Phase F contract (never report 1 on a path that can't run f64 end-to-end — no silent f32
# fallback; the M.6b mipmap-generate posture), this returns 0 while MABDA_WGPU_COMPUTE == 0.
# Flipping MABDA_WGPU_COMPUTE when dispatch lands makes the gate the ShaderF64 device bit.
fn gpu_caps_wgpu_shader_f64(device): i64 {
    if (device == 0) { return 0; }
    if (MABDA_WGPU_COMPUTE == 0) { return 0; }
    return gpu_wgpu_shader_f64_supported(device);
}

fn gpu_caps_detect_texture_compression(adapter): i64 {
    if (adapter == 0) { return 0; }
    var mask = 0;
    if (wgpu_adapter_has_feature(adapter, WGPU_FEATURE_TEXTURE_COMPRESSION_BC) != 0) {
        mask = mask | MABDA_TEXCOMP_BC;
    }
    if (wgpu_adapter_has_feature(adapter, WGPU_FEATURE_TEXTURE_COMPRESSION_ETC2) != 0) {
        mask = mask | MABDA_TEXCOMP_ETC2;
    }
    if (wgpu_adapter_has_feature(adapter, WGPU_FEATURE_TEXTURE_COMPRESSION_ASTC) != 0) {
        mask = mask | MABDA_TEXCOMP_ASTC;
    }
    return mask;
}

# ================================================================
# Builder
# ================================================================
# Allocates a Backend, fills all 21 fnptr slots with the wrapper
# functions above, and sets kind = BACKEND_KIND_WGPU. Caller owns
# the returned pointer; pair with backend release once that exists
# (none required today — the bump allocator reclaims at process
# end; persistent allocators are a Step 4 / Phase B.4 follow-up (see docs/development/roadmap.md)).

fn backend_wgpu_new(): i64 {
    var b = backend_new();
    backend_set_slot(b, BACKEND_SLOT_CTX_CREATE_FROM_PREINIT,
    &_backend_wgpu_ctx_create_from_preinit);
    backend_set_slot(b, BACKEND_SLOT_CTX_RELEASE,
    &_backend_wgpu_ctx_release);
    backend_set_slot(b, BACKEND_SLOT_BUFFER_CREATE,
    &_backend_wgpu_buffer_create);
    backend_set_slot(b, BACKEND_SLOT_BUFFER_WRITE,
    &_backend_wgpu_buffer_write);
    backend_set_slot(b, BACKEND_SLOT_BUFFER_READ,
    &_backend_wgpu_buffer_read);
    backend_set_slot(b, BACKEND_SLOT_BUFFER_RELEASE,
    &_backend_wgpu_buffer_release);
    backend_set_slot(b, BACKEND_SLOT_SHADER_MODULE_CREATE,
    &_backend_wgpu_shader_module_create);
    backend_set_slot(b, BACKEND_SLOT_SHADER_MODULE_RELEASE,
    &_backend_wgpu_shader_module_release);
    backend_set_slot(b, BACKEND_SLOT_COMPUTE_DISPATCH,
    &_backend_wgpu_compute_dispatch);
    backend_set_slot(b, BACKEND_SLOT_DEVICE_WAIT_IDLE,
    &_backend_wgpu_device_wait_idle);
    backend_set_slot(b, BACKEND_SLOT_TEXTURE_CREATE_2D_RGBA8,
    &_backend_wgpu_texture_create_2d_rgba8);
    # v3.2 T.6 — format-parameterized create. The backend_is_complete walk
    # over the texfmt range activates in T.7 once backend_native_new fills
    # it too (the M.6b "activate when both fill" pattern).
    backend_set_slot(b, BACKEND_SLOT_TEXTURE_CREATE_2D_FMT,
    &_backend_wgpu_texture_create_2d_fmt);
    backend_set_slot(b, BACKEND_SLOT_TEXTURE_CREATE_2D_RGBA8_MIPPED,
    &_backend_wgpu_texture_create_2d_rgba8_mipped);
    backend_set_slot(b, BACKEND_SLOT_TEXTURE_GENERATE_MIPMAPS,
    &_backend_wgpu_texture_generate_mipmaps);
    backend_set_slot(b, BACKEND_SLOT_TEXTURE_WRITE,
    &_backend_wgpu_texture_write);
    backend_set_slot(b, BACKEND_SLOT_TEXTURE_READ,
    &_backend_wgpu_texture_read);
    backend_set_slot(b, BACKEND_SLOT_TEXTURE_RELEASE,
    &_backend_wgpu_texture_release);
    backend_set_slot(b, BACKEND_SLOT_RENDER_TARGET_CREATE_2D_RGBA8,
    &_backend_wgpu_render_target_create_2d_rgba8);
    backend_set_slot(b, BACKEND_SLOT_RENDER_TARGET_RELEASE,
    &_backend_wgpu_render_target_release);
    backend_set_slot(b, BACKEND_SLOT_RENDER_PIPELINE_CREATE,
    &_backend_wgpu_render_pipeline_create);
    backend_set_slot(b, BACKEND_SLOT_RENDER_PIPELINE_RELEASE,
    &_backend_wgpu_render_pipeline_release);
    backend_set_slot(b, BACKEND_SLOT_RENDER_PASS_BEGIN,
    &_backend_wgpu_render_pass_begin);
    backend_set_slot(b, BACKEND_SLOT_RENDER_PASS_DRAW,
    &_backend_wgpu_render_pass_draw);
    backend_set_slot(b, BACKEND_SLOT_RENDER_PASS_END,
    &_backend_wgpu_render_pass_end);
    # v3 surface slots (Step 7.6 stubs; 7.7 fills with real impls).
    backend_set_slot(b, BACKEND_SLOT_SURFACE_CONFIGURE,
    &_backend_wgpu_surface_configure);
    backend_set_slot(b, BACKEND_SLOT_SURFACE_ACQUIRE,
    &_backend_wgpu_surface_acquire);
    backend_set_slot(b, BACKEND_SLOT_SURFACE_PRESENT,
    &_backend_wgpu_surface_present);
    backend_set_slot(b, BACKEND_SLOT_SURFACE_RELEASE,
    &_backend_wgpu_surface_release);
    # v3.1 queue slots (Q.2) — logical queues alias the single
    # WGPUQueue; barrier is a submit-order no-op, wait_idle a device
    # poll. The backend_is_complete walk over this range activates in
    # Q.3 once backend_native_new fills it too (matches the M.6b
    # "activate when both backends fill" pattern).
    backend_set_slot(b, BACKEND_SLOT_QUEUE_GET,
    &_backend_wgpu_queue_get);
    backend_set_slot(b, BACKEND_SLOT_QUEUE_BARRIER,
    &_backend_wgpu_queue_barrier);
    backend_set_slot(b, BACKEND_SLOT_QUEUE_WAIT_IDLE,
    &_backend_wgpu_queue_wait_idle);
    # v3.2 X.6 — buffer-copy (copy_buffer_to_buffer). Both backends now
    # fill the buffer_copy slot (native X.5), so the backend_is_complete
    # walk over the range activates this step ("activate when both fill").
    backend_set_slot(b, BACKEND_SLOT_BUFFER_COPY,
    &_backend_wgpu_buffer_copy);
    # v3.2 TS.5 — sampleable-texture slots. Both backends fill these now
    # (native TS.5a), so the backend_is_complete walk over 264..280 activates.
    backend_set_slot(b, BACKEND_SLOT_TEXTURE_CREATE_2D_SAMPLEABLE,
    &_backend_wgpu_texture_create_2d_sampleable);
    backend_set_slot(b, BACKEND_SLOT_TEXTURE_BIND_FOR_SAMPLE,
    &_backend_wgpu_texture_bind_for_sample);
    backend_set_kind(b, BACKEND_KIND_WGPU);
    return b;
}

# --- context.cyr ---

# @public — stable API surface (survives the v3.0 backend swap)
# context.cyr — GPU device lifecycle
# Ported from mabda/src/context.rs
#
# GpuContext struct layout (168 bytes — grew 48 → 96 at v3 Step
# 4f.iv, 96 → 112 at v3 Step 7.7 for the surface API consumer-
# stash slots, 112 → 120 at v3 rc.2 audit MED-7 to cache the per-
# dispatch PM4 scratch buffer, → 128 (tex VA cursor, v3.1 M.1), →
# 160 (queue table, v3.1 Q.1), → 168 (IB-slot cursor, v3.2.14 R.5)):
#   +0:  instance / fd          (wgpu: WGPUInstance | native: DRM fd)
#   +8:  adapter  / ctx_id      (wgpu: WGPUAdapter  | native: amdgpu ctx id)
#   +16: device   / stub_handle (wgpu: WGPUDevice   | native: stub BO handle)
#   +24: queue    / stub_va     (wgpu: WGPUQueue    | native: stub BO VA)
#   +32: backend  (Backend*, 8) — @internal dispatch table
#   +40: stub_addr  (8)         — native: stub BO CPU mmap; zero on wgpu
#   +48: ib_handle  (8)         — native: per-context IB BO handle (Step 4f.iv)
#   +56: ib_va      (8)         — native: IB BO GPU VA
#   +64: ib_addr    (8)         — native: IB BO CPU mmap (memcpy PM4 here)
#   +72: fence_handle (8)       — native: per-context fence BO handle
#   +80: fence_va   (8)         — native: fence BO GPU VA
#   +88: fence_addr (8)         — native: fence BO CPU mmap (pre-zero seqno slot)
#   +96: wgpu_surface_handle (8) — wgpu: WGPUSurface; set by
#                                  gpu_surface_configure_wgpu before the
#                                  slot reads it. Zero on native.
#   +104: native_card_fd (8)    — native: DRM master card fd; set by
#                                  gpu_surface_configure_native_kiosk.
#                                  Zero on wgpu.
#   +112: pm4_scratch (8)       — native: 1024-byte PM4 build buffer,
#                                  allocated once at gpu_context_new_native,
#                                  reused (memset on each entry) by
#                                  _backend_native_compute_dispatch and
#                                  _backend_native_render_pass_draw. Audit
#                                  MED-7: replaces per-dispatch alloc(256)
#                                  / alloc(1024) which leaked through the
#                                  bump allocator. Zero on wgpu (the wgpu
#                                  slots never read it). Lifetime contract:
#                                  shared across compute + render slots,
#                                  reset on each dispatch entry, NEVER
#                                  reclaimed — Cyrius single-threaded
#                                  execution model means a slot fn is the
#                                  sole writer for the duration of its
#                                  call.
#   +120: tex_va_next (8)       — native: bump cursor for the per-context
#                                  texture VA sub-allocator (v3.1 M.1(c)).
#                                  Zero-initialized by the ctx memset;
#                                  native_ctx_alloc_texture_va lazy-inits
#                                  it to _NATIVE_TEXTURE_VA_BASE on first
#                                  use and hands out aligned VA ranges.
#                                  Zero on wgpu.
#   +128: queue_graphics (8)    — Queue* for QUEUE_KIND_GRAPHICS, lazily
#                                  populated by the backend's queue_get
#                                  slot (v3.1 Q.1). Zero until first get.
#   +136: queue_compute  (8)    — Queue* for QUEUE_KIND_COMPUTE.
#   +144: queue_transfer (8)    — Queue* for QUEUE_KIND_TRANSFER.
#   +152: queue_current  (8)    — Queue* the next queue-targeted dispatch
#                                  submits onto ("current queue" stash,
#                                  read in Q.3). Zero = backend default
#                                  ring. The queue table is deliberately
#                                  OUTSIDE the +0..+24 dual-interpretation
#                                  region — it is backend-agnostic state.
#   +160: ib_slot_cursor (8)    — native: round-robin index of the active
#                                  IB staging slice (v3.2.14 R.5). Zero-
#                                  initialized by the ctx memset; the MQ
#                                  render-graph executor advances it per
#                                  node so concurrently-in-flight submits
#                                  stage into distinct IB slices. Zero on
#                                  wgpu / single-shot native paths.
#
# The dual interpretation of +0..+24 is documented in
# src/backend_native.cyr; backend_kind(gpu_ctx_backend(ctx)) tells
# you which view applies. Native-side accessors live in
# src/backend_native.cyr (native_ctx_fd / _id / _stub_handle /
# _stub_va). The +32 backend ptr is always a Backend struct.
#
# +96 / +104 are the consumer-stash fields the v3.0 surface API
# uses to pass backend-specific resources into the
# `surface_configure(ctx, w, h)` slot whose signature can't
# carry them directly (see docs/proposals/v3-surface-api-design.md
# § "Why 'stash on ctx' rather than passing through every slot").

var GPU_CONTEXT_SIZE = 168;
var _NATIVE_PM4_SCRATCH_BYTES = 2048;   # v3.2 TS.5: 1024->2048 (the textured
# render draw appends ~15 override dwords past the 256-dword/1024-B minimum
# pad, reaching ~261 dwords; 2048 keeps comfortable headroom).

fn gpu_ctx_instance(ctx): i64 { return load64(ctx); }
fn gpu_ctx_adapter(ctx): i64 { return load64(ctx + 8); }
fn gpu_ctx_device(ctx): i64 { return load64(ctx + 16); }
fn gpu_ctx_queue(ctx): i64 { return load64(ctx + 24); }
fn gpu_ctx_backend(ctx): i64 { return load64(ctx + 32); }

# v3 Step 7.7 — surface API consumer-stash accessors. Set by the
# backend-specific `gpu_surface_configure_*` public fns; read by
# the matching `_backend_*_surface_configure` slot impls.
fn gpu_ctx_wgpu_surface_handle(ctx): i64 { return load64(ctx + 96); }
fn gpu_ctx_native_card_fd(ctx): i64 { return load64(ctx + 104); }
fn gpu_ctx_set_wgpu_surface_handle(ctx, h): i64 {
    if (ctx == 0) { return -1; }
    store64(ctx + 96, h);
    return 0;
}
fn gpu_ctx_set_native_card_fd(ctx, fd): i64 {
    if (ctx == 0) { return -1; }
    store64(ctx + 104, fd);
    return 0;
}

# Create from pre-initialized handles (C launcher fills these).
# Failure paths route through gpu_err_result, which already emits a
# sakshi event when observability is enabled. The success path emits
# its own info-level event for the trace consumer (v2.4.1).
#
# Step 4e: branches on MABDA_BACKEND_KIND (set in src/lib.cyr).
# Default = BACKEND_KIND_WGPU (v2.x behaviour preserved). Setting
# the constant to BACKEND_KIND_AMD makes this fn route to
# gpu_context_new_native() — preinit_ptr is ignored on that path
# (the C launcher's preinit struct is wgpu-shaped). Programs that
# want to opt into the native path explicitly without touching the
# global default can call gpu_context_new_native() directly.
fn gpu_context_from_preinit(preinit_ptr): i64 {
    if (MABDA_BACKEND_KIND == BACKEND_KIND_AMD) {
        return gpu_context_new_native();
    }
    if (preinit_ptr == 0) { return gpu_err_result(GPU_ERR_ADAPTER_NOT_FOUND); }
    var instance = load64(preinit_ptr);
    var adapter  = load64(preinit_ptr + 8);
    var device   = load64(preinit_ptr + 16);
    var queue    = load64(preinit_ptr + 24);
    if (instance == 0) { return gpu_err_result(GPU_ERR_ADAPTER_NOT_FOUND); }
    if (adapter == 0)  { return gpu_err_result(GPU_ERR_ADAPTER_NOT_FOUND); }
    if (device == 0)   { return gpu_err_result(GPU_ERR_DEVICE_REQUEST); }
    var ctx = alloc(GPU_CONTEXT_SIZE);
    memset(ctx, 0, GPU_CONTEXT_SIZE);
    store64(ctx,      instance);
    store64(ctx + 8,  adapter);
    store64(ctx + 16, device);
    store64(ctx + 24, queue);
    store64(ctx + 32, backend_wgpu_new());
    _sk_info_cstr("mabda: gpu context created");
    return gpu_ok(ctx);
}

# Bring up a native (AMD/amdgpu) GpuContext. Opens /dev/dri/renderD128,
# allocates an amdgpu context id, creates and va-maps a 4 KiB stub BO
# at the canonical-high stub VA (Mesa scratch V# reference point), and
# attaches a backend_native_new() at the backend slot. Returns
# Result<ctx>.
#
# Stub BO note: the stub is owned by the GpuContext but its mmap
# address is not stored. On gpu_context_release, _backend_native_ctx_release
# closes the fd, which kicks the kernel into auto-releasing the BO.
# This is acceptable for v3.0 (process-lifetime contexts); revisit if
# long-lived create/destroy cycles ever surface.
var _NATIVE_STUB_VA   = 0xFFFF800100004000;
var _NATIVE_STUB_SIZE = 4096;

# Per-context cached IB + fence (Step 4f.iv). Allocated once in
# gpu_context_new_native, reused across every dispatch through
# native_compute_dispatch_simple. Released in
# _backend_native_ctx_release. Avoids ~7 syscalls of BO churn per
# dispatch (alloc/va_map/munmap/va_unmap/close × 2 BOs + syncobj).
var _NATIVE_IB_VA     = 0xFFFF800100200000;
var _NATIVE_IB_SIZE   = 4096;
# v3.2.14 R.5 — per-node IB staging. The cached IB BO is partitioned into
# _NATIVE_IB_SLOTS contiguous 4 KiB slices (one per concurrently-in-flight
# queue-targeted submit) so genuine cross-ring overlap can't clobber a
# sibling's PM4 mid-flight. The whole BO is _NATIVE_IB_SIZE * _NATIVE_IB_SLOTS
# bytes mapped at _NATIVE_IB_VA; slice i lives at base + i*_NATIVE_IB_SIZE.
# 16 slices = 64 KiB, well inside the 4 MiB IB→FENCE VA gap (no collision).
# The cursor (ctx +160) selects the active slice; the MQ executor (R.6)
# advances it per node. Single-shot / synchronous paths stay on slice 0.
var _NATIVE_IB_SLOTS  = 16;
var _NATIVE_FENCE_VA  = 0xFFFF800100600000;
var _NATIVE_FENCE_SIZE = 4096;

fn gpu_context_new_native(): i64 {
    var fd = native_open_render_node();
    if (fd < 0) {
        return gpu_err_result(_native_neg_rc_to_gpu_err(fd));
    }

    var ctx_req[16];
    var rc = native_ctx_alloc(fd, &ctx_req);
    if (rc != 0) {
        var rc_save = rc;
        sys_close(fd);
        return gpu_err_result(_native_neg_rc_to_gpu_err(rc_save));
    }
    var ctx_id = native_ctx_alloc_id(&ctx_req);

    var stub_bo[16];
    rc = native_bo_create_gtt(fd, _NATIVE_STUB_SIZE, &stub_bo);
    if (rc != 0) {
        var rc_save = rc;
        native_ctx_free(fd, ctx_id);
        sys_close(fd);
        return gpu_err_result(_native_neg_rc_to_gpu_err(rc_save));
    }
    var stub_handle = load64(&stub_bo + 0);
    var stub_map    = load64(&stub_bo + 8);
    memset(stub_map, 0, _NATIVE_STUB_SIZE);

    rc = native_gem_va_map(fd, stub_handle, _NATIVE_STUB_VA,
    _NATIVE_STUB_SIZE, _NATIVE_PERM_DATA);
    if (rc != 0) {
        var rc_save = rc;
        native_bo_release_gtt(fd, stub_handle, stub_map, _NATIVE_STUB_SIZE);
        native_ctx_free(fd, ctx_id);
        sys_close(fd);
        return gpu_err_result(_native_neg_rc_to_gpu_err(rc_save));
    }

    # Step 4f.iv: allocate the per-context IB + fence BOs once
    # (cached for reuse across dispatches).
    # R.5: the IB BO spans _NATIVE_IB_SLOTS contiguous 4 KiB slices.
    var ib_total = _NATIVE_IB_SIZE * _NATIVE_IB_SLOTS;
    var ib_bo[16];
    rc = native_bo_create_gtt(fd, ib_total, &ib_bo);
    if (rc != 0) {
        var rc_save = rc;
        native_bo_release_gtt(fd, stub_handle, stub_map, _NATIVE_STUB_SIZE);
        native_ctx_free(fd, ctx_id);
        sys_close(fd);
        return gpu_err_result(_native_neg_rc_to_gpu_err(rc_save));
    }
    var ib_handle = load64(&ib_bo + 0);
    var ib_map    = load64(&ib_bo + 8);
    rc = native_gem_va_map(fd, ib_handle, _NATIVE_IB_VA,
    ib_total, _NATIVE_PERM_IB);
    if (rc != 0) {
        var rc_save = rc;
        native_bo_release_gtt(fd, ib_handle, ib_map, ib_total);
        native_bo_release_gtt(fd, stub_handle, stub_map, _NATIVE_STUB_SIZE);
        native_ctx_free(fd, ctx_id);
        sys_close(fd);
        return gpu_err_result(_native_neg_rc_to_gpu_err(rc_save));
    }

    var fence_bo[16];
    rc = native_bo_create_gtt(fd, _NATIVE_FENCE_SIZE, &fence_bo);
    if (rc != 0) {
        var rc_save = rc;
        native_gem_va_unmap(fd, ib_handle, _NATIVE_IB_VA, ib_total);
        native_bo_release_gtt(fd, ib_handle, ib_map, ib_total);
        native_bo_release_gtt(fd, stub_handle, stub_map, _NATIVE_STUB_SIZE);
        native_ctx_free(fd, ctx_id);
        sys_close(fd);
        return gpu_err_result(_native_neg_rc_to_gpu_err(rc_save));
    }
    var fence_handle = load64(&fence_bo + 0);
    var fence_map    = load64(&fence_bo + 8);
    memset(fence_map, 0, _NATIVE_FENCE_SIZE);
    rc = native_gem_va_map(fd, fence_handle, _NATIVE_FENCE_VA,
    _NATIVE_FENCE_SIZE, _NATIVE_PERM_DATA);
    if (rc != 0) {
        var rc_save = rc;
        native_bo_release_gtt(fd, fence_handle, fence_map, _NATIVE_FENCE_SIZE);
        native_gem_va_unmap(fd, ib_handle, _NATIVE_IB_VA, ib_total);
        native_bo_release_gtt(fd, ib_handle, ib_map, ib_total);
        native_bo_release_gtt(fd, stub_handle, stub_map, _NATIVE_STUB_SIZE);
        native_ctx_free(fd, ctx_id);
        sys_close(fd);
        return gpu_err_result(_native_neg_rc_to_gpu_err(rc_save));
    }

    # Audit MED-7: per-context cached PM4 scratch buffer. 1024 bytes
    # is the worst-case render-stream size (`_backend_native_render_pass_draw`
    # builds up to a 256-dword pad target = 1024 B); compute dispatch
    # uses the first 256 bytes. Allocated once here, reused on every
    # dispatch — replaces the per-dispatch alloc(256)/alloc(1024)
    # that previously leaked through the bump allocator.
    var pm4_scratch = alloc(_NATIVE_PM4_SCRATCH_BYTES);
    memset(pm4_scratch, 0, _NATIVE_PM4_SCRATCH_BYTES);

    var ctx = alloc(GPU_CONTEXT_SIZE);
    memset(ctx, 0, GPU_CONTEXT_SIZE);
    store64(ctx +   0, fd);
    store64(ctx +   8, ctx_id);
    store64(ctx +  16, stub_handle);
    store64(ctx +  24, _NATIVE_STUB_VA);
    store64(ctx +  32, backend_native_new());
    store64(ctx +  40, stub_map);
    store64(ctx +  48, ib_handle);
    store64(ctx +  56, _NATIVE_IB_VA);
    store64(ctx +  64, ib_map);
    store64(ctx +  72, fence_handle);
    store64(ctx +  80, _NATIVE_FENCE_VA);
    store64(ctx +  88, fence_map);
    store64(ctx + 112, pm4_scratch);
    _sk_info_cstr("mabda: gpu context created (native)");
    return gpu_ok(ctx);
}

# Step 3b: dispatches through ctx->backend->ctx_release. The slot
# wrapper in src/backend_wgpu.cyr does the wgpu_*_release calls;
# the native counterpart in src/backend_native.cyr frees ctx_id and
# closes the DRM fd (which kicks the kernel into auto-releasing the
# stub BO). Public callers see the same behaviour as v2.x, but the
# per-backend release path is now under the abstraction.
fn gpu_context_release(ctx): i64 {
    if (ctx == 0) { return 0; }
    var slot = backend_get_slot(gpu_ctx_backend(ctx), BACKEND_SLOT_CTX_RELEASE);
    fncall1(slot, ctx);
    _sk_info_cstr("mabda: gpu context released");
    return 0;
}

# Block until all submitted GPU work has completed. Returns 0.
# Step 3f: dispatches through ctx->backend->device_wait_idle.
# On wgpu the slot wrapper calls wgpu_device_poll(device, wait=1).
fn gpu_device_wait_idle(ctx): i64 {
    if (ctx == 0) { return 0; }
    var slot = backend_get_slot(gpu_ctx_backend(ctx),
    BACKEND_SLOT_DEVICE_WAIT_IDLE);
    return fncall1(slot, ctx);
}

# --- backend_native_amdgpu.cyr ---

# @internal — native GPU backend, AMDGPU/DRM ioctl wrappers
# backend_native_amdgpu.cyr — pure-Cyrius DRM/AMDGPU foundational layer
#
# Split out from backend_native.cyr at v3 rc.2 (audit toolchain item)
# to keep each file under cyrius lint/fmt's 128 KiB read-buffer cap.
# This file owns the syscall-level foundation:
#   - DRM ioctl encoding helpers + render-node open
#   - GEM/BO lifecycle (create_gtt, create_vram, mmap_offset, close, release)
#   - AMDGPU ctx + bo_list + va_map ioctls
#   - DRM syncobj (create, destroy, wait)
#   - DRM CS submit (3 variants: bo_list-by-handle, inline-bos, 4chunk-Mesa-shape)
#
# PM4 byte builders live in backend_native_pm4.cyr; GFX9 ISA shaders
# + register addresses live in backend_native_shaders.cyr; the slot
# fillers + dispatch fns + texture/RT/pipeline primitives live in
# backend_native.cyr (which depends on this file).
#
# All data types are i64 / u64 unless noted. drm_version struct layout
# mirrors include/uapi/drm/drm.h on x86_64 Linux. No libdrm — direct
# syscall(SYS_IOCTL) only.

# ================================================================
# Constants
# ================================================================
# DRM ioctl encoding mirrors include/uapi/asm-generic/ioctl.h:
#   _IOC(dir, type, nr, size) = (dir << 30) | (size << 16) | (type << 8) | nr
# Size field is 14 bits, type 8, nr 8, dir 2.
var _IOC_NONE  = 0;
var _IOC_WRITE = 1;
var _IOC_READ  = 2;
var _IOC_RW    = 3;

# DRM: type 'd' = 0x64
var DRM_IOCTL_TYPE = 0x64;

# drm_version: nr 0x00, RW, sizeof(struct drm_version) == 64 on x86_64
#   0x64 | (3 << 30) | (64 << 16) | (0x64 << 8) | 0x00 == 0xC0406400
var DRM_VERSION_SIZE = 64;
var DRM_IOCTL_VERSION = 0xC0406400;

# drm_version struct (64 bytes on x86_64):
#   +0:  version_major      (i32)
#   +4:  version_minor      (i32)
#   +8:  version_patchlevel (i32)
#   +12: pad (4)
#   +16: name_len  (u64)  — in: buffer capacity; out: required length
#   +24: name_ptr  (u64)  — caller-allocated char buffer
#   +32: date_len  (u64)
#   +40: date_ptr  (u64)
#   +48: desc_len  (u64)
#   +56: desc_ptr  (u64)

# Render node path. renderD128 is the first unprivileged render-only
# node; renderD129+ exist on multi-GPU systems.
var DRM_RENDER_NODE_PATH = "/dev/dri/renderD128";

# ================================================================
# Errno → GpuErr mapping (v3 Step 4f.i)
# ================================================================
# Native primitives return 0 on success or negative errno on
# failure (Linux ABI convention). Slot wrappers and public
# dispatchers want positive GPU_ERR_* codes from src/error.cyr.
# Until v3.0 ships, we keep the existing GpuErrCode enum stable
# and route specific errno values to the closest existing code:
#
#   ENOMEM  (12)      → GPU_ERR_BUFFER          (BO alloc OOM)
#   EPERM   (1)       → GPU_ERR_ADAPTER_NOT_FOUND (no DRM access)
#   EACCES  (13)      → GPU_ERR_ADAPTER_NOT_FOUND (no DRM access)
#   ENOENT  (2)       → GPU_ERR_ADAPTER_NOT_FOUND (no render node)
#   EBUSY   (16)      → GPU_ERR_DEVICE_REQUEST   (device contention)
#   ETIMEDOUT (110)   → GPU_ERR_SURFACE_TIMEOUT  (syncobj wait)
#   ETIME   (62)      → GPU_ERR_SURFACE_TIMEOUT  (syncobj wait alt)
#   default           → GPU_ERR_OTHER
#
# Adding a new GPU_ERR_* code (e.g. INVALID_ARG, FENCE_TIMEOUT) is
# a v3.0+1 follow-up (see docs/development/roadmap.md) — error.cyr enum
# is part of the @public surface and should not churn during v3.0 stabilisation.

var _NATIVE_ERRNO_EPERM     =   1;
var _NATIVE_ERRNO_ENOENT    =   2;
var _NATIVE_ERRNO_ENOMEM    =  12;
var _NATIVE_ERRNO_EACCES    =  13;
var _NATIVE_ERRNO_EBUSY     =  16;
var _NATIVE_ERRNO_ETIME     =  62;
var _NATIVE_ERRNO_ETIMEDOUT = 110;

# Map a positive errno to a GPU_ERR_* code. Caller passes the
# absolute value (i.e. converted from negative-rc convention by
# _native_neg_rc_to_gpu_err below).
fn _native_errno_to_gpu_err(errno): i64 {
    if (errno == _NATIVE_ERRNO_ENOMEM)    { return GPU_ERR_BUFFER; }
    if (errno == _NATIVE_ERRNO_EPERM)     { return GPU_ERR_ADAPTER_NOT_FOUND; }
    if (errno == _NATIVE_ERRNO_EACCES)    { return GPU_ERR_ADAPTER_NOT_FOUND; }
    if (errno == _NATIVE_ERRNO_ENOENT)    { return GPU_ERR_ADAPTER_NOT_FOUND; }
    if (errno == _NATIVE_ERRNO_EBUSY)     { return GPU_ERR_DEVICE_REQUEST; }
    if (errno == _NATIVE_ERRNO_ETIMEDOUT) { return GPU_ERR_SURFACE_TIMEOUT; }
    if (errno == _NATIVE_ERRNO_ETIME)     { return GPU_ERR_SURFACE_TIMEOUT; }
    return GPU_ERR_OTHER;
}

# Map a negative-errno return code (rc <= 0 convention used by
# native_* primitives) to 0 (success) or GPU_ERR_*. Pass the rc
# directly; this fn handles the sign flip + mapping.
fn _native_neg_rc_to_gpu_err(rc): i64 {
    if (rc == 0) { return 0; }
    if (rc > 0)  { return _native_errno_to_gpu_err(rc); }
    return _native_errno_to_gpu_err(0 - rc);
}

# ================================================================
# Helpers
# ================================================================

# Encode an ioctl number. Public to make the encoding testable.
# dir ∈ {0=NONE, 1=WRITE, 2=READ, 3=RW}
# size must fit in 14 bits (masked to 0x3FFF)
# type, nr are byte-sized (masked to 0xFF)
fn native_ioc_encode(dir, size, type, nr): i64 {
    var d = dir & 3;
    var s = size & 0x3FFF;
    var t = type & 0xFF;
    var n = nr & 0xFF;
    return (d * 0x40000000) | (s * 0x10000) | (t * 0x100) | n;
}

# Open /dev/dri/renderD128 for read/write. Returns fd on success or
# the negative errno on failure (Linux syscall convention). No auth
# needed — render nodes bypass the DRM master/auth dance.
fn native_open_render_node(): i64 {
    return sys_open(DRM_RENDER_NODE_PATH, O_RDWR, 0);
}

# Issue DRM_IOCTL_VERSION in two passes against the given fd. First
# pass collects version_major/minor/patchlevel + required name_len.
# Second pass writes the driver-name string into a heap-allocated
# buffer whose address is stored in the caller's struct.
#
# `ver` points to a 64-byte caller-allocated region, zeroed by the
# caller. On success:
#   ver + 0..12  = version triple (major, minor, patchlevel)
#   ver + 16     = name_len (actual bytes written)
#   ver + 24     = pointer to heap name buffer (NUL-terminated string
#                  of length name_len; caller does not free — alloc()
#                  memory is process-lifetime in mabda today)
# Returns 0 on success, negative errno on ioctl failure.
fn native_drm_version(fd, ver): i64 {
    # Zero the struct — caller is expected to have done this, but be
    # defensive since we're about to issue a kernel ioctl.
    memset(ver, 0, 64);

    # Pass 1: lengths only. All _ptr fields stay 0 so kernel skips
    # string writes but still reports required lengths.
    var rc = syscall(SYS_IOCTL, fd, DRM_IOCTL_VERSION, ver);
    if (rc != 0) { return rc; }

    var name_len = load64(ver + 16);
    if (name_len == 0) { return 0; }

    # Pass 2: allocate a buffer, point name_ptr at it, re-issue.
    # +1 for a defensive NUL terminator beyond the kernel's writeback.
    var name_buf = alloc(name_len + 1);
    memset(name_buf, 0, name_len + 1);
    store64(ver + 16, name_len);  # capacity
    store64(ver + 24, name_buf);

    rc = syscall(SYS_IOCTL, fd, DRM_IOCTL_VERSION, ver);
    if (rc != 0) { return rc; }
    return 0;
}

# Convenience: full probe. Opens the render node, reads version,
# closes fd. Fills `out` (64 bytes) with the drm_version struct.
# Returns 0 on success, non-zero on failure (open or ioctl).
fn native_probe_device(out): i64 {
    var fd = native_open_render_node();
    if (fd < 0) { return fd; }
    var rc = native_drm_version(fd, out);
    sys_close(fd);
    return rc;
}

# ================================================================
# v3 Phase B.2 — GEM buffer object lifecycle (AMDGPU)
# ================================================================
# Kernel UAPI reference: /usr/include/drm/amdgpu_drm.h,
#                        /usr/include/drm/drm.h (for generic GEM_CLOSE).
# All numbers here are verifiable via native_ioc_encode; tests lock
# them down in tests/tcyr/mabda.tcyr.

# DRM_COMMAND_BASE = 0x40 in drm.h; AMDGPU driver-specific ioctls
# start there. We pre-compute the absolute nr for each ioctl.
var DRM_COMMAND_BASE       = 0x40;
var DRM_AMDGPU_GEM_CREATE  = 0x00;
var DRM_AMDGPU_GEM_MMAP    = 0x01;

# Union / struct sizes on x86_64 (in bytes):
#   union drm_amdgpu_gem_create { in (32) | out (8) } = 32
#   union drm_amdgpu_gem_mmap   { in (8)  | out (8) } = 8
#   struct drm_gem_close                              = 8
var DRM_AMDGPU_GEM_CREATE_SIZE = 32;
var DRM_AMDGPU_GEM_MMAP_SIZE   = 8;
var DRM_GEM_CLOSE_SIZE         = 8;

# Absolute ioctl numbers (precomputed; tests verify via native_ioc_encode):
#   DRM_IOCTL_AMDGPU_GEM_CREATE = _IOWR('d', 0x40, union drm_amdgpu_gem_create)
#     dir=3, size=32, type=0x64, nr=0x40 → 0xC0206440
#   DRM_IOCTL_AMDGPU_GEM_MMAP   = _IOWR('d', 0x41, union drm_amdgpu_gem_mmap)
#     dir=3, size=8, type=0x64, nr=0x41 → 0xC0086441
#   DRM_IOCTL_GEM_CLOSE         = _IOW ('d', 0x09, struct drm_gem_close)
#     dir=1, size=8, type=0x64, nr=0x09 → 0x40086409
var DRM_IOCTL_AMDGPU_GEM_CREATE = 0xC0206440;
var DRM_IOCTL_AMDGPU_GEM_MMAP   = 0xC0086441;
var DRM_IOCTL_GEM_CLOSE         = 0x40086409;

# Memory domain flags (bitwise OR for combinations; we only use CPU,
# GTT, VRAM for Phase B.2 — the rest appear in later phases).
var AMDGPU_GEM_DOMAIN_CPU      = 0x1;
var AMDGPU_GEM_DOMAIN_GTT      = 0x2;
var AMDGPU_GEM_DOMAIN_VRAM     = 0x4;

# GEM BO create. Args are written into `req` (caller-owned 32 bytes,
# will be zeroed); on success the BO handle is read back from req+0.
# Returns 0 on success, negative errno on failure.
#
# `domains` is a bitmask of AMDGPU_GEM_DOMAIN_*. For a plain
# CPU-visible buffer (Phase B.2 round-trip), use GTT.
fn native_gem_create(fd, size, alignment, domains, domain_flags, req): i64 {
    memset(req, 0, DRM_AMDGPU_GEM_CREATE_SIZE);
    store64(req + 0,  size);
    store64(req + 8,  alignment);
    store64(req + 16, domains);
    store64(req + 24, domain_flags);
    return syscall(SYS_IOCTL, fd, DRM_IOCTL_AMDGPU_GEM_CREATE, req);
}

# Read the handle out of a req buffer that native_gem_create populated.
fn native_gem_create_handle(req): i64 { return load32(req + 0); }

# GEM BO mmap-offset query. Given a handle, returns the offset to pass
# as the mmap(2) `offset` argument. `req` is caller-owned 8 bytes.
# Returns 0 on success (with offset at req+0 on out), negative errno
# on failure.
fn native_gem_mmap_offset(fd, handle, req): i64 {
    memset(req, 0, DRM_AMDGPU_GEM_MMAP_SIZE);
    store32(req + 0, handle);
    return syscall(SYS_IOCTL, fd, DRM_IOCTL_AMDGPU_GEM_MMAP, req);
}

fn native_gem_mmap_offset_value(req): i64 { return load64(req + 0); }

# GEM handle close. Generic DRM ioctl — not AMDGPU-specific.
# Returns 0 on success, negative errno on failure.
fn native_gem_close(fd, handle): i64 {
    var req[8];
    store32(&req + 0, handle);
    store32(&req + 4, 0);
    return syscall(SYS_IOCTL, fd, DRM_IOCTL_GEM_CLOSE, &req);
}

# Convenience: create a CPU-visible GTT BO and mmap it. Populates
# `out` (16 bytes):
#   +0: handle       (u32 zero-extended to u64)
#   +8: mapped_addr  (u64 from mmap return, or negative errno on failure)
# Returns 0 on success, negative errno on failure (out+0 is valid if
# we got past gem_create but failed at mmap; caller should gem_close
# the handle in that case).
fn native_bo_create_gtt(fd, size, out): i64 {
    return _native_bo_create_domain(fd, size, AMDGPU_GEM_DOMAIN_GTT, out);
}

# Shader BOs may need VRAM domain on some hardware — on Cezanne
# (Vega APU) physical memory is shared, but the domain flag affects
# residency semantics. Per Mesa rusticl behavior, shader code lives
# in VRAM-domain BOs.
fn native_bo_create_vram(fd, size, out): i64 {
    return _native_bo_create_domain(fd, size, AMDGPU_GEM_DOMAIN_VRAM, out);
}

fn _native_bo_create_domain(fd, size, domain, out): i64 {
    store64(out + 0, 0);
    store64(out + 8, 0);

    var req[32];
    # For VRAM-domain on APUs we need CPU_ACCESS_REQUIRED (bit 0) so
    # the BO lands in BAR-accessible VRAM we can mmap.
    var flags = 0;
    if (domain == AMDGPU_GEM_DOMAIN_VRAM) { flags = 1; }  # CPU_ACCESS_REQUIRED
    var rc = native_gem_create(fd, size, 4096, domain, flags, &req);
    if (rc != 0) { return rc; }
    var handle = native_gem_create_handle(&req);
    store64(out + 0, handle);

    # On a mid-create failure (mmap-offset or mmap), the GEM handle is already
    # live — close it + clear out+0 so a non-zero return leaves NO leaked handle.
    # (Review 2026-06-16 LOW: callers check `!= 0` and early-return without
    # closing; fixing it here covers every call site at once.)
    var mreq[8];
    rc = native_gem_mmap_offset(fd, handle, &mreq);
    if (rc != 0) { native_gem_close(fd, handle); store64(out + 0, 0); return rc; }
    var offset = native_gem_mmap_offset_value(&mreq);

    var addr = cyr_mmap(0, size, PROT_READ | PROT_WRITE, MAP_SHARED, fd, offset);
    if (addr < 0) { native_gem_close(fd, handle); store64(out + 0, 0); return addr; }
    store64(out + 8, addr);
    return 0;
}

# Release a BO created via native_bo_create_gtt: munmap, then
# gem_close. Returns 0 on success.
fn native_bo_release_gtt(fd, handle, addr, size): i64 {
    if (addr != 0) { cyr_munmap(addr, size); }
    if (handle != 0) { native_gem_close(fd, handle); }
    return 0;
}

# ================================================================
# v3 Phase B.3.a — submission infrastructure (ctx, BO list, VA map)
# ================================================================
# Prerequisites for DRM_IOCTL_AMDGPU_CS (Phase B.3.d):
#   1. GPU context — isolates submissions from other processes.
#   2. BO list — residency tracking (kernel keeps listed BOs live).
#   3. VA map — gives the BO a virtual address in the process's GPU
#      address space. Without this the GPU cannot touch the BO.
# All three are cheap, ioctl-only, no PM4 yet.

var DRM_AMDGPU_CTX      = 0x02;
var DRM_AMDGPU_BO_LIST  = 0x03;
var DRM_AMDGPU_GEM_VA   = 0x08;

# Union / struct sizes (bytes):
#   union drm_amdgpu_ctx       { in(16) | out(16) } = 16
#   union drm_amdgpu_bo_list   { in(24) | out(8)  } = 24
#   struct drm_amdgpu_gem_va                        = 64
#   struct drm_amdgpu_bo_list_entry                 = 8
var DRM_AMDGPU_CTX_SIZE              = 16;
var DRM_AMDGPU_BO_LIST_SIZE          = 24;
var DRM_AMDGPU_GEM_VA_SIZE           = 64;
var DRM_AMDGPU_BO_LIST_ENTRY_SIZE    = 8;

# Precomputed ioctl numbers; native_ioc_encode-verified in tests.
var DRM_IOCTL_AMDGPU_CTX     = 0xC0106442;
var DRM_IOCTL_AMDGPU_BO_LIST = 0xC0186443;
var DRM_IOCTL_AMDGPU_GEM_VA  = 0x40406448;

# Context operations.
var AMDGPU_CTX_OP_ALLOC_CTX = 1;
var AMDGPU_CTX_OP_FREE_CTX  = 2;

# BO list operations.
var AMDGPU_BO_LIST_OP_CREATE  = 0;
var AMDGPU_BO_LIST_OP_DESTROY = 1;

# VA operations.
var AMDGPU_VA_OP_MAP   = 1;
var AMDGPU_VA_OP_UNMAP = 2;

# VM page flags.
var AMDGPU_VM_PAGE_READABLE   = 0x2;
var AMDGPU_VM_PAGE_WRITEABLE  = 0x4;
var AMDGPU_VM_PAGE_EXECUTABLE = 0x8;

# ================================================================
# BO page-perm constants (v3 Step 4f.ii)
# ================================================================
# Per-BO page perms for the AMDGPU VA mapping. Session 25b granted
# R | W | X everywhere as a workaround during bring-up. Step 4f.ii
# narrows back to the per-BO minimum each role needs — empirically
# verified on Cezanne kernel 6.18.24:
#
#   _NATIVE_PERM_SHADER (R | X)  shader BOs — CP fetches, the wave
#                                executes from these pages. CPU
#                                writes shader bytes via the host
#                                mmap (separate page table), so
#                                GPU W is not required.
#   _NATIVE_PERM_DATA   (R | W)  data BOs — stub, output, fence.
#                                HW reads V# state / output target,
#                                CP writes diagnostic markers,
#                                kernel writes user fence seqno.
#   _NATIVE_PERM_IB     (R | X)  IB BOs — CP only reads PM4 from
#                                these, but on Cezanne the X bit is
#                                load-bearing: dropping X causes the
#                                compute ring to TDR. Hardware
#                                bisect during Step 4f.ii (R-only,
#                                R+W, R+X all tested) — only R+X
#                                makes the dispatch land. AMDGPU
#                                gates CP fetch through the execute
#                                bit even though PM4 isn'"'"'t shader
#                                code. The W bit is not required.
#
# Earlier this session a constants-init-order bug had _NATIVE_PERM_*
# evaluating to 0 (referenced AMDGPU_VM_PAGE_* before they were
# defined). The block now sits AFTER the AMDGPU_VM_PAGE_* defs,
# which Cyrius initialises in declaration order. The CPU regression
# test in tests/tcyr/mabda_v3.tcyr locks the values so further
# narrowing trips a test before reaching hardware.

var _NATIVE_PERM_FULL   = AMDGPU_VM_PAGE_READABLE
| AMDGPU_VM_PAGE_WRITEABLE
| AMDGPU_VM_PAGE_EXECUTABLE;
var _NATIVE_PERM_SHADER = AMDGPU_VM_PAGE_READABLE
| AMDGPU_VM_PAGE_EXECUTABLE;
var _NATIVE_PERM_DATA   = AMDGPU_VM_PAGE_READABLE
| AMDGPU_VM_PAGE_WRITEABLE;
var _NATIVE_PERM_IB     = AMDGPU_VM_PAGE_READABLE
| AMDGPU_VM_PAGE_EXECUTABLE;

# Sensible default for a first-BO VA base — 2 MiB into the GPU VA
# space, well above any kernel-reserved low region. Phase B.3.a only
# supports one-BO-at-a-time; a full VA allocator lands in B.3.b.
var NATIVE_GPU_VA_BASE = 0x200000;

# Context lifecycle. `req` is caller-owned 16 bytes.
# On ALLOC: sets in={op=1, flags=0, ctx_id=0, priority=0}; kernel
# writes out.alloc.ctx_id at req+0.
fn native_ctx_alloc(fd, req): i64 {
    memset(req, 0, DRM_AMDGPU_CTX_SIZE);
    store32(req + 0,  AMDGPU_CTX_OP_ALLOC_CTX);
    store32(req + 4,  0);
    store32(req + 8,  0);
    store32(req + 12, 0);
    return syscall(SYS_IOCTL, fd, DRM_IOCTL_AMDGPU_CTX, req);
}

fn native_ctx_alloc_id(req): i64 { return load32(req + 0); }

fn native_ctx_free(fd, ctx_id): i64 {
    var req[16];
    memset(&req, 0, 16);
    store32(&req + 0,  AMDGPU_CTX_OP_FREE_CTX);
    store32(&req + 4,  0);
    store32(&req + 8,  ctx_id);
    store32(&req + 12, 0);
    return syscall(SYS_IOCTL, fd, DRM_IOCTL_AMDGPU_CTX, &req);
}

# BO list lifecycle. `entries` points to an array of
# drm_amdgpu_bo_list_entry (8 bytes each); `count` is the element
# count. `req` is caller-owned 24 bytes; on CREATE success,
# out.list_handle is at req+0.
fn native_bo_list_create(fd, entries, count, req): i64 {
    memset(req, 0, DRM_AMDGPU_BO_LIST_SIZE);
    store32(req + 0,  AMDGPU_BO_LIST_OP_CREATE);
    store32(req + 4,  0);  # list_handle (in): 0 = create new
    store32(req + 8,  count);
    store32(req + 12, DRM_AMDGPU_BO_LIST_ENTRY_SIZE);
    store64(req + 16, entries);
    return syscall(SYS_IOCTL, fd, DRM_IOCTL_AMDGPU_BO_LIST, req);
}

fn native_bo_list_create_handle(req): i64 { return load32(req + 0); }

fn native_bo_list_destroy(fd, list_handle): i64 {
    var req[24];
    memset(&req, 0, 24);
    store32(&req + 0, AMDGPU_BO_LIST_OP_DESTROY);
    store32(&req + 4, list_handle);
    store32(&req + 8, 0);
    store32(&req + 12, 0);
    store64(&req + 16, 0);
    return syscall(SYS_IOCTL, fd, DRM_IOCTL_AMDGPU_BO_LIST, &req);
}

# VA map / unmap. `va_address` and `size` must be page-aligned
# (4 KiB). `flags` combines AMDGPU_VM_PAGE_*.
fn native_gem_va_map(fd, handle, va_address, size, flags): i64 {
    var req[64];
    memset(&req, 0, 64);
    store32(&req + 0,  handle);
    store32(&req + 4,  0);
    store32(&req + 8,  AMDGPU_VA_OP_MAP);
    store32(&req + 12, flags);
    store64(&req + 16, va_address);
    store64(&req + 24, 0);       # offset_in_bo
    store64(&req + 32, size);
    # vm_timeline_point / syncobjs stay zero; unused by legacy CS path.
    return syscall(SYS_IOCTL, fd, DRM_IOCTL_AMDGPU_GEM_VA, &req);
}

fn native_gem_va_unmap(fd, handle, va_address, size): i64 {
    var req[64];
    memset(&req, 0, 64);
    store32(&req + 0,  handle);
    store32(&req + 4,  0);
    store32(&req + 8,  AMDGPU_VA_OP_UNMAP);
    store32(&req + 12, 0);
    store64(&req + 16, va_address);
    store64(&req + 24, 0);
    store64(&req + 32, size);
    return syscall(SYS_IOCTL, fd, DRM_IOCTL_AMDGPU_GEM_VA, &req);
}

# ================================================================
# v3 Phase B.3.d — syncobj lifecycle (generic DRM, not AMDGPU-specific)
# ================================================================
# drm_syncobj_create  = {handle u32, flags u32} = 8 bytes
# drm_syncobj_destroy = {handle u32, pad u32}  = 8 bytes
# drm_syncobj_wait    = {handles u64, timeout_nsec s64, count_handles u32,
#                        flags u32, first_signaled u32, pad u32,
#                        deadline_nsec u64} = 40 bytes (kernel ≥ 6.10)
var DRM_SYNCOBJ_CREATE_SIZE   = 8;
var DRM_SYNCOBJ_DESTROY_SIZE  = 8;
var DRM_SYNCOBJ_WAIT_SIZE     = 40;

# Generic DRM ioctls: nr values 0xBF / 0xC0 / 0xC3.
var DRM_IOCTL_SYNCOBJ_CREATE  = 0xC00864BF;
var DRM_IOCTL_SYNCOBJ_DESTROY = 0xC00864C0;
var DRM_IOCTL_SYNCOBJ_WAIT    = 0xC02864C3;

var DRM_SYNCOBJ_WAIT_FLAGS_WAIT_ALL         = 0x1;
var DRM_SYNCOBJ_WAIT_FLAGS_WAIT_FOR_SUBMIT  = 0x2;

# Create a syncobj. Returns handle on success, negative errno on
# failure. Handle returned via writable req+0.
fn native_syncobj_create(fd, out_handle_ptr): i64 {
    var req[8];
    store32(&req + 0, 0);
    store32(&req + 4, 0);
    var rc = syscall(SYS_IOCTL, fd, DRM_IOCTL_SYNCOBJ_CREATE, &req);
    if (rc != 0) { return rc; }
    store64(out_handle_ptr, load32(&req + 0));
    return 0;
}

fn native_syncobj_destroy(fd, handle): i64 {
    var req[8];
    store32(&req + 0, handle);
    store32(&req + 4, 0);
    return syscall(SYS_IOCTL, fd, DRM_IOCTL_SYNCOBJ_DESTROY, &req);
}

# Wait for the syncobj to become signaled. `timeout_ns` is absolute
# CLOCK_MONOTONIC nanoseconds. Returns 0 on signaled, negative errno
# on timeout or error. Caller supplies one handle.
fn native_syncobj_wait(fd, handle, timeout_ns): i64 {
    var handles[8];
    store64(&handles + 0, handle);
    var req[40];
    memset(&req, 0, 40);
    store64(&req + 0,  &handles);       # handles ptr
    store64(&req + 8,  timeout_ns);     # timeout_nsec (absolute)
    store32(&req + 16, 1);              # count_handles
    store32(&req + 20, DRM_SYNCOBJ_WAIT_FLAGS_WAIT_ALL | DRM_SYNCOBJ_WAIT_FLAGS_WAIT_FOR_SUBMIT);
    store32(&req + 24, 0);              # first_signaled (out)
    store32(&req + 28, 0);              # pad
    store64(&req + 32, 0);              # deadline_nsec
    return syscall(SYS_IOCTL, fd, DRM_IOCTL_SYNCOBJ_WAIT, &req);
}

# ================================================================
# v3.1 Q.3 — timeline syncobj (multi-queue coordination)
# ================================================================
# A timeline syncobj is an ordinary syncobj (created via
# native_syncobj_create) read/written at monotonically increasing u64
# "points" instead of the binary signaled/unsignaled state. The native
# multi-queue path (Q.3) gives each logical Queue ONE persistent
# timeline syncobj: every queue-targeted submit signals point N+1 on
# GPU completion (via a CS TIMELINE_SIGNAL chunk), wait_idle waits for
# the queue's latest point, and gpu_queue_barrier (Q.4) makes a
# consumer ring wait on a producer ring's point (a CS TIMELINE_WAIT
# chunk). Persistent + monotonic avoids the reset/reuse races a binary
# syncobj would hit across repeated cross-ring submits.
#
# ABI ground-truthed against /usr/include/drm/{drm.h,amdgpu_drm.h} on
# this box (kernel 7.0): see the struct/ioctl notes below.

# struct drm_syncobj_timeline_wait = {handles u64, points u64,
#   timeout_nsec s64, count_handles u32, flags u32, first_signaled u32,
#   pad u32, deadline_nsec u64} = 48 bytes.
# DRM_IOCTL_SYNCOBJ_TIMELINE_WAIT = DRM_IOWR(0xCA, .. 48) = 0xC03064CA.
var DRM_SYNCOBJ_TIMELINE_WAIT_SIZE = 48;
var DRM_IOCTL_SYNCOBJ_TIMELINE_WAIT = 0xC03064CA;

# struct drm_syncobj_timeline_array = {handles u64, points u64,
#   count_handles u32, flags u32} = 24 bytes.
# DRM_IOCTL_SYNCOBJ_QUERY = DRM_IOWR(0xCB, .. 24) = 0xC01864CB — reads
# back each syncobj's last-signaled point (used to verify point
# accounting on HW in the Q.6 e2e).
var DRM_SYNCOBJ_TIMELINE_ARRAY_SIZE = 24;
var DRM_IOCTL_SYNCOBJ_QUERY = 0xC01864CB;

# amdgpu CS chunk IDs for cross-ring sync. SYNCOBJ_IN/OUT (0x04/0x05)
# carry a 4-byte sem (handle only, binary); the TIMELINE variants
# (0x08/0x09) carry the 16-byte drm_amdgpu_cs_chunk_syncobj
# {handle u32, flags u32, point u64}.
var AMDGPU_CHUNK_ID_SYNCOBJ_IN            = 0x04;
var AMDGPU_CHUNK_ID_SYNCOBJ_TIMELINE_WAIT   = 0x08;
var AMDGPU_CHUNK_ID_SYNCOBJ_TIMELINE_SIGNAL = 0x09;

# Pure byte-builder: write a 16-byte drm_amdgpu_cs_chunk_syncobj at
# `buf`. Factored out so the chunk layout is CPU-testable independent
# of the (HW-gated) CS submit. flags is 0 for both signal and wait on
# the GFX/COMPUTE rings today.
fn native_build_cs_chunk_syncobj(buf, handle, flags, point): i64 {
    store32(buf + 0, handle);
    store32(buf + 4, flags);
    store64(buf + 8, point);
    return 0;
}

# Wait until `handle` reaches timeline `point`. `timeout_ns` is
# absolute CLOCK_MONOTONIC ns. WAIT_FOR_SUBMIT covers the case where
# the signalling submit hasn't landed yet. Returns 0 on reached,
# negative errno on timeout/error. (HW-gated.)
fn native_syncobj_timeline_wait(fd, handle, point, timeout_ns): i64 {
    var handles[8];
    store64(&handles + 0, handle);
    var points[8];
    store64(&points + 0, point);
    var req[48];
    memset(&req, 0, 48);
    store64(&req + 0,  &handles);       # handles ptr
    store64(&req + 8,  &points);        # points ptr
    store64(&req + 16, timeout_ns);     # timeout_nsec (absolute)
    store32(&req + 24, 1);              # count_handles
    store32(&req + 28, DRM_SYNCOBJ_WAIT_FLAGS_WAIT_ALL | DRM_SYNCOBJ_WAIT_FLAGS_WAIT_FOR_SUBMIT);
    store32(&req + 32, 0);              # first_signaled (out)
    store32(&req + 36, 0);              # pad
    store64(&req + 40, 0);              # deadline_nsec
    return syscall(SYS_IOCTL, fd, DRM_IOCTL_SYNCOBJ_TIMELINE_WAIT, &req);
}

# Read back `handle`'s last-signaled timeline point into
# out_point_ptr. Returns 0 on success, negative errno on failure.
# (HW-gated; used to verify point accounting end-to-end.)
fn native_syncobj_timeline_query(fd, handle, out_point_ptr): i64 {
    var handles[8];
    store64(&handles + 0, handle);
    var points[8];
    store64(&points + 0, 0);
    var req[24];
    memset(&req, 0, 24);
    store64(&req + 0,  &handles);       # handles ptr
    store64(&req + 8,  &points);        # points ptr (out)
    store32(&req + 16, 1);              # count_handles
    store32(&req + 20, 0);              # flags
    var rc = syscall(SYS_IOCTL, fd, DRM_IOCTL_SYNCOBJ_QUERY, &req);
    if (rc != 0) { return rc; }
    store64(out_point_ptr, load64(&points + 0));
    return 0;
}

# ================================================================
# v3 Phase B.3.d — CS (command submission) ioctl
# ================================================================
# union drm_amdgpu_cs { in (24) | out (8) } = 24
# struct drm_amdgpu_cs_chunk                = 16 (id u32 + length_dw u32 + data u64)
# struct drm_amdgpu_cs_chunk_ib             = 32 (pad u32 + flags u32 + va_start u64
#                                              + ib_bytes u32 + ip_type u32
#                                              + ip_instance u32 + ring u32)
# struct drm_amdgpu_cs_chunk_sem            = 4  (handle u32 only)
#   Used by DEPENDENCIES / SYNCOBJ_IN / SYNCOBJ_OUT / SCHEDULED_DEPENDENCIES.
# struct drm_amdgpu_cs_chunk_syncobj        = 16 (handle u32 + flags u32 + point u64)
#   Used by SYNCOBJ_TIMELINE_WAIT / SYNCOBJ_TIMELINE_SIGNAL only.
var DRM_AMDGPU_CS                     = 0x04;
var DRM_AMDGPU_CS_SIZE                = 24;
var DRM_AMDGPU_CS_CHUNK_SIZE          = 16;
var DRM_AMDGPU_CS_CHUNK_IB_SIZE       = 32;
var DRM_AMDGPU_CS_CHUNK_SEM_SIZE      = 4;
var DRM_AMDGPU_CS_CHUNK_SYNCOBJ_SIZE  = 16;
var DRM_IOCTL_AMDGPU_CS               = 0xC0186444;

var AMDGPU_CHUNK_ID_IB           = 0x01;
var AMDGPU_CHUNK_ID_FENCE        = 0x02;
var AMDGPU_CHUNK_ID_SYNCOBJ_OUT  = 0x05;
var AMDGPU_CHUNK_ID_BO_HANDLES   = 0x06;

var AMDGPU_HW_IP_GFX      = 0;
var AMDGPU_HW_IP_COMPUTE  = 1;
var AMDGPU_HW_IP_DMA      = 2;   # SDMA ring (v3.1 Q.5 TRANSFER queue)

# Submit a command stream with one IB chunk + one SYNCOBJ_OUT chunk.
# Returns 0 on success (CS ioctl accepted). The syncobj becomes
# signaled when the GPU finishes the submission; caller waits via
# native_syncobj_wait.
#
# Arguments:
#   fd             — DRM render-node fd
#   ctx_id         — from native_ctx_alloc
#   bo_list_handle — from native_bo_list_create
#   ib_va          — GPU virtual address of the IB (PM4 stream)
#   ib_bytes       — size of the PM4 stream (multiple of 4)
#   ip_type        — AMDGPU_HW_IP_COMPUTE or AMDGPU_HW_IP_GFX
#   syncobj_handle — pre-created syncobj to signal on completion (or 0 to omit)
fn native_cs_submit(fd, ctx_id, bo_list_handle, ib_va, ib_bytes, ip_type, syncobj_handle): i64 {
    # Build IB chunk payload (32 bytes).
    var ib_chunk[32];
    memset(&ib_chunk, 0, 32);
    store32(&ib_chunk + 0,  0);         # _pad
    store32(&ib_chunk + 4,  0);         # flags
    store64(&ib_chunk + 8,  ib_va);
    store32(&ib_chunk + 16, ib_bytes);
    store32(&ib_chunk + 20, ip_type);
    store32(&ib_chunk + 24, 0);         # ip_instance
    store32(&ib_chunk + 28, 0);         # ring

    # Build SYNCOBJ_OUT chunk payload. The kernel treats this chunk as
    # an array of drm_amdgpu_cs_chunk_sem (4 bytes: handle only) — NOT
    # the 16-byte drm_amdgpu_cs_chunk_syncobj (which is timeline-only).
    # Getting this wrong manifests as -EINVAL because the kernel reads
    # more "handles" than you meant and 0-valued slots fail syncobj
    # lookup. See feedback memory & CHANGELOG note for v3 Phase B.3.d.
    var syncobj_chunk[4];
    store32(&syncobj_chunk + 0, syncobj_handle);

    var include_sync = 1;
    if (syncobj_handle == 0) { include_sync = 0; }

    # Build chunk descriptors (16 bytes each).
    var chunks[32];
    memset(&chunks, 0, 32);
    store32(&chunks + 0,  AMDGPU_CHUNK_ID_IB);
    store32(&chunks + 4,  32 / 4);       # length_dw = 8 (IB chunk payload)
    store64(&chunks + 8,  &ib_chunk);

    if (include_sync == 1) {
        store32(&chunks + 16, AMDGPU_CHUNK_ID_SYNCOBJ_OUT);
        store32(&chunks + 20, 1);         # length_dw = 1 (single u32 handle)
        store64(&chunks + 24, &syncobj_chunk);
    }

    var chunk_ptrs[16];
    store64(&chunk_ptrs + 0, &chunks);
    if (include_sync == 1) {
        store64(&chunk_ptrs + 8, &chunks + 16);
    }

    var num_chunks = 1 + include_sync;

    var req[24];
    memset(&req, 0, 24);
    store32(&req + 0,  ctx_id);
    store32(&req + 4,  bo_list_handle);
    store32(&req + 8,  num_chunks);
    store32(&req + 12, 0);                # flags
    store64(&req + 16, &chunk_ptrs);

    return syscall(SYS_IOCTL, fd, DRM_IOCTL_AMDGPU_CS, &req);
}

# Submit a CS using the BO_HANDLES chunk path (Mesa rusticl pattern) instead
# of the BO_LIST_OP_CREATE ioctl. The kernel parser at drivers/gpu/drm/amd/
# amdgpu/amdgpu_cs.c:p1_bo_handles consumes the chunk_data as a
# drm_amdgpu_bo_list_in (24 bytes); its bo_info_ptr field then points to the
# array of {handle u32, priority u32} entries. cs.in.bo_list_handle is
# unused (the BO list is reconstructed from the chunk).
#
# Caller pre-builds bo_list_in (24 bytes) with:
#   off  0: operation    = 0xFFFFFFFF  (sentinel — kernel infers from chunk)
#   off  4: list_handle  = 0xFFFFFFFF  (sentinel)
#   off  8: bo_number    = N
#   off 12: bo_info_size = 8           (sizeof drm_amdgpu_bo_list_entry)
#   off 16: bo_info_ptr  = &entries    (N × {u32 handle, u32 priority})
#
# Chunk order matches Mesa's amdgpu_cs_submit_ib_kernelq:
#   1. BO_HANDLES
#   2. SYNCOBJ_OUT  (when syncobj_handle != 0)
#   3. IB
fn native_cs_submit_inline_bos(fd, ctx_id, bo_list_in_ptr, ib_va, ib_bytes, ip_type, syncobj_handle): i64 {
    var ib_chunk[32];
    memset(&ib_chunk, 0, 32);
    store32(&ib_chunk + 0,  0);
    store32(&ib_chunk + 4,  0);
    store64(&ib_chunk + 8,  ib_va);
    store32(&ib_chunk + 16, ib_bytes);
    store32(&ib_chunk + 20, ip_type);
    store32(&ib_chunk + 24, 0);
    store32(&ib_chunk + 28, 0);

    var syncobj_chunk[4];
    store32(&syncobj_chunk + 0, syncobj_handle);

    var include_sync = 1;
    if (syncobj_handle == 0) { include_sync = 0; }

    # Up to 3 chunk descriptors (16 bytes each): BO_HANDLES, SYNCOBJ_OUT, IB.
    var chunks[48];
    memset(&chunks, 0, 48);
    # 1. BO_HANDLES — length_dw = sizeof(drm_amdgpu_bo_list_in)/4 = 6.
    store32(&chunks + 0,  AMDGPU_CHUNK_ID_BO_HANDLES);
    store32(&chunks + 4,  6);
    store64(&chunks + 8,  bo_list_in_ptr);

    var pos = 16;
    if (include_sync == 1) {
        store32(&chunks + pos + 0,  AMDGPU_CHUNK_ID_SYNCOBJ_OUT);
        store32(&chunks + pos + 4,  1);
        store64(&chunks + pos + 8,  &syncobj_chunk);
        pos = pos + 16;
    }
    # IB chunk last (matches Mesa).
    store32(&chunks + pos + 0,  AMDGPU_CHUNK_ID_IB);
    store32(&chunks + pos + 4,  32 / 4);
    store64(&chunks + pos + 8,  &ib_chunk);

    var num_chunks = 2 + include_sync;

    var chunk_ptrs[24];
    store64(&chunk_ptrs + 0,  &chunks + 0);
    if (include_sync == 1) {
        store64(&chunk_ptrs + 8,  &chunks + 16);
        store64(&chunk_ptrs + 16, &chunks + 32);
    }
    if (include_sync == 0) {
        store64(&chunk_ptrs + 8,  &chunks + 16);
    }

    var req[24];
    memset(&req, 0, 24);
    store32(&req + 0,  ctx_id);
    store32(&req + 4,  0);                # bo_list_handle = 0 (chunk replaces it)
    store32(&req + 8,  num_chunks);
    store32(&req + 12, 0);
    store64(&req + 16, &chunk_ptrs);

    return syscall(SYS_IOCTL, fd, DRM_IOCTL_AMDGPU_CS, &req);
}

# Submit a CS using the full 4-chunk Mesa-rusticl shape:
# BO_HANDLES + SYNCOBJ_OUT + FENCE + IB, with caller-provided IB flags.
# This is the byte-shape that the working session-25b C spike uses
# (deps/libdrm_store_spike_v3.c). The 3-chunk variant
# native_cs_submit_inline_bos (without FENCE) accepts the submit ioctl
# but never queues the IB to MEC for compute on this kernel — TDR fires
# after 10s and the syncobj signals as if the IB completed.
#
# Caller pre-builds bo_list_in (24 bytes) per native_cs_submit_inline_bos.
# fence_kh = KMS handle of a BO mapped into the GPU VA space. The kernel
# writes the IB completion sequence number to (fence_bo + fence_offset),
# 8 bytes. fence_offset is typically 32 (matches Mesa).
# ib_flags = AMDGPU_IB_FLAG_TC_WB_NOT_INVALIDATE (0x08) for compute.
fn native_cs_submit_4chunk(fd, ctx_id, bo_list_in_ptr, ib_va, ib_bytes, ip_type,
syncobj_handle, fence_kh, fence_offset, ib_flags): i64 {
    # Audit 2026-06-14 (defense-in-depth, CVE-2026-46220 class): the user
    # fence writeback address (fence_bo + fence_offset) must be DWORD-
    # aligned — an unaligned address trips a kernel BUG_ON on some IP
    # blocks (drm/amdgpu SDMA4: `BUG_ON(addr & 0x3)`). mabda only ever
    # passes a fixed, aligned 32 on the GFX/COMPUTE ring today, so this
    # guards a future regression (a new caller, or an SDMA submit path)
    # rather than a live bug — reject before the CS ioctl rather than let
    # a misaligned offset reach the kernel.
    if ((fence_offset & 3) != 0) { return 0 - 22; }   # -EINVAL
    var ib_chunk[32];
    memset(&ib_chunk, 0, 32);
    store32(&ib_chunk + 0,  0);
    store32(&ib_chunk + 4,  ib_flags);
    store64(&ib_chunk + 8,  ib_va);
    store32(&ib_chunk + 16, ib_bytes);
    store32(&ib_chunk + 20, ip_type);
    store32(&ib_chunk + 24, 0);
    store32(&ib_chunk + 28, 0);

    var syncobj_chunk[4];
    store32(&syncobj_chunk + 0, syncobj_handle);

    var fence_chunk[8];
    store32(&fence_chunk + 0, fence_kh);
    store32(&fence_chunk + 4, fence_offset);

    var chunks_4[64];
    memset(&chunks_4, 0, 64);
    store32(&chunks_4 + 0,  AMDGPU_CHUNK_ID_BO_HANDLES);
    store32(&chunks_4 + 4,  6);
    store64(&chunks_4 + 8,  bo_list_in_ptr);
    store32(&chunks_4 + 16, AMDGPU_CHUNK_ID_SYNCOBJ_OUT);
    store32(&chunks_4 + 20, 1);
    store64(&chunks_4 + 24, &syncobj_chunk);
    store32(&chunks_4 + 32, AMDGPU_CHUNK_ID_FENCE);
    store32(&chunks_4 + 36, 2);
    store64(&chunks_4 + 40, &fence_chunk);
    store32(&chunks_4 + 48, AMDGPU_CHUNK_ID_IB);
    store32(&chunks_4 + 52, 32 / 4);
    store64(&chunks_4 + 56, &ib_chunk);

    var chunk_ptrs_4[32];
    store64(&chunk_ptrs_4 + 0,  &chunks_4 + 0);
    store64(&chunk_ptrs_4 + 8,  &chunks_4 + 16);
    store64(&chunk_ptrs_4 + 16, &chunks_4 + 32);
    store64(&chunk_ptrs_4 + 24, &chunks_4 + 48);

    var req_4[24];
    memset(&req_4, 0, 24);
    store32(&req_4 + 0,  ctx_id);
    store32(&req_4 + 4,  0);
    store32(&req_4 + 8,  4);
    store32(&req_4 + 12, 0);
    store64(&req_4 + 16, &chunk_ptrs_4);

    return syscall(SYS_IOCTL, fd, DRM_IOCTL_AMDGPU_CS, &req_4);
}

# v3.1 Q.3 — timeline-syncobj CS submit (queue-targeted path). Same
# Mesa 4-chunk shape as native_cs_submit_4chunk (BO_HANDLES + FENCE + IB
# — the FENCE chunk is what actually queues a compute IB to MEC on this
# kernel; dropping it lets the syncobj signal on TDR instead of real
# completion), but SYNCOBJ_OUT is swapped for a TIMELINE_SIGNAL chunk
# and an optional TIMELINE_WAIT chunk is prepended for cross-ring
# barriers (Q.4). Chunk order:
#   BO_HANDLES, [TIMELINE_WAIT], TIMELINE_SIGNAL, FENCE, IB
# The GPU signals `signal_syncobj` at `signal_point` on completion;
# when `wait_syncobj != 0` the submission first waits for that syncobj
# to reach `wait_point`. Returns 0 on accepted, negative errno on
# failure. (HW-gated; chunk byte layout is CPU-tested via the pure
# native_build_cs_chunk_syncobj helper.)
fn native_cs_submit_timeline(fd, ctx_id, bo_list_in_ptr, ib_va, ib_bytes, ip_type,
signal_syncobj, signal_point, wait_syncobj, wait_point, fence_kh, fence_offset, ib_flags): i64 {
    if ((fence_offset & 3) != 0) { return 0 - 22; }   # -EINVAL: DWORD-align guard
    # Timeline points are strictly monotonic from an initial 0, so the
    # kernel rejects a SIGNAL of point 0 (drm_syncobj_add_point requires
    # new > current) and would fail the whole CS with -EINVAL. Guard it
    # here — same validation-parity posture as the fence-align guard. The
    # queue path never trips this (queue_bump_point starts at 1); this
    # catches a stray caller.
    if (signal_point == 0) { return 0 - 22; }

    var ib_chunk[32];
    memset(&ib_chunk, 0, 32);
    store32(&ib_chunk + 0,  0);
    store32(&ib_chunk + 4,  ib_flags);
    store64(&ib_chunk + 8,  ib_va);
    store32(&ib_chunk + 16, ib_bytes);
    store32(&ib_chunk + 20, ip_type);
    store32(&ib_chunk + 24, 0);
    store32(&ib_chunk + 28, 0);

    # SIGNAL chunk: flags unused on signal; the GPU signals (handle,
    # point) on completion.
    var signal_chunk[16];
    native_build_cs_chunk_syncobj(&signal_chunk, signal_syncobj, 0, signal_point);

    var wait_chunk[16];
    var include_wait = 1;
    if (wait_syncobj == 0) { include_wait = 0; }
    if (include_wait == 1) {
        # Waiting on timeline point 0 is meaningless (nothing is signalled
        # at 0); reject rather than submit a dead dependency.
        if (wait_point == 0) { return 0 - 22; }
        # WAIT chunk: the amdgpu CS parser routes flags through
        # drm_syncobj_find_fence, which reads WAIT_FLAGS_WAIT_FOR_SUBMIT
        # (0x2). Setting it (the Mesa/RADV choice) makes the in-CS wait
        # tolerate a consumer submit that races ahead of the producer —
        # the dependency resolves once the producer's fence installs,
        # instead of failing -ENOENT. Harmless for our barrier path
        # (which waits on already-signalled points), robust against
        # future render-graph cross-queue scheduling (3.1.2).
        native_build_cs_chunk_syncobj(&wait_chunk, wait_syncobj,
        DRM_SYNCOBJ_WAIT_FLAGS_WAIT_FOR_SUBMIT, wait_point);
    }

    var fence_chunk[8];
    store32(&fence_chunk + 0, fence_kh);
    store32(&fence_chunk + 4, fence_offset);

    # Chunk descriptors (16 bytes each) + parallel pointer array.
    var chunks[80];
    memset(&chunks, 0, 80);
    var chunk_ptrs[40];
    memset(&chunk_ptrs, 0, 40);

    var co = 0;     # byte cursor into chunks
    var po = 0;     # byte cursor into chunk_ptrs

    store32(&chunks + co + 0, AMDGPU_CHUNK_ID_BO_HANDLES);
    store32(&chunks + co + 4, 6);                    # bo_list_in = 24 B = 6 dw
    store64(&chunks + co + 8, bo_list_in_ptr);
    store64(&chunk_ptrs + po, &chunks + co);
    co = co + 16;
    po = po + 8;

    if (include_wait == 1) {
        store32(&chunks + co + 0, AMDGPU_CHUNK_ID_SYNCOBJ_TIMELINE_WAIT);
        store32(&chunks + co + 4, 4);               # chunk_syncobj = 16 B = 4 dw
        store64(&chunks + co + 8, &wait_chunk);
        store64(&chunk_ptrs + po, &chunks + co);
        co = co + 16;
        po = po + 8;
    }

    store32(&chunks + co + 0, AMDGPU_CHUNK_ID_SYNCOBJ_TIMELINE_SIGNAL);
    store32(&chunks + co + 4, 4);                    # chunk_syncobj = 16 B = 4 dw
    store64(&chunks + co + 8, &signal_chunk);
    store64(&chunk_ptrs + po, &chunks + co);
    co = co + 16;
    po = po + 8;

    store32(&chunks + co + 0, AMDGPU_CHUNK_ID_FENCE);
    store32(&chunks + co + 4, 2);                    # cs_chunk_fence = 8 B = 2 dw
    store64(&chunks + co + 8, &fence_chunk);
    store64(&chunk_ptrs + po, &chunks + co);
    co = co + 16;
    po = po + 8;

    store32(&chunks + co + 0, AMDGPU_CHUNK_ID_IB);
    store32(&chunks + co + 4, 8);                    # cs_chunk_ib = 32 B = 8 dw
    store64(&chunks + co + 8, &ib_chunk);
    store64(&chunk_ptrs + po, &chunks + co);
    co = co + 16;
    po = po + 8;

    var num_chunks = 4 + include_wait;

    var req[24];
    memset(&req, 0, 24);
    store32(&req + 0,  ctx_id);
    store32(&req + 4,  0);                  # bo_list_handle unused (BO_HANDLES chunk)
    store32(&req + 8,  num_chunks);
    store32(&req + 12, 0);
    store64(&req + 16, &chunk_ptrs);

    return syscall(SYS_IOCTL, fd, DRM_IOCTL_AMDGPU_CS, &req);
}

# --- gfx9_encode.cyr ---

# @internal — GFX9 instruction encoders (Phase N.0, the compiler's output stage)
# gfx9_encode.cyr — operand-parameterized GFX9 ISA encoders
#
# Phase N (docs/proposals/v3.2-spirv-gfx9-native-lowering.md) builds an
# in-tree SPIR-V → GFX9 compute compiler. N.0 is the SAFETY NET that lands
# before any generated code exists: it lifts the fixed, hand-verified byte
# emitters in backend_native_shaders.cyr into general, operand-parameterized
# encoders — one pure function per GFX9 instruction FORMAT — so the later
# instruction-selection / register-allocation stages emit bytes through a
# stage that is already proven correct.
#
# THE ORACLE (tests/tcyr/compiler.tcyr): every encoder is regression-tested
# to reproduce, byte-for-byte, the exact dwords the hand-authored shaders in
# backend_native_shaders.cyr already pin (each of which is itself
# llvm-mc-round-tripped on gfx90c per
# feedback_verify_gfx9_shader_bytes_with_llvm_mc). So an encoder bug is
# caught against ~90 known-good dwords *before* it can reach hardware. The
# hand-authored shader builders are LEFT UNTOUCHED — they stay the
# HW-verified ground truth; these encoders are a new, independently-proven
# library the compiler's N.5 encode stage will drive.
#
# Authorities: GFX9/Vega ISA reference (instruction-format bit layouts) +
# the byte constants in backend_native_shaders.cyr (the regression oracle).
# Pure byte math: no syscalls, no fn deps, no allocation. Included in the
# build chain BEFORE backend_native_shaders.cyr — the hand-authored shader
# builders there were refactored (N.0 follow-on) to emit through these
# encoders, so this module is now their dependency.
#
# SCOPE (matches the proposal's compute-only compiler boundary): this lifts
# the formats the compute compiler emits — VOP1, VOP2, VOP3a, SOP2, SOPP,
# SMEM, FLAT(global). EXP (graphics color/pos export) and MIMG (image
# load/sample) are NOT lifted here: the proposal scopes the compiler
# "compute-only, no graphics shaders, no texture sampling", so their
# encoders land with a future graphics/texture compiler phase, not N.0.
# The hand-authored EXP/MIMG dwords keep their existing byte-pinned tests.

# ================================================================
# Operand encoding — VOP src field (9-bit) value table
# ================================================================
# GFX9 VOP source operands share a 9-bit encoding:
#   0..101    SGPR 0..101
#   124..127  m0 / exec / etc. (special; not emitted here)
#   128       inline constant 0
#   129..192  inline constants 1..64
#   193..208  inline constants -1..-16
#   240..247  inline f32 0.5/-0.5/1.0/-1.0/2.0/-2.0/4.0/-4.0
#   255       a 32-bit literal follows in the next dword
#   256..511  VGPR 0..255  (256 + index)
var GFX9_SRC_LITERAL = 255;            # src0 = 255 → literal dword follows
var GFX9_INLINE_F32_0_0 = 128;         # inline f32 0.0
var GFX9_INLINE_F32_0_5 = 240;         # inline f32 0.5 (= f64 0.5 in a VOP3 src; F.7f.7b)
var GFX9_INLINE_F32_1_0 = 242;         # inline f32 1.0
var GFX9_SADDR_OFF = 127;              # FLAT SADDR field = 127 → "off" (no scalar addr)
var GFX9_FLAT_SEG_GLOBAL = 2;          # FLAT SEG field: 0=flat, 1=scratch, 2=global

# A VGPR as a 9-bit VOP src operand.
fn gfx9_vgpr(n): i64 {
    return 256 + (n & 0xFF);
}

# An SGPR as a 9-bit VOP src operand (identity 0..101; documents intent).
fn gfx9_sgpr(n): i64 {
    return n & 0xFF;
}

# An integer inline-constant as a 9-bit VOP src operand.
# Returns GFX9_SRC_LITERAL (255) when k is outside the inline range
# [-16, 64] — the caller then emits k as a trailing literal dword.
fn gfx9_inline_int(k): i64 {
    if (k >= 0) {
        if (k <= 64) { return 128 + k; }
        return GFX9_SRC_LITERAL;
    }
    var neg = 0 - k;
    if (neg <= 16) { return 192 + neg; }
    return GFX9_SRC_LITERAL;
}

# An f32 inline-constant as a 9-bit VOP src operand. GFX9 has dedicated operand codes for
# a fixed set of float constants (no literal dword): ±0.5/±1.0/±2.0/±4.0 → 240..247.
# `bits` is the f32 bit pattern (zero-extended). Returns GFX9_SRC_LITERAL for any other
# value — the caller then emits it as a trailing literal dword (VOP2) or fails loud (VOP3).
fn gfx9_inline_float(bits): i64 {
    if (bits == 0x3F000000) { return 240; }   # 0.5
    if (bits == 0xBF000000) { return 241; }   # -0.5
    if (bits == 0x3F800000) { return 242; }   # 1.0
    if (bits == 0xBF800000) { return 243; }   # -1.0
    if (bits == 0x40000000) { return 244; }   # 2.0
    if (bits == 0xC0000000) { return 245; }   # -2.0
    if (bits == 0x40800000) { return 246; }   # 4.0
    if (bits == 0xC0800000) { return 247; }   # -4.0
    return GFX9_SRC_LITERAL;
}

# ================================================================
# Per-format opcode constants (GFX9 numbering)
# ================================================================
# VOP1 (single-dword) — bits 16-9 opcode.
var GFX9_VOP1_V_MOV_B32     = 0x01;
var GFX9_VOP1_V_CVT_F32_I32 = 0x05;
var GFX9_VOP1_V_CVT_I32_F32 = 0x08;
var GFX9_VOP1_V_SQRT_F32    = 0x27;   # GLSL.std.450 Sqrt (N.8b)
var GFX9_VOP1_V_FLOOR_F32   = 0x1F;   # GLSL.std.450 Floor (N.8b)
# Integer-division reciprocal primitives (N.9 — float-reciprocal udiv). llvm-mc-verified.
var GFX9_VOP1_V_CVT_F32_U32 = 0x06;   # (f32)u32
var GFX9_VOP1_V_CVT_U32_F32 = 0x07;   # (u32)f32, saturating
var GFX9_VOP1_V_RCP_IFLAG_F32 = 0x23; # 1/x approx (iflag — the integer-div variant)
# v3.2 F.7b — f64 conversions (VOP1). f64 dst/src name the EVEN reg of a pair; the f32/i32
# side is a single reg. All llvm-mc gfx900-verified.
var GFX9_VOP1_V_CVT_F64_F32 = 0x10;   # widen: (f64)f32
var GFX9_VOP1_V_CVT_F32_F64 = 0x0F;   # narrow: (f32)f64
var GFX9_VOP1_V_CVT_F64_I32 = 0x04;   # (f64)i32
var GFX9_VOP1_V_CVT_I32_F64 = 0x03;   # (i32)f64
var GFX9_VOP1_V_CVT_F64_U32 = 0x16;   # (f64)u32
var GFX9_VOP1_V_CVT_U32_F64 = 0x15;   # (u32)f64
# v3.2 F.7f.6 — f64 reciprocal seed (VOP1). Raw v_rcp_f64 is an ~f32-precision
# APPROXIMATION (HW-proven F.7f.5) — usable ONLY as the seed of the FDiv
# Newton-refinement macro, never as a standalone op. llvm-mc gfx900-verified.
var GFX9_VOP1_V_RCP_F64     = 0x25;   # 1/x approx (f64 seed; refine with v_fma_f64)
# v3.2 F.7f.7 — f64 reciprocal-sqrt seed (VOP1). Like v_rcp_f64, an ~f32-precision APPROXIMATION
# usable ONLY as the seed of the FSqrt Newton-Goldschmidt macro. llvm-mc gfx900-verified.
var GFX9_VOP1_V_RSQ_F64     = 0x26;   # 1/sqrt(x) approx (f64 seed)

# VOP2 (single-dword) — bits 30-25 opcode. (llvm-mc gfx900-verified, N.5a.)
var GFX9_VOP2_V_CNDMASK_B32 = 0x00;   # d = vcc ? vsrc1 : src0 (VCC implicit) — N.9 udiv
var GFX9_VOP2_V_ADD_F32     = 0x01;
var GFX9_VOP2_V_SUB_F32     = 0x02;
var GFX9_VOP2_V_SUBREV_F32  = 0x03;   # D = vsrc1 - src0 (subtrahend in src0)
var GFX9_VOP2_V_MUL_F32     = 0x05;
var GFX9_VOP2_V_MIN_F32     = 0x0A;   # GLSL.std.450 FMin (N.8b)
var GFX9_VOP2_V_MAX_F32     = 0x0B;   # GLSL.std.450 FMax (N.8b)
var GFX9_VOP2_V_ASHRREV_I32 = 0x11;   # arithmetic >> (sign-extend); N.9d signed div
var GFX9_VOP2_V_LSHRREV_B32 = 0x10;
var GFX9_VOP2_V_LSHLREV_B32 = 0x12;
var GFX9_VOP2_V_AND_B32     = 0x13;
var GFX9_VOP2_V_OR_B32      = 0x14;
var GFX9_VOP2_V_XOR_B32     = 0x15;
var GFX9_VOP2_V_ADD_U32     = 0x34;
var GFX9_VOP2_V_SUB_U32     = 0x35;
var GFX9_VOP2_V_SUBREV_U32  = 0x36;   # D = vsrc1 - src0 (subtrahend in src0)

# VOPC (single-dword) — vector compare → VCC. bits 24-17 opcode. (N.7c, divergent
# control flow.) llvm-mc gfx900-verified; consecutive u32 forms.
var GFX9_VOPC_V_CMP_LT_U32  = 0xC9;
var GFX9_VOPC_V_CMP_EQ_U32  = 0xCA;
var GFX9_VOPC_V_CMP_LE_U32  = 0xCB;
var GFX9_VOPC_V_CMP_GT_U32  = 0xCC;
var GFX9_VOPC_V_CMP_NE_U32  = 0xCD;
var GFX9_VOPC_V_CMP_GE_U32  = 0xCE;
# Signed i32 vector compares (N.8b-4). llvm-mc gfx900-verified.
var GFX9_VOPC_V_CMP_LT_I32  = 0xC1;
var GFX9_VOPC_V_CMP_LE_I32  = 0xC3;
var GFX9_VOPC_V_CMP_GT_I32  = 0xC4;
var GFX9_VOPC_V_CMP_GE_I32  = 0xC6;
# v3.2 F.7f.7 — f64 vector compares (→ VCC), the FSqrt macro's subnormal gate + special-case
# classifier. CMP_GT_F64: ordered greater-than. CMP_CLASS_F64: src1 is a 10-bit class bitmask
# (per-bit: sNaN/qNaN/-inf/-norm/-sub/-0/+0/+sub/+norm/+inf) → VCC if x is in any set class.
# Both reuse gfx9_enc_vopc (f64 operands name the pair's low reg). llvm-mc gfx900-verified.
var GFX9_VOPC_V_CMP_GT_F64    = 0x64;
var GFX9_VOPC_V_CMP_CLASS_F64 = 0x12;
# v3.2 F.7f.8 — the ORDERED f64 compares (false if either operand is NaN) for OpFOrd* → bool. The
# set is contiguous 0x61..0x66; reuse the VOPC encoder + _emit_vopc (the f64 pair names its low reg).
# llvm-mc gfx900-verified. (The unordered OpFUnord* compares are the separate 0x69.. set, not wired;
# tracked in docs/development/3-2-punchlist.md under the F.7f.8 follow-ups.)
var GFX9_VOPC_V_CMP_LT_F64    = 0x61;   # ordered <
var GFX9_VOPC_V_CMP_EQ_F64    = 0x62;   # ordered ==
var GFX9_VOPC_V_CMP_LE_F64    = 0x63;   # ordered <=
var GFX9_VOPC_V_CMP_LG_F64    = 0x65;   # ordered != (less-greater)
var GFX9_VOPC_V_CMP_GE_F64    = 0x66;   # ordered >=

# VOP3a (two-dword) — bits 25-16 opcode (10-bit).
var GFX9_VOP3_V_BFE_U32     = 0x1C8;
var GFX9_VOP3_V_ADD3_U32    = 0x1FF;
var GFX9_VOP3_V_OR3_B32     = 0x202;
var GFX9_VOP3_V_MUL_LO_U32  = 0x285;   # VOP3-only on GFX9 (no VOP2 form); llvm-mc-verified
var GFX9_VOP3_V_MUL_HI_U32  = 0x286;   # high 32 bits of u32*u32 (N.9 udiv Newton step)
var GFX9_VOP3_V_FMA_F32     = 0x1CB;   # GLSL.std.450 Fma (3-src); llvm-mc-verified
var GFX9_VOP3_V_FMA_F64     = 0x1CC;   # f64 a*b+c (3-src, 64-bit VGPR pairs); llvm-mc gfx900-verified (v3.2 F.4)
var GFX9_VOP3_V_MED3_F32    = 0x1D6;   # GLSL.std.450 FClamp = median-of-3; llvm-mc-verified
# v3.2 F.7f.8 — bit-field insert: d = (s0 & s1) | (~s0 & s2). With s0 a 0/-1 mask, bfi(mask, x, y)
# is a branchless select (mask ? x : y) per 32-bit lane — the OpSelect primitive (no VCC needed).
var GFX9_VOP3_V_BFI_B32     = 0x1CA;   # llvm-mc gfx900-verified
# v3.2 F.7b — f64 ALU (VOP3, 64-bit VGPR pairs; src/dst name the EVEN reg of each pair).
# All llvm-mc gfx900-verified. GFX9 has no V_SUB_F64 (use V_ADD_F64 + a negate src-mod) and
# no V_ABS_F64 (sign-bit clear / abs src-mod); FDiv/FSqrt are multi-instruction macros — those
# land with their isel/lowering logic in the F.7 breadth bites, not here.
var GFX9_VOP3_V_ADD_F64     = 0x280;   # f64 a + b
var GFX9_VOP3_V_MUL_F64     = 0x281;   # f64 a * b
var GFX9_VOP3_V_MIN_F64     = 0x282;   # GLSL.std.450 FMin (f64)
var GFX9_VOP3_V_MAX_F64     = 0x283;   # GLSL.std.450 FMax (f64)
# v3.2 F.7f.6 — f64 correctly-rounded division macro ops (the LLVM gfx900 fdiv
# expansion). V_DIV_SCALE_F64 is VOP3B: it writes a second SGPR-pair output
# (the divide-scale flag VCC) in lo[14:8], so it needs gfx9_enc_vop3b_lo.
# V_DIV_FMAS_F64 reads VCC implicitly; V_DIV_FIXUP_F64 is the rounding fixup.
# All llvm-mc gfx900-verified. Macro lowering lives in gfx9_compile.cyr (F.7f.6b).
var GFX9_VOP3_V_DIV_SCALE_F64 = 0x1E1; # VOP3B: scale operand, sets VCC scale-flag
var GFX9_VOP3_V_DIV_FMAS_F64  = 0x1E3; # fma + scale (reads VCC)
var GFX9_VOP3_V_DIV_FIXUP_F64 = 0x1DF; # correctly-rounding division fixup
# v3.2 F.7f.7 — f64 sqrt macro: ldexp scales x by 2^exp (the subnormal scale-up + result rescale).
# VOP3 2-src (src0 = f64 pair, src1 = i32 exponent VGPR); reuses gfx9_enc_vop3a_lo/hi. llvm-mc-verified.
var GFX9_VOP3_V_LDEXP_F64     = 0x284; # x * 2^n  (f64, i32)

# SOP2 (single-dword) — bits 29-23 opcode. (llvm-mc gfx900-verified, N.5a.)
var GFX9_SOP2_S_ADD_U32     = 0x00;
var GFX9_SOP2_S_ADD_I32     = 0x02;
var GFX9_SOP2_S_SUB_I32     = 0x03;
var GFX9_SOP2_S_ADDC_U32    = 0x04;
var GFX9_SOP2_S_AND_B32     = 0x0C;
var GFX9_SOP2_S_OR_B32      = 0x0E;
var GFX9_SOP2_S_XOR_B32     = 0x10;
var GFX9_SOP2_S_LSHL_B32    = 0x1C;
var GFX9_SOP2_S_LSHR_B32    = 0x1E;
var GFX9_SOP2_S_ASHR_I32    = 0x20;   # arithmetic >> (sign-extend); N.9d signed div
var GFX9_SOP2_S_MUL_I32     = 0x24;
# 64-bit EXEC-mask ops for divergent control flow (N.7). llvm-mc gfx900-verified.
var GFX9_SOP2_S_OR_B64      = 0x0F;
var GFX9_SOP2_S_ANDN2_B64   = 0x13;

# SOP1 (single-dword) — bits 15-8 opcode.
var GFX9_SOP1_S_MOV_B32           = 0x00;
var GFX9_SOP1_S_MOV_B64           = 0x01;   # N.7: save/restore EXEC (64-bit)
var GFX9_SOP1_S_AND_SAVEEXEC_B64  = 0x20;   # N.7: divergent if — mask EXEC, save old

# SOPP (single-dword) — bits 22-16 opcode.
var GFX9_SOPP_S_NOP             = 0x00;
var GFX9_SOPP_S_ENDPGM          = 0x01;
var GFX9_SOPP_S_BRANCH          = 0x02;   # N.7: unconditional PC-relative branch
var GFX9_SOPP_S_CBRANCH_SCC0    = 0x04;   # N.7: branch if SCC == 0 (uniform)
var GFX9_SOPP_S_CBRANCH_SCC1    = 0x05;   # N.7: branch if SCC == 1 (uniform)
var GFX9_SOPP_S_CBRANCH_EXECZ   = 0x08;   # N.7: branch if EXEC == 0 (divergent skip)
var GFX9_SOPP_S_CBRANCH_EXECNZ  = 0x09;
var GFX9_SOPP_S_WAITCNT         = 0x0C;

# SOPC (single-dword) — scalar compare, sets SCC. bits 22-16 opcode. The u32
# compares the uniform-branch path needs (signed i32 variants are 0x00..0x05).
var GFX9_SOPC_S_CMP_EQ_U32  = 0x06;
var GFX9_SOPC_S_CMP_LG_U32  = 0x07;   # "lg" = not-equal
var GFX9_SOPC_S_CMP_GT_U32  = 0x08;
var GFX9_SOPC_S_CMP_GE_U32  = 0x09;
var GFX9_SOPC_S_CMP_LT_U32  = 0x0A;
var GFX9_SOPC_S_CMP_LE_U32  = 0x0B;
# Signed i32 scalar compares (N.8b-4). llvm-mc gfx900-verified.
var GFX9_SOPC_S_CMP_GT_I32  = 0x02;
var GFX9_SOPC_S_CMP_GE_I32  = 0x03;
var GFX9_SOPC_S_CMP_LT_I32  = 0x04;
var GFX9_SOPC_S_CMP_LE_I32  = 0x05;

# GFX9 special scalar registers (operand codes).
var GFX9_REG_EXEC_LO = 126;   # EXEC pair s[126:127]; the 64-bit ops name EXEC_LO
var GFX9_REG_VCC_LO  = 106;   # VCC pair s[106:107]; v_cmp writes it, s_and_saveexec reads it

# SMEM (two-dword) — bits 25-18 opcode.
var GFX9_SMEM_S_LOAD_DWORD   = 0x00;
var GFX9_SMEM_S_LOAD_DWORDX2 = 0x01;
var GFX9_SMEM_S_LOAD_DWORDX4 = 0x02;
var GFX9_SMEM_S_LOAD_DWORDX8 = 0x03;

# FLAT/global (two-dword) — bits 24-18 opcode.
var GFX9_FLAT_GLOBAL_LOAD_DWORD   = 0x14;   # llvm-mc-verified
var GFX9_FLAT_GLOBAL_LOAD_DWORDX2 = 0x15;   # 2 dwords (an f64 / vec2) per lane; llvm-mc-verified
var GFX9_FLAT_GLOBAL_STORE_DWORD  = 0x1C;
var GFX9_FLAT_GLOBAL_STORE_DWORDX2 = 0x1D;  # 2-dword store (f64); llvm-mc gfx900-verified (v3.2 F.4)

# ================================================================
# VOP1 — vector ALU, one source.   0x7E000000 | vdst<<17 | op<<9 | src0
# ================================================================
# Marker bits 31-25 = 0b0111111. Reproduces e.g. v_mov_b32 v0,s0 = 0x7E000200.
fn gfx9_enc_vop1(op, vdst, src0): i64 {
    return 0x7E000000 | ((vdst & 0xFF) << 17) | ((op & 0xFF) << 9) | (src0 & 0x1FF);
}

# ================================================================
# VOP2 — vector ALU, two sources.  op<<25 | vdst<<17 | vsrc1<<9 | src0
# ================================================================
# Marker bit 31 = 0. src0 is the full 9-bit operand (SGPR/VGPR/inline/literal);
# vsrc1 is always a VGPR (8-bit index). Reproduces v_lshlrev_b32 v2,1,v0 =
# 0x24040081 and v_mul_f32 v2,s12,v2 = 0x0A04040C.
fn gfx9_enc_vop2(op, vdst, src0, vsrc1): i64 {
    return ((op & 0x3F) << 25) | ((vdst & 0xFF) << 17) | ((vsrc1 & 0xFF) << 9) | (src0 & 0x1FF);
}

# ================================================================
# VOPC — vector compare → VCC.   0x7C000000 | op<<17 | vsrc1<<9 | src0
# ================================================================
# Marker bits 31-25 = 0b0111110. The result is the implicit VCC mask (no vdst).
# src0 is the full 9-bit operand (VGPR/inline); vsrc1 is an 8-bit VGPR index. To
# compare a VGPR against a constant, put the constant in src0 and flip the predicate
# (e.g. `v < 8` ⇒ v_cmp_gt_u32 vcc, 8, v). Reproduces v_cmp_lt_u32 vcc,v1,v2 =
# 0x7D920501 and v_cmp_lt_u32 vcc,8,v2 = 0x7D920488.
fn gfx9_enc_vopc(op, src0, vsrc1): i64 {
    return 0x7C000000 | ((op & 0xFF) << 17) | ((vsrc1 & 0xFF) << 9) | (src0 & 0x1FF);
}

# ================================================================
# VOP3a — vector ALU, three sources (two dwords).
# ================================================================
# Word 0: 0xD0000000 | op<<16 | vdst   (clamp/opsel/abs = 0 for the MVP).
# Word 1: src2<<18 | src1<<9 | src0     (omod/neg = 0).
# Marker bits 31-26 = 0b110100. Reproduces v_add3_u32 v8,v8,v9,v10 =
# 0xD1FF0008 / 0x042A1308.
fn gfx9_enc_vop3a_lo(op, vdst): i64 {
    return 0xD0000000 | ((op & 0x3FF) << 16) | (vdst & 0xFF);
}

fn gfx9_enc_vop3a_hi(src0, src1, src2): i64 {
    return ((src2 & 0x1FF) << 18) | ((src1 & 0x1FF) << 9) | (src0 & 0x1FF);
}
# VOP3B lo dword — same as VOP3A but carries a second (scalar) destination in
# bits[14:8]: the SGPR-pair / VCC output that v_div_scale_f64 writes. The hi
# dword reuses gfx9_enc_vop3a_hi (src0/src1/src2 + modifiers). F.7f.6.
fn gfx9_enc_vop3b_lo(op, sdst, vdst): i64 {
    return 0xD0000000 | ((op & 0x3FF) << 16) | ((sdst & 0x7F) << 8) | (vdst & 0xFF);
}

# ================================================================
# SOP2 — scalar ALU, two sources.  0x80000000 | op<<23 | sdst<<16 | ssrc1<<8 | ssrc0
# ================================================================
# Marker bits 31-30 = 0b10. ssrc0/ssrc1 are 8-bit (SGPR or inline constant);
# inline 0 = 128. Reproduces s_mul_i32 s8,s7,s4 = 0x92080407 and
# s_addc_u32 s13,s1,0 = 0x820D8001.
fn gfx9_enc_sop2(op, sdst, ssrc0, ssrc1): i64 {
    return 0x80000000 | ((op & 0x7F) << 23) | ((sdst & 0x7F) << 16) | ((ssrc1 & 0xFF) << 8) | (ssrc0 & 0xFF);
}

# ================================================================
# SOP1 — scalar ALU, one source.  0xBE800000 | sdst<<16 | op<<8 | ssrc0
# ================================================================
# Marker bits 31-23 = 0b101111101. ssrc0 is 8-bit (SGPR or inline). Reproduces
# s_mov_b32 s8,s6 = 0xBE880006.
fn gfx9_enc_sop1(op, sdst, ssrc0): i64 {
    return 0xBE800000 | ((sdst & 0x7F) << 16) | ((op & 0xFF) << 8) | (ssrc0 & 0xFF);
}

# ================================================================
# SOPP — scalar program control.  0xBF800000 | op<<16 | simm16
# ================================================================
# Marker bits 31-23 = 0b101111111. Reproduces s_endpgm = 0xBF810000,
# s_nop 0 = 0xBF800000, s_waitcnt vmcnt(0) lgkmcnt(0) = 0xBF8C0070.
fn gfx9_enc_sopp(op, simm16): i64 {
    return 0xBF800000 | ((op & 0x7F) << 16) | (simm16 & 0xFFFF);
}

# ================================================================
# SOPC — scalar compare (sets SCC).  0xBF000000 | op<<16 | ssrc1<<8 | ssrc0
# ================================================================
# Marker bits 31-23 = 0b101111110. ssrc0/ssrc1 are 8-bit (SGPR or inline; inline
# 0 = 128). Reproduces s_cmp_eq_u32 s2,s3 = 0xBF060302 and s_cmp_eq_u32 s2,0 =
# 0xBF068002. SCC is then the branch predicate for s_cbranch_scc0/scc1.
fn gfx9_enc_sopc(op, ssrc0, ssrc1): i64 {
    return 0xBF000000 | ((op & 0x7F) << 16) | ((ssrc1 & 0xFF) << 8) | (ssrc0 & 0xFF);
}

# ================================================================
# SMEM — scalar memory load (two dwords).
# ================================================================
# Word 0: 0xC0000000 | op<<18 | IMM(1)<<17 | glc<<16 | sdata<<6 | sbase
# Word 1: the immediate byte offset.
# `sbase` is the SBASE FIELD = (base SGPR index >> 1) (SMEM bases are SGPR
# pairs). `sdata` is the destination SGPR index. IMM is always 1 (immediate
# offset form). Reproduces s_load_dwordx8 s[0:7],s[0:1],0x0 = 0xC00E0000 and
# s_load_dwordx2 s[12:13],s[0:1],0x30 = 0xC0060300 / 0x30.
fn gfx9_enc_smem_lo(op, sdata, sbase, glc): i64 {
    return 0xC0000000 | ((op & 0xFF) << 18) | (1 << 17) | ((glc & 1) << 16) | ((sdata & 0x7F) << 6) | (sbase & 0x3F);
}

# ================================================================
# FLAT (global segment) — vector memory (two dwords).
# ================================================================
# Word 0: 0xDC000000 | op<<18 | slc<<17 | glc<<16 | seg<<14 | offset(13-bit)
# Word 1: vdst<<24 | saddr<<16 | data<<8 | vaddr
# For a global op pass seg = GFX9_FLAT_SEG_GLOBAL and saddr = GFX9_SADDR_OFF
# (off → address comes wholly from the v[addr:addr+1] VGPR pair). `data` is
# the store-source VGPR (stores) and `vdst` the load-dest VGPR (loads).
# Reproduces global_store_dword v[0:1],v2,off glc slc = 0xDC738000 / 0x007F0200
# and global_load_dwordx2 v[4:5],v[0:1],off = 0xDC548000 / 0x047F0000.
fn gfx9_enc_flat_lo(op, seg, offset, glc, slc): i64 {
    var w = 0xDC000000 | ((op & 0x7F) << 18) | ((slc & 1) << 17) | ((glc & 1) << 16);
    return w | ((seg & 3) << 14) | (offset & 0x1FFF);
}

fn gfx9_enc_flat_hi(vdst, saddr, data, vaddr): i64 {
    return ((vdst & 0xFF) << 24) | ((saddr & 0x7F) << 16) | ((data & 0xFF) << 8) | (vaddr & 0xFF);
}

# ================================================================
# Emit helpers — store an encoded dword into an ISA stream and advance.
# ================================================================
# The N.5 compiler encode stage and the (refactored) hand-authored shader
# builders both lay down a contiguous GFX9 ISA byte stream. gfx9_emit32 stores
# one dword at `pos` and returns the next write position (pos + 4) — the
# running-position idiom that replaces manual `buf + pos + N` offset math.
fn gfx9_emit32(buf, pos, dword): i64 {
    store32(buf + pos, dword);
    return pos + 4;
}

# Append the AMDGPU-mandated 16 × s_nop 0 prefetch padding (64 bytes) that
# every GFX9 shader needs after s_endpgm: the CP prefetches past the program
# end, and without the pad it can fetch into an unmapped page. Returns
# pos + 64. (Lifted from the identical loop duplicated in every shader builder.)
fn gfx9_emit_prefetch_pad(buf, pos): i64 {
    var p = pos;
    var i = 0;
    while (i < 16) {
        p = gfx9_emit32(buf, p, gfx9_enc_sopp(GFX9_SOPP_S_NOP, 0));
        i = i + 1;
    }
    return p;
}

# --- spirv_parse.cyr ---

# @internal — SPIR-V word-stream parser (Phase N.1, the compiler's front end)
# spirv_parse.cyr — header validation + instruction iterator + module probes
#
# Stage N.1 of the in-tree SPIR-V → GFX9 compute compiler
# (docs/proposals/v3.2-spirv-gfx9-native-lowering.md). A compiler ingests
# FULLY UNTRUSTED bytes — a consumer's toolchain produced the SPIR-V — so
# structural validation is the first audit gate: every field is bounds-checked
# before use, and a malformed stream is rejected (never walked into UB).
#
# SPIR-V is a u32 word stream (SPIR-V spec §2.3): a 5-word header
#   [0] magic 0x07230203   [1] version   [2] generator   [3] id-bound
#   [4] schema (reserved, 0)
# followed by instructions, each led by a word whose low 16 bits are the opcode
# and whose high 16 bits are the word count (INCLUDING the leading word).
#
# N.1a (this file's first cut) provides: header accessors, the
# (opcode, wordcount) decode, a whole-stream validator (the rejection gate),
# instruction counting, and entry-point / LocalSize probes. The type /
# constant / decoration LOOKUP TABLES (the SSA model N.2 lowers from) land at
# N.1b. Reuses MABDA_SPIRV_MAGIC + `_spirv_validate` (the Phase S header check
# in wgpu_descriptors.cyr) — this module is included after it. Pure byte
# walking: no syscalls, no allocation.

# ================================================================
# SPIR-V opcodes (the subset N.1 references; SPIR-V spec §3.37)
# ================================================================
var SPIRV_OP_MEMORY_MODEL   = 14;
var SPIRV_OP_ENTRY_POINT    = 15;
var SPIRV_OP_EXECUTION_MODE = 16;
var SPIRV_OP_CAPABILITY     = 17;
var SPIRV_OP_FUNCTION       = 54;
var SPIRV_OP_FUNCTION_END   = 56;
var SPIRV_OP_LABEL          = 248;

# Execution model (OpEntryPoint word 1) + execution mode (OpExecutionMode word 2)
var SPIRV_EXEC_MODEL_GLCOMPUTE = 5;
var SPIRV_EXEC_MODE_LOCAL_SIZE = 17;

# OpCapability operand for double-precision floats (SPIR-V spec, Capability). A module that
# computes in f64 declares `OpCapability Float64`; v3.2 F.3 keys the f64 shader gate on it.
var SPIRV_CAPABILITY_FLOAT64   = 10;

# The header is 5 words (20 bytes); instructions begin at word index 5.
var SPIRV_HEADER_WORDS = 5;

# Parse result codes. Header errors 1-6 PASS THROUGH from `_spirv_validate`
# (1 too-short, 2 unaligned, 3 bad-magic, 4 byte-swapped, 5 id-bound-bad,
# 6 over-cap). Instruction-stream errors use a disjoint 10+ range.
var SPIRV_PARSE_OK          = 0;
var SPIRV_PARSE_ERR_ZERO_WC = 10;   # an instruction declared word count 0 (would not advance)
var SPIRV_PARSE_ERR_TRUNC   = 11;   # an instruction's words run past the end of the stream

# ================================================================
# Word + instruction-header accessors
# ================================================================
fn spirv_word(ptr, idx): i64 {
    return load32(ptr + idx * 4);
}

fn spirv_hdr_magic(ptr): i64 {
    return spirv_word(ptr, 0);
}

fn spirv_hdr_version(ptr): i64 {
    return spirv_word(ptr, 1);
}

fn spirv_hdr_generator(ptr): i64 {
    return spirv_word(ptr, 2);
}

fn spirv_hdr_id_bound(ptr): i64 {
    return spirv_word(ptr, 3);
}

fn spirv_hdr_schema(ptr): i64 {
    return spirv_word(ptr, 4);
}

# Opcode = low 16 bits of an instruction's leading word.
fn spirv_op(word0): i64 {
    return word0 & 0xFFFF;
}

# Word count (incl. the leading word) = high 16 bits. `>>` is logical on i64
# (feedback_cyrius_logical_right_shift) and load32 zero-extends, so no masking
# of sign bits is needed before the &.
fn spirv_op_wordcount(word0): i64 {
    return (word0 >> 16) & 0xFFFF;
}

# ================================================================
# The rejection gate — validate the WHOLE stream before any walk
# ================================================================
# Header via `_spirv_validate`, then every instruction: word count must be >= 1
# (a 0 would loop forever) and the instruction's words must not run past the
# end. Returns SPIRV_PARSE_OK or the first error encountered. Call this before
# any of the probe/walk fns below — they assume a validated stream.
fn spirv_validate_stream(ptr, byte_len): i64 {
    var hv = _spirv_validate(ptr, byte_len);
    if (hv != 0) { return hv; }
    var total = byte_len / 4;
    var off = SPIRV_HEADER_WORDS;
    while (off < total) {
        var wc = spirv_op_wordcount(spirv_word(ptr, off));
        if (wc == 0) { return SPIRV_PARSE_ERR_ZERO_WC; }
        if (off + wc > total) { return SPIRV_PARSE_ERR_TRUNC; }
        off = off + wc;
    }
    return SPIRV_PARSE_OK;
}

# ================================================================
# Probes (assume a validated stream)
# ================================================================
# Count instructions. Self-guards: returns -1 if the stream is malformed, so it
# is safe to call without a prior validate.
fn spirv_count_instructions(ptr, byte_len): i64 {
    if (spirv_validate_stream(ptr, byte_len) != 0) { return 0 - 1; }
    var total = byte_len / 4;
    var off = SPIRV_HEADER_WORDS;
    var n = 0;
    while (off < total) {
        off = off + spirv_op_wordcount(spirv_word(ptr, off));
        n = n + 1;
    }
    return n;
}

# The GLCompute entry point's target <id>, or -1 if there is no OpEntryPoint
# with the GLCompute execution model. Layout (SPIR-V spec OpEntryPoint):
#   word0 | ExecutionModel (word1) | entry <id> (word2) | name... | iface...
# The wc >= 3 guard keeps the word1/word2 reads inside the instruction even if a
# (validated-but-odd) stream carries a short OpEntryPoint.
# v3.2 F.3 — does this module compute in f64? Scans for `OpCapability Float64` — the
# spec-MANDATED marker for f64 (SPIR-V §2.4: a module using the Float64 type MUST declare it),
# so detecting the capability is the correct conformant-input signal. (A non-conformant module
# that uses 64-bit OpTypeFloat WITHOUT the capability would slip this gate, but is then caught
# downstream by _mir_lower_type rejecting the 64-bit float type — defense in depth.) Runs on
# untrusted bytes (the shader-create f64 gate, BEFORE full validation), so it bounds the stream,
# breaks on a zero word-count, and stops before a truncated instruction's operands. 1 if f64.
fn spirv_uses_f64(ptr, byte_len): i64 {
    var total = byte_len / 4;
    var off = SPIRV_HEADER_WORDS;
    while (off < total) {
        var w0 = spirv_word(ptr, off);
        var wc = spirv_op_wordcount(w0);
        if (wc == 0) { return 0; }
        # A truncated instruction (its words run past the stream) is malformed — stop before
        # reading an operand past the buffer (this runs on untrusted bytes pre-validation, and
        # also covers a non-multiple-of-4 byte_len, where total = byte_len/4 floors). F.3 review.
        if (off + wc > total) { return 0; }
        if (spirv_op(w0) == SPIRV_OP_CAPABILITY) {
            if (wc >= 2) {
                if (spirv_word(ptr, off + 1) == SPIRV_CAPABILITY_FLOAT64) { return 1; }
            }
        }
        off = off + wc;
    }
    return 0;
}

fn spirv_find_entry_point(ptr, byte_len): i64 {
    var total = byte_len / 4;
    var off = SPIRV_HEADER_WORDS;
    while (off < total) {
        var w0 = spirv_word(ptr, off);
        var wc = spirv_op_wordcount(w0);
        if (wc == 0) { return 0 - 1; }
        if (off + wc > total) { return 0 - 1; }   # truncated instruction — operand reads would OOB
        if (spirv_op(w0) == SPIRV_OP_ENTRY_POINT) {
            if (wc >= 3) {
                if (spirv_word(ptr, off + 1) == SPIRV_EXEC_MODEL_GLCOMPUTE) {
                    return spirv_word(ptr, off + 2);
                }
            }
        }
        off = off + wc;
    }
    return 0 - 1;
}

# Find the LocalSize execution mode for `entry_id`: writes x/y/z (3 × i64) to
# `out_xyz` and returns 1, or returns 0 (out_xyz untouched) if absent. Layout:
#   word0 | entry <id> (word1) | mode (word2) | x (word3) y (word4) z (word5)
# The wc >= 6 guard keeps the x/y/z reads inside the instruction.
fn spirv_find_local_size(ptr, byte_len, entry_id, out_xyz): i64 {
    var total = byte_len / 4;
    var off = SPIRV_HEADER_WORDS;
    while (off < total) {
        var w0 = spirv_word(ptr, off);
        var wc = spirv_op_wordcount(w0);
        if (wc == 0) { return 0; }
        if (off + wc > total) { return 0; }   # truncated instruction — x/y/z reads would OOB
        if (spirv_op(w0) == SPIRV_OP_EXECUTION_MODE) {
            if (wc >= 6) {
                if (spirv_word(ptr, off + 1) == entry_id) {
                    if (spirv_word(ptr, off + 2) == SPIRV_EXEC_MODE_LOCAL_SIZE) {
                        store64(out_xyz + 0, spirv_word(ptr, off + 3));
                        store64(out_xyz + 8, spirv_word(ptr, off + 4));
                        store64(out_xyz + 16, spirv_word(ptr, off + 5));
                        return 1;
                    }
                }
            }
        }
        off = off + wc;
    }
    return 0;
}

# ================================================================
# Phase N.1b — type / constant / decoration lookup tables
# ================================================================
# The SSA module model N.2 lowers from. Each table is a CALLER-PROVIDED buffer
# of `id_bound` fixed-size records indexed directly by SPIR-V <id> (ids are
# dense and < id_bound, so direct indexing beats a hashmap AND keeps callers/
# tests stack-based — no bump-allocator pressure). The build fns ASSUME a
# validated stream (call spirv_validate_stream first); they self-initialize
# their buffer and bail (-1) if a zero-word-count instruction slips through.

# Type-defining opcodes — the result <id> is word 1 for all of them.
var SPIRV_OP_TYPE_VOID          = 19;
var SPIRV_OP_TYPE_BOOL          = 20;
var SPIRV_OP_TYPE_INT           = 21;
var SPIRV_OP_TYPE_FLOAT         = 22;
var SPIRV_OP_TYPE_VECTOR        = 23;
var SPIRV_OP_TYPE_ARRAY         = 28;
var SPIRV_OP_TYPE_RUNTIME_ARRAY = 29;
var SPIRV_OP_TYPE_STRUCT        = 30;
var SPIRV_OP_TYPE_POINTER       = 32;
var SPIRV_OP_TYPE_FUNCTION      = 33;
var SPIRV_OP_CONSTANT           = 43;
var SPIRV_OP_VARIABLE           = 59;
var SPIRV_OP_DECORATE           = 71;

# Decoration operands (OpDecorate word 2).
var SPIRV_DECO_BINDING        = 33;
var SPIRV_DECO_DESCRIPTOR_SET = 34;

# Type-table record kinds (slot 0 of a type record; 0 = id is not a type).
var SPIRV_TYK_NONE          = 0;
var SPIRV_TYK_VOID          = 1;
var SPIRV_TYK_BOOL          = 2;
var SPIRV_TYK_INT           = 3;   # p0 = width, p1 = signedness
var SPIRV_TYK_FLOAT         = 4;   # p0 = width
var SPIRV_TYK_VECTOR        = 5;   # p0 = component type <id>, p1 = count
var SPIRV_TYK_ARRAY         = 6;   # p0 = element type <id>, p1 = length <id>
var SPIRV_TYK_RUNTIME_ARRAY = 7;   # p0 = element type <id>
var SPIRV_TYK_STRUCT        = 8;   # p0 = member count, p1 = first member type <id>
var SPIRV_TYK_POINTER       = 9;   # p0 = storage class, p1 = pointee type <id>
var SPIRV_TYK_FUNCTION      = 10;  # p0 = return type <id>

# Record sizes (bytes). Caller sizes each table buffer to >= `cap` records and
# passes `cap` so the builder can reject a SPIR-V `id_bound` (UNTRUSTED, from the
# header) that would write past it. The validate gate only caps `id_bound` at a
# loose 0x40000000, unrelated to the caller's fixed buffer — without `cap` a
# crafted oversized `id_bound` silently corrupts memory (the `memset` below and
# every per-id write index by `id`). N-HARDEN.1 (found via N.5g adversarial review).
var SPIRV_TYPE_REC  = 24;   # [kind, p0, p1]
var SPIRV_CONST_REC = 16;   # [result-type <id>, value]
var SPIRV_DECO_REC  = 16;   # [binding, descriptor-set]  (-1 = absent)

# Builder error: a SPIR-V <id> / id_bound exceeds the caller's table capacity.
# Distinct from the malformed-stream `-1` so the driver can surface "module too
# large for the configured tables" separately from "bad bytes".
var SPIRV_ERR_ID_CAP = 2;

# ---- type table ----
# Guarded write: skip id 0 (unused in SPIR-V) and any id >= cap (a malformed
# stream whose result <id> exceeds the declared id_bound — defense in depth on
# top of the id_bound > cap gate the builders apply up front).
fn _spirv_set_type(out, id, kind, p0, p1, cap): i64 {
    if (id <= 0) { return 0; }
    if (id >= cap) { return 0; }
    var base = out + id * SPIRV_TYPE_REC;
    store64(base + 0, kind);
    store64(base + 8, p0);
    store64(base + 16, p1);
    return 0;
}

# Build the type table: out[id] = (kind, p0, p1) for every OpType* in the
# stream. Returns 0, -1 on a malformed (zero-wc) instruction, or
# -SPIRV_ERR_ID_CAP if id_bound exceeds the caller's `cap`-record table. Per-op
# `wc` guards keep operand reads inside the instruction (a compiler ingests
# untrusted input). `a` = word 2, `b` = word 3 (read only when wc allows).
fn spirv_build_type_table(ptr, byte_len, id_bound, cap, out): i64 {
    if (id_bound > cap) { return 0 - SPIRV_ERR_ID_CAP; }
    memset(out, 0, id_bound * SPIRV_TYPE_REC);
    var total = byte_len / 4;
    var off = SPIRV_HEADER_WORDS;
    while (off < total) {
        var w0 = spirv_word(ptr, off);
        var wc = spirv_op_wordcount(w0);
        if (wc == 0) { return 0 - 1; }
        var op = spirv_op(w0);
        if (wc >= 2) {
            var id = spirv_word(ptr, off + 1);
            var a = 0;
            var b = 0;
            if (wc >= 3) { a = spirv_word(ptr, off + 2); }
            if (wc >= 4) { b = spirv_word(ptr, off + 3); }
            if (op == SPIRV_OP_TYPE_VOID) { _spirv_set_type(out, id, SPIRV_TYK_VOID, 0, 0, cap); }
            if (op == SPIRV_OP_TYPE_BOOL) { _spirv_set_type(out, id, SPIRV_TYK_BOOL, 0, 0, cap); }
            if (op == SPIRV_OP_TYPE_FLOAT) {
                if (wc >= 3) { _spirv_set_type(out, id, SPIRV_TYK_FLOAT, a, 0, cap); }
            }
            if (op == SPIRV_OP_TYPE_FUNCTION) {
                if (wc >= 3) { _spirv_set_type(out, id, SPIRV_TYK_FUNCTION, a, 0, cap); }
            }
            if (op == SPIRV_OP_TYPE_RUNTIME_ARRAY) {
                if (wc >= 3) { _spirv_set_type(out, id, SPIRV_TYK_RUNTIME_ARRAY, a, 0, cap); }
            }
            if (op == SPIRV_OP_TYPE_STRUCT) {
                if (wc >= 3) { _spirv_set_type(out, id, SPIRV_TYK_STRUCT, wc - 2, a, cap); }
            }
            if (op == SPIRV_OP_TYPE_INT) {
                if (wc >= 4) { _spirv_set_type(out, id, SPIRV_TYK_INT, a, b, cap); }
            }
            if (op == SPIRV_OP_TYPE_VECTOR) {
                if (wc >= 4) { _spirv_set_type(out, id, SPIRV_TYK_VECTOR, a, b, cap); }
            }
            if (op == SPIRV_OP_TYPE_ARRAY) {
                if (wc >= 4) { _spirv_set_type(out, id, SPIRV_TYK_ARRAY, a, b, cap); }
            }
            if (op == SPIRV_OP_TYPE_POINTER) {
                if (wc >= 4) { _spirv_set_type(out, id, SPIRV_TYK_POINTER, a, b, cap); }
            }
        }
        off = off + wc;
    }
    return 0;
}

fn spirv_type_kind(out, id): i64 { return load64(out + id * SPIRV_TYPE_REC + 0); }
fn spirv_type_p0(out, id): i64 { return load64(out + id * SPIRV_TYPE_REC + 8); }
fn spirv_type_p1(out, id): i64 { return load64(out + id * SPIRV_TYPE_REC + 16); }

# ---- constant table ----
# out[result-id] = (result-type <id>, value). Scalar OpConstant only (the 32-bit
# value is word 3); composite/64-bit constants land when the lowering needs them.
fn spirv_build_const_table(ptr, byte_len, id_bound, cap, out): i64 {
    if (id_bound > cap) { return 0 - SPIRV_ERR_ID_CAP; }
    memset(out, 0, id_bound * SPIRV_CONST_REC);
    var total = byte_len / 4;
    var off = SPIRV_HEADER_WORDS;
    while (off < total) {
        var w0 = spirv_word(ptr, off);
        var wc = spirv_op_wordcount(w0);
        if (wc == 0) { return 0 - 1; }
        if (spirv_op(w0) == SPIRV_OP_CONSTANT) {
            if (wc >= 4) {
                var rid = spirv_word(ptr, off + 2);
                if (rid > 0) { if (rid < cap) {
                        store64(out + rid * SPIRV_CONST_REC + 0, spirv_word(ptr, off + 1));
                        # Word 3 (low dword) only. This table is consumed solely for i32 access-chain
                        # INDEX constants (spirv_const_value), which are 32-bit — so the high dword of a
                        # 64-bit (f64) const is never read here. f64 literal VALUES flow through the MIR
                        # const payload (spirv_lower mir_set_const, type-gated to read word 4), not this
                        # table — so packing the hi word here would be dead + can't be type-gated (no
                        # type table in the parser). (F.7f.9 review: avoid the untyped wc>=5 pack.)
                        store64(out + rid * SPIRV_CONST_REC + 8, spirv_word(ptr, off + 3));
                    } }
            }
        }
        off = off + wc;
    }
    return 0;
}

fn spirv_const_type(out, id): i64 { return load64(out + id * SPIRV_CONST_REC + 0); }
fn spirv_const_value(out, id): i64 { return load64(out + id * SPIRV_CONST_REC + 8); }

# ---- decoration table ----
# out[target-id] = (Binding, DescriptorSet); both default to -1 (absent). Only
# the two binding decorations N.2 needs to resolve buffer slots are recorded.
fn spirv_build_decoration_table(ptr, byte_len, id_bound, cap, out): i64 {
    if (id_bound > cap) { return 0 - SPIRV_ERR_ID_CAP; }
    memset(out, 0xFF, id_bound * SPIRV_DECO_REC);
    var total = byte_len / 4;
    var off = SPIRV_HEADER_WORDS;
    while (off < total) {
        var w0 = spirv_word(ptr, off);
        var wc = spirv_op_wordcount(w0);
        if (wc == 0) { return 0 - 1; }
        if (spirv_op(w0) == SPIRV_OP_DECORATE) {
            if (wc >= 4) {
                var tid = spirv_word(ptr, off + 1);
                var deco = spirv_word(ptr, off + 2);
                var operand = spirv_word(ptr, off + 3);
                if (tid > 0) { if (tid < cap) {
                        if (deco == SPIRV_DECO_BINDING) { store64(out + tid * SPIRV_DECO_REC + 0, operand); }
                        if (deco == SPIRV_DECO_DESCRIPTOR_SET) { store64(out + tid * SPIRV_DECO_REC + 8, operand); }
                    } }
            }
        }
        off = off + wc;
    }
    return 0;
}

fn spirv_deco_binding(out, id): i64 { return load64(out + id * SPIRV_DECO_REC + 0); }
fn spirv_deco_set(out, id): i64 { return load64(out + id * SPIRV_DECO_REC + 8); }

# --- mir.cyr ---

# @internal — mabda-IR (MIR): the SSA IR the SPIR-V→GFX9 compiler lowers through
# mir.cyr — Phase N.2a: the MIR data model + builders + accessors + the GFX9
# uniformity pass. Pure data structures; no SPIR-V dependency beyond the
# read-only N.1b type-table accessors (`spirv_type_kind`/`_p0`/`_p1`), so this
# module is testable in isolation with hand-built MIR (no parser walk). The
# SPIR-V→MIR lowering itself is N.2b (`spirv_lower.cyr`).
#
# Design (see the N.2 design synthesis): a small SSA IR shaped for GFX9, split
# into FOUR caller-provided buffers wired through one MirMod header. Operands are
# stored as SPIR-V <id>s (not instruction indices) so SPIR-V's SSA graph maps 1:1
# with zero renumbering. Each value carries kind + distilled MIR type +
# GFX9 UNIFORMITY (the load-bearing scalar-vs-vector classification) + a
# defining-instruction back-pointer. Buffers are caller-provided fixed-size
# records indexed directly by <id> (ids are dense, < id_bound) — the same
# stack-friendly, alloc-free pattern as spirv_parse.cyr's tables.
#
# Sentinels: SPIR-V <id> 0 is always invalid, so 0 = "no operand / no value".
# Index-returning builders (mir_emit / mir_add_ptr) return the index (>= 0) on
# success or a NEGATIVE error code on failure (indices and error codes would
# otherwise collide). Pure byte math; no syscalls.

# ================================================================
# Value kinds (value record slot 0)
# ================================================================
var MIR_VK_NONE    = 0;   # id is not (yet) a value — the memset-0 default
var MIR_VK_CONST   = 1;   # payload = 32-bit constant bits
var MIR_VK_BUILTIN = 2;   # payload = MIR_BI_* code
var MIR_VK_BUFVAR  = 3;   # payload = binding number (a StorageBuffer/Uniform var)
var MIR_VK_SSA     = 4;   # def = defining instruction index
var MIR_VK_PTR     = 5;   # payload = index into the ptrs[] access side-table
var MIR_VK_VECTOR  = 6;   # payload = packed component <id>s (16 bits each); count in the type

# Uniformity (value record slot 2). UNIFORM → SGPR/SALU, DIVERGENT → VGPR/VALU.
var MIR_UNIFORM   = 0;
var MIR_DIVERGENT = 1;
var MIR_UNKNOWN   = 2;   # transient: an SSA result before the propagate sweep

# Distilled MIR scalar types (value/instr type slot). Vectors encode as
# base | (count << 8) with count in 2..4; a scalar has count 0.
var MIR_T_VOID        = 0;
var MIR_T_I32         = 1;
var MIR_T_U32         = 2;
var MIR_T_F32         = 3;
var MIR_T_BOOL        = 4;
# v3.2 F.7a — f64 (double): a 64-bit scalar occupying an even-aligned register PAIR
# downstream (v[2:3] / s[0:1]); the base byte stays < 256 so vec2/3/4 f64 still encode
# as MIR_T_F64 | (count << 8). Production stays gated by MABDA_NATIVE_F64 until F.7 is
# complete end-to-end, so the partial back end (isel/regalloc/encode landing across
# F.7b–F.7d) is only reachable via the compiler_*.tcyr tests, never a real dispatch.
var MIR_T_F64         = 5;
var MIR_T_UNSUPPORTED = 255;

# Built-in codes (value payload for MIR_VK_BUILTIN).
var MIR_BI_LOCAL_INVOC_ID  = 0;
var MIR_BI_WORKGROUP_ID    = 1;
var MIR_BI_GLOBAL_INVOC_ID = 2;

# Block terminators (block record slot 3). N.7 adds _BRANCH / _COND_BRANCH.
var MIR_TERM_RETURN = 1;

# MIR op codes — 1:1 with the gfx9_encode formats N.3 selects (the MIR→GFX9
# seam is a flat switch on (op, result-uniformity)).
var MIR_OP_IADD    = 1;
var MIR_OP_ISUB    = 2;
var MIR_OP_IMUL    = 3;
var MIR_OP_SHL     = 4;
var MIR_OP_SHR     = 5;
var MIR_OP_AND     = 6;
var MIR_OP_OR      = 7;
var MIR_OP_XOR     = 8;
var MIR_OP_FADD    = 9;
var MIR_OP_FSUB    = 10;
var MIR_OP_FMUL    = 11;
var MIR_OP_FMA     = 12;
var MIR_OP_CVT_F32 = 13;
var MIR_OP_CVT_I32 = 14;
var MIR_OP_EXTRACT = 15;
var MIR_OP_LOAD    = 16;
var MIR_OP_STORE   = 17;
var MIR_OP_RET     = 18;
# N.7 control flow — modelled as instructions in the flat list (no separate block
# array): the back-end derives block layout by scanning for LABEL, then patches each
# branch's PC-relative offset to its target LABEL. LABEL: a = label <id>, 0 bytes.
# BRANCH: a = target label. COND_BRANCH: a = cond value, b = true label (the
# fall-through then-block), c = false label (the merge). ICMP_*: a,b -> a bool result
# (a uniform compare sets SCC; the divergent VCC path is N.7c).
var MIR_OP_LABEL       = 19;
var MIR_OP_BRANCH      = 20;
var MIR_OP_COND_BRANCH = 21;
var MIR_OP_ICMP_EQ     = 22;
var MIR_OP_ICMP_NE     = 23;
var MIR_OP_ICMP_ULT    = 24;
var MIR_OP_ICMP_UGT    = 25;
var MIR_OP_ICMP_ULE    = 26;
var MIR_OP_ICMP_UGE    = 27;
# GLSL.std.450 float math (N.8b). Uniformity is generic (meet of operands); the result
# is always VALU (float), like FMUL.
var MIR_OP_FMIN        = 28;
var MIR_OP_FMAX        = 29;
var MIR_OP_FSQRT       = 30;
var MIR_OP_FFLOOR      = 31;
# (MIR_OP_FMA = 12, defined above; GLSL.std.450 Fma reaches it via the ExtInst front end.)
# Signed integer compares (N.8b-4). EQ/NE are sign-agnostic (reuse ICMP_EQ/NE).
var MIR_OP_ICMP_SLT    = 32;
var MIR_OP_ICMP_SGT    = 33;
var MIR_OP_ICMP_SLE    = 34;
var MIR_OP_ICMP_SGE    = 35;
var MIR_OP_FCLAMP      = 36;   # GLSL.std.450 FClamp = median-of-3 (v_med3_f32)
var MIR_OP_FABS        = 37;   # GLSL.std.450 FAbs = clear sign bit (v_and_b32 0x7FFFFFFF)
# Integer-division primitives (N.9 — the float-reciprocal udiv macro). These are GFX9
# VECTOR-only ops (no scalar form), so the uniformity sweep forces their result DIVERGENT
# → they always select to VALU/VGPR. VMOV copies an operand into a VGPR (force-vector).
var MIR_OP_VMOV        = 38;   # copy → VGPR (v_mov_b32)
var MIR_OP_CVT_F32_U   = 39;   # (f32)u32
var MIR_OP_CVT_U_F32   = 40;   # (u32)f32 saturating
var MIR_OP_RCP_IFLAG   = 41;   # 1/x approx (iflag)
var MIR_OP_MUL_HI      = 42;   # high 32 bits of u32*u32
var MIR_OP_CNDMASK     = 43;   # a = vcc ? b(true) : a(false); reads the implicit VCC
# Arithmetic shift right (N.9d signed div sign masks). Uniformity is generic (it has both
# a SALU and a VALU form, unlike the vector-only div primitives above).
var MIR_OP_ASHR        = 44;
# v3.2 F.7f.2 — f32<->f64 conversion (OpFConvert). isel picks the direction from the RESULT type:
# f64 result → widen (V_CVT_F64_F32), f32 result → narrow (V_CVT_F32_F64).
var MIR_OP_FCONVERT    = 45;
# v3.2 F.7f.6b — f64 division macro primitives (OpFDiv → the LLVM gfx900 reciprocal Newton
# expansion). All VALU/f64 (64-bit VGPR pairs). DIV_SCALE writes the per-lane scale flag to
# the implicit VCC (consumed by DIV_FMAS); the chain is emitted contiguously so that VCC
# survives (only the two DIV_SCALEs write it; the intervening FMA/MUL never touch it — same
# adjacency-by-construction the udiv CNDMASK relies on). FMA_N0 = fma(-a,b,c); FMA_N0_ONE =
# fma(-a,b,1.0) (the Newton refinement step, inline-1.0 src2).
var MIR_OP_F64_RCP        = 46;   # v_rcp_f64 reciprocal seed (unary; refine via Newton)
var MIR_OP_F64_DIV_SCALE  = 47;   # v_div_scale_f64 (3-src; scaled value → dst, flag → VCC)
var MIR_OP_F64_DIV_FMAS   = 48;   # v_div_fmas_f64 (3-src; reads VCC for the 2^±64 post-scale)
var MIR_OP_F64_DIV_FIXUP  = 49;   # v_div_fixup_f64 (3-src; correctly-rounding fixup)
var MIR_OP_F64_FMA_N0     = 50;   # v_fma_f64(-a, b, c) — NEGATE src0
var MIR_OP_F64_FMA_N0_ONE = 51;   # v_fma_f64(-a, b, 1.0) — NEGATE src0 + inline-1.0 src2
# v3.2 F.7f.7b — f64 sqrt macro primitives (OpExtInst Sqrt → the Newton-Goldschmidt expansion).
# All VALU/f64. CMP_CLASS writes VCC (classify x against a bitmask); CNDMASK selects an f64 PAIR on
# VCC (2× v_cndmask_b32 on the halves); FMA_N0_HALF = fma(-a,b,0.5); MUL_HALF = mul(a,0.5).
var MIR_OP_F64_RSQ        = 52;   # v_rsq_f64 reciprocal-sqrt seed (unary)
var MIR_OP_F64_CMP_CLASS  = 53;   # v_cmp_class_f64 (a=x, b=mask vreg) → VCC; dst unused
var MIR_OP_F64_CNDMASK    = 54;   # f64-pair select: dst = VCC ? b(true) : a(false)
var MIR_OP_F64_FMA_N0_HALF = 55;  # v_fma_f64(-a, b, 0.5) — NEG src0 + inline-0.5 src2
var MIR_OP_F64_MUL_HALF   = 56;   # v_mul_f64(a, 0.5) — inline-0.5 src1
# v3.2 F.7f.7c — f64 sqrt subnormal-scaling wrapper (the LLVM full-range expansion). F64_CONST
# materializes an f64 from its TWO 32-bit halves (a = low dword, b = high dword, both IMM) via 2×
# v_mov_b32 — the MIR record packs a/b into 32-bit slots, so a single 64-bit imm would truncate
# (the F.7f.7c review). The F.7f.9 primitive — the 2^-767 threshold, later transcendental coeffs.
# LDEXP scales an f64 by 2^(i32 exponent); CMP_GT writes VCC (the subnormal gate). Vector-only.
var MIR_OP_F64_CONST      = 57;   # materialize f64 const (a = lo dword imm, b = hi dword imm)
var MIR_OP_F64_LDEXP      = 58;   # v_ldexp_f64 (a = f64, b = i32 exponent)
var MIR_OP_F64_CMP_GT     = 59;   # v_cmp_gt_f64 (a, b) → VCC; dst unused
# v3.2 F.7f.10 — i32<->f64 conversions (the exp range reduction: k_i32 = round(x*invln2),
# k_f64 = (f64)k_i32). VOP1, round-to-nearest-even (GFX9 v_cvt_i32_f64). NOT forced-DIVERGENT
# (general conversions, meet-classified like the i32<->f32 CVTs; the exp chain gets divergence
# from the F64_CONST operands anyway). The f32<->f64 FCONVERT (45) is a different op.
var MIR_OP_CVT_I32_F64    = 60;   # (i32)f64 round-to-nearest (v_cvt_i32_f64 0x03)
var MIR_OP_CVT_F64_I32    = 61;   # (f64)i32 (v_cvt_f64_i32 0x04)
# v3.2 F.7f.8 — f64 ordered compare (OpFOrd*): writes the implicit VCC (dst=0), the f64 VOPC opcode
# rides in flags bits 8+ (like the integer V_CMP). The bool result is realized by a following cndmask
# (compare→VCC→cndmask, mabda-generated adjacent). isel reuses GISEL_V_CMP / _emit_vopc.
var MIR_OP_F64_CMP        = 62;   # v_cmp_*_f64 (a, b) → VCC; opcode in flags 8+
# v3.2 F.7f.8 — OpSelect: a = cond MASK (0/-1, from a compare), b = true value, c = false value.
# Branchless via v_bfi_b32 (mask ? b : c) per 32-bit lane — 1 for i32/f32, 2 for an f64 pair. No VCC,
# so it's order-independent (the mask is a normal VGPR value). Result type picks the lane count.
var MIR_OP_SELECT         = 63;   # mask ? b : c  (v_bfi_b32 blend)

# Error codes (shared with spirv_lower.cyr; disjoint from spirv_parse's 1-11).
# Index-returning builders return these NEGATED; status fns return them positive.
var MIR_ERR_UNSUPPORTED_OP   = 20;
var MIR_ERR_UNSUPPORTED_TYPE = 21;
var MIR_ERR_CAP_EXCEEDED     = 22;
var MIR_ERR_BAD_ACCESS_CHAIN = 23;
var MIR_ERR_OVERFLOW         = 24;
var MIR_ERR_ID_OOR           = 25;

# Record sizes (bytes). One i64 per field — no bit-packing of load-bearing
# fields (uniformity especially). The instr/ptr records pack two <id>/flag
# halves per slot only where both halves are < 2^32 (SPIR-V id_bound is a
# 32-bit header field, capped < 2^30 by _spirv_validate).
var MIR_VAL_REC   = 40;   # [kind, type, unif, def, payload]
var MIR_INSTR_REC = 32;   # [op, result|type<<32, a|b<<32, c|flags<<32]
var MIR_PTR_REC   = 32;   # [binding, elem_type, off_id, const_off|dynamic<<32]
var MIR_BLOCK_REC = 32;   # [first_instr, instr_count, label_id, terminator]

# instr flags bits (high 32 of slot +24): which operands are immediates (so the
# uniformity meet skips them — an immediate is wave-uniform).
var MIR_FLAG_A_IMM = 2;
var MIR_FLAG_B_IMM = 4;
var MIR_FLAG_C_IMM = 8;

# ================================================================
# MirMod header (80 bytes; caller stack `var m[80]`)
#   +0 vals  +8 instrs  +16 ptrs  +24 blocks
#   +32 n_instrs  +40 cap_instrs  +48 n_ptrs  +56 cap_ptrs
#   +64 cap_ids  +72 next_synth
# ================================================================
# `cap_ids` is the value-id CEILING = the vals[] backing-store capacity in
# records (>= id_bound + synth headroom). It is the bound every value write is
# checked against — DISTINCT from the SPIR-V id_bound, because mir_alloc_synth_id
# hands out fresh ids >= id_bound for synthesized terms (e.g. the
# GlobalInvocationId expansion). Caller MUST size vals[] as cap_ids * MIR_VAL_REC.
# `next_synth` starts at id_bound so synth ids occupy [id_bound, cap_ids).
fn mir_mod_init(m, vals, instrs, ptrs, blocks, cap_instrs, cap_ptrs, id_bound, cap_ids): i64 {
    store64(m + 0, vals);
    store64(m + 8, instrs);
    store64(m + 16, ptrs);
    store64(m + 24, blocks);
    store64(m + 32, 0);
    store64(m + 40, cap_instrs);
    store64(m + 48, 0);
    store64(m + 56, cap_ptrs);
    store64(m + 64, cap_ids);
    store64(m + 72, id_bound);
    memset(vals, 0, cap_ids * MIR_VAL_REC);
    store64(blocks + 0, 0);
    store64(blocks + 8, 0);
    store64(blocks + 16, 0);
    store64(blocks + 24, MIR_TERM_RETURN);
    return 0;
}

# Allocate a fresh <id> >= id_bound (for synthesized terms, e.g. the
# GlobalInvocationId = WorkgroupId*localsize + LocalInvocationId expansion).
# Allocate the next synthetic <id> (for lowering-introduced values: access-chain
# offsets, the GID expansion). Returns -1 when the cap_ids ceiling is reached
# rather than handing out an out-of-range id that would OOB-write vals[] — callers
# MUST check for < 0. (N.5c-2b review.)
fn mir_alloc_synth_id(m): i64 {
    var s = load64(m + 72);
    if (s >= load64(m + 64)) { return 0 - 1; }
    store64(m + 72, s + 1);
    return s;
}

# ================================================================
# Value table (vals + id * 40)
# ================================================================
# Write a value record. Bound-checks `id` against the id-0 sentinel and the
# cap_ids ceiling so the mir_set_* builders (which forward their return) can
# never write outside the vals[] buffer on an untrusted/synth id. Returns 0 or
# a NEGATIVE error.
fn _mir_set_val(m, id, kind, type, unif, def, payload): i64 {
    if (id <= 0) { return 0 - MIR_ERR_ID_OOR; }
    if (id >= load64(m + 64)) { return 0 - MIR_ERR_ID_OOR; }
    var b = load64(m + 0) + id * MIR_VAL_REC;
    store64(b + 0, kind);
    store64(b + 8, type);
    store64(b + 16, unif);
    store64(b + 24, def);
    store64(b + 32, payload);
    return 0;
}

fn mir_set_const(m, id, type, value): i64 {
    return _mir_set_val(m, id, MIR_VK_CONST, type, MIR_UNIFORM, 0 - 1, value);
}

fn mir_set_builtin(m, id, type, bi_code): i64 {
    return _mir_set_val(m, id, MIR_VK_BUILTIN, type, _mir_builtin_unif(bi_code), 0 - 1, bi_code);
}

fn mir_set_bufvar(m, id, binding): i64 {
    return _mir_set_val(m, id, MIR_VK_BUFVAR, MIR_T_VOID, MIR_UNIFORM, 0 - 1, binding);
}

# A vector value (vec2..4): the result of OpCompositeConstruct / a component-wise op / a
# vector OpLoad. GFX9 has no vector registers, so a vecN is just N scalar component values;
# this record packs the N component <id>s (16 bits each, low component first) into the
# payload and carries the count in the type (mir_type_count). The component ids are
# themselves ordinary scalar values (CONST/SSA) the back end already handles — nothing
# references the vector <id> itself as an instruction operand. (N.10a)
fn mir_set_vector(m, id, type, packed): i64 {
    return _mir_set_val(m, id, MIR_VK_VECTOR, type, MIR_UNIFORM, 0 - 1, packed);
}

# Caller MUST have bounded `id` against cap_ids (mir_val_kind indexes vals[] unchecked).
fn mir_is_vector(m, id): i64 {
    if (mir_val_kind(m, id) == MIR_VK_VECTOR) { return 1; }
    return 0;
}

# The i-th component <id> of a vector value (`>>` is logical; the payload is positive).
fn mir_vec_comp(m, id, i): i64 { return (mir_val_payload(m, id) >> (i * 16)) & 0xFFFF; }

fn mir_val_kind(m, id): i64 { return load64(load64(m + 0) + id * MIR_VAL_REC + 0); }
fn mir_val_type(m, id): i64 { return load64(load64(m + 0) + id * MIR_VAL_REC + 8); }
fn mir_val_unif(m, id): i64 { return load64(load64(m + 0) + id * MIR_VAL_REC + 16); }
fn mir_val_def(m, id): i64 { return load64(load64(m + 0) + id * MIR_VAL_REC + 24); }
fn mir_val_payload(m, id): i64 { return load64(load64(m + 0) + id * MIR_VAL_REC + 32); }

fn _mir_set_val_unif(m, id, unif): i64 {
    store64(load64(m + 0) + id * MIR_VAL_REC + 16, unif);
    return 0;
}

# ================================================================
# Instruction array (instrs + i * 32, program order)
# ================================================================
# Append an instruction. If result != 0 the result <id> becomes an SSA value
# (kind SSA, type, unif UNKNOWN until mir_run_uniformity, def = this index).
# Returns the instruction index (>= 0), or a NEGATIVE error.
fn mir_emit(m, op, result, type, a, b, c, flags): i64 {
    var n = load64(m + 32);
    if (n >= load64(m + 40)) { return 0 - MIR_ERR_CAP_EXCEEDED; }
    var cap = load64(m + 64);
    if (result != 0) {
        if (result >= cap) { return 0 - MIR_ERR_ID_OOR; }
    }
    # Bound every NON-immediate operand against cap_ids: operands become vals[]
    # indices in mir_run_uniformity, and an untrusted SPIR-V operand <id> would
    # otherwise drive a wild OOB read there. Immediate operands (lane indices,
    # etc.) are not ids and are skipped. (N.2b-1 adversarial review.)
    # A vecN value (MIR_VK_VECTOR) is a grouping of N scalar components, never a hardware
    # operand — it MUST be scalarized (its components passed instead) before reaching here.
    # Reject it centrally so an unimplemented vector op (e.g. vec arith before N.10b) fails
    # loud instead of reading the vector record's placeholder uniformity. (N.10a review.)
    if (a != 0) { if ((flags & MIR_FLAG_A_IMM) == 0) {
            if (a >= cap) { return 0 - MIR_ERR_ID_OOR; }
            if (mir_val_kind(m, a) == MIR_VK_VECTOR) { return 0 - MIR_ERR_UNSUPPORTED_OP; }
        } }
    if (b != 0) { if ((flags & MIR_FLAG_B_IMM) == 0) {
            if (b >= cap) { return 0 - MIR_ERR_ID_OOR; }
            if (mir_val_kind(m, b) == MIR_VK_VECTOR) { return 0 - MIR_ERR_UNSUPPORTED_OP; }
        } }
    if (c != 0) { if ((flags & MIR_FLAG_C_IMM) == 0) {
            if (c >= cap) { return 0 - MIR_ERR_ID_OOR; }
            if (mir_val_kind(m, c) == MIR_VK_VECTOR) { return 0 - MIR_ERR_UNSUPPORTED_OP; }
        } }
    var base = load64(m + 8) + n * MIR_INSTR_REC;
    store64(base + 0, op);
    store64(base + 8, result | (type << 32));
    store64(base + 16, a | (b << 32));
    store64(base + 24, c | (flags << 32));
    if (result != 0) {
        _mir_set_val(m, result, MIR_VK_SSA, type, MIR_UNKNOWN, n, 0);
    }
    store64(m + 32, n + 1);
    return n;
}

fn mir_n_instrs(m): i64 { return load64(m + 32); }
fn mir_instr_op(m, i): i64 { return load64(load64(m + 8) + i * MIR_INSTR_REC + 0); }
fn mir_instr_result(m, i): i64 { return load64(load64(m + 8) + i * MIR_INSTR_REC + 8) & 0xFFFFFFFF; }
fn mir_instr_type(m, i): i64 { return (load64(load64(m + 8) + i * MIR_INSTR_REC + 8) >> 32) & 0xFFFFFFFF; }
fn mir_instr_a(m, i): i64 { return load64(load64(m + 8) + i * MIR_INSTR_REC + 16) & 0xFFFFFFFF; }
fn mir_instr_b(m, i): i64 { return (load64(load64(m + 8) + i * MIR_INSTR_REC + 16) >> 32) & 0xFFFFFFFF; }
fn mir_instr_c(m, i): i64 { return load64(load64(m + 8) + i * MIR_INSTR_REC + 24) & 0xFFFFFFFF; }
fn mir_instr_flags(m, i): i64 { return (load64(load64(m + 8) + i * MIR_INSTR_REC + 24) >> 32) & 0xFFFFFFFF; }

# ================================================================
# Access (ptr) side-table (ptrs + idx * 32) — OpAccessChain results
# ================================================================
# Records a (binding, byte-offset-expression) buffer access. `off_id` is the SSA
# <id> giving the dynamic byte offset (0 = none → const offset only). Sets
# vals[result_id] = PTR (payload = ptr index). Returns the ptr index or a
# NEGATIVE error.
fn mir_add_ptr(m, result_id, binding, elem_type, off_id, const_off, dynamic): i64 {
    var n = load64(m + 48);
    if (n >= load64(m + 56)) { return 0 - MIR_ERR_CAP_EXCEEDED; }
    if (result_id == 0) { return 0 - MIR_ERR_ID_OOR; }
    if (result_id >= load64(m + 64)) { return 0 - MIR_ERR_ID_OOR; }
    var base = load64(m + 16) + n * MIR_PTR_REC;
    store64(base + 0, binding);
    store64(base + 8, elem_type);
    store64(base + 16, off_id);
    store64(base + 24, (const_off & 0xFFFFFFFF) | (dynamic << 32));
    _mir_set_val(m, result_id, MIR_VK_PTR, MIR_T_VOID, MIR_UNIFORM, 0 - 1, n);
    store64(m + 48, n + 1);
    return n;
}

fn mir_n_ptrs(m): i64 { return load64(m + 48); }
fn mir_ptr_binding(m, idx): i64 { return load64(load64(m + 16) + idx * MIR_PTR_REC + 0); }
fn mir_ptr_elem_type(m, idx): i64 { return load64(load64(m + 16) + idx * MIR_PTR_REC + 8); }
fn mir_ptr_off_id(m, idx): i64 { return load64(load64(m + 16) + idx * MIR_PTR_REC + 16); }
fn mir_ptr_const_off(m, idx): i64 { return load64(load64(m + 16) + idx * MIR_PTR_REC + 24) & 0xFFFFFFFF; }
fn mir_ptr_dynamic(m, idx): i64 { return (load64(load64(m + 16) + idx * MIR_PTR_REC + 24) >> 32) & 0xFFFFFFFF; }

# ================================================================
# Blocks (blocks + b * 32) — MVP is a single block
# ================================================================
fn mir_finalize_block0(m): i64 {
    store64(load64(m + 24) + 8, load64(m + 32));   # block0.instr_count = n_instrs
    return 0;
}

fn mir_block_first(m, b): i64 { return load64(load64(m + 24) + b * MIR_BLOCK_REC + 0); }
fn mir_block_count(m, b): i64 { return load64(load64(m + 24) + b * MIR_BLOCK_REC + 8); }
fn mir_block_label(m, b): i64 { return load64(load64(m + 24) + b * MIR_BLOCK_REC + 16); }
fn mir_block_term(m, b): i64 { return load64(load64(m + 24) + b * MIR_BLOCK_REC + 24); }
fn mir_block_count_total(m): i64 { return 1; }   # MVP: one block (N.7 adds n_blocks)

# ================================================================
# Type distillation (SPIR-V type table → MIR type byte)
# ================================================================
# `types` is a spirv_parse.cyr type table; `spv_tid` a SPIR-V type <id>. i32/u32
# by signedness, f32, bool, and vec2..4 of a supported scalar. Anything else
# (non-32-bit width, matrices, images, unknown) → MIR_T_UNSUPPORTED so the
# lowering can fail loud.
fn _mir_lower_type(types, spv_tid, id_bound): i64 {
    # `spv_tid` comes from untrusted instruction words; the type table is sized
    # id_bound records, so reject any id outside (0, id_bound) before indexing it
    # (the recursion below re-enters with the component id, bounding it too).
    if (spv_tid == 0) { return MIR_T_UNSUPPORTED; }
    if (spv_tid >= id_bound) { return MIR_T_UNSUPPORTED; }
    var k = spirv_type_kind(types, spv_tid);
    if (k == SPIRV_TYK_INT) {
        if (spirv_type_p0(types, spv_tid) != 32) { return MIR_T_UNSUPPORTED; }
        if (spirv_type_p1(types, spv_tid) == 1) { return MIR_T_I32; }
        return MIR_T_U32;
    }
    if (k == SPIRV_TYK_FLOAT) {
        var fw = spirv_type_p0(types, spv_tid);
        if (fw == 32) { return MIR_T_F32; }
        if (fw == 64) { return MIR_T_F64; }   # v3.2 F.7a — f64 (even-aligned reg pair)
        return MIR_T_UNSUPPORTED;
    }
    if (k == SPIRV_TYK_BOOL) { return MIR_T_BOOL; }
    if (k == SPIRV_TYK_VECTOR) {
        var comp_id = spirv_type_p0(types, spv_tid);
        # Bound the component id before reading its kind (it is a table index from
        # the stream too), then require it to be a scalar (INT/FLOAT/BOOL): this
        # rejects vector-of-vector / vector-of-aggregate as UNSUPPORTED AND bounds
        # the recursion (a crafted self-/mutually-referential component would
        # otherwise recurse forever). A scalar component recurses one level.
        if (comp_id == 0) { return MIR_T_UNSUPPORTED; }
        if (comp_id >= id_bound) { return MIR_T_UNSUPPORTED; }
        var ck = spirv_type_kind(types, comp_id);
        if (ck != SPIRV_TYK_INT) {
            if (ck != SPIRV_TYK_FLOAT) {
                if (ck != SPIRV_TYK_BOOL) { return MIR_T_UNSUPPORTED; }
            }
        }
        var comp = _mir_lower_type(types, comp_id, id_bound);
        if (comp == MIR_T_UNSUPPORTED) { return MIR_T_UNSUPPORTED; }
        var count = spirv_type_p1(types, spv_tid);
        if (count < 2) { return MIR_T_UNSUPPORTED; }
        if (count > 4) { return MIR_T_UNSUPPORTED; }
        return comp | (count << 8);
    }
    return MIR_T_UNSUPPORTED;
}

fn mir_type_base(t): i64 { return t & 0xFF; }

fn mir_type_count(t): i64 {
    var c = (t >> 8) & 0xFF;
    if (c == 0) { return 1; }
    return c;
}

# ================================================================
# Uniformity classification (GFX9 SGPR/SALU vs VGPR/VALU)
# ================================================================
# meet: DIVERGENT dominates (no || in Cyrius → nested ifs).
fn _mir_meet(u0, u1): i64 {
    if (u0 == MIR_DIVERGENT) { return MIR_DIVERGENT; }
    if (u1 == MIR_DIVERGENT) { return MIR_DIVERGENT; }
    return MIR_UNIFORM;
}

# WorkgroupId is uniform across the wave (one TGID per workgroup); the
# per-invocation ids are per-lane divergent.
fn _mir_builtin_unif(bi_code): i64 {
    if (bi_code == MIR_BI_WORKGROUP_ID) { return MIR_UNIFORM; }
    return MIR_DIVERGENT;
}

# The uniformity of instruction `i`'s result. LOAD follows its byte-offset
# operand (a = off_id; 0 = const offset → uniform load). Other ops meet over
# their live, non-immediate operands (a/b/c); immediates and absent (0) operands
# are wave-uniform and skipped.
fn _mir_instr_unif(m, i): i64 {
    var op = mir_instr_op(m, i);
    var a = mir_instr_a(m, i);
    if (op == MIR_OP_LOAD) {
        if (a == 0) { return MIR_UNIFORM; }
        return mir_val_unif(m, a);
    }
    # GFX9 vector-only ops (N.9 udiv primitives) have no scalar form, so their result is
    # always per-lane VGPR — force DIVERGENT regardless of operand uniformity. This makes
    # the udiv macro fully vector even for uniform operands (each lane computes the same).
    if (op >= MIR_OP_VMOV) {
        if (op <= MIR_OP_CNDMASK) { return MIR_DIVERGENT; }
    }
    # v3.2 F.7f.6b/7b/7c — the f64 division + sqrt macro primitives (RCP..FMA_N0_ONE [46–51];
    # RSQ..MUL_HALF [52–56]; F64_CONST / LDEXP / CMP_GT [57–59]) are the same class: VOP1/VOP3/VOPC-
    # only with implicit per-lane VCC, no scalar form (F64_CONST is a 2× v_mov_b32 into a VGPR pair).
    # Force DIVERGENT (a uniform-operand FDiv/FSqrt must not classify them UNIFORM and become an
    # SGPR-coalescing candidate — they have no SALU form). (F.7f.6b adversarial review.)
    if (op >= MIR_OP_F64_RCP) {
        if (op <= MIR_OP_F64_CMP_GT) { return MIR_DIVERGENT; }
    }
    var flags = mir_instr_flags(m, i);
    var b = mir_instr_b(m, i);
    var c = mir_instr_c(m, i);
    var u = MIR_UNIFORM;
    if (a != 0) {
        if ((flags & MIR_FLAG_A_IMM) == 0) { u = _mir_meet(u, mir_val_unif(m, a)); }
    }
    if (b != 0) {
        if ((flags & MIR_FLAG_B_IMM) == 0) { u = _mir_meet(u, mir_val_unif(m, b)); }
    }
    if (c != 0) {
        if ((flags & MIR_FLAG_C_IMM) == 0) { u = _mir_meet(u, mir_val_unif(m, c)); }
    }
    return u;
}

# Single forward sweep over instrs 0..n_instrs. Exact for straight-line SSA (no
# back-edges; every operand is defined before use). Writes each result's
# uniformity into its value record. N.7 (control flow) adds a worklist +
# divergent-region re-seed. After this, no live SSA result is MIR_UNKNOWN.
fn mir_run_uniformity(m): i64 {
    var n = load64(m + 32);
    var i = 0;
    while (i < n) {
        var result = mir_instr_result(m, i);
        if (result != 0) { _mir_set_val_unif(m, result, _mir_instr_unif(m, i)); }
        i = i + 1;
    }
    return 0;
}

# --- spirv_lower.cyr ---

# @internal — SPIR-V module → MIR lowering (Phase N.2b)
# spirv_lower.cyr — walks a *validated* SPIR-V compute module (via the N.1b
# parser + tables) and builds MIR (the N.2a data model) for a STRAIGHT-LINE
# compute function. Plus the gap-closing probe passes the N.1b parser does NOT
# provide: OpDecorate BuiltIn resolution (the N.2 design + adversarial review
# flagged this as the highest-risk gap — a mis-resolved builtin silently flips a
# value's uniformity).
#
# N.2b-1 (this cut): the non-memory subset — constants, builtins, the builtin
# OpLoad alias, OpCompositeExtract, the i32/u32/f32 ALU + conversion ops, and
# OpReturn; control flow is rejected (LOWER_ERR_CONTROL_FLOW), unmapped ops fail
# loud (MIR_ERR_UNSUPPORTED_OP). N.2b-2 adds the buffer memory path
# (OpAccessChain + OpLoad/OpStore of a StorageBuffer + the offset-overflow
# guard) — those ops currently fail loud, not silently.
#
# Returns: 0 (SPIRV_LOWER_OK) on success, or a NEGATIVE error code (mirrors the
# mir.cyr index-builder convention so a single `r < 0` check propagates).
# Included after mir.cyr (it drives the mir_* builders + the spirv_* tables).

# Executable / memory / structural opcodes (spec §3.37) not already declared in
# spirv_parse.cyr (which owns the type/constant/decorate/function opcodes).
var SPIRV_OP_EXT_INST_IMPORT   = 11;
var SPIRV_OP_EXT_INST          = 12;
var SPIRV_OP_LOAD              = 61;
var SPIRV_OP_STORE             = 62;
var SPIRV_OP_ACCESS_CHAIN      = 65;
var SPIRV_OP_CONSTANT_COMPOSITE = 44;
var SPIRV_OP_COMPOSITE_CONSTRUCT = 80;
var SPIRV_OP_COMPOSITE_EXTRACT = 81;
var SPIRV_OP_CONVERT_F_TO_S    = 110;
var SPIRV_OP_CONVERT_S_TO_F    = 111;
var SPIRV_OP_CONVERT_U_TO_F    = 112;
var SPIRV_OP_FCONVERT          = 115;   # f32<->f64 (v3.2 F.7f.2)
var SPIRV_OP_IADD              = 128;
var SPIRV_OP_FADD              = 129;
var SPIRV_OP_ISUB             = 130;
var SPIRV_OP_FSUB             = 131;
var SPIRV_OP_IMUL             = 132;
var SPIRV_OP_FMUL             = 133;
var SPIRV_OP_UDIV             = 134;   # N.9 — float-reciprocal macro
var SPIRV_OP_SDIV             = 135;   # N.9d — sign-magnitude over the udiv core
var SPIRV_OP_FDIV             = 136;   # F.7f.6b — f64 reciprocal Newton macro (f32 fail-loud)
var SPIRV_OP_UMOD             = 137;   # N.9c — udiv core, remainder select
var SPIRV_OP_SREM             = 138;   # N.9d — signed remainder (dividend sign)
var SPIRV_OP_SMOD             = 139;   # N.9d — floored modulo (divisor sign)
var SPIRV_OP_SHR_LOGICAL      = 194;
var SPIRV_OP_SHL              = 196;
var SPIRV_OP_BITWISE_OR       = 197;
var SPIRV_OP_BITWISE_XOR      = 198;
var SPIRV_OP_BITWISE_AND      = 199;
# v3.2 F.7f.8 — ordered f64 comparisons (→ a bool the consumer feeds to OpSelect / a branch).
var SPIRV_OP_FORD_EQUAL          = 180;
var SPIRV_OP_FORD_NOTEQUAL       = 182;
var SPIRV_OP_FORD_LESSTHAN       = 184;
var SPIRV_OP_FORD_GREATERTHAN    = 186;
var SPIRV_OP_FORD_LESSTHANEQUAL  = 188;
var SPIRV_OP_FORD_GREATERTHANEQUAL = 190;
var SPIRV_OP_SELECT           = 169;   # F.7f.8 — cond ? x : y (v_bfi_b32 blend)
var SPIRV_OP_RETURN           = 253;

# Control-flow ops. N.7: BRANCH/BRANCH_CONDITIONAL/SELECTION_MERGE lower; LOOP_MERGE
# (back-edges break the forward linear-scan) + PHI (the MVP forbids merge-consumed
# values) still fail loud.
var SPIRV_OP_LOOP_MERGE          = 246;
var SPIRV_OP_SELECTION_MERGE     = 247;
var SPIRV_OP_BRANCH              = 249;
var SPIRV_OP_BRANCH_CONDITIONAL  = 250;
var SPIRV_OP_PHI                 = 245;

# Integer comparison opcodes (N.7) → MIR_OP_ICMP_*. Unsigned forms (indices are
# unsigned); the signed variants land when a kernel needs them.
var SPIRV_OP_IEQUAL              = 170;
var SPIRV_OP_INOTEQUAL           = 171;
var SPIRV_OP_UGREATERTHAN        = 172;
var SPIRV_OP_UGREATERTHANEQUAL   = 174;
var SPIRV_OP_ULESSTHAN           = 176;
var SPIRV_OP_ULESSTHANEQUAL      = 178;
var SPIRV_OP_SGREATERTHAN        = 173;
var SPIRV_OP_SGREATERTHANEQUAL   = 175;
var SPIRV_OP_SLESSTHAN           = 177;
var SPIRV_OP_SLESSTHANEQUAL      = 179;

# GLSL.std.450 extended-instruction numbers (the `OpExtInst` instruction field). N.11 verifies
# (via `_spirv_check_ext_sets`) that every OpExtInst references the actual GLSL.std.450 import,
# so these numbers are only ever decoded for that set — a non-GLSL set fails loud up front.
# Sqrt is unary; FMin/FMax are binary.
var GLSL_STD450_FABS             = 4;
var GLSL_STD450_FLOOR            = 8;
var GLSL_STD450_FMA              = 50;
var GLSL_STD450_FCLAMP           = 43;
var GLSL_STD450_SQRT             = 31;
var GLSL_STD450_FMIN             = 37;
var GLSL_STD450_FMAX             = 40;
var GLSL_STD450_LDEXP            = 53;   # F.7f.10 — x * 2^k (f64-valid; reuses MIR_OP_F64_LDEXP)

# OpDecorate Decoration = BuiltIn, and the compute BuiltIn enum values.
var SPIRV_DECO_BUILTIN              = 11;
var SPIRV_BI_WORKGROUP_ID          = 26;
var SPIRV_BI_LOCAL_INVOCATION_ID   = 27;
var SPIRV_BI_GLOBAL_INVOCATION_ID  = 28;

# StorageClass values (OpVariable word 3).
var SPIRV_SC_INPUT          = 1;
var SPIRV_SC_UNIFORM        = 2;
var SPIRV_SC_PUSH_CONSTANT  = 9;
var SPIRV_SC_STORAGE_BUFFER = 12;

# Lowering error codes (disjoint from spirv_parse 1-11 and mir 20-25).
var SPIRV_LOWER_OK          = 0;
var LOWER_ERR_CONTROL_FLOW  = 26;
var LOWER_ERR_NO_ENTRY      = 27;
var LOWER_ERR_ARRAY_STRIDE  = 28;   # an array ArrayStride disagrees with the assumed std430
var LOWER_ERR_EXT_SET       = 29;   # an OpExtInst references a non-GLSL.std.450 ext set

var SPIRV_DECO_ARRAY_STRIDE = 6;    # OpDecorate %arrayType ArrayStride <n>

# ================================================================
# Gap-closing pass: OpDecorate BuiltIn → a per-<id> side-table
# ================================================================
# Map the SPIR-V BuiltIn enum to a MIR_BI_* code (or -1 for builtins outside the
# compute MVP).
fn _spirv_builtin_to_mir(k): i64 {
    if (k == SPIRV_BI_GLOBAL_INVOCATION_ID) { return MIR_BI_GLOBAL_INVOC_ID; }
    if (k == SPIRV_BI_LOCAL_INVOCATION_ID) { return MIR_BI_LOCAL_INVOC_ID; }
    if (k == SPIRV_BI_WORKGROUP_ID) { return MIR_BI_WORKGROUP_ID; }
    return 0 - 1;
}

# Build out_bi[<id>] = MIR_BI_* for every `OpDecorate %v BuiltIn k` (the N.1b
# decoration table records Binding/DescriptorSet but NOT BuiltIn). `out_bi` is a
# caller-provided array of `id_bound` i64s; -1 = not a (recognized) builtin.
fn _spirv_resolve_builtins(ptr, byte_len, id_bound, out_bi): i64 {
    # PRECONDITION (untrusted id_bound): out_bi must hold >= id_bound i64s. On the
    # public path this is guaranteed — gfx9_compile gates id_bound <= CC_CAP_IDS via
    # the table builders before reaching here, and CC_CAP_IDS's contract sizes OUTBI
    # for >= CC_CAP_IDS records (see CC_CAP_IDS in gfx9_compile.cyr). The per-id
    # store below is independently bounded (`tid < id_bound`, N.2b-1); this memset
    # trusts that contract. A direct caller bypassing gfx9_compile owns the sizing.
    memset(out_bi, 0xFF, id_bound * 8);
    var total = byte_len / 4;
    var off = SPIRV_HEADER_WORDS;
    while (off < total) {
        var w0 = spirv_word(ptr, off);
        var wc = spirv_op_wordcount(w0);
        if (spirv_op(w0) == SPIRV_OP_DECORATE) {
            if (wc >= 4) {
                if (spirv_word(ptr, off + 2) == SPIRV_DECO_BUILTIN) {
                    var tid = spirv_word(ptr, off + 1);
                    var bi = _spirv_builtin_to_mir(spirv_word(ptr, off + 3));
                    # Bound the (untrusted) target <id> before the store — out_bi
                    # is id_bound-sized and this is a WRITE (controlled-offset OOB
                    # write otherwise). N.2b-1 adversarial review.
                    if (bi != 0 - 1) {
                        if (tid != 0) {
                            if (tid < id_bound) { store64(out_bi + tid * 8, bi); }
                        }
                    }
                }
            }
        }
        off = off + wc;
    }
    return 0;
}

fn _spirv_builtin_for_var(out_bi, vid): i64 {
    return load64(out_bi + vid * 8);
}

# ================================================================
# Seed pass: globals (constants + variables) → MIR values
# ================================================================
# A StorageBuffer/Uniform/PushConstant variable → a bound buffer value; an Input
# variable decorated BuiltIn → a builtin value (typed as the pointee). `off` is
# the OpVariable instruction offset (word 1 = its pointer result-type).
fn _spirv_seed_variable(types, deco, m, out_bi, ptr, off, vid, sclass): i64 {
    var idb = spirv_hdr_id_bound(ptr);
    # `vid` indexes the id_bound-sized deco / out_bi tables — bound it first.
    if (vid == 0) { return 0; }
    if (vid >= idb) { return 0; }
    if (sclass == SPIRV_SC_STORAGE_BUFFER) { return mir_set_bufvar(m, vid, spirv_deco_binding(deco, vid)); }
    if (sclass == SPIRV_SC_UNIFORM) { return mir_set_bufvar(m, vid, spirv_deco_binding(deco, vid)); }
    if (sclass == SPIRV_SC_PUSH_CONSTANT) { return mir_set_bufvar(m, vid, spirv_deco_binding(deco, vid)); }
    if (sclass == SPIRV_SC_INPUT) {
        var bi = _spirv_builtin_for_var(out_bi, vid);
        if (bi != 0 - 1) {
            var ptype = spirv_word(ptr, off + 1);
            if (ptype == 0) { return 0 - MIR_ERR_UNSUPPORTED_TYPE; }
            if (ptype >= idb) { return 0 - MIR_ERR_UNSUPPORTED_TYPE; }
            var bty = _mir_lower_type(types, spirv_type_p1(types, ptype), idb);
            if (bty == MIR_T_UNSUPPORTED) { return 0 - MIR_ERR_UNSUPPORTED_TYPE; }
            return mir_set_builtin(m, vid, bty, bi);
        }
    }
    return 0;
}

fn _spirv_lower_seed_globals(ptr, byte_len, types, deco, m, out_bi): i64 {
    var idb = spirv_hdr_id_bound(ptr);
    var total = byte_len / 4;
    var off = SPIRV_HEADER_WORDS;
    while (off < total) {
        var w0 = spirv_word(ptr, off);
        var wc = spirv_op_wordcount(w0);
        var op = spirv_op(w0);
        if (op == SPIRV_OP_CONSTANT) {
            if (wc >= 4) {
                var cty = _mir_lower_type(types, spirv_word(ptr, off + 1), idb);
                if (cty == MIR_T_UNSUPPORTED) { return 0 - MIR_ERR_UNSUPPORTED_TYPE; }
                # An f64 OpConstant's value spans words 3+4 (so wc>=5); keep the full 64-bit value (the
                # MIR const payload is 64-bit) so it doesn't truncate (F.7f.9). The hi word is read ONLY
                # for an f64 type (type-gated, not by wc alone — a malformed 32-bit const with wc>=5
                # must not read word 4; a malformed f64 const with wc<5 fails loud). 32-bit: word 3.
                var cval = spirv_word(ptr, off + 3);
                if (mir_type_base(cty) == MIR_T_F64) {
                    if (wc < 5) { return 0 - MIR_ERR_UNSUPPORTED_TYPE; }
                    cval = cval | (spirv_word(ptr, off + 4) << 32);
                }
                var cr = mir_set_const(m, spirv_word(ptr, off + 2), cty, cval);
                if (cr < 0) { return cr; }
            }
        }
        # OpConstantComposite is structurally identical to OpCompositeConstruct (same
        # [type, result, constituents…] layout); its constituents are scalar OpConstants
        # already seeded above (they precede it in the stream), so the same packer registers
        # the vecN constant. A const array/struct composite is non-vector → fails loud. (N.10d)
        if (op == SPIRV_OP_CONSTANT_COMPOSITE) {
            var ccr = _spirv_lower_composite_construct(ptr, off, wc, types, m);
            if (ccr < 0) { return ccr; }
        }
        if (op == SPIRV_OP_VARIABLE) {
            if (wc >= 4) {
                var vr = _spirv_seed_variable(types, deco, m, out_bi, ptr, off,
                spirv_word(ptr, off + 2), spirv_word(ptr, off + 3));
                if (vr < 0) { return vr; }
            }
        }
        off = off + wc;
    }
    return 0;
}

# ================================================================
# Body pass: the entry function's executable instructions → MIR
# ================================================================
# SPIR-V binary-ALU opcode → MIR op, or 0 if not a binary ALU we lower.
fn _spirv_alu_to_mir(op): i64 {
    if (op == SPIRV_OP_IADD) { return MIR_OP_IADD; }
    if (op == SPIRV_OP_ISUB) { return MIR_OP_ISUB; }
    if (op == SPIRV_OP_IMUL) { return MIR_OP_IMUL; }
    if (op == SPIRV_OP_SHL) { return MIR_OP_SHL; }
    if (op == SPIRV_OP_SHR_LOGICAL) { return MIR_OP_SHR; }
    if (op == SPIRV_OP_BITWISE_AND) { return MIR_OP_AND; }
    if (op == SPIRV_OP_BITWISE_OR) { return MIR_OP_OR; }
    if (op == SPIRV_OP_BITWISE_XOR) { return MIR_OP_XOR; }
    if (op == SPIRV_OP_FADD) { return MIR_OP_FADD; }
    if (op == SPIRV_OP_FSUB) { return MIR_OP_FSUB; }
    if (op == SPIRV_OP_FMUL) { return MIR_OP_FMUL; }
    return 0;
}

# 1 if both `a` and `b` are compile-time constants (so a binary op over them folds).
# Bounds-guarded against the untrusted id range (cap_ids = m+64), like the table builders.
fn _spirv_both_const(m, a, b): i64 {
    if (a == 0) { return 0; }
    if (b == 0) { return 0; }
    var cap = load64(m + 64);
    if (a >= cap) { return 0; }
    if (b >= cap) { return 0; }
    if (mir_val_kind(m, a) != MIR_VK_CONST) { return 0; }
    if (mir_val_kind(m, b) != MIR_VK_CONST) { return 0; }
    # f64 const-fold isn't supported (the 32-bit _spirv_const_fold would mangle the 64-bit value);
    # f64 const operands take the materialize-via-F64_CONST path instead (F.7f.9).
    if (mir_type_base(mir_val_type(m, a)) == MIR_T_F64) { return 0; }
    if (mir_type_base(mir_val_type(m, b)) == MIR_T_F64) { return 0; }
    return 1;
}

# If `opid` is an f64 compile-time constant, materialize it into a VGPR pair via MIR_OP_F64_CONST
# (its 64-bit payload split lo/hi) and return the new value id; else return opid unchanged. VOP3
# cannot encode a 64-bit literal operand, so an f64 const operand of an arith op must first be in a
# register pair — unlike f32, whose const operand the emit can inline/literal-materialize (F.7f.9).
fn _spirv_f64_arg(m, opid): i64 {
    if (opid == 0) { return opid; }
    var cap = load64(m + 64);
    if (opid >= cap) { return opid; }
    if (mir_val_kind(m, opid) != MIR_VK_CONST) { return opid; }
    if (mir_type_base(mir_val_type(m, opid)) != MIR_T_F64) { return opid; }
    var v = mir_val_payload(m, opid);
    return _udiv_op(m, MIR_OP_F64_CONST, MIR_T_F64, v & 0xFFFFFFFF, (v >> 32) & 0xFFFFFFFF, 0,
    MIR_FLAG_A_IMM | MIR_FLAG_B_IMM);
}

# Fold a binary ALU op over two constant operands → the 32-bit result value. Integer ops
# use i64 arithmetic masked to 32 bits (`>>` is logical, correct for SHR); float ops
# decode the f32 bits to f64, compute, and re-encode (f32_to / f64_* / f32_from). Only
# called for the ops _spirv_alu_to_mir returns, so the trailing return is unreachable.
fn _spirv_const_fold(m, mop, a, b): i64 {
    var va = mir_val_payload(m, a) & 0xFFFFFFFF;
    var vb = mir_val_payload(m, b) & 0xFFFFFFFF;
    if (mop == MIR_OP_IADD) { return (va + vb) & 0xFFFFFFFF; }
    if (mop == MIR_OP_ISUB) { return (va - vb) & 0xFFFFFFFF; }
    if (mop == MIR_OP_IMUL) { return (va * vb) & 0xFFFFFFFF; }
    if (mop == MIR_OP_AND) { return va & vb; }
    if (mop == MIR_OP_OR) { return va | vb; }
    if (mop == MIR_OP_XOR) { return va ^ vb; }
    if (mop == MIR_OP_SHL) { return (va << (vb & 31)) & 0xFFFFFFFF; }
    if (mop == MIR_OP_SHR) { return (va >> (vb & 31)) & 0xFFFFFFFF; }
    if (mop == MIR_OP_FADD) { return f32_from(f64_add(f32_to(va), f32_to(vb))) & 0xFFFFFFFF; }
    if (mop == MIR_OP_FSUB) { return f32_from(f64_sub(f32_to(va), f32_to(vb))) & 0xFFFFFFFF; }
    if (mop == MIR_OP_FMUL) { return f32_from(f64_mul(f32_to(va), f32_to(vb))) & 0xFFFFFFFF; }
    return va;
}

# SPIR-V integer-comparison opcode → MIR_OP_ICMP_*, or 0 if not a comparison we
# lower. The result is a bool the COND_BRANCH consumes (a uniform compare → SCC).
fn _spirv_cmp_to_mir(op): i64 {
    if (op == SPIRV_OP_IEQUAL) { return MIR_OP_ICMP_EQ; }
    if (op == SPIRV_OP_INOTEQUAL) { return MIR_OP_ICMP_NE; }
    if (op == SPIRV_OP_UGREATERTHAN) { return MIR_OP_ICMP_UGT; }
    if (op == SPIRV_OP_UGREATERTHANEQUAL) { return MIR_OP_ICMP_UGE; }
    if (op == SPIRV_OP_ULESSTHAN) { return MIR_OP_ICMP_ULT; }
    if (op == SPIRV_OP_ULESSTHANEQUAL) { return MIR_OP_ICMP_ULE; }
    if (op == SPIRV_OP_SGREATERTHAN) { return MIR_OP_ICMP_SGT; }
    if (op == SPIRV_OP_SGREATERTHANEQUAL) { return MIR_OP_ICMP_SGE; }
    if (op == SPIRV_OP_SLESSTHAN) { return MIR_OP_ICMP_SLT; }
    if (op == SPIRV_OP_SLESSTHANEQUAL) { return MIR_OP_ICMP_SLE; }
    return 0;
}

# Ordered f64 comparison SPIR-V opcode → the GFX9 f64 VOPC opcode (or 0 if not an f64 ordered cmp).
# F.7f.8. (Unordered OpFUnord* not wired; tracked in docs/development/3-2-punchlist.md.)
fn _spirv_fcmp_to_vopc(op): i64 {
    if (op == SPIRV_OP_FORD_LESSTHAN) { return GFX9_VOPC_V_CMP_LT_F64; }
    if (op == SPIRV_OP_FORD_GREATERTHAN) { return GFX9_VOPC_V_CMP_GT_F64; }
    if (op == SPIRV_OP_FORD_LESSTHANEQUAL) { return GFX9_VOPC_V_CMP_LE_F64; }
    if (op == SPIRV_OP_FORD_GREATERTHANEQUAL) { return GFX9_VOPC_V_CMP_GE_F64; }
    if (op == SPIRV_OP_FORD_EQUAL) { return GFX9_VOPC_V_CMP_EQ_F64; }
    if (op == SPIRV_OP_FORD_NOTEQUAL) { return GFX9_VOPC_V_CMP_LG_F64; }
    return 0;
}

# OpFOrd*(result, a, b) → an i32 bool (0/1). f64 compare → VCC (MIR_OP_F64_CMP, opcode in flags),
# then cndmask(0, 1) reads VCC → result. The compare + cndmask are emitted adjacently (mabda-
# generated, so VCC is live by construction); the bool is then a normal VGPR value (order-independent,
# unlike a bare VCC). f64-const operands are materialized first (VOP3/VOPC has no 64-bit literal). F.7f.8.
fn _spirv_lower_fcmp(m, vopc, a, b, result): i64 {
    var ma = _spirv_f64_arg(m, a);  if (ma < 0) { return ma; }
    var mb = _spirv_f64_arg(m, b);  if (mb < 0) { return mb; }
    var ec = mir_emit(m, MIR_OP_F64_CMP, 0, MIR_T_U32, ma, mb, 0, vopc << 8);  if (ec < 0) { return ec; }
    var z = _udiv_op(m, MIR_OP_VMOV, MIR_T_U32, 0, 0, 0, MIR_FLAG_A_IMM);          if (z < 0) { return z; }
    var ones = _udiv_op(m, MIR_OP_VMOV, MIR_T_U32, 0xFFFFFFFF, 0, 0, MIR_FLAG_A_IMM); if (ones < 0) { return ones; }
    # 0/-1 MASK (not 0/1): OpSelect blends it with v_bfi_b32 (mask ? x : y) branchlessly. An i32
    # OpSelect of int consts still gets 0/1 (bfi(mask,1,0)). result = VCC ? -1 : 0. The result type is
    # MIR_T_BOOL — the MARKER that distinguishes a 0/-1 select mask (which OpSelect requires) from an
    # integer-compare bool (MIR_T_U32, lowered to VCC/SCC not a mask). (F.7f.8 review.)
    var er = mir_emit(m, MIR_OP_CNDMASK, result, MIR_T_BOOL, z, ones, 0, 0);    if (er < 0) { return er; }
    return 0;
}

# OpSelect(result, cond, obj1, obj2) → obj1 if cond true else obj2, via v_bfi_b32 (MIR_OP_SELECT).
# `cond` must be a 0/-1 MASK — i.e. the result of an OpFOrd* compare (F.7f.8). f64-const obj1/obj2
# are materialized to VGPR pairs first. (A non-mask cond — e.g. from an integer compare, which lowers
# to VCC/SCC not a mask value — is not supported here; that needs a unified bool representation.)
fn _spirv_lower_select(ptr, off, wc, types, m): i64 {
    if (wc < 6) { return 0 - MIR_ERR_UNSUPPORTED_OP; }
    var rty = _mir_lower_type(types, spirv_word(ptr, off + 1), spirv_hdr_id_bound(ptr));
    if (rty == MIR_T_UNSUPPORTED) { return 0 - MIR_ERR_UNSUPPORTED_TYPE; }
    if (mir_type_count(rty) != 1) { return 0 - MIR_ERR_UNSUPPORTED_TYPE; }   # vector select not wired (punchlist)
    var result = spirv_word(ptr, off + 2);
    var cond = spirv_word(ptr, off + 3);
    # ENFORCE: cond must be a 0/-1 select MASK — an OpFOrd* result (SSA, MIR_T_BOOL). v_bfi_b32 needs
    # exactly 0/0xFFFFFFFF; any other cond (a bool CONSTANT, or an integer-compare bool which lowers to
    # VCC/SCC with no mask register) would silently corrupt the blend. Fail loud instead. (F.7f.8 review.)
    if (cond == 0) { return 0 - MIR_ERR_UNSUPPORTED_OP; }
    if (cond >= load64(m + 64)) { return 0 - MIR_ERR_ID_OOR; }
    if (mir_val_kind(m, cond) != MIR_VK_SSA) { return 0 - MIR_ERR_UNSUPPORTED_OP; }
    if (mir_type_base(mir_val_type(m, cond)) != MIR_T_BOOL) { return 0 - MIR_ERR_UNSUPPORTED_OP; }
    var x = _spirv_f64_arg(m, spirv_word(ptr, off + 4));  if (x < 0) { return x; }   # obj1 (true)
    var y = _spirv_f64_arg(m, spirv_word(ptr, off + 5));  if (y < 0) { return y; }   # obj2 (false)
    return mir_emit(m, MIR_OP_SELECT, result, rty, cond, x, y, 0);
}

# A unary op (conversion): result-type(w1), result(w2), src(w3).
fn _spirv_lower_unary(ptr, off, wc, mop, types, m): i64 {
    if (wc < 4) { return 0 - MIR_ERR_UNSUPPORTED_OP; }
    var rty = _mir_lower_type(types, spirv_word(ptr, off + 1), spirv_hdr_id_bound(ptr));
    if (rty == MIR_T_UNSUPPORTED) { return 0 - MIR_ERR_UNSUPPORTED_TYPE; }
    var e = mir_emit(m, mop, spirv_word(ptr, off + 2), rty, spirv_word(ptr, off + 3), 0, 0, 0);
    if (e < 0) { return e; }
    return 0;
}

# OpLoad: a load of a builtin variable aliases the result to the seeded builtin
# value (no instruction); a load of a buffer pointer (an OpAccessChain result,
# kind PTR) emits MIR_OP_LOAD referencing the ptr side-table record (a = off_id
# OpLoad of a vecN element (N.10c): emit N scalar loads at consecutive `esize`-byte offsets
# (off_id + j*esize) into N consecutive component synths, then register the result vector. The
# base byte offset (off_id, a VGPR) already accounts for the array index * element stride; the
# per-component +j*esize is a synth IADD (j>0). esize = 4 for i32/f32 components, 8 for f64
# (F.7e review: a hardcoded *4 mis-addressed f64 vec components, which are 8 bytes apart). The
# components are packed MIR_VK_VECTOR. (HW-tested for f32 vec; f64 vec arrays land with breadth.)
fn _spirv_lower_vec_load(m, result, elem, count, off_id, pidx): i64 {
    var base_ty = mir_type_base(elem);
    var esize = 4;
    if (base_ty == MIR_T_F64) { esize = 8; }
    var base = mir_alloc_synth_id(m);
    if (base < 0) { return 0 - MIR_ERR_ID_OOR; }
    var k = 1;
    while (k < count) {
        var s = mir_alloc_synth_id(m);
        if (s < 0) { return 0 - MIR_ERR_ID_OOR; }
        k = k + 1;
    }
    if (base + count > 0x10000) { return 0 - MIR_ERR_ID_OOR; }
    var packed = 0;
    var i = 0;
    while (i < count) {
        var coff = off_id;
        if (i > 0) {
            coff = mir_alloc_synth_id(m);
            if (coff < 0) { return 0 - MIR_ERR_ID_OOR; }
            var ea = mir_emit(m, MIR_OP_IADD, coff, MIR_T_U32, off_id, i * esize, 0, MIR_FLAG_B_IMM);
            if (ea < 0) { return ea; }
        }
        var e = mir_emit(m, MIR_OP_LOAD, base + i, base_ty, coff, pidx, 0, MIR_FLAG_B_IMM);
        if (e < 0) { return e; }
        packed = packed | ((base + i) << (i * 16));
        i = i + 1;
    }
    return mir_set_vector(m, result, elem, packed);
}

# OpStore of a vecN value to a vecN element (N.10c): N scalar stores of the packed components at
# off_id + j*esize (esize = 4 for i32/f32, 8 for f64 — F.7e review). The value MUST be a
# matching-count vector (else fail loud).
fn _spirv_lower_vec_store(m, elem, count, off_id, pidx, value): i64 {
    if (mir_is_vector(m, value) != 1) { return 0 - MIR_ERR_UNSUPPORTED_OP; }
    if (mir_type_count(mir_val_type(m, value)) != count) { return 0 - MIR_ERR_UNSUPPORTED_TYPE; }
    var esize = 4;
    if (mir_type_base(elem) == MIR_T_F64) { esize = 8; }
    var i = 0;
    while (i < count) {
        var coff = off_id;
        if (i > 0) {
            coff = mir_alloc_synth_id(m);
            if (coff < 0) { return 0 - MIR_ERR_ID_OOR; }
            var ea = mir_emit(m, MIR_OP_IADD, coff, MIR_T_U32, off_id, i * esize, 0, MIR_FLAG_B_IMM);
            if (ea < 0) { return ea; }
        }
        var cv = mir_vec_comp(m, value, i);
        cv = _spirv_f64_arg(m, cv);  if (cv < 0) { return cv; }   # f64-const component → VGPR pair (F.7f.9)
        var e = mir_emit(m, MIR_OP_STORE, 0, MIR_T_VOID, coff, pidx, cv, MIR_FLAG_B_IMM);
        if (e < 0) { return e; }
        i = i + 1;
    }
    return 0;
}

# so the uniformity sweep classifies the load; b = ptr index for N.3).
fn _spirv_lower_load(ptr, off, wc, m): i64 {
    if (wc < 4) { return 0 - MIR_ERR_UNSUPPORTED_OP; }
    var src = spirv_word(ptr, off + 3);
    # `src` indexes vals[] (sized cap_ids) — bound it before mir_val_kind reads it.
    if (src == 0) { return 0 - MIR_ERR_UNSUPPORTED_OP; }
    if (src >= load64(m + 64)) { return 0 - MIR_ERR_ID_OOR; }
    var k = mir_val_kind(m, src);
    if (k == MIR_VK_BUILTIN) {
        return _mir_set_val(m, spirv_word(ptr, off + 2), MIR_VK_BUILTIN,
        mir_val_type(m, src), mir_val_unif(m, src), 0 - 1, mir_val_payload(m, src));
    }
    if (k == MIR_VK_PTR) {
        var pidx = mir_val_payload(m, src);
        var elem = mir_ptr_elem_type(m, pidx);
        var ecount = mir_type_count(elem);
        if (ecount > 1) {
            return _spirv_lower_vec_load(m, spirv_word(ptr, off + 2), elem, ecount, mir_ptr_off_id(m, pidx), pidx);
        }
        var e = mir_emit(m, MIR_OP_LOAD, spirv_word(ptr, off + 2), elem,
        mir_ptr_off_id(m, pidx), pidx, 0, MIR_FLAG_B_IMM);
        if (e < 0) { return e; }
        return 0;
    }
    return 0 - MIR_ERR_UNSUPPORTED_OP;
}

# OpStore %pointer %object: pointer(w1, a PTR), object(w2, the value). Emits
# MIR_OP_STORE (no result; a = off_id, b = ptr index, c = value id).
fn _spirv_lower_store(ptr, off, wc, m): i64 {
    if (wc < 3) { return 0 - MIR_ERR_UNSUPPORTED_OP; }
    var pid = spirv_word(ptr, off + 1);
    if (pid == 0) { return 0 - MIR_ERR_UNSUPPORTED_OP; }
    if (pid >= load64(m + 64)) { return 0 - MIR_ERR_ID_OOR; }
    if (mir_val_kind(m, pid) != MIR_VK_PTR) { return 0 - MIR_ERR_UNSUPPORTED_OP; }
    var pidx = mir_val_payload(m, pid);
    var value = spirv_word(ptr, off + 2);
    if (value == 0) { return 0 - MIR_ERR_UNSUPPORTED_OP; }
    if (value >= load64(m + 64)) { return 0 - MIR_ERR_ID_OOR; }
    var elem = mir_ptr_elem_type(m, pidx);
    var ecount = mir_type_count(elem);
    if (ecount > 1) { return _spirv_lower_vec_store(m, elem, ecount, mir_ptr_off_id(m, pidx), pidx, value); }
    value = _spirv_f64_arg(m, value);  if (value < 0) { return value; }   # f64-const store value → VGPR pair (F.7f.9)
    var e = mir_emit(m, MIR_OP_STORE, 0, MIR_T_VOID, mir_ptr_off_id(m, pidx), pidx, value, MIR_FLAG_B_IMM);
    if (e < 0) { return e; }
    return 0;
}

fn _spirv_finish_ptr(m, rid, binding, elem, off_id, const_off, dynamic): i64 {
    var pr = mir_add_ptr(m, rid, binding, elem, off_id, const_off, dynamic);
    if (pr < 0) { return pr; }
    return 0;
}

# OpAccessChain, MVP shape: pointer -> struct{ runtimearray<scalar> }, exactly two
# indices: result-type(w1, pointer-to-element), result(w2, %ptr), base(w3, %var),
# member-index(w4, const = 0), array-index(w5, id). Records a (binding, byte-
# offset) access; byte offset = array_index * element_stride. A constant index
# folds to const_off (overflow-guarded); a dynamic index emits a synth IMUL whose
# result is off_id. Deeper nesting / non-zero member / non-pointer result-type all
# fail loud (deferred; see docs/development/3-2-punchlist.md, N.6). The dynamic-index
# range vs the array length is an N.6/audit gate (runtime length not statically known here).
fn _spirv_lower_access_chain(ptr, off, wc, types, consts, deco, m): i64 {
    var idb = spirv_hdr_id_bound(ptr);
    if (wc != 6) { return 0 - MIR_ERR_BAD_ACCESS_CHAIN; }
    var rty = spirv_word(ptr, off + 1);
    var rid = spirv_word(ptr, off + 2);
    var base = spirv_word(ptr, off + 3);
    var midx = spirv_word(ptr, off + 4);
    var aidx = spirv_word(ptr, off + 5);
    if (rty == 0) { return 0 - MIR_ERR_BAD_ACCESS_CHAIN; }
    if (rty >= idb) { return 0 - MIR_ERR_ID_OOR; }
    if (base == 0) { return 0 - MIR_ERR_BAD_ACCESS_CHAIN; }
    if (base >= idb) { return 0 - MIR_ERR_ID_OOR; }
    if (midx >= idb) { return 0 - MIR_ERR_ID_OOR; }
    if (aidx == 0) { return 0 - MIR_ERR_BAD_ACCESS_CHAIN; }
    if (aidx >= idb) { return 0 - MIR_ERR_ID_OOR; }
    if (spirv_type_kind(types, rty) != SPIRV_TYK_POINTER) { return 0 - MIR_ERR_BAD_ACCESS_CHAIN; }
    var elem = _mir_lower_type(types, spirv_type_p1(types, rty), idb);
    if (elem == MIR_T_UNSUPPORTED) { return 0 - MIR_ERR_UNSUPPORTED_TYPE; }
    # Element stride: a scalar element is `esize` bytes (4 for i32/f32, 8 for f64 — F.7e); a vecN
    # element uses the std430 array stride (vec2 → 2*esize, vec3/vec4 → 4*esize; vec3 is padded).
    # N.10c: this is what lets `array<vecN>` be indexed, with OpLoad/OpStore scalarizing the
    # element into consecutive components. std430 is the SSBO default — a non-default ArrayStride
    # decoration is not consulted (an MVP layout assumption, like the single-member-struct limit).
    var esize = 4;
    if (mir_type_base(elem) == MIR_T_F64) { esize = 8; }
    var ecount = mir_type_count(elem);
    var stride = esize;
    if (ecount != 1) {
        if (ecount == 2) { stride = esize * 2; } else { stride = esize * 4; }
    }
    # MVP: single-member struct, the member index must be the constant 0.
    if (spirv_const_type(consts, midx) == 0) { return 0 - MIR_ERR_BAD_ACCESS_CHAIN; }
    if (spirv_const_value(consts, midx) != 0) { return 0 - MIR_ERR_BAD_ACCESS_CHAIN; }
    var binding = spirv_deco_binding(deco, base);
    # constant array index -> materialize the constant byte offset into a VGPR. The index
    # must be an INTEGER constant (else its bits would be reinterpreted as the index), and
    # the byte offset must not overflow i32. The FLAT load/store emitter requires the per-lane
    # offset in a VGPR (the immediate-offset FLAT form is a later optimization), so a constant
    # index is VMOV'd into a synth VGPR rather than folded to a const_off the back end can't
    # consume — this is what enables constant-index buffer access (N.10b; prior kernels only
    # ever used the dynamic gid offset). The offset is uniform, but a VMOV forces it to a VGPR,
    # which is correct: every lane addresses the same element.
    if (spirv_const_type(consts, aidx) != 0) {
        var aty = _mir_lower_type(types, spirv_const_type(consts, aidx), idb);
        if (aty != MIR_T_I32) {
            if (aty != MIR_T_U32) { return 0 - MIR_ERR_BAD_ACCESS_CHAIN; }
        }
        var civ = spirv_const_value(consts, aidx);
        if (civ > (0x7FFFFFFF / stride)) { return 0 - MIR_ERR_OVERFLOW; }
        var coff = mir_alloc_synth_id(m);
        if (coff < 0) { return 0 - MIR_ERR_ID_OOR; }
        var em = mir_emit(m, MIR_OP_VMOV, coff, MIR_T_U32, civ * stride, 0, 0, MIR_FLAG_A_IMM);
        if (em < 0) { return em; }
        return _spirv_finish_ptr(m, rid, binding, elem, coff, 0, 1);
    }
    # dynamic array index -> off_id = aidx * stride (synth IMUL; stride immediate). No overflow
    # guard: aidx is a runtime value, and an out-of-bounds array index is UNDEFINED in SPIR-V
    # (the consumer owns in-range indices) — unlike the constant path, which folds at compile
    # time and so CAN bound the offset. Runtime bounds-checking is out of the compiler's scope
    # (a non-regression: the gid-indexed scalar path has always behaved this way). N.10c review #5.
    var off_id = mir_alloc_synth_id(m);
    if (off_id < 0) { return 0 - MIR_ERR_ID_OOR; }
    var e = mir_emit(m, MIR_OP_IMUL, off_id, MIR_T_U32, aidx, stride, 0, MIR_FLAG_B_IMM);
    if (e < 0) { return e; }
    return _spirv_finish_ptr(m, rid, binding, elem, off_id, 0, 1);
}

# Lower one executable body instruction. Returns 0, or a negative error.
# Expand GlobalInvocationId.comp into the standard compute index identity
# gid.comp = WorkgroupId.comp * local_size_comp + LocalInvocationId.comp. `result`
# keeps the original OpCompositeExtract <id> (so downstream access chains still
# reference it). Synthesizes the two primitive builtins + their per-component
# extracts + the mul/add; the uniformity sweep then classifies the wgid-extract
# and the mul as UNIFORM (→ s_mul) and the +lid add as DIVERGENT (→ v_add), and
# the N.5c-2a EXTRACT file-class rule puts wgid in an SGPR, lid in a VGPR.
fn _spirv_expand_gid(m, result, ety, comp, lsz_c): i64 {
    var wgid = mir_alloc_synth_id(m);
    if (wgid < 0) { return 0 - MIR_ERR_ID_OOR; }
    var r1 = mir_set_builtin(m, wgid, ety, MIR_BI_WORKGROUP_ID);
    if (r1 < 0) { return r1; }
    var lid = mir_alloc_synth_id(m);
    if (lid < 0) { return 0 - MIR_ERR_ID_OOR; }
    var r2 = mir_set_builtin(m, lid, ety, MIR_BI_LOCAL_INVOC_ID);
    if (r2 < 0) { return r2; }
    var wcid = mir_alloc_synth_id(m);
    if (wcid < 0) { return 0 - MIR_ERR_ID_OOR; }
    var e1 = mir_emit(m, MIR_OP_EXTRACT, wcid, ety, wgid, 0, comp, MIR_FLAG_C_IMM);
    if (e1 < 0) { return e1; }
    var lcid = mir_alloc_synth_id(m);
    if (lcid < 0) { return 0 - MIR_ERR_ID_OOR; }
    var e2 = mir_emit(m, MIR_OP_EXTRACT, lcid, ety, lid, 0, comp, MIR_FLAG_C_IMM);
    if (e2 < 0) { return e2; }
    var scaled = mir_alloc_synth_id(m);
    if (scaled < 0) { return 0 - MIR_ERR_ID_OOR; }
    var e3 = mir_emit(m, MIR_OP_IMUL, scaled, ety, wcid, lsz_c, 0, MIR_FLAG_B_IMM);
    if (e3 < 0) { return e3; }
    return mir_emit(m, MIR_OP_IADD, result, ety, scaled, lcid, 0, 0);
}

# Allocate a fresh synth id and emit one op into it; returns the id (>= 1) or a negative
# error. The udiv macro chains these.
fn _udiv_op(m, op, type, a, b, c, flags): i64 {
    var id = mir_alloc_synth_id(m);
    if (id < 0) { return 0 - MIR_ERR_ID_OOR; }
    var e = mir_emit(m, op, id, type, a, b, c, flags);
    if (e < 0) { return e; }
    return id;
}

# OpUDiv(result, N, D) → LLVM's gfx900 float-reciprocal VECTOR macro (N.9b). Loop-free,
# 19 core ops; N/D are first VMOV'd into VGPRs (force-vector, so uniform/const operands
# work). The two cmp_ge/cndmask correction pairs are emitted contiguously so the implicit
# VCC survives (nothing between writes VCC; no waitcnt is inserted there). 0x4F7FFFFE is
# the magic reciprocal scale (biases the estimate down so v_rcp's ≤1-ULP error can't
# overshoot). b=0 → q saturates to 0xFFFFFFFF (pinned in the HW test).
# The shared u32 division CORE: VMOV N/D into VGPRs, then LLVM's float-reciprocal
# sequence through correction-1 (the Newton-refined reciprocal, the quotient estimate,
# remainder, and the first correction). Writes [dc, nc, q2, m2] into out (4 i64 slots) for
# OpUDiv/OpUMod (and later signed peers) to apply their final correction + zero guard.
fn _udiv_core(m, nn, dd, out): i64 {
    var u = MIR_T_U32;
    var f = MIR_T_F32;
    var nc = _udiv_op(m, MIR_OP_VMOV, u, nn, 0, 0, 0);            if (nc < 0) { return nc; }
    var dc = _udiv_op(m, MIR_OP_VMOV, u, dd, 0, 0, 0);            if (dc < 0) { return dc; }
    var r1 = _udiv_op(m, MIR_OP_CVT_F32_U, f, dc, 0, 0, 0);       if (r1 < 0) { return r1; }
    var r2 = _udiv_op(m, MIR_OP_RCP_IFLAG, f, r1, 0, 0, 0);       if (r2 < 0) { return r2; }
    var r3 = _udiv_op(m, MIR_OP_FMUL, f, r2, 0x4F7FFFFE, 0, MIR_FLAG_B_IMM); if (r3 < 0) { return r3; }
    var r4 = _udiv_op(m, MIR_OP_CVT_U_F32, u, r3, 0, 0, 0);       if (r4 < 0) { return r4; }
    var t1 = _udiv_op(m, MIR_OP_ISUB, u, 0, dc, 0, MIR_FLAG_A_IMM); if (t1 < 0) { return t1; }
    var t2 = _udiv_op(m, MIR_OP_IMUL, u, t1, r4, 0, 0);          if (t2 < 0) { return t2; }
    var t3 = _udiv_op(m, MIR_OP_MUL_HI, u, r4, t2, 0, 0);        if (t3 < 0) { return t3; }
    var r5 = _udiv_op(m, MIR_OP_IADD, u, r4, t3, 0, 0);          if (r5 < 0) { return r5; }
    var q1 = _udiv_op(m, MIR_OP_MUL_HI, u, nc, r5, 0, 0);        if (q1 < 0) { return q1; }
    var t4 = _udiv_op(m, MIR_OP_IMUL, u, q1, dc, 0, 0);          if (t4 < 0) { return t4; }
    var m1 = _udiv_op(m, MIR_OP_ISUB, u, nc, t4, 0, 0);          if (m1 < 0) { return m1; }
    var s1 = _udiv_op(m, MIR_OP_IADD, u, q1, 1, 0, MIR_FLAG_B_IMM); if (s1 < 0) { return s1; }
    var c1 = _udiv_op(m, MIR_OP_ICMP_UGE, u, m1, dc, 0, 0);      if (c1 < 0) { return c1; }
    var t5 = _udiv_op(m, MIR_OP_ISUB, u, m1, dc, 0, 0);          if (t5 < 0) { return t5; }
    var q2 = _udiv_op(m, MIR_OP_CNDMASK, u, q1, s1, 0, 0);       if (q2 < 0) { return q2; }
    var m2 = _udiv_op(m, MIR_OP_CNDMASK, u, m1, t5, 0, 0);       if (m2 < 0) { return m2; }
    store64(out + 0, dc);
    store64(out + 8, nc);
    store64(out + 16, q2);
    store64(out + 24, m2);
    return 0;
}

# OpUDiv: the core + the quotient's correction-2 (q+1 when m2>=D), then a divide-by-zero
# guard pinning a deterministic 0xFFFFFFFF (the bare macro yields a-derived garbage; the
# common GPU all-ones convention — N.9b-2).
fn _spirv_lower_udiv(ptr, off, wc, m): i64 {
    if (wc < 5) { return 0 - MIR_ERR_UNSUPPORTED_OP; }
    var result = spirv_word(ptr, off + 2);
    var co[32];
    var rc = _udiv_core(m, spirv_word(ptr, off + 3), spirv_word(ptr, off + 4), &co);
    if (rc < 0) { return rc; }
    var dc = load64(&co + 0);
    var q2 = load64(&co + 16);
    var m2 = load64(&co + 24);
    var u = MIR_T_U32;
    var s2 = _udiv_op(m, MIR_OP_IADD, u, q2, 1, 0, MIR_FLAG_B_IMM); if (s2 < 0) { return s2; }
    var c2 = _udiv_op(m, MIR_OP_ICMP_UGE, u, m2, dc, 0, 0);      if (c2 < 0) { return c2; }
    var qf = _udiv_op(m, MIR_OP_CNDMASK, u, q2, s2, 0, 0);       if (qf < 0) { return qf; }
    var ones = _udiv_op(m, MIR_OP_VMOV, u, 0xFFFFFFFF, 0, 0, MIR_FLAG_A_IMM); if (ones < 0) { return ones; }
    var cz = _udiv_op(m, MIR_OP_ICMP_EQ, u, 0, dc, 0, MIR_FLAG_A_IMM);  if (cz < 0) { return cz; }
    var er = mir_emit(m, MIR_OP_CNDMASK, result, u, qf, ones, 0, 0);  # (dc==0) ? ones : qf
    if (er < 0) { return er; }
    return 0;
}

# OpUMod: the same core, then the REMAINDER's correction-2 (m2-D when m2>=D). Divide-by-
# zero → r = N (the dividend) — the standard remainder-of-zero convention (N.9c).
fn _spirv_lower_umod(ptr, off, wc, m): i64 {
    if (wc < 5) { return 0 - MIR_ERR_UNSUPPORTED_OP; }
    var result = spirv_word(ptr, off + 2);
    var co[32];
    var rc = _udiv_core(m, spirv_word(ptr, off + 3), spirv_word(ptr, off + 4), &co);
    if (rc < 0) { return rc; }
    var dc = load64(&co + 0);
    var nc = load64(&co + 8);
    var m2 = load64(&co + 24);
    var u = MIR_T_U32;
    var c2 = _udiv_op(m, MIR_OP_ICMP_UGE, u, m2, dc, 0, 0);      if (c2 < 0) { return c2; }
    var t6 = _udiv_op(m, MIR_OP_ISUB, u, m2, dc, 0, 0);          if (t6 < 0) { return t6; }
    var mf = _udiv_op(m, MIR_OP_CNDMASK, u, m2, t6, 0, 0);       if (mf < 0) { return mf; }
    var cz = _udiv_op(m, MIR_OP_ICMP_EQ, u, 0, dc, 0, MIR_FLAG_A_IMM);  if (cz < 0) { return cz; }
    var er = mir_emit(m, MIR_OP_CNDMASK, result, u, mf, nc, 0, 0);  # (dc==0) ? nc : mf
    if (er < 0) { return er; }
    return 0;
}

# OpFDiv(result, N, D) → the LLVM gfx900 correctly-rounded f64 division: a scaled-reciprocal
# Newton macro. GFX9 has no f64 divide and v_rcp_f64 is only an ~f32-precision seed (the F.7f.5
# finding), so the quotient is refined to full f64 precision: two DIV_SCALE ops normalise the
# operands (the second writes the scale flag to VCC), v_rcp_f64 seeds 1/D, three FMA Newton
# steps lift it to ~full precision, then DIV_FMAS (which reads VCC for the 2^±64 fixup) and
# DIV_FIXUP produce the correctly-rounded result. The chain is emitted contiguously so VCC
# from the 2nd DIV_SCALE survives to DIV_FMAS (the FMA/MUL between never write VCC).
# f64-only — f32 FDiv is a parallel (simpler) macro with no consumer yet (wgpu/naga covers
# the f32 portable path); it fails loud here (tracked: punchlist F.7f, native-f32-div note).
fn _spirv_lower_fdiv(ptr, off, wc, types, m): i64 {
    if (wc < 5) { return 0 - MIR_ERR_UNSUPPORTED_OP; }
    var rty = _mir_lower_type(types, spirv_word(ptr, off + 1), spirv_hdr_id_bound(ptr));
    if (mir_type_base(rty) != MIR_T_F64) { return 0 - MIR_ERR_UNSUPPORTED_TYPE; }
    if (mir_type_count(rty) != 1) { return 0 - MIR_ERR_UNSUPPORTED_TYPE; }
    var result = spirv_word(ptr, off + 2);
    var a = spirv_word(ptr, off + 3);   # N — dividend (numerator)
    var b = spirv_word(ptr, off + 4);   # D — divisor (denominator)
    a = _spirv_f64_arg(m, a);  if (a < 0) { return a; }   # f64-const operand → VGPR pair (F.7f.9)
    b = _spirv_f64_arg(m, b);  if (b < 0) { return b; }
    var t = MIR_T_F64;
    # s0 = div_scale(D, D, N) — scaled denominator; its VCC flag is dead (overwritten below).
    var s0 = _udiv_op(m, MIR_OP_F64_DIV_SCALE, t, b, b, a, 0);       if (s0 < 0) { return s0; }
    var rcp = _udiv_op(m, MIR_OP_F64_RCP, t, s0, 0, 0, 0);          if (rcp < 0) { return rcp; }
    var e1 = _udiv_op(m, MIR_OP_F64_FMA_N0_ONE, t, s0, rcp, 0, 0);  if (e1 < 0) { return e1; }
    var rcp2 = _udiv_op(m, MIR_OP_FMA, t, rcp, e1, rcp, 0);         if (rcp2 < 0) { return rcp2; }
    # s1 = div_scale(N, D, N) — scaled numerator; its VCC flag is LIVE → DIV_FMAS reads it.
    var s1 = _udiv_op(m, MIR_OP_F64_DIV_SCALE, t, a, b, a, 0);      if (s1 < 0) { return s1; }
    var e2 = _udiv_op(m, MIR_OP_F64_FMA_N0_ONE, t, s0, rcp2, 0, 0); if (e2 < 0) { return e2; }
    var rcp3 = _udiv_op(m, MIR_OP_FMA, t, rcp2, e2, rcp2, 0);       if (rcp3 < 0) { return rcp3; }
    var q = _udiv_op(m, MIR_OP_FMUL, t, s1, rcp3, 0, 0);            if (q < 0) { return q; }
    var r = _udiv_op(m, MIR_OP_F64_FMA_N0, t, s0, q, s1, 0);        if (r < 0) { return r; }
    var qf = _udiv_op(m, MIR_OP_F64_DIV_FMAS, t, r, rcp3, q, 0);    if (qf < 0) { return qf; }
    var er = mir_emit(m, MIR_OP_F64_DIV_FIXUP, result, t, qf, b, a, 0);
    if (er < 0) { return er; }
    return 0;
}

# GLSL.std.450 Sqrt (f64) → the full-range LLVM gfx900 expansion (F.7f.7b core + 7c wrapper). GFX9
# has no f64 sqrt and v_sqrt_f64 is only an ~f32-precision approximation (F.7f.5), so:
#  (1) subnormal scale-up — vcc_sub = (2^-767 > x); scale tiny x up by 2^256 (else 2^0) so the
#      Newton core keeps full precision (rsq/products of a subnormal would underflow);
#  (2) Newton-Goldschmidt — v_rsq_f64 seed + simultaneous sqrt/rsqrt refinement (h≈√xs, g≈0.5/√xs),
#      two correction rounds → correctly-rounded sqrt(xs);
#  (3) rescale — multiply the result by 2^-128 when x was scaled (sqrt halves the exponent shift);
#  (4) special-case — v_cmp_class_f64 (mask 0x260 = +0/-0/+inf) passes those classes through (the
#      Newton path would give 0·inf=NaN). NaN/negative take the Newton path → NaN (correct).
# DUAL VCC: vcc_sub (from CMP_GT) drives BOTH cndmasks (scale-up + rescale) and must survive the
# whole core — only VMOV/LDEXP/FMA/MUL sit between, none of which write VCC; then CMP_CLASS
# overwrites VCC with vcc_class for the final pair-select. The chain is emitted in this exact order.
fn _spirv_lower_fsqrt_f64(m, x, result): i64 {
    var t = MIR_T_F64;
    var u = MIR_T_U32;
    # (1) subnormal gate + scale-up. threshold f64 = 0x1000000000000000 (2^-767): lo dword 0,
    # hi dword 0x10000000 (split across a/b — the MIR record packs operands into 32-bit halves).
    var thr = _udiv_op(m, MIR_OP_F64_CONST, t, 0, 0x10000000, 0, MIR_FLAG_A_IMM | MIR_FLAG_B_IMM);
    if (thr < 0) { return thr; }
    var ecg = mir_emit(m, MIR_OP_F64_CMP_GT, 0, u, thr, x, 0, 0);  if (ecg < 0) { return ecg; }  # VCC=thr>x
    var z = _udiv_op(m, MIR_OP_VMOV, u, 0, 0, 0, MIR_FLAG_A_IMM);          if (z < 0) { return z; }
    var c256 = _udiv_op(m, MIR_OP_VMOV, u, 256, 0, 0, MIR_FLAG_A_IMM);     if (c256 < 0) { return c256; }
    var sup = _udiv_op(m, MIR_OP_CNDMASK, u, z, c256, 0, 0);               if (sup < 0) { return sup; }
    var xs = _udiv_op(m, MIR_OP_F64_LDEXP, t, x, sup, 0, 0);               if (xs < 0) { return xs; }
    # (2) Newton-Goldschmidt core on the scaled input xs.
    var rsq = _udiv_op(m, MIR_OP_F64_RSQ, t, xs, 0, 0, 0);                 if (rsq < 0) { return rsq; }
    var h = _udiv_op(m, MIR_OP_FMUL, t, xs, rsq, 0, 0);                    if (h < 0) { return h; }
    var g = _udiv_op(m, MIR_OP_F64_MUL_HALF, t, rsq, 0, 0, 0);            if (g < 0) { return g; }
    var r = _udiv_op(m, MIR_OP_F64_FMA_N0_HALF, t, g, h, 0, 0);           if (r < 0) { return r; }  # 0.5-g*h
    var h2 = _udiv_op(m, MIR_OP_FMA, t, h, r, h, 0);                      if (h2 < 0) { return h2; }
    var g2 = _udiv_op(m, MIR_OP_FMA, t, g, r, g, 0);                     if (g2 < 0) { return g2; }
    var d = _udiv_op(m, MIR_OP_F64_FMA_N0, t, h2, h2, xs, 0);            if (d < 0) { return d; }  # xs-h*h
    var h3 = _udiv_op(m, MIR_OP_FMA, t, d, g2, h2, 0);                   if (h3 < 0) { return h3; }
    var d2 = _udiv_op(m, MIR_OP_F64_FMA_N0, t, h3, h3, xs, 0);           if (d2 < 0) { return d2; }
    var core = _udiv_op(m, MIR_OP_FMA, t, d2, g2, h3, 0);                if (core < 0) { return core; }
    # (3) rescale-down (reads the SAME vcc_sub) + (4) special-case passthrough (new vcc_class).
    var cn = _udiv_op(m, MIR_OP_VMOV, u, 0xFFFFFF80, 0, 0, MIR_FLAG_A_IMM); if (cn < 0) { return cn; }  # -128
    var resc = _udiv_op(m, MIR_OP_CNDMASK, u, z, cn, 0, 0);               if (resc < 0) { return resc; }
    var mask = _udiv_op(m, MIR_OP_VMOV, u, 0x260, 0, 0, MIR_FLAG_A_IMM);  if (mask < 0) { return mask; }
    var ecl = mir_emit(m, MIR_OP_F64_CMP_CLASS, 0, u, xs, mask, 0, 0);    if (ecl < 0) { return ecl; }  # VCC=class
    var rr = _udiv_op(m, MIR_OP_F64_LDEXP, t, core, resc, 0, 0);          if (rr < 0) { return rr; }
    var ecm = mir_emit(m, MIR_OP_F64_CNDMASK, result, t, rr, xs, 0, 0);   # vcc_class ? xs : rr
    if (ecm < 0) { return ecm; }
    return 0;
}

# Signed-division prep: sign masks (ASHR 31 → 0 or 0xFFFFFFFF) + magnitudes via the
# branchless abs (x^sign)-sign. Writes [signA, signB, absA, absB] into out (N.9d).
fn _signed_prep(m, a, b, out): i64 {
    var u = MIR_T_U32;
    var sa = _udiv_op(m, MIR_OP_ASHR, u, a, 31, 0, MIR_FLAG_B_IMM);  if (sa < 0) { return sa; }
    var sb = _udiv_op(m, MIR_OP_ASHR, u, b, 31, 0, MIR_FLAG_B_IMM);  if (sb < 0) { return sb; }
    var xa = _udiv_op(m, MIR_OP_XOR, u, a, sa, 0, 0);               if (xa < 0) { return xa; }
    var aa = _udiv_op(m, MIR_OP_ISUB, u, xa, sa, 0, 0);             if (aa < 0) { return aa; }
    var xb = _udiv_op(m, MIR_OP_XOR, u, b, sb, 0, 0);               if (xb < 0) { return xb; }
    var ab = _udiv_op(m, MIR_OP_ISUB, u, xb, sb, 0, 0);            if (ab < 0) { return ab; }
    store64(out + 0, sa);
    store64(out + 8, sb);
    store64(out + 16, aa);
    store64(out + 24, ab);
    return 0;
}

# OpSDiv (135): truncated signed division (toward zero). Sign-magnitude wrapper — run the
# unsigned quotient on |a|/|b|, then apply the result sign (signA ⊕ signB) via (q^rs)-rs.
# Div-by-zero / INT_MIN/-1 are UB in SPIR-V (the value is pinned in the HW test).
fn _spirv_lower_sdiv(ptr, off, wc, m): i64 {
    if (wc < 5) { return 0 - MIR_ERR_UNSUPPORTED_OP; }
    var result = spirv_word(ptr, off + 2);
    var u = MIR_T_U32;
    var sp[32];
    var rp = _signed_prep(m, spirv_word(ptr, off + 3), spirv_word(ptr, off + 4), &sp);
    if (rp < 0) { return rp; }
    var sa = load64(&sp + 0);
    var sb = load64(&sp + 8);
    var co[32];
    var rc = _udiv_core(m, load64(&sp + 16), load64(&sp + 24), &co);
    if (rc < 0) { return rc; }
    var dc = load64(&co + 0);
    var q2 = load64(&co + 16);
    var m2 = load64(&co + 24);
    var s2 = _udiv_op(m, MIR_OP_IADD, u, q2, 1, 0, MIR_FLAG_B_IMM); if (s2 < 0) { return s2; }
    var c2 = _udiv_op(m, MIR_OP_ICMP_UGE, u, m2, dc, 0, 0);        if (c2 < 0) { return c2; }
    var qf = _udiv_op(m, MIR_OP_CNDMASK, u, q2, s2, 0, 0);         if (qf < 0) { return qf; }
    var rs = _udiv_op(m, MIR_OP_XOR, u, sa, sb, 0, 0);            if (rs < 0) { return rs; }
    var xq = _udiv_op(m, MIR_OP_XOR, u, qf, rs, 0, 0);            if (xq < 0) { return xq; }
    var er = mir_emit(m, MIR_OP_ISUB, result, u, xq, rs, 0, 0);    # (qf ^ rs) - rs
    if (er < 0) { return er; }
    return 0;
}

# OpSRem (138): signed remainder, sign of the DIVIDEND (C `%`). Unsigned remainder of the
# magnitudes, then apply signA via (r^signA)-signA.
fn _spirv_lower_srem(ptr, off, wc, m): i64 {
    if (wc < 5) { return 0 - MIR_ERR_UNSUPPORTED_OP; }
    var result = spirv_word(ptr, off + 2);
    var u = MIR_T_U32;
    var sp[32];
    var rp = _signed_prep(m, spirv_word(ptr, off + 3), spirv_word(ptr, off + 4), &sp);
    if (rp < 0) { return rp; }
    var sa = load64(&sp + 0);
    var co[32];
    var rc = _udiv_core(m, load64(&sp + 16), load64(&sp + 24), &co);
    if (rc < 0) { return rc; }
    var dc = load64(&co + 0);
    var m2 = load64(&co + 24);
    var c2 = _udiv_op(m, MIR_OP_ICMP_UGE, u, m2, dc, 0, 0);        if (c2 < 0) { return c2; }
    var t6 = _udiv_op(m, MIR_OP_ISUB, u, m2, dc, 0, 0);            if (t6 < 0) { return t6; }
    var mf = _udiv_op(m, MIR_OP_CNDMASK, u, m2, t6, 0, 0);         if (mf < 0) { return mf; }
    var xr = _udiv_op(m, MIR_OP_XOR, u, mf, sa, 0, 0);            if (xr < 0) { return xr; }
    var er = mir_emit(m, MIR_OP_ISUB, result, u, xr, sa, 0, 0);    # (r ^ signA) - signA
    if (er < 0) { return er; }
    return 0;
}

# OpSMod (139): floored modulo, sign of the DIVISOR. Compute the truncated remainder (srem,
# sign of dividend), then the floored fixup: when srem != 0 AND the operand signs differ, add
# the divisor (two chained CNDMASKs gate the add → adj = b iff both hold; else adj = 0).
fn _spirv_lower_smod(ptr, off, wc, m): i64 {
    if (wc < 5) { return 0 - MIR_ERR_UNSUPPORTED_OP; }
    var result = spirv_word(ptr, off + 2);
    var aa_id = spirv_word(ptr, off + 3);
    var bb_id = spirv_word(ptr, off + 4);
    var u = MIR_T_U32;
    var bc = _udiv_op(m, MIR_OP_VMOV, u, bb_id, 0, 0, 0);          if (bc < 0) { return bc; }
    var sp[32];
    var rp = _signed_prep(m, aa_id, bb_id, &sp);                   if (rp < 0) { return rp; }
    var sa = load64(&sp + 0);
    var sb = load64(&sp + 8);
    var co[32];
    var rc = _udiv_core(m, load64(&sp + 16), load64(&sp + 24), &co);  if (rc < 0) { return rc; }
    var dc = load64(&co + 0);
    var m2 = load64(&co + 24);
    # unsigned remainder of the magnitudes, then srem = (r ^ signA) - signA
    var c2 = _udiv_op(m, MIR_OP_ICMP_UGE, u, m2, dc, 0, 0);        if (c2 < 0) { return c2; }
    var t6 = _udiv_op(m, MIR_OP_ISUB, u, m2, dc, 0, 0);            if (t6 < 0) { return t6; }
    var mf = _udiv_op(m, MIR_OP_CNDMASK, u, m2, t6, 0, 0);         if (mf < 0) { return mf; }
    var xr = _udiv_op(m, MIR_OP_XOR, u, mf, sa, 0, 0);            if (xr < 0) { return xr; }
    var sr = _udiv_op(m, MIR_OP_ISUB, u, xr, sa, 0, 0);           if (sr < 0) { return sr; }
    # floored fixup: adj = (signs differ AND sr != 0) ? b : 0 ; smod = sr + adj
    var rs = _udiv_op(m, MIR_OP_XOR, u, sa, sb, 0, 0);            if (rs < 0) { return rs; }
    var zv = _udiv_op(m, MIR_OP_VMOV, u, 0, 0, 0, MIR_FLAG_A_IMM); if (zv < 0) { return zv; }
    var cd = _udiv_op(m, MIR_OP_ICMP_NE, u, 0, rs, 0, MIR_FLAG_A_IMM);  if (cd < 0) { return cd; }
    var bs = _udiv_op(m, MIR_OP_CNDMASK, u, zv, bc, 0, 0);         if (bs < 0) { return bs; }
    var cr = _udiv_op(m, MIR_OP_ICMP_NE, u, 0, sr, 0, MIR_FLAG_A_IMM);  if (cr < 0) { return cr; }
    var aj = _udiv_op(m, MIR_OP_CNDMASK, u, zv, bs, 0, 0);         if (aj < 0) { return aj; }
    var er = mir_emit(m, MIR_OP_IADD, result, u, sr, aj, 0, 0);    # sr + adj
    if (er < 0) { return er; }
    return 0;
}

# OpCompositeConstruct %vecT %r %c0 %c1 [%c2 %c3] — build a vecN from N scalar components.
# GFX9 has no vector registers, so this emits NO instructions: the result is a MIR_VK_VECTOR
# packing the operand <id>s, which consumers (extract / component-wise ops / store) read back
# via mir_vec_comp. MVP: exactly `count` SCALAR operands (a vector operand, or fewer/more than
# count, fails loud; broader Construct deferred — see docs/development/3-2-punchlist.md, N.10). N.10a.
fn _spirv_lower_composite_construct(ptr, off, wc, types, m): i64 {
    if (wc < 4) { return 0 - MIR_ERR_UNSUPPORTED_OP; }
    var idb = spirv_hdr_id_bound(ptr);
    var rty = _mir_lower_type(types, spirv_word(ptr, off + 1), idb);
    if (rty == MIR_T_UNSUPPORTED) { return 0 - MIR_ERR_UNSUPPORTED_TYPE; }
    var count = mir_type_count(rty);
    if (count < 2) { return 0 - MIR_ERR_UNSUPPORTED_OP; }
    if (wc - 3 != count) { return 0 - MIR_ERR_UNSUPPORTED_OP; }   # scalar-per-component MVP
    var cap = load64(m + 64);
    var packed = 0;
    var i = 0;
    while (i < count) {
        var c = spirv_word(ptr, off + 3 + i);
        if (c == 0) { return 0 - MIR_ERR_UNSUPPORTED_OP; }
        if (c >= cap) { return 0 - MIR_ERR_ID_OOR; }
        if (c >= 0x10000) { return 0 - MIR_ERR_ID_OOR; }          # 16-bit component-pack ceiling (defensive)
        # Components must be scalar CONST/SSA values — the kinds the back end resolves as a
        # VMOV/op source. This rejects a nested vector operand, a raw builtin, a pointer, or
        # an undefined id (nested/mixed vectors deferred — see docs/development/3-2-punchlist.md, N.10).
        var ck = mir_val_kind(m, c);
        if (ck != MIR_VK_CONST) { if (ck != MIR_VK_SSA) { return 0 - MIR_ERR_UNSUPPORTED_OP; } }
        packed = packed | (c << (i * 16));
        i = i + 1;
    }
    return mir_set_vector(m, spirv_word(ptr, off + 2), rty, packed);
}

# Component-wise vector binary op (N.10b): emit `count` scalar ops, one per component pair,
# into `count` consecutive synth ids, then register the result as a MIR_VK_VECTOR packing
# them. Each operand is either a vecN of the SAME count+base (use its components) or a scalar
# (broadcast to every lane). The scalar back end sees only scalar ops — vectors never reach it.
fn _spirv_lower_vec_binop(m, mop, rty, rid, aop, bop): i64 {
    var count = mir_type_count(rty);
    var base_ty = mir_type_base(rty);
    var cap = load64(m + 64);
    if (aop == 0) { return 0 - MIR_ERR_UNSUPPORTED_OP; }
    if (aop >= cap) { return 0 - MIR_ERR_ID_OOR; }
    if (bop == 0) { return 0 - MIR_ERR_UNSUPPORTED_OP; }
    if (bop >= cap) { return 0 - MIR_ERR_ID_OOR; }
    # A vector operand must match the result's count AND base type (else malformed / OOB).
    if (mir_is_vector(m, aop) == 1) {
        if (mir_type_count(mir_val_type(m, aop)) != count) { return 0 - MIR_ERR_UNSUPPORTED_TYPE; }
        if (mir_type_base(mir_val_type(m, aop)) != base_ty) { return 0 - MIR_ERR_UNSUPPORTED_TYPE; }
    }
    if (mir_is_vector(m, bop) == 1) {
        if (mir_type_count(mir_val_type(m, bop)) != count) { return 0 - MIR_ERR_UNSUPPORTED_TYPE; }
        if (mir_type_base(mir_val_type(m, bop)) != base_ty) { return 0 - MIR_ERR_UNSUPPORTED_TYPE; }
    }
    # Allocate the `count` component-result synths as a consecutive block (so comp i = base + i).
    var base = mir_alloc_synth_id(m);
    if (base < 0) { return 0 - MIR_ERR_ID_OOR; }
    var k = 1;
    while (k < count) {
        var s = mir_alloc_synth_id(m);
        if (s < 0) { return 0 - MIR_ERR_ID_OOR; }
        k = k + 1;
    }
    if (base + count > 0x10000) { return 0 - MIR_ERR_ID_OOR; }   # 16-bit component-pack ceiling
    var packed = 0;
    var i = 0;
    while (i < count) {
        var ai = aop;
        if (mir_is_vector(m, aop) == 1) { ai = mir_vec_comp(m, aop, i); }
        var bi = bop;
        if (mir_is_vector(m, bop) == 1) { bi = mir_vec_comp(m, bop, i); }
        # Per-component const-fold, mirroring the scalar ALU path (the vector op is routed before
        # that fold). Two constant components must NOT emit a runtime op — a VOP2 cannot take two
        # non-VGPR operands, so it would fail/mis-encode (e.g. vec const + vec const). N.10d review.
        if (_spirv_both_const(m, ai, bi) == 1) {
            var ec = mir_set_const(m, base + i, base_ty, _spirv_const_fold(m, mop, ai, bi));
            if (ec < 0) { return ec; }
        } else {
            # f64-const components (incl. a broadcast scalar f64 const) → materialize to a VGPR pair;
            # VOP3 has no 64-bit literal (else the emit silently truncates to 0.0). (F.7f.9 review)
            var mai = _spirv_f64_arg(m, ai);  if (mai < 0) { return mai; }
            var mbi = _spirv_f64_arg(m, bi);  if (mbi < 0) { return mbi; }
            var e = mir_emit(m, mop, base + i, base_ty, mai, mbi, 0, 0);
            if (e < 0) { return e; }
        }
        packed = packed | ((base + i) << (i * 16));
        i = i + 1;
    }
    return mir_set_vector(m, rid, rty, packed);
}

fn _spirv_lower_one_instr(ptr, off, wc, op, types, consts, deco, m, lsz): i64 {
    # Loops + phi remain unsupported: a back-edge breaks the forward linear-scan
    # liveness, and the MVP if/merge carries no merge-consumed (phi) values.
    if (op == SPIRV_OP_LOOP_MERGE) { return 0 - LOWER_ERR_CONTROL_FLOW; }
    if (op == SPIRV_OP_PHI) { return 0 - LOWER_ERR_CONTROL_FLOW; }
    # SelectionMerge is a structured hint (the merge block id); the back-end derives
    # layout from the LABELs, so it is a no-op here.
    if (op == SPIRV_OP_SELECTION_MERGE) { return 0; }
    # OpLabel %L → a 0-byte LABEL marker (a = label <id>) the back-end resolves
    # branch offsets against. The ENTRY label (the first instruction emitted) is
    # skipped: it is always laid out at offset 0 and is never a branch target in a
    # forward if, so emitting it would shift every straight-line kernel's MIR.
    if (op == SPIRV_OP_LABEL) {
        if (wc < 2) { return 0 - MIR_ERR_UNSUPPORTED_OP; }
        if (mir_n_instrs(m) == 0) { return 0; }
        return mir_emit(m, MIR_OP_LABEL, 0, MIR_T_VOID, spirv_word(ptr, off + 1), 0, 0, MIR_FLAG_A_IMM);
    }
    # OpBranch %target → unconditional branch (a = target label).
    if (op == SPIRV_OP_BRANCH) {
        if (wc < 2) { return 0 - MIR_ERR_UNSUPPORTED_OP; }
        return mir_emit(m, MIR_OP_BRANCH, 0, MIR_T_VOID, spirv_word(ptr, off + 1), 0, 0, MIR_FLAG_A_IMM);
    }
    # OpBranchConditional %cond %true %false → a = cond value, b = true (the
    # fall-through then), c = false (the merge); b/c are labels (immediate tags).
    if (op == SPIRV_OP_BRANCH_CONDITIONAL) {
        if (wc < 4) { return 0 - MIR_ERR_UNSUPPORTED_OP; }
        return mir_emit(m, MIR_OP_COND_BRANCH, 0, MIR_T_VOID, spirv_word(ptr, off + 1),
        spirv_word(ptr, off + 2), spirv_word(ptr, off + 3), MIR_FLAG_B_IMM | MIR_FLAG_C_IMM);
    }
    if (op == SPIRV_OP_RETURN) {
        var er = mir_emit(m, MIR_OP_RET, 0, MIR_T_VOID, 0, 0, 0, 0);
        if (er < 0) { return er; }
        return 0;
    }
    # Integer comparisons → ICMP (a bool result the COND_BRANCH consumes). The
    # OpUDiv / OpUMod / OpSDiv / OpSRem expand to the float-reciprocal macro (no GFX9
    # integer divide); signed ops wrap it in a sign-magnitude shell. N.9b/c/d.
    if (op == SPIRV_OP_UDIV) { return _spirv_lower_udiv(ptr, off, wc, m); }
    if (op == SPIRV_OP_FDIV) { return _spirv_lower_fdiv(ptr, off, wc, types, m); }
    if (op == SPIRV_OP_UMOD) { return _spirv_lower_umod(ptr, off, wc, m); }
    if (op == SPIRV_OP_SDIV) { return _spirv_lower_sdiv(ptr, off, wc, m); }
    if (op == SPIRV_OP_SREM) { return _spirv_lower_srem(ptr, off, wc, m); }
    if (op == SPIRV_OP_SMOD) { return _spirv_lower_smod(ptr, off, wc, m); }
    # SPIR-V result type is OpTypeBool (not a scalar _mir_lower_type recognizes); the
    # bool is realized as SCC in isel, so a fixed MIR_T_U32 (0/1) suffices here.
    var cop = _spirv_cmp_to_mir(op);
    if (cop != 0) {
        if (wc < 5) { return 0 - MIR_ERR_UNSUPPORTED_OP; }
        return mir_emit(m, cop, spirv_word(ptr, off + 2), MIR_T_U32,
        spirv_word(ptr, off + 3), spirv_word(ptr, off + 4), 0, 0);
    }
    # Ordered f64 comparison → an i32 bool (F.7f.8). f64-only (the f64 VOPC opcodes); f32 float
    # compares are not wired (punchlist). Operand type checked from the first operand's MIR value.
    var fvopc = _spirv_fcmp_to_vopc(op);
    if (fvopc != 0) {
        if (wc < 5) { return 0 - MIR_ERR_UNSUPPORTED_OP; }
        var fa = spirv_word(ptr, off + 3);
        if (mir_type_base(mir_val_type(m, fa)) != MIR_T_F64) { return 0 - MIR_ERR_UNSUPPORTED_TYPE; }
        return _spirv_lower_fcmp(m, fvopc, fa, spirv_word(ptr, off + 4), spirv_word(ptr, off + 2));
    }
    if (op == SPIRV_OP_SELECT) { return _spirv_lower_select(ptr, off, wc, types, m); }
    var mop = _spirv_alu_to_mir(op);
    if (mop != 0) {
        if (wc < 5) { return 0 - MIR_ERR_UNSUPPORTED_OP; }
        var rty = _mir_lower_type(types, spirv_word(ptr, off + 1), spirv_hdr_id_bound(ptr));
        if (rty == MIR_T_UNSUPPORTED) { return 0 - MIR_ERR_UNSUPPORTED_TYPE; }
        var aop = spirv_word(ptr, off + 3);
        var bop = spirv_word(ptr, off + 4);
        var rid = spirv_word(ptr, off + 2);
        # Component-wise vector arithmetic (N.10b): a vecN result → N scalar ops, one per
        # component pair, reusing the whole scalar back end. Routed before the scalar fold.
        if (mir_type_count(rty) > 1) { return _spirv_lower_vec_binop(m, mop, rty, rid, aop, bop); }
        # Const-fold: both operands compile-time constants → one materialized constant
        # (instead of an op that would fail loud once both sources are non-VGPR).
        if (_spirv_both_const(m, aop, bop) == 1) {
            var ec = mir_set_const(m, rid, rty, _spirv_const_fold(m, mop, aop, bop));
            if (ec < 0) { return ec; }
            return 0;
        }
        # f64 const operands → materialize into a VGPR pair first (VOP3 has no 64-bit literal). f32
        # const operands are left for the emit to inline/literal-materialize. (F.7f.9)
        var na = _spirv_f64_arg(m, aop);  if (na < 0) { return na; }
        var nb = _spirv_f64_arg(m, bop);  if (nb < 0) { return nb; }
        var e = mir_emit(m, mop, rid, rty, na, nb, 0, 0);
        if (e < 0) { return e; }
        return 0;
    }
    # OpExtInst: result_type(+1) result(+2) set(+3) instruction(+4) operand0(+5) [op1(+6)].
    # GLSL.std.450 math → MIR float ops (uniformity is generic; result is VALU). Unknown
    # ext instructions fail loud (N.8b+).
    if (op == SPIRV_OP_EXT_INST) {
        if (wc < 6) { return 0 - MIR_ERR_UNSUPPORTED_OP; }
        var ety = _mir_lower_type(types, spirv_word(ptr, off + 1), spirv_hdr_id_bound(ptr));
        if (ety == MIR_T_UNSUPPORTED) { return 0 - MIR_ERR_UNSUPPORTED_TYPE; }
        var glsl = spirv_word(ptr, off + 4);
        var rid = spirv_word(ptr, off + 2);
        var x0 = spirv_word(ptr, off + 5);
        x0 = _spirv_f64_arg(m, x0);  if (x0 < 0) { return x0; }   # f64-const operand → VGPR pair (F.7f.9)
        # Unary: Sqrt, Floor. f64 Sqrt expands to the Newton-Goldschmidt macro (F.7f.7b — GFX9
        # v_sqrt_f64 is only an approximation); f32 keeps the single v_sqrt_f32.
        if (glsl == GLSL_STD450_SQRT) {
            if (mir_type_base(ety) == MIR_T_F64) {
                if (mir_type_count(ety) != 1) { return 0 - MIR_ERR_UNSUPPORTED_TYPE; }
                return _spirv_lower_fsqrt_f64(m, x0, rid);
            }
            var es = mir_emit(m, MIR_OP_FSQRT, rid, ety, x0, 0, 0, 0);
            if (es < 0) { return es; }
            return 0;
        }
        if (glsl == GLSL_STD450_FLOOR) {
            var ef = mir_emit(m, MIR_OP_FFLOOR, rid, ety, x0, 0, 0, 0);
            if (ef < 0) { return ef; }
            return 0;
        }
        if (glsl == GLSL_STD450_FABS) {
            var ea = mir_emit(m, MIR_OP_FABS, rid, ety, x0, 0, 0, 0);
            if (ea < 0) { return ea; }
            return 0;
        }
        # Binary: FMin, FMax.
        if (wc < 7) { return 0 - MIR_ERR_UNSUPPORTED_OP; }
        var x1 = spirv_word(ptr, off + 6);
        x1 = _spirv_f64_arg(m, x1);  if (x1 < 0) { return x1; }   # f64-const operand → VGPR pair (F.7f.9)
        if (glsl == GLSL_STD450_FMIN) {
            var en = mir_emit(m, MIR_OP_FMIN, rid, ety, x0, x1, 0, 0);
            if (en < 0) { return en; }
            return 0;
        }
        if (glsl == GLSL_STD450_FMAX) {
            var ex = mir_emit(m, MIR_OP_FMAX, rid, ety, x0, x1, 0, 0);
            if (ex < 0) { return ex; }
            return 0;
        }
        # Ldexp(x, k) = x * 2^k. f64 reuses MIR_OP_F64_LDEXP (a=f64 x0, b=i32 exponent x1). The 2^k
        # primitive consumers use for a hand-rolled exp. f32 Ldexp (v_ldexp_f32) is unwired — no
        # native f32 consumer (the f32 path runs on wgpu, per the F.7f arithmetic-only decision); it
        # fails loud below.
        if (glsl == GLSL_STD450_LDEXP) {
            if (mir_type_base(ety) != MIR_T_F64) { return 0 - MIR_ERR_UNSUPPORTED_TYPE; }
            var ed = mir_emit(m, MIR_OP_F64_LDEXP, rid, ety, x0, x1, 0, 0);
            if (ed < 0) { return ed; }
            return 0;
        }
        # Ternary: Fma (a*b + c).
        if (wc < 8) { return 0 - MIR_ERR_UNSUPPORTED_OP; }
        var x2 = spirv_word(ptr, off + 7);
        x2 = _spirv_f64_arg(m, x2);  if (x2 < 0) { return x2; }   # f64-const operand → VGPR pair (F.7f.9)
        if (glsl == GLSL_STD450_FMA) {
            var em = mir_emit(m, MIR_OP_FMA, rid, ety, x0, x1, x2, 0);
            if (em < 0) { return em; }
            return 0;
        }
        # FClamp(x, lo, hi) = median(x, lo, hi) when lo <= hi → a single v_med3_f32.
        if (glsl == GLSL_STD450_FCLAMP) {
            var ec = mir_emit(m, MIR_OP_FCLAMP, rid, ety, x0, x1, x2, 0);
            if (ec < 0) { return ec; }
            return 0;
        }
        return 0 - MIR_ERR_UNSUPPORTED_OP;
    }
    # i32<->float conversions. The f64 variants (F.7f.10) route to the i32<->f64 cvt ops; f32 keeps
    # the i32<->f32 ones. SToF picks by the RESULT type (f64 → CVT_F64_I32); FToS by the OPERAND type
    # (f64 operand → CVT_I32_F64). (OpConvertSToF/FToS are valid SPIR-V core ops for f64, unlike the
    # GLSL.std.450 transcendentals — see the F.7f arithmetic-only decision.)
    if (op == SPIRV_OP_CONVERT_S_TO_F) {
        if (wc < 4) { return 0 - MIR_ERR_UNSUPPORTED_OP; }
        var srt = _mir_lower_type(types, spirv_word(ptr, off + 1), spirv_hdr_id_bound(ptr));
        if (mir_type_base(srt) == MIR_T_F64) { return _spirv_lower_unary(ptr, off, wc, MIR_OP_CVT_F64_I32, types, m); }
        return _spirv_lower_unary(ptr, off, wc, MIR_OP_CVT_F32, types, m);
    }
    if (op == SPIRV_OP_CONVERT_U_TO_F) { return _spirv_lower_unary(ptr, off, wc, MIR_OP_CVT_F32, types, m); }
    if (op == SPIRV_OP_CONVERT_F_TO_S) {
        if (wc < 4) { return 0 - MIR_ERR_UNSUPPORTED_OP; }
        if (mir_type_base(mir_val_type(m, spirv_word(ptr, off + 3))) == MIR_T_F64) {
            return _spirv_lower_unary(ptr, off, wc, MIR_OP_CVT_I32_F64, types, m);
        }
        return _spirv_lower_unary(ptr, off, wc, MIR_OP_CVT_I32, types, m);
    }
    if (op == SPIRV_OP_FCONVERT) { return _spirv_lower_unary(ptr, off, wc, MIR_OP_FCONVERT, types, m); }
    if (op == SPIRV_OP_COMPOSITE_CONSTRUCT) { return _spirv_lower_composite_construct(ptr, off, wc, types, m); }
    if (op == SPIRV_OP_COMPOSITE_EXTRACT) {
        if (wc < 5) { return 0 - MIR_ERR_UNSUPPORTED_OP; }
        var ety = _mir_lower_type(types, spirv_word(ptr, off + 1), spirv_hdr_id_bound(ptr));
        if (ety == MIR_T_UNSUPPORTED) { return 0 - MIR_ERR_UNSUPPORTED_TYPE; }
        var composite = spirv_word(ptr, off + 3);
        var comp = spirv_word(ptr, off + 4);
        # GlobalInvocationId.comp is not a hardware register — expand it to
        # wgid.comp * local_size_comp + lid.comp (lsz holds the 3 LocalSize dims).
        if (composite != 0) {
            if (composite < load64(m + 64)) {
                if (mir_val_kind(m, composite) == MIR_VK_BUILTIN) {
                    # Every supported builtin (LocalInvocationId / WorkgroupId /
                    # GlobalInvocationId) is a vec3 → comp ∈ {0,1,2}. A larger (malformed)
                    # component would OOB-read the 3-entry lsz here, or (for lid/wgid falling
                    # through to the legacy EXTRACT below) make the back end read a register
                    # past the builtin's 3 ABI slots — bound it for ALL builtins. (N.10a review.)
                    if (comp > 2) { return 0 - MIR_ERR_UNSUPPORTED_OP; }
                    if (mir_val_payload(m, composite) == MIR_BI_GLOBAL_INVOC_ID) {
                        return _spirv_expand_gid(m, spirv_word(ptr, off + 2), ety, comp, load64(lsz + comp * 8));
                    }
                }
                # vecN component extract → VMOV from the packed component <id> (a CONST/SSA
                # value the back end resolves). A scalarized vec carries no EXTRACT op. N.10a.
                if (mir_is_vector(m, composite) == 1) {
                    if (comp >= mir_type_count(mir_val_type(m, composite))) { return 0 - MIR_ERR_UNSUPPORTED_OP; }
                    var ev = mir_emit(m, MIR_OP_VMOV, spirv_word(ptr, off + 2), ety,
                    mir_vec_comp(m, composite, comp), 0, 0, 0);
                    if (ev < 0) { return ev; }
                    return 0;
                }
            }
        }
        var e2 = mir_emit(m, MIR_OP_EXTRACT, spirv_word(ptr, off + 2), ety, composite, 0, comp, MIR_FLAG_C_IMM);
        if (e2 < 0) { return e2; }
        return 0;
    }
    if (op == SPIRV_OP_ACCESS_CHAIN) { return _spirv_lower_access_chain(ptr, off, wc, types, consts, deco, m); }
    if (op == SPIRV_OP_LOAD) { return _spirv_lower_load(ptr, off, wc, m); }
    if (op == SPIRV_OP_STORE) { return _spirv_lower_store(ptr, off, wc, m); }
    return 0 - MIR_ERR_UNSUPPORTED_OP;
}

# Walk to the entry function's OpFunction (result <id> == entry_id), then lower
# its body up to OpFunctionEnd. Globals/types/decorations (before OpFunction) are
# never re-seen here — the seed pass owns them.
fn _spirv_lower_body(ptr, byte_len, types, consts, deco, m, entry_id, lsz): i64 {
    var total = byte_len / 4;
    var off = SPIRV_HEADER_WORDS;
    var in_body = 0;
    while (off < total) {
        var w0 = spirv_word(ptr, off);
        var wc = spirv_op_wordcount(w0);
        var op = spirv_op(w0);
        if (in_body == 0) {
            if (op == SPIRV_OP_FUNCTION) {
                if (wc >= 3) {
                    if (spirv_word(ptr, off + 2) == entry_id) { in_body = 1; }
                }
            }
        } else {
            if (op == SPIRV_OP_FUNCTION_END) { return 0; }
            var r = _spirv_lower_one_instr(ptr, off, wc, op, types, consts, deco, m, lsz);
            if (r < 0) { return r; }
        }
        off = off + wc;
    }
    # Reached end-of-stream without an OpFunctionEnd return: the entry function's
    # OpFunction was never matched (in_body stayed 0) or its body was truncated.
    # Fail loud rather than silently producing an empty body. N.2b-1 review.
    return 0 - LOWER_ERR_NO_ENTRY;
}

# An array type's ArrayStride must match the std430 stride the access-chain assumes (computed
# from the element type: scalar `esize`, vec2 2*esize, vec3/vec4 4*esize; esize = 4 for i32/f32,
# 8 for f64 — F.7e). Returns 0 if it matches (or the element is one we don't lower — the
# access-chain rejects it later), else a NEGATIVE error. Kept in lock-step with the stride
# computed in _spirv_lower_access_chain.
fn _spirv_std430_stride_ok(types, array_tid, idb, declared): i64 {
    var elem = _mir_lower_type(types, spirv_type_p0(types, array_tid), idb);
    if (elem == MIR_T_UNSUPPORTED) { return 0; }
    var es = 4;
    if (mir_type_base(elem) == MIR_T_F64) { es = 8; }
    var ec = mir_type_count(elem);
    var expect = es;
    if (ec == 2) { expect = es * 2; }
    if (ec > 2) { expect = es * 4; }
    if (declared != expect) { return 0 - LOWER_ERR_ARRAY_STRIDE; }
    return 0;
}

# The access-chain assumes the std430 array stride (no ArrayStride decoration is consulted).
# To keep that honest, scan OpDecorate for an explicit ArrayStride on an Array/RuntimeArray and
# fail loud if it disagrees with std430 — a non-std430 layout would otherwise SILENTLY
# mis-address (e.g. a tightly-packed vec3 array stride 12 vs the assumed 16). N.10c review.
fn _spirv_check_array_strides(ptr, byte_len, types, idb): i64 {
    var total = byte_len / 4;
    var off = SPIRV_HEADER_WORDS;
    while (off < total) {
        var w0 = spirv_word(ptr, off);
        var wc = spirv_op_wordcount(w0);
        if (spirv_op(w0) == SPIRV_OP_DECORATE) {
            if (wc >= 4) {
                if (spirv_word(ptr, off + 2) == SPIRV_DECO_ARRAY_STRIDE) {
                    var tid = spirv_word(ptr, off + 1);
                    if (tid != 0) {
                        if (tid < idb) {
                            var k = spirv_type_kind(types, tid);
                            if (k == SPIRV_TYK_RUNTIME_ARRAY) {
                                var r = _spirv_std430_stride_ok(types, tid, idb, spirv_word(ptr, off + 3));
                                if (r < 0) { return r; }
                            }
                            if (k == SPIRV_TYK_ARRAY) {
                                var r2 = _spirv_std430_stride_ok(types, tid, idb, spirv_word(ptr, off + 3));
                                if (r2 < 0) { return r2; }
                            }
                        }
                    }
                }
            }
        }
        off = off + wc;
    }
    return 0;
}

# Find the result <id> of the `OpExtInstImport "GLSL.std.450"` (the only ext set the back end
# implements). The name rides as a packed null-terminated literal string: "GLSL.std.450\0" is
# exactly four words. Returns the import <id>, or 0 if no such import is present. (N.11)
fn _spirv_find_glsl_ext_set(ptr, byte_len): i64 {
    var total = byte_len / 4;
    var off = SPIRV_HEADER_WORDS;
    while (off < total) {
        var w0 = spirv_word(ptr, off);
        var wc = spirv_op_wordcount(w0);
        if (spirv_op(w0) == SPIRV_OP_EXT_INST_IMPORT) {
            # op + result + the 4 string words of "GLSL.std.450\0" → exactly 6 words.
            if (wc >= 6) {
                if (spirv_word(ptr, off + 2) == 0x4C534C47) {         # "GLSL"
                    if (spirv_word(ptr, off + 3) == 0x6474732E) {     # ".std"
                        if (spirv_word(ptr, off + 4) == 0x3035342E) { # ".450"
                            # The 13th byte (low byte of this word) must be the nul terminator;
                            # the spec zero-pads the rest, but check only the nul byte so a
                            # non-zero-padded producer is not false-rejected (a longer name has
                            # a non-nul 13th byte, so this still rejects "GLSL.std.450X…").
                            if ((spirv_word(ptr, off + 5) & 0xFF) == 0) {
                                return spirv_word(ptr, off + 1);
                            }
                        }
                    }
                }
            }
        }
        off = off + wc;
    }
    return 0;
}

# The OpExtInst handler only implements GLSL.std.450 numbers. Drop the MVP "the only imported
# set is GLSL.std.450" assumption: every OpExtInst must reference the actual GLSL.std.450
# import <id>. A reference to any other ext set — or an OpExtInst with no GLSL.std.450 import at
# all (glsl == 0, so set != glsl) — fails loud rather than mis-decoding another set's numbers. (N.11)
fn _spirv_check_ext_sets(ptr, byte_len): i64 {
    var glsl = _spirv_find_glsl_ext_set(ptr, byte_len);
    var total = byte_len / 4;
    var off = SPIRV_HEADER_WORDS;
    while (off < total) {
        var w0 = spirv_word(ptr, off);
        var wc = spirv_op_wordcount(w0);
        if (spirv_op(w0) == SPIRV_OP_EXT_INST) {
            if (wc >= 4) {
                # No GLSL.std.450 import at all → reject ANY OpExtInst (covers a malformed
                # set==0, which would otherwise pass the `!= glsl` test when glsl is also 0).
                if (glsl == 0) { return 0 - LOWER_ERR_EXT_SET; }
                if (spirv_word(ptr, off + 3) != glsl) { return 0 - LOWER_ERR_EXT_SET; }
            }
        }
        off = off + wc;
    }
    return 0;
}

# ================================================================
# Top-level driver
# ================================================================
# Lower a validated SPIR-V compute module into MIR. `m` is an initialized MirMod;
# `types`/`consts`/`deco` are N.1b tables; `out_bi` is a caller-provided
# id_bound-sized builtin side-table. Returns SPIRV_LOWER_OK or a negative error.
fn spirv_lower_module(ptr, byte_len, types, consts, deco, m, out_bi): i64 {
    var entry = spirv_find_entry_point(ptr, byte_len);
    if (entry == 0 - 1) { return 0 - LOWER_ERR_NO_ENTRY; }
    var as_chk = _spirv_check_array_strides(ptr, byte_len, types, spirv_hdr_id_bound(ptr));
    if (as_chk < 0) { return as_chk; }
    var es_chk = _spirv_check_ext_sets(ptr, byte_len);
    if (es_chk < 0) { return es_chk; }
    _spirv_resolve_builtins(ptr, byte_len, spirv_hdr_id_bound(ptr), out_bi);
    var sr = _spirv_lower_seed_globals(ptr, byte_len, types, deco, m, out_bi);
    if (sr < 0) { return sr; }
    # LocalSize dims (default 1,1,1 if absent) — the GlobalInvocationId expansion
    # scales WorkgroupId by these.
    var lsz[24];
    store64(&lsz + 0, 1);
    store64(&lsz + 8, 1);
    store64(&lsz + 16, 1);
    spirv_find_local_size(ptr, byte_len, entry, &lsz);
    var br = _spirv_lower_body(ptr, byte_len, types, consts, deco, m, entry, &lsz);
    if (br < 0) { return br; }
    mir_finalize_block0(m);
    mir_run_uniformity(m);
    return SPIRV_LOWER_OK;
}

# --- gfx9_isel.cyr ---

# @internal — GFX9 instruction selection (Phase N.3, MIR → virtual-reg GFX9)
# gfx9_isel.cyr — selects a GFX9 instruction (over VIRTUAL registers) for each
# MIR instruction. The IR→bytes bridge: it turns the abstract MIR ops + the
# N.2 uniformity classification into concrete GFX9 op choices, which N.4
# (register allocation) then assigns physical VGPR/SGPR numbers to and N.5
# (encode) turns into bytes via gfx9_encode.cyr.
#
# Virtual registers ARE the MIR SSA value <id>s (operands pass through as MIR
# ids; N.4 maps each to a physical register, and N.5 resolves constants /
# builtins / the ptr side-table). The register CLASS is the MIR uniformity:
# UNIFORM → SGPR/SALU, DIVERGENT → VGPR/VALU. So the load-bearing decision —
# scalar vs vector ALU — falls out of the N.2 sweep: an integer op selects the
# S_* form when its result is uniform and the V_* form when divergent; float
# ops are always VALU (GFX9 has no scalar f32 ALU). The straight-line
# uniformity propagation guarantees operand-class compatibility (a uniform
# result has all-uniform operands; a divergent VALU op reads its at-most-one
# uniform operand as an SGPR/inline source), so no class-coercion copies are
# needed for the MVP — the constant-bus / multi-SGPR cases are N.8.
#
# Output: a caller-provided buffer of 48-byte selected-instruction records
# (op / dst / a / b / c / flags). gfx9_isel returns the instruction count
# (>= 0) or a NEGATIVE error. Included after spirv_lower.cyr (drives the mir_*
# accessors). Pure byte math; no syscalls.

# Selected GFX9 op codes (abstract — N.5 maps each to a gfx9_encode format+op).
var GISEL_S_ADD_I32     = 1;
var GISEL_V_ADD_U32     = 2;
var GISEL_S_SUB_I32     = 3;
var GISEL_V_SUB_U32     = 4;
var GISEL_S_MUL_I32     = 5;
var GISEL_V_MUL_LO_U32  = 6;
var GISEL_S_LSHL_B32    = 7;
var GISEL_V_LSHLREV_B32 = 8;
var GISEL_S_LSHR_B32    = 9;
var GISEL_V_LSHRREV_B32 = 10;
var GISEL_S_AND_B32     = 11;
var GISEL_V_AND_B32     = 12;
var GISEL_S_OR_B32      = 13;
var GISEL_V_OR_B32      = 14;
var GISEL_S_XOR_B32     = 15;
var GISEL_V_XOR_B32     = 16;
var GISEL_V_ADD_F32     = 17;
var GISEL_V_SUB_F32     = 18;
var GISEL_V_MUL_F32     = 19;
var GISEL_V_FMA_F32     = 20;
var GISEL_V_CVT_F32_I32 = 21;
var GISEL_V_CVT_I32_F32 = 22;
var GISEL_EXTRACT       = 23;   # vector/builtin component subscript (resolved N.5)
var GISEL_GLOBAL_LOAD   = 24;   # b = ptr-table index; flags bits 8+ = binding
var GISEL_GLOBAL_STORE  = 25;   # a = off vreg, c = value vreg, b = ptr index
var GISEL_S_ENDPGM      = 26;
var GISEL_S_WAITCNT     = 27;   # a = simm16 (immediate); inserted by N.4b
# N.7 control flow. LABEL: a = label <id>, 0 bytes (the emit records its offset).
# S_BRANCH: a = target label. S_CBRANCH: c = target label (the merge/false target —
# branch there if SCC==0, i.e. the condition the preceding S_CMP set is false).
# S_CMP: dst = 0 (result is SCC, not a register), a/b = compared operands, the SOPC
# compare opcode rides in flags bits 8+ (like GLOBAL_LOAD's binding).
var GISEL_LABEL         = 28;
var GISEL_S_BRANCH      = 29;
var GISEL_S_CBRANCH     = 30;
var GISEL_S_CMP         = 31;
# V_CMP: a DIVERGENT compare → the implicit VCC mask (N.7c). dst = 0 (VCC is implicit),
# a = src0 (9-bit operand, VGPR/inline), b = vsrc1 (a VGPR), VOPC opcode in flags 8+.
var GISEL_V_CMP         = 32;
# The divergent-if EXEC-mask trio (N.7c-2b). SAVEEXEC: EXEC &= VCC, save old EXEC to the
# reserved pair. S_CBRANCH_EXECZ: skip to the merge (c) when no lane is active. S_OR_EXEC:
# restore EXEC at the merge. The reserved pair + VCC are implicit (no register operands).
var GISEL_S_SAVEEXEC      = 33;
var GISEL_S_CBRANCH_EXECZ = 34;
var GISEL_S_OR_EXEC       = 35;
# GLSL.std.450 float math (N.8b): min/max are VOP2, sqrt is VOP1.
var GISEL_V_MIN_F32       = 36;
var GISEL_V_MAX_F32       = 37;
var GISEL_V_SQRT_F32      = 38;
var GISEL_V_FLOOR_F32     = 39;
var GISEL_V_MED3_F32      = 40;   # GLSL.std.450 FClamp (N.8b-4)
var GISEL_V_ABS_F32       = 41;   # GLSL.std.450 FAbs = clear sign bit (N.8b-7)
# Integer-division primitives (N.9): all VALU. CNDMASK reads the implicit VCC and is NOT
# commutative — a (src0) is the false value, b (vsrc1) the true value.
var GISEL_V_MOV           = 42;
var GISEL_V_CVT_F32_U32   = 43;
var GISEL_V_CVT_U32_F32   = 44;
var GISEL_V_RCP_IFLAG_F32 = 45;
var GISEL_V_MUL_HI_U32    = 46;
var GISEL_V_CNDMASK       = 47;
# Arithmetic shift right (N.9d): SALU (uniform) vs VALU (divergent), like LSHR.
var GISEL_V_ASHRREV_I32   = 48;
var GISEL_S_ASHR_I32      = 49;
# v3.2 F.7d — f64 (double) ALU. All VALU/VOP3 over 64-bit VGPR pairs; the dispatch reuses the
# scalar VOP3/VOP1 emitters because regalloc hands out the EVEN (low) reg of each pair and the
# encoders name a pair by its low reg (F.7c). f64 SUB/SQRT/FLOOR/CLAMP/ABS + f32<->f64 CVT are
# breadth bites (no single f64 opcode / need the negate-or-modifier or lowering logic).
var GISEL_V_ADD_F64          = 50;
var GISEL_V_MUL_F64          = 51;
var GISEL_V_FMA_F64          = 52;
var GISEL_V_MIN_F64          = 53;
var GISEL_V_MAX_F64          = 54;
# 64-bit (f64) global load/store — DWORDX2 variants of GLOBAL_LOAD/STORE (same operands).
var GISEL_GLOBAL_LOAD_DWORDX2  = 55;
var GISEL_GLOBAL_STORE_DWORDX2 = 56;
# f32<->f64 conversion (F.7f.2): widen reads an f32 single + writes an f64 pair; narrow the reverse.
# Both are VOP1 (single source); _emit_vop1 + regalloc's per-type width handle the reg encoding.
var GISEL_V_CVT_F64_F32        = 57;   # widen (f64)f32
var GISEL_V_CVT_F32_F64        = 58;   # narrow (f32)f64
# f64 sub/abs (F.7f.3): GFX9 has no V_SUB_F64 / V_ABS_F64. FSub = V_ADD_F64 with a NEGATE src1
# modifier; FAbs = V_MAX_F64(|x|,|x|) with ABS on both srcs. Distinct GISEL ops so the dispatch
# emits the right opcode + modifier bits (encoded in gfx9_compile, reusing the F.7b opcodes).
var GISEL_V_SUB_F64            = 59;   # a - b  (v_add_f64 a, -b)
var GISEL_V_ABS_F64            = 60;   # |x|    (v_max_f64 |x|, |x|)
# v3.2 F.7f.6b — f64 division macro ops. All VALU/VOP3 over 64-bit pairs. DIV_SCALE is VOP3B
# (writes the scale flag to the implicit VCC); DIV_FMAS reads VCC; the FMA_N0 forms ride a
# NEGATE-src0 modifier (N0_ONE adds an inline-1.0 src2). Emit detail in gfx9_compile.cyr.
var GISEL_V_RCP_F64           = 61;   # v_rcp_f64 reciprocal seed
var GISEL_V_DIV_SCALE_F64     = 62;   # v_div_scale_f64 (3-src; flag → VCC)
var GISEL_V_DIV_FMAS_F64      = 63;   # v_div_fmas_f64 (3-src; reads VCC)
var GISEL_V_DIV_FIXUP_F64     = 64;   # v_div_fixup_f64 (3-src)
var GISEL_V_FMA_F64_N0        = 65;   # v_fma_f64(-a, b, c)
var GISEL_V_FMA_F64_N0_ONE    = 66;   # v_fma_f64(-a, b, 1.0)
# v3.2 F.7f.7b — f64 sqrt macro ops. RSQ is VOP1; CMP_CLASS is VOPC (→ VCC, dst=0); CNDMASK_F64
# emits 2× v_cndmask_b32 (the pair halves); FMA_N0_HALF/MUL_HALF carry an inline-0.5 operand.
var GISEL_V_RSQ_F64           = 67;   # v_rsq_f64 seed
var GISEL_V_CMP_CLASS_F64     = 68;   # v_cmp_class_f64 (a=x, b=mask) → VCC
var GISEL_V_CNDMASK_F64       = 69;   # f64-pair select on VCC
var GISEL_V_FMA_F64_N0_HALF   = 70;   # v_fma_f64(-a, b, 0.5)
var GISEL_V_MUL_F64_HALF      = 71;   # v_mul_f64(a, 0.5)
# v3.2 F.7f.7c — f64 sqrt subnormal-scaling ops. CONST_F64 = 2× v_mov_b32 (an f64 literal into a
# pair); LDEXP_F64 is VOP3 2-src; CMP_GT_F64 is VOPC (→ VCC, dst=0).
var GISEL_V_CONST_F64         = 72;   # materialize f64 const into a VGPR pair
var GISEL_V_LDEXP_F64         = 73;   # v_ldexp_f64 (f64, i32)
var GISEL_V_CMP_GT_F64        = 74;   # v_cmp_gt_f64 (a, b) → VCC
# v3.2 F.7f.10 — i32<->f64 conversions (exp range reduction). VOP1, reuse _emit_vop1.
var GISEL_V_CVT_I32_F64       = 75;   # (i32)f64 round-nearest
var GISEL_V_CVT_F64_I32       = 76;   # (f64)i32
# v3.2 F.7f.8 — OpSelect blend (v_bfi_b32: mask ? b : c). 1 lane for i32/f32, 2 for an f64 pair.
var GISEL_V_SELECT            = 77;

var GISEL_REC = 48;   # [op, dst, a, b, c, flags]

# Error codes — based at 100 so they stay clear of the GISEL op enum (positive opcode
# tags) above; errors are always returned NEGATED, but a shared literal value with an op
# is a needless smell. Disjoint from mir 20-25, lower 26-27, and CMP 70-87.
var GISEL_ERR_UNSUPPORTED_OP = 100;
var GISEL_ERR_CAP_EXCEEDED   = 101;

# ================================================================
# Selected-instruction emit + accessors
# ================================================================
fn _gisel_emit(out, k, op, dst, a, b, c, flags): i64 {
    var base = out + k * GISEL_REC;
    store64(base + 0, op);
    store64(base + 8, dst);
    store64(base + 16, a);
    store64(base + 24, b);
    store64(base + 32, c);
    store64(base + 40, flags);
    return 0;
}

# Which register file a selected op WRITES its result to: the scalar ALU ops
# (S_*) write an SGPR; everything else with a result (V_* ALU, V_CVT, EXTRACT,
# GLOBAL_LOAD) writes a VGPR. This is the authoritative file for N.4 — NOT the
# value's uniformity, because float/CVT ops are always VALU even for a uniform
# result (GFX9 has no scalar f32 ALU), so a "uniform" float value lives in a
# VGPR. (STORE / S_ENDPGM have no result and never reach this.)
fn gisel_writes_vgpr(op): i64 {
    if (op == GISEL_S_ADD_I32) { return 0; }
    if (op == GISEL_S_SUB_I32) { return 0; }
    if (op == GISEL_S_MUL_I32) { return 0; }
    if (op == GISEL_S_LSHL_B32) { return 0; }
    if (op == GISEL_S_LSHR_B32) { return 0; }
    if (op == GISEL_S_AND_B32) { return 0; }
    if (op == GISEL_S_OR_B32) { return 0; }
    if (op == GISEL_S_XOR_B32) { return 0; }
    return 1;
}

# The register file of instruction `i`'s RESULT (1 = VGPR, 0 = SGPR). For most ops
# it is the op's destination class (gisel_writes_vgpr). EXTRACT is the exception:
# it reads a builtin's register, whose file is the builtin's uniformity
# (WorkgroupId → SGPR; Local/GlobalInvocationId → VGPR), so an EXTRACT result
# follows its OWN uniformity. Used by both regalloc and the encode file-map so the
# two agree. (gisel_writes_vgpr can't decide EXTRACT — it lacks the operand.)
fn gisel_result_is_vgpr(m, out, i): i64 {
    if (gisel_op(out, i) == GISEL_EXTRACT) {
        if (mir_val_unif(m, gisel_dst(out, i)) == MIR_DIVERGENT) { return 1; }
        return 0;
    }
    return gisel_writes_vgpr(gisel_op(out, i));
}

fn gisel_op(out, i): i64 { return load64(out + i * GISEL_REC + 0); }
fn gisel_dst(out, i): i64 { return load64(out + i * GISEL_REC + 8); }
fn gisel_a(out, i): i64 { return load64(out + i * GISEL_REC + 16); }
fn gisel_b(out, i): i64 { return load64(out + i * GISEL_REC + 24); }
fn gisel_c(out, i): i64 { return load64(out + i * GISEL_REC + 32); }
fn gisel_flags(out, i): i64 { return load64(out + i * GISEL_REC + 40); }

# ================================================================
# Op selection
# ================================================================
# Integer MIR op → GFX9 op, choosing the SALU (uniform) or VALU (divergent)
# form. Returns 0 if `mop` is not an integer ALU op.
fn _gisel_int_op(mop, divergent): i64 {
    if (mop == MIR_OP_IADD) { if (divergent == 1) { return GISEL_V_ADD_U32; } return GISEL_S_ADD_I32; }
    if (mop == MIR_OP_ISUB) { if (divergent == 1) { return GISEL_V_SUB_U32; } return GISEL_S_SUB_I32; }
    if (mop == MIR_OP_IMUL) { if (divergent == 1) { return GISEL_V_MUL_LO_U32; } return GISEL_S_MUL_I32; }
    if (mop == MIR_OP_SHL) { if (divergent == 1) { return GISEL_V_LSHLREV_B32; } return GISEL_S_LSHL_B32; }
    if (mop == MIR_OP_SHR) { if (divergent == 1) { return GISEL_V_LSHRREV_B32; } return GISEL_S_LSHR_B32; }
    if (mop == MIR_OP_ASHR) { if (divergent == 1) { return GISEL_V_ASHRREV_I32; } return GISEL_S_ASHR_I32; }
    if (mop == MIR_OP_AND) { if (divergent == 1) { return GISEL_V_AND_B32; } return GISEL_S_AND_B32; }
    if (mop == MIR_OP_OR) { if (divergent == 1) { return GISEL_V_OR_B32; } return GISEL_S_OR_B32; }
    if (mop == MIR_OP_XOR) { if (divergent == 1) { return GISEL_V_XOR_B32; } return GISEL_S_XOR_B32; }
    return 0;
}

# Float MIR op → GFX9 VALU op (always vector; GFX9 has no scalar float ALU). `tbase` is the
# result's MIR type BASE (MIR_T_F32 / MIR_T_F64); f64 selects the V_*_F64 form. Returns 0 if
# `mop` is not a float ALU op OR the f64 variant is a breadth bite (SUB/SQRT/FLOOR/CLAMP/ABS on
# f64) — the caller then fails loud rather than silently emitting the f32 opcode on a pair.
fn _gisel_float_op(mop, tbase): i64 {
    var f64 = 0;
    if (tbase == MIR_T_F64) { f64 = 1; }
    if (mop == MIR_OP_FADD) { if (f64 == 1) { return GISEL_V_ADD_F64; } return GISEL_V_ADD_F32; }
    if (mop == MIR_OP_FMUL) { if (f64 == 1) { return GISEL_V_MUL_F64; } return GISEL_V_MUL_F32; }
    if (mop == MIR_OP_FMA) { if (f64 == 1) { return GISEL_V_FMA_F64; } return GISEL_V_FMA_F32; }
    if (mop == MIR_OP_FMIN) { if (f64 == 1) { return GISEL_V_MIN_F64; } return GISEL_V_MIN_F32; }
    if (mop == MIR_OP_FMAX) { if (f64 == 1) { return GISEL_V_MAX_F64; } return GISEL_V_MAX_F32; }
    # f64 SUB/ABS via source modifiers (F.7f.3); f32 has its own (V_SUB_F32 / V_AND_B32 mask).
    if (mop == MIR_OP_FSUB) { if (f64 == 1) { return GISEL_V_SUB_F64; } return GISEL_V_SUB_F32; }
    if (mop == MIR_OP_FABS) { if (f64 == 1) { return GISEL_V_ABS_F64; } return GISEL_V_ABS_F32; }
    # f64 SQRT/FLOOR/CLAMP have no correct single-instruction form → fail loud (return 0). GFX9
    # v_sqrt_f64 is only an ~f32-precision approximation (HW-proven, the F.7f.5 finding), so a correct
    # f64 sqrt needs a v_rsq_f64 + Newton-refinement macro. f64 DIV is now lowered as a macro in
    # spirv_lower.cyr (OpFDiv, F.7f.6b) — NOT routed here. FSqrt is tracked in
    # docs/development/3-2-punchlist.md (F.7f.7); FFLOOR/FCLAMP f64 are later breadth bites.
    if (f64 == 1) { return 0; }
    if (mop == MIR_OP_FSQRT) { return GISEL_V_SQRT_F32; }
    if (mop == MIR_OP_FFLOOR) { return GISEL_V_FLOOR_F32; }
    if (mop == MIR_OP_FCLAMP) { return GISEL_V_MED3_F32; }
    return 0;
}

# Integer-compare MIR op → the SOPC scalar-compare opcode (uniform path → SCC).
fn _gisel_cmp_sopc(mop): i64 {
    if (mop == MIR_OP_ICMP_EQ) { return GFX9_SOPC_S_CMP_EQ_U32; }
    if (mop == MIR_OP_ICMP_NE) { return GFX9_SOPC_S_CMP_LG_U32; }
    if (mop == MIR_OP_ICMP_ULT) { return GFX9_SOPC_S_CMP_LT_U32; }
    if (mop == MIR_OP_ICMP_UGT) { return GFX9_SOPC_S_CMP_GT_U32; }
    if (mop == MIR_OP_ICMP_ULE) { return GFX9_SOPC_S_CMP_LE_U32; }
    if (mop == MIR_OP_ICMP_UGE) { return GFX9_SOPC_S_CMP_GE_U32; }
    if (mop == MIR_OP_ICMP_SLT) { return GFX9_SOPC_S_CMP_LT_I32; }
    if (mop == MIR_OP_ICMP_SGT) { return GFX9_SOPC_S_CMP_GT_I32; }
    if (mop == MIR_OP_ICMP_SLE) { return GFX9_SOPC_S_CMP_LE_I32; }
    if (mop == MIR_OP_ICMP_SGE) { return GFX9_SOPC_S_CMP_GE_I32; }
    return 0 - 1;
}

# Integer-compare MIR op → the VOPC vector-compare opcode (divergent path → VCC). When
# the constant operand must move to src0 (vsrc1 is VGPR-only), `flip` reverses the
# predicate so (b flip a) ≡ (a op b): lt↔gt, le↔ge; eq/ne are symmetric.
fn _gisel_vcmp(mop, flip): i64 {
    if (mop == MIR_OP_ICMP_EQ) { return GFX9_VOPC_V_CMP_EQ_U32; }
    if (mop == MIR_OP_ICMP_NE) { return GFX9_VOPC_V_CMP_NE_U32; }
    if (mop == MIR_OP_ICMP_ULT) {
        if (flip == 1) { return GFX9_VOPC_V_CMP_GT_U32; }
        return GFX9_VOPC_V_CMP_LT_U32;
    }
    if (mop == MIR_OP_ICMP_UGT) {
        if (flip == 1) { return GFX9_VOPC_V_CMP_LT_U32; }
        return GFX9_VOPC_V_CMP_GT_U32;
    }
    if (mop == MIR_OP_ICMP_ULE) {
        if (flip == 1) { return GFX9_VOPC_V_CMP_GE_U32; }
        return GFX9_VOPC_V_CMP_LE_U32;
    }
    if (mop == MIR_OP_ICMP_UGE) {
        if (flip == 1) { return GFX9_VOPC_V_CMP_LE_U32; }
        return GFX9_VOPC_V_CMP_GE_U32;
    }
    if (mop == MIR_OP_ICMP_SLT) {
        if (flip == 1) { return GFX9_VOPC_V_CMP_GT_I32; }
        return GFX9_VOPC_V_CMP_LT_I32;
    }
    if (mop == MIR_OP_ICMP_SGT) {
        if (flip == 1) { return GFX9_VOPC_V_CMP_LT_I32; }
        return GFX9_VOPC_V_CMP_GT_I32;
    }
    if (mop == MIR_OP_ICMP_SLE) {
        if (flip == 1) { return GFX9_VOPC_V_CMP_GE_I32; }
        return GFX9_VOPC_V_CMP_LE_I32;
    }
    if (mop == MIR_OP_ICMP_SGE) {
        if (flip == 1) { return GFX9_VOPC_V_CMP_LE_I32; }
        return GFX9_VOPC_V_CMP_GE_I32;
    }
    return 0 - 1;
}

# Select + emit the GFX9 instruction for one MIR instruction.
fn _gisel_one(m, out, k, op, dst, a, b, c, flags): i64 {
    if (op == MIR_OP_RET) { return _gisel_emit(out, k, GISEL_S_ENDPGM, 0, 0, 0, 0, 0); }
    # N.7 control flow. LABEL/BRANCH carry the label <id> in `a`; COND_BRANCH skips to
    # its FALSE/merge target (c) when SCC==0 (the preceding S_CMP set SCC = condition).
    if (op == MIR_OP_LABEL) { return _gisel_emit(out, k, GISEL_LABEL, 0, a, 0, 0, 0); }
    if (op == MIR_OP_BRANCH) { return _gisel_emit(out, k, GISEL_S_BRANCH, 0, a, 0, 0, 0); }
    # A UNIFORM cond branches on SCC (s_cbranch_scc0 → merge). A DIVERGENT cond needs
    # the EXEC-mask sequence (s_and_saveexec_b64 + s_cbranch_execz + restore) — N.7c-2b.
    if (op == MIR_OP_COND_BRANCH) {
        if (mir_val_unif(m, a) == MIR_DIVERGENT) { return 0 - GISEL_ERR_UNSUPPORTED_OP; }
        return _gisel_emit(out, k, GISEL_S_CBRANCH, 0, 0, 0, c, 0);
    }
    var sop = _gisel_cmp_sopc(op);
    if (sop >= 0) {
        if (dst == 0) { return 0 - GISEL_ERR_UNSUPPORTED_OP; }
        var cu = mir_val_unif(m, dst);
        # UNIFORM compare → SCC via s_cmp.
        if (cu == MIR_UNIFORM) {
            return _gisel_emit(out, k, GISEL_S_CMP, 0, a, b, 0, flags | (sop << 8));
        }
        # DIVERGENT compare → VCC via v_cmp. vsrc1 must be a VGPR, so when the second
        # operand is a constant, move it to src0 and flip the predicate.
        if (cu == MIR_DIVERGENT) {
            if (mir_val_kind(m, b) == MIR_VK_CONST) {
                var vopf = _gisel_vcmp(op, 1);
                return _gisel_emit(out, k, GISEL_V_CMP, 0, b, a, 0, flags | (vopf << 8));
            }
            var vop = _gisel_vcmp(op, 0);
            return _gisel_emit(out, k, GISEL_V_CMP, 0, a, b, 0, flags | (vop << 8));
        }
        return 0 - GISEL_ERR_UNSUPPORTED_OP;
    }
    if (op == MIR_OP_LOAD) {
        # b = ptr-table index; carry binding in flags bits 8+ (b stays immediate). An f64
        # result is a 64-bit load → DWORDX2 (F.7d).
        var lop = GISEL_GLOBAL_LOAD;
        if (mir_type_base(mir_val_type(m, dst)) == MIR_T_F64) { lop = GISEL_GLOBAL_LOAD_DWORDX2; }
        return _gisel_emit(out, k, lop, dst, a, b, 0, flags | (mir_ptr_binding(m, b) << 8));
    }
    if (op == MIR_OP_STORE) {
        # c = the stored value; an f64 value is a 64-bit store → DWORDX2 (F.7d).
        var sop = GISEL_GLOBAL_STORE;
        if (mir_type_base(mir_val_type(m, c)) == MIR_T_F64) { sop = GISEL_GLOBAL_STORE_DWORDX2; }
        return _gisel_emit(out, k, sop, 0, a, b, c, flags | (mir_ptr_binding(m, b) << 8));
    }
    if (op == MIR_OP_CVT_F32) { return _gisel_emit(out, k, GISEL_V_CVT_F32_I32, dst, a, 0, 0, flags); }
    if (op == MIR_OP_CVT_I32) { return _gisel_emit(out, k, GISEL_V_CVT_I32_F32, dst, a, 0, 0, flags); }
    # f32<->f64 (F.7f.2): the RESULT picks the direction — f64 = widen (from f32), f32 = narrow (from
    # f64). The OPERAND width must match the OTHER side, else the VOP1 would read the wrong register
    # size (a 32-bit read of an f64 pair / vice-versa) — FAIL LOUD rather than silently miscompile a
    # malformed OpFConvert (e.g. f64->f64), which mabda's light spirv_validate_stream does not reject
    # (untrusted input; ADR-006). (F.7f.2 review #1.)
    if (op == MIR_OP_FCONVERT) {
        var rb = mir_type_base(mir_val_type(m, dst));
        var ab = mir_type_base(mir_val_type(m, a));
        if (rb == MIR_T_F64) {
            if (ab != MIR_T_F32) { return 0 - GISEL_ERR_UNSUPPORTED_OP; }
            return _gisel_emit(out, k, GISEL_V_CVT_F64_F32, dst, a, 0, 0, flags);
        }
        if (rb == MIR_T_F32) {
            if (ab != MIR_T_F64) { return 0 - GISEL_ERR_UNSUPPORTED_OP; }
            return _gisel_emit(out, k, GISEL_V_CVT_F32_F64, dst, a, 0, 0, flags);
        }
        return 0 - GISEL_ERR_UNSUPPORTED_OP;
    }
    # N.9 integer-division primitives. The unary forms (VMOV/CVT_F32_U/CVT_U_F32/RCP) carry
    # the source in `a`; MUL_HI is binary (a,b); CNDMASK is binary (a=false src0, b=true
    # vsrc1) reading the implicit VCC. All VALU.
    if (op == MIR_OP_VMOV) { return _gisel_emit(out, k, GISEL_V_MOV, dst, a, 0, 0, flags); }
    if (op == MIR_OP_CVT_F32_U) { return _gisel_emit(out, k, GISEL_V_CVT_F32_U32, dst, a, 0, 0, flags); }
    if (op == MIR_OP_CVT_U_F32) { return _gisel_emit(out, k, GISEL_V_CVT_U32_F32, dst, a, 0, 0, flags); }
    if (op == MIR_OP_RCP_IFLAG) { return _gisel_emit(out, k, GISEL_V_RCP_IFLAG_F32, dst, a, 0, 0, flags); }
    if (op == MIR_OP_MUL_HI) { return _gisel_emit(out, k, GISEL_V_MUL_HI_U32, dst, a, b, 0, flags); }
    if (op == MIR_OP_CNDMASK) { return _gisel_emit(out, k, GISEL_V_CNDMASK, dst, a, b, 0, flags); }
    # F.7f.6b f64 division macro: all VALU/f64 (dst type is f64 → regalloc claims a pair). The
    # 3-src forms carry a/b/c; RCP is unary; FMA_N0_ONE drops c (the inline 1.0 is in the emit).
    if (op == MIR_OP_F64_RCP) { return _gisel_emit(out, k, GISEL_V_RCP_F64, dst, a, 0, 0, flags); }
    if (op == MIR_OP_F64_DIV_SCALE) { return _gisel_emit(out, k, GISEL_V_DIV_SCALE_F64, dst, a, b, c, flags); }
    if (op == MIR_OP_F64_DIV_FMAS) { return _gisel_emit(out, k, GISEL_V_DIV_FMAS_F64, dst, a, b, c, flags); }
    if (op == MIR_OP_F64_DIV_FIXUP) { return _gisel_emit(out, k, GISEL_V_DIV_FIXUP_F64, dst, a, b, c, flags); }
    if (op == MIR_OP_F64_FMA_N0) { return _gisel_emit(out, k, GISEL_V_FMA_F64_N0, dst, a, b, c, flags); }
    if (op == MIR_OP_F64_FMA_N0_ONE) { return _gisel_emit(out, k, GISEL_V_FMA_F64_N0_ONE, dst, a, b, 0, flags); }
    # F.7f.7b f64 sqrt macro. CMP_CLASS writes the implicit VCC (dst=0, like V_CMP); the rest produce
    # an f64-pair dst. CNDMASK reads VCC (a=false, b=true); FMA_N0_HALF is 2-src; MUL_HALF/RSQ unary.
    if (op == MIR_OP_F64_RSQ) { return _gisel_emit(out, k, GISEL_V_RSQ_F64, dst, a, 0, 0, flags); }
    if (op == MIR_OP_F64_CMP_CLASS) { return _gisel_emit(out, k, GISEL_V_CMP_CLASS_F64, 0, a, b, 0, flags); }
    if (op == MIR_OP_F64_CNDMASK) { return _gisel_emit(out, k, GISEL_V_CNDMASK_F64, dst, a, b, 0, flags); }
    if (op == MIR_OP_F64_FMA_N0_HALF) { return _gisel_emit(out, k, GISEL_V_FMA_F64_N0_HALF, dst, a, b, 0, flags); }
    if (op == MIR_OP_F64_MUL_HALF) { return _gisel_emit(out, k, GISEL_V_MUL_F64_HALF, dst, a, 0, 0, flags); }
    # F.7f.7c sqrt subnormal wrapper. CONST carries the 64-bit value in a (immediate); LDEXP is
    # binary (f64 a, i32 b); CMP_GT writes the implicit VCC (dst=0, like V_CMP).
    if (op == MIR_OP_F64_CONST) { return _gisel_emit(out, k, GISEL_V_CONST_F64, dst, a, b, 0, flags); }
    if (op == MIR_OP_F64_LDEXP) { return _gisel_emit(out, k, GISEL_V_LDEXP_F64, dst, a, b, 0, flags); }
    if (op == MIR_OP_F64_CMP_GT) { return _gisel_emit(out, k, GISEL_V_CMP_GT_F64, 0, a, b, 0, flags); }
    # F.7f.10 i32<->f64 cvt (exp reduction): unary, reuse _emit_vop1. Result type drives the reg file.
    if (op == MIR_OP_CVT_I32_F64) { return _gisel_emit(out, k, GISEL_V_CVT_I32_F64, dst, a, 0, 0, flags); }
    if (op == MIR_OP_CVT_F64_I32) { return _gisel_emit(out, k, GISEL_V_CVT_F64_I32, dst, a, 0, 0, flags); }
    # F.7f.8 f64 ordered compare → VCC (dst=0). Reuses GISEL_V_CMP / _emit_vopc — the f64 VOPC opcode
    # is already in flags 8+ (set by the lowering), and the f64 pair operands resolve to their low reg.
    if (op == MIR_OP_F64_CMP) { return _gisel_emit(out, k, GISEL_V_CMP, 0, a, b, 0, flags); }
    # F.7f.8 OpSelect blend: a = cond mask, b = true, c = false (the bfi emit reads the dst type for
    # the lane count). Always VALU (bfi); the cond mask carries divergence.
    if (op == MIR_OP_SELECT) { return _gisel_emit(out, k, GISEL_V_SELECT, dst, a, b, c, flags); }
    if (op == MIR_OP_EXTRACT) {
        # The EXTRACT result's register file is decided from its uniformity
        # (gisel_result_is_vgpr), so a result-less or UNKNOWN-uniformity extract
        # (the N.2 sweep not run / a value it missed) would be silently mis-filed
        # to an SGPR — fail loud instead, mirroring the integer-ALU guard. (N.5c-2a
        # review.)
        if (dst == 0) { return 0 - GISEL_ERR_UNSUPPORTED_OP; }
        if (mir_val_unif(m, dst) == MIR_UNKNOWN) { return 0 - GISEL_ERR_UNSUPPORTED_OP; }
        return _gisel_emit(out, k, GISEL_EXTRACT, dst, a, b, c, flags);
    }
    # float ALU: always VALU. The result type base picks the f32 vs f64 (V_*_F64) opcode (F.7d).
    var fop = _gisel_float_op(op, mir_type_base(mir_val_type(m, dst)));
    if (fop != 0) { return _gisel_emit(out, k, fop, dst, a, b, c, flags); }
    # integer ALU: SALU (uniform) vs VALU (divergent) per the result's uniformity.
    var u = mir_val_unif(m, dst);
    var div = 0;
    if (u == MIR_DIVERGENT) { div = 1; }
    var iop = _gisel_int_op(op, div);
    if (iop == 0) { return 0 - GISEL_ERR_UNSUPPORTED_OP; }
    # A value-producing ALU op must have a real result with a CLASSIFIED
    # uniformity. A result-less arith op (dst 0 reads the vals[0] sentinel) or an
    # UNKNOWN result (the N.2 uniformity sweep did not run / missed it) would
    # otherwise be silently selected as SALU — fail loud instead. (N.3 review.)
    if (dst == 0) { return 0 - GISEL_ERR_UNSUPPORTED_OP; }
    if (u == MIR_UNKNOWN) { return 0 - GISEL_ERR_UNSUPPORTED_OP; }
    return _gisel_emit(out, k, iop, dst, a, b, c, flags);
}

# ================================================================
# Driver: MIR instruction list → selected GFX9 instruction list
# ================================================================
# Selects one GFX9 instruction per MIR instruction, in program order, into
# `out` (caller-provided, sized cap * GISEL_REC). Returns the count, or a
# NEGATIVE error (cap exceeded / unsupported op).
fn gfx9_isel(m, out, cap): i64 {
    var n = mir_n_instrs(m);
    var i = 0;
    var k = 0;
    var pending_merge = 0;   # merge label of an open divergent if (0 = none; MVP = no nesting)
    while (i < n) {
        if (k >= cap) { return 0 - GISEL_ERR_CAP_EXCEEDED; }
        var op = mir_instr_op(m, i);
        var a = mir_instr_a(m, i);
        var c = mir_instr_c(m, i);
        var handled = 0;
        # A DIVERGENT cond branch opens the EXEC-mask region: save+mask EXEC, then skip
        # the then-block entirely when no lane is active. The restore is emitted at merge.
        if (op == MIR_OP_COND_BRANCH) {
            if (mir_val_unif(m, a) == MIR_DIVERGENT) {
                if (pending_merge != 0) { return 0 - GISEL_ERR_UNSUPPORTED_OP; }
                if (k + 2 > cap) { return 0 - GISEL_ERR_CAP_EXCEEDED; }
                _gisel_emit(out, k, GISEL_S_SAVEEXEC, 0, 0, 0, 0, 0);
                _gisel_emit(out, k + 1, GISEL_S_CBRANCH_EXECZ, 0, 0, 0, c, 0);
                k = k + 2;
                pending_merge = c;
                handled = 1;
            }
        }
        # Its merge label closes the region: the label points at the EXEC restore, so a
        # skip OR a fall-through both land on it. Label first (records the offset), then
        # the s_or_b64 restore as the first real instruction there.
        if (handled == 0) {
            if (op == MIR_OP_LABEL) {
                if (pending_merge != 0) {
                    if (a == pending_merge) {
                        if (k + 2 > cap) { return 0 - GISEL_ERR_CAP_EXCEEDED; }
                        _gisel_emit(out, k, GISEL_LABEL, 0, a, 0, 0, 0);
                        _gisel_emit(out, k + 1, GISEL_S_OR_EXEC, 0, 0, 0, 0, 0);
                        k = k + 2;
                        pending_merge = 0;
                        handled = 1;
                    }
                }
            }
        }
        if (handled == 0) {
            var rc = _gisel_one(m, out, k, op, mir_instr_result(m, i),
            a, mir_instr_b(m, i), c, mir_instr_flags(m, i));
            if (rc < 0) { return rc; }
            k = k + 1;
        }
        i = i + 1;
    }
    if (pending_merge != 0) { return 0 - GISEL_ERR_UNSUPPORTED_OP; }   # unclosed divergent if
    return k;
}

# --- gfx9_regalloc.cyr ---

# @internal — GFX9 register allocation (Phase N.4a, virtual regs → physical)
# gfx9_regalloc.cyr — linear-scan allocation of the N.3 virtual registers (MIR
# SSA value <id>s) to physical VGPR / SGPR numbers. Two independent register
# files: a value's file is its N.2 uniformity (UNIFORM → SGPR, DIVERGENT → VGPR),
# so the scalar-vs-vector decision is already made; this pass only assigns
# numbers within each file and tracks the high-water marks N.6 feeds into RSRC1.
#
# Linear-scan with per-register "free-at" reuse: each physical register records
# the step at which its current occupant dies (last_use + 1); a later value
# claims the lowest register that is free at its definition step. So a divergent
# value reclaims a freed VGPR (the reuse that lets the downsample's many SSA
# values fit the hand-authored ~15-VGPR budget — the N.5 byte-match oracle).
# MVP = NO SPILL: if a file is exhausted the compile FAILS LOUD (a wrong spill
# beats nothing, ADR-006 spirit). ABI-fixed registers are reserved by the caller
# via sgpr_base / vgpr_base (USER_DATA + TGID SGPRs, v0 = LocalInvocationId);
# the allocator hands out [base, cap) so it never collides with them.
#
# Only SSA results are allocated. Constants are inline operands; builtins live in
# ABI registers; buffer vars are USER_DATA VAs reached via the binding — all
# skipped (operand uses are filtered by the immediate flags + value kind).
#
# `alloc` is a caller buffer of `cap_ids` 16-byte records [phys_reg, last_use]
# (reg = -1 if unallocated); `hw` is a caller [2] = [sgpr_hw, vgpr_hw]. Returns
# 0 or a NEGATIVE error. Included after gfx9_isel.cyr. Pure byte math.

var RA_REC     = 16;    # per-id record: +0 phys_reg, +8 last_use
var RA_HW_SGPR = 0;     # hw[] offsets
var RA_HW_VGPR = 8;
var RA_MAX_REGS = 256;  # free-at scratch size (the full GFX9 VGPR file)

var RA_ERR_SGPR_OVERFLOW = 50;
var RA_ERR_VGPR_OVERFLOW = 51;
var RA_ERR_CAP_TOO_LARGE = 52;

# ================================================================
# Accessors
# ================================================================
fn gfx9_reg(alloc, id): i64 { return load64(alloc + id * RA_REC + 0); }
fn gfx9_reg_lastuse(alloc, id): i64 { return load64(alloc + id * RA_REC + 8); }
fn gfx9_hw_sgpr(hw): i64 { return load64(hw + RA_HW_SGPR); }
fn gfx9_hw_vgpr(hw): i64 { return load64(hw + RA_HW_VGPR); }

# ================================================================
# Live-interval helpers
# ================================================================
# Extend value `id`'s last-use to step `i` (max). Only SSA values are tracked.
fn _ra_use(m, alloc, op, i): i64 {
    if (op != 0) {
        if (mir_val_kind(m, op) == MIR_VK_SSA) {
            if (i > load64(alloc + op * RA_REC + 8)) { store64(alloc + op * RA_REC + 8, i); }
        }
    }
    return 0;
}

# Claim the lowest physical register in [base, cap) that is free at `step`
# (free-at <= step; never-used = 0). Marks it busy until `freeat_new`. Returns
# the register number, or -1 if the file is exhausted.
fn _ra_claim(freeat, base, cap, step, freeat_new): i64 {
    var r = base;
    while (r < cap) {
        if (load64(freeat + r * 8) <= step) {
            store64(freeat + r * 8, freeat_new);
            return r;
        }
        r = r + 1;
    }
    return 0 - 1;
}

# v3.2 F.7c — claim the lowest EVEN-aligned register PAIR [r, r+1] in [base, cap) with BOTH
# halves free at `step`; mark both busy until `freeat_new`. f64 (64-bit) values occupy
# even-aligned pairs (v[2:3] / s[0:1]) on GFX9, so an odd `base` rounds up and r steps by 2.
# Returns the low (even) register, or -1 if no aligned pair fits the file.
fn _ra_claim_pair(freeat, base, cap, step, freeat_new): i64 {
    var r = base;
    if ((r & 1) != 0) { r = r + 1; }   # round up to the next even register
    while (r + 1 < cap) {
        if (load64(freeat + r * 8) <= step) {
            if (load64(freeat + (r + 1) * 8) <= step) {
                store64(freeat + r * 8, freeat_new);
                store64(freeat + (r + 1) * 8, freeat_new);
                return r;
            }
        }
        r = r + 2;
    }
    return 0 - 1;
}

# ================================================================
# Driver
# ================================================================
# Allocate physical registers for every SSA result of the selected-instruction
# list `isel` (n_isel instrs), over the MIR `m`. sgpr_base/vgpr_base = first
# allocatable register in each file (above the ABI-reserved region);
# sgpr_cap/vgpr_cap = file ceilings (<= RA_MAX_REGS). Writes the per-id reg into
# `alloc` and the high-water marks into `hw`. Returns 0 or a negative error.
fn gfx9_regalloc(m, isel, n_isel, sgpr_base, vgpr_base, sgpr_cap, vgpr_cap, alloc, hw): i64 {
    if (sgpr_cap > RA_MAX_REGS) { return 0 - RA_ERR_CAP_TOO_LARGE; }
    if (vgpr_cap > RA_MAX_REGS) { return 0 - RA_ERR_CAP_TOO_LARGE; }
    var cap_ids = load64(m + 64);
    memset(alloc, 0xFF, cap_ids * RA_REC);   # reg = -1, last_use = -1
    var sfreeat[2048];
    var vfreeat[2048];
    memset(&sfreeat, 0, 2048);
    memset(&vfreeat, 0, 2048);
    # Pass 1 — live intervals: a result is defined at its step; an operand use
    # extends that operand's interval. Immediate operands (flagged) and the
    # ptr-index of a load/store are not register uses.
    var i = 0;
    while (i < n_isel) {
        var dst = gisel_dst(isel, i);
        if (dst != 0) {
            if (mir_val_kind(m, dst) == MIR_VK_SSA) {
                if (i > load64(alloc + dst * RA_REC + 8)) { store64(alloc + dst * RA_REC + 8, i); }
            }
        }
        var fl = gisel_flags(isel, i);
        if ((fl & MIR_FLAG_A_IMM) == 0) { _ra_use(m, alloc, gisel_a(isel, i), i); }
        if ((fl & MIR_FLAG_B_IMM) == 0) { _ra_use(m, alloc, gisel_b(isel, i), i); }
        if ((fl & MIR_FLAG_C_IMM) == 0) { _ra_use(m, alloc, gisel_c(isel, i), i); }
        i = i + 1;
    }
    # Pass 2 — allocate each SSA result in its file, reusing freed registers.
    var sgpr_hw = sgpr_base;
    var vgpr_hw = vgpr_base;
    i = 0;
    while (i < n_isel) {
        var d2 = gisel_dst(isel, i);
        if (d2 != 0) {
            if (mir_val_kind(m, d2) == MIR_VK_SSA) {
                var freeat_new = load64(alloc + d2 * RA_REC + 8) + 1;
                # v3.2 F.7c — register WIDTH: an f64 value occupies an even-aligned
                # 64-bit PAIR (2 regs), everything else a single reg. The high-water
                # bumps by `w`, so the RSRC1 ceil(hw/4)-1 formula already counts pairs
                # (a kernel ending at v[8:9] → hw 10 → VGPRS 2, the F.4 oracle).
                var w = 1;
                if (mir_type_base(mir_val_type(m, d2)) == MIR_T_F64) { w = 2; }
                # The file follows the SELECTED op's destination class, not the
                # value's uniformity: a float/CVT op is always VALU (writes a
                # VGPR) even for a uniform result, so uniformity would misfile it
                # into an SGPR. Integer S_*/V_* already track uniformity in isel,
                # so the two agree there. (A uniform value held in a VGPR feeding
                # a later SALU op is the operand-class-coercion case — N.8.)
                if (gisel_result_is_vgpr(m, isel, i) == 1) {
                    var rv = 0;
                    if (w == 2) { rv = _ra_claim_pair(&vfreeat, vgpr_base, vgpr_cap, i, freeat_new); }
                    else { rv = _ra_claim(&vfreeat, vgpr_base, vgpr_cap, i, freeat_new); }
                    if (rv < 0) { return 0 - RA_ERR_VGPR_OVERFLOW; }
                    store64(alloc + d2 * RA_REC + 0, rv);
                    if (rv + w > vgpr_hw) { vgpr_hw = rv + w; }
                } else {
                    var rs = 0;
                    if (w == 2) { rs = _ra_claim_pair(&sfreeat, sgpr_base, sgpr_cap, i, freeat_new); }
                    else { rs = _ra_claim(&sfreeat, sgpr_base, sgpr_cap, i, freeat_new); }
                    if (rs < 0) { return 0 - RA_ERR_SGPR_OVERFLOW; }
                    store64(alloc + d2 * RA_REC + 0, rs);
                    if (rs + w > sgpr_hw) { sgpr_hw = rs + w; }
                }
            }
        }
        i = i + 1;
    }
    store64(hw + RA_HW_SGPR, sgpr_hw);
    store64(hw + RA_HW_VGPR, vgpr_hw);
    return 0;
}

# --- gfx9_waitcnt.cyr ---

# @internal — GFX9 s_waitcnt insertion (Phase N.4b)
# gfx9_waitcnt.cyr — inserts s_waitcnt instructions into the N.3 selected-
# instruction list so no instruction ever reads the result of a memory op that
# has not yet completed. GFX9 memory ops are ASYNCHRONOUS: a global_load issues
# and returns immediately; its destination VGPR is not valid until the hardware
# vmcnt counter (outstanding vmem ops) drains. Reading it early reads STALE /
# GARBAGE memory — a silent data-corruption class, the top-tier correctness risk
# of the compiler. This pass makes a use-before-wait IMPOSSIBLE BY CONSTRUCTION:
# before the first instruction that consumes an outstanding load result it emits
# s_waitcnt vmcnt(0), and before s_endpgm (if any memory op ran) it emits
# s_waitcnt vmcnt(0) lgkmcnt(0) so the wave does not retire before its stores
# (and any smem) complete. This is exactly the hand-authored downsample pattern
# (0xBF8C0F70 after the loads, 0xBF8C0070 before the end), so the N.5 byte-match
# oracle reproduces it.
#
# MVP policy = CONSERVATIVE vmcnt(0): a use of any outstanding load waits for ALL
# outstanding vmem ops (never under-waits — correctness over a tighter count;
# the per-load count is N.8). Tracks outstanding loads by result <id>. Runs on
# the isel list independently of regalloc (waits carry no register, and the
# regalloc reg-map is id-keyed so it is unaffected by the index shift). N.5 walks
# this output and resolves regs via the regalloc map.
#
# Output: a NEW caller-provided buffer of 48-byte GISEL records (the input copied
# with s_waitcnt records spliced in). gfx9_waitcnt returns the new instruction
# count (>= 0) or a NEGATIVE error. Included after gfx9_regalloc.cyr. Pure byte
# math; no syscalls.

# s_waitcnt simm16 operands (GFX9). vmcnt is split [3:0]+[15:14]; lgkmcnt [11:8];
# expcnt [6:4]; a maxed field means "don't care". These two match the downsample:
var GFX9_WAITCNT_VM      = 3952;  # 0x0F70: vmcnt(0), lgkm/exp don't-care
var GFX9_WAITCNT_VM_LGKM = 112;   # 0x0070: vmcnt(0) AND lgkmcnt(0), exp don't-care

# Error codes (disjoint from mir 20-25, lower 26-27, regalloc 50-52, cmp 70-87, gisel 100-101).
var WC_ERR_CAP          = 60;   # output buffer cap exceeded
var WC_ERR_TOO_MANY_IDS = 61;   # cap_ids beyond the outstanding-tracker scratch

# ================================================================
# Helpers
# ================================================================
# Copy selected instruction `i` from `src` into `dst` slot `k` verbatim.
fn _wc_copy(src, i, dst, k): i64 {
    return _gisel_emit(dst, k, gisel_op(src, i), gisel_dst(src, i),
    gisel_a(src, i), gisel_b(src, i), gisel_c(src, i), gisel_flags(src, i));
}

# 1 if instruction `i` reads a register operand that is an outstanding (un-waited)
# load result; 0 otherwise. Immediate operands (flagged) and the load/store ptr
# index are not register reads, so they never trigger a wait.
fn _wc_uses_outstanding(src, i, outstanding): i64 {
    var fl = gisel_flags(src, i);
    var a = gisel_a(src, i);
    var b = gisel_b(src, i);
    var c = gisel_c(src, i);
    if (a != 0) { if ((fl & MIR_FLAG_A_IMM) == 0) { if (load64(outstanding + a * 8) == 1) { return 1; } } }
    if (b != 0) { if ((fl & MIR_FLAG_B_IMM) == 0) { if (load64(outstanding + b * 8) == 1) { return 1; } } }
    if (c != 0) { if ((fl & MIR_FLAG_C_IMM) == 0) { if (load64(outstanding + c * 8) == 1) { return 1; } } }
    return 0;
}

# Emit an s_waitcnt with simm `s` into `dst` slot `k` (a = simm, flagged
# immediate so no later pass treats it as a register).
fn _wc_emit_wait(dst, k, s): i64 {
    return _gisel_emit(dst, k, GISEL_S_WAITCNT, 0, s, 0, 0, MIR_FLAG_A_IMM);
}

# ================================================================
# Driver
# ================================================================
# Splice s_waitcnt into the selected-instruction list `in_buf` (n_in instrs) into
# the caller buffer `out` (sized cap_out * GISEL_REC). Returns the new count or a
# negative error.
fn gfx9_waitcnt(m, in_buf, n_in, out, cap_out): i64 {
    var cap_ids = load64(m + 64);
    if (cap_ids > RA_MAX_REGS) { return 0 - WC_ERR_TOO_MANY_IDS; }
    var outstanding[2048];   # RA_MAX_REGS (256) i64; 1 = id is an un-waited load
    memset(&outstanding, 0, cap_ids * 8);
    var any_vmem = 0;
    var k = 0;
    var i = 0;
    while (i < n_in) {
        var op = gisel_op(in_buf, i);
        if (op == GISEL_S_ENDPGM) {
            # Drain all memory before the wave retires (stores must land).
            if (any_vmem == 1) {
                if (k >= cap_out) { return 0 - WC_ERR_CAP; }
                _wc_emit_wait(out, k, GFX9_WAITCNT_VM_LGKM);
                k = k + 1;
            }
            if (k >= cap_out) { return 0 - WC_ERR_CAP; }
            _wc_copy(in_buf, i, out, k);
            k = k + 1;
        } else {
            # Wait before consuming an outstanding load result. vmcnt(0) clears
            # ALL outstanding loads, so one wait covers every prior load.
            if (_wc_uses_outstanding(in_buf, i, &outstanding) == 1) {
                if (k >= cap_out) { return 0 - WC_ERR_CAP; }
                _wc_emit_wait(out, k, GFX9_WAITCNT_VM);
                k = k + 1;
                memset(&outstanding, 0, cap_ids * 8);
            }
            if (k >= cap_out) { return 0 - WC_ERR_CAP; }
            _wc_copy(in_buf, i, out, k);
            k = k + 1;
            if (op == GISEL_GLOBAL_LOAD) {
                store64(&outstanding + gisel_dst(in_buf, i) * 8, 1);
                any_vmem = 1;
            }
            # v3.2 F.7d — a DWORDX2 (f64) load is one result <id> spanning a VGPR pair; track it
            # exactly like a 32-bit load (the conservative vmcnt(0) waits for it before any use).
            if (op == GISEL_GLOBAL_LOAD_DWORDX2) {
                store64(&outstanding + gisel_dst(in_buf, i) * 8, 1);
                any_vmem = 1;
            }
            if (op == GISEL_GLOBAL_STORE) { any_vmem = 1; }
            if (op == GISEL_GLOBAL_STORE_DWORDX2) { any_vmem = 1; }
        }
        i = i + 1;
    }
    return k;
}

# --- gfx9_abi.cyr ---

# @internal — GFX9 compute ABI + RSRC wiring (Phase N.5b)
# gfx9_abi.cyr — the canonical compute ABI the SPIR-V→GFX9 compiler always emits,
# plus the COMPUTE_PGM_RSRC1/RSRC2 dword computation from the regalloc high-water
# marks + the ABI. This is the seam between the abstract MIR/regalloc world and
# the hardware dispatch contract (USER_DATA layout, TGID enables, register
# counts) that native_pm4_build_compute_* consumes.
#
# CANONICAL ABI (one layout for every compiled compute kernel — see
# project_n5_saxpy_first_proven_equiv): the HW preloads, in order,
#   USER_DATA SGPRs s0..s[user_sgpr-1] : buffer base VAs, binding k → s[2k:2k+1]
#   TGID SGPRs      s[user_sgpr..]      : WorkgroupId .x/.y/.z (RSRC2 TGID_*_EN)
#   v0 / v1 / v2                        : LocalInvocationId .x/.y/.z
# So the first register the allocator may hand out is sgpr_base = user_sgpr +
# (#tgid) and vgpr_base = (#lid). GlobalInvocationId is NOT a register — it is
# wgid*local_size + lid, materialized by a lowering step (later sub-bite); the
# ABI only pins the primitive builtins.
#
# Full 3-D dispatch: TGID_X/Y/Z + LID.x/y/z enables are derived from the max
# component each builtin is actually extracted with (gfx9_abi_assign). Pure integer
# math; no syscalls. Included after mir.cyr (reads the value table + instr list)
# and before gfx9_compile.cyr (which resolves binding/builtin operands here).

# COMPUTE_PGM_RSRC1: the fixed FLOAT_MODE(0xC0)+DX10_CLAMP flags with the VGPRS
# (bits 0-5) and SGPRS (bits 6-9) fields ZEROED — the per-shader register counts
# OR in. (= GFX9_COMPUTE_PGM_RSRC1_MIN 0x2C0040 with its SGPRS=1 field cleared.)
var GFX9_RSRC1_FLAGS = 0x2C0000;

# Error codes (disjoint from the compile module's CMP_ERR_* 70-79).
var ABI_ERR_VGPR_OVERFLOW     = 80;   # VGPRS field (6-bit) would overflow
var ABI_ERR_SGPR_OVERFLOW     = 81;   # SGPRS field (4-bit) would overflow
var ABI_ERR_TOO_MANY_BINDINGS = 82;   # binding VA pairs exceed the 16-SGPR USER_DATA capacity

# GFX9 USER_DATA capacity: s0..s15 are HW-preloadable, so at most 8 binding VA pairs.
var GFX9_USER_DATA_MAX = 16;

# ABI descriptor record (caller buffer, 64 B): field byte offsets.
var ABI_USER_SGPR    = 0;    # # of preloaded USER_DATA SGPRs (= 2 * #bindings)
var ABI_NUM_BINDINGS = 8;
var ABI_TGID_X       = 16;   # RSRC2 TGID_X_EN (0/1)
var ABI_TGID_Y       = 24;
var ABI_TGID_Z       = 32;
var ABI_LID_COUNT    = 40;   # # of LocalInvocationId components (v0..)
var ABI_SGPR_BASE    = 48;   # first allocatable SGPR (above USER_DATA + TGID)
var ABI_VGPR_BASE    = 56;   # first allocatable VGPR (above the LID v0..)

# ================================================================
# RSRC1 / RSRC2 from the regalloc high-water marks + the ABI
# ================================================================
# COMPUTE_PGM_RSRC1 from the VGPR/SGPR high-water marks (max reg used + 1, incl.
# the ABI region). VGPRS = ceil(vgpr_hw/4) - 1; SGPRS = ceil((sgpr_hw+2)/8) - 1
# (+2 reserves VCC), floored at 1 (16 SGPRs — SGPRS=0 gives only 8, too few once
# VCC is live; matches the hand-authored RSRC1_MIN rationale). FAIL LOUD (negative
# error) if either field would overflow its width rather than silently masking to
# a too-small allocation (N.5b-1 review): the SGPRS field is only 4 bits (≤128
# SGPRs) so sgpr_hw > 120 must be rejected, not wrapped. (A correctly-bounded
# regalloc keeps both inside range; this guards a future driver passing the wrong
# file cap — see the regalloc SGPR-cap note in the punchlist.)
fn gfx9_rsrc1(vgpr_hw, sgpr_hw): i64 {
    var vgprs = (vgpr_hw + 3) / 4;
    if (vgprs > 0) { vgprs = vgprs - 1; }
    var sgprs = (sgpr_hw + 2 + 7) / 8;
    if (sgprs > 0) { sgprs = sgprs - 1; }
    if (sgprs < 1) { sgprs = 1; }
    if (vgprs > 0x3F) { return 0 - ABI_ERR_VGPR_OVERFLOW; }
    if (sgprs > 0xF) { return 0 - ABI_ERR_SGPR_OVERFLOW; }
    return GFX9_RSRC1_FLAGS | vgprs | (sgprs << 6);
}

# COMPUTE_PGM_RSRC2: USER_SGPR count (bits 1-5), TRAP_PRESENT (bit 6), TGID_X_EN
# (bit 7), TGID_Y_EN (bit 8), TGID_Z_EN (bit 9), TIDIG_COMP_CNT (bits 11-12 — the
# number of LocalInvocationId components MINUS 1 the HW writes to v0/v1/v2). Without
# the right TGID_*_EN / TIDIG_COMP_CNT the HW never loads wgid.y/z or lid.y/z, so a
# 2-D/3-D kernel reads uninitialized registers (the N.6 2-D bug). (LDS/scratch zero.)
fn gfx9_rsrc2(user_sgpr, tgid_x, tgid_y, tgid_z, tidig_comp_cnt, trap): i64 {
    var r = (user_sgpr & 0x1F) << 1;
    if (trap != 0) { r = r | 0x40; }
    if (tgid_x != 0) { r = r | 0x80; }
    if (tgid_y != 0) { r = r | 0x100; }
    if (tgid_z != 0) { r = r | 0x200; }
    r = r | ((tidig_comp_cnt & 0x3) << 11);
    return r;
}

# ================================================================
# ABI assignment — scan the MIR for bindings + builtins, fill the descriptor
# ================================================================
fn gfx9_abi_assign(m, abi): i64 {
    var cap_ids = load64(m + 64);
    var max_binding = 0 - 1;
    var i = 1;
    while (i < cap_ids) {
        if (mir_val_kind(m, i) == MIR_VK_BUFVAR) {
            var bind = mir_val_payload(m, i);
            if (bind > max_binding) { max_binding = bind; }
        }
        i = i + 1;
    }
    # The number of WorkgroupId / LocalInvocationId components the kernel actually
    # uses is the MAX component subscript across its EXTRACT instructions on those
    # builtins (the GlobalInvocationId expansion already lowered to wgid/lid extracts).
    # That fixes how many TGID SGPRs / LID VGPRs the HW must preload — a 2-D kernel
    # needs TGID_Y_EN + TIDIG_COMP_CNT=1, which the 1-D MVP never set.
    var max_wgid = 0 - 1;
    var max_lid  = 0 - 1;
    var ni = mir_n_instrs(m);
    var j = 0;
    while (j < ni) {
        if (mir_instr_op(m, j) == MIR_OP_EXTRACT) {
            var a = mir_instr_a(m, j);
            var comp = mir_instr_c(m, j);
            if (a > 0) {
                if (a < cap_ids) {
                    if (mir_val_kind(m, a) == MIR_VK_BUILTIN) {
                        var bi = mir_val_payload(m, a);
                        if (bi == MIR_BI_WORKGROUP_ID) { if (comp > max_wgid) { max_wgid = comp; } }
                        if (bi == MIR_BI_LOCAL_INVOC_ID) { if (comp > max_lid) { max_lid = comp; } }
                    }
                }
            }
        }
        j = j + 1;
    }
    var num_bindings = max_binding + 1;
    var user_sgpr = num_bindings * 2;
    if (user_sgpr > GFX9_USER_DATA_MAX) { return 0 - ABI_ERR_TOO_MANY_BINDINGS; }
    # Enable TGID_X..TGID_{max_wgid} contiguously so wgid.comp maps to s[user+comp]
    # (gfx9_abi_builtin_reg); likewise LID v0..v{max_lid}.
    var tgid_x = 0;
    var tgid_y = 0;
    var tgid_z = 0;
    if (max_wgid >= 0) { tgid_x = 1; }
    if (max_wgid >= 1) { tgid_y = 1; }
    if (max_wgid >= 2) { tgid_z = 1; }
    var n_tgid = 0;
    if (max_wgid >= 0) { n_tgid = max_wgid + 1; }
    var lid_count = 0;
    if (max_lid >= 0) { lid_count = max_lid + 1; }
    store64(abi + ABI_NUM_BINDINGS, num_bindings);
    store64(abi + ABI_USER_SGPR, user_sgpr);
    store64(abi + ABI_TGID_X, tgid_x);
    store64(abi + ABI_TGID_Y, tgid_y);
    store64(abi + ABI_TGID_Z, tgid_z);
    store64(abi + ABI_LID_COUNT, lid_count);
    store64(abi + ABI_SGPR_BASE, user_sgpr + n_tgid);
    store64(abi + ABI_VGPR_BASE, lid_count);
    return 0;
}

# Number of LocalInvocationId components the kernel uses (v0..). RSRC2's
# TIDIG_COMP_CNT = max(lid_count - 1, 0).
fn gfx9_abi_lid_count(abi): i64 { return load64(abi + ABI_LID_COUNT); }

# ================================================================
# Accessors + operand resolution
# ================================================================
fn gfx9_abi_user_sgpr(abi): i64 { return load64(abi + ABI_USER_SGPR); }
fn gfx9_abi_num_bindings(abi): i64 { return load64(abi + ABI_NUM_BINDINGS); }
fn gfx9_abi_tgid_x(abi): i64 { return load64(abi + ABI_TGID_X); }
fn gfx9_abi_tgid_y(abi): i64 { return load64(abi + ABI_TGID_Y); }
fn gfx9_abi_tgid_z(abi): i64 { return load64(abi + ABI_TGID_Z); }
fn gfx9_abi_sgpr_base(abi): i64 { return load64(abi + ABI_SGPR_BASE); }
fn gfx9_abi_vgpr_base(abi): i64 { return load64(abi + ABI_VGPR_BASE); }

# Buffer binding k → its USER_DATA base-VA SGPR (the low half of the pair s[2k:2k+1]).
fn gfx9_abi_binding_sgpr(abi, binding): i64 { return binding * 2; }

# A primitive builtin component → its ABI register number. LocalInvocationId → a
# VGPR (v0..); WorkgroupId → an SGPR (above USER_DATA). The CALLER picks the file
# from the builtin code. GlobalInvocationId returns -1 (must be expanded, not a
# single register).
fn gfx9_abi_builtin_reg(abi, bi_code, comp): i64 {
    if (bi_code == MIR_BI_LOCAL_INVOC_ID) { return comp; }
    if (bi_code == MIR_BI_WORKGROUP_ID) { return load64(abi + ABI_USER_SGPR) + comp; }
    return 0 - 1;
}

# --- gfx9_compile.cyr ---

# @internal — GFX9 encode driver (Phase N.5a, the compiler's output stage)
# gfx9_compile.cyr — walks the N.4 selected-instruction list + the regalloc map
# and emits a GFX9 ISA byte stream through the gfx9_encode.cyr encoders. This is
# the stage that finally turns the abstract GISEL records (op / dst / a / b / c /
# flags, operands = MIR <id>s) into runnable dwords: each operand resolves to a
# physical register (regalloc map + the per-value file), an inline constant, a
# 32-bit literal dword, or (N.5b) an ABI register; each op dispatches to the
# right encoder + format.
#
# N.5a SCOPE: the single-dword ALU/control formats the current isel already
# produces over SSA-or-constant operands — SOP2, VOP1 (CVT), VOP2 (incl. the
# rev-operand shifts), SOPP (s_waitcnt / s_endpgm) — plus the literal-dword path.
# FLAT load/store, VOP3 (v_mul_lo_u32 / add3 / bfe / or3), GISEL_EXTRACT, and
# builtin/buffer operands fail loud (CMP_ERR_*) — they land with the ABI module
# in N.5b+. The driver returns the end byte position so the caller appends
# gfx9_emit_prefetch_pad. Pure byte math; no syscalls. Included after
# gfx9_waitcnt.cyr (drives gfx9_isel + gfx9_regalloc + gfx9_encode accessors).
#
# The OPERAND FILE (VGPR vs SGPR) of an SSA value is the destination class of the
# instruction that DEFINES it (gisel_writes_vgpr) — NOT its uniformity (the N.4a
# lesson: a uniform float/CVT result lives in a VGPR). The driver builds a
# file-map over the list's results in a first pass, then resolves operands
# against it. Every SSA operand of a straight-line program is defined earlier in
# the same list, so the map covers them all.

# Error codes (disjoint from mir 20-25, lower 26-27, regalloc 50-52, waitcnt 60-61,
# gisel 100-101).
var CMP_ERR_UNSUPPORTED_OP      = 70;   # a GISEL op N.5a does not encode yet
var CMP_ERR_UNSUPPORTED_OPERAND = 71;   # a builtin/buffer/ptr operand (N.5b)
var CMP_ERR_NO_VGPR_OPERAND     = 72;   # a VALU op with no VGPR operand for vsrc1
var CMP_ERR_BAD_SALU_OPERAND    = 73;   # a SALU op handed a VGPR operand
var CMP_ERR_TWO_LITERALS        = 74;   # >1 literal in one instruction (illegal)
var CMP_ERR_TOO_MANY_IDS        = 75;   # cap_ids beyond the file-map scratch
var CMP_ERR_VOP3_LITERAL        = 76;   # a 32-bit literal operand in a VOP3 (no literal form)
var CMP_ERR_FLAT_CONST_OFFSET   = 77;   # const-offset access chain (off_id 0); imm-offset form
# is a later bite (see docs/development/3-2-punchlist.md)
var CMP_ERR_FLAT_NONVGPR        = 78;   # a FLAT offset/data operand not in a VGPR (uniform → needs materialization)
var CMP_ERR_BINDING_RANGE       = 79;   # a binding outside the loaded USER_DATA region
var CMP_ERR_UNSUPPORTED_BUILTIN = 83;   # an EXTRACT of a builtin N.5c does not resolve yet (WGID/GID)
var CMP_ERR_VALIDATE            = 84;   # spirv_validate_stream rejected the input
var CMP_ERR_TABLE               = 85;   # a type/const/deco table builder rejected the
# input (malformed, or id_bound > CC_CAP_IDS) (N-HARDEN.1)
var CMP_ERR_UNRESOLVED_LABEL    = 86;   # a branch targets a label not in the program (N.7)
var CMP_ERR_TOO_MANY_BRANCHES   = 87;   # branch count exceeds the patch-list scratch (N.7)

# Top-level compile context (caller buffer, 80 B): pointers to the stage scratch.
# `m` is an initialized MirMod (it holds vals/instrs/ptrs/blocks); the rest are
# the per-stage tables/lists the driver fills.
var CC_TYPES  = 0;
var CC_CONSTS = 8;
var CC_DECO   = 16;
var CC_M      = 24;
var CC_OUTBI  = 32;
var CC_ISEL   = 40;   # selected-instruction list (>= CMP_ISEL_CAP * GISEL_REC)
var CC_ISEL2  = 48;   # waitcnt-spliced list (same size)
var CC_ALLOC  = 56;
var CC_HW     = 64;
var CC_ABI    = 72;
var CC_CAP_IDS = 80;  # capacity (in records) of the <id>-indexed scratch tables.
# The caller MUST size ALL of types (CC_CAP_IDS*24 B), consts
# (*16), deco (*16) AND the OUTBI builtin table (*8) for at
# least CC_CAP_IDS records, and set this field. The table
# builders reject id_bound > CC_CAP_IDS (N-HARDEN.1) before any
# write, which — because OUTBI is in this same contract — also
# bounds the OUTBI memset in _spirv_resolve_builtins downstream.

# Compile output descriptor (caller buffer, 40 B).
var DESC_ISA_LEN      = 0;    # ISA byte length (incl. the prefetch pad)
var DESC_RSRC1        = 8;
var DESC_RSRC2        = 16;
var DESC_USER_SGPR    = 24;
var DESC_NUM_BINDINGS = 32;

var CMP_ISEL_CAP  = 256;   # max selected instrs (caller sizes isel/isel2 to match) —
# matched to the RA_MAX_REGS=256 id ceiling so a kernel at
# the cap can still select an instr per value.
var GFX9_SGPR_CAP = 104;   # GFX9 SGPR file limit (s0..s103) — the regalloc ceiling
var GFX9_VGPR_CAP = 256;   # GFX9 VGPR file
# Divergent control flow saves the old EXEC mask into a fixed 64-bit SGPR pair at the
# top of the usable general-SGPR range (s[100:101] — s102+ are reserved for FLAT_SCRATCH
# / XNACK / VCC on GFX9). When a kernel has divergent CF, the regalloc cap drops to this
# so the pair is never allocated, and the rsrc1 SGPR count is bumped to cover s101.
var GFX9_EXEC_SAVE_SGPR  = 100;
var GFX9_EXEC_SAVE_COUNT = 102;   # general-SGPR count that covers s[100:101]

# ================================================================
# Operand resolution
# ================================================================
# Resolve a GISEL operand to a 9-bit VOP src code (SGPR 0-101 / inline 128-208 /
# VGPR 256+n / GFX9_SRC_LITERAL 255 = a literal dword follows). `is_imm` non-zero
# means the field IS an inline immediate value; otherwise the field is a MIR <id>
# (CONST -> its bits; SSA -> its physical register + file). Returns a negative
# error for a builtin/buffer/ptr operand (N.5b) or the id-0 sentinel.
fn _cmp_resolve(m, alloc, isvgpr, field, is_imm): i64 {
    if (is_imm != 0) { return gfx9_inline_int(field); }
    if (field == 0) { return 0 - CMP_ERR_UNSUPPORTED_OPERAND; }
    var k = mir_val_kind(m, field);
    if (k == MIR_VK_CONST) {
        # An f32 constant uses the float inline-operand codes (±0.5/1/2/4); integers use
        # the integer inline range. Anything else resolves to a literal.
        if (mir_val_type(m, field) == MIR_T_F32) { return gfx9_inline_float(mir_val_payload(m, field)); }
        # An f64 constant is a 64-bit value VOP3 cannot encode as a literal — it MUST be
        # pre-materialized into a VGPR pair via MIR_OP_F64_CONST in spirv_lower (_spirv_f64_arg).
        # Fail loud if one reaches here unmaterialized rather than silently truncating to the low
        # dword (which is 0.0 for 0.5/1.0/1.5/... → silent corruption). (F.7f.9 review backstop.)
        if (mir_type_base(mir_val_type(m, field)) == MIR_T_F64) { return 0 - CMP_ERR_VOP3_LITERAL; }
        return gfx9_inline_int(mir_val_payload(m, field));
    }
    if (k == MIR_VK_SSA) {
        var r = gfx9_reg(alloc, field);
        if (load64(isvgpr + field * 8) != 0) { return gfx9_vgpr(r); }
        return gfx9_sgpr(r);
    }
    return 0 - CMP_ERR_UNSUPPORTED_OPERAND;
}

# The 32-bit literal value for an operand whose _cmp_resolve returned LITERAL.
fn _cmp_lit(m, field, is_imm): i64 {
    if (is_imm != 0) { return field; }
    return mir_val_payload(m, field);
}

# 1 if the operand resolves to a VGPR (a non-immediate SSA value in the VGPR
# file); 0 otherwise (immediate / constant / SGPR value).
fn _cmp_is_vgpr(m, isvgpr, field, is_imm): i64 {
    if (is_imm != 0) { return 0; }
    if (field == 0) { return 0; }
    if (mir_val_kind(m, field) != MIR_VK_SSA) { return 0; }
    if (load64(isvgpr + field * 8) != 0) { return 1; }
    return 0;
}

# ================================================================
# Per-format emitters — each returns the new byte position or a negative error.
# ================================================================
# SOP2: scalar ALU, sdst = a OP b. ssrc0/ssrc1 are 8-bit (SGPR / inline /
# literal); a VGPR operand is illegal. At most one literal.
fn _emit_sop2(m, isel, i, alloc, isvgpr, buf, pos, opc): i64 {
    var fl = gisel_flags(isel, i);
    var a = gisel_a(isel, i);
    var b = gisel_b(isel, i);
    var ssrc0 = _cmp_resolve(m, alloc, isvgpr, a, fl & MIR_FLAG_A_IMM);
    if (ssrc0 < 0) { return ssrc0; }
    var ssrc1 = _cmp_resolve(m, alloc, isvgpr, b, fl & MIR_FLAG_B_IMM);
    if (ssrc1 < 0) { return ssrc1; }
    if (ssrc0 >= 256) { return 0 - CMP_ERR_BAD_SALU_OPERAND; }
    if (ssrc1 >= 256) { return 0 - CMP_ERR_BAD_SALU_OPERAND; }
    if (ssrc0 == GFX9_SRC_LITERAL) { if (ssrc1 == GFX9_SRC_LITERAL) { return 0 - CMP_ERR_TWO_LITERALS; } }
    var p = gfx9_emit32(buf, pos, gfx9_enc_sop2(opc, gfx9_reg(alloc, gisel_dst(isel, i)), ssrc0, ssrc1));
    if (ssrc0 == GFX9_SRC_LITERAL) { return gfx9_emit32(buf, p, _cmp_lit(m, a, fl & MIR_FLAG_A_IMM)); }
    if (ssrc1 == GFX9_SRC_LITERAL) { return gfx9_emit32(buf, p, _cmp_lit(m, b, fl & MIR_FLAG_B_IMM)); }
    return p;
}

# VOP1: vector ALU, one source (the CVT ops). vdst = OP(src0).
fn _emit_vop1(m, isel, i, alloc, isvgpr, buf, pos, opc): i64 {
    var fl = gisel_flags(isel, i);
    var a = gisel_a(isel, i);
    var src0 = _cmp_resolve(m, alloc, isvgpr, a, fl & MIR_FLAG_A_IMM);
    if (src0 < 0) { return src0; }
    var p = gfx9_emit32(buf, pos, gfx9_enc_vop1(opc, gfx9_reg(alloc, gisel_dst(isel, i)), src0));
    if (src0 == GFX9_SRC_LITERAL) { return gfx9_emit32(buf, p, _cmp_lit(m, a, fl & MIR_FLAG_A_IMM)); }
    return p;
}

# GLSL FAbs(x) = clear the f32 sign bit: v_and_b32 dst, 0x7FFFFFFF, x (the mask rides
# src0 as a trailing literal; x is vsrc1, so x must be a VGPR). Correct for finite/inf
# (sign cleared) and nan (stays nan). One operand — no commutative-swap needed.
fn _emit_fabs(m, isel, i, alloc, isvgpr, buf, pos): i64 {
    var x = _cmp_vgpr_operand(m, alloc, isvgpr, gisel_a(isel, i));
    if (x < 0) { return x; }
    var dst = gfx9_reg(alloc, gisel_dst(isel, i));
    var p = gfx9_emit32(buf, pos, gfx9_enc_vop2(GFX9_VOP2_V_AND_B32, dst, GFX9_SRC_LITERAL, x));
    return gfx9_emit32(buf, p, 0x7FFFFFFF);
}

# v_cndmask_b32 dst, src0(=a, false value), vsrc1(=b, true value), VCC (implicit). NON-
# commutative + VCC-dependent: both operands MUST be VGPRs (the udiv macro guarantees it),
# and it must immediately follow its v_cmp with no VCC-writer between (true by construction
# in the macro). a → the 9-bit src0 code, b → the raw vsrc1 index. (N.9 udiv.)
fn _emit_cndmask(m, isel, i, alloc, isvgpr, buf, pos): i64 {
    var fa = _cmp_vgpr_operand(m, alloc, isvgpr, gisel_a(isel, i));
    if (fa < 0) { return fa; }
    var tb = _cmp_vgpr_operand(m, alloc, isvgpr, gisel_b(isel, i));
    if (tb < 0) { return tb; }
    var dst = gfx9_reg(alloc, gisel_dst(isel, i));
    return gfx9_emit32(buf, pos, gfx9_enc_vop2(GFX9_VOP2_V_CNDMASK_B32, dst, gfx9_vgpr(fa), tb));
}

# VOP2: vector ALU, two sources. Encoding is src0 (9-bit, flexible) + vsrc1
# (an 8-bit VGPR index). `is_rev` ops (v_lshlrev/lshrrev) are vdst = vsrc1 OP
# src0 with src0 = the shift amount, so the value operand (a) MUST be the VGPR
# vsrc1. Commutative ops place the VGPR operand in vsrc1 and the other in src0.
fn _emit_vop2(m, isel, i, alloc, isvgpr, buf, pos, opc, is_rev): i64 {
    var fl = gisel_flags(isel, i);
    var a = gisel_a(isel, i);
    var b = gisel_b(isel, i);
    var aimm = fl & MIR_FLAG_A_IMM;
    var bimm = fl & MIR_FLAG_B_IMM;
    var src0 = 0;
    var vsrc1 = 0;
    var lit_field = 0;
    var lit_imm = 0;
    if (is_rev != 0) {
        if (_cmp_is_vgpr(m, isvgpr, a, aimm) == 0) { return 0 - CMP_ERR_NO_VGPR_OPERAND; }
        vsrc1 = gfx9_reg(alloc, a);
        src0 = _cmp_resolve(m, alloc, isvgpr, b, bimm);
        lit_field = b;
        lit_imm = bimm;
    } else {
        if (_cmp_is_vgpr(m, isvgpr, b, bimm) != 0) {
            vsrc1 = gfx9_reg(alloc, b);
            src0 = _cmp_resolve(m, alloc, isvgpr, a, aimm);
            lit_field = a;
            lit_imm = aimm;
        } else {
            if (_cmp_is_vgpr(m, isvgpr, a, aimm) == 0) { return 0 - CMP_ERR_NO_VGPR_OPERAND; }
            vsrc1 = gfx9_reg(alloc, a);
            src0 = _cmp_resolve(m, alloc, isvgpr, b, bimm);
            lit_field = b;
            lit_imm = bimm;
        }
    }
    if (src0 < 0) { return src0; }
    var p = gfx9_emit32(buf, pos, gfx9_enc_vop2(opc, gfx9_reg(alloc, gisel_dst(isel, i)), src0, vsrc1));
    if (src0 == GFX9_SRC_LITERAL) { return gfx9_emit32(buf, p, _cmp_lit(m, lit_field, lit_imm)); }
    return p;
}

# VOP2 SUBTRACTION (NON-commutative): result = a (minuend) - b (subtrahend).
# GFX9 v_sub computes src0 - vsrc1; v_subrev computes vsrc1 - src0; vsrc1 must be
# a VGPR. So: if b is a VGPR, emit v_sub with src0 = a, vsrc1 = b (a - b). Else
# (b is a constant/SGPR) a MUST be the VGPR, so emit v_subrev with vsrc1 = a,
# src0 = b (still a - b). The commutative path would silently negate the
# minuend-is-VGPR / subtrahend-is-const case (N.5a review).
fn _emit_vop2_sub(m, isel, i, alloc, isvgpr, buf, pos, sub_opc, subrev_opc): i64 {
    var fl = gisel_flags(isel, i);
    var a = gisel_a(isel, i);
    var b = gisel_b(isel, i);
    var aimm = fl & MIR_FLAG_A_IMM;
    var bimm = fl & MIR_FLAG_B_IMM;
    var opc = 0;
    var src0 = 0;
    var vsrc1 = 0;
    var lit_field = 0;
    var lit_imm = 0;
    if (_cmp_is_vgpr(m, isvgpr, b, bimm) != 0) {
        opc = sub_opc;
        vsrc1 = gfx9_reg(alloc, b);
        src0 = _cmp_resolve(m, alloc, isvgpr, a, aimm);
        lit_field = a;
        lit_imm = aimm;
    } else {
        if (_cmp_is_vgpr(m, isvgpr, a, aimm) == 0) { return 0 - CMP_ERR_NO_VGPR_OPERAND; }
        opc = subrev_opc;
        vsrc1 = gfx9_reg(alloc, a);
        src0 = _cmp_resolve(m, alloc, isvgpr, b, bimm);
        lit_field = b;
        lit_imm = bimm;
    }
    if (src0 < 0) { return src0; }
    var p = gfx9_emit32(buf, pos, gfx9_enc_vop2(opc, gfx9_reg(alloc, gisel_dst(isel, i)), src0, vsrc1));
    if (src0 == GFX9_SRC_LITERAL) { return gfx9_emit32(buf, p, _cmp_lit(m, lit_field, lit_imm)); }
    return p;
}

# VOP3 two-source (v_mul_lo_u32: VOP3-only on GFX9). vdst = a OP b. VOP3 has no
# 32-bit-literal form, so a literal operand fails loud (an out-of-inline-range
# constant must be materialized into a register — not needed for the MVP strides).
fn _emit_vop3_2src(m, isel, i, alloc, isvgpr, buf, pos, opc, scratch_vgpr): i64 {
    var fl = gisel_flags(isel, i);
    var src0 = _cmp_resolve(m, alloc, isvgpr, gisel_a(isel, i), fl & MIR_FLAG_A_IMM);
    if (src0 < 0) { return src0; }
    var src1 = _cmp_resolve(m, alloc, isvgpr, gisel_b(isel, i), fl & MIR_FLAG_B_IMM);
    if (src1 < 0) { return src1; }
    var p = pos;
    # VOP3a has no literal form, so a non-inline constant operand is first materialized
    # into the scratch VGPR (the first free VGPR) via v_mov_b32. At most one operand is a
    # literal (the other is a VGPR/inline); two literals are const-foldable (N.8+).
    if (src0 == GFX9_SRC_LITERAL) {
        if (src1 == GFX9_SRC_LITERAL) { return 0 - CMP_ERR_VOP3_LITERAL; }
        if (scratch_vgpr >= GFX9_VGPR_CAP) { return 0 - CMP_ERR_VOP3_LITERAL; }
        p = gfx9_emit32(buf, p, gfx9_enc_vop1(GFX9_VOP1_V_MOV_B32, scratch_vgpr, GFX9_SRC_LITERAL));
        p = gfx9_emit32(buf, p, _cmp_lit(m, gisel_a(isel, i), fl & MIR_FLAG_A_IMM));
        src0 = gfx9_vgpr(scratch_vgpr);
    } else {
        if (src1 == GFX9_SRC_LITERAL) {
            if (scratch_vgpr >= GFX9_VGPR_CAP) { return 0 - CMP_ERR_VOP3_LITERAL; }
            p = gfx9_emit32(buf, p, gfx9_enc_vop1(GFX9_VOP1_V_MOV_B32, scratch_vgpr, GFX9_SRC_LITERAL));
            p = gfx9_emit32(buf, p, _cmp_lit(m, gisel_b(isel, i), fl & MIR_FLAG_B_IMM));
            src1 = gfx9_vgpr(scratch_vgpr);
        }
    }
    p = gfx9_emit32(buf, p, gfx9_enc_vop3a_lo(opc, gfx9_reg(alloc, gisel_dst(isel, i))));
    return gfx9_emit32(buf, p, gfx9_enc_vop3a_hi(src0, src1, 0));
}

# VOP3a 3-source (e.g. v_fma_f32). All three operands resolve to VGPR/SGPR/inline; VOP3
# has no literal form, so a non-inline constant operand fails loud (3-src materialization
# is N.8b+). Most FMA operands are computed VGPRs, so this is rarely hit.
fn _emit_vop3_3src(m, isel, i, alloc, isvgpr, buf, pos, opc): i64 {
    var fl = gisel_flags(isel, i);
    var src0 = _cmp_resolve(m, alloc, isvgpr, gisel_a(isel, i), fl & MIR_FLAG_A_IMM);
    if (src0 < 0) { return src0; }
    var src1 = _cmp_resolve(m, alloc, isvgpr, gisel_b(isel, i), fl & MIR_FLAG_B_IMM);
    if (src1 < 0) { return src1; }
    var src2 = _cmp_resolve(m, alloc, isvgpr, gisel_c(isel, i), fl & MIR_FLAG_C_IMM);
    if (src2 < 0) { return src2; }
    if (src0 == GFX9_SRC_LITERAL) { return 0 - CMP_ERR_VOP3_LITERAL; }
    if (src1 == GFX9_SRC_LITERAL) { return 0 - CMP_ERR_VOP3_LITERAL; }
    if (src2 == GFX9_SRC_LITERAL) { return 0 - CMP_ERR_VOP3_LITERAL; }
    var p = gfx9_emit32(buf, pos, gfx9_enc_vop3a_lo(opc, gfx9_reg(alloc, gisel_dst(isel, i))));
    return gfx9_emit32(buf, p, gfx9_enc_vop3a_hi(src0, src1, src2));
}

# v3.2 F.7f.3 — f64 SUB: a - b = v_add_f64(a, -b). GFX9 has no V_SUB_F64; the NEGATE-src1 source
# modifier is hi bit 30 (NEG[1]). Operands are f64 register pairs (f64 inline consts are a later
# bite; a literal is unencodable in VOP3 → fail loud).
fn _emit_fsub_f64(m, isel, i, alloc, isvgpr, buf, pos): i64 {
    var fl = gisel_flags(isel, i);
    var src0 = _cmp_resolve(m, alloc, isvgpr, gisel_a(isel, i), fl & MIR_FLAG_A_IMM);
    if (src0 < 0) { return src0; }
    var src1 = _cmp_resolve(m, alloc, isvgpr, gisel_b(isel, i), fl & MIR_FLAG_B_IMM);
    if (src1 < 0) { return src1; }
    if (src0 == GFX9_SRC_LITERAL) { return 0 - CMP_ERR_VOP3_LITERAL; }
    if (src1 == GFX9_SRC_LITERAL) { return 0 - CMP_ERR_VOP3_LITERAL; }
    var p = gfx9_emit32(buf, pos, gfx9_enc_vop3a_lo(GFX9_VOP3_V_ADD_F64, gfx9_reg(alloc, gisel_dst(isel, i))));
    return gfx9_emit32(buf, p, gfx9_enc_vop3a_hi(src0, src1, 0) | 0x40000000);
}

# v3.2 F.7f.3 — f64 ABS: |x| = v_max_f64(|x|, |x|). GFX9 has no V_ABS_F64; the ABS-src0/src1 source
# modifiers are lo bits 8,9 (ABS[0], ABS[1]). x is the single operand, fed as both srcs.
fn _emit_fabs_f64(m, isel, i, alloc, isvgpr, buf, pos): i64 {
    var fl = gisel_flags(isel, i);
    var x = _cmp_resolve(m, alloc, isvgpr, gisel_a(isel, i), fl & MIR_FLAG_A_IMM);
    if (x < 0) { return x; }
    if (x == GFX9_SRC_LITERAL) { return 0 - CMP_ERR_VOP3_LITERAL; }
    var p = gfx9_emit32(buf, pos, gfx9_enc_vop3a_lo(GFX9_VOP3_V_MAX_F64, gfx9_reg(alloc, gisel_dst(isel, i))) | 0x300);
    return gfx9_emit32(buf, p, gfx9_enc_vop3a_hi(x, x, 0));
}

# v3.2 F.7f.6b — f64 div_scale: VOP3B writing the per-lane scale flag to VCC (consumed by the
# later div_fmas). 3 VGPR-pair operands; the scaled value → vdst. (The two scale operands are
# the operand being scaled + the other; the macro in spirv_lower wires D,D,N / N,D,N.)
fn _emit_div_scale_f64(m, isel, i, alloc, isvgpr, buf, pos): i64 {
    var fl = gisel_flags(isel, i);
    var src0 = _cmp_resolve(m, alloc, isvgpr, gisel_a(isel, i), fl & MIR_FLAG_A_IMM);
    if (src0 < 0) { return src0; }
    var src1 = _cmp_resolve(m, alloc, isvgpr, gisel_b(isel, i), fl & MIR_FLAG_B_IMM);
    if (src1 < 0) { return src1; }
    var src2 = _cmp_resolve(m, alloc, isvgpr, gisel_c(isel, i), fl & MIR_FLAG_C_IMM);
    if (src2 < 0) { return src2; }
    if (src0 == GFX9_SRC_LITERAL) { return 0 - CMP_ERR_VOP3_LITERAL; }
    if (src1 == GFX9_SRC_LITERAL) { return 0 - CMP_ERR_VOP3_LITERAL; }
    if (src2 == GFX9_SRC_LITERAL) { return 0 - CMP_ERR_VOP3_LITERAL; }
    var vdst = gfx9_reg(alloc, gisel_dst(isel, i));
    var p = gfx9_emit32(buf, pos, gfx9_enc_vop3b_lo(GFX9_VOP3_V_DIV_SCALE_F64, GFX9_REG_VCC_LO, vdst));
    return gfx9_emit32(buf, p, gfx9_enc_vop3a_hi(src0, src1, src2));
}

# v3.2 F.7f.6b — f64 fma(-a, b, c): the Newton residual/correction FMAs with a NEGATE-src0
# source modifier (hi bit 29 = 0x20000000). All three operands are computed VGPR pairs.
fn _emit_fma_n0_f64(m, isel, i, alloc, isvgpr, buf, pos): i64 {
    var fl = gisel_flags(isel, i);
    var src0 = _cmp_resolve(m, alloc, isvgpr, gisel_a(isel, i), fl & MIR_FLAG_A_IMM);
    if (src0 < 0) { return src0; }
    var src1 = _cmp_resolve(m, alloc, isvgpr, gisel_b(isel, i), fl & MIR_FLAG_B_IMM);
    if (src1 < 0) { return src1; }
    var src2 = _cmp_resolve(m, alloc, isvgpr, gisel_c(isel, i), fl & MIR_FLAG_C_IMM);
    if (src2 < 0) { return src2; }
    if (src0 == GFX9_SRC_LITERAL) { return 0 - CMP_ERR_VOP3_LITERAL; }
    if (src1 == GFX9_SRC_LITERAL) { return 0 - CMP_ERR_VOP3_LITERAL; }
    if (src2 == GFX9_SRC_LITERAL) { return 0 - CMP_ERR_VOP3_LITERAL; }
    var p = gfx9_emit32(buf, pos, gfx9_enc_vop3a_lo(GFX9_VOP3_V_FMA_F64, gfx9_reg(alloc, gisel_dst(isel, i))));
    return gfx9_emit32(buf, p, gfx9_enc_vop3a_hi(src0, src1, src2) | 0x20000000);
}

# v3.2 F.7f.6b — f64 fma(-a, b, 1.0): the Newton refinement step. NEGATE src0 (0x20000000) +
# the inline-1.0 constant in src2 (GFX9_INLINE_F32_1_0 = 242; the same code denotes f64 1.0).
fn _emit_fma_n0_one_f64(m, isel, i, alloc, isvgpr, buf, pos): i64 {
    var fl = gisel_flags(isel, i);
    var src0 = _cmp_resolve(m, alloc, isvgpr, gisel_a(isel, i), fl & MIR_FLAG_A_IMM);
    if (src0 < 0) { return src0; }
    var src1 = _cmp_resolve(m, alloc, isvgpr, gisel_b(isel, i), fl & MIR_FLAG_B_IMM);
    if (src1 < 0) { return src1; }
    if (src0 == GFX9_SRC_LITERAL) { return 0 - CMP_ERR_VOP3_LITERAL; }
    if (src1 == GFX9_SRC_LITERAL) { return 0 - CMP_ERR_VOP3_LITERAL; }
    var p = gfx9_emit32(buf, pos, gfx9_enc_vop3a_lo(GFX9_VOP3_V_FMA_F64, gfx9_reg(alloc, gisel_dst(isel, i))));
    return gfx9_emit32(buf, p, gfx9_enc_vop3a_hi(src0, src1, GFX9_INLINE_F32_1_0) | 0x20000000);
}

# v3.2 F.7f.7b — f64 fma(-a, b, 0.5): the FSqrt Newton-Goldschmidt residual r = 0.5 - g*h. NEGATE
# src0 + the inline-0.5 src2 (GFX9_INLINE_F32_0_5 = 240; the same code denotes f64 0.5).
fn _emit_fma_n0_half_f64(m, isel, i, alloc, isvgpr, buf, pos): i64 {
    var fl = gisel_flags(isel, i);
    var src0 = _cmp_resolve(m, alloc, isvgpr, gisel_a(isel, i), fl & MIR_FLAG_A_IMM);
    if (src0 < 0) { return src0; }
    var src1 = _cmp_resolve(m, alloc, isvgpr, gisel_b(isel, i), fl & MIR_FLAG_B_IMM);
    if (src1 < 0) { return src1; }
    if (src0 == GFX9_SRC_LITERAL) { return 0 - CMP_ERR_VOP3_LITERAL; }
    if (src1 == GFX9_SRC_LITERAL) { return 0 - CMP_ERR_VOP3_LITERAL; }
    var p = gfx9_emit32(buf, pos, gfx9_enc_vop3a_lo(GFX9_VOP3_V_FMA_F64, gfx9_reg(alloc, gisel_dst(isel, i))));
    return gfx9_emit32(buf, p, gfx9_enc_vop3a_hi(src0, src1, GFX9_INLINE_F32_0_5) | 0x20000000);
}

# v3.2 F.7f.7b — f64 mul(a, 0.5): g = 0.5 * rsq. The inline-0.5 rides in src1 (a 2-src VOP3).
fn _emit_mul_half_f64(m, isel, i, alloc, isvgpr, buf, pos): i64 {
    var fl = gisel_flags(isel, i);
    var src0 = _cmp_resolve(m, alloc, isvgpr, gisel_a(isel, i), fl & MIR_FLAG_A_IMM);
    if (src0 < 0) { return src0; }
    if (src0 == GFX9_SRC_LITERAL) { return 0 - CMP_ERR_VOP3_LITERAL; }
    var p = gfx9_emit32(buf, pos, gfx9_enc_vop3a_lo(GFX9_VOP3_V_MUL_F64, gfx9_reg(alloc, gisel_dst(isel, i))));
    return gfx9_emit32(buf, p, gfx9_enc_vop3a_hi(src0, GFX9_INLINE_F32_0_5, 0));
}

# v3.2 F.7f.7b/7c — f64 VOPC compare → the implicit VCC (no register dst). src0 is the f64 pair
# (resolved 9-bit operand), vsrc1 a VGPR (the f64 pair's low reg for CMP_GT, or the i32 class mask
# for CMP_CLASS). The FSqrt subnormal gate (CMP_GT) + special-case gate (CMP_CLASS) share this.
fn _emit_vopc_f64(m, isel, i, alloc, isvgpr, buf, pos, opc): i64 {
    var fl = gisel_flags(isel, i);
    var src0 = _cmp_resolve(m, alloc, isvgpr, gisel_a(isel, i), fl & MIR_FLAG_A_IMM);
    if (src0 < 0) { return src0; }
    var vsrc1 = _cmp_vgpr_operand(m, alloc, isvgpr, gisel_b(isel, i));
    if (vsrc1 < 0) { return vsrc1; }
    return gfx9_emit32(buf, pos, gfx9_enc_vopc(opc, src0, vsrc1));
}

# v3.2 F.7f.7c — materialize an f64 constant into a VGPR pair via two v_mov_b32 literals. The value
# arrives as TWO 32-bit immediates — gisel_a = low dword, gisel_b = high dword — NOT one 64-bit imm:
# the MIR instr record packs a/b into 32-bit halves (mir_instr_a masks &0xFFFFFFFF), so a single
# 64-bit immediate would be truncated (the F.7f.7c review CRITICAL). Both are MIR_FLAG_*_IMM so
# waitcnt/regalloc don't treat them as value ids. The F.7f.9 primitive (sqrt threshold, coeffs).
fn _emit_f64_const(m, isel, i, alloc, isvgpr, buf, pos): i64 {
    var lo = gisel_a(isel, i);
    var hi = gisel_b(isel, i);
    var dst = gfx9_reg(alloc, gisel_dst(isel, i));
    var p = gfx9_emit32(buf, pos, gfx9_enc_vop1(GFX9_VOP1_V_MOV_B32, dst, GFX9_SRC_LITERAL));
    p = gfx9_emit32(buf, p, lo & 0xFFFFFFFF);
    p = gfx9_emit32(buf, p, gfx9_enc_vop1(GFX9_VOP1_V_MOV_B32, dst + 1, GFX9_SRC_LITERAL));
    return gfx9_emit32(buf, p, hi & 0xFFFFFFFF);
}

# v3.2 F.7f.7b — f64-pair cndmask: dst = VCC ? b(true) : a(false), realized as TWO v_cndmask_b32
# (the lo and hi 32-bit halves of each pair). VCC is implicit; both value operands are VGPR pairs.
fn _emit_cndmask_f64(m, isel, i, alloc, isvgpr, buf, pos): i64 {
    var fa = _cmp_vgpr_operand(m, alloc, isvgpr, gisel_a(isel, i));
    if (fa < 0) { return fa; }
    var tb = _cmp_vgpr_operand(m, alloc, isvgpr, gisel_b(isel, i));
    if (tb < 0) { return tb; }
    var dst = gfx9_reg(alloc, gisel_dst(isel, i));
    var p = gfx9_emit32(buf, pos, gfx9_enc_vop2(GFX9_VOP2_V_CNDMASK_B32, dst, gfx9_vgpr(fa), tb));
    return gfx9_emit32(buf, p, gfx9_enc_vop2(GFX9_VOP2_V_CNDMASK_B32, dst + 1, gfx9_vgpr(fa + 1), tb + 1));
}

# v3.2 F.7f.8 — OpSelect blend via v_bfi_b32 (d = (mask & x) | (~mask & y) = mask ? x : y). The cond
# MASK (0/-1) is src0, the true/false values src1/src2. One bfi for i32/f32; two (lo+hi, same mask)
# for an f64 pair. No VCC — order-independent (the mask is a normal VGPR value).
fn _emit_select(m, isel, i, alloc, isvgpr, buf, pos): i64 {
    var fl = gisel_flags(isel, i);
    var mask = _cmp_resolve(m, alloc, isvgpr, gisel_a(isel, i), fl & MIR_FLAG_A_IMM);  if (mask < 0) { return mask; }
    var x = _cmp_resolve(m, alloc, isvgpr, gisel_b(isel, i), fl & MIR_FLAG_B_IMM);      if (x < 0) { return x; }
    var y = _cmp_resolve(m, alloc, isvgpr, gisel_c(isel, i), fl & MIR_FLAG_C_IMM);      if (y < 0) { return y; }
    if (mask == GFX9_SRC_LITERAL) { return 0 - CMP_ERR_VOP3_LITERAL; }
    if (x == GFX9_SRC_LITERAL) { return 0 - CMP_ERR_VOP3_LITERAL; }
    if (y == GFX9_SRC_LITERAL) { return 0 - CMP_ERR_VOP3_LITERAL; }
    var dst = gfx9_reg(alloc, gisel_dst(isel, i));
    var p = gfx9_emit32(buf, pos, gfx9_enc_vop3a_lo(GFX9_VOP3_V_BFI_B32, dst));
    p = gfx9_emit32(buf, p, gfx9_enc_vop3a_hi(mask, x, y));
    if (mir_type_base(mir_val_type(m, gisel_dst(isel, i))) == MIR_T_F64) {
        p = gfx9_emit32(buf, p, gfx9_enc_vop3a_lo(GFX9_VOP3_V_BFI_B32, dst + 1));
        return gfx9_emit32(buf, p, gfx9_enc_vop3a_hi(mask, x + 1, y + 1));
    }
    return p;
}

# 1 if an operand resolves to a non-inline 32-bit literal (the VOP3-materialization case).
fn _cmp_operand_is_literal(m, field, is_imm): i64 {
    if (is_imm != 0) {
        if (gfx9_inline_int(field) == GFX9_SRC_LITERAL) { return 1; }
        return 0;
    }
    if (field == 0) { return 0; }
    if (mir_val_kind(m, field) != MIR_VK_CONST) { return 0; }
    if (gfx9_inline_int(mir_val_payload(m, field)) == GFX9_SRC_LITERAL) { return 1; }
    return 0;
}

# 1 if a global-store value operand is a constant — FLAT store data must be a VGPR, so
# the constant is materialized into the scratch VGPR (any const, inline or literal).
fn _cmp_store_value_is_const(m, field, fl): i64 {
    if ((fl & MIR_FLAG_C_IMM) != 0) { return 1; }
    if (field == 0) { return 0; }
    if (mir_val_kind(m, field) == MIR_VK_CONST) { return 1; }
    return 0;
}

# 1 if the program needs the materialization scratch VGPR: a VOP3a op with a literal
# operand, OR a global store of a constant value. The driver then bumps the rsrc1 VGPR
# count to cover the scratch.
fn _cmp_needs_scratch(m, isel, ni): i64 {
    var i = 0;
    while (i < ni) {
        var op = gisel_op(isel, i);
        if (op == GISEL_V_MUL_LO_U32) {
            var fl = gisel_flags(isel, i);
            if (_cmp_operand_is_literal(m, gisel_a(isel, i), fl & MIR_FLAG_A_IMM) == 1) { return 1; }
            if (_cmp_operand_is_literal(m, gisel_b(isel, i), fl & MIR_FLAG_B_IMM) == 1) { return 1; }
        }
        if (op == GISEL_GLOBAL_STORE) {
            if (_cmp_store_value_is_const(m, gisel_c(isel, i), gisel_flags(isel, i)) == 1) { return 1; }
        }
        i = i + 1;
    }
    return 0;
}

# A FLAT address/data operand must be an SSA value living in a VGPR (a per-lane
# offset or store value). Returns the raw VGPR index, or fails loud: id-0 is the
# const-offset access chain (off_id 0 — the FLAT immediate-offset form is a later
# bite); a non-SSA / SGPR-file value is a uniform operand that would need a
# SGPR→VGPR materialization (also later) — NOT silently emitted as a VGPR index.
# (N.5b-2 review: the FLAT emitters used to read gfx9_reg(alloc, field) raw, so an
# id-0 const offset became v255 and a uniform offset read an unrelated VGPR.)
fn _cmp_vgpr_operand(m, alloc, isvgpr, field): i64 {
    if (field == 0) { return 0 - CMP_ERR_FLAT_CONST_OFFSET; }
    if (mir_val_kind(m, field) != MIR_VK_SSA) { return 0 - CMP_ERR_FLAT_NONVGPR; }
    if (load64(isvgpr + field * 8) == 0) { return 0 - CMP_ERR_FLAT_NONVGPR; }
    return gfx9_reg(alloc, field);
}

# The binding (flags bits 8+) must index a buffer actually loaded into USER_DATA.
fn _cmp_flat_saddr(abi, isel, i): i64 {
    var binding = (gisel_flags(isel, i) >> 8) & 0xFF;
    if (binding >= gfx9_abi_num_bindings(abi)) { return 0 - CMP_ERR_BINDING_RANGE; }
    return gfx9_abi_binding_sgpr(abi, binding);
}

# FLAT global load (SADDR form): the 64-bit base lives in the binding's USER_DATA
# SGPR pair (saddr), the per-lane byte offset in a VGPR (vaddr). dst = the loaded
# VGPR. a = offset vreg, binding in flags bits 8+. No SGPR→VGPR move or 64-bit add
# needed — the divergent offset rides the vaddr field.
fn _emit_flat_load(m, isel, i, alloc, abi, isvgpr, buf, pos, load_opc): i64 {
    var saddr = _cmp_flat_saddr(abi, isel, i);
    if (saddr < 0) { return saddr; }
    var vaddr = _cmp_vgpr_operand(m, alloc, isvgpr, gisel_a(isel, i));
    if (vaddr < 0) { return vaddr; }
    var vdst = gfx9_reg(alloc, gisel_dst(isel, i));
    var p = gfx9_emit32(buf, pos, gfx9_enc_flat_lo(load_opc, GFX9_FLAT_SEG_GLOBAL, 0, 0, 0));
    return gfx9_emit32(buf, p, gfx9_enc_flat_hi(vdst, saddr, 0, vaddr));
}

# FLAT global store (SADDR form): a = offset vreg, c = value vreg, binding in
# flags bits 8+. saddr = binding base pair, data = value VGPR, vaddr = offset.
fn _emit_flat_store(m, isel, i, alloc, abi, isvgpr, buf, pos, scratch_vgpr, store_opc): i64 {
    var saddr = _cmp_flat_saddr(abi, isel, i);
    if (saddr < 0) { return saddr; }
    var vaddr = _cmp_vgpr_operand(m, alloc, isvgpr, gisel_a(isel, i));
    if (vaddr < 0) { return vaddr; }
    var cfield = gisel_c(isel, i);
    var fl = gisel_flags(isel, i);
    var p = pos;
    var data = 0;
    # FLAT store data must be a VGPR; a constant value is first materialized into the
    # scratch VGPR with v_mov_b32 (inline or trailing-literal source).
    if (_cmp_store_value_is_const(m, cfield, fl) == 1) {
        if (scratch_vgpr >= GFX9_VGPR_CAP) { return 0 - CMP_ERR_FLAT_NONVGPR; }
        var v = _cmp_resolve(m, alloc, isvgpr, cfield, fl & MIR_FLAG_C_IMM);
        if (v < 0) { return v; }
        p = gfx9_emit32(buf, p, gfx9_enc_vop1(GFX9_VOP1_V_MOV_B32, scratch_vgpr, v));
        if (v == GFX9_SRC_LITERAL) { p = gfx9_emit32(buf, p, _cmp_lit(m, cfield, fl & MIR_FLAG_C_IMM)); }
        data = scratch_vgpr;
    } else {
        data = _cmp_vgpr_operand(m, alloc, isvgpr, cfield);
        if (data < 0) { return data; }
    }
    p = gfx9_emit32(buf, p, gfx9_enc_flat_lo(store_opc, GFX9_FLAT_SEG_GLOBAL, 0, 0, 0));
    return gfx9_emit32(buf, p, gfx9_enc_flat_hi(0, saddr, data, vaddr));
}

# GISEL_EXTRACT of a builtin component → the builtin's ABI register, moved into the
# allocated result register. a = the builtin value, c = the component index. MVP:
# LocalInvocationId.comp lives in v[comp] → v_mov into the result VGPR. WorkgroupId
# / GlobalInvocationId need the uniform-SGPR / wgid*size+lid expansion (N.5c-2) and
# fail loud here.
fn _emit_extract(m, isel, i, alloc, abi, buf, pos): i64 {
    var bid = gisel_a(isel, i);
    if (mir_val_kind(m, bid) != MIR_VK_BUILTIN) { return 0 - CMP_ERR_UNSUPPORTED_OPERAND; }
    var bi = mir_val_payload(m, bid);
    var comp = gisel_c(isel, i);
    var dst = gfx9_reg(alloc, gisel_dst(isel, i));
    # LocalInvocationId.comp = v[comp] (divergent → the result is a VGPR): v_mov.
    if (bi == MIR_BI_LOCAL_INVOC_ID) {
        var lsrc = gfx9_vgpr(gfx9_abi_builtin_reg(abi, MIR_BI_LOCAL_INVOC_ID, comp));
        return gfx9_emit32(buf, pos, gfx9_enc_vop1(GFX9_VOP1_V_MOV_B32, dst, lsrc));
    }
    # WorkgroupId.comp = the TGID SGPR s[user_sgpr+comp] (uniform → the result is an
    # SGPR, via the EXTRACT file-class rule): s_mov. (GlobalInvocationId is never a
    # GISEL_EXTRACT operand — the lowering expands it to wgid*size+lid.)
    if (bi == MIR_BI_WORKGROUP_ID) {
        var ssrc = gfx9_abi_builtin_reg(abi, MIR_BI_WORKGROUP_ID, comp);
        return gfx9_emit32(buf, pos, gfx9_enc_sop1(GFX9_SOP1_S_MOV_B32, dst, ssrc));
    }
    return 0 - CMP_ERR_UNSUPPORTED_BUILTIN;
}

# GISEL_S_CMP → SOPC scalar compare (sets SCC for the following s_cbranch). The SOPC
# opcode rides in flags bits 8+. Operands resolve like SOP2: SGPR / inline / literal;
# a VGPR operand is illegal (a divergent compare was rejected in isel → N.7c).
fn _emit_sopc(m, isel, i, alloc, isvgpr, buf, pos): i64 {
    var fl = gisel_flags(isel, i);
    var sopc_op = fl >> 8;
    var a = gisel_a(isel, i);
    var b = gisel_b(isel, i);
    var ssrc0 = _cmp_resolve(m, alloc, isvgpr, a, fl & MIR_FLAG_A_IMM);
    if (ssrc0 < 0) { return ssrc0; }
    var ssrc1 = _cmp_resolve(m, alloc, isvgpr, b, fl & MIR_FLAG_B_IMM);
    if (ssrc1 < 0) { return ssrc1; }
    if (ssrc0 >= 256) { return 0 - CMP_ERR_BAD_SALU_OPERAND; }
    if (ssrc1 >= 256) { return 0 - CMP_ERR_BAD_SALU_OPERAND; }
    if (ssrc0 == GFX9_SRC_LITERAL) { if (ssrc1 == GFX9_SRC_LITERAL) { return 0 - CMP_ERR_TWO_LITERALS; } }
    var p = gfx9_emit32(buf, pos, gfx9_enc_sopc(sopc_op, ssrc0, ssrc1));
    if (ssrc0 == GFX9_SRC_LITERAL) { return gfx9_emit32(buf, p, _cmp_lit(m, a, fl & MIR_FLAG_A_IMM)); }
    if (ssrc1 == GFX9_SRC_LITERAL) { return gfx9_emit32(buf, p, _cmp_lit(m, b, fl & MIR_FLAG_B_IMM)); }
    return p;
}

# GISEL_V_CMP → VOPC vector compare (sets VCC for the EXEC-mask sequence). The VOPC
# opcode rides in flags bits 8+. a = src0 (the full 9-bit operand: VGPR / inline /
# literal), b = vsrc1 (a VGPR — isel guaranteed it by flipping a constant to src0).
fn _emit_vopc(m, isel, i, alloc, isvgpr, buf, pos): i64 {
    var fl = gisel_flags(isel, i);
    var vop = fl >> 8;
    var a = gisel_a(isel, i);
    var b = gisel_b(isel, i);
    var src0 = _cmp_resolve(m, alloc, isvgpr, a, fl & MIR_FLAG_A_IMM);
    if (src0 < 0) { return src0; }
    var vsrc1 = _cmp_vgpr_operand(m, alloc, isvgpr, b);
    if (vsrc1 < 0) { return vsrc1; }
    var p = gfx9_emit32(buf, pos, gfx9_enc_vopc(vop, src0, vsrc1));
    if (src0 == GFX9_SRC_LITERAL) { return gfx9_emit32(buf, p, _cmp_lit(m, a, fl & MIR_FLAG_A_IMM)); }
    return p;
}

# ================================================================
# Op dispatch — one GISEL record -> its encoder(s).
# ================================================================
fn _cmp_emit_one(m, isel, i, alloc, abi, isvgpr, buf, pos, scratch_vgpr): i64 {
    var op = gisel_op(isel, i);
    if (op == GISEL_S_ADD_I32) { return _emit_sop2(m, isel, i, alloc, isvgpr, buf, pos, GFX9_SOP2_S_ADD_I32); }
    if (op == GISEL_S_SUB_I32) { return _emit_sop2(m, isel, i, alloc, isvgpr, buf, pos, GFX9_SOP2_S_SUB_I32); }
    if (op == GISEL_S_MUL_I32) { return _emit_sop2(m, isel, i, alloc, isvgpr, buf, pos, GFX9_SOP2_S_MUL_I32); }
    if (op == GISEL_S_LSHL_B32) { return _emit_sop2(m, isel, i, alloc, isvgpr, buf, pos, GFX9_SOP2_S_LSHL_B32); }
    if (op == GISEL_S_LSHR_B32) { return _emit_sop2(m, isel, i, alloc, isvgpr, buf, pos, GFX9_SOP2_S_LSHR_B32); }
    if (op == GISEL_S_ASHR_I32) { return _emit_sop2(m, isel, i, alloc, isvgpr, buf, pos, GFX9_SOP2_S_ASHR_I32); }
    if (op == GISEL_S_AND_B32) { return _emit_sop2(m, isel, i, alloc, isvgpr, buf, pos, GFX9_SOP2_S_AND_B32); }
    if (op == GISEL_S_OR_B32) { return _emit_sop2(m, isel, i, alloc, isvgpr, buf, pos, GFX9_SOP2_S_OR_B32); }
    if (op == GISEL_S_XOR_B32) { return _emit_sop2(m, isel, i, alloc, isvgpr, buf, pos, GFX9_SOP2_S_XOR_B32); }
    if (op == GISEL_V_ADD_U32) { return _emit_vop2(m, isel, i, alloc, isvgpr, buf, pos, GFX9_VOP2_V_ADD_U32, 0); }
    if (op == GISEL_V_SUB_U32) {
        return _emit_vop2_sub(m, isel, i, alloc, isvgpr, buf, pos, GFX9_VOP2_V_SUB_U32, GFX9_VOP2_V_SUBREV_U32);
    }
    if (op == GISEL_V_AND_B32) { return _emit_vop2(m, isel, i, alloc, isvgpr, buf, pos, GFX9_VOP2_V_AND_B32, 0); }
    if (op == GISEL_V_OR_B32) { return _emit_vop2(m, isel, i, alloc, isvgpr, buf, pos, GFX9_VOP2_V_OR_B32, 0); }
    if (op == GISEL_V_XOR_B32) { return _emit_vop2(m, isel, i, alloc, isvgpr, buf, pos, GFX9_VOP2_V_XOR_B32, 0); }
    if (op == GISEL_V_ADD_F32) { return _emit_vop2(m, isel, i, alloc, isvgpr, buf, pos, GFX9_VOP2_V_ADD_F32, 0); }
    if (op == GISEL_V_SUB_F32) {
        return _emit_vop2_sub(m, isel, i, alloc, isvgpr, buf, pos, GFX9_VOP2_V_SUB_F32, GFX9_VOP2_V_SUBREV_F32);
    }
    if (op == GISEL_V_MUL_F32) { return _emit_vop2(m, isel, i, alloc, isvgpr, buf, pos, GFX9_VOP2_V_MUL_F32, 0); }
    if (op == GISEL_V_MIN_F32) { return _emit_vop2(m, isel, i, alloc, isvgpr, buf, pos, GFX9_VOP2_V_MIN_F32, 0); }
    if (op == GISEL_V_MAX_F32) { return _emit_vop2(m, isel, i, alloc, isvgpr, buf, pos, GFX9_VOP2_V_MAX_F32, 0); }
    if (op == GISEL_V_SQRT_F32) { return _emit_vop1(m, isel, i, alloc, isvgpr, buf, pos, GFX9_VOP1_V_SQRT_F32); }
    if (op == GISEL_V_FLOOR_F32) { return _emit_vop1(m, isel, i, alloc, isvgpr, buf, pos, GFX9_VOP1_V_FLOOR_F32); }
    if (op == GISEL_V_FMA_F32) { return _emit_vop3_3src(m, isel, i, alloc, isvgpr, buf, pos, GFX9_VOP3_V_FMA_F32); }
    if (op == GISEL_V_MED3_F32) { return _emit_vop3_3src(m, isel, i, alloc, isvgpr, buf, pos, GFX9_VOP3_V_MED3_F32); }
    if (op == GISEL_V_ABS_F32) { return _emit_fabs(m, isel, i, alloc, isvgpr, buf, pos); }
    if (op == GISEL_V_LSHLREV_B32) {
        return _emit_vop2(m, isel, i, alloc, isvgpr, buf, pos, GFX9_VOP2_V_LSHLREV_B32, 1);
    }
    if (op == GISEL_V_LSHRREV_B32) {
        return _emit_vop2(m, isel, i, alloc, isvgpr, buf, pos, GFX9_VOP2_V_LSHRREV_B32, 1);
    }
    if (op == GISEL_V_ASHRREV_I32) {
        return _emit_vop2(m, isel, i, alloc, isvgpr, buf, pos, GFX9_VOP2_V_ASHRREV_I32, 1);
    }
    if (op == GISEL_V_CVT_F32_I32) { return _emit_vop1(m, isel, i, alloc, isvgpr, buf, pos, GFX9_VOP1_V_CVT_F32_I32); }
    if (op == GISEL_V_CVT_I32_F32) { return _emit_vop1(m, isel, i, alloc, isvgpr, buf, pos, GFX9_VOP1_V_CVT_I32_F32); }
    if (op == GISEL_V_MUL_LO_U32) {
        return _emit_vop3_2src(m, isel, i, alloc, isvgpr, buf, pos, GFX9_VOP3_V_MUL_LO_U32, scratch_vgpr);
    }
    # N.9 integer-division primitives. The unary forms reuse _emit_vop1; MUL_HI reuses the
    # VOP3 2-src emit (operands are always VGPRs in the macro); CNDMASK is dedicated.
    if (op == GISEL_V_MOV) { return _emit_vop1(m, isel, i, alloc, isvgpr, buf, pos, GFX9_VOP1_V_MOV_B32); }
    if (op == GISEL_V_CVT_F32_U32) { return _emit_vop1(m, isel, i, alloc, isvgpr, buf, pos, GFX9_VOP1_V_CVT_F32_U32); }
    if (op == GISEL_V_CVT_U32_F32) { return _emit_vop1(m, isel, i, alloc, isvgpr, buf, pos, GFX9_VOP1_V_CVT_U32_F32); }
    if (op == GISEL_V_RCP_IFLAG_F32) {
        return _emit_vop1(m, isel, i, alloc, isvgpr, buf, pos, GFX9_VOP1_V_RCP_IFLAG_F32);
    }
    if (op == GISEL_V_MUL_HI_U32) {
        return _emit_vop3_2src(m, isel, i, alloc, isvgpr, buf, pos, GFX9_VOP3_V_MUL_HI_U32, scratch_vgpr);
    }
    if (op == GISEL_V_CNDMASK) { return _emit_cndmask(m, isel, i, alloc, isvgpr, buf, pos); }
    if (op == GISEL_EXTRACT) { return _emit_extract(m, isel, i, alloc, abi, buf, pos); }
    if (op == GISEL_GLOBAL_LOAD) {
        return _emit_flat_load(m, isel, i, alloc, abi, isvgpr, buf, pos, GFX9_FLAT_GLOBAL_LOAD_DWORD);
    }
    if (op == GISEL_GLOBAL_STORE) {
        return _emit_flat_store(m, isel, i, alloc, abi, isvgpr, buf, pos, scratch_vgpr, GFX9_FLAT_GLOBAL_STORE_DWORD);
    }
    # v3.2 F.7d — f64: DWORDX2 global load/store + the V_*_F64 ALU (VOP3, reusing the scalar
    # emitters — regalloc gave the EVEN low reg of each pair, which the encoders name directly).
    if (op == GISEL_GLOBAL_LOAD_DWORDX2) {
        return _emit_flat_load(m, isel, i, alloc, abi, isvgpr, buf, pos, GFX9_FLAT_GLOBAL_LOAD_DWORDX2);
    }
    if (op == GISEL_GLOBAL_STORE_DWORDX2) {
        return _emit_flat_store(m, isel, i, alloc, abi, isvgpr, buf, pos, scratch_vgpr, GFX9_FLAT_GLOBAL_STORE_DWORDX2);
    }
    if (op == GISEL_V_ADD_F64) {
        return _emit_vop3_2src(m, isel, i, alloc, isvgpr, buf, pos, GFX9_VOP3_V_ADD_F64, scratch_vgpr);
    }
    if (op == GISEL_V_MUL_F64) {
        return _emit_vop3_2src(m, isel, i, alloc, isvgpr, buf, pos, GFX9_VOP3_V_MUL_F64, scratch_vgpr);
    }
    if (op == GISEL_V_MIN_F64) {
        return _emit_vop3_2src(m, isel, i, alloc, isvgpr, buf, pos, GFX9_VOP3_V_MIN_F64, scratch_vgpr);
    }
    if (op == GISEL_V_MAX_F64) {
        return _emit_vop3_2src(m, isel, i, alloc, isvgpr, buf, pos, GFX9_VOP3_V_MAX_F64, scratch_vgpr);
    }
    if (op == GISEL_V_FMA_F64) {
        return _emit_vop3_3src(m, isel, i, alloc, isvgpr, buf, pos, GFX9_VOP3_V_FMA_F64);
    }
    if (op == GISEL_V_CVT_F64_F32) {
        return _emit_vop1(m, isel, i, alloc, isvgpr, buf, pos, GFX9_VOP1_V_CVT_F64_F32);
    }
    if (op == GISEL_V_CVT_F32_F64) {
        return _emit_vop1(m, isel, i, alloc, isvgpr, buf, pos, GFX9_VOP1_V_CVT_F32_F64);
    }
    if (op == GISEL_V_SUB_F64) { return _emit_fsub_f64(m, isel, i, alloc, isvgpr, buf, pos); }
    if (op == GISEL_V_ABS_F64) { return _emit_fabs_f64(m, isel, i, alloc, isvgpr, buf, pos); }
    # F.7f.6b f64 division macro. RCP reuses _emit_vop1; DIV_FMAS/DIV_FIXUP reuse _emit_vop3_3src
    # (VCC is implicit for DIV_FMAS — no extra encoding); div_scale + the NEG-src0 FMAs are dedicated.
    if (op == GISEL_V_RCP_F64) { return _emit_vop1(m, isel, i, alloc, isvgpr, buf, pos, GFX9_VOP1_V_RCP_F64); }
    if (op == GISEL_V_DIV_SCALE_F64) { return _emit_div_scale_f64(m, isel, i, alloc, isvgpr, buf, pos); }
    if (op == GISEL_V_DIV_FMAS_F64) {
        return _emit_vop3_3src(m, isel, i, alloc, isvgpr, buf, pos, GFX9_VOP3_V_DIV_FMAS_F64);
    }
    if (op == GISEL_V_DIV_FIXUP_F64) {
        return _emit_vop3_3src(m, isel, i, alloc, isvgpr, buf, pos, GFX9_VOP3_V_DIV_FIXUP_F64);
    }
    if (op == GISEL_V_FMA_F64_N0) { return _emit_fma_n0_f64(m, isel, i, alloc, isvgpr, buf, pos); }
    if (op == GISEL_V_FMA_F64_N0_ONE) { return _emit_fma_n0_one_f64(m, isel, i, alloc, isvgpr, buf, pos); }
    # F.7f.7b f64 sqrt macro. RSQ reuses _emit_vop1; the rest are dedicated (the inline-0.5 FMA/MUL,
    # the VCC-writing cmp_class, the f64-pair cndmask).
    if (op == GISEL_V_RSQ_F64) { return _emit_vop1(m, isel, i, alloc, isvgpr, buf, pos, GFX9_VOP1_V_RSQ_F64); }
    if (op == GISEL_V_FMA_F64_N0_HALF) { return _emit_fma_n0_half_f64(m, isel, i, alloc, isvgpr, buf, pos); }
    if (op == GISEL_V_MUL_F64_HALF) { return _emit_mul_half_f64(m, isel, i, alloc, isvgpr, buf, pos); }
    if (op == GISEL_V_CMP_CLASS_F64) {
        return _emit_vopc_f64(m, isel, i, alloc, isvgpr, buf, pos, GFX9_VOPC_V_CMP_CLASS_F64);
    }
    if (op == GISEL_V_CNDMASK_F64) { return _emit_cndmask_f64(m, isel, i, alloc, isvgpr, buf, pos); }
    # F.7f.7c sqrt subnormal wrapper: f64-const materialize, ldexp scale (VOP3 2-src), the GT gate.
    if (op == GISEL_V_CONST_F64) { return _emit_f64_const(m, isel, i, alloc, isvgpr, buf, pos); }
    if (op == GISEL_V_LDEXP_F64) {
        return _emit_vop3_2src(m, isel, i, alloc, isvgpr, buf, pos, GFX9_VOP3_V_LDEXP_F64, scratch_vgpr);
    }
    if (op == GISEL_V_CMP_GT_F64) {
        return _emit_vopc_f64(m, isel, i, alloc, isvgpr, buf, pos, GFX9_VOPC_V_CMP_GT_F64);
    }
    # F.7f.10 i32<->f64 cvt (exp reduction): VOP1, reuse _emit_vop1 with the existing encoders.
    if (op == GISEL_V_CVT_I32_F64) { return _emit_vop1(m, isel, i, alloc, isvgpr, buf, pos, GFX9_VOP1_V_CVT_I32_F64); }
    if (op == GISEL_V_CVT_F64_I32) { return _emit_vop1(m, isel, i, alloc, isvgpr, buf, pos, GFX9_VOP1_V_CVT_F64_I32); }
    if (op == GISEL_S_WAITCNT) { return gfx9_emit32(buf, pos, gfx9_enc_sopp(GFX9_SOPP_S_WAITCNT, gisel_a(isel, i))); }
    if (op == GISEL_S_ENDPGM) { return gfx9_emit32(buf, pos, gfx9_enc_sopp(GFX9_SOPP_S_ENDPGM, 0)); }
    if (op == GISEL_S_CMP) { return _emit_sopc(m, isel, i, alloc, isvgpr, buf, pos); }
    if (op == GISEL_V_CMP) { return _emit_vopc(m, isel, i, alloc, isvgpr, buf, pos); }
    if (op == GISEL_V_SELECT) { return _emit_select(m, isel, i, alloc, isvgpr, buf, pos); }
    # Divergent-if EXEC mask: save+AND EXEC with VCC into the reserved pair; restore it.
    if (op == GISEL_S_SAVEEXEC) {
        return gfx9_emit32(buf, pos,
        gfx9_enc_sop1(GFX9_SOP1_S_AND_SAVEEXEC_B64, GFX9_EXEC_SAVE_SGPR, GFX9_REG_VCC_LO));
    }
    if (op == GISEL_S_OR_EXEC) {
        return gfx9_emit32(buf, pos,
        gfx9_enc_sop2(GFX9_SOP2_S_OR_B64, GFX9_REG_EXEC_LO, GFX9_REG_EXEC_LO, GFX9_EXEC_SAVE_SGPR));
    }
    # LABEL / S_BRANCH / S_CBRANCH are handled in gfx9_emit_program's layout loop (they
    # need the label-offset map + branch patch list), never here.
    return 0 - CMP_ERR_UNSUPPORTED_OP;
}

# ================================================================
# Driver
# ================================================================
# Encode the selected-instruction list `isel` (n_isel instrs) over the MIR `m`,
# the regalloc map `alloc`, and the ABI descriptor `abi` (for binding→SGPR on FLAT
# ops), writing the ISA byte stream into `buf` starting at `pos`. Returns the end
# byte position or a negative error. The caller appends gfx9_emit_prefetch_pad to
# the returned position.
fn gfx9_emit_program(m, isel, n_isel, alloc, abi, buf, pos): i64 {
    var cap_ids = load64(m + 64);
    if (cap_ids > RA_MAX_REGS) { return 0 - CMP_ERR_TOO_MANY_IDS; }
    var isvgpr[2048];   # per-id file-map: 1 = the value lives in a VGPR
    memset(&isvgpr, 0, cap_ids * 8);
    var i = 0;
    while (i < n_isel) {
        var d = gisel_dst(isel, i);
        if (d != 0) {
            if (mir_val_kind(m, d) == MIR_VK_SSA) {
                store64(&isvgpr + d * 8, gisel_result_is_vgpr(m, isel, i));
            }
        }
        i = i + 1;
    }
    # The scratch VGPR for VOP3-literal materialization is the first free one: the VGPR
    # high-water (ABI region + every allocated VGPR result). Matches gfx9_hw_vgpr(hw), so
    # the driver's rsrc1 VGPR bump and this stay in lock-step.
    var scratch_vgpr = gfx9_abi_vgpr_base(abi);
    i = 0;
    while (i < cap_ids) {
        if (load64(&isvgpr + i * 8) != 0) {
            var r = gfx9_reg(alloc, i);
            if (r + 1 > scratch_vgpr) { scratch_vgpr = r + 1; }
        }
        i = i + 1;
    }
    # N.7 control flow: a LABEL emits 0 bytes but records its byte offset; a branch
    # emits a placeholder simm16 and is patched after all labels are known (forward
    # branches resolve here). laboff is id-indexed (-1 = unseen); the patch list pairs
    # each branch's byte position with its target label.
    var laboff[2048];   # cap_ids (<= RA_MAX_REGS 256) i64
    memset(&laboff, 0xFF, cap_ids * 8);
    var patch_off[2048];
    var patch_tgt[2048];
    var npatch = 0;
    var p = pos;
    i = 0;
    while (i < n_isel) {
        var op = gisel_op(isel, i);
        if (op == GISEL_LABEL) {
            store64(&laboff + gisel_a(isel, i) * 8, p);
        } else {
            if (op == GISEL_S_BRANCH) {
                if (npatch >= 256) { return 0 - CMP_ERR_TOO_MANY_BRANCHES; }
                store64(&patch_off + npatch * 8, p);
                store64(&patch_tgt + npatch * 8, gisel_a(isel, i));
                npatch = npatch + 1;
                p = gfx9_emit32(buf, p, gfx9_enc_sopp(GFX9_SOPP_S_BRANCH, 0));
            } else {
                if (op == GISEL_S_CBRANCH) {
                    if (npatch >= 256) { return 0 - CMP_ERR_TOO_MANY_BRANCHES; }
                    store64(&patch_off + npatch * 8, p);
                    store64(&patch_tgt + npatch * 8, gisel_c(isel, i));
                    npatch = npatch + 1;
                    p = gfx9_emit32(buf, p, gfx9_enc_sopp(GFX9_SOPP_S_CBRANCH_SCC0, 0));
                } else {
                    if (op == GISEL_S_CBRANCH_EXECZ) {
                        if (npatch >= 256) { return 0 - CMP_ERR_TOO_MANY_BRANCHES; }
                        store64(&patch_off + npatch * 8, p);
                        store64(&patch_tgt + npatch * 8, gisel_c(isel, i));
                        npatch = npatch + 1;
                        p = gfx9_emit32(buf, p, gfx9_enc_sopp(GFX9_SOPP_S_CBRANCH_EXECZ, 0));
                    } else {
                        var rc = _cmp_emit_one(m, isel, i, alloc, abi, &isvgpr, buf, p, scratch_vgpr);
                        if (rc < 0) { return rc; }
                        p = rc;
                    }
                }
            }
        }
        i = i + 1;
    }
    # Patch each branch: SOPP simm16 = (target - (branch + 4)) / 4 dwords (signed,
    # PC-relative to the instruction after the branch).
    var j = 0;
    while (j < npatch) {
        var boff = load64(&patch_off + j * 8);
        var toff = load64(&laboff + load64(&patch_tgt + j * 8) * 8);
        if (toff < 0) { return 0 - CMP_ERR_UNRESOLVED_LABEL; }
        var simm = (toff - (boff + 4)) / 4;
        var dw = load32(buf + boff);
        store32(buf + boff, (dw & 0xFFFF0000) | (simm & 0xFFFF));
        j = j + 1;
    }
    return p;
}

# 1 if the selected list uses the divergent-if EXEC mask (an s_and_saveexec) — the
# driver then reserves the saved-EXEC SGPR pair and bumps the rsrc1 SGPR count.
fn _cmp_has_exec_save(isel, ni): i64 {
    var i = 0;
    while (i < ni) {
        if (gisel_op(isel, i) == GISEL_S_SAVEEXEC) { return 1; }
        i = i + 1;
    }
    return 0;
}

# ================================================================
# Top-level driver: SPIR-V bytes -> GFX9 ISA + RSRC descriptor
# ================================================================
# Chains the whole compiler over the caller-provided context `ctx` (stage scratch
# pointers; `m` pre-initialized): validate -> type/const/decoration tables ->
# lower (+ uniformity) -> isel -> ABI assign -> regalloc (ABI-reserved bases) ->
# s_waitcnt -> encode -> prefetch pad. Writes the ISA byte stream into `isa` and
# the [isa_len, rsrc1, rsrc2, user_sgpr, num_bindings] descriptor into `desc`.
# Returns 0 or a NEGATIVE error from whichever stage rejected the input.
fn gfx9_compile(ctx, spirv, n, isa, desc): i64 {
    # spirv_validate_stream returns 0 (OK) or a POSITIVE error code — the untrusted-
    # input gate must reject any non-zero, NOT `< 0` (which never fires and would let
    # malformed SPIR-V reach the table builders → OOB reads). (N.5c review, CRITICAL.)
    if (spirv_validate_stream(spirv, n) != 0) { return 0 - CMP_ERR_VALIDATE; }
    var idb = spirv_hdr_id_bound(spirv);
    var types = load64(ctx + CC_TYPES);
    var consts = load64(ctx + CC_CONSTS);
    var deco = load64(ctx + CC_DECO);
    # The SPIR-V id_bound is untrusted (header field); the table builders reject any
    # id_bound that would overflow the caller's CC_CAP_IDS-record tables, and guard
    # every per-id write, so a crafted module fails loud instead of corrupting
    # memory (N-HARDEN.1, found via the N.5g adversarial review).
    var cap = load64(ctx + CC_CAP_IDS);
    if (spirv_build_type_table(spirv, n, idb, cap, types) < 0) { return 0 - CMP_ERR_TABLE; }
    if (spirv_build_const_table(spirv, n, idb, cap, consts) < 0) { return 0 - CMP_ERR_TABLE; }
    if (spirv_build_decoration_table(spirv, n, idb, cap, deco) < 0) { return 0 - CMP_ERR_TABLE; }
    var m = load64(ctx + CC_M);
    var lr = spirv_lower_module(spirv, n, types, consts, deco, m, load64(ctx + CC_OUTBI));
    if (lr < 0) { return lr; }
    var isel = load64(ctx + CC_ISEL);
    var ni = gfx9_isel(m, isel, CMP_ISEL_CAP);
    if (ni < 0) { return ni; }
    var abi = load64(ctx + CC_ABI);
    var ar = gfx9_abi_assign(m, abi);
    if (ar < 0) { return ar; }
    var alloc = load64(ctx + CC_ALLOC);
    var hw = load64(ctx + CC_HW);
    # A divergent if reserves s[100:101] for the saved EXEC, so the regalloc must not
    # allocate that high (cap drops to GFX9_EXEC_SAVE_SGPR).
    var div_cf = _cmp_has_exec_save(isel, ni);
    var scap = GFX9_SGPR_CAP;
    if (div_cf == 1) { scap = GFX9_EXEC_SAVE_SGPR; }
    var rr = gfx9_regalloc(m, isel, ni, gfx9_abi_sgpr_base(abi), gfx9_abi_vgpr_base(abi),
    scap, GFX9_VGPR_CAP, alloc, hw);
    if (rr < 0) { return rr; }
    var isel2 = load64(ctx + CC_ISEL2);
    var ni2 = gfx9_waitcnt(m, isel, ni, isel2, CMP_ISEL_CAP);
    if (ni2 < 0) { return ni2; }
    var ep = gfx9_emit_program(m, isel2, ni2, alloc, abi, isa, 0);
    if (ep < 0) { return ep; }
    ep = gfx9_emit_prefetch_pad(isa, ep);
    # The saved-EXEC pair lives at s[100:101], so the grant must cover s101 even though
    # the regalloc high-water (allocated GPRs only) is lower.
    var sgpr_count = gfx9_hw_sgpr(hw);
    if (div_cf == 1) { if (sgpr_count < GFX9_EXEC_SAVE_COUNT) { sgpr_count = GFX9_EXEC_SAVE_COUNT; } }
    # VOP3-literal materialization parks its constant in the first free VGPR
    # (gfx9_hw_vgpr(hw)), so the grant must cover that one extra register.
    var vgpr_count = gfx9_hw_vgpr(hw);
    if (_cmp_needs_scratch(m, isel2, ni2) == 1) { vgpr_count = vgpr_count + 1; }
    var r1 = gfx9_rsrc1(vgpr_count, sgpr_count);
    if (r1 < 0) { return r1; }
    var lidc = gfx9_abi_lid_count(abi);
    var tidig = 0;
    if (lidc > 0) { tidig = lidc - 1; }
    var r2 = gfx9_rsrc2(gfx9_abi_user_sgpr(abi), gfx9_abi_tgid_x(abi), gfx9_abi_tgid_y(abi),
    gfx9_abi_tgid_z(abi), tidig, 1);
    store64(desc + DESC_ISA_LEN, ep);
    store64(desc + DESC_RSRC1, r1);
    store64(desc + DESC_RSRC2, r2);
    store64(desc + DESC_USER_SGPR, gfx9_abi_user_sgpr(abi));
    store64(desc + DESC_NUM_BINDINGS, gfx9_abi_num_bindings(abi));
    return 0;
}

# --- backend_native_shaders.cyr ---

# @internal — native GPU backend, GFX9 ISA shader libraries + register addresses
# backend_native_shaders.cyr — bytes-into-buffer GFX9 ISA writers + GFX9 reg ABCs
#
# Split out from backend_native.cyr at v3 rc.2 (audit toolchain item).
# This file owns:
#   - GFX9 ISA shader-builder fns (s_endpgm, store_deadbeef, solid_red,
#     fullscreen_triangle_vs) — write pre-compiled GFX9 ISA dwords into a
#     caller-supplied buffer at canonical-high VA; pair with
#     native_shader_lib_publish (in backend_native.cyr) to wrap as a BO.
#   - GFX9 register address constants (R_VGT_*, R_PA_SC_*, R_CB_COLOR0_*,
#     R_SPI_*, etc.) — Mesa gfx9.json `map.at` address values, used by the
#     render PM4 composer in backend_native_pm4.cyr.
#   - GFX9 register-value minimum constants (GFX9_VGT_PRIMITIVE_TYPE_*,
#     GFX9_FULLSCREEN_TRI_VCOUNT, GFX9_*_CONTROL_MIN, etc.) — the actual
#     bit values the registers get programmed with.
#
# No syscalls, no PM4 packet builders, no fn dependencies on AMDGPU
# ioctls. Included BEFORE backend_native_pm4.cyr in the build chain
# because the render composer uses these R_*/GFX9_* constants.
#
# Authoritative source for every R_* address: Mesa gfx9.json
# `<reg>` map. Cite the `map.at` value in the comment when adding any
# new register (per project memory `feedback_gfx9_register_authoritative_source`).

# ================================================================
# v3 Phase B.3.c — minimum GFX9 shader
# ================================================================
# A compute shader consisting of a single s_endpgm instruction.
# GFX9 encoding: the SOPP format for s_endpgm is 0xBF810000.
# Usage: write this 4-byte instruction at a 256-byte-aligned VA in
# a GPU-visible BO; point COMPUTE_PGM_LO/HI at that VA.
var GFX9_S_ENDPGM = 0xBF810000;

# GFX9 COMPUTE_PGM_RSRC1 minimum viable mask.
#   bits  0-5  VGPRS        = 0 → allocate 4 VGPRs (enough for v0-v3)
#   bits  6-9  SGPRS        = 1 → allocate 16 SGPRs
#       SGPRS=0 allocates only 8 and is too few once VCC (+2) and
#       flat_scratch (+3) overhead are counted on a store shader.
#   bits 12-19 FLOAT_MODE   = 0xC0 → round-to-nearest-even for f32 + f64.
#                              Some GFX9 firmware rejects FLOAT_MODE = 0.
#   bit  21    DX10_CLAMP   = 1 → well-behaved clamp semantics
#   bit  23    IEEE_MODE    = 1 → IEEE-conformant float behaviour
# Encoded value matches Mesa rusticl for gfx90c: FLOAT_MODE=0xC0,
# SGPRS=1 (16 regs), DX10_CLAMP=1, IEEE_MODE=0.
#   (0xC0 << 12) | (1 << 6) | (1 << 21) = 0x002C0040
var GFX9_COMPUTE_PGM_RSRC1_MIN = 0x2C0040;

# COMPUTE_PGM_RSRC2: 0 = no user SGPR args, no scratch, no LDS.
var GFX9_COMPUTE_PGM_RSRC2_MIN = 0;

# DISPATCH_INITIATOR = 0x45 (Mesa-verified): bits 0 (COMPUTE_SHADER_EN)
# | 2 (FORCE_START_AT_000) | 6 (ORDER_MODE).
var GFX9_DISPATCH_INITIATOR = 0x45;

# Write the s_endpgm shader into buf at pos. Returns new pos.
fn native_gfx9_shader_endpgm(buf, pos): i64 {
    return gfx9_emit32(buf, pos, gfx9_enc_sopp(GFX9_SOPP_S_ENDPGM, 0));
}

# Write a "store 0xDEADBEEF to buffer[0]" shader at `pos` in `buf`.
# Expects s0/s1 pre-loaded with the low/high 32 bits of the output VA
# (either via USER_SGPR = 2 loading from USER_DATA_0/1, or via
# USER_SGPR ≥ 2 where the caller places the VA in those slots).
#
# Source (assembled via `clang -target amdgcn--amdhsa -mcpu=gfx90c`):
#   v_mov_b32_e32  v0, s0                            ; low 32 bits of VA
#   v_mov_b32_e32  v1, s1                            ; high 32 bits of VA
#   v_mov_b32_e32  v2, 0xDEADBEEF                    ; constant
#   global_store_dword v[0:1], v2, off glc slc       ; write-through store
#   s_waitcnt vmcnt(0) lgkmcnt(0)                    ; wait for store
#   s_endpgm                                         ; terminate
#
# GLC + SLC bypass the GPU's L1 and L2 caches, writing straight to
# system memory. Without them the store lands in L2; CPU readback
# from the mapped GTT sees stale data until a cache-flush preempts
# it. Combined with s_waitcnt before s_endpgm, SLC=1 makes the store
# CPU-visible by the time the syncobj fires.
#
# Layout (bytes):
#   +0:  0x7E000200  v_mov_b32_e32 v0, s0   (VOP1: opcode=1, vdst=0, src0=0)
#   +4:  0x7E020201  v_mov_b32_e32 v1, s1   (VOP1: opcode=1, vdst=1, src0=1)
#   +8:  0x7E0402FF  v_mov_b32_e32 v2, <literal>  (src0=255 → literal follows)
#   +12: 0xDEADBEEF  literal
#   +16: 0xDC738000  global_store_dword dword 1  (FLAT+GLOBAL, glc=1, slc=1)
#   +20: 0x007F0200  global_store_dword dword 2  (addr=v0, data=v2, saddr=off=127)
#   +24: 0xBF8C0070  s_waitcnt vmcnt(0) lgkmcnt(0)  (SIMM16 = 0x0070)
#   +28: 0xBF810000  s_endpgm
#   +32..+95: 16 × 0xBF800000  s_nop 0  (AMDGPU-ABI-required prefetch padding)
#
# Returns new pos (pos + 96). RSRC1 must include FLOAT_MODE = 0xC0,
# DX10_CLAMP, IEEE_MODE (GFX9_COMPUTE_PGM_RSRC1_MIN satisfies all).
# USER_SGPR ≥ 2 required so s0/s1 are populated; the canonical setup
# is RSRC2 = 0x8 (USER_SGPR=4) with USER_DATA_0/1 = VA low/high and
# USER_DATA_2/3 = Mesa's scratch-V# stub (0x00200000/0).
fn native_gfx9_shader_store_deadbeef(buf, pos): i64 {
    var p = pos;
    p = gfx9_emit32(buf, p, gfx9_enc_vop1(GFX9_VOP1_V_MOV_B32, 0, gfx9_sgpr(0)));   # v_mov_b32 v0, s0
    p = gfx9_emit32(buf, p, gfx9_enc_vop1(GFX9_VOP1_V_MOV_B32, 1, gfx9_sgpr(1)));   # v_mov_b32 v1, s1
    p = gfx9_emit32(buf, p, gfx9_enc_vop1(GFX9_VOP1_V_MOV_B32, 2, GFX9_SRC_LITERAL));   # v_mov v2, <lit>
    p = gfx9_emit32(buf, p, 0xDEADBEEF);   # literal
    # global_store_dword v[0:1], v2, off glc slc (cache-bypassing write-through)
    p = gfx9_emit32(buf, p, gfx9_enc_flat_lo(GFX9_FLAT_GLOBAL_STORE_DWORD, GFX9_FLAT_SEG_GLOBAL, 0, 1, 1));
    p = gfx9_emit32(buf, p, gfx9_enc_flat_hi(0, GFX9_SADDR_OFF, 2, 0));   # addr=v0, data=v2, saddr=off
    p = gfx9_emit32(buf, p, gfx9_enc_sopp(GFX9_SOPP_S_WAITCNT, 0x0070));   # s_waitcnt vmcnt(0) lgkmcnt(0)
    p = gfx9_emit32(buf, p, gfx9_enc_sopp(GFX9_SOPP_S_ENDPGM, 0));   # s_endpgm
    return gfx9_emit_prefetch_pad(buf, p);
}

# v3.1 [M.4]: 2×2 box-filter downsample compute shader (RGBA8 → RGBA8),
# one workgroup per destination texel (NUM_THREAD 1/1/1; dispatch grid =
# dst_w × dst_h). 316 bytes of GFX9 ISA + 64 bytes (16 × s_nop 0) prefetch
# padding = 380 bytes total.
#
# Every dword below was assembled by `llvm-mc -triple=amdgcn--amdhsa
# -mcpu=gfx90c -show-encoding` from hand-written assembly and is round-
# trip-verified by `scripts/disasm-shaders.sh`
# (feedback_verify_gfx9_shader_bytes_with_llvm_mc). The byte-averaging
# (bfe / add3 / lshrrev-by-2) mirrors what `clang -O2` emits for an
# equivalent OpenCL kernel; the address math is in SALU because every
# input is uniform (single thread).
#
# ABI (the M.5 PM4 composer must set this up):
#   s0:s1 = src level base VA   s2:s3 = dst level base VA
#   s4    = dst_w               s6 = tgid_x (= dst x)   s7 = tgid_y (= dst y)
#   USER_SGPR = 6 (s0..s5); RSRC2 must enable TGID_X | TGID_Y so the CP
#   loads the workgroup id into s6/s7. src is 2·dst_w wide, so the two
#   texels of a destination row are adjacent dwords — one
#   global_load_dwordx2 fetches a pair.
#   Register usage (for RSRC1): VGPRs v0..v14 (15 → alloc 16), SGPRs
#   s0..s19 (20 → alloc 24). RSRC1 must reserve at least that.
fn native_gfx9_shader_downsample_2x2(buf, pos): i64 {
    # Opcode + operand aliases keep the emit body assembler-clean (the encoder
    # call + alias names ARE the mnemonic; the per-dword bytes are pinned by
    # tests/tcyr/compiler.tcyr + native.tcyr's checksum). vN = gfx9_vgpr(N).
    var mov = GFX9_VOP1_V_MOV_B32;
    var smul = GFX9_SOP2_S_MUL_I32;
    var slsh = GFX9_SOP2_S_LSHL_B32;
    var saddi = GFX9_SOP2_S_ADD_I32;
    var saddu = GFX9_SOP2_S_ADD_U32;
    var saddc = GFX9_SOP2_S_ADDC_U32;
    var vand = GFX9_VOP2_V_AND_B32;
    var vor2 = GFX9_VOP2_V_OR_B32;
    var vadd = GFX9_VOP2_V_ADD_U32;
    var vsr = GFX9_VOP2_V_LSHRREV_B32;
    var vsl = GFX9_VOP2_V_LSHLREV_B32;
    var add3 = GFX9_VOP3_V_ADD3_U32;
    var bfe = GFX9_VOP3_V_BFE_U32;
    var or3 = GFX9_VOP3_V_OR3_B32;
    var ld2 = GFX9_FLAT_GLOBAL_LOAD_DWORDX2;
    var st1 = GFX9_FLAT_GLOBAL_STORE_DWORD;
    var glob = GFX9_FLAT_SEG_GLOBAL;
    var noff = GFX9_SADDR_OFF;
    var lit = GFX9_SRC_LITERAL;
    var i0 = gfx9_inline_int(0);
    var i2 = gfx9_inline_int(2);
    var i3 = gfx9_inline_int(3);
    var i4 = gfx9_inline_int(4);
    var i8 = gfx9_inline_int(8);
    var i16 = gfx9_inline_int(16);
    var i24 = gfx9_inline_int(24);
    var p = pos;
    # Address math (all SALU — every input is uniform): src_a / src_c / dst
    # byte offsets, then base+offset into 64-bit VAs (s12:13, s14:15, s18:19).
    p = gfx9_emit32(buf, p, gfx9_enc_sop2(smul, 8, gfx9_sgpr(7), gfx9_sgpr(4)));   # y*dst_w
    p = gfx9_emit32(buf, p, gfx9_enc_sop2(slsh, 9, gfx9_sgpr(8), i4));
    p = gfx9_emit32(buf, p, gfx9_enc_sop2(slsh, 10, gfx9_sgpr(6), i3));
    p = gfx9_emit32(buf, p, gfx9_enc_sop2(saddi, 9, gfx9_sgpr(9), gfx9_sgpr(10)));   # off_a
    p = gfx9_emit32(buf, p, gfx9_enc_sop2(saddu, 12, gfx9_sgpr(0), gfx9_sgpr(9)));   # src_a lo
    p = gfx9_emit32(buf, p, gfx9_enc_sop2(saddc, 13, gfx9_sgpr(1), i0));             # src_a hi
    p = gfx9_emit32(buf, p, gfx9_enc_sop2(slsh, 11, gfx9_sgpr(4), i3));              # 8*dst_w
    p = gfx9_emit32(buf, p, gfx9_enc_sop2(saddu, 14, gfx9_sgpr(12), gfx9_sgpr(11)));  # src_c lo
    p = gfx9_emit32(buf, p, gfx9_enc_sop2(saddc, 15, gfx9_sgpr(13), i0));            # src_c hi
    p = gfx9_emit32(buf, p, gfx9_enc_sop2(slsh, 16, gfx9_sgpr(8), i2));
    p = gfx9_emit32(buf, p, gfx9_enc_sop2(slsh, 17, gfx9_sgpr(6), i2));
    p = gfx9_emit32(buf, p, gfx9_enc_sop2(saddi, 16, gfx9_sgpr(16), gfx9_sgpr(17)));  # dst_off
    p = gfx9_emit32(buf, p, gfx9_enc_sop2(saddu, 18, gfx9_sgpr(2), gfx9_sgpr(16)));   # dst lo
    p = gfx9_emit32(buf, p, gfx9_enc_sop2(saddc, 19, gfx9_sgpr(3), i0));             # dst hi
    # Move the src VA pairs into VGPRs for the global loads.
    p = gfx9_emit32(buf, p, gfx9_enc_vop1(mov, 0, gfx9_sgpr(12)));
    p = gfx9_emit32(buf, p, gfx9_enc_vop1(mov, 1, gfx9_sgpr(13)));
    p = gfx9_emit32(buf, p, gfx9_enc_vop1(mov, 2, gfx9_sgpr(14)));
    p = gfx9_emit32(buf, p, gfx9_enc_vop1(mov, 3, gfx9_sgpr(15)));
    # Fetch the 2x2 block: row a/b (v[4:5]) and row c/d (v[6:7]); src is 2*dst_w.
    p = gfx9_emit32(buf, p, gfx9_enc_flat_lo(ld2, glob, 0, 0, 0));
    p = gfx9_emit32(buf, p, gfx9_enc_flat_hi(4, noff, 0, 0));   # v[4:5] <- v[0:1]
    p = gfx9_emit32(buf, p, gfx9_enc_flat_lo(ld2, glob, 0, 0, 0));
    p = gfx9_emit32(buf, p, gfx9_enc_flat_hi(6, noff, 0, 2));   # v[6:7] <- v[2:3]
    p = gfx9_emit32(buf, p, gfx9_enc_sopp(GFX9_SOPP_S_WAITCNT, 0x0F70));   # vmcnt(0)
    # R channel: low byte of each of a/b/c/d (literal 0xff follows the AND), sum, /4.
    p = gfx9_emit32(buf, p, gfx9_enc_vop2(vand, 8, lit, 4));
    p = gfx9_emit32(buf, p, 0x000000FF);
    p = gfx9_emit32(buf, p, gfx9_enc_vop2(vand, 9, lit, 5));
    p = gfx9_emit32(buf, p, 0x000000FF);
    p = gfx9_emit32(buf, p, gfx9_enc_vop2(vand, 10, lit, 6));
    p = gfx9_emit32(buf, p, 0x000000FF);
    p = gfx9_emit32(buf, p, gfx9_enc_vop2(vand, 11, lit, 7));
    p = gfx9_emit32(buf, p, 0x000000FF);
    p = gfx9_emit32(buf, p, gfx9_enc_vop3a_lo(add3, 8));
    p = gfx9_emit32(buf, p, gfx9_enc_vop3a_hi(gfx9_vgpr(8), gfx9_vgpr(9), gfx9_vgpr(10)));
    p = gfx9_emit32(buf, p, gfx9_enc_vop2(vadd, 8, gfx9_vgpr(8), 11));
    p = gfx9_emit32(buf, p, gfx9_enc_vop2(vsr, 8, i2, 8));   # r avg
    # G channel: byte 1 of each (bfe off=8 w=8), sum, /4, <<8.
    p = gfx9_emit32(buf, p, gfx9_enc_vop3a_lo(bfe, 9));
    p = gfx9_emit32(buf, p, gfx9_enc_vop3a_hi(gfx9_vgpr(4), i8, i8));
    p = gfx9_emit32(buf, p, gfx9_enc_vop3a_lo(bfe, 10));
    p = gfx9_emit32(buf, p, gfx9_enc_vop3a_hi(gfx9_vgpr(5), i8, i8));
    p = gfx9_emit32(buf, p, gfx9_enc_vop3a_lo(bfe, 11));
    p = gfx9_emit32(buf, p, gfx9_enc_vop3a_hi(gfx9_vgpr(6), i8, i8));
    p = gfx9_emit32(buf, p, gfx9_enc_vop3a_lo(bfe, 12));
    p = gfx9_emit32(buf, p, gfx9_enc_vop3a_hi(gfx9_vgpr(7), i8, i8));
    p = gfx9_emit32(buf, p, gfx9_enc_vop3a_lo(add3, 9));
    p = gfx9_emit32(buf, p, gfx9_enc_vop3a_hi(gfx9_vgpr(9), gfx9_vgpr(10), gfx9_vgpr(11)));
    p = gfx9_emit32(buf, p, gfx9_enc_vop2(vadd, 9, gfx9_vgpr(9), 12));
    p = gfx9_emit32(buf, p, gfx9_enc_vop2(vsr, 9, i2, 9));   # g avg
    p = gfx9_emit32(buf, p, gfx9_enc_vop2(vsl, 9, i8, 9));   # g<<8
    # B channel: byte 2 of each (bfe off=16 w=8), sum, /4, <<16.
    p = gfx9_emit32(buf, p, gfx9_enc_vop3a_lo(bfe, 10));
    p = gfx9_emit32(buf, p, gfx9_enc_vop3a_hi(gfx9_vgpr(4), i16, i8));
    p = gfx9_emit32(buf, p, gfx9_enc_vop3a_lo(bfe, 11));
    p = gfx9_emit32(buf, p, gfx9_enc_vop3a_hi(gfx9_vgpr(5), i16, i8));
    p = gfx9_emit32(buf, p, gfx9_enc_vop3a_lo(bfe, 12));
    p = gfx9_emit32(buf, p, gfx9_enc_vop3a_hi(gfx9_vgpr(6), i16, i8));
    p = gfx9_emit32(buf, p, gfx9_enc_vop3a_lo(bfe, 13));
    p = gfx9_emit32(buf, p, gfx9_enc_vop3a_hi(gfx9_vgpr(7), i16, i8));
    p = gfx9_emit32(buf, p, gfx9_enc_vop3a_lo(add3, 10));
    p = gfx9_emit32(buf, p, gfx9_enc_vop3a_hi(gfx9_vgpr(10), gfx9_vgpr(11), gfx9_vgpr(12)));
    p = gfx9_emit32(buf, p, gfx9_enc_vop2(vadd, 10, gfx9_vgpr(10), 13));
    p = gfx9_emit32(buf, p, gfx9_enc_vop2(vsr, 10, i2, 10));   # b avg
    p = gfx9_emit32(buf, p, gfx9_enc_vop2(vsl, 10, i16, 10));   # b<<16
    # A channel: byte 3 of each (lshrrev 24), sum, /4, <<24.
    p = gfx9_emit32(buf, p, gfx9_enc_vop2(vsr, 11, i24, 4));
    p = gfx9_emit32(buf, p, gfx9_enc_vop2(vsr, 12, i24, 5));
    p = gfx9_emit32(buf, p, gfx9_enc_vop2(vsr, 13, i24, 6));
    p = gfx9_emit32(buf, p, gfx9_enc_vop2(vsr, 14, i24, 7));
    p = gfx9_emit32(buf, p, gfx9_enc_vop3a_lo(add3, 11));
    p = gfx9_emit32(buf, p, gfx9_enc_vop3a_hi(gfx9_vgpr(11), gfx9_vgpr(12), gfx9_vgpr(13)));
    p = gfx9_emit32(buf, p, gfx9_enc_vop2(vadd, 11, gfx9_vgpr(11), 14));
    p = gfx9_emit32(buf, p, gfx9_enc_vop2(vsr, 11, i2, 11));   # a avg
    p = gfx9_emit32(buf, p, gfx9_enc_vop2(vsl, 11, i24, 11));   # a<<24
    # Pack R|G|B|A into v8, then store the packed texel.
    p = gfx9_emit32(buf, p, gfx9_enc_vop3a_lo(or3, 8));
    p = gfx9_emit32(buf, p, gfx9_enc_vop3a_hi(gfx9_vgpr(8), gfx9_vgpr(9), gfx9_vgpr(10)));
    p = gfx9_emit32(buf, p, gfx9_enc_vop2(vor2, 8, gfx9_vgpr(8), 11));
    p = gfx9_emit32(buf, p, gfx9_enc_vop1(mov, 0, gfx9_sgpr(18)));
    p = gfx9_emit32(buf, p, gfx9_enc_vop1(mov, 1, gfx9_sgpr(19)));
    p = gfx9_emit32(buf, p, gfx9_enc_flat_lo(st1, glob, 0, 0, 0));
    p = gfx9_emit32(buf, p, gfx9_enc_flat_hi(0, noff, 8, 0));   # v[0:1] <- v8
    p = gfx9_emit32(buf, p, gfx9_enc_sopp(GFX9_SOPP_S_WAITCNT, 0x0070));   # vmcnt(0) lgkmcnt(0)
    p = gfx9_emit32(buf, p, gfx9_enc_sopp(GFX9_SOPP_S_ENDPGM, 0));
    return gfx9_emit_prefetch_pad(buf, p);
}

var GFX9_DOWNSAMPLE_2X2_SIZE = 380;

# PGM_RSRC2 with USER_SGPR = 2 AND TRAP_PRESENT = 1 (bit 6).
# On GFX9, TRAP_PRESENT must be set or memory-op trap paths fire
# bad_op_irq even when no actual trap occurs. Per kfdtest this bit
# is mandatory for any compute dispatch that touches memory.
#   USER_SGPR = 2 → bits 1-5 = 0b00010 → value 0x04
#   TRAP_PRESENT → bit 6        → value 0x40
# Combined: 0x04 | 0x40 = 0x44
var GFX9_COMPUTE_PGM_RSRC2_USER_SGPR_2_TRAP = 0x44;

# RSRC2 with USER_SGPR = 2 — tells HW to pre-load SGPRs s0, s1 with
# COMPUTE_USER_DATA_0, COMPUTE_USER_DATA_1 before shader entry.
# USER_SGPR field occupies bits 1-5; value 2 encodes as 0x04.
var GFX9_COMPUTE_PGM_RSRC2_USER_SGPR_2 = 0x04;

# ================================================================
# v3 Step 6.2(b) — fragment shader: solid red, exp mrt0
# ================================================================
# Trivial fragment shader for the first native render pipeline. No
# inputs (SPI_PS_INPUT_ENA = 0), no varyings, no memory ops — just
# write four f32 channels and export to MRT0 with done+vm.
#
# Source-level equivalent (spec citation, not yet clang-derived — see docs/proposals/v3-shader-bytes-capture.md):
# verify against `clang -target amdgcn--amdhsa -mcpu=gfx90c` once
# clang+LLVM AMDGPU is installed ("What unblocks Layer 2").
#   v_mov_b32_e32  v0, 1.0      ; R = 1.0
#   v_mov_b32_e32  v1, 0.0      ; G = 0.0
#   v_mov_b32_e32  v2, 0.0      ; B = 0.0
#   v_mov_b32_e32  v3, 1.0      ; A = 1.0
#   exp mrt0 v0, v1, v2, v3 done vm
#   s_endpgm                    ; HW serializes exp-done before retire,
#                               ; no s_waitcnt needed
#
# Encoding cross-checks (GCN5/GFX9 ISA spec, AMD vega-isa.pdf):
#
# VOP1 v_mov_b32_e32 vdst, src — bits 25-31 = 0x3F (top byte 0x7E),
#   bits 17-24 = vdst, bits 9-16 = opcode 1, bits 0-8 = src.
#   Inline constants per VOP src table: 128=0.0, 242=1.0.
#   v0,1.0 → 0x7E000000 | (0<<17) | (1<<9) | 242 = 0x7E0002F2
#   v1,0.0 → 0x7E000000 | (1<<17) | (1<<9) | 128 = 0x7E020280
#   v2,0.0 → 0x7E000000 | (2<<17) | (1<<9) | 128 = 0x7E040280
#   v3,1.0 → 0x7E000000 | (3<<17) | (1<<9) | 242 = 0x7E0602F2
#
# EXP encoding (64-bit, two dwords) — bits 31-26 = 0x3E (top byte 0xF8).
#   Word 0 layout: bits 0-3 en, bits 4-9 tgt, bit 10 compr, bit 11 done,
#                  bit 12 vm, bits 13-25 reserved=0, bits 26-31 = 0x3E.
#   Word 1 layout: vsrc0[0-7], vsrc1[8-15], vsrc2[16-23], vsrc3[24-31].
#   exp mrt0 v0,v1,v2,v3 done vm:
#     en=0xF, tgt=0 (mrt0), compr=0, done=1, vm=1
#     Word 0 = 0xF8000000 | (1<<12) | (1<<11) | (0<<4) | 0xF
#            = 0xF8000000 | 0x1000 | 0x800 | 0xF = 0xF800180F
#     Word 1 = (3<<24) | (2<<16) | (1<<8) | 0     = 0x03020100
#
# SOPP s_endpgm — bits 23-31 = 0x17F, bits 16-22 opcode, bits 0-15 simm16.
#   opcode 1 = s_endpgm. Encoding: 0xBF810000 (matches existing compute).
# SOPP s_nop 0 — opcode 0, simm16 0. Encoding: 0xBF800000 (padding).
#
# Layout (bytes; total = 92):
#   +0:  0x7E0002F2  v_mov_b32_e32 v0, 1.0
#   +4:  0x7E020280  v_mov_b32_e32 v1, 0.0
#   +8:  0x7E040280  v_mov_b32_e32 v2, 0.0
#   +12: 0x7E0602F2  v_mov_b32_e32 v3, 1.0
#   +16: 0xF800180F  exp mrt0 done vm en=0xF tgt=0 (word 0)
#   +20: 0x03020100  exp word 1 (vsrc0..3 = v0..v3)
#   +24: 0xBF810000  s_endpgm
#   +28..+91: 16 × 0xBF800000  s_nop 0  (AMDGPU prefetch padding)
#
# RSRC1 expects FLOAT_MODE=0xC0 + DX10_CLAMP + IEEE_MODE
# (GFX9_GFX_PGM_RSRC1_MIN satisfies all). 4 VGPRs allocated for
# v0-v3: VGPRS field = ceil(4/4) - 1 = 0, already encoded in MIN.
# RSRC2: 0 (no USER_DATA, no scratch, no LDS, no memory ops, so
# TRAP_PRESENT bit 6 is the spec minimum 0; HW verify at Step 6.5).
# COL_FORMAT for RGBA8 RT: try FP32_ABGR=0xE first, fall back to
# UNORM16_ABGR=0xA if export quantization misbehaves.
#
# Returns new pos (pos + 92).
fn native_gfx9_shader_solid_red(buf, pos): i64 {
    var mov = GFX9_VOP1_V_MOV_B32;
    var p = pos;
    p = gfx9_emit32(buf, p, gfx9_enc_vop1(mov, 0, GFX9_INLINE_F32_1_0));   # v0 = 1.0
    p = gfx9_emit32(buf, p, gfx9_enc_vop1(mov, 1, GFX9_INLINE_F32_0_0));   # v1 = 0.0
    p = gfx9_emit32(buf, p, gfx9_enc_vop1(mov, 2, GFX9_INLINE_F32_0_0));   # v2 = 0.0
    p = gfx9_emit32(buf, p, gfx9_enc_vop1(mov, 3, GFX9_INLINE_F32_1_0));   # v3 = 1.0
    # exp mrt0 v0,v1,v2,v3 done vm — word 0 = 0xC400180F (NOT 0xF800180F).
    # Top byte is 0xC4 (bits 31-26 = 110001 = EXP opcode class), not 0xF8.
    # The 0xF8 in the prior code came from a wrong reading of the GFX9
    # ISA spec — bits 31-26 = 0x3E gives 0xF8 but that's not the EXP
    # opcode on GFX9. Verified via `llvm-mc --disassemble --arch=amdgcn
    # --mcpu=gfx90c` on the byte sequence: 0xC4 decodes to a valid
    # EXP encoding; 0xF8 decodes as "invalid instruction encoding".
    # The VS/FS waves executed the v_mov/v_cvt fine then hit the
    # malformed exp, silently failed to publish position/color, and
    # the VGT hung waiting for output → 2-second GFX TDR. THIS was
    # the rc.2 native_render_e2e root cause.
    # EXP is a graphics export — out of the N.0 compute-encoder scope, so the
    # two exp dwords stay raw literals (a future graphics phase lifts gfx9_enc_exp).
    p = gfx9_emit32(buf, p, 0xC400180F);   # exp mrt0 done vm (word 0)
    p = gfx9_emit32(buf, p, 0x03020100);   # exp word 1 (v0..v3)
    p = gfx9_emit32(buf, p, gfx9_enc_sopp(GFX9_SOPP_S_ENDPGM, 0));   # s_endpgm
    return gfx9_emit_prefetch_pad(buf, p);
}

# Total byte count produced by native_gfx9_shader_solid_red. The PM4
# stream builder at Step 6.5 needs this to size the BO and to emit
# the right SET_SH_REG values for SPI_SHADER_PGM_LO_PS / _HI_PS.
var GFX9_FS_SOLID_RED_SIZE = 92;

# v3 Step 6.2(b) VS — full-screen triangle from vertex_id.
#
# Computes NDC position from system VGPR v0 (vertex_id at shader
# entry on GFX9 graphics-ABI) using the standard radv pattern:
#   x = (vid     & 1) * 4 - 1
#   y = ((vid>>1) & 1) * 4 - 1
# vid ∈ {0,1,2} → (-1,-1), (3,-1), (-1,3) — covers RT entirely
# after rasterizer clips to viewport.
#
# VOP2 encodings cross-checked against `clang -target
# amdgcn--amdhsa -mcpu=gfx90c -O2` disassembly of an equivalent CL
# kernel (vid_to_pos.cl); see docs/proposals/v3-shader-bytes-capture.md
# Layer-1 protocol. The arithmetic VOP2 opcodes (lshlrev_b32=0x12,
# and_b32=0x13, add_u32=0x34) are ABI-independent — same encodings
# whether dispatched from compute or graphics.
#
# System VGPRs at VS entry on GFX9 (RSRC2_VS = 0):
#   v0: vertex_id
#   v1: instance_id (always loaded; clobberable since we don't use it)
#   v2+: free
# We use v0 and v1 as scratch — instance_id in v1 gets overwritten
# with the y float result before exp pos0. This keeps total VGPR
# usage at 4 (v0..v3), so VGPRS field in RSRC1 stays at 0
# (GFX9_GFX_PGM_RSRC1_MIN unchanged from compute's 0x002C0040).
#
# Source-level equivalent:
#   v_lshlrev_b32_e32 v2, 1, v0    ; v2 = vid << 1   (save y prep)
#   v_lshlrev_b32_e32 v0, 2, v0    ; v0 = vid << 2   (x prep)
#   v_and_b32_e32     v0, 4, v0    ; v0 = (vid<<2) & 4 = (vid&1)*4
#   v_and_b32_e32     v2, 4, v2    ; v2 = (vid<<1) & 4 = ((vid>>1)&1)*4
#   v_add_u32_e32     v0, -1, v0   ; v0 = (vid&1)*4 - 1     (x int)
#   v_add_u32_e32     v2, -1, v2   ; v2 = ((vid>>1)&1)*4 - 1 (y int)
#   v_cvt_f32_i32_e32 v0, v0       ; v0 = float(x)
#   v_cvt_f32_i32_e32 v1, v2       ; v1 = float(y)  (clobbers instance_id)
#   v_mov_b32_e32     v2, 0        ; v2 = 0.0       (z)
#   v_mov_b32_e32     v3, 1.0      ; v3 = 1.0       (w)
#   exp pos0 v0, v1, v2, v3 done
#   s_endpgm
#
# Encoding cross-checks (VOP2: bits 30-25 opcode, 24-17 vdst,
# 16-9 vsrc1, 8-0 src0; -1 = inline 193 = 0xC1; constants 1,2,4 =
# inline 129/130/132 = 0x81/0x82/0x84; v_cvt_f32_i32 = VOP1
# opcode 5, VGPR src = 256 + index):
#
# Layout (bytes; total = 116):
#   +0:  0x24040081  v_lshlrev_b32_e32 v2, 1, v0
#   +4:  0x24000082  v_lshlrev_b32_e32 v0, 2, v0
#   +8:  0x26000084  v_and_b32_e32     v0, 4, v0
#   +12: 0x26040484  v_and_b32_e32     v2, 4, v2
#   +16: 0x680000C1  v_add_u32_e32     v0, -1, v0
#   +20: 0x680404C1  v_add_u32_e32     v2, -1, v2
#   +24: 0x7E000B00  v_cvt_f32_i32_e32 v0, v0
#   +28: 0x7E020B02  v_cvt_f32_i32_e32 v1, v2
#   +32: 0x7E040280  v_mov_b32_e32     v2, 0.0
#   +36: 0x7E0602F2  v_mov_b32_e32     v3, 1.0
#   +40: 0xF80008CF  exp pos0 done en=0xF tgt=12 (word 0)
#   +44: 0x03020100  exp word 1 (vsrc0..3 = v0..v3)
#   +48: 0xBF810000  s_endpgm
#   +52..+115: 16 × 0xBF800000  s_nop 0  (AMDGPU prefetch padding)
#
# RSRC1: GFX9_GFX_PGM_RSRC1_MIN (4 VGPRs, 16 SGPRs, FLOAT_MODE 0xC0).
# RSRC2: 0 (no USER_DATA preload, no scratch, no LDS, no extra
# system VGPRs beyond vid/instance_id).
# SPI_SHADER_POS_FORMAT: 4 (POS_FLOAT_4 — VS exports 4 f32 lanes).
# Returns new pos (pos + 116).
fn native_gfx9_shader_fullscreen_triangle_vs(buf, pos): i64 {
    var mov = GFX9_VOP1_V_MOV_B32;
    var cvt = GFX9_VOP1_V_CVT_F32_I32;
    var vand = GFX9_VOP2_V_AND_B32;
    var vsl = GFX9_VOP2_V_LSHLREV_B32;
    var vadd = GFX9_VOP2_V_ADD_U32;
    var im1 = gfx9_inline_int(0 - 1);
    var p = pos;
    p = gfx9_emit32(buf, p, gfx9_enc_vop2(vsl, 2, gfx9_inline_int(1), 0));   # v2 = vid<<1
    p = gfx9_emit32(buf, p, gfx9_enc_vop2(vsl, 0, gfx9_inline_int(2), 0));   # v0 = vid<<2
    p = gfx9_emit32(buf, p, gfx9_enc_vop2(vand, 0, gfx9_inline_int(4), 0));   # v0 = (vid&1)*4
    p = gfx9_emit32(buf, p, gfx9_enc_vop2(vand, 2, gfx9_inline_int(4), 2));   # v2 = ((vid>>1)&1)*4
    p = gfx9_emit32(buf, p, gfx9_enc_vop2(vadd, 0, im1, 0));   # v0 = x int
    p = gfx9_emit32(buf, p, gfx9_enc_vop2(vadd, 2, im1, 2));   # v2 = y int
    p = gfx9_emit32(buf, p, gfx9_enc_vop1(cvt, 0, gfx9_vgpr(0)));   # v0 = float(x)
    p = gfx9_emit32(buf, p, gfx9_enc_vop1(cvt, 1, gfx9_vgpr(2)));   # v1 = float(y)
    p = gfx9_emit32(buf, p, gfx9_enc_vop1(mov, 2, GFX9_INLINE_F32_0_0));   # v2 = 0.0 (z)
    p = gfx9_emit32(buf, p, gfx9_enc_vop1(mov, 3, GFX9_INLINE_F32_1_0));   # v3 = 1.0 (w)
    # exp pos0 v0,v1,v2,v3 done — word 0 = 0xC40008CF (NOT 0xF80008CF).
    # Same encoding fix as the FS — top byte is 0xC4 (EXP opcode class
    # on GFX9), not 0xF8. See the comment in native_gfx9_shader_solid_red
    # for the full root-cause writeup. Verified by `llvm-mc --disassemble
    # --arch=amdgcn --mcpu=gfx90c` on the corrected encoding.
    # EXP is a graphics export — out of N.0 compute-encoder scope; raw literals.
    p = gfx9_emit32(buf, p, 0xC40008CF);   # exp pos0 done (word 0)
    p = gfx9_emit32(buf, p, 0x03020100);   # exp word 1 (v0..v3)
    p = gfx9_emit32(buf, p, gfx9_enc_sopp(GFX9_SOPP_S_ENDPGM, 0));   # s_endpgm
    return gfx9_emit_prefetch_pad(buf, p);
}

# Total byte count produced by native_gfx9_shader_fullscreen_triangle_vs.
# Step 6.5 sizes the VS BO slot accordingly.
var GFX9_VS_FULLSCREEN_TRIANGLE_SIZE = 116;

# ================================================================
# v3.2 TS.4 — textured fragment shader (image_load bring-up oracle)
# ================================================================
# The sampling-path replacement for native_gfx9_shader_solid_red: each
# fragment LOADS the texel at its own screen position and exports it, so a
# fullscreen quad over a W×H render target sampling a W×H texture reproduces
# the texture (RT[x,y] = tex[x,y]) — the exact, zero-interpolation oracle
# TS.5 verifies on Cezanne. (Normalized-UV `image_sample` + the UV-export VS
# come at TS.7 for the compressed/scaled path.)
#
# v3.2 TS.8 — SCALED: the FS now multiplies the fragment position by a per-draw
# scale (scale_x/scale_y = tex_dim/rt_dim, f32, loaded from descriptor+48/+52)
# before the int-cvt, so a W×H texture maps over an arbitrary RT. The draw writes
# scale=1.0 for equal dims, so RT[x,y]==tex[x,y] stays bit-exact (1.0*x == x).
#
# ABI:
#   - s[0:1] = PS user-data (the T#+S# descriptor BO VA; pipeline SET_SH_REGs
#     SPI_SHADER_USER_DATA_PS_0/1 at bind, TS.5). RSRC2_PS USER_SGPR=2.
#   - SPI_PS_INPUT_ENA = GFX9_SPI_PS_INPUT_TEXTURED (0x302): PERSP_CENTER
#     (hang-quirk, VGPRs v0/v1 unused) + POS_X_FLOAT + POS_Y_FLOAT, so the
#     fragment screen position arrives as floats in v2 (x) / v3 (y).
#   - High-water: VGPRs v0..v5 (6), SGPRs s[0:13] (T# s[0:7] + scale s[12:13]) —
#     both fit RSRC1_PS MIN|1 (8 VGPR / 16 SGPR), so the TS.5 draw override + ABI
#     are unchanged.
#
# Source (assembled + round-tripped via `llvm-mc -mcpu=gfx90c`, per
# feedback_verify_gfx9_shader_bytes_with_llvm_mc):
#   s_load_dwordx8 s[0:7], s[0:1], 0x0   ; load the T# from the descriptor BO
#   s_load_dwordx2 s[12:13], s[0:1], 0x30 ; scale_x@+48 -> s12, scale_y@+52 -> s13
#   s_waitcnt lgkmcnt(0)
#   v_mul_f32 v2, s12, v2 ; v_mul_f32 v3, s13, v3   ; pos *= scale
#   v_cvt_i32_f32_e32 v4, v2             ; tx = int(scaled pos_x)
#   v_cvt_i32_f32_e32 v5, v3             ; ty = int(scaled pos_y)
#   image_load v[0:3], v[4:5], s[0:7] dmask:0xf unorm
#   s_waitcnt vmcnt(0)
#   exp mrt0 v0, v1, v2, v3 done vm
#   s_endpgm
# exp word0 = 0xC400180F — identical to the proven solid-red EXP encoding.
# Returns pos + 124 (60 B code + 16 × s_nop 0 prefetch pad). @internal
fn native_gfx9_shader_textured_load_fs(buf, pos): i64 {
    var p = pos;
    p = gfx9_emit32(buf, p, gfx9_enc_smem_lo(GFX9_SMEM_S_LOAD_DWORDX8, 0, 0, 0));   # T# s[0:7]
    p = gfx9_emit32(buf, p, 0x00000000);   # offset 0x0
    p = gfx9_emit32(buf, p, gfx9_enc_smem_lo(GFX9_SMEM_S_LOAD_DWORDX2, 12, 0, 0));   # scale s[12:13]
    p = gfx9_emit32(buf, p, 0x00000030);   # offset 0x30 (descriptor+48)
    p = gfx9_emit32(buf, p, gfx9_enc_sopp(GFX9_SOPP_S_WAITCNT, 0xC07F));   # lgkmcnt(0)
    p = gfx9_emit32(buf, p, gfx9_enc_vop2(GFX9_VOP2_V_MUL_F32, 2, gfx9_sgpr(12), 2));   # pos_x *= scale_x
    p = gfx9_emit32(buf, p, gfx9_enc_vop2(GFX9_VOP2_V_MUL_F32, 3, gfx9_sgpr(13), 3));   # pos_y *= scale_y
    p = gfx9_emit32(buf, p, gfx9_enc_vop1(GFX9_VOP1_V_CVT_I32_F32, 4, gfx9_vgpr(2)));   # POS_X -> tx
    p = gfx9_emit32(buf, p, gfx9_enc_vop1(GFX9_VOP1_V_CVT_I32_F32, 5, gfx9_vgpr(3)));   # POS_Y -> ty
    # image_load + exp are graphics/texture ops — out of N.0 compute-encoder
    # scope, so their dwords stay raw literals (a future phase lifts the encoders).
    p = gfx9_emit32(buf, p, 0xF0001F00);   # image_load v[0:3], v[4:5], s[0:7] dmask:0xf unorm (w0)
    p = gfx9_emit32(buf, p, 0x00000004);   # image_load (w1: vaddr=v4, vdata=v0, srsrc=s[0:7])
    p = gfx9_emit32(buf, p, gfx9_enc_sopp(GFX9_SOPP_S_WAITCNT, 0x0F70));   # vmcnt(0)
    p = gfx9_emit32(buf, p, 0xC400180F);   # exp mrt0 v0,v1,v2,v3 done vm (w0)
    p = gfx9_emit32(buf, p, 0x03020100);   # exp (w1)
    p = gfx9_emit32(buf, p, gfx9_enc_sopp(GFX9_SOPP_S_ENDPGM, 0));   # s_endpgm
    return gfx9_emit_prefetch_pad(buf, p);
}

var GFX9_FS_TEXTURED_LOAD_SIZE = 124;

# SPI_PS_INPUT_ENA/_ADDR for the textured FS — see the ABI note above.
# gfx9.json SPI_PS_INPUT_ENA: PERSP_CENTER_ENA[1], POS_X_FLOAT_ENA[8],
# POS_Y_FLOAT_ENA[9]. (1<<1)|(1<<8)|(1<<9) = 0x302. Shared by both textured FS.
var GFX9_SPI_PS_INPUT_TEXTURED = 0x302;

# ================================================================
# v3.2 TS.7 — textured fragment shader (image_sample, BC-decoding)
# ================================================================
# The compressed-sampling FS: unlike image_load (raw bytes), image_sample runs
# the TA's block DECODE + filter, so BC/ETC2/ASTC textures sample to RGBA. Same
# screen-pos oracle as the image_load FS — and the S# uses FORCE_UNNORMALIZED
# (TS.7), so image_sample takes the fragment position directly as a texel coord
# (no UV divide, no rcp). This keeps the ABI identical to the image_load FS, so
# the render_pass_draw textured override (TS.5) is reused unchanged.
#
# v3.2 TS.8 — SCALED (same as the image_load FS): the coord = fragment_pos *
# scale (scale_x/scale_y = tex_dim/rt_dim, f32, from descriptor+48/+52), so a
# texture maps over an arbitrary RT with the S#'s filter (POINT or BILINEAR). The
# v_mov pos->coord became v_mul (the multiply reads the scale SGPR as src0, so no
# extra v_mov). Equal dims -> scale 1.0 -> coord==pos (bit-exact, BC path stays
# pixel-exact). The S# stays FORCE_UNNORMALIZED (coords are texel-space).
#
# ABI (same as the image_load FS — 2 user SGPRs, RSRC2_PS=MIN, RSRC1=MIN|1):
#   s0,s1 = T#/S# descriptor BO VA (T# at +0, S# at +32; S# is FORCE_UNNORMALIZED).
#   SPI_PS_INPUT = GFX9_SPI_PS_INPUT_TEXTURED (pos in v2/v3).
#   High-water: VGPRs v0..v5 (6), SGPRs s0..s13 (T# s[0:7] + S# s[8:11] + scale
#   s[12:13]) — both fit MIN|1 (8 VGPR / 16 SGPR); draw override unchanged.
#
# Source (llvm-mc -mcpu=gfx90c, round-tripped):
#   s_load_dwordx4 s[8:11], s[0:1], 0x20     ; S# (descriptor + 32)
#   s_load_dwordx8 s[0:7], s[0:1], 0x0       ; T# (descriptor + 0)
#   s_load_dwordx2 s[12:13], s[0:1], 0x30    ; scale_x@+48 -> s12, scale_y@+52 -> s13
#   s_waitcnt lgkmcnt(0)
#   v_mul_f32 v4, s12, v2 ; v_mul_f32 v5, s13, v3   ; coord = scale * pos
#   image_sample v[0:3], v[4:5], s[0:7], s[8:11] dmask:0xf
#   s_waitcnt vmcnt(0) ; exp mrt0 v0,v1,v2,v3 done vm ; s_endpgm
# Returns pos + 124 (60 B code + 16 × s_nop 0). @internal
fn native_gfx9_shader_textured_sample_fs(buf, pos): i64 {
    var p = pos;
    p = gfx9_emit32(buf, p, gfx9_enc_smem_lo(GFX9_SMEM_S_LOAD_DWORDX4, 8, 0, 0));   # S# s[8:11]
    p = gfx9_emit32(buf, p, 0x00000020);   # offset 0x20 (descriptor+32)
    p = gfx9_emit32(buf, p, gfx9_enc_smem_lo(GFX9_SMEM_S_LOAD_DWORDX8, 0, 0, 0));   # T# s[0:7]
    p = gfx9_emit32(buf, p, 0x00000000);   # offset 0x0
    p = gfx9_emit32(buf, p, gfx9_enc_smem_lo(GFX9_SMEM_S_LOAD_DWORDX2, 12, 0, 0));   # scale s[12:13]
    p = gfx9_emit32(buf, p, 0x00000030);   # offset 0x30 (descriptor+48)
    p = gfx9_emit32(buf, p, gfx9_enc_sopp(GFX9_SOPP_S_WAITCNT, 0xC07F));   # lgkmcnt(0)
    p = gfx9_emit32(buf, p, gfx9_enc_vop2(GFX9_VOP2_V_MUL_F32, 4, gfx9_sgpr(12), 2));   # coord x
    p = gfx9_emit32(buf, p, gfx9_enc_vop2(GFX9_VOP2_V_MUL_F32, 5, gfx9_sgpr(13), 3));   # coord y
    # image_sample + exp are graphics/texture ops — out of N.0 compute-encoder
    # scope, so their dwords stay raw literals (a future phase lifts the encoders).
    p = gfx9_emit32(buf, p, 0xF0800F00);   # image_sample v[0:3], v[4:5], s[0:7], s[8:11] dmask:0xf (w0)
    p = gfx9_emit32(buf, p, 0x00400004);   # image_sample (w1)
    p = gfx9_emit32(buf, p, gfx9_enc_sopp(GFX9_SOPP_S_WAITCNT, 0x0F70));   # vmcnt(0)
    p = gfx9_emit32(buf, p, 0xC400180F);   # exp mrt0 v0,v1,v2,v3 done vm (w0)
    p = gfx9_emit32(buf, p, 0x03020100);   # exp (w1)
    p = gfx9_emit32(buf, p, gfx9_enc_sopp(GFX9_SOPP_S_ENDPGM, 0));   # s_endpgm
    return gfx9_emit_prefetch_pad(buf, p);
}

var GFX9_FS_TEXTURED_SAMPLE_SIZE = 124;

# ================================================================
# v3.2 F.4 — first native f64 (double-precision) compute shader
# ================================================================
# A hand-authored GFX9 compute kernel computing, per lane i:
#   out[i] = fma(a[i], b[i], c[i])   (IEEE-754 double, single rounding)
# over four StorageBuffers of f64 (8-byte stride). This is the first
# native double-precision GPU compute in mabda — the V_FMA_F64 path
# (GFX9_VOP3_V_FMA_F64 = 0x1CC), proven byte-identical to llvm-mc and
# dispatched bit-exact vs a CPU fused reference on Cezanne (Phase F.6).
#
# Canonical compute ABI (the F.5 PM4 composer sets this up — binding k →
# USER_DATA s[2k:2k+1]):
#   s[0:1] = a base VA      s[2:3] = b base VA
#   s[4:5] = c base VA      s[6:7] = out base VA
#   v0     = lid.x (the CP loads the per-lane id into v0; one workgroup of
#            LocalSize_x lanes, so lid.x ∈ 0..ntx-1 indexes the element).
#   USER_SGPR = 8 (s0..s7) — RSRC2 = GFX9_COMPUTE_PGM_RSRC2_FMA_F64 = 0x10.
#
# f64 occupies an even-aligned VGPR pair; the kernel uses v[2:3]/v[4:5]/
# v[6:7] for a/b/c and v[8:9] for the result, plus v0 (lid) and v1 (the
# per-lane byte offset). High-water VGPR = v9 ⇒ 10 VGPRs ⇒ VGPRS field =
# ceil(10/4) - 1 = 2, so RSRC1 = GFX9_COMPUTE_PGM_RSRC1_MIN | 2 =
# GFX9_COMPUTE_PGM_RSRC1_FMA_F64 = 0x2C0042.
#
# The FLAT ops use the SADDR form: the 64-bit base lives in the binding's
# USER_DATA SGPR pair (saddr field = that SGPR index), and the per-lane
# 32-bit byte offset (lid.x * 8) rides vaddr (v1). This needs no in-shader
# 64-bit address add — the SADDR form does base+offset in HW.
#
# Source (assembled + round-tripped via `llvm-mc -mcpu=gfx90c -show-encoding`,
# per feedback_verify_gfx9_shader_bytes_with_llvm_mc):
#   v_lshlrev_b32_e32   v1, 3, v0                  ; v1 = lid.x * 8 (f64 stride)
#   global_load_dwordx2 v[2:3], v1, s[0:1]         ; a[i]
#   global_load_dwordx2 v[4:5], v1, s[2:3]         ; b[i]
#   global_load_dwordx2 v[6:7], v1, s[4:5]         ; c[i]
#   s_waitcnt vmcnt(0)                             ; all three loads done
#   v_fma_f64 v[8:9], v[2:3], v[4:5], v[6:7]       ; out = a*b + c (one rounding)
#   global_store_dwordx2 v1, v[8:9], s[6:7]        ; out[i]
#   s_waitcnt vmcnt(0) lgkmcnt(0)                  ; store visible
#   s_endpgm
#
# Layout (bytes; total = 120 = 56 B code + 64 B prefetch pad):
#   +0:  0x24020083  v_lshlrev_b32_e32 v1, 3, v0
#   +4:  0xDC548000  global_load_dwordx2 (lo)
#   +8:  0x02000001  v[2:3] <- v1, s[0:1]  (hi: vdst=2, saddr=0, vaddr=1)
#   +12: 0xDC548000  global_load_dwordx2 (lo)
#   +16: 0x04020001  v[4:5] <- v1, s[2:3]  (hi: vdst=4, saddr=2, vaddr=1)
#   +20: 0xDC548000  global_load_dwordx2 (lo)
#   +24: 0x06040001  v[6:7] <- v1, s[4:5]  (hi: vdst=6, saddr=4, vaddr=1)
#   +28: 0xBF8C0F70  s_waitcnt vmcnt(0)
#   +32: 0xD1CC0008  v_fma_f64 v[8:9] (lo) — GFX9_VOP3_V_FMA_F64
#   +36: 0x041A0902  v_fma_f64 (hi: src0=v2, src1=v4, src2=v6)
#   +40: 0xDC748000  global_store_dwordx2 (lo)
#   +44: 0x00060801  v1, v[8:9], s[6:7]  (hi: data=8, saddr=6, vaddr=1)
#   +48: 0xBF8C0070  s_waitcnt vmcnt(0) lgkmcnt(0)
#   +52: 0xBF810000  s_endpgm
#   +56..+119: 16 × 0xBF800000  s_nop 0  (AMDGPU prefetch padding)
#
# Returns new pos (pos + 120). @internal
fn native_gfx9_shader_fma_f64(buf, pos): i64 {
    var ld2 = GFX9_FLAT_GLOBAL_LOAD_DWORDX2;
    var st2 = GFX9_FLAT_GLOBAL_STORE_DWORDX2;
    var glob = GFX9_FLAT_SEG_GLOBAL;
    var p = pos;
    # v1 = lid.x * 8 (the f64-stride per-lane byte offset).
    p = gfx9_emit32(buf, p, gfx9_enc_vop2(GFX9_VOP2_V_LSHLREV_B32, 1, gfx9_inline_int(3), 0));
    # Three f64 loads (SADDR form): base in s[2k:2k+1], 32-bit offset in v1.
    p = gfx9_emit32(buf, p, gfx9_enc_flat_lo(ld2, glob, 0, 0, 0));
    p = gfx9_emit32(buf, p, gfx9_enc_flat_hi(2, gfx9_sgpr(0), 0, 1));   # a -> v[2:3]
    p = gfx9_emit32(buf, p, gfx9_enc_flat_lo(ld2, glob, 0, 0, 0));
    p = gfx9_emit32(buf, p, gfx9_enc_flat_hi(4, gfx9_sgpr(2), 0, 1));   # b -> v[4:5]
    p = gfx9_emit32(buf, p, gfx9_enc_flat_lo(ld2, glob, 0, 0, 0));
    p = gfx9_emit32(buf, p, gfx9_enc_flat_hi(6, gfx9_sgpr(4), 0, 1));   # c -> v[6:7]
    p = gfx9_emit32(buf, p, gfx9_enc_sopp(GFX9_SOPP_S_WAITCNT, 0x0F70));   # vmcnt(0)
    # out = a*b + c in IEEE-754 double, single rounding (the fused multiply-add).
    p = gfx9_emit32(buf, p, gfx9_enc_vop3a_lo(GFX9_VOP3_V_FMA_F64, 8));
    p = gfx9_emit32(buf, p, gfx9_enc_vop3a_hi(gfx9_vgpr(2), gfx9_vgpr(4), gfx9_vgpr(6)));
    # Store the f64 result (SADDR form): out base in s[6:7], offset in v1.
    p = gfx9_emit32(buf, p, gfx9_enc_flat_lo(st2, glob, 0, 0, 0));
    p = gfx9_emit32(buf, p, gfx9_enc_flat_hi(0, gfx9_sgpr(6), 8, 1));   # v[8:9] -> out[i]
    p = gfx9_emit32(buf, p, gfx9_enc_sopp(GFX9_SOPP_S_WAITCNT, 0x0070));   # vmcnt(0) lgkmcnt(0)
    p = gfx9_emit32(buf, p, gfx9_enc_sopp(GFX9_SOPP_S_ENDPGM, 0));
    return gfx9_emit_prefetch_pad(buf, p);
}

# Total byte count produced by native_gfx9_shader_fma_f64 (56 B code + 64 B pad).
var GFX9_FMA_F64_SIZE = 120;

# RSRC1 for the f64 FMA kernel: MIN | VGPRS=2 (10 VGPRs, v0..v9). See the
# builder's header for the ceil(10/4)-1 = 2 derivation.
var GFX9_COMPUTE_PGM_RSRC1_FMA_F64 = 0x2C0042;

# RSRC2 for the f64 FMA kernel: USER_SGPR = 8 (s0..s7, the four binding VA
# pairs). USER_SGPR occupies bits 1-5, value 8 → 8 << 1 = 0x10. No TGID
# (a single workgroup of LocalSize_x lanes — lid.x in v0 is sufficient),
# no scratch, no LDS.
var GFX9_COMPUTE_PGM_RSRC2_FMA_F64 = 0x10;

# ================================================================
# v3 Step 6.2(a) — graphics-pipeline register addresses + minimums
# ================================================================
# Spec-anchor for the trivial vertex+fragment pipeline that Step
# 6.5 will assemble into a PM4 stream. Decision-independent half
# of Step 6.2 — the shader-byte derivation path (6.2(b)) doesn't
# affect any of these addresses or bitfield minimums.
#
# Addresses use the same mabda convention as the compute side: SH
# registers at their real sid.h byte offsets in the 0xB000 block,
# context registers at the synthetic 0xA000-base shorthand (Mesa
# uses 0x28000; both produce identical wire-form dwords through
# native_context_reg_offset() since only the difference matters).
#
# Citations are Mesa sid.h naming (R_<6digits>_<name>). Hazard:
# none of the SH-side addresses below have been hardware-verified
# on Cezanne yet — the compute equivalents took an AMD_DEBUG=ib
# pass to confirm (see line 522 comment). 6.2(a) stages the values;
# Step 6.5's PM4-stream-vs-radv diff is the verification gate.
# Protocol details: docs/proposals/v3-shader-bytes-capture.md.

# Vertex shader SH registers (Mesa: R_00B12{0,4,8,C}_SPI_SHADER_*_VS).
# Within the SH-reg block (0xB000 base; native_sh_reg_offset divides
# by 4). Wire-form offsets: PGM_LO=0x48, _HI=0x49, _RSRC1=0x4A, _RSRC2=0x4B.
# RSRC3 (CU enable mask) and LATE_ALLOC live immediately BELOW PGM_LO:
# wire-form offsets RSRC3=0x46, LATE_ALLOC=0x47. Without these the VS
# has no CUs allocated → waves can't launch → 2-second GFX TDR.
var R_SPI_SHADER_PGM_RSRC3_VS = 0xB118;
var R_SPI_SHADER_LATE_ALLOC_VS = 0xB11C;
var R_SPI_SHADER_PGM_LO_VS    = 0xB120;
var R_SPI_SHADER_PGM_HI_VS    = 0xB124;
var R_SPI_SHADER_PGM_RSRC1_VS = 0xB128;
var R_SPI_SHADER_PGM_RSRC2_VS = 0xB12C;

# CU enable mask + late VS allocation count captured byte-for-byte from
# radv on Cezanne/Renoir (gfx90c). 0x003FFFFE enables CUs 1-21; the low
# bit (CU0) is masked off per AMD's recommended SE/SH layout. Late VS
# allocation 24 is the Cezanne-tuned value radv computes from CU count.
var GFX9_SPI_SHADER_PGM_RSRC3_VS_CU_EN_ALL = 0x003FFFFE;
var GFX9_SPI_SHADER_LATE_ALLOC_VS_CEZANNE  = 0x00000018;

# Pixel shader SH registers (Mesa: R_00B02{0,4,8,C}_SPI_SHADER_*_PS).
# Wire-form offsets: PGM_LO=0x08, _HI=0x09, _RSRC1=0x0A, _RSRC2=0x0B.
var R_SPI_SHADER_PGM_LO_PS    = 0xB020;
var R_SPI_SHADER_PGM_HI_PS    = 0xB024;
var R_SPI_SHADER_PGM_RSRC1_PS = 0xB028;
var R_SPI_SHADER_PGM_RSRC2_PS = 0xB02C;
# v3.2 TS.4 — PS user-data SH registers (Mesa R_00B03{0,4}). The textured FS's
# 2 user SGPRs (s[0:1]) hold the bound texture's T#+S# descriptor BO VA; the
# pipeline SET_SH_REGs these at bind/draw time (TS.5). RSRC2_PS USER_SGPR=2
# (GFX9_PS_PGM_RSRC2_MIN = 0x4 already encodes 2).
var R_SPI_SHADER_USER_DATA_PS_0 = 0xB030;
var R_SPI_SHADER_USER_DATA_PS_1 = 0xB034;

# SPI shader output format context registers
# (Mesa gfx9.json: R_02870C_SPI_SHADER_POS_FORMAT,
#                  R_028710_SPI_SHADER_Z_FORMAT,
#                  R_028714_SPI_SHADER_COL_FORMAT).
# Mabda 0xA-shorthand: subtract 0x1E000 from Mesa's MMIO byte addr
# (only the difference matters in PM4 wire form).
# Corrected 2026-04-30 against authoritative Mesa gfx9.json — initial
# 6.2(a) values had the three addresses scrambled (caught via the
# 6.5(a) sweep before any HW test ran).
var R_SPI_SHADER_POS_FORMAT = 0xA70C;
var R_SPI_SHADER_Z_FORMAT   = 0xA710;
var R_SPI_SHADER_COL_FORMAT = 0xA714;

# Color-buffer write-mask context register
# (Mesa: R_028238_CB_TARGET_MASK). Representative pipeline-static
# context register; CB_SHADER_MASK / CB_COLOR_CONTROL / blend / raster
# state lands in 6.5 alongside the assembled PM4 stream.
var R_CB_TARGET_MASK = 0xA238;

# RSRC1 bitfield minimum — graphics shaders use the same FLOAT_MODE +
# DX10_CLAMP + IEEE_MODE encoding as compute (encoded value 0x002C0040).
# VS and PS share this minimum; per-shader overrides (VGPR/SGPR counts)
# get OR'd in by the assembler at Step 6.2(b).
# Graphics (VS/PS) RSRC1 minimum. Differs from the compute constant
# by bit 24 = LS_VGPR_COMP_CNT[0] = 1. On GFX9 the VS / merged-LS
# path requires LS_VGPR_COMP_CNT >= 1 to allocate the system VGPRs
# SPI_SHADER_PGM_RSRC1_VS/PS = 0x002C0040. Decoded:
#   VGPRS=0 (4 VGPRs allocated — exactly fits v0..v3 our shaders use)
#   SGPRS=1 (16 SGPRs)
#   FLOAT_MODE=0xC0 (FP_16_64_DENORMS)
#   DX10_CLAMP=1
#   VGPR_COMP_CNT=0 (only v0 preloaded for VS; PS irrelevant)
# Captured byte-exact from radv on Cezanne via the triangle reference
# (`programs/diagnostics/radv_capture_triangle`). The previous value
# 0x012C0041 had bit 24 (VGPR_COMP_CNT=1) and bit 0 (VGPRS=1, 8 VGPRs
# allocated) — sourced from a vkcube IB whose VS reads instance_id,
# unlike ours. Matching radv's triangle-test value byte-for-byte.
var GFX9_GFX_PGM_RSRC1_MIN = 0x002C0040;

# SPI_SHADER_PGM_RSRC2_VS = 0x6. Bits 1+2 set → USER_SGPR=3 (3 user-data
# SGPRs preloaded). Even though our VS doesn't read user_data, the SPI
# requires a non-zero USER_SGPR allocation for graphics-stage shaders.
# Captured byte-for-byte from radv triangle test.
var GFX9_VS_PGM_RSRC2_MIN = 0x6;

# SPI_SHADER_PGM_RSRC2_PS = 0x4. Bit 2 set → USER_SGPR=2 (2 user-data
# SGPRs preloaded). Required by SPI for PS-stage shaders.
# Captured byte-for-byte from radv triangle test.
var GFX9_PS_PGM_RSRC2_MIN = 0x4;

# SPI_SHADER_POS_FORMAT — vertex stage exports four f32 lanes for pos0.
# Encoding: bits 0-3 = format (0=NONE, 4=FLOAT_4). Other formats reserved
# for tess / GS pipelines we don't use yet.
var SPI_SHADER_POS_FORMAT_4 = 0x4;

# SPI_SHADER_Z_FORMAT — fragment stage does not export depth.
var SPI_SHADER_Z_FORMAT_INVALID = 0x0;

# SPI_SHADER_COL_FORMAT for color target 0 — RGBA8 RT.
# Three candidates documented in the GFX9 ISA spec; the export
# hardware quantizes the FS f32 output to the RT format. FP32_ABGR
# is the natural choice (FS does v_mov_b32 of 4 f32s, hardware does
# the unorm conversion). FP16_ABGR / UNORM16_ABGR are listed for
# Step 6.5 fallback if FP32_ABGR misbehaves on Cezanne — verification
# is "render a known color, CPU-readback the RT, compare bytes."
# SPI_SHADER_COL_FORMAT per-MRT 4-bit field values (GFX9 ISA spec):
#   0 SPI_SHADER_ZERO        (no output)
#   1 SPI_SHADER_32_R
#   2 SPI_SHADER_32_GR
#   3 SPI_SHADER_32_AR
#   4 SPI_SHADER_FP16_ABGR
#   5 SPI_SHADER_UNORM16_ABGR
#   6 SPI_SHADER_SNORM16_ABGR
#   7 SPI_SHADER_UINT16_ABGR
#   8 SPI_SHADER_SINT16_ABGR
#   9 SPI_SHADER_32_ABGR     (FP32 export)
# Previous constants (0x9 / 0xA / 0xE) were OFF by a whole field —
# 0xE is reserved/undocumented; the SX silently routes it to ZERO,
# making the FS's exported color disappear and the CB write zeros to
# the RT. THIS was the post-EXP-fix "draw completes but pixel = 0"
# root cause. 2026-05-13.
var SPI_SHADER_COL_FORMAT_FP16_ABGR    = 0x4;
var SPI_SHADER_COL_FORMAT_UNORM16_ABGR = 0x5;
var SPI_SHADER_COL_FORMAT_FP32_ABGR    = 0x9;

# Vertex count for a single full-screen triangle. The VS pulls
# positions from a 3-entry switch on vertex_id (built into the
# shader, no VBO bind). DRAW_INDEX_AUTO with this count + an
# initiator of DI_SRC_SEL_AUTO_INDEX produces the assembly.
var GFX9_FULLSCREEN_TRI_VCOUNT = 3;

# ================================================================
# v3 Step 6.5(a) — clear-triangle PM4 register addresses + values
# ================================================================
# Extension to the 6.2(a) constant set, covering the registers Step
# 6.5(b)'s native_pm4_build_render_clear_triangle composer needs.
# Every address below was extracted from
# https://gitlab.freedesktop.org/mesa/mesa/-/raw/main/src/amd/registers/gfx9.json
# (Mesa main, fetched 2026-04-30) — the authoritative source for
# GFX9 MMIO offsets. The lookup script that produced these is
# captured in docs/proposals/v3-shader-bytes-capture.md.
#
# Mabda convention: SH (0xBxxx) and UConfig (0x3xxxx) addresses are
# real MMIO byte offsets. Context registers use the synthetic
# 0xA000 shorthand (Mesa MMIO byte addr - 0x1E000) — produces the
# same PM4 wire-form dword via native_context_reg_offset() since
# only the difference from base matters.
#
# The constants split mirrors the 3-block PM4 design from
# docs/proposals/v3-backend-interface.md v2.1: pipeline_sh_block
# (per-pipeline, shader VAs + RSRC), pipeline_ctx_block
# (per-pipeline, blend/raster/depth-test mode), pass_target_block
# (per-pass, RT-extent-derived). The 6.5(b) builder will compose
# them in that order.

# --- Pipeline-static context regs (ctx block) ---

# Color/blend mode — Mesa gfx9.json names + addresses.
var R_CB_SHADER_MASK     = 0xA23C;   # Mesa 0x02823C
var R_CB_COLOR_CONTROL   = 0xA808;   # Mesa 0x028808
var R_CB_BLEND0_CONTROL  = 0xA780;   # Mesa 0x028780

# Rasterizer / clip mode.
var R_PA_SU_SC_MODE_CNTL = 0xA814;   # Mesa 0x028814
var R_PA_CL_CLIP_CNTL    = 0xA810;   # Mesa 0x028810
# PA_CL_VS_OUT_CNTL — VS output enable mask (clip/cull dist, viewport
# index, etc.). For a trivial VS that only exports position, radv emits
# 0; the cube draws that export clip distances emit 0x01240000. Without
# an explicit emit, the register holds whatever the prior context left
# behind (likely the compositor's value) → the PA stage waits on output
# slots our VS doesn't fill → GFX TDR.
var R_PA_CL_VS_OUT_CNTL  = 0xA81C;   # Mesa 0x02881C

# Pipeline-stage handshake registers that radv explicitly emits even
# when the value is 0. Without explicit emit, mabda inherits whatever
# the prior context (the compositor) left in these registers, which
# can stall pipeline stages waiting on handshakes that never complete.
# Each captured from radv on Cezanne via RADV_DEBUG=dumpibs.
var R_DB_Z_INFO              = 0xA038;   # Mesa 0x028038
var R_DB_STENCIL_INFO        = 0xA03C;   # Mesa 0x02803C
var R_SPI_BARYC_CNTL         = 0xA6E0;   # Mesa 0x0286E0
var R_VGT_GS_MODE            = 0xAA40;   # Mesa 0x028A40
var R_VGT_PRIMITIVEID_EN     = 0xAA84;   # Mesa 0x028A84
var R_PA_SC_AA_MASK_X0Y0_X1Y0 = 0xAC38;  # Mesa 0x028C38
var R_PA_SC_AA_MASK_X0Y1_X1Y1 = 0xAC3C;  # Mesa 0x028C3C
var R_PA_SC_SHADER_CONTROL   = 0xAC40;   # Mesa 0x028C40
# Additional regs radv emits before the triangle draw on Cezanne.
# Captured byte-for-byte from radv_capture_triangle 2026-05-12.
var R_PA_SC_MODE_CNTL_0      = 0xAA48;   # Mesa 0x028A48
var R_VGT_GS_OUT_PRIM_TYPE   = 0xAA6C;   # Mesa 0x028A6C
var R_IA_MULTI_VGT_PARAM     = 0x30960;  # UConfig (Mesa 0x030960)

# Stage enable + reuse.
var R_VGT_SHADER_STAGES_EN = 0xAB54; # Mesa 0x028B54
var R_VGT_REUSE_OFF        = 0xAAB4; # Mesa 0x028AB4

# Per-stage SPI inputs (FS) and outputs (VS).
var R_SPI_PS_INPUT_ENA   = 0xA6CC;   # Mesa 0x0286CC
var R_SPI_PS_INPUT_ADDR  = 0xA6D0;   # Mesa 0x0286D0
var R_SPI_PS_IN_CONTROL  = 0xA6D8;   # Mesa 0x0286D8
var R_SPI_VS_OUT_CONFIG  = 0xA6C4;   # Mesa 0x0286C4

# Depth/stencil test (we run depth-disabled, but radv still emits
# DB_SHADER_CONTROL + DB_RENDER_OVERRIDE in its preamble).
var R_DB_SHADER_CONTROL    = 0xA80C; # Mesa 0x02880C
var R_DB_HTILE_SURFACE     = 0xAABC; # Mesa 0x028ABC
var R_DB_RENDER_OVERRIDE   = 0xA00C; # Mesa 0x02800C
var R_DB_RENDER_OVERRIDE2  = 0xA010; # Mesa 0x028010

# --- Pass-target context regs (pass block, RT-extent dependent) ---

# Scissor (screen + generic). Trivial draw uses a single scissor
# matching the RT extent.
var R_PA_SC_SCREEN_SCISSOR_TL  = 0xA030;   # Mesa 0x028030
var R_PA_SC_SCREEN_SCISSOR_BR  = 0xA034;   # Mesa 0x028034
var R_PA_SC_GENERIC_SCISSOR_TL = 0xA240;   # Mesa 0x028240
var R_PA_SC_GENERIC_SCISSOR_BR = 0xA244;   # Mesa 0x028244

# Viewport (xyz scale + offset for VPORT_0).
var R_PA_CL_VPORT_XSCALE   = 0xA43C;   # Mesa 0x02843C
var R_PA_CL_VPORT_XOFFSET  = 0xA440;   # Mesa 0x028440
var R_PA_CL_VPORT_YSCALE   = 0xA444;   # Mesa 0x028444
var R_PA_CL_VPORT_YOFFSET  = 0xA448;   # Mesa 0x028448
var R_PA_CL_VPORT_ZSCALE   = 0xA44C;   # Mesa 0x02844C
var R_PA_CL_VPORT_ZOFFSET  = 0xA450;   # Mesa 0x028450
var R_PA_SC_VPORT_ZMIN_0   = 0xA2D0;   # Mesa 0x0282D0
var R_PA_SC_VPORT_ZMAX_0   = 0xA2D4;   # Mesa 0x0282D4

# Raster engine config + AA config + screen offset.
# PA_SC_RASTER_CONFIG: Cezanne has 1 SE; default 0 works.
var R_PA_SC_RASTER_CONFIG       = 0xA350;  # Mesa 0x028350
var R_PA_SC_AA_CONFIG           = 0xABE0;  # Mesa 0x028BE0
var R_PA_SU_HARDWARE_SCREEN_OFFSET = 0xA234; # Mesa 0x028234

# CB_COLOR0 — color target 0 binding. CB_COLOR0_PITCH/_SLICE were
# removed in GFX9; surface extent (MIP0_WIDTH / MIP0_HEIGHT) lives in
# CB_COLOR0_ATTRIB2 (NOT ATTRIB — earlier comments here were wrong;
# omitting ATTRIB2 was the rc.2 native-render-e2e 0x55-sentinel bug,
# fixed 2026-05-13 after gfx9.json cross-check). ATTRIB carries
# RESOURCE_TYPE / NUM_SAMPLES / COLOR_SW_MODE only.
# PA_SC_WINDOW_SCISSOR_TL/BR — radv writes both unconditionally with
# WINDOW_OFFSET_DISABLE set on TL and BR pinned at (16384,16384) so
# the rasterizer's window-scissor stage doesn't crop to 0x0 (which
# would silently drop every pixel). 0x028204 / 0x028208.
var R_PA_SC_WINDOW_SCISSOR_TL = 0xA204;  # Mesa 0x028204
var R_PA_SC_WINDOW_SCISSOR_BR = 0xA208;  # Mesa 0x028208

# Per-viewport scissor — radv sets viewport 0's scissor to wide-open
# with WINDOW_OFFSET_DISABLE on TL. Without this, the post-viewport
# scissor stage (separate from screen/window/generic) crops the
# triangle. 0x028250 / 0x028254.
var R_PA_SC_VPORT_SCISSOR_0_TL = 0xA250;  # Mesa 0x028250
var R_PA_SC_VPORT_SCISSOR_0_BR = 0xA254;  # Mesa 0x028254

# Guard-band clip / discard adjusts (4 contiguous regs starting at
# 0x028BE8). Required for the rasterizer to not hang on Cezanne and
# similar GFX9 APUs — radv writes these unconditionally in
# ac_cmdbuf.c's preamble. Value = 1.0 as f32 bit-pattern (0x3f800000),
# meaning "no extra guard-band, clip = NDC exactly."
var R_PA_CL_GB_VERT_CLIP_ADJ = 0xABE8;  # Mesa 0x028BE8
var R_PA_CL_GB_VERT_DISC_ADJ = 0xABEC;  # Mesa 0x028BEC
var R_PA_CL_GB_HORZ_CLIP_ADJ = 0xABF0;  # Mesa 0x028BF0
var R_PA_CL_GB_HORZ_DISC_ADJ = 0xABF4;  # Mesa 0x028BF4

# Additional GFX9 preamble safety registers — second batch of the
# Cezanne bring-up. Each cited from gfx9.json + radv ac_cmdbuf.c
# preamble; without them the GFX ring can TDR on first dispatch.

# DB_DEPTH_CONTROL = 0 — explicit "no depth test, no stencil test,
# no z-write." The default state after a ring reset is undefined;
# without this an in-flight depth read can deadlock pixel waves.
var R_DB_DEPTH_CONTROL  = 0xA800;  # Mesa 0x028800

# DB_RENDER_CONTROL = 0 — explicit "no depth clear, no decompress."
var R_DB_RENDER_CONTROL = 0xA000;  # Mesa 0x028000

# PA_SU_VTX_CNTL: PIX_CENTER + ROUND_MODE=truncate. Half-pixel
# convention is the GFX9 standard for D3D-style rasterization;
# without it the rasterizer can step off-screen and hang.
# bits[0]=PIX_CENTER, bits[1:2]=ROUND_MODE.
var R_PA_SU_VTX_CNTL    = 0xABE4;  # Mesa 0x028BE4

# PA_SC_MODE_CNTL_1 = 0 — explicit walk-order / fence-size defaults.
var R_PA_SC_MODE_CNTL_1 = 0xAA4C;  # Mesa 0x028A4C

# SPI_TMPRING_SIZE = 0 — explicit "no scratch ring". Without this
# the shader can wait forever for scratch slots the host never
# allocated.
var R_SPI_TMPRING_SIZE  = 0xAAE8;  # Mesa 0x028AE8

# PA_SC_CLIPRECT_RULE = 0xFFFF — allow all 16 clip-rect combinations
# (default would otherwise be 0 = reject everything → no pixels).
var R_PA_SC_CLIPRECT_RULE = 0xA20C;  # Mesa 0x02820C

# PA_SU_PRIM_FILTER_CNTL = 0 — explicit "no prim filtering."
var R_PA_SU_PRIM_FILTER_CNTL = 0xA82C;  # Mesa 0x02882C

# PA_SC_BINNER_CNTL_0 — primitive binning control. Cezanne / Picasso /
# Raven / Renoir APUs default to binning ON; if not configured the
# DPB pipeline hangs the GFX ring. CRITICAL: value 0 is *not* "off" —
# it's "BINNING_ALLOWED" (BinningMode enum entry 0). The actual disable
# values are 2 (USE_NEW_SC) or 3 (USE_LEGACY_SC). This was the rc.2
# GFX-ring 2-second TDR symptom; fixed 2026-05-13.
var R_PA_SC_BINNER_CNTL_0    = 0xAC44;  # Mesa 0x028C44

# PA_SC_BINNER_CNTL_1 — paired with CNTL_0. radv writes this
# unconditionally with MAX_ALLOC_COUNT and MAX_PRIM_PER_BATCH;
# omitting it leaves the binner with 0 allocator slots which can
# stall the DPB pipeline even when binning is "disabled" via CNTL_0.
var R_PA_SC_BINNER_CNTL_1    = 0xAC48;  # Mesa 0x028C48

# BinningMode enum (gfx9.json):
#   0 BINNING_ALLOWED                (DO NOT USE for "disabled")
#   1 FORCE_BINNING_ON
#   2 DISABLE_BINNING_USE_NEW_SC     (the value radv uses for GFX10+)
#   3 DISABLE_BINNING_USE_LEGACY_SC  (the value radv uses for GFX9)
#
# For GFX9 (Cezanne / Raven2 / Renoir family) the disable value is
# the LEGACY_SC variant, plus two paired bits:
#   bit 18 = DISABLE_START_OF_PRIM = 1
#   bit 28 = FLUSH_ON_BINNING_TRANSITION = 1 (Raven2+/Vega12/Vega20)
#
# Composed: 3 | (1 << 18) | (1 << 28) = 0x10040003.
# Cited from radv_cmd.c radv_get_disabled_binning_state() GFX9 branch.
var GFX9_BINNER_CNTL_0_DISABLED = 0x10040003;

# CNTL_1 reasonable defaults for gfx9 APU: 31 alloc slots, 1023 prim/batch.
# Encoding: MAX_ALLOC_COUNT[0:15] | MAX_PRIM_PER_BATCH[16:31].
var GFX9_BINNER_CNTL_1_DEFAULT = 0x03FF001F;

# SX (shader export) downconvert + blend-opt registers. 3 contiguous
# starting at 0x028754. Without these the SX block doesn't know how
# to convert the FS's FP32 export to RGBA8_UNORM and may stall the CB.
var R_SX_PS_DOWNCONVERT      = 0xA754;  # Mesa 0x028754
var R_SX_BLEND_OPT_EPSILON   = 0xA758;  # Mesa 0x028758
var R_SX_BLEND_OPT_CONTROL   = 0xA75C;  # Mesa 0x02875C

# VGT vertex reuse + output dealloc — required for VGT (vertex stream
# fetch) on GFX9 to not deadlock waiting on reuse / dealloc slots.
# radv writes both unconditionally in ac_cmdbuf.c.
var R_VGT_VERTEX_REUSE_BLOCK_CNTL = 0xAC58;  # Mesa 0x028C58
var R_VGT_OUT_DEALLOC_CNTL        = 0xAC5C;  # Mesa 0x028C5C

# Defaults from radv:
#   VGT_VERTEX_REUSE_BLOCK_CNTL = 14 (max reuse blocks for legacy non-NGG)
#   VGT_OUT_DEALLOC_CNTL = 16 (max dealloc slots for VS output)
#   PA_CL_GB_*_CLIP_ADJ = 0x437efe00 (≈ 254.992f) — guard-band span
#   PA_CL_GB_*_DISC_ADJ = 0x3f800000 (= 1.0f)     — discard scale
#
# THE GUARD-BAND CLIP_ADJ MUST NOT BE 1.0. Previously every register
# defaulted to 1.0f which clamped the guard band to the clip volume
# itself ([-1,1]) — fullscreen triangles with vertices at (3,-1) and
# (-1,3) fell OUTSIDE the guard band, invoking the hardware's slow-
# path clipper, which on Cezanne hangs the GFX ring → 2-second TDR.
# Captured byte-for-byte from radv `programs/diagnostics/radv_capture_triangle`
# on this exact Cezanne/Renoir (gfx90c).
# VGT_VERTEX_REUSE_BLOCK_CNTL = 30 (0x1E) — radv triangle test on
# Cezanne. Previously 14 (sourced from vkcube). Higher value = more
# vertex reuse blocks for the legacy non-NGG path.
var GFX9_VGT_VERTEX_REUSE_BLOCK = 30;
var GFX9_VGT_OUT_DEALLOC        = 16;
var GFX9_PA_CL_GB_CLIP_ADJ_F32  = 0x437efe00;  # ≈ 254.992f
var GFX9_PA_CL_GB_DISC_ADJ_F32  = 0x3f800000;  # 1.0f

var R_CB_COLOR0_BASE         = 0xAC60;  # Mesa 0x028C60
var R_CB_COLOR0_BASE_EXT     = 0xAC64;  # Mesa 0x028C64 (high bits)
var R_CB_COLOR0_ATTRIB2      = 0xAC68;  # Mesa 0x028C68
# bits[0:13]  MIP0_HEIGHT
# bits[14:27] MIP0_WIDTH
# bits[28:31] MAX_MIP
var R_CB_COLOR0_VIEW         = 0xAC6C;  # Mesa 0x028C6C
var R_CB_COLOR0_INFO         = 0xAC70;  # Mesa 0x028C70
var R_CB_COLOR0_ATTRIB       = 0xAC74;  # Mesa 0x028C74
var R_CB_COLOR0_DCC_CONTROL  = 0xAC78;  # Mesa 0x028C78

# CMASK / FMASK / DCC base addresses + EXT (high bits) — even for a
# trivial uncompressed RT, the CB hardware's compression-sidekick
# state-machine reads these as base addresses on every dispatch. If
# left at the previous context's stale values, the CB attempts to
# fetch CMASK/FMASK metadata from a stale VA → VM fault → GFX-ring
# hang. radv emits all four as part of the 11-reg CB_COLOR0 sequence
# at draw time (gfx9_emit_fb_color_state). Setting them explicitly
# to 0 = "no compression / no FMASK / no DCC" — the matching
# CB_COLOR0_INFO bits already disable compression so the CB skips
# the prefetch path entirely.
var R_CB_COLOR0_CMASK         = 0xAC7C;  # Mesa 0x028C7C
var R_CB_COLOR0_CMASK_BASE_EXT = 0xAC80; # Mesa 0x028C80
var R_CB_COLOR0_FMASK         = 0xAC84;  # Mesa 0x028C84
var R_CB_COLOR0_FMASK_BASE_EXT = 0xAC88; # Mesa 0x028C88
var R_CB_COLOR0_DCC_BASE      = 0xAC94;  # Mesa 0x028C94
var R_CB_COLOR0_DCC_BASE_EXT  = 0xAC98;  # Mesa 0x028C98

# MRT0 effective pitch — encodes the RT's effective pitch in pixel
# elements minus one. For a linear 256-wide RT this is 255.
# Comes from gfx9-specific R_0287A0 set last in radv's gfx9 path.
var R_CB_MRT0_EPITCH          = 0xA7A0;  # Mesa 0x0287A0

# --- UConfig graphics regs ---

# Primitive-list shape + instance count. UConfig regs encode at
# their real MMIO addresses (no shorthand); native_pm4_set_uconfig_*
# strips the 0x30000 base when emitting wire form.
var R_VGT_PRIMITIVE_TYPE = 0x30908;   # Mesa 0x030908
var R_VGT_NUM_INSTANCES  = 0x30934;   # Mesa 0x030934

# --- Pipeline-static value constants (from design doc + gfx9.json) ---

# Write all four channels of color target 0 (RGBA mask = 0xF in low
# 4 bits). Used in CB_TARGET_MASK.
var GFX9_CB_TARGET_MASK_RGBA = 0xF;

# Output enable for color target 0, all four channels. Used in
# CB_SHADER_MASK; bit pattern is identical to CB_TARGET_MASK for
# our single-RT trivial pipeline.
var GFX9_CB_SHADER_MASK_RGBA0 = 0xF;

# CB_COLOR_CONTROL: NORMAL ROP, no compression, blend dest = NONE.
# Bit pattern 0xCC matches the design doc; encodes ROP=0xCC (NORMAL),
# DEFAULT_BLEND_OP_DEST=0 (no compression source).
var GFX9_CB_COLOR_CONTROL_NORMAL = 0xCC;

# Blend disabled — write source verbatim into RT, no per-channel mask.
var GFX9_CB_BLEND_DISABLED = 0x0;

# PA_SU_SC_MODE_CNTL = 0x4 — cull none, POLY_MODE=disabled (filled
# triangles). radv emits 0x240 for the same intent but with extra
# bits 6+9 set (PROVOKING_VTX_LAST + VTX_WINDOW_OFFSET_ENABLE or
# similar). 0x4 worked for the no-hang verification; 0x240 produced
# black pixels (the extra bits may toggle attribute routing).
var GFX9_PA_SU_SC_MODE_CULL_NONE = 0x4;

# VGT_SHADER_STAGES_EN: VS+PS only, no tess, no GS, no NGG.
# Bit 16 = VS_EN = VS_STAGE_REAL — REQUIRED. Without it the VGT
# treats the vertex stage as off and waits forever for vertex
# output that can't arrive → 2-second GFX TDR. Captured byte-for-
# byte from radv on Cezanne (vkcube preamble: 0x00010000).
# All other stage bits (LS/HS/ES/GS/etc.) stay 0 for VS+PS only.
var GFX9_VGT_SHADER_STAGES_VS_PS = 0x00010000;

# PA_CL_CLIP_CNTL = 0x90000 — DX_CLIP_SPACE_DEF=1 + lower clip bits.
# radv emits 0x01080000 (DX_CLIP_SPACE_DEF + DX_LINEAR_ATTR_CLIP_ENA).
# 0x90000 was mabda's original. The radv value also passed the no-hang
# test but produced black pixels.
var GFX9_PA_CL_CLIP_CNTL_DEFAULT = 0x90000;

# VGT_PRIMITIVE_TYPE: PT_TRIANGLELIST = 4 (independent triangles, no strip).
var GFX9_VGT_PRIMITIVE_TYPE_TRIANGLELIST = 0x4;

# VGT_NUM_INSTANCES: single instance.
var GFX9_VGT_NUM_INSTANCES_ONE = 0x1;

# SPI_PS_INPUT_ENA / _ADDR: minimum non-zero pattern. Bit 0 =
# PERSP_SAMPLE_ENA enables sample-rate perspective correction.
# A zero value reportedly causes hangs on some GFX9 firmware
# (design doc § "Required register state"); 0x2 is the radv-tested
# safe minimum. Step 6.5(b) ships this as the value; revisit if
# the trivial PS proves to be a hang case.
# SPI_PS_INPUT_ENA = 0x2 — bit 1 = PERSP_CENTER_ENA. Either PERSP_CENTER
# (0x2) or LINEAR_CENTER (0x80) satisfies the "at-least-one-must-be-set"
# hang quirk. PERSP_CENTER works on Cezanne (verified post-EXP-fix);
# LINEAR_CENTER also passed the no-hang test but produced black pixels
# (the SX may need extra companion bits when using linear interp).
var GFX9_SPI_PS_INPUT_HANG_QUIRK_MIN = 0x2;

# SX_MRT0..7_BLEND_OPT — per-MRT blend optimization hints. radv emits
# 0x06000600 for all 8 MRTs even when only MRT0 is bound. Without these
# the SX block can stall waiting on blend-opt info that never arrives.
# Captured from radv triangle reference. 8 contiguous regs at 0xA760
# (Mesa 0x028760..0x02877C).
var R_SX_MRT0_BLEND_OPT = 0xA760;  # Mesa 0x028760
var GFX9_SX_MRT_BLEND_OPT_DEFAULT = 0x06000600;

# SPI_VS_OUT_CONFIG.NUM_INTERP = 0 — no varyings between VS and PS.
# bit 0 = VS_HALF_PACK = 0; bits 1-5 = VS_EXPORT_COUNT = 0
# (1 export = pos0 only, no params).
var GFX9_SPI_VS_OUT_CONFIG_NO_VARYING = 0x0;

# DB_SHADER_CONTROL: KILL_ENABLE=0, Z_ORDER=EARLY_Z_THEN_LATE_Z (1),
# DEPTH_BEFORE_SHADER=0. Trivial PS does no depth/stencil writes;
# minimum pattern from radv.
var GFX9_DB_SHADER_CONTROL_DEFAULT = 0x10;

# CB_COLOR_CONTROL composed value: MODE = CB_NORMAL (1, bits 4-6) +
# ROP3 = 0xCC (COPY_SOURCE, bits 16-23). Caught in 6.5(a) cross-check
# that the design doc's "0xCC" was field-shorthand, not the encoded
# register value: 0xCC at bit 0 would mis-set DEGAMMA_ENABLE + MODE.
# Authoritative composition:
#   MODE  = CB_NORMAL << 4    = 0x10
#   ROP3  = 0xCC << 16        = 0xCC0000
#   union                     = 0xCC0010
var GFX9_CB_COLOR_CONTROL_NORMAL_COPY = 0xCC0010;

# CB_COLOR0_INFO bit-composed value for a linear RGBA8-unorm RT:
#   FORMAT[2:6]               = COLOR_8_8_8_8 (0xA) << 2  = 0x28
#   NUMBER_TYPE[8:10]         = NUMBER_UNORM (0)          = 0
#   COMP_SWAP[11:12]          = SWAP_STD (0)              = 0
#   FMASK_COMPRESSION_DISABLE[26] = 1                     = 0x04000000
#   DCC_ENABLE[28]            = 0
# Captured from radv triangle reference (`programs/diagnostics/radv_capture_triangle`)
# on this exact Cezanne — radv emits 0x00028028 for an RGBA8_UNORM RT.
# Bits 3+5 = FORMAT_LO = COLOR_8_8_8_8. Bits 15+17 = unidentified
# (likely NUMBER_TYPE_HI + COMP_SWAP_HI) that route the FS's RGBA
# export lanes correctly to the CB's storage layout. Mabda's previous
# value 0x04000028 (bit 26 instead of 15+17) had the right FORMAT but
# missing channel-routing bits — the CB wrote zeros instead of the FS's
# exported color even after the TDR was fixed.
var GFX9_CB_COLOR0_INFO_RGBA8_UNORM = 0x00028028;

# CB_COLOR0_ATTRIB for 2D linear RGBA8 single-sample:
#   COLOR_SW_MODE[18:22] = 0    (linear surface, no swizzle)
#   NUM_SAMPLES[12:14]   = 0    (1 sample = 0)
#   NUM_FRAGMENTS[15:16] = 0
#   RESOURCE_TYPE[28:29] = 1    (2D image)
# union = 1 << 28 = 0x10000000.
# RESOURCE_TYPE encoding cited from radv source pattern; field
# enum was not in the gfx9.json snapshot, so flag for HW verify.
var GFX9_CB_COLOR0_ATTRIB_2D_LINEAR_RGBA8 = 0x10000000;

# ================================================================
# v3.2 TS.2 — GFX9 sampler (S#) descriptor + format->IMG table
# ================================================================
# Re-introduces the sampler/image-format descriptor infra the v3.1 mipmap
# PIVOT deleted, so native AMD can SAMPLE textures (Phase TS). Pure byte
# builders + a format table — no HW here; the bytes are HW-verified at the
# TS.5 sampling MVP. Every field/enum value is cited from the authoritative
# Mesa register DB src/amd/registers/gfx9.json (per
# feedback_gfx9_register_authoritative_source): `enums` for the value
# tables, `register_types` for the bit layouts.

# --- GFX9 image data/num-format enum values (gfx9.json enums
#     IMG_DATA_FORMAT / IMG_NUM_FORMAT). ---
var GFX9_IMG_DATA_FORMAT_8_8_8_8   = 10;
var GFX9_IMG_DATA_FORMAT_ETC2_RGB  = 24;
var GFX9_IMG_DATA_FORMAT_ETC2_RGBA = 25;
var GFX9_IMG_DATA_FORMAT_BC1       = 35;
var GFX9_IMG_DATA_FORMAT_BC3       = 37;
var GFX9_IMG_DATA_FORMAT_BC4       = 38;
var GFX9_IMG_DATA_FORMAT_BC5       = 39;
var GFX9_IMG_DATA_FORMAT_BC6       = 40;
var GFX9_IMG_DATA_FORMAT_BC7       = 41;
var GFX9_IMG_DATA_FORMAT_ASTC_2D_LDR = 46;
var GFX9_IMG_NUM_FORMAT_UNORM = 0;
var GFX9_IMG_NUM_FORMAT_FLOAT = 7;
var GFX9_IMG_NUM_FORMAT_SRGB  = 9;

# Map a MABDA_TEXFMT_* id to a packed GFX9 (data_format, num_format) pair:
# `(data_format << 8) | num_format`. Returns -1 for an unsupported id (the
# T# builder / create rejects). The native T# analog of mabda_texfmt_to_wgpu.
# BC6H is unsigned-float HDR (NUM_FORMAT_FLOAT); the rest decode UNORM. The
# three ASTC ids all map to GFX9's single ASTC_2D_LDR data-format — ASTC
# per-block-size + HW-decode presence on Cezanne is a TS.8 verification item.
fn native_gfx9_texfmt_to_img_format(fmt): i64 {
    if (fmt == MABDA_TEXFMT_RGBA8) {
        return (GFX9_IMG_DATA_FORMAT_8_8_8_8 << 8) | GFX9_IMG_NUM_FORMAT_UNORM;
    }
    if (fmt == MABDA_TEXFMT_BC1) {
        return (GFX9_IMG_DATA_FORMAT_BC1 << 8) | GFX9_IMG_NUM_FORMAT_UNORM;
    }
    if (fmt == MABDA_TEXFMT_BC3) {
        return (GFX9_IMG_DATA_FORMAT_BC3 << 8) | GFX9_IMG_NUM_FORMAT_UNORM;
    }
    if (fmt == MABDA_TEXFMT_BC4) {
        return (GFX9_IMG_DATA_FORMAT_BC4 << 8) | GFX9_IMG_NUM_FORMAT_UNORM;
    }
    if (fmt == MABDA_TEXFMT_BC5) {
        return (GFX9_IMG_DATA_FORMAT_BC5 << 8) | GFX9_IMG_NUM_FORMAT_UNORM;
    }
    if (fmt == MABDA_TEXFMT_BC6H) {
        return (GFX9_IMG_DATA_FORMAT_BC6 << 8) | GFX9_IMG_NUM_FORMAT_FLOAT;
    }
    if (fmt == MABDA_TEXFMT_BC7) {
        return (GFX9_IMG_DATA_FORMAT_BC7 << 8) | GFX9_IMG_NUM_FORMAT_UNORM;
    }
    if (fmt == MABDA_TEXFMT_ETC2_RGB8) {
        return (GFX9_IMG_DATA_FORMAT_ETC2_RGB << 8) | GFX9_IMG_NUM_FORMAT_UNORM;
    }
    if (fmt == MABDA_TEXFMT_ETC2_RGBA8) {
        return (GFX9_IMG_DATA_FORMAT_ETC2_RGBA << 8) | GFX9_IMG_NUM_FORMAT_UNORM;
    }
    if (fmt == MABDA_TEXFMT_ASTC_4X4) {
        return (GFX9_IMG_DATA_FORMAT_ASTC_2D_LDR << 8) | GFX9_IMG_NUM_FORMAT_UNORM;
    }
    if (fmt == MABDA_TEXFMT_ASTC_6X6) {
        return (GFX9_IMG_DATA_FORMAT_ASTC_2D_LDR << 8) | GFX9_IMG_NUM_FORMAT_UNORM;
    }
    if (fmt == MABDA_TEXFMT_ASTC_8X8) {
        return (GFX9_IMG_DATA_FORMAT_ASTC_2D_LDR << 8) | GFX9_IMG_NUM_FORMAT_UNORM;
    }
    return 0 - 1;
}

# Unpack the (data_format, num_format) pair from native_gfx9_texfmt_to_img_format.
# DATA_FORMAT is the 6-bit IMG field, NUM_FORMAT the 4-bit field.
fn native_img_data_format(packed): i64 { return (packed >> 8) & 0x3F; }
fn native_img_num_format(packed): i64 { return packed & 0xF; }

# --- mabda sampler intent (backend-agnostic). The native builder maps
#     these to GFX9 enums; the wgpu filler (TS.3) to WGPU{Filter,Address}Mode. ---
var NATIVE_SAMP_FILTER_POINT    = 0;
var NATIVE_SAMP_FILTER_BILINEAR = 1;
var NATIVE_SAMP_ADDR_CLAMP      = 0;   # clamp-to-edge
var NATIVE_SAMP_ADDR_WRAP       = 1;   # repeat

# --- GFX9 sampler-field enum values (gfx9.json enums SQ_TEX_CLAMP /
#     SQ_TEX_XY_FILTER / SQ_TEX_{Z,MIP}_FILTER / SQ_IMG_FILTER_TYPE). ---
var GFX9_SQ_TEX_WRAP               = 0;   # SQ_TEX_CLAMP.SQ_TEX_WRAP
var GFX9_SQ_TEX_CLAMP_LAST_TEXEL   = 2;   # clamp-to-edge
var GFX9_SQ_TEX_XY_FILTER_POINT    = 0;
var GFX9_SQ_TEX_XY_FILTER_BILINEAR = 1;
var GFX9_SQ_TEX_Z_FILTER_NONE      = 0;
var GFX9_SQ_TEX_MIP_FILTER_NONE    = 0;
var GFX9_SQ_IMG_FILTER_MODE_BLEND  = 0;

# Build a 128-bit (4-dword) GFX9 S# sampler descriptor into buf at pos.
# Bit layout cited from gfx9.json register_types SQ_IMG_SAMP_WORD0..3:
#   W0: CLAMP_X[0:2] CLAMP_Y[3:5] CLAMP_Z[6:8] FILTER_MODE[29:30]
#   W1: MIN_LOD[0:11] MAX_LOD[12:23]
#   W2: XY_MAG_FILTER[20:21] XY_MIN_FILTER[22:23] Z_FILTER[24:25] MIP_FILTER[26:27]
#   W3: BORDER_COLOR_PTR[0:11] BORDER_COLOR_TYPE[30:31]
# `filter`/`addr` are NATIVE_SAMP_* intents. point+clamp is the MVP sampler
# (deterministic, CPU-verifiable); bilinear/wrap are field swaps. MAX_LOD =
# 0xFFF (U4.8 max) so a mipped texture can sample every level; MIP_FILTER =
# NONE keeps single-level sampling deterministic. FILTER_MODE = BLEND
# (normal, non-min/max). Returns pos + 16.  @internal
fn native_gfx9_sampler_descriptor(buf, pos, filter, addr, unnorm): i64 {
    var clamp = GFX9_SQ_TEX_WRAP;
    if (addr == NATIVE_SAMP_ADDR_CLAMP) { clamp = GFX9_SQ_TEX_CLAMP_LAST_TEXEL; }
    var xy = GFX9_SQ_TEX_XY_FILTER_POINT;
    if (filter == NATIVE_SAMP_FILTER_BILINEAR) { xy = GFX9_SQ_TEX_XY_FILTER_BILINEAR; }

    var w0 = (clamp & 0x7) | ((clamp & 0x7) << 3) | ((clamp & 0x7) << 6);
    # FORCE_UNNORMALIZED[15] (gfx9.json SQ_IMG_SAMP_WORD0) — the image_sample FS
    # (TS.7) feeds the fragment position as a texel coord, so the S# must treat
    # coords as unnormalized (Texel space) rather than [0,1].
    if (unnorm != 0) { w0 = w0 | (1 << 15); }
    w0 = w0 | ((GFX9_SQ_IMG_FILTER_MODE_BLEND & 0x3) << 29);
    var w1 = (0 & 0xFFF) | ((0xFFF & 0xFFF) << 12);   # MIN_LOD=0, MAX_LOD=max
    var w2 = ((xy & 0x3) << 20) | ((xy & 0x3) << 22);
    w2 = w2 | ((GFX9_SQ_TEX_Z_FILTER_NONE & 0x3) << 24);
    w2 = w2 | ((GFX9_SQ_TEX_MIP_FILTER_NONE & 0x3) << 26);
    var w3 = 0;
    store32(buf + pos +  0, w0);
    store32(buf + pos +  4, w1);
    store32(buf + pos +  8, w2);
    store32(buf + pos + 12, w3);
    return pos + 16;
}

# --- GFX9 image-descriptor field enum values (gfx9.json enums
#     SQ_SEL_XYZW01 / SQ_RSRC_IMG_TYPE). SW_MODE has no register enum (raw
#     5-bit field); SW_LINEAR = 0 (matches COLOR_SW_MODE=0 linear, used by
#     GFX9_CB_COLOR0_ATTRIB_2D_LINEAR_RGBA8). The tiled SW_64KB_S value is
#     an addrlib mode pinned at TS.6 with the swizzle transform. ---
var GFX9_SQ_SEL_0       = 0;
var GFX9_SQ_SEL_1       = 1;
var GFX9_SQ_SEL_X       = 4;
var GFX9_SQ_SEL_Y       = 5;
var GFX9_SQ_SEL_Z       = 6;
var GFX9_SQ_SEL_W       = 7;
var GFX9_SQ_RSRC_IMG_2D = 9;
var GFX9_SW_MODE_LINEAR = 0;
# ADDR_SW_64KB_S — the 64 KiB standard-swizzle tiled mode used for compressed
# sampling (TS.7c). Value 9 matches the swizzle_mode the SDMA COPY_TILED packet
# (TS.6) tiles with, so the SDMA-written layout and the TA's read agree.
var GFX9_SW_MODE_64KB_S = 9;

# Build a 256-bit (8-dword) GFX9 T# image descriptor into buf at pos.
# base_va: GPU VA of the surface (canonical-high; the 48-bit form is stored
# as BASE_ADDRESS[47:8]). fmt: MABDA_TEXFMT_* -> GFX9 (data,num) format via
# native_gfx9_texfmt_to_img_format. sw_mode: GFX9 SW_MODE (LINEAR for
# uncompressed; a tiled mode for compressed, TS.6/7). mip_count >= 1.
# Bit layout cited from gfx9.json register_types SQ_IMG_RSRC_WORD0..6:
#   W0: BASE_ADDRESS[31:0]        = va[39:8]
#   W1: BASE_ADDRESS_HI[0:7]=va[47:40]  MIN_LOD[8:19]=0
#       DATA_FORMAT[20:25]  NUM_FORMAT[26:29]
#   W2: WIDTH[0:13]=w-1   HEIGHT[14:27]=h-1
#   W3: DST_SEL_X[0:2] Y[3:5] Z[6:8] W[9:11] (identity RGBA = X/Y/Z/W)
#       BASE_LEVEL[12:15]=0  LAST_LEVEL[16:19]=mips-1  SW_MODE[20:24]
#       TYPE[28:31]=SQ_RSRC_IMG_2D
#   W4: DEPTH[0:12]=0  PITCH[13:28]=epitch   BC_SWIZZLE[29:31]=0
#       (epitch = w-1 for LINEAR; for a SW_64KB_S tiled compressed surface it
#        is the tile-aligned block pitch - 1 = awb-1, matching the SDMA
#        COPY_TILED epitch the surface was tiled with — TS.7c)
#   W5: MAX_MIP[28:31]=mips-1     W6/W7: 0 (no DCC / metadata)
# Returns pos + 32, or -1 if fmt is unsupported / dims invalid (caller
# rejects). NOTE: bit POSITIONS are gfx9.json-authoritative; field VALUE
# semantics (PITCH alignment, MIN_LOD/MAX_MIP) are HW-cross-checked at the
# TS.5 (linear) / TS.7c (tiled) sampling e2e on Cezanne. @internal
fn native_gfx9_image_descriptor(buf, pos, base_va, width, height,
fmt, sw_mode, mip_count, epitch): i64 {
    if (width <= 0)  { return 0 - 1; }
    if (height <= 0) { return 0 - 1; }
    var packed = native_gfx9_texfmt_to_img_format(fmt);
    if (packed < 0) { return 0 - 1; }
    var df = native_img_data_format(packed);
    var nf = native_img_num_format(packed);
    var levels = mip_count;
    if (levels < 1) { levels = 1; }
    var last_level = levels - 1;

    # W0: low 32 of (va >> 8). `>>` is logical (no sign-extend); mask to 32.
    var w0 = (base_va >> 8) & 0xFFFFFFFF;
    # W1: BASE_ADDRESS_HI[0:7] | DATA_FORMAT[20:25] | NUM_FORMAT[26:29].
    var base_hi = (base_va >> 40) & 0xFF;
    var w1 = (base_hi & 0xFF) | ((df & 0x3F) << 20) | ((nf & 0xF) << 26);
    # W2: WIDTH[0:13]=w-1, HEIGHT[14:27]=h-1.
    var w2 = ((width - 1) & 0x3FFF) | (((height - 1) & 0x3FFF) << 14);
    # W3: DST_SEL (per component count) + LAST_LEVEL + SW_MODE + TYPE=2D.
    # 4-component formats (RGBA8 / BC1 / BC3 / BC7) take identity X/Y/Z/W. The
    # single/dual-channel BC formats must override Z/W (and Y) to SEL_0/SEL_1 —
    # else the TA broadcasts the present channel(s) to RGBA (BC4 sampled (R,R,R,R)
    # instead of (R,0,0,1); HW-confirmed TS.7c-4). BC4 = R -> (X,0,0,1);
    # BC5 = RG -> (X,Y,0,1).
    var sel_x = GFX9_SQ_SEL_X;
    var sel_y = GFX9_SQ_SEL_Y;
    var sel_z = GFX9_SQ_SEL_Z;
    var sel_w = GFX9_SQ_SEL_W;
    if (fmt == MABDA_TEXFMT_BC4) {
        sel_y = GFX9_SQ_SEL_0; sel_z = GFX9_SQ_SEL_0; sel_w = GFX9_SQ_SEL_1;
    }
    if (fmt == MABDA_TEXFMT_BC5) {
        sel_z = GFX9_SQ_SEL_0; sel_w = GFX9_SQ_SEL_1;
    }
    # ETC2_RGB is 3-channel (no alpha — ETC2_RGBA is the separate alpha variant),
    # so W must force SEL_1; identity W would broadcast B into alpha (the BC4
    # broadcast behavior). X/Y/Z stay identity (R/G/B all present). (v3.2 TS.8)
    if (fmt == MABDA_TEXFMT_ETC2_RGB8) {
        sel_w = GFX9_SQ_SEL_1;
    }
    var w3 = (sel_x & 0x7) | ((sel_y & 0x7) << 3);
    w3 = w3 | ((sel_z & 0x7) << 6) | ((sel_w & 0x7) << 9);
    w3 = w3 | ((last_level & 0xF) << 16) | ((sw_mode & 0x1F) << 20);
    w3 = w3 | ((GFX9_SQ_RSRC_IMG_2D & 0xF) << 28);
    # W4: PITCH[13:28] = epitch (caller supplies: w-1 for LINEAR, awb-1 tiled).
    var w4 = (epitch & 0xFFFF) << 13;
    # W5: MAX_MIP[28:31].
    var w5 = (last_level & 0xF) << 28;
    store32(buf + pos +  0, w0);
    store32(buf + pos +  4, w1);
    store32(buf + pos +  8, w2);
    store32(buf + pos + 12, w3);
    store32(buf + pos + 16, w4);
    store32(buf + pos + 20, w5);
    store32(buf + pos + 24, 0);
    store32(buf + pos + 28, 0);
    return pos + 32;
}

# --- backend_native_pm4.cyr ---

# @internal — native GPU backend, PM4 packet builders + composers
# backend_native_pm4.cyr — pure-byte PM4 stream construction
#
# Split out from backend_native.cyr at v3 rc.2 (audit toolchain item).
# This file owns:
#   - PM4 packet primitives: pkt3 header, set_sh_reg, set_uconfig_reg,
#     set_context_reg, draw_index_auto, dispatch_direct, acquire_mem,
#     event_write, nop. Each takes a (buf, pos, ...) shape and returns
#     the new pos after writing N dwords.
#   - IT_* opcode constants and R_COMPUTE_* register addresses (the
#     compute-side registers; graphics-side R_VGT_*/R_PA_*/etc. live in
#     backend_native_shaders.cyr).
#   - Compute composer: native_pm4_build_compute_store_deadbeef — emits
#     the full PM4 stream for the v3 Step 4a store-DEADBEEF test fixture.
#   - Render composer: native_pm4_build_render_pipeline_sh / _ctx /
#     _pass_target / _draw_tail / native_pm4_build_render_clear_triangle
#     — the clear-triangle stream for v3 Phase C render.
#
# Depends on backend_native_shaders.cyr for R_*/GFX9_* graphics-register
# addresses + value minimums. No syscalls; no AMDGPU ioctl dependency.
# Included AFTER shaders.cyr so the composer fns can resolve those names.

# ================================================================
# v3 Phase B.3.b — PM4 packet builder (GFX9 / Vega, target Cezanne)
# ================================================================
# Packet format reference: AMD GCN3 ISA docs (public) + Mesa's
# src/amd/common/sid.h. AMD does not publish a current PM4 manual —
# Mesa is the de-facto spec.
#
# Type-3 packet dword format (32-bit, little-endian):
#   bits 0-7   — predicate (0 = unconditional)
#   bits 8-15  — IT_* opcode
#   bits 16-29 — count (N-1 where N = data-dword count after header)
#   bits 30-31 — type (must be 3)
#
# IT_SET_SH_REG payload:
#   +0: register offset (from 0xB000, divided by 4)
#   +4: register value (first; more values follow for contiguous runs)
#
# IT_DISPATCH_DIRECT payload:
#   +0: COMPUTE_DIM_X (workgroup count in x)
#   +4: COMPUTE_DIM_Y
#   +8: COMPUTE_DIM_Z
#   +12: COMPUTE_DISPATCH_INITIATOR (bit 0 = COMPUTE_SHADER_EN)

# Opcodes
var IT_NOP              = 0x10;
var IT_SET_SH_REG       = 0x76;
var IT_SET_CONTEXT_REG  = 0x69;
var IT_DISPATCH_DIRECT  = 0x15;
var IT_DRAW_INDEX_AUTO  = 0x2D;
var IT_ACQUIRE_MEM      = 0x58;
var IT_RELEASE_MEM      = 0x49;
var IT_EVENT_WRITE      = 0x46;
var IT_NUM_INSTANCES    = 0x2F;  # dedicated PKT3 for VGT_NUM_INSTANCES
var IT_PFP_SYNC_ME      = 0x42;  # PFP wait for ME drain
var IT_SET_UCONFIG_REG  = 0x79;
var IT_CONTEXT_CONTROL  = 0x28;  # Disable HW context-state shadowing

# SH-register offsets (byte addresses in MMIO space). The SH_REG base
# is 0xB000; IT_SET_SH_REG takes `(byte_offset - 0xB000) / 4`.
# Covered by native_sh_reg_offset() helper.
# Register offsets verified by AMD_DEBUG=ib dump of Mesa rusticl
# compute dispatch on this exact Cezanne APU (gfx90c). The PGM_LO/HI
# and RSRC1/2 positions I had previously were wrong by an entire
# register — PGM_LO at 0xB830 (not 0xB848), with every register in
# the block shifted. B.3.d still worked because s_endpgm is tolerant
# of garbage pipeline state.
var R_COMPUTE_DISPATCH_INITIATOR      = 0xB800;
var R_COMPUTE_START_X                 = 0xB810;
var R_COMPUTE_START_Y                 = 0xB814;
var R_COMPUTE_START_Z                 = 0xB818;
var R_COMPUTE_NUM_THREAD_X            = 0xB81C;
var R_COMPUTE_NUM_THREAD_Y            = 0xB820;
var R_COMPUTE_NUM_THREAD_Z            = 0xB824;
var R_COMPUTE_PGM_LO                  = 0xB830;
var R_COMPUTE_PGM_HI                  = 0xB834;
var R_COMPUTE_PGM_RSRC1               = 0xB848;
var R_COMPUTE_PGM_RSRC2               = 0xB84C;
var R_COMPUTE_RESOURCE_LIMITS         = 0xB854;
var R_COMPUTE_STATIC_THREAD_MGMT_SE0  = 0xB858;
var R_COMPUTE_STATIC_THREAD_MGMT_SE1  = 0xB85C;
var R_COMPUTE_TMPRING_SIZE            = 0xB860;
var R_COMPUTE_STATIC_THREAD_MGMT_SE2  = 0xB864;
var R_COMPUTE_STATIC_THREAD_MGMT_SE3  = 0xB868;
var R_COMPUTE_USER_DATA_0        = 0xB900;
# COMPUTE_USER_DATA_1..15 follow in 4-byte increments up to 0xB93C.

var PM4_SH_REG_BASE = 0xB000;
var PM4_CONTEXT_REG_BASE = 0xA000;
var PM4_UCONFIG_REG_BASE = 0x30000;

# GFX9 UCONFIG registers we program in the queue preamble.
var R_CP_COHER_START_DELAY = 0x301EC;
# Texture addressing border-color base. Mesa rusticl programs these
# in its preamble even for shaders that don't sample textures.
var R_TA_CS_BC_BASE_ADDR    = 0x30E00;
var R_TA_CS_BC_BASE_ADDR_HI = 0x30E04;

# Dispatch initiator: minimum bits to launch a shader.
# COMPUTE_SHADER_EN at bit 0 triggers the dispatch.
var COMPUTE_DISPATCH_INITIATOR_MIN = 0x1;

# Encode a type-3 PM4 header. `count` is the number of data dwords
# that follow the header (kernel wants count-1 in the bit field).
# `count` must be ≥ 1 and ≤ 0x4000.
fn native_pm4_pkt3_header(opcode, count, predicate): i64 {
    var d = 3 & 3;                     # type
    var c = (count - 1) & 0x3FFF;      # count field (N-1)
    var o = opcode & 0xFF;             # opcode
    var p = predicate & 0xFF;          # predicate
    return (d * 0x40000000) | (c * 0x10000) | (o * 0x100) | p;
}

# Convert a register byte-offset into the SH_REG form the SET_SH_REG
# packet expects: `(offset - 0xB000) / 4`.
fn native_sh_reg_offset(byte_offset): i64 {
    return (byte_offset - PM4_SH_REG_BASE) / 4;
}

# Convert a context-register byte-offset into the SET_CONTEXT_REG
# wire form: `(offset - 0xA000) / 4`. Context registers cover the
# rasterizer/viewport/CB target/DB depth state — graphics-only,
# distinct from SH (shader) and UConfig (top-level chip state).
fn native_context_reg_offset(byte_offset): i64 {
    return (byte_offset - PM4_CONTEXT_REG_BASE) / 4;
}

# Emit a SET_SH_REG packet for `n` contiguous registers starting at
# `byte_offset`. Writes header + register-offset dword + n value
# dwords into `buf` starting at `pos`. `values` points to an array
# of n u32 values. Returns the new position (pos + 8 + 4*n bytes,
# i.e., position after the last dword written).
fn native_pm4_set_sh_reg(buf, pos, byte_offset, n, values): i64 {
    # PKT3 count: `n + 1` data dwords (offset + n values); bit-field
    # stores count - 1 = n.
    store32(buf + pos, native_pm4_pkt3_header(IT_SET_SH_REG, n + 1, 0));
    pos = pos + 4;
    store32(buf + pos, native_sh_reg_offset(byte_offset));
    pos = pos + 4;
    var i = 0;
    while (i < n) {
        store32(buf + pos, load32(values + i * 4));
        pos = pos + 4;
        i = i + 1;
    }
    return pos;
}

# Convenience for setting a single SH register — the common case in
# compute dispatch setup. Returns new position.
fn native_pm4_set_sh_reg_one(buf, pos, byte_offset, value): i64 {
    var one[4];
    store32(&one, value);
    return native_pm4_set_sh_reg(buf, pos, byte_offset, 1, &one);
}

# Emit a SET_UCONFIG_REG packet for a single register. UCONFIG regs
# are the chip-wide "this register applies to the whole GPU, not a
# specific shader" space — used for things like CP_COHER_START_DELAY
# and TA_CS_BC_BASE_ADDR that radv emits in its queue preamble.
# Packet: header + (offset - 0x30000)/4 + value = 3 dwords.
fn native_pm4_set_uconfig_reg_one(buf, pos, byte_offset, value): i64 {
    store32(buf + pos, native_pm4_pkt3_header(IT_SET_UCONFIG_REG, 2, 0));
    store32(buf + pos + 4, (byte_offset - PM4_UCONFIG_REG_BASE) / 4);
    store32(buf + pos + 8, value);
    return pos + 12;
}

# Emit a SET_UCONFIG_REG packet for two consecutive registers. `values`
# points to two u32s. Packet: header + reg_offset + 2 values = 4 dwords.
fn native_pm4_set_uconfig_reg_pair(buf, pos, byte_offset, values): i64 {
    store32(buf + pos, native_pm4_pkt3_header(IT_SET_UCONFIG_REG, 3, 0));
    store32(buf + pos + 4, (byte_offset - PM4_UCONFIG_REG_BASE) / 4);
    store32(buf + pos + 8,  load32(values + 0));
    store32(buf + pos + 12, load32(values + 4));
    return pos + 16;
}

# ================================================================
# v3 Step 6.4 — context-register + draw PM4 builders (Phase C)
# ================================================================
# SET_CONTEXT_REG (opcode 0x69) writes to the graphics-only context
# register file (rasterizer / viewport / CB color-target / DB depth-
# target state). Wire format mirrors SET_SH_REG / SET_UCONFIG_REG:
# header + reg_offset + N values; reg_offset is dword-relative to
# PM4_CONTEXT_REG_BASE = 0xA000.
#
# DRAW_INDEX_AUTO (opcode 0x2D) kicks a vertex+fragment dispatch on
# the GFX ring with auto-generated vertex IDs (0..vertex_count-1),
# no index buffer required. The "auto" source-select is what makes
# the first cut tractable — no VBO binding, no index buffer.
#
# Both opcodes will be byte-exact-validated against radv's output
# (AMD_DEBUG=ib) in Step 6.5 when we compose the full clear-triangle
# PM4 stream.

# Multi-register SET_CONTEXT_REG: header + reg_offset + n values.
# Packet body length = n + 1 dwords.
fn native_pm4_set_context_reg(buf, pos, byte_offset, n, values): i64 {
    store32(buf + pos, native_pm4_pkt3_header(IT_SET_CONTEXT_REG, n + 1, 0));
    pos = pos + 4;
    store32(buf + pos, native_context_reg_offset(byte_offset));
    pos = pos + 4;
    var i = 0;
    while (i < n) {
        store32(buf + pos, load32(values + i * 4));
        pos = pos + 4;
        i = i + 1;
    }
    return pos;
}

# Single-register convenience: SET_CONTEXT_REG with one value.
fn native_pm4_set_context_reg_one(buf, pos, byte_offset, value): i64 {
    store32(buf + pos, native_pm4_pkt3_header(IT_SET_CONTEXT_REG, 2, 0));
    store32(buf + pos + 4, native_context_reg_offset(byte_offset));
    store32(buf + pos + 8, value);
    return pos + 12;
}

# Pair convenience: SET_CONTEXT_REG with two consecutive registers.
# Useful for things like CB_COLOR0_BASE + _PITCH or PA_SC_SCREEN_SCISSOR_TL + _BR.
fn native_pm4_set_context_reg_pair(buf, pos, byte_offset, values): i64 {
    store32(buf + pos, native_pm4_pkt3_header(IT_SET_CONTEXT_REG, 3, 0));
    store32(buf + pos + 4, native_context_reg_offset(byte_offset));
    store32(buf + pos + 8,  load32(values + 0));
    store32(buf + pos + 12, load32(values + 4));
    return pos + 16;
}

# Emit a DRAW_INDEX_AUTO packet. `vertex_count` is the number of
# vertices the rasterizer will assemble; `draw_initiator` carries
# the SOURCE_SELECT bits + USE_OPAQUE / etc. The standard value
# for auto-index draws is 0x02 (DI_SRC_SEL_AUTO_INDEX in bits[1:0]).
# Packet shape: header + 2 data dwords. count = 2.
fn native_pm4_draw_index_auto(buf, pos, vertex_count, draw_initiator): i64 {
    store32(buf + pos, native_pm4_pkt3_header(IT_DRAW_INDEX_AUTO, 2, 0));
    store32(buf + pos + 4, vertex_count);
    store32(buf + pos + 8, draw_initiator);
    return pos + 12;
}

# Specific context-register addresses (R_PA_SC_*, R_CB_COLOR0_*,
# etc.) are deferred to Step 6.5 (see docs/development/roadmap.md) — those values get verified
# byte-exact against radv's AMD_DEBUG=ib output for an equivalent
# clear-triangle dispatch. The Phase B.4 protocol applies: don't
# claim a register address is correct until a working hardware
# diff confirms it. The builders above are the load-bearing part
# of Step 6.4; Step 6.5 supplies the addresses they'll be called
# with.

# DRAW_INDEX_AUTO source-select constants. See
# docs/proposals/v3-native-render-design.md § PM4 packet families.
var DI_SRC_SEL_AUTO_INDEX = 0x02;

# Emit a DISPATCH_DIRECT packet. Kicks the compute dispatch with the
# given workgroup counts and the provided initiator mask (typically
# COMPUTE_DISPATCH_INITIATOR_MIN). Returns new position.
fn native_pm4_dispatch_direct(buf, pos, dim_x, dim_y, dim_z, initiator): i64 {
    # 4 data dwords: dim_x, dim_y, dim_z, initiator. count = 4.
    # Low byte of header is shader_type (2 = compute), not predicate.
    # Mesa emits 0xc0031502 — verified via AMD_DEBUG=ib dump.
    store32(buf + pos, native_pm4_pkt3_header(IT_DISPATCH_DIRECT, 4, 2));
    pos = pos + 4;
    store32(buf + pos, dim_x); pos = pos + 4;
    store32(buf + pos, dim_y); pos = pos + 4;
    store32(buf + pos, dim_z); pos = pos + 4;
    store32(buf + pos, initiator); pos = pos + 4;
    return pos;
}

# Emit an ACQUIRE_MEM packet that invalidates the shader I-cache,
# K-cache, and TC (texture / L2) caches. Per ROCT-Thunk kfdtest,
# this is mandatory before a compute dispatch on GFX9 — without it
# the I-cache can return stale bytes and the SQ decodes garbage
# as an "illegal opcode". Packet format:
#   +0  PKT3 header (opcode IT_ACQUIRE_MEM, count=5+1 data dwords)
#   +4  coher_cntl (cache-invalidate action bits)
#   +8  coher_size_lo (bytes to invalidate; 0xFFFFFFFF = everything)
#   +12 coher_size_hi (24-bit mask for GFX9)
#   +16 coher_base_lo (base VA; 0 = start from 0)
#   +20 coher_base_hi
#   +24 poll_interval (cycles between state-check; 0x0A standard)
# Total: 7 dwords (28 bytes). Returns new pos.
fn native_pm4_acquire_mem_full_invalidate(buf, pos): i64 {
    # Compute-ring shape (shader_type=2). Calls this helper from
    # gfx-ring code (render) routed the CP coherence ops to the
    # compute cache hierarchy instead of CB/DB — Cezanne's GFX ring
    # then hung on FS export through a stale graphics cache (rc.2
    # 0x55-sentinel + 2-second TDR). Fixed 2026-05-13 by routing the
    # render path through `_for_gfx_ring` (shader_type=0). Compute
    # callers keep the legacy shape via this helper.
    return native_pm4_acquire_mem_full_invalidate_for_ring(buf, pos, 2);
}

# Graphics-ring variant: shader_type=0 → CP coherence ops invalidate
# the CB / DB / SX / VS / PS caches that the GFX ring actually uses.
fn native_pm4_acquire_mem_full_invalidate_for_gfx_ring(buf, pos): i64 {
    return native_pm4_acquire_mem_full_invalidate_for_ring(buf, pos, 0);
}

# Internal — parameterized by shader_type (0 = graphics, 2 = compute).
# Both rings use the same coher_cntl mask (full invalidate) and poll
# interval; only the PKT3 header low byte differs.
fn native_pm4_acquire_mem_full_invalidate_for_ring(buf, pos, shader_type): i64 {
    # coher_cntl = 0x28C40000. Captured byte-exact from RADV's
    # preamble IB (vkcube under `RADV_DEBUG=dumpibs` on the same
    # Renoir / Cezanne hardware, 2026-05-13). Sets:
    #   bit 18 SH_ICACHE_ACTION_ENA
    #   bit 22 TCL1_ACTION_ENA
    #   bit 23 SH_KCACHE_ACTION_ENA
    #   bit 27 TC_WB_ACTION_ENA
    #   bit 29 TC_ACTION_ENA
    # Mabda previously also set bit 31 (TC_NC_ACTION_ENA — non-
    # coherent cache action) which on the GFX ring caused the CP to
    # wait on a non-coherent action that never resolved → 2-second
    # TDR. That was the rc.2 native_render_e2e 0x55-sentinel root
    # cause; fixed 2026-05-13.
    store32(buf + pos +  0, native_pm4_pkt3_header(IT_ACQUIRE_MEM, 6, shader_type));
    store32(buf + pos +  4, 0x28C40000);   # coher_cntl (no TC_NC bit)
    store32(buf + pos +  8, 0xFFFFFFFF);   # coher_size_lo
    store32(buf + pos + 12, 0x00FFFFFF);   # coher_size_hi (24 bits)
    store32(buf + pos + 16, 0);            # coher_base_lo
    store32(buf + pos + 20, 0);            # coher_base_hi
    store32(buf + pos + 24, 0x0A);         # poll_interval
    return pos + 28;
}

# GFX9 EVENT_WRITE event-type values. Sourced from Mesa
# `src/amd/registers/gfx9.json` (search for `VGT_EVENT_TYPE`) and
# cross-referenced with radv's `si_emit_*` paths in
# `src/amd/vulkan/radv_cmd_buffer.c`. The event_type goes in
# bits[5:0] of the body dword; event_index in bits[11:8].
#
# Step 6.10 prep (see docs/development/roadmap.md) — these are stand-alone primitives, not yet wired
# into the render PM4 composer. They land here so when the first
# `make test-native-render-e2e` run on Cezanne reveals "RT readback
# is the GTT sentinel; CB caches never flushed" (the documented
# Failure A in `programs/native_render_e2e.cyr`), the fix is one
# call to `native_pm4_event_write_cache_flush_and_inv` at the end
# of `native_pm4_build_render_clear_triangle`'s draw block.
var GFX9_EVENT_TYPE_CACHE_FLUSH         = 0x04;  # gfx9.json VGT_EVENT_TYPE
var GFX9_EVENT_TYPE_CACHE_FLUSH_AND_INV = 0x16;  # gfx9.json VGT_EVENT_TYPE
# Pre-draw flush events captured byte-exact from RADV's main IB
# (vkcube under RADV_DEBUG=dumpibs on the same Cezanne / Renoir).
# Without these, in-flight pixel waves from prior contexts (e.g. the
# Wayland compositor's draws) keep the pixel pipeline busy past our
# dispatch's start — the GFX ring then TDRs waiting for the pipeline
# to drain. This is the actual root cause of the rc.2
# native_render_e2e 0x55-sentinel hang; fixed 2026-05-13 after
# capturing radv's IB stream.
var GFX9_EVENT_TYPE_FLUSH_AND_INV_CB_META = 0x2E;  # gfx9.json VGT_EVENT_TYPE
var GFX9_EVENT_TYPE_FLUSH_AND_INV_DB_META = 0x2C;  # gfx9.json VGT_EVENT_TYPE
var GFX9_EVENT_TYPE_PS_PARTIAL_FLUSH      = 0x10;  # gfx9.json VGT_EVENT_TYPE
var GFX9_EVENT_INDEX_PARTIAL_FLUSH        = 0x4;   # PS_PARTIAL_FLUSH uses index 4
# PIPELINESTAT_START — radv emits this in every preamble. The GPU
# stat-counter pipeline starts counting (and unblocking dependent
# state machines) on receipt. Without it, Cezanne's pipeline may
# wait on stat-counter readiness that never fires.
var GFX9_EVENT_TYPE_PIPELINESTAT_START    = 0x19;  # gfx9.json VGT_EVENT_TYPE

# event_index encodes how the kernel/CP interprets the event:
#   0 = "other" — event_type only, no address (the EVENT_WRITE form
#                 we use here is 2-dword, just header + body).
#   5 = sample / cache_flush_ts / cache_flush_and_inv_ts — adds
#       a 64-bit address pair for timestamp / fence writeback. Used
#       by RELEASE_MEM-style flushes.
#       Deferred follow-up if a TS-style flush is needed: see docs/development/roadmap.md.
var GFX9_EVENT_INDEX_OTHER = 0x0;
var GFX9_EVENT_INDEX_TS    = 0x5;

# PKT3_PFP_SYNC_ME — forces the PFP (Prefetch Parser) to wait for the
# ME (Middle Engine) to drain pending work. Required between cache
# invalidate and the first draw, otherwise the PFP can read context
# state the ME hasn't yet committed. 2-dword packet: header + 0.
# radv emits this between RELEASE_MEM and ACQUIRE_MEM on every draw.
fn native_pm4_pfp_sync_me(buf, pos): i64 {
    store32(buf + pos + 0, native_pm4_pkt3_header(IT_PFP_SYNC_ME, 1, 0));
    store32(buf + pos + 4, 0);
    return pos + 8;
}

# PKT3_CONTEXT_CONTROL — controls HW context-state shadowing on the
# GFX ring. radv relies on the kernel-emitted preamble IB (jumped to
# via INDIRECT_BUFFER at queue init) to set this up; mabda has no such
# kernel-side preamble, so we must emit it ourselves at the start of
# every IB. Body: load_control (dw1) + shadow_control (dw2). The
# canonical "disable shadowing, load all state from packets" value is
# (0x80000000, 0x80000000) — bit 31 = LOAD_ENABLE_PIPELINE_STAT_ENABLE
# on dw1, bit 31 = SHADOW_ENABLE on dw2 (kernel sets these for the
# initial context). Cited from drivers/gpu/drm/amd/amdgpu/gfx_v9_0.c
# `gfx_v9_default_init_state[]` and Mesa's si_emit_initial_cmdbuffer.
fn native_pm4_context_control(buf, pos): i64 {
    store32(buf + pos + 0, native_pm4_pkt3_header(IT_CONTEXT_CONTROL, 2, 0));
    store32(buf + pos + 4, 0x80000000);  # load_control
    store32(buf + pos + 8, 0x80000000);  # shadow_control
    return pos + 12;
}

# Emit a PKT3_NUM_INSTANCES packet (opcode 0x2F). Per-draw replacement
# for SET_UCONFIG_REG(VGT_NUM_INSTANCES, n) — the AMD CP recognizes
# this as a draw-state hint and updates VGT internals more directly
# than the generic uconfig path. radv emits this byte-for-byte before
# every DRAW_INDEX_AUTO; mabda previously used SET_UCONFIG_REG which
# Cezanne's VGT may not pick up reliably as a per-dispatch update.
# 2-dword packet: header + instance_count.
fn native_pm4_num_instances(buf, pos, count): i64 {
    store32(buf + pos +  0, native_pm4_pkt3_header(IT_NUM_INSTANCES, 1, 0));
    store32(buf + pos +  4, count);
    return pos + 8;
}

# Emit a 2-dword EVENT_WRITE PKT3. Used for event_index = 0 events
# (no address). For TS-style events with a writeback address, use
# RELEASE_MEM or a wider EVENT_WRITE_EOP — not implemented here.
# Body dword shape: event_type in bits[5:0], event_index in
# bits[11:8] (matches Mesa `EVENT_TYPE(t) | EVENT_INDEX(i)`).
# Returns new pos.
fn native_pm4_event_write(buf, pos, event_type, event_index): i64 {
    store32(buf + pos, native_pm4_pkt3_header(IT_EVENT_WRITE, 1, 0));
    var body = (event_index << 8) | event_type;
    store32(buf + pos + 4, body);
    return pos + 8;
}

# Convenience wrapper: emit CACHE_FLUSH_AND_INV at the current
# position. The CP processes this event before the kernel's
# completion fence is written to the user-fence BO, so by the time
# the syncobj signals the RT writes are CPU-visible. Pair this with
# a draw at end-of-pass for any path that does CPU readback — the
# 6.5(b) composer doesn't include it today (matches radv's pattern
# of emitting separately at command-buffer end).
fn native_pm4_event_write_cache_flush_and_inv(buf, pos): i64 {
    return native_pm4_event_write(buf, pos,
    GFX9_EVENT_TYPE_CACHE_FLUSH_AND_INV,
    GFX9_EVENT_INDEX_OTHER);
}

# PIPELINESTAT_START — emitted by radv in every GFX preamble after the
# heavy ACQUIRE_MEM. Starts the GPU's pipeline-statistics counters and
# unblocks dependent state machines that wait on stat-counter readiness
# at context start. Without it, on Cezanne/Renoir the GFX ring can sit
# waiting on the stat-counter pipeline → 2-second TDR.
fn native_pm4_event_write_pipelinestat_start(buf, pos): i64 {
    return native_pm4_event_write(buf, pos,
    GFX9_EVENT_TYPE_PIPELINESTAT_START,
    GFX9_EVENT_INDEX_OTHER);
}

# Emit a NOP of `pad_dwords` total dwords (header + pad_dwords-1
# filler). Useful for aligning IBs to 8-dword boundaries (kernel
# requirement on some rings). Returns new position.
fn native_pm4_nop(buf, pos, pad_dwords): i64 {
    if (pad_dwords < 2) { return pos; }
    # Session 25b fix: NOP packet of `pad_dwords` total dwords needs body =
    # pad_dwords - 1, so pass count = pad_dwords - 1 to pkt3_header (which
    # subtracts one to encode count_minus_1). Prior code passed pad_dwords
    # directly, causing the on-wire header to claim body = pad_dwords (one
    # too many) — CP read 1 dw past the IB end and either hung trying to
    # fetch the missing dw or processed garbage. This silently bricked
    # every native compute submit (TDR after 10s).
    store32(buf + pos, native_pm4_pkt3_header(IT_NOP, pad_dwords - 1, 0));
    pos = pos + 4;
    var i = 1;
    while (i < pad_dwords) {
        store32(buf + pos, 0);
        pos = pos + 4;
        i = i + 1;
    }
    return pos;
}

# ================================================================
# v3 Step 4a — composed PM4 stream for the store-DEADBEEF shader
# ================================================================
# Emit the full Mesa-verified PM4 preamble + DISPATCH_DIRECT
# (workgroup count = x, y, z) + post-dispatch C0FFEE12 marker +
# trailing NOP padding to 64 dwords. Returns the byte count
# written into buf.
#
# Caller owns the BOs at shader_va / stub_va / out_va; this fn
# only emits a PM4 stream that, when submitted on the COMPUTE
# ring with those BOs in the residency list, will dispatch the
# store_deadbeef shader to write 0xDEADBEEF at out_va.
#
# The PM4 layout is byte-identical to the working
# programs/native_compute_store.cyr build — see the B.4-verified
# handoff (docs/handoff/2026-04-28-session25-b4-verified.md) for
# the full Mesa-rusticl alignment rationale.
fn native_pm4_build_compute_store_deadbeef(buf, shader_va, stub_va,
out_va, x, y, z): i64 {
    var pos = 0;
    # GFX9 PGM_LO/HI encoding: PGM_LO = (va >> 8) & 0xFFFFFFFF,
    # PGM_HI = (va >> 40) & 0xFF. HW reconstructs:
    # shader_addr = (PGM_HI << 40) | (PGM_LO << 8).
    var pgm_lo = (shader_va >> 8) & 0xFFFFFFFF;
    var pgm_hi = (shader_va >> 40) & 0xFF;
    # 1. PGM_HI.
    pos = native_pm4_set_sh_reg_one(buf, pos, R_COMPUTE_PGM_HI, pgm_hi);
    # 2. STATIC_THREAD_MGMT_SE0/SE1 — SE0 all CUs, SE1 absent on Cezanne.
    var thread_mgmt_01[8];
    store32(&thread_mgmt_01 + 0, 0xFFFFFFFF);
    store32(&thread_mgmt_01 + 4, 0);
    pos = native_pm4_set_sh_reg(buf, pos, R_COMPUTE_STATIC_THREAD_MGMT_SE0,
    2, &thread_mgmt_01);
    # 3. STATIC_THREAD_MGMT_SE2/SE3 = 0, 0 (absent on Cezanne).
    var thread_mgmt_23[8];
    store32(&thread_mgmt_23 + 0, 0);
    store32(&thread_mgmt_23 + 4, 0);
    pos = native_pm4_set_sh_reg(buf, pos, R_COMPUTE_STATIC_THREAD_MGMT_SE2,
    2, &thread_mgmt_23);
    # 4. CP_COHER_START_DELAY = 0.
    pos = native_pm4_set_uconfig_reg_one(buf, pos, R_CP_COHER_START_DELAY, 0);
    # 5. TA_CS_BC_BASE_ADDR + _HI = 0/0 (Session 25b: BC_BASE = 0 works
    # on Cezanne; the session-16 magic-VA hypothesis was falsified).
    var bc_va = 0;
    var bc_pair[8];
    store32(&bc_pair + 0, (bc_va >> 8) & 0xFFFFFFFF);
    store32(&bc_pair + 4, (bc_va >> 40) & 0xFF);
    pos = native_pm4_set_uconfig_reg_pair(buf, pos, R_TA_CS_BC_BASE_ADDR,
    &bc_pair);
    # 6. PGM_LO.
    pos = native_pm4_set_sh_reg_one(buf, pos, R_COMPUTE_PGM_LO, pgm_lo);
    # 7. PGM_RSRC1 + RSRC2 as a pair.
    var rsrc[8];
    store32(&rsrc + 0, GFX9_COMPUTE_PGM_RSRC1_MIN);
    store32(&rsrc + 4, 0x8);
    pos = native_pm4_set_sh_reg(buf, pos, R_COMPUTE_PGM_RSRC1, 2, &rsrc);
    # 8. TMPRING_SIZE.
    pos = native_pm4_set_sh_reg_one(buf, pos, R_COMPUTE_TMPRING_SIZE, 0x100);
    # 9. USER_DATA_2 + 3 — Mesa scratch V# stub VA (canonical-high).
    var user23[8];
    store32(&user23 + 0, stub_va & 0xFFFFFFFF);
    store32(&user23 + 4, (stub_va >> 32) & 0xFFFFFFFF);
    pos = native_pm4_set_sh_reg(buf, pos, R_COMPUTE_USER_DATA_0 + 8,
    2, &user23);
    # 10. USER_DATA_0 + 1 — output VA low/high.
    var user01[8];
    store32(&user01 + 0, out_va & 0xFFFFFFFF);
    store32(&user01 + 4, (out_va >> 32) & 0xFFFFFFFF);
    pos = native_pm4_set_sh_reg(buf, pos, R_COMPUTE_USER_DATA_0,
    2, &user01);
    # 11. ACQUIRE_MEM flushes I/K/L2 caches before dispatch.
    pos = native_pm4_acquire_mem_full_invalidate(buf, pos);
    # 12. RESOURCE_LIMITS = 0x140.
    pos = native_pm4_set_sh_reg_one(buf, pos,
    R_COMPUTE_RESOURCE_LIMITS, 0x140);
    # 13. NUM_THREAD_X/Y/Z = 1/1/1 (single-thread workgroup; the
    # store_deadbeef shader has only one wave).
    var nt[12];
    store32(&nt + 0, 1);
    store32(&nt + 4, 1);
    store32(&nt + 8, 1);
    pos = native_pm4_set_sh_reg(buf, pos, R_COMPUTE_NUM_THREAD_X, 3, &nt);
    # 14. DISPATCH_DIRECT with shader_type=2 (compute), workgroup
    # count = (x, y, z).
    pos = native_pm4_dispatch_direct(buf, pos, x, y, z,
    GFX9_DISPATCH_INITIATOR);
    # Session 25b diagnostic: WRITE_DATA(WR_CONFIRM=1) marker at
    # stub_va+4 = 0xC0FFEE12. Proves CP returned cleanly from
    # DISPATCH_DIRECT and continued through the IB.
    store32(buf + pos +  0, 0xC0033700);
    store32(buf + pos +  4, 0x00100500);
    store32(buf + pos +  8, (stub_va + 4) & 0xFFFFFFFF);
    store32(buf + pos + 12, ((stub_va + 4) >> 32) & 0xFFFFFFFF);
    store32(buf + pos + 16, 0xC0FFEE12);
    pos = pos + 20;
    # Pad to 64 dwords (AMDGPU cache-line alignment).
    var cur_dwords = pos / 4;
    var target_dwords = 64;
    if (cur_dwords < target_dwords) {
        pos = native_pm4_nop(buf, pos, target_dwords - cur_dwords);
    }
    return pos;
}

# N.5d-2: generic single-binding compute dispatch for a COMPILED shader. Same
# proven Cezanne scaffold as the deadbeef composer (STATIC_THREAD_MGMT / COHER /
# BC_BASE / scratch stub in s2:s3 / ACQUIRE_MEM / RESOURCE_LIMITS / WR_CONFIRM
# marker) but parameterized: rsrc1/rsrc2 from the compiler, USER_DATA_0/1 = the
# binding-0 buffer VA (the compiler's ABI: binding k → s[2k:2k+1]; k=0 here),
# NUM_THREAD_X = the kernel's LocalSize_x (so lid.x ranges 0..ntx-1 within one
# workgroup), DISPATCH grid = (gx, 1, 1). Returns the byte length (64-dword pad).
fn native_pm4_build_compute_generic(buf, shader_va, stub_va,
rsrc1, rsrc2, b0_va, ntx, gx): i64 {
    var pos = 0;
    pos = native_pm4_set_sh_reg_one(buf, pos, R_COMPUTE_PGM_HI, (shader_va >> 40) & 0xFF);
    var tm01[8];
    store32(&tm01 + 0, 0xFFFFFFFF);
    store32(&tm01 + 4, 0);
    pos = native_pm4_set_sh_reg(buf, pos, R_COMPUTE_STATIC_THREAD_MGMT_SE0, 2, &tm01);
    var tm23[8];
    store32(&tm23 + 0, 0);
    store32(&tm23 + 4, 0);
    pos = native_pm4_set_sh_reg(buf, pos, R_COMPUTE_STATIC_THREAD_MGMT_SE2, 2, &tm23);
    pos = native_pm4_set_uconfig_reg_one(buf, pos, R_CP_COHER_START_DELAY, 0);
    var bc_pair[8];
    store32(&bc_pair + 0, 0);
    store32(&bc_pair + 4, 0);
    pos = native_pm4_set_uconfig_reg_pair(buf, pos, R_TA_CS_BC_BASE_ADDR, &bc_pair);
    pos = native_pm4_set_sh_reg_one(buf, pos, R_COMPUTE_PGM_LO, (shader_va >> 8) & 0xFFFFFFFF);
    var rsrc[8];
    store32(&rsrc + 0, rsrc1);
    store32(&rsrc + 4, rsrc2);
    pos = native_pm4_set_sh_reg(buf, pos, R_COMPUTE_PGM_RSRC1, 2, &rsrc);
    pos = native_pm4_set_sh_reg_one(buf, pos, R_COMPUTE_TMPRING_SIZE, 0x100);
    # USER_DATA_2/3 = scratch V# stub (proven); USER_DATA_0/1 = binding-0 VA.
    var user23[8];
    store32(&user23 + 0, stub_va & 0xFFFFFFFF);
    store32(&user23 + 4, (stub_va >> 32) & 0xFFFFFFFF);
    pos = native_pm4_set_sh_reg(buf, pos, R_COMPUTE_USER_DATA_0 + 8, 2, &user23);
    var user01[8];
    store32(&user01 + 0, b0_va & 0xFFFFFFFF);
    store32(&user01 + 4, (b0_va >> 32) & 0xFFFFFFFF);
    pos = native_pm4_set_sh_reg(buf, pos, R_COMPUTE_USER_DATA_0, 2, &user01);
    pos = native_pm4_acquire_mem_full_invalidate(buf, pos);
    pos = native_pm4_set_sh_reg_one(buf, pos, R_COMPUTE_RESOURCE_LIMITS, 0x140);
    var nt[12];
    store32(&nt + 0, ntx);
    store32(&nt + 4, 1);
    store32(&nt + 8, 1);
    pos = native_pm4_set_sh_reg(buf, pos, R_COMPUTE_NUM_THREAD_X, 3, &nt);
    pos = native_pm4_dispatch_direct(buf, pos, gx, 1, 1, GFX9_DISPATCH_INITIATOR);
    store32(buf + pos + 0, 0xC0033700);
    store32(buf + pos + 4, 0x00100500);
    store32(buf + pos + 8, (stub_va + 4) & 0xFFFFFFFF);
    store32(buf + pos + 12, ((stub_va + 4) >> 32) & 0xFFFFFFFF);
    store32(buf + pos + 16, 0xC0FFEE12);
    pos = pos + 20;
    var cur_dwords = pos / 4;
    if (cur_dwords < 64) { pos = native_pm4_nop(buf, pos, 64 - cur_dwords); }
    return pos;
}

# N.6: generic MULTI-binding compute dispatch for a compiled shader. Lays each of
# `n_binds` storage-buffer VAs (a caller [n_binds] array of 64-bit VAs) into the
# compiler's USER_DATA ABI — binding k → USER_DATA_{2k}/{2k+1} = s[2k:2k+1] — and
# uses the compiler's RSRC1/RSRC2 verbatim (USER_SGPR = 2*n_binds, TGID enables).
# No scratch (TMPRING=0): a compiled MVP kernel does not spill, and every USER_DATA
# slot is a real binding. NUM_THREAD_{X,Y,Z} = LocalSize; grid = (gx,gy,gz) work-
# groups (the compiled kernel's WorkgroupId.y/z are enabled in rsrc2 by the ABI).
# Returns the 64-dword byte length.
fn native_pm4_build_compute_dispatch(buf, shader_va, rsrc1, rsrc2,
binds, n_binds, ntx, nty, ntz, gx, gy, gz): i64 {
    var pos = 0;
    pos = native_pm4_set_sh_reg_one(buf, pos, R_COMPUTE_PGM_HI, (shader_va >> 40) & 0xFF);
    var tm01[8];
    store32(&tm01 + 0, 0xFFFFFFFF);
    store32(&tm01 + 4, 0);
    pos = native_pm4_set_sh_reg(buf, pos, R_COMPUTE_STATIC_THREAD_MGMT_SE0, 2, &tm01);
    var tm23[8];
    store32(&tm23 + 0, 0);
    store32(&tm23 + 4, 0);
    pos = native_pm4_set_sh_reg(buf, pos, R_COMPUTE_STATIC_THREAD_MGMT_SE2, 2, &tm23);
    pos = native_pm4_set_uconfig_reg_one(buf, pos, R_CP_COHER_START_DELAY, 0);
    var bc_pair[8];
    store32(&bc_pair + 0, 0);
    store32(&bc_pair + 4, 0);
    pos = native_pm4_set_uconfig_reg_pair(buf, pos, R_TA_CS_BC_BASE_ADDR, &bc_pair);
    pos = native_pm4_set_sh_reg_one(buf, pos, R_COMPUTE_PGM_LO, (shader_va >> 8) & 0xFFFFFFFF);
    var rsrc[8];
    store32(&rsrc + 0, rsrc1);
    store32(&rsrc + 4, rsrc2);
    pos = native_pm4_set_sh_reg(buf, pos, R_COMPUTE_PGM_RSRC1, 2, &rsrc);
    pos = native_pm4_set_sh_reg_one(buf, pos, R_COMPUTE_TMPRING_SIZE, 0);
    var bi = 0;
    while (bi < n_binds) {
        var va = load64(binds + bi * 8);
        var pair[8];
        store32(&pair + 0, va & 0xFFFFFFFF);
        store32(&pair + 4, (va >> 32) & 0xFFFFFFFF);
        pos = native_pm4_set_sh_reg(buf, pos, R_COMPUTE_USER_DATA_0 + bi * 8, 2, &pair);
        bi = bi + 1;
    }
    pos = native_pm4_acquire_mem_full_invalidate(buf, pos);
    pos = native_pm4_set_sh_reg_one(buf, pos, R_COMPUTE_RESOURCE_LIMITS, 0x140);
    var nt[12];
    store32(&nt + 0, ntx);
    store32(&nt + 4, nty);
    store32(&nt + 8, ntz);
    pos = native_pm4_set_sh_reg(buf, pos, R_COMPUTE_NUM_THREAD_X, 3, &nt);
    pos = native_pm4_dispatch_direct(buf, pos, gx, gy, gz, GFX9_DISPATCH_INITIATOR);
    var cur2 = pos / 4;
    if (cur2 < 64) { pos = native_pm4_nop(buf, pos, 64 - cur2); }
    return pos;
}

# v3.2 F.5: PM4 stream that dispatches native_gfx9_shader_fma_f64 — the first
# native f64 (double-precision) compute on Cezanne. Computes, per lane i in a
# single workgroup of `ntx` (= LocalSize_x) lanes:
#   out[i] = fma(a[i], b[i], c[i])   over four f64 StorageBuffers.
#
# The kernel's 4-binding ABI (binding k → USER_DATA s[2k:2k+1]) means every
# USER_DATA SGPR pair s0..s7 is a real binding — there is NO scratch stub
# slot (the shader has no spills), so this composer uses TMPRING_SIZE = 0 and
# loads the four base VAs into USER_DATA_0/1, _2/3, _4/5, _6/7 (the same
# generic shape as the N.6 native_pm4_build_compute_dispatch, specialized +
# documented for the f64 ABI). RSRC1/RSRC2 are the f64 kernel's
# (GFX9_COMPUTE_PGM_RSRC1_FMA_F64 / _RSRC2_FMA_F64). NUM_THREAD = (ntx,1,1);
# grid = (1,1,1) workgroup, so lid.x in v0 ranges 0..ntx-1 — one lane per
# element. The proven Cezanne scaffold (STATIC_THREAD_MGMT / COHER / BC_BASE /
# ACQUIRE_MEM / RESOURCE_LIMITS) is identical to the other compute composers.
# `a_va`/`b_va`/`c_va`/`out_va` are the four binding base VAs. Returns the
# 64-dword byte length.
fn native_pm4_build_compute_fma_f64(buf, shader_va, rsrc1, rsrc2,
a_va, b_va, c_va, out_va, ntx): i64 {
    var pos = 0;
    pos = native_pm4_set_sh_reg_one(buf, pos, R_COMPUTE_PGM_HI, (shader_va >> 40) & 0xFF);
    var tm01[8];
    store32(&tm01 + 0, 0xFFFFFFFF);
    store32(&tm01 + 4, 0);
    pos = native_pm4_set_sh_reg(buf, pos, R_COMPUTE_STATIC_THREAD_MGMT_SE0, 2, &tm01);
    var tm23[8];
    store32(&tm23 + 0, 0);
    store32(&tm23 + 4, 0);
    pos = native_pm4_set_sh_reg(buf, pos, R_COMPUTE_STATIC_THREAD_MGMT_SE2, 2, &tm23);
    pos = native_pm4_set_uconfig_reg_one(buf, pos, R_CP_COHER_START_DELAY, 0);
    var bc_pair[8];
    store32(&bc_pair + 0, 0);
    store32(&bc_pair + 4, 0);
    pos = native_pm4_set_uconfig_reg_pair(buf, pos, R_TA_CS_BC_BASE_ADDR, &bc_pair);
    pos = native_pm4_set_sh_reg_one(buf, pos, R_COMPUTE_PGM_LO, (shader_va >> 8) & 0xFFFFFFFF);
    var rsrc[8];
    store32(&rsrc + 0, rsrc1);
    store32(&rsrc + 4, rsrc2);
    pos = native_pm4_set_sh_reg(buf, pos, R_COMPUTE_PGM_RSRC1, 2, &rsrc);
    pos = native_pm4_set_sh_reg_one(buf, pos, R_COMPUTE_TMPRING_SIZE, 0);
    # USER_DATA: binding 0 = a (s0:1), 1 = b (s2:3), 2 = c (s4:5), 3 = out (s6:7).
    var u01[8];
    store32(&u01 + 0, a_va & 0xFFFFFFFF);
    store32(&u01 + 4, (a_va >> 32) & 0xFFFFFFFF);
    pos = native_pm4_set_sh_reg(buf, pos, R_COMPUTE_USER_DATA_0 + 0, 2, &u01);
    var u23[8];
    store32(&u23 + 0, b_va & 0xFFFFFFFF);
    store32(&u23 + 4, (b_va >> 32) & 0xFFFFFFFF);
    pos = native_pm4_set_sh_reg(buf, pos, R_COMPUTE_USER_DATA_0 + 8, 2, &u23);
    var u45[8];
    store32(&u45 + 0, c_va & 0xFFFFFFFF);
    store32(&u45 + 4, (c_va >> 32) & 0xFFFFFFFF);
    pos = native_pm4_set_sh_reg(buf, pos, R_COMPUTE_USER_DATA_0 + 16, 2, &u45);
    var u67[8];
    store32(&u67 + 0, out_va & 0xFFFFFFFF);
    store32(&u67 + 4, (out_va >> 32) & 0xFFFFFFFF);
    pos = native_pm4_set_sh_reg(buf, pos, R_COMPUTE_USER_DATA_0 + 24, 2, &u67);
    pos = native_pm4_acquire_mem_full_invalidate(buf, pos);
    pos = native_pm4_set_sh_reg_one(buf, pos, R_COMPUTE_RESOURCE_LIMITS, 0x140);
    var nt[12];
    store32(&nt + 0, ntx);
    store32(&nt + 4, 1);
    store32(&nt + 8, 1);
    pos = native_pm4_set_sh_reg(buf, pos, R_COMPUTE_NUM_THREAD_X, 3, &nt);
    pos = native_pm4_dispatch_direct(buf, pos, 1, 1, 1, GFX9_DISPATCH_INITIATOR);
    var cur = pos / 4;
    if (cur < 64) { pos = native_pm4_nop(buf, pos, 64 - cur); }
    return pos;
}

# v3.1 [M.5]: PM4 stream that dispatches native_gfx9_shader_downsample_2x2
# to fill one mip level from its parent. Mirrors the deadbeef composer
# (same STATIC_THREAD_MGMT / COHER / BC_BASE / ACQUIRE_MEM / RESOURCE_LIMITS
# / completion-marker scaffold proven on Cezanne) but with the downsample
# shader's ABI:
#   RSRC1 / RSRC2 — caller-supplied (PGM_RSRC1/RSRC2). The hand-authored
#           downsample passes 0x2C0083 / 0x18C: RSRC1 VGPRS=3 (16 VGPRs, v0..v14),
#           SGPRS=2 (24 SGPRs, s0..s19), FLOAT_MODE=0xC0, DX10_CLAMP; RSRC2
#           USER_SGPR=6 (s0..s5) | TGID_X_EN | TGID_Y_EN (CP loads the workgroup
#           id into s6/s7). The SPIR-V→GFX9 compiler passes its own gfx9_rsrc1 /
#           gfx9_rsrc2 (N.5d — the seam that lets a compiled shader dispatch).
#   USER_DATA_0/1 = src level VA, _2/3 = dst level VA, _4 = dst_w.
#   DISPATCH grid = (dst_w, dst_h, 1). NUM_THREAD 1/1/1, so one workgroup ==
#           one dst texel and tgid == (x, y).
# stub_va is used only for the post-dispatch WR_CONFIRM marker (no scratch
# is enabled — the shader does not spill). Pure-Cyrius (9 params is fine;
# the fncall6 ceiling is only for fns that fncall into wgpu).
fn native_pm4_build_compute_downsample(buf, shader_va, stub_va,
src_va, dst_va, dst_w, dst_h, rsrc1, rsrc2): i64 {
    var pos = 0;
    var pgm_lo = (shader_va >> 8) & 0xFFFFFFFF;
    var pgm_hi = (shader_va >> 40) & 0xFF;
    pos = native_pm4_set_sh_reg_one(buf, pos, R_COMPUTE_PGM_HI, pgm_hi);
    var thread_mgmt_01[8];
    store32(&thread_mgmt_01 + 0, 0xFFFFFFFF);
    store32(&thread_mgmt_01 + 4, 0);
    pos = native_pm4_set_sh_reg(buf, pos, R_COMPUTE_STATIC_THREAD_MGMT_SE0,
    2, &thread_mgmt_01);
    var thread_mgmt_23[8];
    store32(&thread_mgmt_23 + 0, 0);
    store32(&thread_mgmt_23 + 4, 0);
    pos = native_pm4_set_sh_reg(buf, pos, R_COMPUTE_STATIC_THREAD_MGMT_SE2,
    2, &thread_mgmt_23);
    pos = native_pm4_set_uconfig_reg_one(buf, pos, R_CP_COHER_START_DELAY, 0);
    var bc_va = 0;
    var bc_pair[8];
    store32(&bc_pair + 0, (bc_va >> 8) & 0xFFFFFFFF);
    store32(&bc_pair + 4, (bc_va >> 40) & 0xFF);
    pos = native_pm4_set_uconfig_reg_pair(buf, pos, R_TA_CS_BC_BASE_ADDR,
    &bc_pair);
    pos = native_pm4_set_sh_reg_one(buf, pos, R_COMPUTE_PGM_LO, pgm_lo);
    var rsrc[8];
    store32(&rsrc + 0, rsrc1);
    store32(&rsrc + 4, rsrc2);
    pos = native_pm4_set_sh_reg(buf, pos, R_COMPUTE_PGM_RSRC1, 2, &rsrc);
    pos = native_pm4_set_sh_reg_one(buf, pos, R_COMPUTE_TMPRING_SIZE, 0x100);
    var user23[8];
    store32(&user23 + 0, dst_va & 0xFFFFFFFF);
    store32(&user23 + 4, (dst_va >> 32) & 0xFFFFFFFF);
    pos = native_pm4_set_sh_reg(buf, pos, R_COMPUTE_USER_DATA_0 + 8,
    2, &user23);
    var user01[8];
    store32(&user01 + 0, src_va & 0xFFFFFFFF);
    store32(&user01 + 4, (src_va >> 32) & 0xFFFFFFFF);
    pos = native_pm4_set_sh_reg(buf, pos, R_COMPUTE_USER_DATA_0,
    2, &user01);
    pos = native_pm4_set_sh_reg_one(buf, pos, R_COMPUTE_USER_DATA_0 + 16,
    dst_w);
    pos = native_pm4_acquire_mem_full_invalidate(buf, pos);
    pos = native_pm4_set_sh_reg_one(buf, pos,
    R_COMPUTE_RESOURCE_LIMITS, 0x140);
    var nt[12];
    store32(&nt + 0, 1);
    store32(&nt + 4, 1);
    store32(&nt + 8, 1);
    pos = native_pm4_set_sh_reg(buf, pos, R_COMPUTE_NUM_THREAD_X, 3, &nt);
    pos = native_pm4_dispatch_direct(buf, pos, dst_w, dst_h, 1,
    GFX9_DISPATCH_INITIATOR);
    store32(buf + pos +  0, 0xC0033700);
    store32(buf + pos +  4, 0x00100500);
    store32(buf + pos +  8, (stub_va + 4) & 0xFFFFFFFF);
    store32(buf + pos + 12, ((stub_va + 4) >> 32) & 0xFFFFFFFF);
    store32(buf + pos + 16, 0xC0FFEE12);
    pos = pos + 20;
    var cur_dwords = pos / 4;
    var target_dwords = 64;
    if (cur_dwords < target_dwords) {
        pos = native_pm4_nop(buf, pos, target_dwords - cur_dwords);
    }
    return pos;
}

# ================================================================
# v3 Step 6.5(b) — PM4 stream composer for clear-triangle dispatch
# ================================================================
# Composes the four PM4 blocks per docs/proposals/v3-backend-interface.md
# v2.1 split:
#   1. pipeline_sh   — VS+PS shader VAs + RSRC1/RSRC2
#   2. pipeline_ctx  — color/blend/raster/depth/SPI mode-static state
#   3. pass_target   — RT bind + viewport + scissor (RT-extent dependent)
#   4. draw_tail     — DRAW_INDEX_AUTO with vcount=3
# Plus an ACQUIRE_MEM cache-invalidate preamble + UConfig graphics
# regs (primitive type, num instances) + NOP padding.
#
# Every block is its own helper fn so each can be tested independently
# at the CPU level. The top-level `native_pm4_build_render_clear_triangle`
# composes them in order.
#
# Layer-2 verification gate: byte-exact diff vs `RADV_DEBUG=hang` IB
# capture of an equivalent `vkCmdDraw` clear. Captured under a desktop
# session — gated on the Hyprland reinstall (see
# docs/proposals/v3-shader-bytes-capture.md "What unblocks Layer 2").

# Convert an i64 integer to its IEEE-754 f32 bit pattern.
# Routes through stdlib's `f64_from(int)` and color.cyr's
# `f64_to_f32(f64bits)`. Used for viewport scale/offset conversions.
fn native_int_to_f32_bits(i): i64 {
    return f64_to_f32(f64_from(i));
}

# Negate an f32 bit pattern (low 32 bits) by flipping the sign bit.
# Operates on the integer holding the f32 bits; returns the negated
# f32 bit pattern.
fn native_f32_neg_bits(f32_bits): i64 {
    return f32_bits ^ 0x80000000;
}

# --- Block 1: pipeline_sh ---
#
# Two SET_SH_REG packets, each writing 4 contiguous regs starting at
# the PGM_LO of each stage. VS at 0xB120, PS at 0xB020. Total: 12
# dwords (48 bytes). Returns new pos.
fn native_pm4_build_render_pipeline_sh(buf, pos, vs_va, fs_va): i64 {
    # PGM_HI mask = 0xFF: the HW register is 32-bit but only the low 8
    # bits hold meaningful VA bits [47:40]; matches compute pattern at
    # line ~809 (R_COMPUTE_PGM_HI). PGM_LO carries bits [39:8].
    var vs_pgm_lo = (vs_va >> 8)  & 0xFFFFFFFF;
    var vs_pgm_hi = (vs_va >> 40) & 0xFF;
    var fs_pgm_lo = (fs_va >> 8)  & 0xFFFFFFFF;
    var fs_pgm_hi = (fs_va >> 40) & 0xFF;

    # Contiguous SET_SH_REG covering RSRC3_VS, LATE_ALLOC_VS, PGM_LO_VS,
    # PGM_HI_VS, PGM_RSRC1_VS, PGM_RSRC2_VS (6 regs, addresses 0xB118 →
    # 0xB12C in 4-byte steps). RSRC3 + LATE_ALLOC must lead because they
    # control wave allocation; if absent or zero the VS can't launch on
    # any CU → 2-second GFX TDR even with otherwise-correct shader code.
    var vs_regs[24];
    store32(&vs_regs +  0, GFX9_SPI_SHADER_PGM_RSRC3_VS_CU_EN_ALL);
    store32(&vs_regs +  4, GFX9_SPI_SHADER_LATE_ALLOC_VS_CEZANNE);
    store32(&vs_regs +  8, vs_pgm_lo);
    store32(&vs_regs + 12, vs_pgm_hi);
    store32(&vs_regs + 16, GFX9_GFX_PGM_RSRC1_MIN);
    store32(&vs_regs + 20, GFX9_VS_PGM_RSRC2_MIN);
    pos = native_pm4_set_sh_reg(buf, pos, R_SPI_SHADER_PGM_RSRC3_VS, 6, &vs_regs);

    var ps_regs[16];
    store32(&ps_regs +  0, fs_pgm_lo);
    store32(&ps_regs +  4, fs_pgm_hi);
    store32(&ps_regs +  8, GFX9_GFX_PGM_RSRC1_MIN);
    store32(&ps_regs + 12, GFX9_PS_PGM_RSRC2_MIN);
    pos = native_pm4_set_sh_reg(buf, pos, R_SPI_SHADER_PGM_LO_PS, 4, &ps_regs);

    return pos;
}

# --- Block 2: pipeline_ctx ---
#
# Per-pipeline mode-static state: color/blend, rasterizer, clip,
# stage enable, SPI inputs, depth disabled, anti-alias off. This
# block does NOT depend on the RT (no extent, no VA) — it's purely
# a function of the pipeline's intent.
fn native_pm4_build_render_pipeline_ctx(buf, pos): i64 {
    # SPI shader output formats — 3 contiguous regs starting at 0xA70C.
    var spi_fmts[12];
    store32(&spi_fmts +  0, SPI_SHADER_POS_FORMAT_4);
    store32(&spi_fmts +  4, SPI_SHADER_Z_FORMAT_INVALID);
    store32(&spi_fmts +  8, SPI_SHADER_COL_FORMAT_FP32_ABGR);
    pos = native_pm4_set_context_reg(buf, pos, R_SPI_SHADER_POS_FORMAT, 3, &spi_fmts);

    # CB target/shader masks — 2 contiguous regs at 0xA238.
    var cb_masks[8];
    store32(&cb_masks + 0, GFX9_CB_TARGET_MASK_RGBA);
    store32(&cb_masks + 4, GFX9_CB_SHADER_MASK_RGBA0);
    pos = native_pm4_set_context_reg(buf, pos, R_CB_TARGET_MASK, 2, &cb_masks);

    # Color / blend / raster / clip / stage enable.
    pos = native_pm4_set_context_reg_one(buf, pos, R_CB_COLOR_CONTROL,
    GFX9_CB_COLOR_CONTROL_NORMAL_COPY);
    pos = native_pm4_set_context_reg_one(buf, pos, R_CB_BLEND0_CONTROL,
    GFX9_CB_BLEND_DISABLED);
    pos = native_pm4_set_context_reg_one(buf, pos, R_PA_SU_SC_MODE_CNTL,
    GFX9_PA_SU_SC_MODE_CULL_NONE);
    pos = native_pm4_set_context_reg_one(buf, pos, R_PA_CL_CLIP_CNTL,
    GFX9_PA_CL_CLIP_CNTL_DEFAULT);
    pos = native_pm4_set_context_reg_one(buf, pos, R_VGT_SHADER_STAGES_EN,
    GFX9_VGT_SHADER_STAGES_VS_PS);
    pos = native_pm4_set_context_reg_one(buf, pos, R_VGT_REUSE_OFF, 0);
    # PA_CL_VS_OUT_CNTL = 0: our VS exports only position (no clip/cull
    # distances, no viewport-array index, no misc-vec). Must be set
    # explicitly to clear whatever value the prior context left here.
    pos = native_pm4_set_context_reg_one(buf, pos, R_PA_CL_VS_OUT_CNTL, 0);

    # SPI inputs/outputs — FS gets the hang-quirk minimum, VS exports
    # only pos0 (no params).
    pos = native_pm4_set_context_reg_one(buf, pos, R_SPI_PS_INPUT_ENA,
    GFX9_SPI_PS_INPUT_HANG_QUIRK_MIN);
    pos = native_pm4_set_context_reg_one(buf, pos, R_SPI_PS_INPUT_ADDR,
    GFX9_SPI_PS_INPUT_HANG_QUIRK_MIN);
    pos = native_pm4_set_context_reg_one(buf, pos, R_SPI_PS_IN_CONTROL, 0);
    pos = native_pm4_set_context_reg_one(buf, pos, R_SPI_VS_OUT_CONFIG,
    GFX9_SPI_VS_OUT_CONFIG_NO_VARYING);

    # Depth/HTILE/render-override — depth-stencil disabled.
    pos = native_pm4_set_context_reg_one(buf, pos, R_DB_SHADER_CONTROL,
    GFX9_DB_SHADER_CONTROL_DEFAULT);
    pos = native_pm4_set_context_reg_one(buf, pos, R_DB_HTILE_SURFACE, 0);
    pos = native_pm4_set_context_reg_one(buf, pos, R_DB_RENDER_OVERRIDE, 0);
    pos = native_pm4_set_context_reg_one(buf, pos, R_DB_RENDER_OVERRIDE2, 0);
    pos = native_pm4_set_context_reg_one(buf, pos, R_PA_SC_AA_CONFIG, 0);
    pos = native_pm4_set_context_reg_one(buf, pos, R_PA_SC_RASTER_CONFIG, 0);
    pos = native_pm4_set_context_reg_one(buf, pos, R_PA_SU_HARDWARE_SCREEN_OFFSET, 0);

    # GFX9 graphics-pipeline preamble — required to not hang the GFX
    # ring on Cezanne and similar APUs. The rc.2 native_render_e2e
    # 0x55-sentinel symptom was actually a ring TDR (kernel resets
    # the ring at ~2s), masked by CB_COLOR0_ATTRIB2 being missing.
    # Per gfx9.json + radv ac_cmdbuf.c preamble, the following must
    # be set before any DRAW_INDEX_AUTO on GFX9:
    #
    #   - Guard-band adjusts (PA_CL_GB_*_ADJ = 1.0f) — without these,
    #     the rasterizer's clip-to-guard-band step can hang on small
    #     primitives.
    #   - VGT vertex reuse / output dealloc — VGT deadlocks if these
    #     are zero (CLEAR_STATE doesn't reliably clear them on
    #     Bonaire / Cezanne / etc.).
    #   - PA_SC_BINNER_CNTL_0 = 0 — disable primitive binning. APUs
    #     ship with binning enabled by default; without an explicit
    #     BINNER_CNTL_1 batch configuration the DPB pipeline hangs.

    # Four contiguous guard-band adjusts in one SET_CONTEXT_REG packet.
    # CLIP_ADJ ≈ 254.992f (NOT 1.0f); DISC_ADJ = 1.0f. See the constant
    # definition in backend_native_shaders.cyr for the hang explanation.
    var gb_adj[16];
    store32(&gb_adj +  0, GFX9_PA_CL_GB_CLIP_ADJ_F32);  # VERT_CLIP_ADJ
    store32(&gb_adj +  4, GFX9_PA_CL_GB_DISC_ADJ_F32);  # VERT_DISC_ADJ
    store32(&gb_adj +  8, GFX9_PA_CL_GB_CLIP_ADJ_F32);  # HORZ_CLIP_ADJ
    store32(&gb_adj + 12, GFX9_PA_CL_GB_DISC_ADJ_F32);  # HORZ_DISC_ADJ
    pos = native_pm4_set_context_reg(buf, pos, R_PA_CL_GB_VERT_CLIP_ADJ, 4, &gb_adj);

    # PA_SC_BINNER_CNTL_0/1: explicitly disable HW primitive binning.
    # GFX9 needs USE_LEGACY_SC (3), not USE_NEW_SC (2). USE_NEW_SC is
    # GFX10+ syntax that GFX9 doesn't fully implement. Cited from
    # radv_cmd.c::radv_get_disabled_binning_state() GFX9 branch.
    pos = native_pm4_set_context_reg_one(buf, pos, R_PA_SC_BINNER_CNTL_0,
    GFX9_BINNER_CNTL_0_DISABLED);
    pos = native_pm4_set_context_reg_one(buf, pos, R_PA_SC_BINNER_CNTL_1,
    GFX9_BINNER_CNTL_1_DEFAULT);

    # VGT vertex reuse + output dealloc — 2 contiguous regs at 0x028C58.
    var vgt_reuse[8];
    store32(&vgt_reuse + 0, GFX9_VGT_VERTEX_REUSE_BLOCK);
    store32(&vgt_reuse + 4, GFX9_VGT_OUT_DEALLOC);
    pos = native_pm4_set_context_reg(buf, pos, R_VGT_VERTEX_REUSE_BLOCK_CNTL, 2, &vgt_reuse);

    # Second batch of GFX9 preamble registers. Each adds a 12-byte
    # SET_CONTEXT_REG_ONE packet; see the @internal header comment
    # in src/backend_native_shaders.cyr for the per-register rationale.
    pos = native_pm4_set_context_reg_one(buf, pos, R_DB_DEPTH_CONTROL, 0);
    pos = native_pm4_set_context_reg_one(buf, pos, R_DB_RENDER_CONTROL, 0);
    # PA_SU_VTX_CNTL: PIX_CENTER=1 (bit 0), ROUND_MODE=2 (bits 1:2 → 0b10 = trunc).
    # Value = 1 | (2 << 1) = 0x5.
    pos = native_pm4_set_context_reg_one(buf, pos, R_PA_SU_VTX_CNTL, 0x5);
    # PA_SC_MODE_CNTL_1 = 0x760201BC — scan-converter walk-order +
    # FORCE_EOV bits captured byte-for-byte from radv triangle reference.
    # Decoded bits include WALK_FENCE_ENABLE, WALK_FENCE_SIZE=3,
    # SUPERTILE_WALK_ORDER_ENABLE, FORCE_EOV_CNTDWN_ENABLE,
    # FORCE_EOV_REZ_ENABLE, MULTI_SHADER_ENGINE_PRIM_DISCARD_ENABLE.
    # With value 0 the SC's walk-order is unconfigured → can stall on
    # tile traversal.
    pos = native_pm4_set_context_reg_one(buf, pos, R_PA_SC_MODE_CNTL_1, 0x760201BC);
    pos = native_pm4_set_context_reg_one(buf, pos, R_SPI_TMPRING_SIZE, 0);
    pos = native_pm4_set_context_reg_one(buf, pos, R_PA_SC_CLIPRECT_RULE, 0xFFFF);
    # PA_SU_PRIM_FILTER_CNTL = 0xC0000000 — bits 30+31 set. Captured
    # from radv triangle reference. Likely XMAX_RIGHT_EXCLUSION +
    # YMAX_BOTTOM_EXCLUSION (D3D vs OpenGL pixel-rule selection).
    pos = native_pm4_set_context_reg_one(buf, pos, R_PA_SU_PRIM_FILTER_CNTL, 0xC0000000);

    # PA_SC_VPORT_SCISSOR_0_TL/BR — per-viewport scissor (separate
    # stage from screen/window/generic). Without it the rasterizer's
    # last-stage scissor can crop everything.
    var vport_scissor[8];
    store32(&vport_scissor + 0, 0x80000000);
    store32(&vport_scissor + 4, (16384) | (16384 << 16));
    pos = native_pm4_set_context_reg(buf, pos, R_PA_SC_VPORT_SCISSOR_0_TL, 2, &vport_scissor);

    # SX (Shader eXport) downconvert + blend-opt — 3 contiguous regs
    # at 0x028754. Without these the SX block doesn't know how to
    # convert the FS's FP32 export lanes to the CB's RGBA8 storage
    # format and may stall the CB-export handshake.
    var sx_block[12];
    store32(&sx_block + 0, 0);                 # SX_PS_DOWNCONVERT = 0 (no downconvert hint)
    store32(&sx_block + 4, 0);                 # SX_BLEND_OPT_EPSILON = 0
    store32(&sx_block + 8, 0);                 # SX_BLEND_OPT_CONTROL = 0
    pos = native_pm4_set_context_reg(buf, pos, R_SX_PS_DOWNCONVERT, 3, &sx_block);

    # Pipeline-stage handshake state radv always emits — each register
    # must be set to a known value to override whatever the prior
    # context (compositor's draws) left here. The default-after-context-
    # invalidate is NOT zero; it's "whatever was last loaded". Without
    # these explicit emits, the GFX pipeline can stall at the affected
    # stage (PA scan converter, SPI barycentric provider, VGT stream-out,
    # DB depth/stencil eval) waiting on handshakes that never complete →
    # 2-second exact GFX-ring TDR.
    pos = native_pm4_set_context_reg_one(buf, pos, R_SPI_BARYC_CNTL, 0);
    pos = native_pm4_set_context_reg_one(buf, pos, R_PA_SC_SHADER_CONTROL, 0);
    pos = native_pm4_set_context_reg_one(buf, pos, R_VGT_GS_MODE, 0);
    pos = native_pm4_set_context_reg_one(buf, pos, R_VGT_PRIMITIVEID_EN, 0);
    # DB_Z_INFO / DB_STENCIL_INFO = 0 → FORMAT=Z_INVALID/STENCIL_INVALID.
    # Tells the DB block "no depth-stencil attachment" so it doesn't
    # try to read DB_Z_READ_BASE / DB_STENCIL_READ_BASE (which are 0
    # → VM fault path on access).
    pos = native_pm4_set_context_reg_one(buf, pos, R_DB_Z_INFO, 0);
    pos = native_pm4_set_context_reg_one(buf, pos, R_DB_STENCIL_INFO, 0);
    # PA_SC_AA_MASK_X0Y0_X1Y0 / X0Y1_X1Y1 — sample coverage mask for
    # the rasterizer. Default 0 = no samples covered = no pixels written.
    # 0xFFFFFFFF = all samples covered (every pixel passes coverage).
    pos = native_pm4_set_context_reg_one(buf, pos, R_PA_SC_AA_MASK_X0Y0_X1Y0, 0xFFFFFFFF);
    pos = native_pm4_set_context_reg_one(buf, pos, R_PA_SC_AA_MASK_X0Y1_X1Y1, 0xFFFFFFFF);

    # PA_SC_MODE_CNTL_0 = 0x22 — bits 1+5 set. Captured from radv
    # triangle test. Without it the SC's mode is unconfigured.
    pos = native_pm4_set_context_reg_one(buf, pos, R_PA_SC_MODE_CNTL_0, 0x22);
    # VGT_GS_OUT_PRIM_TYPE = 2 (TRIANGLE_STRIP). Even when VGT_SHADER_STAGES_EN
    # has GS_EN=0, VGT consults this for prim-output sizing. Default 0
    # (POINTLIST) makes VGT allocate wrong-sized prim buffers.
    pos = native_pm4_set_context_reg_one(buf, pos, R_VGT_GS_OUT_PRIM_TYPE, 2);

    # SX_MRT0..7_BLEND_OPT removed — radv's value 0x06000600 may encode
    # BLEND_OPT_PRESERVE_NONE which makes the SX think the FS output
    # is don't-care, causing the CB to write zeros instead of the FS's
    # exported color. With these regs left unset (default 0), the FS's
    # FP32 export reaches the CB intact. Re-add only if a regression
    # surfaces on a path that actually uses blend optimization.

    return pos;
}

# --- Block 3: pass_target ---
#
# Per-pass state that depends on the RT: scissor (extent), viewport
# (NDC → pixel mapping with y-flip), and CB_COLOR0_* binding.
# `rt_va` must be 8-byte aligned. `rt_width` and `rt_height` are
# pixel counts (must be even for the /2 viewport math to be exact).
fn native_pm4_build_render_pass_target(buf, pos, rt_va, rt_width, rt_height): i64 {
    # Scissors. Format: low 16 bits = X, high 16 bits = Y.
    var scissor_tl = 0;
    var scissor_br = (rt_width & 0xFFFF) | ((rt_height & 0xFFFF) << 16);

    var screen_scissor[8];
    store32(&screen_scissor + 0, scissor_tl);
    store32(&screen_scissor + 4, scissor_br);
    pos = native_pm4_set_context_reg(buf, pos, R_PA_SC_SCREEN_SCISSOR_TL, 2, &screen_scissor);

    # GENERIC_SCISSOR_TL bit 31 = WINDOW_OFFSET_DISABLE — radv writes
    # this unconditionally; without it the GPU interprets the scissor
    # as relative to a window-offset register that may be unset.
    var generic_scissor[8];
    store32(&generic_scissor + 0, scissor_tl | 0x80000000);
    store32(&generic_scissor + 4, scissor_br);
    pos = native_pm4_set_context_reg(buf, pos, R_PA_SC_GENERIC_SCISSOR_TL, 2, &generic_scissor);

    # PA_SC_WINDOW_SCISSOR_TL/BR — must be set (radv writes these in
    # the gfx6+ preamble path). Pin BR at the GFX9 max (16384,16384)
    # and set WINDOW_OFFSET_DISABLE on TL.
    var window_scissor[8];
    store32(&window_scissor + 0, 0x80000000);                  # TL = (0,0) + WINDOW_OFFSET_DISABLE
    store32(&window_scissor + 4, (16384) | (16384 << 16));     # BR = (16384, 16384)
    pos = native_pm4_set_context_reg(buf, pos, R_PA_SC_WINDOW_SCISSOR_TL, 2, &window_scissor);

    # Viewport: NDC (-1..1) → pixel (0..w, 0..h) with y-flip.
    # XSCALE = w/2, XOFFSET = w/2, YSCALE = -h/2, YOFFSET = h/2.
    # ZSCALE = 1.0, ZOFFSET = 0.0. All as f32 bit patterns in dwords.
    # PA_CL_VPORT_XSCALE..ZOFFSET_0 are 6 contiguous dwords starting at 0xA43C.
    var w_half_f32      = native_int_to_f32_bits(rt_width / 2);
    var h_half_f32      = native_int_to_f32_bits(rt_height / 2);
    var neg_h_half_f32  = native_f32_neg_bits(h_half_f32);
    var one_f32         = native_int_to_f32_bits(1);

    var vport[24];
    store32(&vport +  0, w_half_f32);     # XSCALE
    store32(&vport +  4, w_half_f32);     # XOFFSET
    store32(&vport +  8, neg_h_half_f32); # YSCALE (flipped)
    store32(&vport + 12, h_half_f32);     # YOFFSET
    store32(&vport + 16, one_f32);        # ZSCALE
    store32(&vport + 20, 0);              # ZOFFSET (= 0.0 f32)
    pos = native_pm4_set_context_reg(buf, pos, R_PA_CL_VPORT_XSCALE, 6, &vport);

    # Z viewport range — ZMIN=0.0, ZMAX=1.0 as f32 bits.
    var z_minmax[8];
    store32(&z_minmax + 0, 0);            # ZMIN_0 as f32 = 0.0
    store32(&z_minmax + 4, one_f32);      # ZMAX_0 as f32 = 1.0
    pos = native_pm4_set_context_reg(buf, pos, R_PA_SC_VPORT_ZMIN_0, 2, &z_minmax);

    # CB_COLOR0 RT bind. BASE = (rt_va >> 8) low 32 bits, BASE_EXT
    # = (rt_va >> 40) for the 8-bit high-VA extension.
    var rt_base_lo  = (rt_va >> 8)  & 0xFFFFFFFF;
    var rt_base_ext = (rt_va >> 40) & 0xFF;

    pos = native_pm4_set_context_reg_one(buf, pos, R_CB_COLOR0_BASE, rt_base_lo);
    pos = native_pm4_set_context_reg_one(buf, pos, R_CB_COLOR0_BASE_EXT, rt_base_ext);
    # CB_COLOR0_ATTRIB2: surface extent. Without this the CB sees the
    # RT as zero-extent and silently drops every pixel write (the
    # rc.2 0x55-sentinel bug). bits[0:13]=MIP0_HEIGHT, [14:27]=MIP0_WIDTH,
    # [28:31]=MAX_MIP=0 for a single-mip RT.
    var attrib2 = ((rt_height - 1) & 0x3FFF) | (((rt_width - 1) & 0x3FFF) << 14);
    pos = native_pm4_set_context_reg_one(buf, pos, R_CB_COLOR0_ATTRIB2, attrib2);
    pos = native_pm4_set_context_reg_one(buf, pos, R_CB_COLOR0_VIEW, 0);
    pos = native_pm4_set_context_reg_one(buf, pos, R_CB_COLOR0_INFO,
    GFX9_CB_COLOR0_INFO_RGBA8_UNORM);
    pos = native_pm4_set_context_reg_one(buf, pos, R_CB_COLOR0_ATTRIB,
    GFX9_CB_COLOR0_ATTRIB_2D_LINEAR_RGBA8);
    pos = native_pm4_set_context_reg_one(buf, pos, R_CB_COLOR0_DCC_CONTROL, 0);

    # CMASK / FMASK / DCC base = 0 (uncompressed RT). radv's GFX9
    # emit_fb_color_state writes all of these in a single 11-reg
    # SET_CONTEXT_REG_SEQ; we emit them as singletons here for
    # codepath simplicity. Without these the CB hardware reads
    # stale values from the previous context and VM-faults the
    # GFX ring on first dispatch.
    pos = native_pm4_set_context_reg_one(buf, pos, R_CB_COLOR0_CMASK, 0);
    pos = native_pm4_set_context_reg_one(buf, pos, R_CB_COLOR0_CMASK_BASE_EXT, 0);
    pos = native_pm4_set_context_reg_one(buf, pos, R_CB_COLOR0_FMASK, 0);
    pos = native_pm4_set_context_reg_one(buf, pos, R_CB_COLOR0_FMASK_BASE_EXT, 0);
    pos = native_pm4_set_context_reg_one(buf, pos, R_CB_COLOR0_DCC_BASE, 0);
    pos = native_pm4_set_context_reg_one(buf, pos, R_CB_COLOR0_DCC_BASE_EXT, 0);

    # MRT0 effective pitch — for linear 256-wide: pitch_elements - 1 = 255.
    var mrt_epitch = (rt_width - 1) & 0xFFFF;
    pos = native_pm4_set_context_reg_one(buf, pos, R_CB_MRT0_EPITCH, mrt_epitch);

    return pos;
}

# --- Block 4: draw_tail ---
#
# Single DRAW_INDEX_AUTO with caller-supplied `vertex_count` and
# AUTO_INDEX source select. Hardware generates vertex_id 0/1/...
# /(vertex_count - 1) for the VS to consume from system VGPR v0.
# Audit LOW-4: vertex_count was hardcoded to GFX9_FULLSCREEN_TRI_VCOUNT
# (= 3) in v3.0-rc.1; consumers couldn't draw anything but the
# fullscreen triangle through this builder. The fullscreen-tri
# composer (native_pm4_build_render_clear_triangle) still passes
# GFX9_FULLSCREEN_TRI_VCOUNT explicitly to preserve its byte-for-
# byte equivalence with the v3.0-rc.1 PM4 stream.
fn native_pm4_build_render_draw_tail(buf, pos, vertex_count): i64 {
    return native_pm4_draw_index_auto(buf, pos,
    vertex_count,
    DI_SRC_SEL_AUTO_INDEX);
}

# Top-level composer: emits the full PM4 stream for a single
# clear-triangle dispatch into `buf`. Returns total bytes written
# (= position after the NOP padding tail).
#
# Layout:
#   1. ACQUIRE_MEM full invalidate
#   2. UConfig graphics: VGT_PRIMITIVE_TYPE + VGT_NUM_INSTANCES
#   3. Block 1 — pipeline_sh
#   4. Block 2 — pipeline_ctx
#   5. Block 3 — pass_target
#   6. Block 4 — draw_tail
#   7. NOP padding to 256-dword (1024-byte) alignment
#
# `buf` must be at least 1024 bytes.  `vs_va` and `fs_va` are GPU
# VAs of the VS+FS BOs (256-byte aligned). `rt_va` is the GPU VA of
# the color target (8-byte aligned). `rt_width`/`rt_height` are RT
# dimensions in pixels (must be even).
#
# Verification: every emitted dword is structurally tested by
# `test_native_pm4_render_clear_triangle_*` in mabda_v3.tcyr.
# Layer-2 byte-exact diff against radv is gated on Hyprland.
fn native_pm4_build_render_clear_triangle(buf, vs_va, fs_va,
rt_va, rt_width, rt_height): i64 {
    var pos = 0;
    # Preamble shape captured byte-for-byte from radv's GFX preamble IB
    # on this exact Cezanne/Renoir: PFP_SYNC_ME → heavy ACQUIRE_MEM →
    # EVENT_WRITE PIPELINESTAT_START. The PFP_SYNC_ME forces the
    # Prefetch Parser to drain pending work from a prior context (e.g.
    # the compositor's draws) before our ACQUIRE_MEM invalidates the
    # caches. Without it, PFP can read stale context state ME hasn't
    # finished committing → CP stalls waiting on pipeline subsystems
    # whose state never settles → 2-second exact GFX-ring TDR.
    # NOTE: we do NOT emit our own CONTEXT_CONTROL here. The kernel
    # already emits one (CC0=0x81018003, CC1=0) immediately before
    # jumping to our IB — observed in the GFX-ring devcoredump at
    # 2026-05-12. Emitting a second CONTEXT_CONTROL with conflicting
    # load/shadow bits interacted badly and changed the hang shape.
    # radv also doesn't emit CONTEXT_CONTROL in its userspace IB.
    pos = native_pm4_pfp_sync_me(buf, pos);
    pos = native_pm4_acquire_mem_full_invalidate_for_gfx_ring(buf, pos);
    pos = native_pm4_event_write_pipelinestat_start(buf, pos);
    pos = native_pm4_set_uconfig_reg_one(buf, pos, R_VGT_PRIMITIVE_TYPE,
    GFX9_VGT_PRIMITIVE_TYPE_TRIANGLELIST);
    # IA_MULTI_VGT_PARAM = 0x0070007f — input-assembler multi-VGT config.
    # Captured from radv on Cezanne. Without it the IA stage can't issue
    # primitives correctly to the VGT (default = unconfigured). Bits:
    # PRIMGROUP_SIZE=127, PARTIAL_VS_WAVE_ON=1, SWITCH_ON_EOI=1.
    pos = native_pm4_set_uconfig_reg_one(buf, pos, R_IA_MULTI_VGT_PARAM, 0x0070007F);
    pos = native_pm4_build_render_pipeline_sh(buf, pos, vs_va, fs_va);
    pos = native_pm4_build_render_pipeline_ctx(buf, pos);
    pos = native_pm4_build_render_pass_target(buf, pos, rt_va, rt_width, rt_height);
    # PKT3 NUM_INSTANCES (opcode 0x2F) goes IMMEDIATELY before
    # DRAW_INDEX_AUTO. radv emits it as a per-draw hint; AMD CP picks it
    # up as a draw-state update more reliably than SET_UCONFIG_REG.
    pos = native_pm4_num_instances(buf, pos, GFX9_VGT_NUM_INSTANCES_ONE);
    pos = native_pm4_build_render_draw_tail(buf, pos, GFX9_FULLSCREEN_TRI_VCOUNT);
    # Flush CB/DB caches so the FB the kernel signals "complete" on
    # actually contains the rendered pixels — ACQUIRE_MEM at top of
    # the IB invalidates fetches but does NOT flush dirty CB writes.
    # Without this the documented Failure A in
    # programs/native_render_e2e.cyr fires (pixel readback returns
    # the GTT sentinel byte). 6.10 prep landed the primitive; this
    # is its splice site. See vidya
    # phase_d_cache_flush_and_inv_post_draw entry for the
    # ACQUIRE_MEM-vs-flush semantics.
    pos = native_pm4_event_write_cache_flush_and_inv(buf, pos);

    var cur_dwords = pos / 4;
    var target_dwords = 256;
    if (cur_dwords < target_dwords) {
        pos = native_pm4_nop(buf, pos, target_dwords - cur_dwords);
    }
    return pos;
}

# ================================================================
# v3.1 Q.5 — SDMA copy packets (TRANSFER ring)
# ================================================================
# The SDMA (DMA) ring uses its OWN command format, not GFX/compute PM4.
# COPY_LINEAR does a flat byte copy src -> dst. Format for SDMA v4
# (GFX9 / Cezanne), 7 dwords / 28 bytes:
#   DW0 header : op[7:0]=SDMA_OP_COPY(1), sub_op[15:8]=COPY_LINEAR(0)
#   DW1 count  : byte_count - 1  (HW convention)
#   DW2 params : 0 (linear; no swizzle / host-access bits)
#   DW3 src_lo : src_va[31:0]
#   DW4 src_hi : src_va[63:32]
#   DW5 dst_lo : dst_va[31:0]
#   DW6 dst_hi : dst_va[63:32]
# VA halves use the logical >> (Cyrius `>>` is logical — see the
# feedback_cyrius_logical_right_shift memory) and an explicit mask, so
# canonical-high VAs (0xFFFF8001…) pack correctly. The packet format is
# HW-verified by programs/native_sdma_copy_e2e.cyr on Cezanne.
var SDMA_OP_COPY           = 0x1;
var SDMA_SUBOP_COPY_LINEAR = 0x0;

# Max bytes ONE GFX9 SDMA COPY_LINEAR packet can move. The COUNT field
# (dword 1 = byte_count - 1) is 22 bits wide, so byte_count tops out at
# 1<<22 = 4 MiB; more would spill past bit 21 and silently corrupt the
# copy (audit 2026-06-15 HIGH-2). Larger transfers chain multiple packets
# (native_sdma_build_copy_chained, v3.2 X.8) — each chunk is capped here.
var _NATIVE_SDMA_COPY_MAX_BYTES = 4194304;

# Build a 7-dword SDMA COPY_LINEAR packet at `buf`. Returns 28 (bytes).
# Pure byte-builder — no syscalls; the submit (HW_IP_DMA) is the
# caller's job. Precondition: 0 < bytes <= _NATIVE_SDMA_COPY_MAX_BYTES
# (the count field can't represent more — the driver guards this).
fn native_sdma_build_copy_linear(buf, src_va, dst_va, bytes): i64 {
    var header = SDMA_OP_COPY | (SDMA_SUBOP_COPY_LINEAR << 8);
    store32(buf + 0,  header);
    store32(buf + 4,  bytes - 1);                 # count = byte_count - 1
    store32(buf + 8,  0);                          # parameters
    store32(buf + 12, src_va & 0xFFFFFFFF);        # src_addr_lo
    store32(buf + 16, (src_va >> 32) & 0xFFFFFFFF); # src_addr_hi
    store32(buf + 20, dst_va & 0xFFFFFFFF);        # dst_addr_lo
    store32(buf + 24, (dst_va >> 32) & 0xFFFFFFFF); # dst_addr_hi
    return 28;
}

# v3.2 X.8 — chain N SDMA COPY_LINEAR packets covering `bytes` from src_va
# to dst_va, each chunk capped at _NATIVE_SDMA_COPY_MAX_BYTES (4 MiB), so a
# single DMA submission can move buffers larger than one packet's 22-bit
# count field allows. Successive chunks advance the src/dst VAs by the bytes
# already copied. Pure byte-builder — writes contiguous 28-byte packets into
# `buf`; the submit is the caller's job.
#
# `buf_cap` is the IB byte budget (the cached IB is _NATIVE_IB_SIZE). Returns
# the total packet bytes written (a multiple of 28), or 0 if the chain would
# exceed buf_cap — the caller rejects (the per-IB ceiling is ~146 packets =
# ~584 MiB; bigger copies need multiple submissions, future work). Nothing
# partial is submitted on the 0 path. Precondition: bytes > 0.
fn native_sdma_build_copy_chained(buf, src_va, dst_va, bytes, buf_cap): i64 {
    var remaining = bytes;
    var off = 0;        # bytes already covered (VA advance)
    var written = 0;    # packet bytes staged into buf
    while (remaining > 0) {
        if (written + 28 > buf_cap) { return 0; }   # chain won't fit the IB
        var chunk = remaining;
        if (chunk > _NATIVE_SDMA_COPY_MAX_BYTES) { chunk = _NATIVE_SDMA_COPY_MAX_BYTES; }
        native_sdma_build_copy_linear(buf + written, src_va + off, dst_va + off, chunk);
        written = written + 28;
        off = off + chunk;
        remaining = remaining - chunk;
    }
    return written;
}

# v3.2 TS.6 — SDMA COPY_TILED_SUB_WINDOW (sub-op 5): a linear<->tiled copy
# where the SDMA engine applies the tiled surface's swizzle, so mabda does NOT
# compute the GFX9 SW_64KB_S equation in software (the "let the HW tile it"
# path). A compressed-texture write becomes L2T (detile=0), a read T2L
# (detile=1). 14-dword (56-byte) no-DCC, single-level, depth-1, zero-origin
# full-surface packet. Format transcribed from Mesa
# ac_emit_sdma_copy_tiled_sub_window (SDMA_4_0 path) + sid.h SDMA opcodes:
#   DW0  SDMA_PACKET(COPY=1, TILED_SUB_WINDOW=5, 0) | detile<<31
#   DW1/2  tiled VA lo/hi
#   DW3  tiled offset.x|y (0)
#   DW4  tiled offset.z(0) | (ext_w-1)<<16
#   DW5  (ext_h-1) | (ext_d-1=0)<<16
#   DW6  info = element_size | swizzle_mode<<3 | dim<<9 | epitch<<16
#   DW7/8  linear VA lo/hi
#   DW9  linear offset.x|y (0)
#   DW10 linear offset.z(0) | (lin_pitch-1)<<16
#   DW11 lin_slice_pitch-1
#   DW12 (copy_w-1) | (copy_h-1)<<16
#   DW13 (copy_d-1 = 0)
# element_size = log2(bytes per tiled element/block); swizzle_mode = GFX9
# SW_MODE; dim = gfx9 resource type; epitch = tiled extended pitch in elements
# minus 1; extents/pitches/rect are in ELEMENTS (blocks, for compressed). The
# tiled-surface geometry (swizzle_mode value, epitch, size) is TS.7's job; this
# is the pure packet byte-builder. Returns 56.
var SDMA_SUBOP_COPY_TILED_SUB_WINDOW = 0x5;

fn native_sdma_build_copy_tiled(buf, tiled_va, lin_va, element_size, swizzle_mode,
dim, epitch, ext_w, ext_h, lin_pitch, lin_slice_pitch, copy_w, copy_h, detile): i64 {
    var header = SDMA_OP_COPY | (SDMA_SUBOP_COPY_TILED_SUB_WINDOW << 8);
    if (detile != 0) { header = header | (1 << 31); }
    store32(buf +  0, header);
    store32(buf +  4, tiled_va & 0xFFFFFFFF);
    store32(buf +  8, (tiled_va >> 32) & 0xFFFFFFFF);
    store32(buf + 12, 0);                                   # tiled offset x|y
    store32(buf + 16, ((ext_w - 1) & 0x3FFF) << 16);        # offset.z=0 | ext_w-1
    store32(buf + 20, (ext_h - 1) & 0x3FFF);                # ext_h-1 | ext_d-1=0
    var info = (element_size & 0x7) | ((swizzle_mode & 0x1F) << 3);
    info = info | ((dim & 0x7) << 9) | ((epitch & 0xFFFF) << 16);
    store32(buf + 24, info);
    store32(buf + 28, lin_va & 0xFFFFFFFF);
    store32(buf + 32, (lin_va >> 32) & 0xFFFFFFFF);
    store32(buf + 36, 0);                                   # linear offset x|y
    store32(buf + 40, ((lin_pitch - 1) & 0x3FFF) << 16);    # offset.z=0 | lin_pitch-1
    store32(buf + 44, lin_slice_pitch - 1);
    store32(buf + 48, ((copy_w - 1) & 0x3FFF) | (((copy_h - 1) & 0x3FFF) << 16));
    store32(buf + 52, 0);                                   # copy_d - 1 = 0
    return 56;
}

# --- backend_native.cyr ---

# @internal — native GPU backend, dispatch + slot fillers + integration
# backend_native.cyr — Backend interface implementation for the native AMD path
#
# Split at v3 rc.2 (audit toolchain item) — the foundational ioctl
# wrappers, PM4 builders, and GFX9 ISA shaders moved out into
# backend_native_amdgpu.cyr / backend_native_pm4.cyr /
# backend_native_shaders.cyr respectively. This file owns the
# integration layer:
#   - native_compute_dispatch_cached + native_render_dispatch_simple
#     (the load-bearing CS-submit drivers, both routed through the
#     per-context cached IB + fence BOs from gpu_context_new_native)
#   - native_render_handles_write + native_render_bo_list_pack
#     (helpers for the GFX-ring submit shape)
#   - native_ctx_* field accessors against the GpuContext struct's
#     +0..+112 native-mode interpretation
#   - native_buf_pair_write (the (handle, va) pair shape compute
#     dispatch consumes)
#   - All `_backend_native_*` slot fillers wired into backend_native_new()
#     — context, buffer, shader-module, compute-dispatch, device-wait,
#     texture, render-target, render-pipeline, render-pass-{begin,draw,end},
#     surface-{configure,acquire,present,release}.
#   - native_texture_* / native_rt_* primitives + NativeRenderPipeline +
#     NativePass struct shapes.
#
# Depends on all three split files above; the include chain in
# src/lib.cyr orders them as: amdgpu → shaders → pm4 → backend_native.

# ================================================================
# v3 Step 4b — composed dispatch (PM4 + IB + fence + submit + wait)
# ================================================================
# All-in-one COMPUTE-ring dispatch built on top of the existing
# primitives. Caller owns shader / stub / output BOs (passed in by
# handle); the IB BO, fence BO, syncobj are ephemeral — allocated,
# va-mapped, used once, and released before this fn returns.
#
# Args:
#   fd            — DRM render node fd
#   ctx_id        — amdgpu context id (from native_ctx_alloc)
#   pm4           — pointer to a PM4 dword stream (caller-built)
#   pm4_bytes     — byte count of the PM4 stream
#   shader_handle — KMS handle of the shader BO
#   stub_handle   — KMS handle of the Mesa-stub BO
#   out_handle    — KMS handle of the output BO
#   timeout_ns    — syncobj wait deadline (absolute, in ns; pass
#                   mono_ns() + 15_000_000_000 for a 15-second wait)
#
# Returns 0 on success (syncobj signalled within timeout) or a
# GPU_ERR_* code on failure. Does NOT verify the post-dispatch
# marker or the output bytes — that's the caller's job.
#
# IB and fence are allocated at hardcoded VAs (0xFFFF800100200000
# and 0xFFFF800100600000 respectively) — caller's BOs must not
# collide with these. The 5-entry BO_HANDLES list is hardcoded:
# fence / stub / out / shader / IB. Generalising to caller-provided
# residency is a Step 4c+ follow-up (see docs/development/roadmap.md).
# Step 4f.iv: dispatch using the per-context cached IB + fence BOs
# from gpu_context_new_native. Replaces native_compute_dispatch_simple
# (Step 4b's per-dispatch alloc-and-free path). Caller passes the
# GpuContext so we can pull cached BO handles + VAs + CPU mmap addrs
# (saves ~7 syscalls of BO churn per dispatch). The shader / stub /
# output handles come from the caller (still per-dispatch, since
# they're user-provided resources).
fn native_compute_dispatch_cached(ctx, pm4, pm4_bytes,
shader_handle, out_handle, timeout_ns): i64 {
    var fd = native_ctx_fd(ctx);
    var cid = native_ctx_id(ctx);
    var stub_handle = native_ctx_stub_handle(ctx);
    var ib_handle   = native_ctx_ib_handle(ctx);
    var ib_va       = native_ctx_ib_va(ctx);
    var ib_addr     = native_ctx_ib_addr(ctx);
    var fence_handle = native_ctx_fence_handle(ctx);
    var fence_addr   = native_ctx_fence_addr(ctx);

    # Stage PM4 into the cached IB BO (memset + memcpy; no alloc).
    memset(ib_addr, 0, 4096);
    memcpy(ib_addr, pm4, pm4_bytes);

    # Pre-zero the user-fence slot so the kernel's seqno write is observable.
    store64(fence_addr + 32, 0);

    # Build the 5-entry inline BO_HANDLES list (Mesa rusticl shape).
    var entries[40];
    store32(&entries +  0, fence_handle);  store32(&entries +  4, 1);
    store32(&entries +  8, stub_handle);   store32(&entries + 12, 3);
    store32(&entries + 16, out_handle);    store32(&entries + 20, 3);
    store32(&entries + 24, shader_handle); store32(&entries + 28, 4);
    store32(&entries + 32, ib_handle);     store32(&entries + 36, 10);
    var bo_list_in[24];
    store32(&bo_list_in +  0, 0xFFFFFFFF);
    store32(&bo_list_in +  4, 0xFFFFFFFF);
    store32(&bo_list_in +  8, 5);
    store32(&bo_list_in + 12, 8);
    store64(&bo_list_in + 16, &entries);

    # Per-dispatch syncobj (cheap; one ioctl create + one destroy).
    # Audit LOW-5: out-ptr lives on the stack so we don't bump-leak
    # 8 bytes per dispatch. native_syncobj_create writes the handle
    # into the buffer; we load it back and pass to wait/destroy.
    var syncobj_buf[8];
    var rc = native_syncobj_create(fd, &syncobj_buf);
    if (rc != 0) { return _native_neg_rc_to_gpu_err(rc); }
    var syncobj_handle = load64(&syncobj_buf);

    # 4-chunk Mesa-shape submit.
    rc = native_cs_submit_4chunk(fd, cid, &bo_list_in, ib_va, pm4_bytes,
    AMDGPU_HW_IP_COMPUTE, syncobj_handle,
    fence_handle, 32, 0x08);
    if (rc != 0) {
        var rc_save = rc;
        native_syncobj_destroy(fd, syncobj_handle);
        return _native_neg_rc_to_gpu_err(rc_save);
    }

    var wait_rc = native_syncobj_wait(fd, syncobj_handle, timeout_ns);
    native_syncobj_destroy(fd, syncobj_handle);
    return _native_neg_rc_to_gpu_err(wait_rc);
}

# ================================================================
# N.6 — multi-binding compute dispatch (cached path, N storage BOs)
# ================================================================
# Like native_compute_dispatch_cached but the BO list carries N binding handles
# (a caller [n] array of GEM handles) instead of a single out_handle — so a
# compiled kernel reading/writing several storage buffers (e.g. a 2-binding
# SAXPY) gets every buffer resident. BO list = fence + stub + bind[0..n) +
# shader + ib. Synchronous (creates/waits/destroys an ephemeral syncobj).
fn native_compute_dispatch_cached_n(ctx, pm4, pm4_bytes, shader_handle,
binds, n_binds, timeout_ns): i64 {
    var fd = native_ctx_fd(ctx);
    var cid = native_ctx_id(ctx);
    var stub_handle = native_ctx_stub_handle(ctx);
    var ib_handle = native_ctx_ib_handle(ctx);
    var ib_va = native_ctx_ib_va(ctx);
    var ib_addr = native_ctx_ib_addr(ctx);
    var fence_handle = native_ctx_fence_handle(ctx);
    var fence_addr = native_ctx_fence_addr(ctx);
    memset(ib_addr, 0, 4096);
    memcpy(ib_addr, pm4, pm4_bytes);
    store64(fence_addr + 32, 0);
    # entries: fence(1) + stub(3) + each binding(3) + shader(4) + ib(10).
    var entries[256];
    var ne = 0;
    store32(&entries + ne * 8, fence_handle);
    store32(&entries + ne * 8 + 4, 1);
    ne = ne + 1;
    store32(&entries + ne * 8, stub_handle);
    store32(&entries + ne * 8 + 4, 3);
    ne = ne + 1;
    var bi = 0;
    while (bi < n_binds) {
        store32(&entries + ne * 8, load64(binds + bi * 8));
        store32(&entries + ne * 8 + 4, 3);
        ne = ne + 1;
        bi = bi + 1;
    }
    store32(&entries + ne * 8, shader_handle);
    store32(&entries + ne * 8 + 4, 4);
    ne = ne + 1;
    store32(&entries + ne * 8, ib_handle);
    store32(&entries + ne * 8 + 4, 10);
    ne = ne + 1;
    var bo_list_in[24];
    store32(&bo_list_in + 0, 0xFFFFFFFF);
    store32(&bo_list_in + 4, 0xFFFFFFFF);
    store32(&bo_list_in + 8, ne);
    store32(&bo_list_in + 12, 8);
    store64(&bo_list_in + 16, &entries);
    var syncobj_buf[8];
    var rc = native_syncobj_create(fd, &syncobj_buf);
    if (rc != 0) { return _native_neg_rc_to_gpu_err(rc); }
    var syncobj_handle = load64(&syncobj_buf);
    rc = native_cs_submit_4chunk(fd, cid, &bo_list_in, ib_va, pm4_bytes,
    AMDGPU_HW_IP_COMPUTE, syncobj_handle, fence_handle, 32, 0x08);
    if (rc != 0) {
        var rc_save = rc;
        native_syncobj_destroy(fd, syncobj_handle);
        return _native_neg_rc_to_gpu_err(rc_save);
    }
    var wait_rc = native_syncobj_wait(fd, syncobj_handle, timeout_ns);
    native_syncobj_destroy(fd, syncobj_handle);
    return _native_neg_rc_to_gpu_err(wait_rc);
}

# ================================================================
# v3.1 Q.3c — queue-targeted compute dispatch (async, timeline)
# ================================================================
# Like native_compute_dispatch_cached but submits on `queue`'s ring,
# signalling that queue's PERSISTENT timeline syncobj at the next point
# (queue_bump_point) instead of creating/waiting/destroying an
# ephemeral binary syncobj. It does NOT wait — the caller controls
# completion via gpu_queue_wait_idle / gpu_queue_barrier. This is what
# makes genuine cross-ring overlap possible.
#
# MVP caveat: the cached IB BO is shared, so an async submit followed by
# a second dispatch before wait_idle would overwrite the IB mid-flight.
# The Q.3c contract is one in-flight queue-targeted dispatch per queue
# before a wait/barrier; multi-in-flight needs per-submit IB ring
# buffers (a later 3.1.x concern). Returns 0|GPU_ERR_*.
fn native_compute_dispatch_cached_timeline(ctx, pm4, pm4_bytes,
shader_handle, out_handle, queue, ip_type): i64 {
    var syncobj = queue_syncobj(queue);
    if (syncobj == 0) { return GPU_ERR_OTHER; }

    var fd  = native_ctx_fd(ctx);
    var cid = native_ctx_id(ctx);
    var stub_handle  = native_ctx_stub_handle(ctx);
    var ib_handle    = native_ctx_ib_handle(ctx);
    var ib_va        = native_ctx_ib_active_va(ctx);
    var ib_addr      = native_ctx_ib_active_addr(ctx);
    var fence_handle = native_ctx_fence_handle(ctx);

    # Stage PM4 into the cached IB BO.
    memset(ib_addr, 0, 4096);
    memcpy(ib_addr, pm4, pm4_bytes);

    # Same 5-entry inline BO_HANDLES list as the synchronous path.
    var entries[40];
    store32(&entries +  0, fence_handle);  store32(&entries +  4, 1);
    store32(&entries +  8, stub_handle);   store32(&entries + 12, 3);
    store32(&entries + 16, out_handle);    store32(&entries + 20, 3);
    store32(&entries + 24, shader_handle); store32(&entries + 28, 4);
    store32(&entries + 32, ib_handle);     store32(&entries + 36, 10);
    var bo_list_in[24];
    store32(&bo_list_in +  0, 0xFFFFFFFF);
    store32(&bo_list_in +  4, 0xFFFFFFFF);
    store32(&bo_list_in +  8, 5);
    store32(&bo_list_in + 12, 8);
    store64(&bo_list_in + 16, &entries);

    # Consume any pending cross-ring wait that gpu_queue_barrier (Q.4)
    # recorded on this queue: it becomes an in-CS TIMELINE_WAIT so the
    # GPU resolves the dependency without a CPU stall. Read + clear
    # before submit so the queue state is clean regardless of outcome
    # (a single barrier applies to the next submit only).
    var wait_so = queue_pending_wait_syncobj(queue);
    var wait_pt = queue_pending_wait_point(queue);
    queue_clear_pending_wait(queue);

    # Reserve this dispatch's timeline point and submit signalling it on
    # completion. ib_flags=0x08 (TC_WB_NOT_INVALIDATE) as on the compute
    # path. wait_so==0 omits the wait chunk (the common no-barrier case).
    var point = queue_bump_point(queue);
    var rc = native_cs_submit_timeline(fd, cid, &bo_list_in, ib_va, pm4_bytes,
    ip_type, syncobj, point, wait_so, wait_pt, fence_handle, 32, 0x08);
    return _native_neg_rc_to_gpu_err(rc);
}

# N.6 — the N-binding analog of native_compute_dispatch_cached_timeline: a COMPILED
# kernel reading/writing N storage buffers, dispatched on a LOGICAL QUEUE's ring,
# signalling the queue's persistent timeline (and consuming any pending cross-ring
# barrier as an in-CS wait — same Q.4 contract as the deadbeef timeline path). BO
# list = fence + stub + each binding + shader + ib (the cached_n shape). The caller
# waits via gpu_queue_wait_idle / orders with gpu_queue_barrier.
fn native_compute_dispatch_cached_n_timeline(ctx, pm4, pm4_bytes, shader_handle,
binds, n_binds, queue, ip_type): i64 {
    var syncobj = queue_syncobj(queue);
    if (syncobj == 0) { return GPU_ERR_OTHER; }
    var fd  = native_ctx_fd(ctx);
    var cid = native_ctx_id(ctx);
    var stub_handle  = native_ctx_stub_handle(ctx);
    var ib_handle    = native_ctx_ib_handle(ctx);
    var ib_va        = native_ctx_ib_active_va(ctx);
    var ib_addr      = native_ctx_ib_active_addr(ctx);
    var fence_handle = native_ctx_fence_handle(ctx);
    memset(ib_addr, 0, 4096);
    memcpy(ib_addr, pm4, pm4_bytes);
    # entries: fence(1) + stub(3) + each binding(3) + shader(4) + ib(10).
    var entries[256];
    var ne = 0;
    store32(&entries + ne * 8, fence_handle);
    store32(&entries + ne * 8 + 4, 1);
    ne = ne + 1;
    store32(&entries + ne * 8, stub_handle);
    store32(&entries + ne * 8 + 4, 3);
    ne = ne + 1;
    var bi = 0;
    while (bi < n_binds) {
        store32(&entries + ne * 8, load64(binds + bi * 8));
        store32(&entries + ne * 8 + 4, 3);
        ne = ne + 1;
        bi = bi + 1;
    }
    store32(&entries + ne * 8, shader_handle);
    store32(&entries + ne * 8 + 4, 4);
    ne = ne + 1;
    store32(&entries + ne * 8, ib_handle);
    store32(&entries + ne * 8 + 4, 10);
    ne = ne + 1;
    var bo_list_in[24];
    store32(&bo_list_in + 0, 0xFFFFFFFF);
    store32(&bo_list_in + 4, 0xFFFFFFFF);
    store32(&bo_list_in + 8, ne);
    store32(&bo_list_in + 12, 8);
    store64(&bo_list_in + 16, &entries);
    var wait_so = queue_pending_wait_syncobj(queue);
    var wait_pt = queue_pending_wait_point(queue);
    queue_clear_pending_wait(queue);
    var point = queue_bump_point(queue);
    var rc = native_cs_submit_timeline(fd, cid, &bo_list_in, ib_va, pm4_bytes,
    ip_type, syncobj, point, wait_so, wait_pt, fence_handle, 32, 0x08);
    return _native_neg_rc_to_gpu_err(rc);
}

# ================================================================
# v3.2 X.4 — SDMA buffer-copy on the DMA ring (timeline path)
# ================================================================
# The SDMA analog of native_compute_dispatch_cached_timeline. Copies
# `bytes` from src_va to dst_va on the AMDGPU DMA (SDMA) ring via a
# single COPY_LINEAR packet, signalling the queue's persistent timeline
# on completion. Lifts the HW-proven submit shape from the v3.1 Q.6
# native_multiqueue_e2e leg 3 (manual SDMA leg) into a reusable driver
# the public gpu_buffer_copy / gpu_queue_transfer_copy slot (X.5) calls.
#
# Differences from the compute/render timeline drivers:
#   - ip_type is hard-wired to AMDGPU_HW_IP_DMA — this driver only runs
#     on the SDMA ring, and rejects a queue bound to any other ring.
#   - 4-entry BO_HANDLES list (fence, ib, src, dst): no shader/stub BO,
#     src+dst are the copy operands. Residency priorities match the
#     native_sdma_copy_e2e spike (fence=1, ib=10, src/dst=3).
#   - ib_flags = 0 — SDMA needs no TC writeback hook.
# Pending cross-ring waits recorded by gpu_queue_barrier are consumed
# into an in-CS TIMELINE_WAIT exactly as on the compute path.
fn native_transfer_copy_timeline(ctx, src_handle, src_va,
dst_handle, dst_va, bytes, queue): i64 {
    if (ctx == 0)   { return GPU_ERR_OTHER; }
    if (queue == 0) { return GPU_ERR_OTHER; }
    # SDMA-ring-only: a copy aimed at a GFX/compute queue is a mis-route.
    if (queue_ring(queue) != AMDGPU_HW_IP_DMA) { return GPU_ERR_TRANSFER; }
    if (bytes <= 0) { return GPU_ERR_BUFFER; }
    # Note: no single-packet 4 MiB cap here anymore — the chained builder
    # below (v3.2 X.8) splits `bytes` across packets and rejects only if the
    # chain overflows the IB.
    var syncobj = queue_syncobj(queue);
    if (syncobj == 0) { return GPU_ERR_OTHER; }

    var fd  = native_ctx_fd(ctx);
    var cid = native_ctx_id(ctx);
    var ib_handle    = native_ctx_ib_handle(ctx);
    var ib_va        = native_ctx_ib_active_va(ctx);
    var ib_addr      = native_ctx_ib_active_addr(ctx);
    var fence_handle = native_ctx_fence_handle(ctx);

    # Stage the SDMA copy into the cached IB BO — chained into as many
    # COPY_LINEAR packets as `bytes` needs (each <= 4 MiB; v3.2 X.8). A copy
    # too large to fit the IB's packet chain returns 0 here -> GPU_ERR_BUFFER
    # (nothing submitted); the ceiling is ~146 packets / ~584 MiB per submit.
    memset(ib_addr, 0, _NATIVE_IB_SIZE);
    var sdma_bytes = native_sdma_build_copy_chained(ib_addr, src_va, dst_va,
    bytes, _NATIVE_IB_SIZE);
    if (sdma_bytes == 0) { return GPU_ERR_BUFFER; }

    # 4-entry inline BO_HANDLES list (fence, ib, src, dst).
    var entries[32];
    store32(&entries +  0, fence_handle); store32(&entries +  4, 1);
    store32(&entries +  8, ib_handle);    store32(&entries + 12, 10);
    store32(&entries + 16, src_handle);   store32(&entries + 20, 3);
    store32(&entries + 24, dst_handle);   store32(&entries + 28, 3);
    var bo_list_in[24];
    store32(&bo_list_in +  0, 0xFFFFFFFF);
    store32(&bo_list_in +  4, 0xFFFFFFFF);
    store32(&bo_list_in +  8, 4);
    store32(&bo_list_in + 12, 8);
    store64(&bo_list_in + 16, &entries);

    # Consume any pending cross-ring wait (gpu_queue_barrier) as an in-CS
    # TIMELINE_WAIT; read + clear before submit so queue state is clean.
    var wait_so = queue_pending_wait_syncobj(queue);
    var wait_pt = queue_pending_wait_point(queue);
    queue_clear_pending_wait(queue);

    # Reserve this copy's timeline point and submit signalling it on
    # completion. ib_flags = 0 (SDMA needs no TC writeback hook).
    var point = queue_bump_point(queue);
    var rc = native_cs_submit_timeline(fd, cid, &bo_list_in, ib_va, sdma_bytes,
    AMDGPU_HW_IP_DMA, syncobj, point, wait_so, wait_pt, fence_handle, 32, 0);
    return _native_neg_rc_to_gpu_err(rc);
}

# v3.2 X.5 — buffer_copy backend slot (native). Copies `bytes` from
# src_buf to dst_buf (both NativeBuf*) on `queue`'s SDMA ring, then
# blocks until the copy retires so dst is readable on return (the v3.0
# synchronous buffer write/read contract). The public dispatchers
# (gpu_buffer_copy / gpu_queue_transfer_copy in buffer.cyr / queue.cyr)
# resolve the queue and route here through BACKEND_SLOT_BUFFER_COPY.
# Bounds the copy by both buffers' logical sizes; the queue-ring (DMA)
# check lives in native_transfer_copy_timeline. Returns 0|GPU_ERR_*.
fn _backend_native_buffer_copy(ctx, queue, src_buf, dst_buf, bytes): i64 {
    if (ctx == 0)     { return GPU_ERR_OTHER; }
    if (src_buf == 0) { return GPU_ERR_BUFFER; }
    if (dst_buf == 0) { return GPU_ERR_BUFFER; }
    if (queue == 0)   { return GPU_ERR_OTHER; }
    if (bytes <= 0)   { return GPU_ERR_BUFFER; }
    var src_size = load64(src_buf + NATIVE_BUF_FIELD_SIZE);
    var dst_size = load64(dst_buf + NATIVE_BUF_FIELD_SIZE);
    if (bytes > src_size) { return GPU_ERR_BUFFER; }
    if (bytes > dst_size) { return GPU_ERR_BUFFER; }
    var src_handle = load64(src_buf + NATIVE_BUF_FIELD_HANDLE);
    var src_va     = load64(src_buf + NATIVE_BUF_FIELD_VA);
    var dst_handle = load64(dst_buf + NATIVE_BUF_FIELD_HANDLE);
    var dst_va     = load64(dst_buf + NATIVE_BUF_FIELD_VA);
    var rc = native_transfer_copy_timeline(ctx, src_handle, src_va,
    dst_handle, dst_va, bytes, queue);
    if (rc != 0) { return rc; }
    return _backend_native_queue_wait_idle(ctx, queue);
}

# ================================================================
# v3 Step 6.6 — GFX-ring dispatch (clear-triangle composer's submit path)
# ================================================================
# Mirrors native_compute_dispatch_cached but on the GFX ring. Same
# 4-chunk Mesa-shape submit, same per-context cached IB+fence BOs;
# differs in:
#   - ip_type = AMDGPU_HW_IP_GFX (graphics ring) instead of _COMPUTE.
#   - BO_HANDLES list = (fence, vs, fs, rt, ib) — five entries, like
#     compute's (fence, stub, out, shader, ib) but with the compute
#     stub dropped and shader split into vs+fs.
#   - ib_flags = 0. The PM4 stream's ACQUIRE_MEM preamble (block 0
#     of native_pm4_build_render_clear_triangle) does the cache
#     invalidate; we don't need the kernel's TC writeback hook that
#     0x08 (TC_WB_NOT_INVALIDATE) toggles for compute.
# Render-handle pair convention (the analog of compute's `bp`
# (handle, va) pair): a 24-byte (vs_h, fs_h, rt_h) triple, packed via
# native_render_handles_write below. Caller-managed BOs; the cached
# IB+fence come from the GpuContext.
#
# Verification: structural unit tests in mabda_v3.tcyr pin the
# residency priority list and the 24-byte triple layout. The full
# submit + wait path exercises real syscalls, so the e2e gate is
# 6.9(b)'s programs/native_render_e2e.cyr (HW required).

# Pack a (vs_handle, fs_handle, rt_handle) triple into a 24-byte
# block. Mirror of native_buf_pair_write for the render dispatch
# slot. Caller allocates 24 bytes for `dst` (typically a stack-local
# `var triple[24]`); this helper writes the three u64 fields.
fn native_render_handles_write(dst, vs_h, fs_h, rt_h, tex_h): i64 {
    store64(dst +  0, vs_h);
    store64(dst +  8, fs_h);
    store64(dst + 16, rt_h);
    store64(dst + 24, tex_h);   # v3.2 TS.5 — sampled texture BO, 0 if none
    return 0;
}

# Build the 5-entry BO_HANDLES list for a render dispatch: each entry
# is a u32 KMS handle followed by a u32 residency priority. Layout
# matches compute's inline 5-entry build but with vs+fs+rt instead of
# stub+out+shader.
#
# Priorities match the pattern compute uses (fence=1 lowest, ib=10
# highest): the user-fence BO has lowest priority because the kernel
# only writes 8 bytes to it; the IB has highest because every PM4
# fetch reads from it. VS+FS get shader-priority 4 (matching compute's
# shader_handle); the RT gets out-priority 3 (matching compute's
# out_handle). Caller pre-allocates 40 bytes for `entries40`.
fn native_render_bo_list_pack(entries40, fence_h, vs_h, fs_h, rt_h, ib_h): i64 {
    store32(entries40 +  0, fence_h); store32(entries40 +  4, 1);
    store32(entries40 +  8, vs_h);    store32(entries40 + 12, 4);
    store32(entries40 + 16, fs_h);    store32(entries40 + 20, 4);
    store32(entries40 + 24, rt_h);    store32(entries40 + 28, 3);
    store32(entries40 + 32, ib_h);    store32(entries40 + 36, 10);
    return 0;
}

# v3.2 TS.5 — 6-entry variant adding the sampled texture's surface BO (which,
# in the single-BO sampleable layout, also carries the T#/S# descriptor) to
# residency so the textured FS's s_load_dwordx8 + image_load don't fault.
fn native_render_bo_list_pack6(entries48, fence_h, vs_h, fs_h, rt_h, tex_h, ib_h): i64 {
    store32(entries48 +  0, fence_h); store32(entries48 +  4, 1);
    store32(entries48 +  8, vs_h);    store32(entries48 + 12, 4);
    store32(entries48 + 16, fs_h);    store32(entries48 + 20, 4);
    store32(entries48 + 24, rt_h);    store32(entries48 + 28, 3);
    store32(entries48 + 32, tex_h);   store32(entries48 + 36, 3);
    store32(entries48 + 40, ib_h);    store32(entries48 + 44, 10);
    return 0;
}

# Submit a pre-built render PM4 stream on the GFX ring. The PM4 must
# be the output of native_pm4_build_render_clear_triangle (or a
# future render composer that follows the same per-dispatch self-
# contained shape). `render_handles_ptr` points to a 24-byte triple
# packed by native_render_handles_write.
#
# Returns 0 on success (syncobj signaled within timeout) or a
# GPU_ERR_* code on failure. Does NOT verify pixels — that's the
# 6.9(b) e2e program's job.
fn native_render_dispatch_simple(ctx, pm4, pm4_bytes,
render_handles_ptr, timeout_ns): i64 {
    var fd = native_ctx_fd(ctx);
    var cid = native_ctx_id(ctx);
    var ib_handle   = native_ctx_ib_handle(ctx);
    var ib_va       = native_ctx_ib_va(ctx);
    var ib_addr     = native_ctx_ib_addr(ctx);
    var fence_handle = native_ctx_fence_handle(ctx);
    var fence_addr   = native_ctx_fence_addr(ctx);

    var vs_handle = load64(render_handles_ptr +  0);
    var fs_handle = load64(render_handles_ptr +  8);
    var rt_handle = load64(render_handles_ptr + 16);
    var tex_handle = load64(render_handles_ptr + 24);   # v3.2 TS.5 (0 = none)

    # Stage PM4 into the cached IB BO (memset + memcpy; no alloc).
    memset(ib_addr, 0, 4096);
    memcpy(ib_addr, pm4, pm4_bytes);

    # Pre-zero the user-fence slot so the kernel's seqno write is observable.
    store64(fence_addr + 32, 0);

    # BO_HANDLES list (Mesa-shape): fence / vs / fs / rt / [tex] / ib. The
    # sampled texture BO joins residency only when one is bound (TS.5).
    var entries[48];
    var n_entries = 5;
    if (tex_handle != 0) {
        native_render_bo_list_pack6(&entries, fence_handle,
        vs_handle, fs_handle, rt_handle, tex_handle, ib_handle);
        n_entries = 6;
    } else {
        native_render_bo_list_pack(&entries, fence_handle,
        vs_handle, fs_handle, rt_handle, ib_handle);
    }
    var bo_list_in[24];
    store32(&bo_list_in +  0, 0xFFFFFFFF);
    store32(&bo_list_in +  4, 0xFFFFFFFF);
    store32(&bo_list_in +  8, n_entries);
    store32(&bo_list_in + 12, 8);
    store64(&bo_list_in + 16, &entries);

    # Per-dispatch syncobj (cheap; one ioctl create + one destroy).
    # Audit LOW-5: stack-local out-ptr — same rationale as the
    # compute dispatcher above.
    var syncobj_buf[8];
    var rc = native_syncobj_create(fd, &syncobj_buf);
    if (rc != 0) { return _native_neg_rc_to_gpu_err(rc); }
    var syncobj_handle = load64(&syncobj_buf);

    # 4-chunk Mesa-shape submit on the GFX ring. ib_flags=0 (no
    # TC_WB_NOT_INVALIDATE — graphics' ACQUIRE_MEM in the PM4 stream
    # handles cache invalidation directly).
    rc = native_cs_submit_4chunk(fd, cid, &bo_list_in, ib_va, pm4_bytes,
    AMDGPU_HW_IP_GFX, syncobj_handle,
    fence_handle, 32, 0);
    if (rc != 0) {
        var rc_save = rc;
        native_syncobj_destroy(fd, syncobj_handle);
        return _native_neg_rc_to_gpu_err(rc_save);
    }

    var wait_rc = native_syncobj_wait(fd, syncobj_handle, timeout_ns);
    native_syncobj_destroy(fd, syncobj_handle);
    return _native_neg_rc_to_gpu_err(wait_rc);
}

# ================================================================
# v3.2.13 R.4 — queue-targeted render dispatch (async, timeline)
# ================================================================
# The render analog of native_compute_dispatch_cached_timeline: submits a
# pre-built render PM4 stream on `queue`'s GFX ring, signalling that
# queue's PERSISTENT timeline syncobj at the next point (queue_bump_point)
# instead of an ephemeral binary syncobj, and consuming any pending
# cross-ring barrier (gpu_queue_barrier, Q.4) as an in-CS TIMELINE_WAIT.
# It does NOT wait — the caller controls completion via
# gpu_queue_wait_idle / orders with gpu_queue_barrier. This is the missing
# piece that lets render NODES join cross-ring overlap in the multi-queue
# render graph (Phase R); the synchronous native_render_dispatch_simple
# stays the single-shot path the v2.5 executor uses.
#
# Same BO_HANDLES shape + ib_flags=0 as native_render_dispatch_simple
# (fence / vs / fs / rt / [tex] / ib; the GFX PM4's ACQUIRE_MEM preamble
# does the cache invalidate, so no TC writeback hook). render_handles_ptr
# is a triple packed by native_render_handles_write.
#
# Ring guard: render PM4 (draw packets + graphics registers) only runs on
# the GFX ring, so a queue bound to any other ring is a mis-route
# (GPU_ERR_OTHER) — mirroring native_transfer_copy_timeline's DMA-only
# guard. The pm4_bytes > IB-size guard stops a malformed stream from
# overrunning the cached IB BO (R.4 audit: IB-staging bound check).
#
# MVP caveat (same as the compute timeline path): the cached IB BO is
# shared per context, so the contract is one in-flight queue-targeted
# render dispatch per queue before a wait/barrier. R.5 lifts this with
# per-node IB staging. Returns 0|GPU_ERR_*.
fn native_render_dispatch_timeline(ctx, pm4, pm4_bytes,
render_handles_ptr, queue): i64 {
    if (ctx == 0)   { return GPU_ERR_OTHER; }
    if (queue == 0) { return GPU_ERR_OTHER; }
    # GFX-ring-only: a render stream aimed at a compute/DMA queue mis-routes.
    if (queue_ring(queue) != AMDGPU_HW_IP_GFX) { return GPU_ERR_OTHER; }
    if (pm4_bytes <= 0) { return GPU_ERR_OTHER; }
    if (pm4_bytes > _NATIVE_IB_SIZE) { return GPU_ERR_OTHER; }
    var syncobj = queue_syncobj(queue);
    if (syncobj == 0) { return GPU_ERR_OTHER; }

    var fd = native_ctx_fd(ctx);
    var cid = native_ctx_id(ctx);
    var ib_handle    = native_ctx_ib_handle(ctx);
    var ib_va        = native_ctx_ib_active_va(ctx);
    var ib_addr      = native_ctx_ib_active_addr(ctx);
    var fence_handle = native_ctx_fence_handle(ctx);
    var fence_addr   = native_ctx_fence_addr(ctx);

    var vs_handle  = load64(render_handles_ptr +  0);
    var fs_handle  = load64(render_handles_ptr +  8);
    var rt_handle  = load64(render_handles_ptr + 16);
    var tex_handle = load64(render_handles_ptr + 24);   # TS.5 (0 = none)

    # Stage PM4 into the cached IB BO.
    memset(ib_addr, 0, _NATIVE_IB_SIZE);
    memcpy(ib_addr, pm4, pm4_bytes);
    # Pre-zero the user-fence slot so the kernel's seqno write is observable.
    store64(fence_addr + 32, 0);

    # BO_HANDLES list: fence / vs / fs / rt / [tex] / ib (TS.5 6-entry
    # when a sampled texture is bound).
    var entries[48];
    var n_entries = 5;
    if (tex_handle != 0) {
        native_render_bo_list_pack6(&entries, fence_handle,
        vs_handle, fs_handle, rt_handle, tex_handle, ib_handle);
        n_entries = 6;
    } else {
        native_render_bo_list_pack(&entries, fence_handle,
        vs_handle, fs_handle, rt_handle, ib_handle);
    }
    var bo_list_in[24];
    store32(&bo_list_in +  0, 0xFFFFFFFF);
    store32(&bo_list_in +  4, 0xFFFFFFFF);
    store32(&bo_list_in +  8, n_entries);
    store32(&bo_list_in + 12, 8);
    store64(&bo_list_in + 16, &entries);

    # Consume any pending cross-ring wait (gpu_queue_barrier) as an in-CS
    # TIMELINE_WAIT; read + clear before submit so queue state is clean.
    var wait_so = queue_pending_wait_syncobj(queue);
    var wait_pt = queue_pending_wait_point(queue);
    queue_clear_pending_wait(queue);

    # Reserve this dispatch's timeline point and submit signalling it on
    # completion. ib_flags=0 (GFX ACQUIRE_MEM handles cache invalidation).
    var point = queue_bump_point(queue);
    var rc = native_cs_submit_timeline(fd, cid, &bo_list_in, ib_va, pm4_bytes,
    AMDGPU_HW_IP_GFX, syncobj, point, wait_so, wait_pt, fence_handle, 32, 0);
    return _native_neg_rc_to_gpu_err(rc);
}

# ================================================================
# v3 Step 4c — native Backend interface implementation
# ================================================================
# Fills the @internal Backend struct (src/backend.cyr) with native
# (AMD/amdgpu/GFX9) slot wrappers. Step 4c lands the compute_dispatch
# slot end-to-end + 9 stubs for the rest. Step 4d+ will fill the
# stubs as native buffer / shader_module / surface paths land.
#
# Native GpuContext field interpretation:
#   On wgpu, the +0..+24 fields are instance/adapter/device/queue.
#   On native, they are reinterpreted as:
#     +0:  fd            (DRM render-node fd)
#     +8:  ctx_id        (amdgpu context id)
#     +16: stub_handle   (Mesa scratch V# stub BO handle)
#     +24: stub_va       (stub BO VA, canonical-high)
#     +40: stub_addr     (stub BO CPU mmap pointer; native-only,
#                         used for the post-dispatch marker check)
#   The +32 backend ptr is the same on both; backend_kind(b) tells
#   you which interpretation to use. wgpu leaves +40 zero. Future
#   native contexts that need more state will need to grow
#   GpuContext or push state behind the backend ptr.
#
# Buffer-handle convention used by the slot wrappers:
#   shmod and bp args are pointers to 16-byte (handle, va) pairs:
#     +0: u64 KMS handle
#     +8: u64 GPU VA
#   This is a private convention between caller and the native
#   compute_dispatch slot — until a public gpu_buffer_native_new()
#   helper lands, callers pack the pair manually.

fn native_ctx_fd(ctx): i64 { return load64(ctx +   0); }
fn native_ctx_id(ctx): i64 { return load64(ctx +   8); }
fn native_ctx_stub_handle(ctx): i64 { return load64(ctx +  16); }
fn native_ctx_stub_va(ctx): i64 { return load64(ctx +  24); }
fn native_ctx_stub_addr(ctx): i64 { return load64(ctx +  40); }
fn native_ctx_ib_handle(ctx): i64 { return load64(ctx +  48); }
fn native_ctx_ib_va(ctx): i64 { return load64(ctx +  56); }
fn native_ctx_ib_addr(ctx): i64 { return load64(ctx +  64); }
fn native_ctx_fence_handle(ctx): i64 { return load64(ctx +  72); }
fn native_ctx_fence_va(ctx): i64 { return load64(ctx +  80); }
fn native_ctx_fence_addr(ctx): i64 { return load64(ctx +  88); }
# v3.2.14 R.5 — per-node IB staging. The cached IB BO is partitioned into
# _NATIVE_IB_SLOTS contiguous 4 KiB slices; the cursor (ctx +160) selects
# the active one. native_ctx_ib_active_{va,addr} return the active slice's
# GPU VA / CPU pointer (base + cursor*_NATIVE_IB_SIZE); the slice handle is
# the one BO (native_ctx_ib_handle). The MQ executor calls
# native_ctx_ib_advance per node to rotate; single-shot / synchronous paths
# leave the cursor at 0 (slice 0 == base, so their behaviour is unchanged).
fn native_ctx_ib_slot_cursor(ctx): i64 { return load64(ctx + 160); }
fn native_ctx_ib_active_va(ctx): i64 {
    return native_ctx_ib_va(ctx) + native_ctx_ib_slot_cursor(ctx) * _NATIVE_IB_SIZE;
}
fn native_ctx_ib_active_addr(ctx): i64 {
    return native_ctx_ib_addr(ctx) + native_ctx_ib_slot_cursor(ctx) * _NATIVE_IB_SIZE;
}
# Advance the cursor to the next slice (round-robin over _NATIVE_IB_SLOTS).
# Returns the new cursor. Wrapping past the last slice reuses slice 0 — the
# executor must have retired (wait_idle) any submit still using it; the ring
# depth bounds the safe in-flight count.
fn native_ctx_ib_advance(ctx): i64 {
    var c = native_ctx_ib_slot_cursor(ctx) + 1;
    if (c >= _NATIVE_IB_SLOTS) { c = 0; }
    store64(ctx + 160, c);
    return c;
}
# Reset the staging cursor to slice 0 (the MQ executor calls this at graph
# start so each execution begins from a deterministic slice).
fn native_ctx_ib_reset_slots(ctx): i64 {
    store64(ctx + 160, 0);
    return 0;
}
# Audit MED-7: per-context PM4 build scratch (1024 bytes), allocated
# once at gpu_context_new_native, shared between compute + render slots.
fn native_ctx_pm4_scratch(ctx): i64 { return load64(ctx + 112); }

# v3.1 M.1(c): per-context texture VA bump cursor at +120. Zero on a
# fresh ctx (the memset); native_ctx_alloc_texture_va lazy-inits it.
fn native_ctx_tex_va_next(ctx): i64 { return load64(ctx + 120); }
fn native_ctx_set_tex_va_next(ctx, va): i64 {
    if (ctx == 0) { return 0 - 1; }
    store64(ctx + 120, va);
    return 0;
}

# Pack (handle, va) into the private 16-byte buffer-pair shape.
# Caller allocates 16 bytes for `dst` (typically a stack-local
# `var pair[16]`); this helper writes the two u64 fields.
fn native_buf_pair_write(dst, handle, va): i64 {
    store64(dst + 0, handle);
    store64(dst + 8, va);
    return 0;
}

# ----------------------------------------------------------------
# Slot wrappers
# ----------------------------------------------------------------

# Slot signature: ctx_create_from_preinit(preinit_ptr) → ctx.
# Native does not consume preinit_ptr — it opens its own DRM fd
# and allocates its own ctx_id, packing them into a fresh ctx
# struct. Step 4c stub: returns 0 (caller is expected to populate
# ctx fields explicitly via native_ctx_init_from_handles below
# until a real implementation lands in Step 4d+).
fn _backend_native_ctx_create_from_preinit(preinit_ptr): i64 {
    return 0;
}

fn _backend_native_ctx_release(ctx): i64 {
    if (ctx == 0) { return 0; }
    var fd = native_ctx_fd(ctx);
    var ctx_id = native_ctx_id(ctx);
    var ib_handle = native_ctx_ib_handle(ctx);
    var ib_va = native_ctx_ib_va(ctx);
    var ib_addr = native_ctx_ib_addr(ctx);
    var fence_handle = native_ctx_fence_handle(ctx);
    var fence_va = native_ctx_fence_va(ctx);
    var fence_addr = native_ctx_fence_addr(ctx);
    # Release per-context cached fence + IB BOs (Step 4f.iv).
    if (fence_handle != 0) {
        native_gem_va_unmap(fd, fence_handle, fence_va, 4096);
        native_bo_release_gtt(fd, fence_handle, fence_addr, 4096);
    }
    if (ib_handle != 0) {
        # R.5: the IB BO spans _NATIVE_IB_SLOTS slices.
        var ib_total = _NATIVE_IB_SIZE * _NATIVE_IB_SLOTS;
        native_gem_va_unmap(fd, ib_handle, ib_va, ib_total);
        native_bo_release_gtt(fd, ib_handle, ib_addr, ib_total);
    }
    # v3.1 Q.3b: destroy the per-queue persistent timeline syncobjs.
    # The Queue structs themselves are bump-allocated (native no-reclaim
    # model); only the kernel syncobj handles need explicit release.
    if (fd > 0) {
        var qk = 0;
        while (qk < QUEUE_KIND_COUNT) {
            var q = gpu_ctx_queue_slot(ctx, qk);
            if (q != 0) {
                var so = queue_syncobj(q);
                if (so != 0) { native_syncobj_destroy(fd, so); }
            }
            qk = qk + 1;
        }
    }
    if (ctx_id != 0) { native_ctx_free(fd, ctx_id); }
    if (fd > 0) { sys_close(fd); }
    return 0;
}

# Buffer slots — diagnostic stubs (audit LOW-3).
#
# Public gpu_buffer_* on native AMD — REAL as of v3.2 (Phase X). A native
# buffer is a linear GTT BO (the same primitive textures use): the BO's
# mmap address IS the data, so write/read collapse to memcpy (X.2). This
# unblocks the public transfer-copy API (gpu_buffer_copy, X.5) + portable
# consumer buffer code.
#
# NativeBuf struct (32 bytes — NativeTexture shape):
#   +0:  handle  (u64, KMS handle)
#   +8:  va      (u64, canonical-high GPU VA)
#   +16: addr    (u64, CPU mmap pointer)
#   +24: size    (u64, LOGICAL byte count requested; the BO + VA map use a
#                 4 KiB-page-aligned size since native_gem_va_map rejects a
#                 sub-page size — see reference_gem_va_map_page_align)
var NATIVE_BUF_FIELD_HANDLE = 0;
var NATIVE_BUF_FIELD_VA     = 8;
var NATIVE_BUF_FIELD_ADDR   = 16;
var NATIVE_BUF_FIELD_SIZE   = 24;
var NATIVE_BUF_STRUCT_SIZE  = 32;

# Create a native buffer of `size` bytes. `usage` is ignored on native (a
# GTT BO is general-purpose; wgpu uses it). Returns a NativeBuf* or 0 on
# bad input / region exhaustion / ioctl failure. (HW path; the guards are
# CPU-tested, the BO create/map is HW.)
fn _backend_native_buffer_create(ctx, size, usage): i64 {
    if (ctx == 0) { return 0; }
    if (size <= 0) { return 0; }
    # Bound size so _native_align_up can't overflow + the VA region can hold
    # it (the allocator also returns 0 on exhaustion).
    if (size > _NATIVE_TEXTURE_VA_REGION) { return 0; }
    var fd = native_ctx_fd(ctx);
    var bo_size = _native_align_up(size, 4096);
    var va = native_ctx_alloc_texture_va(ctx, bo_size);
    if (va == 0) { return 0; }
    var bo[16];
    var rc = native_bo_create_gtt(fd, bo_size, &bo);
    if (rc != 0) { return 0; }
    var handle = load64(&bo + 0);
    var addr   = load64(&bo + 8);
    rc = native_gem_va_map(fd, handle, va, bo_size, _NATIVE_PERM_DATA);
    if (rc != 0) {
        native_bo_release_gtt(fd, handle, addr, bo_size);
        return 0;
    }
    var buf = alloc(NATIVE_BUF_STRUCT_SIZE);
    memset(buf, 0, NATIVE_BUF_STRUCT_SIZE);
    store64(buf + NATIVE_BUF_FIELD_HANDLE, handle);
    store64(buf + NATIVE_BUF_FIELD_VA,     va);
    store64(buf + NATIVE_BUF_FIELD_ADDR,   addr);
    store64(buf + NATIVE_BUF_FIELD_SIZE,   size);   # logical
    return buf;
}

# Write `n` bytes from `ptr` into the buffer at byte offset `off`. The BO's
# mmap address IS the data (linear GTT, coherent), so this is a bounds-
# checked memcpy. Bounds are overflow-safe: `off > size` is rejected before
# computing `size - off`, so `off + n` never overflows. Returns 0|GPU_ERR_*.
fn _backend_native_buffer_write(ctx, buf, off, ptr, n): i64 {
    if (ctx == 0) { return GPU_ERR_OTHER; }
    if (buf == 0) { return GPU_ERR_OTHER; }
    if (ptr == 0) { return GPU_ERR_BUFFER; }
    if (n <= 0)   { return GPU_ERR_BUFFER; }
    if (off < 0)  { return GPU_ERR_BUFFER; }
    var size = load64(buf + NATIVE_BUF_FIELD_SIZE);
    var addr = load64(buf + NATIVE_BUF_FIELD_ADDR);
    if (addr == 0) { return GPU_ERR_BUFFER; }
    if (off > size) { return GPU_ERR_BUFFER; }
    if (n > size - off) { return GPU_ERR_BUFFER; }   # off+n > size, overflow-safe
    memcpy(addr + off, ptr, n);
    return 0;
}

# Read `n` bytes from the buffer at offset `off` into `ptr`. Symmetric
# bounds-checked memcpy. Returns 0|GPU_ERR_*.
fn _backend_native_buffer_read(ctx, buf, off, ptr, n): i64 {
    if (ctx == 0) { return GPU_ERR_OTHER; }
    if (buf == 0) { return GPU_ERR_OTHER; }
    if (ptr == 0) { return GPU_ERR_BUFFER; }
    if (n <= 0)   { return GPU_ERR_BUFFER; }
    if (off < 0)  { return GPU_ERR_BUFFER; }
    var size = load64(buf + NATIVE_BUF_FIELD_SIZE);
    var addr = load64(buf + NATIVE_BUF_FIELD_ADDR);
    if (addr == 0) { return GPU_ERR_BUFFER; }
    if (off > size) { return GPU_ERR_BUFFER; }
    if (n > size - off) { return GPU_ERR_BUFFER; }
    memcpy(ptr, addr + off, n);
    return 0;
}

# Release a native buffer: VA-unmap + BO-release using the same page-aligned
# size the create mapped, then zero the struct. Null-safe.
fn _backend_native_buffer_release(ctx, buf): i64 {
    if (ctx == 0) { return 0; }
    if (buf == 0) { return 0; }
    var fd = native_ctx_fd(ctx);
    var handle = load64(buf + NATIVE_BUF_FIELD_HANDLE);
    var va     = load64(buf + NATIVE_BUF_FIELD_VA);
    var addr   = load64(buf + NATIVE_BUF_FIELD_ADDR);
    var bo_size = _native_align_up(load64(buf + NATIVE_BUF_FIELD_SIZE), 4096);
    if (handle != 0) {
        native_gem_va_unmap(fd, handle, va, bo_size);
        native_bo_release_gtt(fd, handle, addr, bo_size);
    }
    memset(buf, 0, NATIVE_BUF_STRUCT_SIZE);
    return 0;
}

# Native compiled shader-module struct (N.6r). The compute-dispatch slot must
# distinguish a COMPILED kernel (carrying the compiler's RSRC + binding count +
# local size, dispatched through the generic composer) from the legacy 16-byte
# (handle,va) "deadbeef" pair that native_compute_store / the queue programs pass
# straight to the hardcoded composer. They share the first words, so a magic tag
# at +0 is the discriminator: a legacy pair holds a small u32 GEM handle there,
# never this 64-bit value. Fields:
#   +0  magic   (NATIVE_SHMOD_MAGIC_VAL)
#   +8  handle  (GTT BO handle of the ISA)
#   +16 va      (GPU VA of the ISA, _NATIVE_PERM_SHADER)
#   +24 addr    (CPU mmap pointer — needed for bo-release)
#   +32 rsrc1   (COMPUTE_PGM_RSRC1 from gfx9_compile)
#   +40 rsrc2   (COMPUTE_PGM_RSRC2)
#   +48 nbind   (binding count — bindings k→USER_DATA s[2k:2k+1])
#   +56 local_x (LocalSize.x → PM4 NUM_THREAD_X; must match the compiled shader)
#   +64 isa_len (ISA byte length, incl. the prefetch pad)
#   +72 local_y / +80 local_z (LocalSize.y/.z → NUM_THREAD_Y/Z — full 3-D geometry)
var NATIVE_SHMOD_MAGIC_VAL = 0x4D42444153484D31;   # "MBDASHM1"
var NATIVE_SHMOD_MAGIC   = 0;
var NATIVE_SHMOD_HANDLE  = 8;
var NATIVE_SHMOD_VA      = 16;
var NATIVE_SHMOD_ADDR    = 24;
var NATIVE_SHMOD_RSRC1   = 32;
var NATIVE_SHMOD_RSRC2   = 40;
var NATIVE_SHMOD_NBIND   = 48;
var NATIVE_SHMOD_LOCALX  = 56;
var NATIVE_SHMOD_ISALEN  = 64;
var NATIVE_SHMOD_LOCALY  = 72;
var NATIVE_SHMOD_LOCALZ  = 80;
var NATIVE_SHMOD_SIZE    = 88;

# Compile cap for shader-module-create: id_bound / cap_ids ceiling for the compile
# scratch below. SPIR-V whose header id_bound exceeds this fails loud (gfx9_compile
# → CMP_ERR_TABLE → this returns 0). 256 is the ARCHITECTURAL ceiling: the regalloc
# free-at scratch + the gfx9_compile/gfx9_waitcnt per-id file-maps are sized for
# RA_MAX_REGS=256, so cap_ids > 256 is rejected by those stages anyway. Raising it
# further needs growing those internal scratch buffers (a deeper N.8 change).
var NATIVE_SHADER_CAP_IDS = 256;

# Compile a SPIR-V compute kernel to GFX9 ISA, stage it in a fresh GTT BO mapped
# at a context-allocated VA, and return a magic-tagged shmod struct the compute
# dispatch consumes. Returns 0 on ANY failure (validate / compile / VA / BO /
# va-map / OOM) — the fail-loud null per the slot contract. All compile scratch is
# stack-transient (freed on return); only the 72-B shmod is alloc'd (it must
# outlive the call), and the ISA BO is a GPU resource freed by _release.
fn _native_shader_compile_spirv(ctx, words_ptr, byte_len): i64 {
    if (ctx == 0)       { return 0; }
    if (words_ptr == 0) { return 0; }
    # The SPIR-V header is 5 words (20 B); reject anything shorter BEFORE reading
    # spirv_hdr_id_bound (word 3, offset 12) below — gfx9_compile's validate gate
    # runs only later, so without this a 1..19-byte buffer is an OOB header read
    # (N.6r review, HIGH). 20 is the floor; full structural validation is the gate's.
    if (byte_len < 20) { return 0; }

    # --- compile (pure CPU); scratch sized for NATIVE_SHADER_CAP_IDS=256 ids ---
    var types[6144];     # 256 * SPIRV_TYPE_REC(24)
    var consts[4096];    # 256 * SPIRV_CONST_REC(16)
    var deco[4096];      # 256 * SPIRV_DECO_REC(16)
    var outbi[2048];     # 256 * 8
    var m[80];
    var vals[10240];     # 256 * MIR_VAL_REC(40)
    var instrs[16384];   # 512 * MIR_INSTR_REC(32)
    var ptrs[2048];      # 128 * MIR_PTR_REC(16)
    var blocks[32];
    # The MIR synth-id counter starts right after the SPIR-V ids (the header's
    # id_bound), so synthesized values (access-chain offsets, GID expansion) get
    # fresh ids in [id_bound, NATIVE_SHADER_CAP_IDS). Passing the cap as the start
    # would leave zero synth room. id_bound > the cap fails loud in gfx9_compile's
    # table-build gate (CMP_ERR_TABLE).
    var idb = spirv_hdr_id_bound(words_ptr);
    mir_mod_init(&m, &vals, &instrs, &ptrs, &blocks, 512, 128, idb,
    NATIVE_SHADER_CAP_IDS);
    var isel[12288];     # CMP_ISEL_CAP(256) * GISEL_REC(48)
    var isel2[12288];
    var alloc[4096];     # 256 * RA_REC(16)
    var hw[16];
    var abi[64];
    var cc[88];
    store64(&cc + CC_TYPES, &types);
    store64(&cc + CC_CONSTS, &consts);
    store64(&cc + CC_DECO, &deco);
    store64(&cc + CC_M, &m);
    store64(&cc + CC_OUTBI, &outbi);
    store64(&cc + CC_ISEL, &isel);
    store64(&cc + CC_ISEL2, &isel2);
    store64(&cc + CC_ALLOC, &alloc);
    store64(&cc + CC_HW, &hw);
    store64(&cc + CC_ABI, &abi);
    store64(&cc + CC_CAP_IDS, NATIVE_SHADER_CAP_IDS);
    var isa[8192];
    memset(&isa, 0, 8192);
    var desc[72];
    if (gfx9_compile(&cc, words_ptr, byte_len, &isa, &desc) != 0) { return 0; }
    var isa_len = load64(&desc + DESC_ISA_LEN);
    if (isa_len <= 0)    { return 0; }
    if (isa_len > 8192)  { return 0; }

    # --- LocalSize x/y/z (drive PM4 NUM_THREAD_X/Y/Z; the kernel was compiled for them) ---
    var entry = spirv_find_entry_point(words_ptr, byte_len);
    var lsz[24];
    store64(&lsz + 0, 1);
    store64(&lsz + 8, 1);
    store64(&lsz + 16, 1);
    spirv_find_local_size(words_ptr, byte_len, entry, &lsz);
    var local_x = load64(&lsz + 0);
    var local_y = load64(&lsz + 8);
    var local_z = load64(&lsz + 16);
    if (local_x <= 0) { local_x = 1; }
    if (local_y <= 0) { local_y = 1; }
    if (local_z <= 0) { local_z = 1; }

    # --- stage the ISA in a GTT BO at a context-allocated VA ---
    var fd = native_ctx_fd(ctx);
    var bo_size = _native_align_up(isa_len, 4096);
    var va = native_ctx_alloc_texture_va(ctx, bo_size);
    if (va == 0) { return 0; }
    var bo[16];
    # Every post-VA-alloc error path reclaims the just-reserved VA (LIFO, no
    # intervening alloc) so a transient failure does not permanently consume the
    # 2 GiB region (N.6r review, HIGH).
    if (native_bo_create_gtt(fd, bo_size, &bo) != 0) {
        native_ctx_free_texture_va(ctx, bo_size);
        return 0;
    }
    var handle = load64(&bo + 0);
    var addr   = load64(&bo + 8);
    memset(addr, 0, bo_size);
    memcpy(addr, &isa, isa_len);
    if (native_gem_va_map(fd, handle, va, bo_size, _NATIVE_PERM_SHADER) != 0) {
        native_bo_release_gtt(fd, handle, addr, bo_size);
        native_ctx_free_texture_va(ctx, bo_size);
        return 0;
    }

    # --- the persistent (alloc'd) shmod struct ---
    var sh = alloc(NATIVE_SHMOD_SIZE);
    if (sh == 0) {
        native_gem_va_unmap(fd, handle, va, bo_size);
        native_bo_release_gtt(fd, handle, addr, bo_size);
        native_ctx_free_texture_va(ctx, bo_size);
        return 0;
    }
    store64(sh + NATIVE_SHMOD_MAGIC, NATIVE_SHMOD_MAGIC_VAL);
    store64(sh + NATIVE_SHMOD_HANDLE, handle);
    store64(sh + NATIVE_SHMOD_VA, va);
    store64(sh + NATIVE_SHMOD_ADDR, addr);
    store64(sh + NATIVE_SHMOD_RSRC1, load64(&desc + DESC_RSRC1));
    store64(sh + NATIVE_SHMOD_RSRC2, load64(&desc + DESC_RSRC2));
    store64(sh + NATIVE_SHMOD_NBIND, load64(&desc + DESC_NUM_BINDINGS));
    store64(sh + NATIVE_SHMOD_LOCALX, local_x);
    store64(sh + NATIVE_SHMOD_ISALEN, isa_len);
    store64(sh + NATIVE_SHMOD_LOCALY, local_y);
    store64(sh + NATIVE_SHMOD_LOCALZ, local_z);
    return sh;
}

# Shader-module create slot (N.6r). SPIR-V is compiled in-tree (Phase N) → a
# magic-tagged compiled shmod. WGSL and pre-compiled GFX9 are NOT accepted here:
# WGSL needs an in-mabda frontend (v3.x), and raw GFX9 ISA carries no RSRC /
# binding metadata for the dispatch to wire — both return 0 (fail-loud).
fn _backend_native_shader_module_create(ctx, bytes_ptr, n, kind): i64 {
    if (ctx == 0) { return 0; }
    if (kind == SHADER_SRC_SPIRV) {
        # v3.2 F.3 — explicit f64 gate. The Phase N emitter has no `V_*_F64` lowering yet
        # (MABDA_NATIVE_F64 = 0 until F.7), so reject an f64 module up front with a clear
        # decision rather than letting gfx9_compile fail deeper on the 64-bit float type. F.7
        # flips MABDA_NATIVE_F64 and this gate opens.
        if (spirv_uses_f64(bytes_ptr, n) == 1) {
            if (MABDA_NATIVE_F64 == 0) { return 0; }
        }
        return _native_shader_compile_spirv(ctx, bytes_ptr, n);
    }
    return 0;
}

# Release a compiled shmod: VA-unmap + BO-release + zero the struct. Null-safe and
# tag-checked — a legacy (handle,va) pair (no magic) is left untouched (its BO is
# owned by the caller that built the pair). The GPU BO — the scarce resource — is
# freed. NOT reclaimed: the 72-B struct (bump allocator has no reclaim) AND the
# shader VA from the forward-only texture region (release can run at any time, not
# LIFO, so the cursor cannot roll back — same policy as gpu_buffer/texture release).
# A consumer churning create/release exhausts the per-context 2 GiB region after
# ~32K shaders; the on-error path DOES reclaim (LIFO) — see _native_shader_compile_spirv.
fn _backend_native_shader_module_release(ctx, shmod): i64 {
    if (ctx == 0)    { return 0; }
    if (shmod == 0)  { return 0; }
    if (load64(shmod + NATIVE_SHMOD_MAGIC) != NATIVE_SHMOD_MAGIC_VAL) { return 0; }
    var fd = native_ctx_fd(ctx);
    var handle  = load64(shmod + NATIVE_SHMOD_HANDLE);
    var va      = load64(shmod + NATIVE_SHMOD_VA);
    var addr    = load64(shmod + NATIVE_SHMOD_ADDR);
    var bo_size = _native_align_up(load64(shmod + NATIVE_SHMOD_ISALEN), 4096);
    if (handle != 0) {
        native_gem_va_unmap(fd, handle, va, bo_size);
        native_bo_release_gtt(fd, handle, addr, bo_size);
    }
    memset(shmod, 0, NATIVE_SHMOD_SIZE);
    return 0;
}

# N.6 — dispatch a COMPILED shmod through the generic N-binding composer. `(x,y,z)`
# are the grid (workgroup counts); the shmod's LocalSize x/y/z are NUM_THREAD_X/Y/Z
# (the kernel's enabled WorkgroupId dims are already encoded in rsrc2 by the ABI).
# `bp` is a count-prefixed binding array (the compiled-path binding ABI): bp+0 =
# count, then count × (handle, va) 16-byte pairs. The count MUST equal the
# compiler's binding count (binding k → USER_DATA s[2k:2k+1]); a mismatch is a
# caller error. Bindings are capped at 16 (the USER_DATA ceiling the ABI enforces).
# Synchronous (cached_n).
fn _native_dispatch_compiled(ctx, shmod, x, y, z, bp, cq): i64 {
    if (bp == 0) { return GPU_ERR_OTHER; }
    var shader_handle = load64(shmod + NATIVE_SHMOD_HANDLE);
    var shader_va     = load64(shmod + NATIVE_SHMOD_VA);
    var rsrc1   = load64(shmod + NATIVE_SHMOD_RSRC1);
    var rsrc2   = load64(shmod + NATIVE_SHMOD_RSRC2);
    var nbind   = load64(shmod + NATIVE_SHMOD_NBIND);
    var local_x = load64(shmod + NATIVE_SHMOD_LOCALX);
    var local_y = load64(shmod + NATIVE_SHMOD_LOCALY);
    var local_z = load64(shmod + NATIVE_SHMOD_LOCALZ);
    if (nbind < 0)   { return GPU_ERR_OTHER; }
    if (nbind > 16)  { return GPU_ERR_OTHER; }
    if (local_x <= 0) { return GPU_ERR_OTHER; }
    if (local_y <= 0) { return GPU_ERR_OTHER; }
    if (local_z <= 0) { return GPU_ERR_OTHER; }
    # The caller's binding array count must match the kernel's binding count, else
    # we would load USER_DATA / residency from unrelated memory.
    if (load64(bp + 0) != nbind) { return GPU_ERR_OTHER; }
    var bind_vas[128];      # 16 * 8
    var bind_handles[128];
    var i = 0;
    while (i < nbind) {
        store64(&bind_handles + i * 8, load64(bp + 8 + i * 16 + 0));
        store64(&bind_vas + i * 8, load64(bp + 8 + i * 16 + 8));
        i = i + 1;
    }
    var pm4 = native_ctx_pm4_scratch(ctx);
    if (pm4 == 0) { return GPU_ERR_OTHER; }
    memset(pm4, 0, 256);
    var pm4_bytes = native_pm4_build_compute_dispatch(pm4, shader_va, rsrc1, rsrc2,
    &bind_vas, nbind, local_x, local_y, local_z, x, y, z);
    # On a logical queue (cq != 0) signal its persistent timeline so the caller can
    # order it via gpu_queue_barrier / wait via gpu_queue_wait_idle (the DMA-ring
    # mis-route was rejected upstream). cq == 0 is the v3.0 synchronous single-ring path.
    if (cq != 0) {
        return native_compute_dispatch_cached_n_timeline(ctx, pm4, pm4_bytes,
        shader_handle, &bind_handles, nbind, cq, queue_ring(cq));
    }
    var t_now[16];
    memset(&t_now, 0, 16);
    if (syscall(228, 1, &t_now) != 0) { return GPU_ERR_OTHER; }
    var deadline = load64(&t_now + 0) * 1000000000 + load64(&t_now + 8) + 15000000000;
    return native_compute_dispatch_cached_n(ctx, pm4, pm4_bytes, shader_handle,
    &bind_handles, nbind, deadline);
}

# Compute dispatch — the load-bearing slot. Step 4c lands this
# end-to-end. shmod and bp are pointers to (handle, va) pairs.
# Audit MED-7: PM4 build buffer comes from the cached per-context
# scratch (`native_ctx_pm4_scratch`) instead of a per-dispatch
# alloc(256). Lifetime contract: the scratch is shared with the
# render slot; Cyrius is single-threaded so no slot can re-enter
# while another holds it. Always memset the bytes we'll write before
# building.
fn _backend_native_compute_dispatch(ctx, shmod, x, y, z, bp): i64 {
    if (ctx == 0)   { return GPU_ERR_OTHER; }
    if (shmod == 0) { return GPU_ERR_OTHER; }
    if (bp == 0)    { return GPU_ERR_OTHER; }
    # Audit 2026-06-14 [MED-3]: defend the native slot independently of the
    # v3 dispatcher — out-of-range counts otherwise bake straight into the
    # PM4 dispatch packet + CS submit toward the kernel/GPU ring.
    if (x <= 0) { return GPU_ERR_WORKGROUP_LIMIT; }
    if (y <= 0) { return GPU_ERR_WORKGROUP_LIMIT; }
    if (z <= 0) { return GPU_ERR_WORKGROUP_LIMIT; }
    if (validate_dispatch(x, y, z, MABDA_MAX_DISPATCH_DIM) != 0) {
        return GPU_ERR_WORKGROUP_LIMIT;
    }

    # v3.2 X.3: a compute dispatch targeted at a DMA-ring (TRANSFER) queue
    # is a mis-route — SDMA cannot execute PM4 compute. Reject before
    # building the PM4 stream. (Zero stash = legacy single-ring path.)
    var cq = gpu_ctx_current_queue(ctx);
    if (cq != 0) {
        if (queue_ring(cq) == AMDGPU_HW_IP_DMA) { return GPU_ERR_TRANSFER; }
    }

    # N.6 — COMPILED-kernel path. A magic-tagged shmod (from
    # gpu_shader_module_create_spirv) carries the compiler's RSRC + binding count
    # + LocalSize, so we dispatch through the generic N-binding composer instead of
    # the hardcoded deadbeef one below. Full 3-D grid (x,y,z workgroups) + 3-D
    # LocalSize. The legacy (handle,va) pair has no magic and falls through to the
    # v3.0 deadbeef path unchanged.
    if (load64(shmod + NATIVE_SHMOD_MAGIC) == NATIVE_SHMOD_MAGIC_VAL) {
        return _native_dispatch_compiled(ctx, shmod, x, y, z, bp, cq);
    }

    var stub_va = native_ctx_stub_va(ctx);
    var shader_handle = load64(shmod + 0);
    var shader_va     = load64(shmod + 8);
    var out_handle = load64(bp + 0);
    var out_va     = load64(bp + 8);

    var pm4 = native_ctx_pm4_scratch(ctx);
    if (pm4 == 0) { return GPU_ERR_OTHER; }
    memset(pm4, 0, 256);
    var pm4_bytes = native_pm4_build_compute_store_deadbeef(pm4,
    shader_va, stub_va, out_va, x, y, z);

    # v3.1 Q.3c: if a logical queue is the current dispatch target (read +
    # DMA-guarded above), route through the async timeline path on that
    # queue's ring (signals the queue's persistent timeline; caller waits
    # via gpu_queue_wait_idle / gpu_queue_barrier). Zero stash = the v3.0
    # synchronous single-ring path verbatim below.
    if (cq != 0) {
        return native_compute_dispatch_cached_timeline(ctx, pm4, pm4_bytes,
        shader_handle, out_handle, cq, queue_ring(cq));
    }

    var t_now[16];
    memset(&t_now, 0, 16);
    # Audit 2026-06-14 [LOW-4]: check clock_gettime's return before reading
    # t_now — a discarded failure left the deadline computed from
    # uninitialized stack (spurious immediate timeout or near-unbounded wait).
    var trc = syscall(228, 1, &t_now);
    if (trc != 0) { return GPU_ERR_OTHER; }
    var ns_now = load64(&t_now + 0) * 1000000000 + load64(&t_now + 8);
    var deadline = ns_now + 15000000000;

    # Step 4f.iv: route through the cached-BO path. The IB and
    # fence BOs were allocated once in gpu_context_new_native; we
    # just memcpy PM4 into the cached IB and submit.
    return native_compute_dispatch_cached(ctx, pm4, pm4_bytes,
    shader_handle, out_handle,
    deadline);
}

# Device wait — stub. Native dispatch is synchronous (waits on the
# syncobj before native_compute_dispatch_simple returns), so a
# separate device_wait_idle is conceptually a no-op until we ever
# add async submit paths.
fn _backend_native_device_wait_idle(ctx): i64 {
    return 0;
}

# ================================================================
# v3.1 Q.3 — native queue slots (multi-queue coordination)
# ================================================================
# Each logical Queue maps to a real AMDGPU hardware ring and carries a
# persistent timeline syncobj. GFX and COMPUTE are distinct rings, so
# genuine graphics/compute overlap is possible (unlike wgpu's single
# queue). The persistent timeline syncobj replaces the ephemeral
# per-dispatch binary syncobj on the queue-targeted path (Q.3c): every
# queue-targeted submit signals the next point, wait_idle waits the
# latest point, and gpu_queue_barrier (Q.4) makes one ring wait on
# another's point.

# Map a logical queue kind to its AMDGPU HW ring (HW_IP). As of v3.2 X.3
# TRANSFER maps to the real SDMA ring (AMDGPU_HW_IP_DMA), driven by the
# public buffer-copy API (X.5) over native_transfer_copy_timeline (X.4).
# Compute/render dispatch onto a DMA-ring queue is rejected with
# GPU_ERR_TRANSFER (SDMA cannot run PM4 shaders) — see the guard in
# _backend_native_compute_dispatch. Returns -1 on bad kind.
fn _native_queue_kind_to_ring(kind): i64 {
    if (kind == QUEUE_KIND_GRAPHICS) { return AMDGPU_HW_IP_GFX; }
    if (kind == QUEUE_KIND_COMPUTE)  { return AMDGPU_HW_IP_COMPUTE; }
    if (kind == QUEUE_KIND_TRANSFER) { return AMDGPU_HW_IP_DMA; }
    return 0 - 1;
}

# Acquire the native logical queue for `kind`. Idempotent: caches one
# Queue (with a freshly created persistent timeline syncobj bound to
# the kind's ring) per kind on the ctx; re-get returns the cached
# pointer. Returns a Queue* or 0 on bad input / syncobj-create
# failure. (HW path — needs a real render-node fd; CPU tests cover the
# bad-kind / null-ctx / no-fd guards.)
fn _backend_native_queue_get(ctx, kind): i64 {
    if (ctx == 0) { return 0; }
    var ring = _native_queue_kind_to_ring(kind);
    if (ring < 0) { return 0; }
    var cached = gpu_ctx_queue_slot(ctx, kind);
    if (cached != 0) { return cached; }
    var fd = native_ctx_fd(ctx);
    if (fd <= 0) { return 0; }
    var sbuf[8];
    var rc = native_syncobj_create(fd, &sbuf);
    if (rc != 0) { return 0; }
    var syncobj = load64(&sbuf);
    var q = queue_new(kind);
    if (q == 0) {
        native_syncobj_destroy(fd, syncobj);
        return 0;
    }
    queue_set_ring(q, ring);
    queue_set_syncobj(q, syncobj);
    gpu_ctx_set_queue_slot(ctx, kind, q);
    return q;
}

# Block until all work submitted on `queue` has retired — a timeline
# wait for the queue's current point. point == 0 means nothing has been
# submitted on this queue yet (no-op). Returns 0|GPU_ERR_*. (HW path
# for point > 0; CPU tests cover the null + point-0 short-circuits.)
fn _backend_native_queue_wait_idle(ctx, queue): i64 {
    if (ctx == 0)   { return GPU_ERR_OTHER; }
    if (queue == 0) { return GPU_ERR_OTHER; }
    var point = queue_point(queue);
    if (point == 0) { return 0; }
    var syncobj = queue_syncobj(queue);
    if (syncobj == 0) { return GPU_ERR_OTHER; }
    var fd = native_ctx_fd(ctx);
    var t_now[16];
    memset(&t_now, 0, 16);
    var trc = syscall(228, 1, &t_now);
    if (trc != 0) { return GPU_ERR_OTHER; }
    var deadline = load64(&t_now + 0) * 1000000000 + load64(&t_now + 8) + 15000000000;
    var rc = native_syncobj_timeline_wait(fd, syncobj, point, deadline);
    return _native_neg_rc_to_gpu_err(rc);
}

# Order work on dst_queue after work submitted on src_queue (Q.4).
# Records the producer's (syncobj, current point) as a PENDING WAIT on
# the consumer queue — no CPU block. The consumer's next queue-targeted
# submit (native_compute_dispatch_cached_timeline) turns it into an
# in-CS TIMELINE_WAIT chunk so the dependency resolves GPU-side, leaving
# the two rings free to overlap. If src has submitted nothing yet
# (point 0) there's nothing to wait for — no-op. Returns 0|GPU_ERR_*.
fn _backend_native_queue_barrier(ctx, src_queue, dst_queue): i64 {
    if (ctx == 0)        { return GPU_ERR_OTHER; }
    if (src_queue == 0)  { return GPU_ERR_OTHER; }
    if (dst_queue == 0)  { return GPU_ERR_OTHER; }
    var src_point = queue_point(src_queue);
    if (src_point == 0) { return 0; }
    queue_set_pending_wait(dst_queue, queue_syncobj(src_queue), src_point);
    return 0;
}

# Texture slots — real impls (Step 5.6). Wraps the Step 5.1 + 5.2
# primitives. Linear-layout GTT textures are CPU-accessible via the
# mmap'd address — write/read collapse to memcpy. Compare with the
# wgpu side's staging-buffer + queue_write / copy_texture_to_buffer
# dance: native is dramatically simpler because the BO's pixel data
# IS the CPU mmap.

fn _backend_native_texture_create_2d_rgba8(ctx, width, height): i64 {
    if (ctx == 0) { return 0; }
    if (width <= 0)  { return 0; }
    if (height <= 0) { return 0; }
    # Audit 2026-06-14 [MED-1]: cap the dimension so width*height*4 cannot
    # overflow i64 before native_texture_size_2d_rgba8 feeds GEM_CREATE +
    # mmap. Defends the native slot independently of the v3 dispatcher.
    if (validate_dimensions(width, height, MABDA_MAX_TEXTURE_DIM_2D) != 0) {
        return 0;
    }
    var fd = native_ctx_fd(ctx);
    # v3.1 M.1(c): allocate a unique VA range for this texture from the
    # per-context region (0 = region exhausted -> create fails).
    var size = native_texture_size_2d_rgba8(width, height);
    var va = native_ctx_alloc_texture_va(ctx, size);
    if (va == 0) { return 0; }
    var tex = alloc(NATIVE_TEX_STRUCT_SIZE);
    memset(tex, 0, NATIVE_TEX_STRUCT_SIZE);
    var rc = native_texture_create_2d_rgba8(fd, va, width, height, tex);
    if (rc != 0) { return 0; }
    return tex;
}

# v3.2 T.7 — format-parameterized native create slot. Block-sized linear
# BO (page-aligned VA span); stores fmt + logical size. write/read are the
# existing size-driven memcpy slots (format-agnostic — they validate n
# against the stored logical size). STORAGE + READBACK only: native cannot
# SAMPLE a compressed texture this minor (no T#/sampler path — that's Phase
# TS), and there is no native sample/bind API to call yet, so a consumer
# simply cannot sample one (nothing to fail loud against until TS adds the
# bind-for-sample slot).
fn _backend_native_texture_create_2d_fmt(ctx, width, height, fmt): i64 {
    if (ctx == 0) { return 0; }
    if (width <= 0)  { return 0; }
    if (height <= 0) { return 0; }
    if (validate_dimensions(width, height, MABDA_MAX_TEXTURE_DIM_2D) != 0) {
        return 0;
    }
    var logical = mabda_texfmt_data_size(fmt, width, height);
    if (logical == 0) { return 0; }                    # unknown format id
    var fd = native_ctx_fd(ctx);
    var bo_size = _native_align_up(logical, 4096);
    var va = native_ctx_alloc_texture_va(ctx, bo_size);
    if (va == 0) { return 0; }
    var tex = alloc(NATIVE_TEX_STRUCT_SIZE);
    memset(tex, 0, NATIVE_TEX_STRUCT_SIZE);
    var rc = native_texture_create_2d_fmt(fd, va, width, height, fmt, tex);
    if (rc != 0) { return 0; }
    return tex;
}

# v3.2 TS.7c — bitmask of texture-compression families native AMD can SAMPLE.
# MABDA_TEXCOMP_BC: BC sampling is HW-verified on Cezanne (TS.7c-4 —
# programs/native_compressed_sample_e2e samples a SW_64KB_S tiled BC1 surface in
# an FS and matches a CPU decode pixel-exact, proving the full create -> L2T tiled
# write -> image_sample path). ETC2/ASTC stay gated off until their own HW decode
# verify (TS.8). The create slot rejects a compressed family not in this mask
# (pre-ioctl) so a consumer never gets a sampleable texture it can't populate —
# the native analog of the wgpu backend's adapter-family caps guard.
var NATIVE_TEXCOMP_SUPPORTED = MABDA_TEXCOMP_BC;

# v3.2 F.2/F.7 — native f64 (double-precision) compute support. GFX9+ AMD HW runs f64 (the throttled
# FP64 ALU on Vega/Cezanne), and as of F.7 mabda's SPIR-V→GFX9 compiler EMITS the full conformant f64
# toolkit — add/sub/mul/div/sqrt/fma, f32↔f64 + i32↔f64 conversions, OpConstant, Ldexp, ordered
# compares, and OpSelect — each HW-verified end-to-end on Cezanne. So this is now 1: f64 compute runs
# natively, the gate at _backend_native_shader_module_create opens, and gpu_caps_native_shader_f64()
# honestly reports f64. (Consumers hand-roll exp/ln/tanh/pow as polynomials from this toolkit —
# GLSL.std.450 transcendentals are f32-only, see [[project_f64_transcendentals_arithmetic_only]].)
var MABDA_NATIVE_F64 = 1;

# v3.2 TS.8 — the single source of truth for "can native SAMPLE `fmt`", at
# PER-FORMAT granularity (the family bitset alone can't express BC6H). 1 for
# RGBA8 (always) + any BC format whose family is in NATIVE_TEXCOMP_SUPPORTED,
# EXCEPT BC6H (HDR float — the native sample path only has an RGBA8_UNORM RT, so
# it would clamp/quantize; gated until an HDR RT path exists). 0 for unsupported
# compressed families (ETC2/ASTC) and unknown ids. The create slot gates on this;
# consumers can call it to pre-check a format before create.
fn native_texfmt_sampleable(fmt): i64 {
    if (fmt == MABDA_TEXFMT_RGBA8) { return 1; }
    var fam = mabda_texfmt_compression_family(fmt);
    if (fam == 0) { return 0; }                            # unknown / non-sampleable id
    if ((NATIVE_TEXCOMP_SUPPORTED & fam) == 0) { return 0; }   # family not supported
    if (fmt == MABDA_TEXFMT_BC6H) { return 0; }            # HDR float vs RGBA8 RT
    return 1;
}

# v3.2 TS.8 — native sibling of the wgpu gpu_caps_detect_texture_compression
# (backend_wgpu.cyr): returns the compression-family bitset native AMD supports
# for sampling, so a consumer building a native context's GpuCapabilities can
# `gpu_caps_set_texture_compression(caps, gpu_caps_native_texture_compression())`
# — the same populate-then-`gpu_caps_supports_format` flow as wgpu (closes the
# native storage-only gap). FAMILY-granular like the caps bitset; the per-format
# BC6H exclusion (see native_texfmt_sampleable) is finer than this advisory can
# express, so a BC6H pre-check should use native_texfmt_sampleable.
fn gpu_caps_native_texture_compression(): i64 {
    return NATIVE_TEXCOMP_SUPPORTED;
}

# v3.2 F.2 — the native f64 ANSWER (unlike the wgpu side, native needs no probe — there is
# ground truth): does the native AMD path support f64 compute? The HW does, but mabda can only
# EMIT f64 once the Phase N SPIR-V→GFX9 f64 emitter lands (F.7), so this returns MABDA_NATIVE_F64
# (0 until F.7). F.7 may flip it to 1 ONLY when f64 runs end-to-end for every op attn11 uses (a
# partial emitter must keep reporting 0 — review F.2 #2). A consumer populates a native context's
# caps via `gpu_caps_set_shader_f64(caps, gpu_caps_native_shader_f64())`.
fn gpu_caps_native_shader_f64(): i64 {
    return MABDA_NATIVE_F64;
}

# v3.2 TS.5/TS.7c — sampleable 2D texture create (native). Differs from the
# storage create_2d_fmt: a SINGLE BO holds [surface | pad-to-256 | T#(32) +
# S#(16)], so one handle covers both for CS residency and t_va points at the
# descriptor in the BO tail. Builds the GFX9 T# (image resource, +0) + a default
# point/clamp unnormalized S# (sampler, +32); stashes t_va + sw_mode on the
# (64-byte) tex. The textured FS (TS.4/TS.7) s_load_dwordx8's the T# from t_va.
#
# Two surface layouts, keyed off the format's compression:
#   - UNCOMPRESSED (RGBA8): LINEAR surface, epitch = w-1, surface = data_size.
#   - COMPRESSED (BC/ETC2/ASTC): a SW_64KB_S TILED surface sized to the
#     block-aligned tiled footprint (native_tex_tiled_params), epitch = awb-1.
#     The block-compressed data must be SDMA-tiled into the surface before it
#     samples right — texture_write routes compressed writes through the L2T
#     COPY_TILED path (TS.7c), so a raw linear blit here would sample garbage.
#
# NATIVE_TEX_FIELD_SIZE stays the LOGICAL (linear) surface bytes — the consumer
# always hands write/read that many bytes; the tiled BO is larger. texture_release
# recomputes the real mapped bo_size from t_va. Returns a tex_ptr, or 0 on invalid
# dims/format, region exhaustion, or an ioctl failure. (HW: the BO alloc/map; the
# guards + geometry + descriptor build are deterministic.)
fn _backend_native_texture_create_2d_sampleable(ctx, width, height, fmt): i64 {
    if (ctx == 0) { return 0; }
    if (width <= 0)  { return 0; }
    if (height <= 0) { return 0; }
    if (validate_dimensions(width, height, MABDA_MAX_TEXTURE_DIM_2D) != 0) {
        return 0;
    }
    if (native_gfx9_texfmt_to_img_format(fmt) < 0) { return 0; }   # unsupported fmt
    var logical = mabda_texfmt_data_size(fmt, width, height);
    if (logical == 0) { return 0; }
    # Backend caps gate (pre-ioctl): reject a compressed family native can't yet
    # sample, so a consumer never gets a tiled BC texture it can't populate via
    # the public write API (which rejects tiled until TS.7c-3). Mirrors the wgpu
    # backend guard. Until NATIVE_TEXCOMP_SUPPORTED flips, this returns 0 BEFORE
    # any allocation — a genuine reject, not an ioctl-failure-on-fake-fd.
    # Backend caps gate (pre-ioctl), per-format: a compressed format native can't
    # faithfully sample (unsupported family, or BC6H's HDR-vs-RGBA8-RT mismatch) is
    # rejected here before any allocation, so a consumer never gets a sampleable
    # texture it can't populate. native_texfmt_sampleable is the single source of
    # truth shared with the consumer-facing pre-check. (RGBA8 -> 1, passes through.)
    var fam = mabda_texfmt_compression_family(fmt);
    if (fam != 0) {
        if (native_texfmt_sampleable(fmt) == 0) { return 0; }
    }
    var fd = native_ctx_fd(ctx);

    # Pick the surface layout: LINEAR for uncompressed, SW_64KB_S tiled (sized to
    # the block-aligned footprint) for compressed.
    var sw_mode = GFX9_SW_MODE_LINEAR;
    var epitch = width - 1;
    var surf_size = logical;
    if (fam != 0) {
        var tp[56];
        if (native_tex_tiled_params(fmt, width, height, &tp) != 0) { return 0; }
        sw_mode = GFX9_SW_MODE_64KB_S;
        # epitch = awb-1 (the tile-aligned block pitch). The TS.7c-3 SDMA write
        # MUST use the same awb-1 so the tiled layout matches the T#.
        epitch = load64(&tp + 16) - 1;
        surf_size = load64(&tp + 32);      # tiled_size (64 KiB-aligned)
    }

    # ONE BO holds [surface | pad-to-256 | T#(32) + S#(16)]: a single handle
    # covers both for CS residency (the descriptor BO handle would otherwise be
    # untracked), and t_va points at the descriptor inside the same BO.
    var desc_off = _native_align_up(surf_size, 256);
    var bo_size = _native_align_up(desc_off + 64, 4096);
    var va = native_ctx_alloc_texture_va(ctx, bo_size);
    if (va == 0) { return 0; }
    var bo[16];
    if (native_bo_create_gtt(fd, bo_size, &bo) != 0) { return 0; }
    var handle = load64(&bo + 0);
    var addr   = load64(&bo + 8);
    if (native_gem_va_map(fd, handle, va, bo_size, _NATIVE_PERM_DATA) != 0) {
        native_bo_release_gtt(fd, handle, addr, bo_size);
        return 0;
    }
    # Build the T# (+0) + a default point/clamp unnormalized S# (+32) in the tail.
    var daddr = addr + desc_off;
    memset(daddr, 0, 64);
    native_gfx9_image_descriptor(daddr, 0, va, width, height, fmt, sw_mode, 1, epitch);
    native_gfx9_sampler_descriptor(daddr, 32,
    NATIVE_SAMP_FILTER_POINT, NATIVE_SAMP_ADDR_CLAMP, 1);   # unnormalized (image_sample FS)
    # v3.2 TS.8 — scale_x/scale_y (f32, descriptor+48/+52) the FS multiplies the
    # fragment position by. Default 1.0 (= equal-dims, fragment==texel); the draw
    # overwrites per-draw from tex_dim/rt_dim. Defaulting to 1.0 (not the memset 0)
    # means a sample without a draw-write reads coord==pos, never coord*0.
    store32(daddr + 48, 0x3F800000);   # scale_x = 1.0f
    store32(daddr + 52, 0x3F800000);   # scale_y = 1.0f

    var tex = alloc(NATIVE_TEX_STRUCT_SIZE);
    memset(tex, 0, NATIVE_TEX_STRUCT_SIZE);
    store64(tex + NATIVE_TEX_FIELD_HANDLE, handle);
    store64(tex + NATIVE_TEX_FIELD_VA,     va);
    store64(tex + NATIVE_TEX_FIELD_ADDR,   addr);
    store64(tex + NATIVE_TEX_FIELD_SIZE,   logical);   # logical linear bytes (write/read bounds)
    store32(tex + NATIVE_TEX_FIELD_WIDTH,     width);
    store32(tex + NATIVE_TEX_FIELD_HEIGHT,    height);
    store32(tex + NATIVE_TEX_FIELD_MIP_COUNT, 1);
    store32(tex + NATIVE_TEX_FIELD_FMT,       fmt);
    native_tex_set_sw_mode(tex, sw_mode);
    native_tex_set_t_va(tex, va + desc_off);
    return tex;
}

# v3.2 TS.5 — bind a sampleable texture into a render pass (native). Stashes
# the texture's T#/S# descriptor VA on the pass; the next render_pass_draw
# emits the PS USER_DATA SET_SH_REG from it (the textured-FS PM4 path, next
# sub-bite). `sampler` is accepted for API stability but unused on the
# image_load MVP path (the FS reads no S#); rebuilding the S# from an explicit
# sampler is TS.7 (image_sample). Returns 0|GPU_ERR_*.
fn _backend_native_texture_bind_for_sample(ctx, pass, tex, sampler): i64 {
    if (ctx == 0)  { return GPU_ERR_OTHER; }
    if (pass == 0) { return GPU_ERR_OTHER; }
    if (tex == 0)  { return GPU_ERR_TEXTURE; }
    if (native_tex_t_va(tex) == 0) { return GPU_ERR_TEXTURE; }   # not sampleable
    # v3.2 TS.8b — rebuild the S# (descriptor +32) from the bound sampler's
    # filter+addr so gpu_sampler_create(POINT/BILINEAR, CLAMP/WRAP) takes effect.
    # unnorm stays 1 (the FS feeds texel-space coords). A POINT/CLAMP sampler
    # rebuilds byte-identically to the create-baked default, so the existing
    # (POINT) sample e2es are unaffected; only fires for a valid sampler.
    if (gpu_sampler_is_valid(sampler) != 0) {
        var dcpu = native_tex_desc_cpu_addr(tex);
        if (dcpu != 0) {
            native_gfx9_sampler_descriptor(dcpu, 32,
            gpu_sampler_filter(sampler), gpu_sampler_addr(sampler), 1);
        }
    }
    # Stash the tex pointer: the draw derives the descriptor VA
    # (native_tex_t_va, for the PS USER_DATA) + the surface BO handle (for
    # residency) from it.
    store64(pass + NATIVE_PASS_FIELD_BOUND_TEX, tex);
    return 0;
}

# v3.1 [M.6]: native mipped-texture create slot. One chain BO sized to the
# whole mip pyramid; generate (M.6b) downsamples level-by-level into it.
fn _backend_native_texture_create_2d_rgba8_mipped(ctx, width, height, mip_count): i64 {
    if (ctx == 0) { return 0; }
    if (width <= 0)  { return 0; }
    if (height <= 0) { return 0; }
    if (mip_count < 1) { return 0; }
    if (validate_dimensions(width, height, MABDA_MAX_TEXTURE_DIM_2D) != 0) {
        return 0;
    }
    var fd = native_ctx_fd(ctx);
    var size = native_mip_chain_size(width, height, mip_count);
    var va = native_ctx_alloc_texture_va(ctx, size);
    if (va == 0) { return 0; }
    var tex = alloc(NATIVE_TEX_STRUCT_SIZE);
    memset(tex, 0, NATIVE_TEX_STRUCT_SIZE);
    var rc = native_texture_create_mipped_2d_rgba8(fd, va, width, height, mip_count, tex);
    if (rc != 0) { return 0; }
    return tex;
}

# v3.1 [M.6b]: native mipmap generation. Fills levels 1..mip_count-1 of a
# chain texture by GPU 2x2-box-filter downsample — one compute dispatch
# per level via the cached-IB path, src/dst level VAs computed from the
# texture's chain base. Read-after-write between levels is handled by the
# per-dispatch syncobj wait (level n completes before n+1 submits) plus
# the composer's ACQUIRE_MEM cache-invalidate before each dispatch (L2 is
# the coherence point for the global_load/store). Returns 0 | GPU_ERR_*.
#
# The downsample shader BO is allocated + loaded here (R|X), VA from the
# texture sub-allocator (fresh, no collision). It is bump-leaked for the
# ctx lifetime — generate is infrequent; caching it on the ctx is a future
# optimization (a ctx field like the IB/fence cache).
fn _backend_native_texture_generate_mipmaps(ctx, tex): i64 {
    if (ctx == 0) { return GPU_ERR_OTHER; }
    if (tex == 0) { return GPU_ERR_OTHER; }
    var mip_count = load32(tex + NATIVE_TEX_FIELD_MIP_COUNT);
    if (mip_count < 2) { return 0; }   # single level: nothing to generate
    var fd = native_ctx_fd(ctx);
    var width  = load32(tex + NATIVE_TEX_FIELD_WIDTH);
    var height = load32(tex + NATIVE_TEX_FIELD_HEIGHT);
    var tex_handle = load64(tex + NATIVE_TEX_FIELD_HANDLE);
    var stub_va = native_ctx_stub_va(ctx);
    # Allocate + load the downsample shader BO (R|X). Page-align the BO/
    # VA-map size (GEM_VA needs 4 KiB alignment); the 380 shader bytes
    # occupy the head, the rest is unused.
    var sh_size = _native_align_up(GFX9_DOWNSAMPLE_2X2_SIZE, 4096);
    var sh_va = native_ctx_alloc_texture_va(ctx, sh_size);
    if (sh_va == 0) { return GPU_ERR_OTHER; }
    var sh_bo[16];
    var rc = native_bo_create_gtt(fd, sh_size, &sh_bo);
    if (rc != 0) { return _native_neg_rc_to_gpu_err(rc); }
    var sh_handle = load64(&sh_bo + 0);
    var sh_addr   = load64(&sh_bo + 8);
    native_gfx9_shader_downsample_2x2(sh_addr, 0);
    rc = native_gem_va_map(fd, sh_handle, sh_va, sh_size, _NATIVE_PERM_SHADER);
    if (rc != 0) {
        var rc_save = rc;
        native_bo_release_gtt(fd, sh_handle, sh_addr, sh_size);
        return _native_neg_rc_to_gpu_err(rc_save);
    }
    # Dispatch one downsample per level.
    var pm4 = native_ctx_pm4_scratch(ctx);
    if (pm4 == 0) { return GPU_ERR_OTHER; }
    var level = 1;
    while (level < mip_count) {
        var src_va = native_texture_level_va(tex, level - 1);
        var dst_va = native_texture_level_va(tex, level);
        var dw = mip_level_dim(width, level);
        var dh = mip_level_dim(height, level);
        memset(pm4, 0, 256);
        # The hand-authored downsample shader's ABI: RSRC1 0x2C0083 (16 VGPR /
        # 24 SGPR), RSRC2 0x18C (USER_SGPR=6 | TGID_X|Y). A compiled shader would
        # pass its own gfx9_rsrc1/gfx9_rsrc2 here (N.5d seam).
        var n = native_pm4_build_compute_downsample(pm4, sh_va, stub_va,
        src_va, dst_va, dw, dh, 0x2C0083, 0x18C);
        var t_now[16];
        memset(&t_now, 0, 16);
        var trc = syscall(228, 1, &t_now);
        if (trc != 0) { return GPU_ERR_OTHER; }
        var deadline = load64(&t_now + 0) * 1000000000
        + load64(&t_now + 8) + 15000000000;
        rc = native_compute_dispatch_cached(ctx, pm4, n, sh_handle,
        tex_handle, deadline);
        if (rc != 0) { return rc; }
        level = level + 1;
    }
    return 0;
}

# v3.2 TS.7c-3 — one-shot SDMA submit on the DMA ring: a 4-entry BO_HANDLES
# list (fence, ib, lin, tiled), a transient syncobj, submit + blocking wait. The
# texture write/read contract is synchronous, so we don't use the persistent
# queue timeline (native_transfer_copy_timeline) here — a per-call syncobj is
# simpler and the copies are infrequent. Lifts the HW-proven submit shape from
# the TS.6 native_sdma_tiled_roundtrip probe. Returns 0 | neg-rc.
fn _native_dma_submit_oneshot(ctx, h_lin, h_tiled, sdma_bytes): i64 {
    var fd = native_ctx_fd(ctx);
    var entries[32];
    store32(&entries +  0, native_ctx_fence_handle(ctx)); store32(&entries +  4, 1);
    store32(&entries +  8, native_ctx_ib_handle(ctx));    store32(&entries + 12, 10);
    store32(&entries + 16, h_lin);                        store32(&entries + 20, 3);
    store32(&entries + 24, h_tiled);                      store32(&entries + 28, 3);
    var bo_list_in[24];
    store32(&bo_list_in +  0, 0xFFFFFFFF);
    store32(&bo_list_in +  4, 0xFFFFFFFF);
    store32(&bo_list_in +  8, 4);
    store32(&bo_list_in + 12, 8);
    store64(&bo_list_in + 16, &entries);
    var sbuf[8];
    if (native_syncobj_create(fd, &sbuf) != 0) { return 0 - 1; }
    var so = load64(&sbuf);
    # Compute the wait deadline BEFORE the submit so the ONLY post-submit step is
    # the wait. (Review 2026-06-16 LOW: if clock_gettime ran after a successful
    # submit and failed, we'd destroy the syncobj + return without waiting, then
    # the caller would free the staging BO while the SDMA CS still reads/writes
    # it — a GPU-side UAF. Now a clock failure happens with nothing in flight.)
    var t_now[16];
    memset(&t_now, 0, 16);
    if (syscall(228, 1, &t_now) != 0) { native_syncobj_destroy(fd, so); return 0 - 1; }
    var deadline = load64(&t_now + 0) * 1000000000 + load64(&t_now + 8) + 15000000000;
    var rc = native_cs_submit_4chunk(fd, native_ctx_id(ctx), &bo_list_in,
    native_ctx_ib_va(ctx), sdma_bytes, AMDGPU_HW_IP_DMA, so,
    native_ctx_fence_handle(ctx), 32, 0);
    if (rc != 0) { native_syncobj_destroy(fd, so); return rc; }
    var wrc = native_syncobj_wait(fd, so, deadline);
    native_syncobj_destroy(fd, so);
    return wrc;
}

# v3.2 TS.7c-3 — move `n` bytes of block-compressed data between a host buffer
# and a SW_64KB_S tiled texture surface via SDMA COPY_TILED_SUB_WINDOW. The
# consumer's compressed data is row-major linear (block pitch = wb); the surface
# is tiled, so a transient linear staging BO bridges them:
#   write (detile=0): memcpy host->staging, then L2T staging->surface
#   read  (detile=1): T2L surface->staging, then memcpy staging->host
# `n` must equal the LOGICAL linear footprint (wb*hb*block_bytes = the tex's
# NATIVE_TEX_FIELD_SIZE). Pure-validation rejects (uncompressed fmt, n mismatch)
# return BEFORE any ioctl. Returns 0 | GPU_ERR_*.
fn _native_texture_tiled_copy(ctx, tex, host, n, detile): i64 {
    var fmt = native_tex_fmt(tex);
    var w = load32(tex + NATIVE_TEX_FIELD_WIDTH);
    var h = load32(tex + NATIVE_TEX_FIELD_HEIGHT);
    var tp[56];
    if (native_tex_tiled_params(fmt, w, h, &tp) != 0) { return GPU_ERR_TEXTURE; }
    var wb = load64(&tp +  0);
    var hb = load64(&tp +  8);
    var bb = load64(&tp + 48);
    if (n != wb * hb * bb) { return GPU_ERR_BUFFER; }

    var fd = native_ctx_fd(ctx);
    # Transient linear staging BO mapped at the DEDICATED, re-used staging VA
    # (page-aligned size; the fixed slot avoids leaking the texture VA region).
    var stage_size = _native_align_up(n, 4096);
    if (stage_size > _NATIVE_STAGING_VA_REGION) { return GPU_ERR_BUFFER; }
    var stage_va = _NATIVE_STAGING_VA;
    var sbo[16];
    if (native_bo_create_gtt(fd, stage_size, &sbo) != 0) { return GPU_ERR_OTHER; }
    var stage_h = load64(&sbo + 0);
    var stage_a = load64(&sbo + 8);
    if (native_gem_va_map(fd, stage_h, stage_va, stage_size, _NATIVE_PERM_DATA) != 0) {
        native_bo_release_gtt(fd, stage_h, stage_a, stage_size);
        return GPU_ERR_OTHER;
    }
    if (detile == 0) { memcpy(stage_a, host, n); }   # host -> staging before L2T

    var ib_addr = native_ctx_ib_addr(ctx);
    memset(ib_addr, 0, _NATIVE_IB_SIZE);
    var sdma_bytes = native_tex_build_tiled_copy_packet(ib_addr, tex, stage_va, detile);
    var rc = 0 - 1;
    if (sdma_bytes > 0) {
        rc = _native_dma_submit_oneshot(ctx, stage_h,
        load64(tex + NATIVE_TEX_FIELD_HANDLE), sdma_bytes);
    }
    if (rc == 0) {
        if (detile != 0) { memcpy(host, stage_a, n); }   # staging -> host after T2L
    }
    native_gem_va_unmap(fd, stage_h, stage_va, stage_size);
    native_bo_release_gtt(fd, stage_h, stage_a, stage_size);
    # Preserve the SDMA errno (timeout vs OOM vs busy) like the sibling buffer
    # path (native_transfer_copy_timeline); a packet-build failure (sdma_bytes<=0,
    # rc left -1) maps to a texture error. (Review 2026-06-16 LOW consistency.)
    if (sdma_bytes <= 0) { return GPU_ERR_TEXTURE; }
    return _native_neg_rc_to_gpu_err(rc);
}

fn _backend_native_texture_write(ctx, tex, src, n): i64 {
    if (ctx == 0) { return GPU_ERR_OTHER; }
    if (tex == 0) { return GPU_ERR_OTHER; }
    if (src == 0) { return GPU_ERR_BUFFER; }
    if (n <= 0)   { return GPU_ERR_BUFFER; }
    var addr = load64(tex + NATIVE_TEX_FIELD_ADDR);
    var size = load64(tex + NATIVE_TEX_FIELD_SIZE);
    if (addr == 0)   { return GPU_ERR_BUFFER; }
    if (n != size)   { return GPU_ERR_BUFFER; }
    # A SW_64KB_S tiled surface (compressed sampleable) is NOT linear — route it
    # through the L2T COPY_TILED path so the blocks land swizzled the way the TA
    # reads them; a raw memcpy would sample as garbage.
    if (native_tex_sw_mode(tex) != GFX9_SW_MODE_LINEAR) {
        return _native_texture_tiled_copy(ctx, tex, src, n, 0);
    }
    memcpy(addr, src, n);
    return 0;
}

fn _backend_native_texture_read(ctx, tex, dst, n): i64 {
    if (ctx == 0) { return GPU_ERR_OTHER; }
    if (tex == 0) { return GPU_ERR_OTHER; }
    if (dst == 0) { return GPU_ERR_BUFFER; }
    if (n <= 0)   { return GPU_ERR_BUFFER; }
    var addr = load64(tex + NATIVE_TEX_FIELD_ADDR);
    var size = load64(tex + NATIVE_TEX_FIELD_SIZE);
    if (addr == 0)   { return GPU_ERR_BUFFER; }
    if (n != size)   { return GPU_ERR_BUFFER; }
    # Tiled (compressed) readback de-tiles via T2L COPY_TILED into a staging BO.
    if (native_tex_sw_mode(tex) != GFX9_SW_MODE_LINEAR) {
        return _native_texture_tiled_copy(ctx, tex, dst, n, 1);
    }
    memcpy(dst, addr, n);
    return 0;
}

fn _backend_native_texture_release(ctx, tex): i64 {
    if (ctx == 0) { return 0; }
    if (tex == 0) { return 0; }
    var fd = native_ctx_fd(ctx);
    native_texture_release_2d_rgba8(fd, tex);
    return 0;
}

# ----------------------------------------------------------------
# Render slot wrappers (v3 Step 6.8(c))
# ----------------------------------------------------------------
# Seven slots wrapping Step 6.3 (RT primitives), 6.5(b) (PM4
# composers), and 6.6 (`native_render_dispatch_simple`). The
# 4-block PM4 split lives in the structs:
#   render_pipeline_create  → pre-builds sh + ctx blocks once
#   render_pass_begin       → just stashes refs (defers PM4)
#   render_pass_draw        → composes the full IB + dispatches
#   render_pass_end         → zeros the pass struct
#
# v2-native limitations (lifted in v3.x):
#   - Single draw per pass (one dispatch per pass_end).
#   - No pipeline state caching (every draw re-emits sh + ctx).
#   - clear_color_ptr ignored — the FS shader (Step 6.2(b)) hardcodes
#     solid red. Honoring runtime clear color requires a v3.x PM4
#     extension (CB_COLOR0_CLEAR_WORD0..3 or shader patching).
#   - color_fmt ignored — only RGBA8_UNORM supported on native.

fn _backend_native_render_target_create_2d_rgba8(ctx, width, height): i64 {
    if (ctx == 0)    { return 0; }
    if (width <= 0)  { return 0; }
    if (height <= 0) { return 0; }
    var fd = native_ctx_fd(ctx);
    var rt = alloc(NATIVE_RT_STRUCT_SIZE);
    memset(rt, 0, NATIVE_RT_STRUCT_SIZE);
    var rc = native_rt_create_2d_rgba8(fd, width, height, rt);
    if (rc != 0) { return 0; }
    return rt;
}

fn _backend_native_render_target_release(ctx, rt): i64 {
    if (ctx == 0) { return 0; }
    if (rt == 0)  { return 0; }
    var fd = native_ctx_fd(ctx);
    native_rt_release_2d_rgba8(fd, rt);
    return 0;
}

# Pipeline create — vs_mod and fs_mod are pointers to (handle, va)
# pairs (the same shmod convention compute_dispatch uses). color_fmt
# is accepted for slot ABI parity with wgpu but ignored for v2-native.
fn _backend_native_render_pipeline_create(ctx, vs_mod, fs_mod, color_fmt): i64 {
    if (ctx == 0)    { return 0; }
    if (vs_mod == 0) { return 0; }
    if (fs_mod == 0) { return 0; }
    var vs_handle = load64(vs_mod + 0);
    var vs_va     = load64(vs_mod + 8);
    var fs_handle = load64(fs_mod + 0);
    var fs_va     = load64(fs_mod + 8);
    var pipe = alloc(NATIVE_PIPE_STRUCT_SIZE);
    var rc = native_render_pipeline_pack(pipe, vs_handle, vs_va,
    fs_handle, fs_va);
    if (rc != 0) { return 0; }
    return pipe;
}

fn _backend_native_render_pipeline_release(ctx, pipe): i64 {
    if (ctx == 0)  { return 0; }
    if (pipe == 0) { return 0; }
    memset(pipe, 0, NATIVE_PIPE_STRUCT_SIZE);
    return 0;
}

fn _backend_native_render_pass_begin(ctx, rt, clear_color_ptr): i64 {
    if (ctx == 0) { return 0; }
    if (rt == 0)  { return 0; }
    if (clear_color_ptr == 0) { return 0; }
    var p = alloc(NATIVE_PASS_STRUCT_SIZE);
    memset(p, 0, NATIVE_PASS_STRUCT_SIZE);
    store64(p + NATIVE_PASS_FIELD_CTX,         ctx);
    store64(p + NATIVE_PASS_FIELD_RT,          rt);
    store64(p + NATIVE_PASS_FIELD_CLEAR_COLOR, clear_color_ptr);
    return p;
}

# Compose the full render PM4 stream and dispatch on the GFX ring.
# v2-native: single-draw-per-pass. Audit LOW-4: `vc` (vertex count)
# is now threaded through to the DRAW_INDEX_AUTO packet; v3.0-rc.1
# silently ignored it and always emitted the fullscreen-triangle
# count of 3. `ic` (instance count) is still ABI-only — we reject
# anything but `ic == 1` because instance rendering needs additional
# VGT_NUM_INSTANCES wiring that's v3.x scope. State caching (skip
# pipeline_sh+ctx if same pipe) is a v3.x perf item.
fn _backend_native_render_pass_draw(ctx, pass, pipe, vc, ic): i64 {
    if (ctx == 0)  { return GPU_ERR_OTHER; }
    if (pass == 0) { return GPU_ERR_OTHER; }
    if (pipe == 0) { return GPU_ERR_OTHER; }
    # Audit LOW-4: reject zero/negative vertex counts and
    # non-singleton instance counts before spending an alloc.
    if (vc <= 0)   { return GPU_ERR_OTHER; }
    if (ic != 1)   { return GPU_ERR_NOT_IMPLEMENTED; }   #skip-lint
    var rt = load64(pass + NATIVE_PASS_FIELD_RT);
    if (rt == 0) { return GPU_ERR_OTHER; }
    var rt_va     = load64(rt + NATIVE_RT_FIELD_VA);
    var rt_handle = load64(rt + NATIVE_RT_FIELD_HANDLE);
    var rt_width  = load32(rt + NATIVE_RT_FIELD_WIDTH);
    var rt_height = load32(rt + NATIVE_RT_FIELD_HEIGHT);
    if (rt_va == 0)     { return GPU_ERR_OTHER; }
    if (rt_handle == 0) { return GPU_ERR_OTHER; }
    if (rt_width <= 0)  { return GPU_ERR_OTHER; }
    if (rt_height <= 0) { return GPU_ERR_OTHER; }

    var vs_handle = load64(pipe + NATIVE_PIPE_FIELD_VS_HANDLE);
    var fs_handle = load64(pipe + NATIVE_PIPE_FIELD_FS_HANDLE);
    if (vs_handle == 0) { return GPU_ERR_OTHER; }
    if (fs_handle == 0) { return GPU_ERR_OTHER; }

    # Build the IB stream into the per-context cached PM4 scratch
    # (audit MED-7) — replaces a per-draw alloc that bumped the allocator
    # forward on every frame. The scratch is _NATIVE_PM4_SCRATCH_BYTES (2048
    # at v3.2 TS.5): the clear-triangle stream pads to the 256-dword/1024-B
    # minimum, and the textured-sample override appends ~15 more dwords.
    var pm4 = native_ctx_pm4_scratch(ctx);
    if (pm4 == 0) { return GPU_ERR_OTHER; }
    memset(pm4, 0, _NATIVE_PM4_SCRATCH_BYTES);
    var pos = 0;
    pos = native_pm4_acquire_mem_full_invalidate_for_gfx_ring(pm4, pos);
    # PIPELINESTAT_START — unblocks the GPU stat-counter pipeline.
    # radv emits this in every preamble; without it Cezanne's
    # pipeline can wait on stat-counter readiness that never fires.
    pos = native_pm4_event_write(pm4, pos,
    GFX9_EVENT_TYPE_PIPELINESTAT_START, GFX9_EVENT_INDEX_OTHER);
    pos = native_pm4_set_uconfig_reg_one(pm4, pos, R_VGT_PRIMITIVE_TYPE,
    GFX9_VGT_PRIMITIVE_TYPE_TRIANGLELIST);
    # Use dedicated PKT3_NUM_INSTANCES (opcode 0x2F) — radv's choice
    # for per-draw instance count; Cezanne VGT picks this up more
    # reliably than the generic SET_UCONFIG_REG path.
    pos = native_pm4_num_instances(pm4, pos, 1);
    # Splice the pre-built sh + ctx blocks (Step 6.5(b) composers
    # already ran at pipeline_create — this is the cached-block path).
    memcpy(pm4 + pos, pipe + NATIVE_PIPE_FIELD_SH_BLOCK,
    NATIVE_PIPE_SH_BLOCK_SIZE);
    pos = pos + NATIVE_PIPE_SH_BLOCK_SIZE;
    memcpy(pm4 + pos, pipe + NATIVE_PIPE_FIELD_CTX_BLOCK,
    NATIVE_PIPE_CTX_BLOCK_SIZE);
    pos = pos + NATIVE_PIPE_CTX_BLOCK_SIZE;
    pos = native_pm4_build_render_pass_target(pm4, pos, rt_va,
    rt_width, rt_height);
    # v3.2 TS.5 — textured sample override. If a sampleable texture is bound
    # (bind_for_sample stashed the tex ptr), re-emit the PS state the textured
    # FS (image_load) needs AFTER the pipeline's sh/ctx blocks (last-write
    # wins): SPI_PS_INPUT_ENA/_ADDR = 0x302 (screen pos arrives in v2/v3),
    # RSRC1_PS VGPRS 0->1 (4->8 VGPRs for the FS's v0..v5; MIN's 16 SGPRs
    # already cover s[0:7]), and the PS USER_DATA = the T#/S# descriptor VA
    # (the FS s_load_dwordx8's the T# from it). The surface BO joins residency.
    var bound_tex = load64(pass + NATIVE_PASS_FIELD_BOUND_TEX);
    var tex_handle = 0;
    if (bound_tex != 0) {
        var desc_va = native_tex_t_va(bound_tex);
        tex_handle = load64(bound_tex + NATIVE_TEX_FIELD_HANDLE);
        # v3.2 TS.8 — write the per-draw scale (f32) into the descriptor tail the
        # FS s_loads (+48/+52): scale = tex_dim / rt_dim, so a W×H texture maps
        # over the RT (equal dims -> 1.0 -> coord==fragment, bit-exact; smaller
        # texture -> <1 -> fractional coords -> the S#'s filter blends). Written
        # UNCONDITIONALLY so the FS never reads a stale tail; the IB-head
        # ACQUIRE_MEM invalidate makes the TA see the fresh bytes. int_ratio_to_f32
        # is the float shim (no native Cyrius float div yet — see the proposal).
        var dcpu = native_tex_desc_cpu_addr(bound_tex);
        if (dcpu != 0) {
            var tw = load32(bound_tex + NATIVE_TEX_FIELD_WIDTH);
            var th = load32(bound_tex + NATIVE_TEX_FIELD_HEIGHT);
            store32(dcpu + 48, int_ratio_to_f32(tw, rt_width));   # scale_x
            store32(dcpu + 52, int_ratio_to_f32(th, rt_height));  # scale_y
        }
        pos = native_pm4_set_sh_reg_one(pm4, pos, R_SPI_SHADER_PGM_RSRC1_PS,
        GFX9_GFX_PGM_RSRC1_MIN | 1);
        pos = native_pm4_set_context_reg_one(pm4, pos, R_SPI_PS_INPUT_ENA,
        GFX9_SPI_PS_INPUT_TEXTURED);
        pos = native_pm4_set_context_reg_one(pm4, pos, R_SPI_PS_INPUT_ADDR,
        GFX9_SPI_PS_INPUT_TEXTURED);
        pos = native_pm4_set_sh_reg_one(pm4, pos, R_SPI_SHADER_USER_DATA_PS_0,
        desc_va & 0xFFFFFFFF);
        pos = native_pm4_set_sh_reg_one(pm4, pos, R_SPI_SHADER_USER_DATA_PS_1,
        (desc_va >> 32) & 0xFFFFFFFF);
    }
    # Pre-draw pixel-pipeline drain — captured byte-exact from radv's
    # main IB. Without these, in-flight pixel waves from prior
    # contexts (e.g. the compositor) keep the pixel pipeline busy past
    # our dispatch's start → GFX ring TDR. The 3-event sequence (CB
    # meta flush + DB meta flush + PS partial flush) forces the
    # pipeline to a clean state before our triangle reaches the
    # rasterizer.
    pos = native_pm4_event_write(pm4, pos,
    GFX9_EVENT_TYPE_FLUSH_AND_INV_CB_META, GFX9_EVENT_INDEX_OTHER);
    pos = native_pm4_event_write(pm4, pos,
    GFX9_EVENT_TYPE_FLUSH_AND_INV_DB_META, GFX9_EVENT_INDEX_OTHER);
    pos = native_pm4_event_write(pm4, pos,
    GFX9_EVENT_TYPE_PS_PARTIAL_FLUSH, GFX9_EVENT_INDEX_PARTIAL_FLUSH);
    # PFP_SYNC_ME — force PFP to wait for ME to drain before draw.
    # Without this PFP can read context state the ME hasn't committed.
    pos = native_pm4_pfp_sync_me(pm4, pos);
    pos = native_pm4_build_render_draw_tail(pm4, pos, vc);
    # Post-draw cache flush — same rationale as the standalone
    # composer above. CB writes need to land in memory before the
    # syncobj signals so the consumer reads / page-flips see the
    # rendered pixels.
    pos = native_pm4_event_write_cache_flush_and_inv(pm4, pos);
    var cur_dwords = pos / 4;
    if (cur_dwords < 256) {
        pos = native_pm4_nop(pm4, pos, 256 - cur_dwords);
    }

    var triple[32];
    native_render_handles_write(&triple, vs_handle, fs_handle, rt_handle, tex_handle);

    # v3.2.14 R.6: when the MQ render-graph executor stashes a current queue
    # (gpu_ctx_set_current_queue), route this draw through the GFX-ring TIMELINE
    # path (async, no CPU stall) so render nodes join cross-ring overlap — the
    # exact analog of the compute slot's current-queue check. A non-GFX current
    # queue is rejected inside native_render_dispatch_timeline. Zero stash = the
    # v3.0 synchronous single-shot path below, unchanged.
    var cq = gpu_ctx_current_queue(ctx);
    if (cq != 0) {
        var tl_rc = native_render_dispatch_timeline(ctx, pm4, pos, &triple, cq);
        store64(pass + NATIVE_PASS_FIELD_BOUND_TEX, 0);
        return tl_rc;
    }

    var t_now[16];
    memset(&t_now, 0, 16);
    # Audit 2026-06-14 [LOW-4]: check clock_gettime's return before reading
    # t_now — a discarded failure left the deadline computed from
    # uninitialized stack (spurious immediate timeout or near-unbounded wait).
    var trc = syscall(228, 1, &t_now);
    if (trc != 0) { return GPU_ERR_OTHER; }
    var ns_now = load64(&t_now + 0) * 1000000000 + load64(&t_now + 8);
    var deadline = ns_now + 15000000000;

    var draw_rc = native_render_dispatch_simple(ctx, pm4, pos, &triple, deadline);
    # v3.2 TS.5 (audit LOW): per-draw bind — clear the stash so a later draw in
    # the same pass must re-bind to sample again (else it would re-emit a stale
    # descriptor once multi-draw-per-pass lands). A fresh pass starts at 0.
    store64(pass + NATIVE_PASS_FIELD_BOUND_TEX, 0);
    return draw_rc;
}

fn _backend_native_render_pass_end(ctx, pass): i64 {
    if (ctx == 0)  { return 0; }
    if (pass == 0) { return 0; }
    memset(pass, 0, NATIVE_PASS_STRUCT_SIZE);
    return 0;
}

# ----------------------------------------------------------------
# Surface slot wrappers (v3 Step 7.7)
# ----------------------------------------------------------------
# The slot reads `card_fd` from `gpu_ctx_native_card_fd(ctx)`,
# which the public `gpu_surface_configure_native_kiosk` dispatcher
# stashes there before calling the slot. The render fd stays at
# `native_ctx_fd(ctx)` (set by `gpu_context_new_native`).
#
# Composes the full pipeline:
#   discovery    (7.1, native_kms_init)
#   modeset      (7.2(d), native_kms_modeset_first_connected)
#   second FB    (7.4(b), native_kms_alloc_fb)
#   page-flip    (7.4(b), native_kms_present) — on each frame
#   teardown     (7.4(b) + 7.2(d), release_fb + release_scanout)
#
# Caveat: surface_configure ONLY works on the kiosk path in v3.0.
# The logind path (gpu_surface_configure_native_logind) is gated
# on the v3.x samvada package; for now its public dispatcher (see docs/development/roadmap.md)
# returns GPU_ERR_NOT_IMPLEMENTED before reaching this slot.   #skip-lint

# NativeSurface layout (120 bytes):
#   +0:   card_fd        (i32)
#   +4:   render_fd      (i32)
#   +8:   state          (u64) — KmsState ptr (96 B elsewhere)
#   +16:  scanout        (40 B inline NativeKmsScanout) — has fb_a
#   +56:  fb_b           (32 B inline NativeKmsFb) — second framebuffer
#   +88:  front_is_b     (u32) — 0 = scanout's fb is front, 1 = fb_b is front
#   +92:  pad            (u32) — alignment
#   +96:  width          (u32) — pixels (mode-bound)
#   +100: height         (u32) — pixels
#   +104: pitch          (u32) — bytes per row (256-aligned, matches both FBs)
#   +108: master_owned   (u32) — 1 = mabda owns card_fd (logind/samvada
#                                acquired); release must give master back +
#                                close. 0 = kiosk consumer-owned fd. [HIGH-2]
#   +112: master_minor   (u32) — DRM minor passed to samvada_session_release
#   +116: pad            (u32)
var NATIVE_SURFACE_SIZE         = 120;
var NATIVE_SURFACE_CARD_FD      = 0;
var NATIVE_SURFACE_RENDER_FD    = 4;
var NATIVE_SURFACE_STATE        = 8;
var NATIVE_SURFACE_SCANOUT      = 16;
var NATIVE_SURFACE_FB_B         = 56;
var NATIVE_SURFACE_FRONT_IS_B   = 88;
var NATIVE_SURFACE_WIDTH        = 96;
var NATIVE_SURFACE_HEIGHT       = 100;
var NATIVE_SURFACE_PITCH        = 104;
var NATIVE_SURFACE_MASTER_OWNED = 108;
var NATIVE_SURFACE_MASTER_MINOR = 112;

# Audit 2026-06-14 [HIGH-2 NEW]: record that mabda (not the consumer)
# owns this surface's DRM master fd, so gpu_surface_release gives it back
# to logind + closes it. Set only by the logind dispatcher's success
# path; the kiosk path leaves master_owned=0 (consumer owns its fd).
fn native_surface_mark_master_owned(surface, minor): i64 {
    if (surface == 0) { return -1; }
    store32(surface + NATIVE_SURFACE_MASTER_OWNED, 1);
    store32(surface + NATIVE_SURFACE_MASTER_MINOR, minor);
    return 0;
}

# Configure a native surface. Reads card_fd from ctx (set by the
# public dispatcher), runs full modeset on first connected
# connector, allocates a second FB for double-buffering, returns
# the populated NativeSurface ptr (or 0 on any failure step).
fn _backend_native_surface_configure(ctx, width, height): i64 {
    if (ctx == 0)    { return 0; }
    if (width <= 0)  { return 0; }
    if (height <= 0) { return 0; }
    var card_fd = gpu_ctx_native_card_fd(ctx);
    if (card_fd <= 0) { return 0; }   # consumer didn't pre-stash
    var render_fd = native_ctx_fd(ctx);
    if (render_fd <= 0) { return 0; }

    var ns = alloc(NATIVE_SURFACE_SIZE);
    memset(ns, 0, NATIVE_SURFACE_SIZE);
    store32(ns + NATIVE_SURFACE_CARD_FD,   card_fd);
    store32(ns + NATIVE_SURFACE_RENDER_FD, render_fd);

    # ---- discovery ----
    var state = native_kms_init(card_fd);
    if (state == 0) { return 0; }
    store64(ns + NATIVE_SURFACE_STATE, state);

    # ---- modeset on first CONNECTED connector ----
    var rc = native_kms_modeset_first_connected(card_fd, render_fd,
    state,
    ns + NATIVE_SURFACE_SCANOUT);
    if (rc != 0) {
        native_kms_release(state);
        return 0;
    }
    var fb_w = load32(ns + NATIVE_SURFACE_SCANOUT + NATIVE_KMS_SCANOUT_WIDTH);
    var fb_h = load32(ns + NATIVE_SURFACE_SCANOUT + NATIVE_KMS_SCANOUT_HEIGHT);

    # Audit HIGH-1 (2026-04-30): preserve cross-backend identity.
    # The wgpu side honors consumer width/height; the native side
    # picks the EDID-preferred mode. If they don't match, fail loudly
    # rather than silently substituting — consumer back-buffer math
    # downstream assumes the dimensions it asked for.
    if (fb_w != width)  {
        native_kms_release_scanout(card_fd, render_fd,
        ns + NATIVE_SURFACE_SCANOUT);
        native_kms_release(state);
        return 0;
    }
    if (fb_h != height) {
        native_kms_release_scanout(card_fd, render_fd,
        ns + NATIVE_SURFACE_SCANOUT);
        native_kms_release(state);
        return 0;
    }

    # ---- alloc second FB matching mode dimensions ----
    rc = native_kms_alloc_fb(card_fd, render_fd, fb_w, fb_h,
    ns + NATIVE_SURFACE_FB_B);
    if (rc != 0) {
        native_kms_release_scanout(card_fd, render_fd,
        ns + NATIVE_SURFACE_SCANOUT);
        native_kms_release(state);
        return 0;
    }

    var pitch_raw = fb_w * 4;
    var pitch = ((pitch_raw + 255) / 256) * 256;
    store32(ns + NATIVE_SURFACE_WIDTH,      fb_w);
    store32(ns + NATIVE_SURFACE_HEIGHT,     fb_h);
    store32(ns + NATIVE_SURFACE_PITCH,      pitch);
    store32(ns + NATIVE_SURFACE_FRONT_IS_B, 0);  # scanout's FB is front
    return ns;
}

# Acquire returns the back-buffer's NativeKmsFb pointer (the FB
# that's NOT currently scanning). Consumer fills its mapped_addr
# with frame content, then calls present.
fn _backend_native_surface_acquire(ctx, surface): i64 {
    if (ctx == 0)     { return 0; }
    if (surface == 0) { return 0; }
    var front_is_b = load32(surface + NATIVE_SURFACE_FRONT_IS_B);
    if (front_is_b != 0) {
        # fb_b is currently scanning → back is the scanout's FB
        return surface + NATIVE_SURFACE_SCANOUT;
    }
    # scanout's FB is currently scanning → back is fb_b
    return surface + NATIVE_SURFACE_FB_B;
}

# Present flips the back buffer to scanning, blocks on vblank,
# then toggles which is "front." After return, the buffer that
# was just presented is on screen, and the next acquire returns
# the OTHER one.
fn _backend_native_surface_present(ctx, surface): i64 {
    if (ctx == 0)     { return GPU_ERR_OTHER; }
    if (surface == 0) { return GPU_ERR_OTHER; }
    var card_fd = load32(surface + NATIVE_SURFACE_CARD_FD);
    var front_is_b = load32(surface + NATIVE_SURFACE_FRONT_IS_B);
    var back_fb_id = 0;
    if (front_is_b != 0) {
        # back is scanout's FB
        back_fb_id = load32(surface + NATIVE_SURFACE_SCANOUT
        + NATIVE_KMS_SCANOUT_FB_ID);
    }
    if (front_is_b == 0) {
        # back is fb_b
        back_fb_id = load32(surface + NATIVE_SURFACE_FB_B
        + NATIVE_KMS_FB_FB_ID);
    }
    var rc = native_kms_present(card_fd,
    surface + NATIVE_SURFACE_SCANOUT,
    back_fb_id, 0);
    # Audit MED-1 (2026-04-30): map negative-errno (kernel) and
    # mabda-internal sentinels (-2 short read, -3 wrong event type)
    # to GPU_ERR_* so consumer error-handling matches the wgpu side.
    if (rc == 0 - 2) { return GPU_ERR_SURFACE_LOST; }
    if (rc == 0 - 3) { return GPU_ERR_SURFACE_LOST; }
    if (rc != 0)     { return _native_neg_rc_to_gpu_err(rc); }
    # Toggle which is front. (The flip-completed event drained inside
    # native_kms_present already ran; back is now scanning.)
    if (front_is_b == 0) { store32(surface + NATIVE_SURFACE_FRONT_IS_B, 1); }
    if (front_is_b != 0) { store32(surface + NATIVE_SURFACE_FRONT_IS_B, 0); }
    return 0;
}

fn _backend_native_surface_release(ctx, surface): i64 {
    if (ctx == 0)     { return 0; }
    if (surface == 0) { return 0; }
    var card_fd      = load32(surface + NATIVE_SURFACE_CARD_FD);
    var render_fd    = load32(surface + NATIVE_SURFACE_RENDER_FD);
    var state        = load64(surface + NATIVE_SURFACE_STATE);
    var master_owned = load32(surface + NATIVE_SURFACE_MASTER_OWNED);
    var master_minor = load32(surface + NATIVE_SURFACE_MASTER_MINOR);
    native_kms_release_fb(card_fd, render_fd,
    surface + NATIVE_SURFACE_FB_B);
    native_kms_release_scanout(card_fd, render_fd,
    surface + NATIVE_SURFACE_SCANOUT);
    if (state != 0) { native_kms_release(state); }
    # Audit 2026-06-14 [HIGH-2 NEW]: if mabda acquired this master fd via
    # logind/samvada, give master back to logind and close the fd — AFTER
    # the KMS teardown ioctls above, which need card_fd. Kiosk fds have
    # master_owned=0 (consumer owns the close), so they are left untouched.
    if (master_owned != 0) {
        samvada_session_release_device(_DRM_MAJOR, master_minor);
        sys_close(card_fd);
    }
    memset(surface, 0, NATIVE_SURFACE_SIZE);
    return 0;
}

# ----------------------------------------------------------------
# Builder
# ----------------------------------------------------------------

# Allocates a Backend, fills all 10 slots with the native wrappers
# above, and sets kind = BACKEND_KIND_AMD. Step 4c only lights the
# compute_dispatch slot end-to-end; the other 9 slots return
# stub values (GPU_ERR_OTHER for fallible operations, 0 for void
# operations). Backend is "complete" per backend_is_complete()
# (every slot non-null) but only the compute_dispatch path is real.
fn backend_native_new(): i64 {
    var b = backend_new();
    backend_set_slot(b, BACKEND_SLOT_CTX_CREATE_FROM_PREINIT,
    &_backend_native_ctx_create_from_preinit);
    backend_set_slot(b, BACKEND_SLOT_CTX_RELEASE,
    &_backend_native_ctx_release);
    backend_set_slot(b, BACKEND_SLOT_BUFFER_CREATE,
    &_backend_native_buffer_create);
    backend_set_slot(b, BACKEND_SLOT_BUFFER_WRITE,
    &_backend_native_buffer_write);
    backend_set_slot(b, BACKEND_SLOT_BUFFER_READ,
    &_backend_native_buffer_read);
    backend_set_slot(b, BACKEND_SLOT_BUFFER_RELEASE,
    &_backend_native_buffer_release);
    backend_set_slot(b, BACKEND_SLOT_SHADER_MODULE_CREATE,
    &_backend_native_shader_module_create);
    backend_set_slot(b, BACKEND_SLOT_SHADER_MODULE_RELEASE,
    &_backend_native_shader_module_release);
    backend_set_slot(b, BACKEND_SLOT_COMPUTE_DISPATCH,
    &_backend_native_compute_dispatch);
    backend_set_slot(b, BACKEND_SLOT_DEVICE_WAIT_IDLE,
    &_backend_native_device_wait_idle);
    backend_set_slot(b, BACKEND_SLOT_TEXTURE_CREATE_2D_RGBA8,
    &_backend_native_texture_create_2d_rgba8);
    # v3.2 T.7 — format-parameterized create (storage). Both backends now
    # fill the texfmt slot, so the backend_is_complete walk over the range
    # activates this step (M.6b "activate when both fill" pattern).
    backend_set_slot(b, BACKEND_SLOT_TEXTURE_CREATE_2D_FMT,
    &_backend_native_texture_create_2d_fmt);
    backend_set_slot(b, BACKEND_SLOT_TEXTURE_CREATE_2D_RGBA8_MIPPED,
    &_backend_native_texture_create_2d_rgba8_mipped);
    backend_set_slot(b, BACKEND_SLOT_TEXTURE_GENERATE_MIPMAPS,
    &_backend_native_texture_generate_mipmaps);
    backend_set_slot(b, BACKEND_SLOT_TEXTURE_WRITE,
    &_backend_native_texture_write);
    backend_set_slot(b, BACKEND_SLOT_TEXTURE_READ,
    &_backend_native_texture_read);
    backend_set_slot(b, BACKEND_SLOT_TEXTURE_RELEASE,
    &_backend_native_texture_release);
    backend_set_slot(b, BACKEND_SLOT_RENDER_TARGET_CREATE_2D_RGBA8,
    &_backend_native_render_target_create_2d_rgba8);
    backend_set_slot(b, BACKEND_SLOT_RENDER_TARGET_RELEASE,
    &_backend_native_render_target_release);
    backend_set_slot(b, BACKEND_SLOT_RENDER_PIPELINE_CREATE,
    &_backend_native_render_pipeline_create);
    backend_set_slot(b, BACKEND_SLOT_RENDER_PIPELINE_RELEASE,
    &_backend_native_render_pipeline_release);
    backend_set_slot(b, BACKEND_SLOT_RENDER_PASS_BEGIN,
    &_backend_native_render_pass_begin);
    backend_set_slot(b, BACKEND_SLOT_RENDER_PASS_DRAW,
    &_backend_native_render_pass_draw);
    backend_set_slot(b, BACKEND_SLOT_RENDER_PASS_END,
    &_backend_native_render_pass_end);
    # v3 surface slots (Step 7.6 stubs; 7.7 fills with real impls).
    backend_set_slot(b, BACKEND_SLOT_SURFACE_CONFIGURE,
    &_backend_native_surface_configure);
    backend_set_slot(b, BACKEND_SLOT_SURFACE_ACQUIRE,
    &_backend_native_surface_acquire);
    backend_set_slot(b, BACKEND_SLOT_SURFACE_PRESENT,
    &_backend_native_surface_present);
    backend_set_slot(b, BACKEND_SLOT_SURFACE_RELEASE,
    &_backend_native_surface_release);
    # v3.1 queue slots (Q.3b) — distinct HW rings + persistent timeline
    # syncobjs. Both backends now fill the queue range, so the
    # backend_is_complete walk over it is activated this step.
    backend_set_slot(b, BACKEND_SLOT_QUEUE_GET,
    &_backend_native_queue_get);
    backend_set_slot(b, BACKEND_SLOT_QUEUE_BARRIER,
    &_backend_native_queue_barrier);
    backend_set_slot(b, BACKEND_SLOT_QUEUE_WAIT_IDLE,
    &_backend_native_queue_wait_idle);
    # v3.2 X.5 — buffer-copy (SDMA transfer). Native fills the slot now;
    # the backend_is_complete walk over the range activates in X.6 once
    # the wgpu filler lands too ("activate when both fill").
    backend_set_slot(b, BACKEND_SLOT_BUFFER_COPY,
    &_backend_native_buffer_copy);
    # v3.2 TS.5 — sampleable-texture slots. The backend_is_complete walk over
    # 264..280 activates once wgpu fills these too (next sub-bite); native
    # fills them now.
    backend_set_slot(b, BACKEND_SLOT_TEXTURE_CREATE_2D_SAMPLEABLE,
    &_backend_native_texture_create_2d_sampleable);
    backend_set_slot(b, BACKEND_SLOT_TEXTURE_BIND_FOR_SAMPLE,
    &_backend_native_texture_bind_for_sample);
    backend_set_kind(b, BACKEND_KIND_AMD);
    return b;
}

# ================================================================
# v3 Step 5.1 — native 2D RGBA8 texture primitives (Phase C)
# ================================================================
# Linear-layout 2D RGBA8 textures. No mipmaps, no DCC, no tiling —
# just a flat array of (width × height × 4) bytes. Sufficient for
# CPU-uploaded textures + compute-shader writes; tiled / mipped /
# format-rich textures are subsequent Phase C chunks (5.x).
#
# NativeTexture struct layout (64 bytes — grew 32 → 48 at v3.1 M.1(b) for
# mip metadata; 48 → 64 at v3.2 TS.3 for sampleable surfaces; offsets 0..44
# unchanged):
#   +0:  handle    (u64, KMS handle)
#   +8:  va        (u64, canonical-high GPU VA of level 0)
#   +16: addr      (u64, CPU mmap pointer to level 0)
#   +24: size      (u64, total BO bytes — single level: w·h·4;
#                   mip chain: native_mip_chain_size (v3.1 M.2))
#   +32: width     (u32, level-0 width)
#   +36: height    (u32, level-0 height)
#   +40: mip_count (u32, 1 = single level; per-level VA = va +
#                   native_mip_level_offset(width, height, level))
#   +44: fmt       (u32, MABDA_TEXFMT_* — 0 = RGBA8; v3.2 T.7)
#   +48: sw_mode   (u32, GFX9 SW_MODE — LINEAR(0) storage/uncompressed;
#                   a tiled mode for sampleable compressed; v3.2 TS.3)
#   +52: t_va      (u64, GPU VA of this texture's 48-byte T#+S# descriptor
#                   BO, or 0 if not sampleable; v3.2 TS.3)
#   +60: pad       (u32)
#
# v3.1 M.1(c): the texture VA region is a per-context bump-allocated
# range (native_ctx_alloc_texture_va), not a single hardcoded VA. It was
# moved UP to 0xFFFF800180000000 with a 2 GiB span so a full mip chain
# (max 8192² RGBA8 ≈ 358 MiB) and several textures fit — the old 6 MiB
# gap below the RT base could not. RT / shader / output / cache VAs are
# untouched and sit well below this region.
#
# VA range layout (canonical-high aperture; offsets above
# 0xFFFF800100000000 unless noted):
#   0x100000000   shader BOs (caller-managed in v3 programs)
#   0x100004000   stub (gpu_context_new_native)
#   0x100200000   cached IB (gpu_context_new_native)
#   0x100400000   output BOs (caller-managed)
#   0x100600000   cached fence (gpu_context_new_native)
#   0x101000000   render targets (_NATIVE_RT_VA_BASE, 16 MiB area)
#   0x180000000   textures — 2 GiB bump region [base, base + 0x80000000),
#                 64 KiB-aligned per allocation (v3.1 M.1(c))
#
# The bump cursor never reclaims (mabda's native-allocator model — the
# create-once texture pattern). A free-list is a later concern if a
# consumer churns textures.

var _NATIVE_TEXTURE_VA_BASE   = 0xFFFF800180000000;
var _NATIVE_TEXTURE_VA_REGION = 0x80000000;   # 2 GiB
var _NATIVE_TEXTURE_VA_ALIGN  = 0x10000;      # 64 KiB per allocation

# v3.2 TS.7c-3 — fixed per-context staging VA for the tiled-copy bounce buffer.
# The tiled write/read path needs a transient linear staging BO; mapping it at a
# DEDICATED, RE-USED VA each call (rather than bump-allocating a fresh one)
# avoids permanently consuming the forward-only texture VA region — without it a
# streaming consumer exhausts the 2 GiB budget after ~32K copies (review
# 2026-06-16 MEDIUM). Tiled copies are synchronous (each waits before returning),
# so the single slot is never live across two copies. Sits in the free gap below
# the texture region; 256 MiB caps the largest single staging map (>= any 8192²
# compressed surface, ~64 MiB).
var _NATIVE_STAGING_VA        = 0xFFFF800140000000;
var _NATIVE_STAGING_VA_REGION = 0x10000000;   # 256 MiB

# Bump-allocate an aligned texture VA range of `size` bytes from the
# per-context region. Returns the base VA, or 0 on region exhaustion
# (caller treats 0 as a create failure). Lazy-inits the cursor to
# _NATIVE_TEXTURE_VA_BASE (the ctx memset leaves +120 zero).
fn native_ctx_alloc_texture_va(ctx, size): i64 {
    if (ctx == 0) { return 0; }
    var cur = native_ctx_tex_va_next(ctx);
    if (cur == 0) { cur = _NATIVE_TEXTURE_VA_BASE; }
    var step = _native_align_up(size, _NATIVE_TEXTURE_VA_ALIGN);
    var next = cur + step;
    if (next > _NATIVE_TEXTURE_VA_BASE + _NATIVE_TEXTURE_VA_REGION) {
        return 0;
    }
    native_ctx_set_tex_va_next(ctx, next);
    return cur;
}

# Roll back the LAST native_ctx_alloc_texture_va of `size` (LIFO). The forward-only
# cursor cannot reclaim an arbitrary freed VA, but an error path that fails right
# after allocating — with no intervening texture-VA allocation (Cyrius is single-
# threaded and these slots are not re-entrant) — can hand the just-reserved range
# back so a transient BO-create / va-map failure does not permanently consume the
# 2 GiB region (N.6r review, HIGH). ONLY valid immediately after the matching alloc.
fn native_ctx_free_texture_va(ctx, size): i64 {
    if (ctx == 0) { return 0 - 1; }
    var step = _native_align_up(size, _NATIVE_TEXTURE_VA_ALIGN);
    var cur = native_ctx_tex_va_next(ctx);
    if (cur == 0) { return 0; }
    native_ctx_set_tex_va_next(ctx, cur - step);
    return 0;
}

var NATIVE_TEX_FIELD_HANDLE    = 0;
var NATIVE_TEX_FIELD_VA        = 8;
var NATIVE_TEX_FIELD_ADDR      = 16;
var NATIVE_TEX_FIELD_SIZE      = 24;
var NATIVE_TEX_FIELD_WIDTH     = 32;
var NATIVE_TEX_FIELD_HEIGHT    = 36;
var NATIVE_TEX_FIELD_MIP_COUNT = 40;
var NATIVE_TEX_FIELD_FMT       = 44;   # v3.2 T.7 — MABDA_TEXFMT_* (0 = RGBA8); was pad
var NATIVE_TEX_FIELD_SW_MODE   = 48;   # v3.2 TS.3 — GFX9 SW_MODE (0 = LINEAR)
var NATIVE_TEX_FIELD_T_VA      = 52;   # v3.2 TS.3 — VA of the T#+S# descriptor BO (0 = none)
var NATIVE_TEX_STRUCT_SIZE     = 64;   # v3.2 TS.3 — 48 -> 64 (sampleable)

# v3.2 TS.3 — NativeTexture sampleable-field accessors.
fn native_tex_fmt(tex): i64 { return load32(tex + NATIVE_TEX_FIELD_FMT); }
fn native_tex_sw_mode(tex): i64 { return load32(tex + NATIVE_TEX_FIELD_SW_MODE); }
fn native_tex_t_va(tex): i64 { return load64(tex + NATIVE_TEX_FIELD_T_VA); }
fn native_tex_set_sw_mode(tex, m): i64 { store32(tex + NATIVE_TEX_FIELD_SW_MODE, m); return 0; }
fn native_tex_set_t_va(tex, va): i64 { store64(tex + NATIVE_TEX_FIELD_T_VA, va); return 0; }
# v3.2 TS.8 — CPU (mmap'd) address of the descriptor tail (T#/S#/scale BO), for
# draw-time writes into +48/+52. The descriptor sits at the same offset in the BO
# as t_va is past va, so addr + (t_va - va) is its CPU address. 0 if not sampleable.
fn native_tex_desc_cpu_addr(tex): i64 {
    if (native_tex_t_va(tex) == 0) { return 0; }
    return load64(tex + NATIVE_TEX_FIELD_ADDR)
    + (native_tex_t_va(tex) - load64(tex + NATIVE_TEX_FIELD_VA));
}

# Compute the byte size of a 2D RGBA8 texture. Pure math; safe to
# call without a fd. width × height × 4 bytes per pixel.
fn native_texture_size_2d_rgba8(width, height): i64 {
    return width * height * 4;
}

# ================================================================
# v3.1 [M.1] — native RGBA8 mip-chain byte layout (pure math)
# ================================================================
# Levels are packed contiguously in a single GTT BO, each level's base
# 256-byte aligned so it can seed a GFX9 image descriptor (V#), whose
# base address requires 256-byte alignment. See
# docs/proposals/v3.1-mipmap-generation.md § "Mipchain BO + VA layout".

var _NATIVE_MIP_ALIGN = 256;

fn _native_align_up(n, align): i64 {
    return ((n + (align - 1)) / align) * align;
}

# ================================================================
# v3.2 TS.7 — GFX9 SW_64KB_S tiled-surface geometry
# ================================================================
# The SDMA engine applies the swizzle (TS.6), but the SDMA tiled packet AND the
# T# descriptor both need the addrlib-exact tiled geometry — aligned pitch
# (epitch) + the 64 KiB-aligned surface size — or the TA reads garbage. Block
# dims come from addrlib's Block256_2d (256-byte micro-tile) << 4 (the 64 KiB
# block: log2BlkSize=16, log2blkSizeIn256B=8, widthAmp=heightAmp=4) — sourced
# from Mesa src/amd/addrlib (gfx9addrlib.cpp ComputeThinBlockDimension +
# addrlib2.cpp Block256_2d). Indexed by log2(element_bytes), 1/2/4/8/16 B.

fn _native_log2(n): i64 {
    var r = 0;
    var v = n;
    while (v > 1) { v = v / 2; r = r + 1; }
    return r;
}

# addrlib Block256_2d[log2(eb)] packed (w<<8)|h: {16,16},{16,8},{8,8},{8,4},{4,4}.
fn _native_block256_2d(esize_log2): i64 {
    if (esize_log2 == 0) { return (16 << 8) | 16; }
    if (esize_log2 == 1) { return (16 << 8) | 8; }
    if (esize_log2 == 2) { return (8 << 8) | 8; }
    if (esize_log2 == 3) { return (8 << 8) | 4; }
    if (esize_log2 == 4) { return (4 << 8) | 4; }
    return 0;
}

# SW_64KB_S 2D block dims in ELEMENTS = Block256_2d << 4.
fn native_tiled_block_w(esize_log2): i64 {
    return ((_native_block256_2d(esize_log2) >> 8) & 0xFF) << 4;
}
fn native_tiled_block_h(esize_log2): i64 {
    return (_native_block256_2d(esize_log2) & 0xFF) << 4;
}

# Compute SW_64KB_S geometry for a `wb`×`hb`-element surface of `element_bytes`.
# Writes 5 i64 to `out`: +0 block_w, +8 block_h, +16 aligned_wb (= epitch+1),
# +24 aligned_hb, +32 size (64 KiB-aligned BO bytes). For BC the elements are
# 4x4 blocks (wb/hb in blocks, element_bytes = block bytes).
fn native_tiled_geometry(out, element_bytes, wb, hb): i64 {
    var es = _native_log2(element_bytes);
    var bw = native_tiled_block_w(es);
    var bh = native_tiled_block_h(es);
    var awb = _native_align_up(wb, bw);
    var ahb = _native_align_up(hb, bh);
    var size = _native_align_up(awb * ahb * element_bytes, 65536);
    store64(out +  0, bw);
    store64(out +  8, bh);
    store64(out + 16, awb);
    store64(out + 24, ahb);
    store64(out + 32, size);
    return 0;
}

# v3.2 TS.7c — SW_64KB_S tiled geometry for a *compressed* `fmt` at
# `width`x`height`, in BLOCK units (a BC/ETC2/ASTC block is the tiled element).
# Writes 7 i64 to `out`:
#   +0 wb (blocks_x)             +8 hb (blocks_y)
#   +16 awb (tile-aligned blocks_x = T#/SDMA epitch + 1)
#   +24 ahb (tile-aligned blocks_y)
#   +32 tiled_size (64 KiB-aligned tiled-BO surface bytes)
#   +40 esize_log2 (SDMA element_size = log2(block_bytes))
#   +48 block_bytes
# Returns 0, or -1 for a non-compressed / invalid fmt or degenerate dims.
# Pure arithmetic over texture_format.cyr block math — fully CPU-checkable.
fn native_tex_tiled_params(fmt, width, height, out): i64 {
    if (mabda_texfmt_is_compressed(fmt) == 0) { return 0 - 1; }
    var bw_tex = mabda_texfmt_block_width(fmt);
    var bh_tex = mabda_texfmt_block_height(fmt);
    var bb = mabda_texfmt_block_bytes(fmt);
    if (bw_tex <= 0) { return 0 - 1; }
    if (bh_tex <= 0) { return 0 - 1; }
    if (bb <= 0)     { return 0 - 1; }
    var wb = mabda_texfmt_blocks_for_dim(width, bw_tex);
    var hb = mabda_texfmt_blocks_for_dim(height, bh_tex);
    if (wb <= 0) { return 0 - 1; }
    if (hb <= 0) { return 0 - 1; }
    var geo[40];
    native_tiled_geometry(&geo, bb, wb, hb);
    store64(out +  0, wb);
    store64(out +  8, hb);
    store64(out + 16, load64(&geo + 16));   # awb
    store64(out + 24, load64(&geo + 24));   # ahb
    store64(out + 32, load64(&geo + 32));   # tiled_size
    store64(out + 40, _native_log2(bb));    # esize_log2
    store64(out + 48, bb);                  # block_bytes
    return 0;
}

# v3.2 TS.7c-3 — build the SDMA COPY_TILED_SUB_WINDOW packet that moves a
# compressed `tex`'s surface to/from a linear staging VA. `buf` = packet dest,
# `lin_va` = staging BO VA, `detile` = 0 (L2T: linear->tiled write) | 1 (T2L:
# tiled->linear read). Pure byte-builder (no fd/ioctl) so the param derivation
# is CPU-pinnable.
#
# CONTRACT (review HIGH, 2026-06-15): the SDMA epitch MUST equal the T#'s epitch
# = awb-1 (the tile-ALIGNED block pitch - 1, from native_tex_tiled_params), NOT
# wb-1 (the unaligned block count - 1). The TS.6 round-trip probe used wb-1, which
# only coincides with awb-1 on a block_w-aligned surface; reusing it on a
# non-aligned BC surface would tile a layout the TA disagrees with -> garbage. We
# read awb straight from the same params the T# was built from, so they can't drift.
# Returns the packet byte length (56), or -1 if `tex`'s fmt isn't compressed.
fn native_tex_build_tiled_copy_packet(buf, tex, lin_va, detile): i64 {
    var fmt = native_tex_fmt(tex);
    var w = load32(tex + NATIVE_TEX_FIELD_WIDTH);
    var h = load32(tex + NATIVE_TEX_FIELD_HEIGHT);
    var tp[56];
    if (native_tex_tiled_params(fmt, w, h, &tp) != 0) { return 0 - 1; }
    var wb  = load64(&tp +  0);
    var hb  = load64(&tp +  8);
    var awb = load64(&tp + 16);
    var esize = load64(&tp + 40);
    var tiled_va = load64(tex + NATIVE_TEX_FIELD_VA);   # surface at BO +0
    var sw = native_tex_sw_mode(tex);
    # epitch = awb-1 (see CONTRACT); ext/copy region + linear pitch in BLOCKS
    # (the tiled element); linear slice = wb*hb blocks; dim = 2D(1).
    return native_sdma_build_copy_tiled(buf, tiled_va, lin_va,
    esize, sw, 1, awb - 1, wb, hb, wb, wb * hb, wb, hb, detile);
}

# Byte offset of mip `level` within the contiguous chain (the sum of the
# 256-aligned sizes of all lower levels). level 0 -> 0. Reusing
# native_mip_chain_size(w, h, level) gives the same value (the chain up to
# but not including `level`), but the explicit name reads clearer at call
# sites that want a single level's base.
fn native_mip_level_offset(width, height, level): i64 {
    var off = 0;
    var i = 0;
    while (i < level) {
        var w = mip_level_dim(width, i);
        var h = mip_level_dim(height, i);
        off = off + _native_align_up(w * h * 4, _NATIVE_MIP_ALIGN);
        i = i + 1;
    }
    return off;
}

# Total byte size of a `count`-level RGBA8 mip chain — i.e. the offset of
# the level just past the last. Feeds the single-BO allocation in the
# mipped texture create path (M.2).
fn native_mip_chain_size(width, height, count): i64 {
    return native_mip_level_offset(width, height, count);
}

# v3.1 [M.3]: GPU VA of mip `level` within a NativeTexture's chain.
# Because native textures are LINEAR GTT BOs, per-level "access" is just
# an address — the chain base VA plus the contiguous-chain byte offset
# (M.1). No image-descriptor table (T#/V#) is needed: the downsample
# shader (M.4) reads/writes via flat global_load/global_store at these
# VAs, exactly the way native_gfx9_shader_store_deadbeef addresses its
# output through a VA passed in user SGPRs. This is the v3.1 pivot away
# from the descriptor-table design in the original proposal — linear
# layout makes it unnecessary.
fn native_texture_level_va(tex, level): i64 {
    if (tex == 0) { return 0; }
    var w    = load32(tex + NATIVE_TEX_FIELD_WIDTH);
    var h    = load32(tex + NATIVE_TEX_FIELD_HEIGHT);
    var base = load64(tex + NATIVE_TEX_FIELD_VA);
    return base + native_mip_level_offset(w, h, level);
}

# Allocate a 2D RGBA8 texture: GTT BO + va_map at the texture VA.
# Caller provides `out` — a 32-byte buffer matching NativeTexture
# layout; on success the function fills handle/va/addr/size. On
# failure returns a GPU_ERR_* code, leaves out untouched.
fn native_texture_create_2d_rgba8(fd, va_base, width, height, out): i64 {
    var size = native_texture_size_2d_rgba8(width, height);
    var bo[16];
    var rc = native_bo_create_gtt(fd, size, &bo);
    if (rc != 0) { return _native_neg_rc_to_gpu_err(rc); }
    var handle = load64(&bo + 0);
    var addr   = load64(&bo + 8);
    # v3.1 M.1(c): VA is supplied by the per-context sub-allocator (the
    # slot calls native_ctx_alloc_texture_va) instead of a hardcoded base,
    # so a context can hold more than one texture without VA collisions.
    var va = va_base;
    rc = native_gem_va_map(fd, handle, va, size, _NATIVE_PERM_DATA);
    if (rc != 0) {
        var rc_save = rc;
        native_bo_release_gtt(fd, handle, addr, size);
        return _native_neg_rc_to_gpu_err(rc_save);
    }
    store64(out + NATIVE_TEX_FIELD_HANDLE, handle);
    store64(out + NATIVE_TEX_FIELD_VA,     va);
    store64(out + NATIVE_TEX_FIELD_ADDR,   addr);
    store64(out + NATIVE_TEX_FIELD_SIZE,   size);
    # v3.1 M.1(b): single-level texture carries mip_count = 1. The mipped
    # create path (M.2) fills width/height/mip_count for a real chain.
    store32(out + NATIVE_TEX_FIELD_WIDTH,     width);
    store32(out + NATIVE_TEX_FIELD_HEIGHT,    height);
    store32(out + NATIVE_TEX_FIELD_MIP_COUNT, 1);
    return 0;
}

# v3.2 T.7 — low-level format-parameterized native texture create. Linear
# GTT BO sized to the format's block data_size, but the BO + VA map use a
# 4 KiB-PAGE-ALIGNED size (compressed sizes are often sub-page — e.g. BC1
# 4x4 = 8 B — and native_gem_va_map rejects a sub-page size with rc=99,
# per reference_gem_va_map_page_align). The struct's SIZE field stores the
# LOGICAL data_size so the (size-driven) write/read validate n correctly.
# fmt is stashed at +44. STORAGE ONLY this minor — sampling is Phase TS.
fn native_texture_create_2d_fmt(fd, va_base, width, height, fmt, out): i64 {
    var logical = mabda_texfmt_data_size(fmt, width, height);
    if (logical == 0) { return GPU_ERR_TEXTURE; }      # invalid fmt / dims
    var bo_size = _native_align_up(logical, 4096);
    var bo[16];
    var rc = native_bo_create_gtt(fd, bo_size, &bo);
    if (rc != 0) { return _native_neg_rc_to_gpu_err(rc); }
    var handle = load64(&bo + 0);
    var addr   = load64(&bo + 8);
    rc = native_gem_va_map(fd, handle, va_base, bo_size, _NATIVE_PERM_DATA);
    if (rc != 0) {
        var rc_save = rc;
        native_bo_release_gtt(fd, handle, addr, bo_size);
        return _native_neg_rc_to_gpu_err(rc_save);
    }
    store64(out + NATIVE_TEX_FIELD_HANDLE, handle);
    store64(out + NATIVE_TEX_FIELD_VA,     va_base);
    store64(out + NATIVE_TEX_FIELD_ADDR,   addr);
    store64(out + NATIVE_TEX_FIELD_SIZE,   logical);   # logical bytes (write n==size)
    store32(out + NATIVE_TEX_FIELD_WIDTH,     width);
    store32(out + NATIVE_TEX_FIELD_HEIGHT,    height);
    store32(out + NATIVE_TEX_FIELD_MIP_COUNT, 1);
    store32(out + NATIVE_TEX_FIELD_FMT,       fmt);
    return 0;
}

# v3.1 [M.6]: allocate a mip-chain texture — one contiguous GTT BO sized
# to native_mip_chain_size, va-mapped at `va_base`. Level n's bytes live
# at va_base + native_mip_level_offset(w, h, n). Stores mip_count so the
# generate path (M.6b) knows how many levels to fill.
fn native_texture_create_mipped_2d_rgba8(fd, va_base, width, height, mip_count, out): i64 {
    # Page-align the BO + VA-map size: GEM_VA map requires a 4 KiB-aligned
    # size (the single-level path only ever used page-aligned sizes). The
    # per-level offsets are still 256-aligned for the V#/shader addressing;
    # only the whole-BO size is rounded up to a page here.
    var size = _native_align_up(native_mip_chain_size(width, height, mip_count), 4096);
    var bo[16];
    var rc = native_bo_create_gtt(fd, size, &bo);
    if (rc != 0) { return _native_neg_rc_to_gpu_err(rc); }
    var handle = load64(&bo + 0);
    var addr   = load64(&bo + 8);
    rc = native_gem_va_map(fd, handle, va_base, size, _NATIVE_PERM_DATA);
    if (rc != 0) {
        var rc_save = rc;
        native_bo_release_gtt(fd, handle, addr, size);
        return _native_neg_rc_to_gpu_err(rc_save);
    }
    store64(out + NATIVE_TEX_FIELD_HANDLE,    handle);
    store64(out + NATIVE_TEX_FIELD_VA,        va_base);
    store64(out + NATIVE_TEX_FIELD_ADDR,      addr);
    store64(out + NATIVE_TEX_FIELD_SIZE,      size);
    store32(out + NATIVE_TEX_FIELD_WIDTH,     width);
    store32(out + NATIVE_TEX_FIELD_HEIGHT,    height);
    store32(out + NATIVE_TEX_FIELD_MIP_COUNT, mip_count);
    return 0;
}

# Release a NativeTexture: va_unmap + bo_release_gtt, then zero
# the struct so accidental double-releases or stale-handle reads
# fail at zero rather than at a recycled BO. Tex with handle == 0
# is a no-op (caller may release an uninitialised struct safely).
fn native_texture_release_2d_rgba8(fd, tex): i64 {
    if (tex == 0) { return 0; }
    var handle = load64(tex + NATIVE_TEX_FIELD_HANDLE);
    if (handle == 0) { return 0; }
    var va   = load64(tex + NATIVE_TEX_FIELD_VA);
    var addr = load64(tex + NATIVE_TEX_FIELD_ADDR);
    var size = load64(tex + NATIVE_TEX_FIELD_SIZE);
    # v3.2 TS.5 (audit MED): a sampleable tex (t_va != 0) is a single BO mapped
    # at the descriptor-tail-padded bo_size, NOT `size` (= the logical surface
    # bytes kept for write/read bounds). Unmap/release the real mapped size or
    # a CPU-mmap page + the GPU-VA reservation leak per release. Storage/mipped
    # textures (t_va == 0) keep the existing `size` path unchanged.
    var t_va = native_tex_t_va(tex);
    var unmap_size = size;
    if (t_va != 0) {
        unmap_size = _native_align_up((t_va - va) + 64, 4096);
    }
    native_gem_va_unmap(fd, handle, va, unmap_size);
    native_bo_release_gtt(fd, handle, addr, unmap_size);
    store64(tex + NATIVE_TEX_FIELD_HANDLE, 0);
    store64(tex + NATIVE_TEX_FIELD_VA,     0);
    store64(tex + NATIVE_TEX_FIELD_ADDR,   0);
    store64(tex + NATIVE_TEX_FIELD_SIZE,   0);
    native_tex_set_t_va(tex, 0);   # so a released sampleable tex no longer binds
    return 0;
}

# ================================================================
# v3 Step 6.3 — native 2D RGBA8 render target primitives (Phase C)
# ================================================================
# Render targets are allocated and mapped almost exactly like
# textures (Step 5.1) — same GTT BO + va_map + linear layout. The
# difference is the *role*: an RT is bound to CB_COLOR0_BASE on the
# graphics ring (Step 6.5) rather than read by a fragment shader as
# a sampled texture. RT VA range is separate so a single ctx can
# hold both a sampled texture and an RT without VA collision (the
# Step 5.1 hardcoded-VA limit applies independently per pool).
#
# NativeRenderTarget struct layout (40 bytes):
#   +0:  handle (u64, KMS handle)
#   +8:  va     (u64, canonical-high GPU VA at RT range)
#   +16: addr   (u64, CPU mmap pointer — for clear-color writes
#                or CPU readback in tests)
#   +24: size   (u64, bytes — width × height × 4)
#   +32: width  (u32, pixels)
#   +36: height (u32, pixels)
#
# Width/height live on the RT (not derived from size) because Step
# 6.8c's render_pass_draw needs to feed them into
# native_pm4_build_render_pass_target (CB_COLOR0_PITCH and the
# scissor/viewport regs). The RT is the source of truth for its
# own dimensions; consumers shouldn't reconstruct them by factoring
# `size`.
#
# RT VA range: 0xFFFF800101000000 — 16 MiB past the texture base
# (0xFFFF800100A00000 + ~6 MiB headroom). Plenty of room for
# 2048x2048 RGBA8 RTs (16 MiB) before colliding with future ranges.

var _NATIVE_RT_VA_BASE  = 0xFFFF800101000000;

var NATIVE_RT_FIELD_HANDLE = 0;
var NATIVE_RT_FIELD_VA     = 8;
var NATIVE_RT_FIELD_ADDR   = 16;
var NATIVE_RT_FIELD_SIZE   = 24;
var NATIVE_RT_FIELD_WIDTH  = 32;
var NATIVE_RT_FIELD_HEIGHT = 36;
var NATIVE_RT_STRUCT_SIZE  = 40;

# Pure-math size formula. Symmetric with native_texture_size_2d_rgba8.
fn native_rt_size_2d_rgba8(width, height): i64 {
    return width * height * 4;
}

# Allocate a 2D RGBA8 render target. Single-RT-per-ctx limit (VA
# is hardcoded at _NATIVE_RT_VA_BASE) — same constraint as the
# texture allocator. Multi-RT VA allocator lands later in Phase C
# when render passes need MRT.
fn native_rt_create_2d_rgba8(fd, width, height, out): i64 {
    # Audit MED-3 (2026-04-30): native_pm4_build_render_pass_target's
    # viewport math uses integer (rt_width / 2) — odd dimensions lose
    # the half-pixel and silently miscalibrate the scissor / viewport.
    # Reject odd dims at the allocator boundary (cleanest fix; v3.x
    # may switch to f64-based viewport math to relax this).
    if (width <= 0)            { return GPU_ERR_TEXTURE_DIMENSION; }
    if (height <= 0)           { return GPU_ERR_TEXTURE_DIMENSION; }
    if ((width & 1) != 0)      { return GPU_ERR_TEXTURE_DIMENSION; }
    if ((height & 1) != 0)     { return GPU_ERR_TEXTURE_DIMENSION; }
    # Audit 2026-06-14 [MED-2]/[LOW-5]: cap the max dimension. Without it,
    # native_rt_size_2d_rgba8's width*height*4 can overflow i64 before
    # GEM_CREATE + mmap, and a width/height > 16384 wraps the 14-bit
    # CB_COLOR0_ATTRIB2 extent native_pm4_build_render_pass_target masks.
    # 8192 keeps the BO <= 268 MiB and the extent within the field.
    if (validate_dimensions(width, height, MABDA_MAX_TEXTURE_DIM_2D) != 0) {
        return GPU_ERR_TEXTURE_DIMENSION;
    }
    var size = native_rt_size_2d_rgba8(width, height);
    var bo[16];
    var rc = native_bo_create_gtt(fd, size, &bo);
    if (rc != 0) { return _native_neg_rc_to_gpu_err(rc); }
    var handle = load64(&bo + 0);
    var addr   = load64(&bo + 8);
    var va = _NATIVE_RT_VA_BASE;
    rc = native_gem_va_map(fd, handle, va, size, _NATIVE_PERM_DATA);
    if (rc != 0) {
        var rc_save = rc;
        native_bo_release_gtt(fd, handle, addr, size);
        return _native_neg_rc_to_gpu_err(rc_save);
    }
    store64(out + NATIVE_RT_FIELD_HANDLE, handle);
    store64(out + NATIVE_RT_FIELD_VA,     va);
    store64(out + NATIVE_RT_FIELD_ADDR,   addr);
    store64(out + NATIVE_RT_FIELD_SIZE,   size);
    store32(out + NATIVE_RT_FIELD_WIDTH,  width);
    store32(out + NATIVE_RT_FIELD_HEIGHT, height);
    return 0;
}

# Release a NativeRenderTarget. Pair with native_rt_create_2d_rgba8.
fn native_rt_release_2d_rgba8(fd, rt): i64 {
    if (rt == 0) { return 0; }
    var handle = load64(rt + NATIVE_RT_FIELD_HANDLE);
    if (handle == 0) { return 0; }
    var va   = load64(rt + NATIVE_RT_FIELD_VA);
    var addr = load64(rt + NATIVE_RT_FIELD_ADDR);
    var size = load64(rt + NATIVE_RT_FIELD_SIZE);
    native_gem_va_unmap(fd, handle, va, size);
    native_bo_release_gtt(fd, handle, addr, size);
    store64(rt + NATIVE_RT_FIELD_HANDLE, 0);
    store64(rt + NATIVE_RT_FIELD_VA,     0);
    store64(rt + NATIVE_RT_FIELD_ADDR,   0);
    store64(rt + NATIVE_RT_FIELD_SIZE,   0);
    store32(rt + NATIVE_RT_FIELD_WIDTH,  0);
    store32(rt + NATIVE_RT_FIELD_HEIGHT, 0);
    return 0;
}

# ================================================================
# v3 Step 6.8(c) — NativeRenderPipeline + NativePass
# ================================================================
# v2.1's 4-block PM4 split (`docs/proposals/v3-backend-interface.md`
# § "GFX9 PM4 block split"). Each lifetime gets its own home:
#
#   pipeline_sh_block  — per-pipeline, built at pipeline_create
#   pipeline_ctx_block — per-pipeline, built at pipeline_create
#   pass_target_block  — per-pass, built at pass_draw (v2: same call
#                        as the dispatch since v2 is single-draw-per-
#                        pass; future state-caching can hoist to
#                        pass_begin)
#   draw_tail          — per-draw, appended at pass_draw
#
# The per-pipeline blocks are pre-built once and memcpy'd into the
# IB at every dispatch. v2 pass_draw rebuilds pass_target_block and
# draw_tail every time (no caching) — that's the single-draw-per-
# pass simplification noted in v2.1 "What v2 still defers".

# NativeRenderPipeline struct layout (644 bytes):
#   +0:   vs_handle (u64, KMS handle for VS shader BO)
#   +8:   vs_va     (u64, canonical-high GPU VA of VS bytes)
#   +16:  fs_handle (u64, KMS handle for FS shader BO)
#   +24:  fs_va     (u64, canonical-high GPU VA of FS bytes)
#   +32:  pipeline_sh_block  (56 bytes — output of
#                              native_pm4_build_render_pipeline_sh)
#   +88:  pipeline_ctx_block (556 bytes — output of
#                              native_pm4_build_render_pipeline_ctx;
#                              grew 240 → 292 → 556 across the 2026-05-13
#                              GFX9 preamble fixes that splice the guard-
#                              band adjusts, BINNER_CNTL_0, and VGT reuse
#                              regs to keep the GFX ring from TDR'ing
#                              on Cezanne APUs)
#
# Audit 2026-06-14 [LOW-1]: this header now matches the load-bearing
# constants below (SH_BLOCK 56 @ +32, CTX_BLOCK 556 @ +88, total 644).
# The two block sizes (56 / 556) are pinned by the 6.5(b) composers and
# CPU-asserted in mabda_v3.tcyr — if those drift, this struct's inline
# layout breaks and tests catch it before runtime.

var NATIVE_PIPE_FIELD_VS_HANDLE = 0;
var NATIVE_PIPE_FIELD_VS_VA     = 8;
var NATIVE_PIPE_FIELD_FS_HANDLE = 16;
var NATIVE_PIPE_FIELD_FS_VA     = 24;
var NATIVE_PIPE_FIELD_SH_BLOCK  = 32;
# SH_BLOCK grew from 48 → 56: VS SET_SH_REG now covers RSRC3_VS +
# LATE_ALLOC_VS + PGM_LO/HI + RSRC1/2 (6 regs, 8 dwords). PS unchanged
# at 4 regs / 6 dwords.
var NATIVE_PIPE_FIELD_CTX_BLOCK = 88;
var NATIVE_PIPE_SH_BLOCK_SIZE   = 56;
# CTX_BLOCK grew from 424 → 556: added PA_CL_VS_OUT_CNTL +
# SPI_BARYC_CNTL + PA_SC_SHADER_CONTROL + VGT_GS_MODE + VGT_PRIMITIVEID_EN
# + DB_Z_INFO + DB_STENCIL_INFO + 2× PA_SC_AA_MASK + PA_SC_MODE_CNTL_0
# + VGT_GS_OUT_PRIM_TYPE (11 × 12 = 132 bytes added).
var NATIVE_PIPE_CTX_BLOCK_SIZE  = 556;
var NATIVE_PIPE_STRUCT_SIZE     = 644;

# Build a NativeRenderPipeline in-place. Caller allocates
# NATIVE_PIPE_STRUCT_SIZE bytes for `out`. Pre-builds both pipeline
# blocks; failure (composer returning a wrong-sized block) returns
# negative.
fn native_render_pipeline_pack(out, vs_handle, vs_va, fs_handle, fs_va): i64 {
    if (out == 0) { return -1; }
    memset(out, 0, NATIVE_PIPE_STRUCT_SIZE);
    store64(out + NATIVE_PIPE_FIELD_VS_HANDLE, vs_handle);
    store64(out + NATIVE_PIPE_FIELD_VS_VA,     vs_va);
    store64(out + NATIVE_PIPE_FIELD_FS_HANDLE, fs_handle);
    store64(out + NATIVE_PIPE_FIELD_FS_VA,     fs_va);
    var sh_end = native_pm4_build_render_pipeline_sh(
    out + NATIVE_PIPE_FIELD_SH_BLOCK, 0, vs_va, fs_va);
    if (sh_end != NATIVE_PIPE_SH_BLOCK_SIZE) { return -2; }
    var ctx_end = native_pm4_build_render_pipeline_ctx(
    out + NATIVE_PIPE_FIELD_CTX_BLOCK, 0);
    if (ctx_end != NATIVE_PIPE_CTX_BLOCK_SIZE) { return -3; }
    return 0;
}

# NativePass struct layout (40 bytes — grew 32 → 40 at v3.2 TS.3 for the
# bound-texture descriptor VA; offsets 0..24 unchanged):
#   +0:  ctx_ref         (u64, GpuContext for pass_draw + pass_end)
#   +8:  reserved        (u64, parallel to wgpu's pass-encoder slot)
#   +16: rt_ptr          (u64, NativeRenderTarget — provides VA / w / h)
#   +24: clear_color_ptr (u64, 32-byte f64 RGBA — captured for v2.1;
#                         v2-native ignores because the FS shader
#                         hardcodes solid red, see Step 6.2(b) FS)
#   +32: bound_tex       (u64, the bound NativeTexture* or 0; v3.2 TS.3/TS.5 —
#                         bind_for_sample stashes the tex pointer so the draw
#                         derives both the T#/S# descriptor VA (native_tex_t_va,
#                         for the PS USER_DATA SET_SH_REG) and the surface BO
#                         handle (for residency — the single sampleable BO))
var NATIVE_PASS_FIELD_CTX         = 0;
var NATIVE_PASS_FIELD_RESERVED    = 8;
var NATIVE_PASS_FIELD_RT          = 16;
var NATIVE_PASS_FIELD_CLEAR_COLOR = 24;
var NATIVE_PASS_FIELD_BOUND_TEX   = 32;   # v3.2 TS.3/TS.5 (was TEX_DESC_VA)
var NATIVE_PASS_STRUCT_SIZE       = 40;

# --- backend_native_kms.cyr ---

# @internal — native KMS / mode-setting (v3 Phase D, Step 7.1)
# backend_native_kms.cyr — direct DRM/KMS ioctls for surface present
#
# Filed separately from backend_native.cyr because the surface path is
# structurally distinct from the compute / render path:
#   - compute / render use /dev/dri/renderD128 (render node, no
#     master) and DRM_IOCTL_AMDGPU_* + generic GEM ioctls.
#   - mode-set / scanout uses /dev/dri/card0 (primary node, requires
#     DRM master) and DRM_IOCTL_MODE_* generic ioctls.
#
# The fd story diverges, the ioctl families diverge, the lifetime
# story diverges (a render-only ctx never touches KMS) — so the code
# diverges too. Keeping it in its own module makes the boundary
# explicit and prevents the compute path from accidentally pulling
# in scanout state.
#
# Phase D sub-bullets (per docs/development/3-0-punchlist.md):
#   7.1(a) — GetResources + KmsState scaffold (THIS FILE, Step 7.1a)
#   7.1(b) — per-connector enumeration (modes + props)
#   7.1(c) — per-encoder enumeration + native_kms_state_summary
#   7.2    — mode-set: pick a default mode + DRM_IOCTL_MODE_SETCRTC
#   7.3    — framebuffer creation: KMS-side wrap of a GTT BO
#   7.4    — page flip + vblank
#   7.5    — present primitive (queue + fence integration)
#   7.6    — surface release lifecycle
#   7.7    — public gpu_surface_* API + e2e program
#
# All data types are i64 / u64 unless noted. drm_mode_* struct layouts
# mirror include/uapi/drm/drm_mode.h on x86_64 Linux. No libdrm —
# direct syscall(SYS_IOCTL) only, same posture as backend_native.cyr.

# ================================================================
# DRM mode-setting ioctl numbers
# ================================================================
# Encoding per asm-generic/ioctl.h:
#   _IOC(dir, type, nr, size) = (dir << 30) | (size << 16) | (type << 8) | nr
# Direction codes are reused from backend_native.cyr (_IOC_RW = 3);
# DRM type 'd' = 0x64 likewise reused as DRM_IOCTL_TYPE.

# DRM_IOCTL_MODE_GETRESOURCES — nr 0xA0, RW, sizeof(drm_mode_card_res) = 64
#   0xC0000000 | (64 << 16) | (0x64 << 8) | 0xA0 == 0xC04064A0
var DRM_IOCTL_MODE_GETRESOURCES = 0xC04064A0;

# DRM_IOCTL_SET_MASTER — nr 0x1E, no payload (dir=0, size=0)
#   (0 << 30) | (0 << 16) | (0x64 << 8) | 0x1E == 0x641E
# Acquires DRM master on this fd. Required for SETCRTC, AddFB,
# PageFlip, and other modesetting ioctls. Returns:
#   0       — got master
#   -EACCES — not allowed (e.g., not active vt, no CAP_SYS_ADMIN)
#   -EINVAL — already master (also fine; treat as success)
#   -EBUSY  — another fd holds master; will fail until that fd
#             closes or calls DROP_MASTER (typical when
#             systemd-logind is keeping master for the
#             desktop-session compositor on a different vt).
var DRM_IOCTL_SET_MASTER  = 0x641E;
var DRM_IOCTL_DROP_MASTER = 0x641F;

# Acquire DRM master. Returns 0 on success, negative errno on
# failure. The kernel return codes the caller may need to handle:
#   0       — got master
#   -EACCES — not allowed (e.g., not active vt, no CAP_SYS_ADMIN)
#   -EINVAL — caller-side error; on some kernels also "already
#             master" but that case is ambiguous with genuine
#             argument problems, so we pass it through unchanged
#             rather than collapsing to success (audit MED-5).
#             Callers that need to disambiguate "already master"
#             from "operation rejected" can probe via
#             DRM_IOCTL_AUTH_MAGIC after a -EINVAL.
#   -EBUSY  — another fd holds master.
# Returns -1 if `fd` is invalid (audit LOW-1) — matches every
# other ioctl wrapper in this file.
fn native_drm_set_master(fd): i64 {
    if (fd <= 0) { return -1; }
    return syscall(SYS_IOCTL, fd, DRM_IOCTL_SET_MASTER, 0);
}

# Release DRM master. Lets the next SET_MASTER on a different fd
# succeed. Returns 0 on success, negative errno on failure, or
# -1 if `fd` is invalid (audit LOW-1).
fn native_drm_drop_master(fd): i64 {
    if (fd <= 0) { return -1; }
    return syscall(SYS_IOCTL, fd, DRM_IOCTL_DROP_MASTER, 0);
}

# DRM_IOCTL_MODE_GETCONNECTOR — nr 0xA7, RW, sizeof(drm_mode_get_connector) = 80
#   0xC0000000 | (80 << 16) | (0x64 << 8) | 0xA7 == 0xC05064A7
# (Constant exposed for 7.1(b); ioctl helper lands there.)
var DRM_IOCTL_MODE_GETCONNECTOR = 0xC05064A7;

# DRM_IOCTL_MODE_GETENCODER — nr 0xA6, RW, sizeof(drm_mode_get_encoder) = 20
#   0xC0000000 | (20 << 16) | (0x64 << 8) | 0xA6 == 0xC01464A6
# (Constant exposed for 7.1(c); ioctl helper lands there.)
var DRM_IOCTL_MODE_GETENCODER = 0xC01464A6;

# ================================================================
# drm_mode_card_res struct layout (64 bytes, x86_64)
# ================================================================
# Mirror of include/uapi/drm/drm_mode.h:drm_mode_card_res:
#
#   +0:  fb_id_ptr           (u64) — userspace ptr to FB-ID array
#   +8:  crtc_id_ptr         (u64) — userspace ptr to CRTC-ID array
#   +16: connector_id_ptr    (u64) — userspace ptr to connector-ID array
#   +24: encoder_id_ptr      (u64) — userspace ptr to encoder-ID array
#   +32: count_fbs           (u32) — IN: cap; OUT: actual count
#   +36: count_crtcs         (u32) — IN: cap; OUT: actual count
#   +40: count_connectors    (u32) — IN: cap; OUT: actual count
#   +44: count_encoders      (u32) — IN: cap; OUT: actual count
#   +48: min_width           (u32) — OUT
#   +52: max_width           (u32) — OUT
#   +56: min_height          (u32) — OUT
#   +60: max_height          (u32) — OUT
#
# Two-call protocol: first ioctl with count_* = 0 and *_ptr = NULL
# returns the actual counts; second ioctl with caller-allocated arrays
# at *_ptr and count_* = capacity returns the IDs. This matches
# libdrm's drmModeGetResources internal pattern.

var DRM_MODE_CARD_RES_SIZE         = 64;
var DRM_MODE_CARD_RES_FB_PTR       = 0;
var DRM_MODE_CARD_RES_CRTC_PTR     = 8;
var DRM_MODE_CARD_RES_CONN_PTR     = 16;
var DRM_MODE_CARD_RES_ENC_PTR      = 24;
var DRM_MODE_CARD_RES_COUNT_FBS    = 32;
var DRM_MODE_CARD_RES_COUNT_CRTCS  = 36;
var DRM_MODE_CARD_RES_COUNT_CONN   = 40;
var DRM_MODE_CARD_RES_COUNT_ENC    = 44;
var DRM_MODE_CARD_RES_MIN_WIDTH    = 48;
var DRM_MODE_CARD_RES_MAX_WIDTH    = 52;
var DRM_MODE_CARD_RES_MIN_HEIGHT   = 56;
var DRM_MODE_CARD_RES_MAX_HEIGHT   = 60;

# Low-level GetResources ioctl. Caller owns `req` (64 bytes), which
# this fn does NOT zero — the caller controls whether *_ptr and
# count_* are set up for a count-only call (zeros) or a capacity-
# bounded fill call. Returns 0 on success, negative errno on failure.
fn native_drm_mode_get_resources(fd, req): i64 {
    return syscall(SYS_IOCTL, fd, DRM_IOCTL_MODE_GETRESOURCES, req);
}

# ================================================================
# drm_mode_get_connector struct layout (80 bytes, x86_64)
# ================================================================
# Mirror of include/uapi/drm/drm_mode.h:drm_mode_get_connector:
#
#   +0:  encoders_ptr        (u64) — userspace ptr to u32[count_encoders]
#   +8:  modes_ptr           (u64) — userspace ptr to drm_mode_modeinfo[count_modes]
#   +16: props_ptr           (u64) — userspace ptr to u32[count_props]
#   +24: prop_values_ptr     (u64) — userspace ptr to u64[count_props]
#   +32: count_modes         (u32) — IN: cap; OUT: actual
#   +36: count_props         (u32) — IN: cap; OUT: actual
#   +40: count_encoders      (u32) — IN: cap; OUT: actual
#   +44: encoder_id          (u32) — OUT: current bound encoder, 0 if not connected
#   +48: connector_id        (u32) — IN: connector id to query
#   +52: connector_type      (u32) — OUT: DRM_MODE_CONNECTOR_*
#   +56: connector_type_id   (u32) — OUT: per-type instance (DP-1 → 1, DP-2 → 2)
#   +60: connection          (u32) — OUT: DRM_MODE_CONNECTED/DISCONNECTED/UNKNOWN
#   +64: mm_width            (u32) — OUT: physical width in mm
#   +68: mm_height           (u32) — OUT: physical height in mm
#   +72: subpixel            (u32) — OUT: subpixel layout
#   +76: pad                 (u32) — kernel ≥ 4.x; ignore
#
# Same two-call protocol as drm_mode_card_res: pass-1 with count_*=0
# and *_ptr=0 to discover sizes; pass-2 with caller-allocated arrays
# and count_* = capacity to fill.
var DRM_MODE_GET_CONNECTOR_SIZE          = 80;
var DRM_MODE_GET_CONNECTOR_ENCODERS_PTR  = 0;
var DRM_MODE_GET_CONNECTOR_MODES_PTR     = 8;
var DRM_MODE_GET_CONNECTOR_PROPS_PTR     = 16;
var DRM_MODE_GET_CONNECTOR_PROP_VALS_PTR = 24;
var DRM_MODE_GET_CONNECTOR_COUNT_MODES   = 32;
var DRM_MODE_GET_CONNECTOR_COUNT_PROPS   = 36;
var DRM_MODE_GET_CONNECTOR_COUNT_ENC     = 40;
var DRM_MODE_GET_CONNECTOR_ENCODER_ID    = 44;
var DRM_MODE_GET_CONNECTOR_CONN_ID       = 48;
var DRM_MODE_GET_CONNECTOR_CONN_TYPE     = 52;
var DRM_MODE_GET_CONNECTOR_CONN_TYPE_ID  = 56;
var DRM_MODE_GET_CONNECTOR_CONNECTION    = 60;
var DRM_MODE_GET_CONNECTOR_MM_WIDTH      = 64;
var DRM_MODE_GET_CONNECTOR_MM_HEIGHT     = 68;
var DRM_MODE_GET_CONNECTOR_SUBPIXEL      = 72;

# Connection status enum (uapi/drm/drm_mode.h):
var DRM_MODE_CONNECTED       = 1;
var DRM_MODE_DISCONNECTED    = 2;
var DRM_MODE_UNKNOWNCONNECTION = 3;

# Connector-type enum — values mirror DRM_MODE_CONNECTOR_* in
# include/uapi/drm/drm_mode.h. Covers everything modern x86 / ARM
# desktops + laptops actually use; obscure connector types
# (TV / Composite / 9PinDIN) shipped pre-2010 hardware and aren't
# worth wiring constants for until a consumer asks.
var DRM_MODE_CONNECTOR_Unknown      = 0;
var DRM_MODE_CONNECTOR_VGA          = 1;
var DRM_MODE_CONNECTOR_DVII         = 2;
var DRM_MODE_CONNECTOR_DVID         = 3;
var DRM_MODE_CONNECTOR_DVIA         = 4;
var DRM_MODE_CONNECTOR_HDMIA        = 11;
var DRM_MODE_CONNECTOR_HDMIB        = 12;
var DRM_MODE_CONNECTOR_DisplayPort  = 10;
var DRM_MODE_CONNECTOR_eDP          = 14;
var DRM_MODE_CONNECTOR_VIRTUAL      = 15;
var DRM_MODE_CONNECTOR_DSI          = 16;
var DRM_MODE_CONNECTOR_USB          = 20;

# Low-level GetConnector ioctl. Caller owns `req` (80 bytes); fills
# count_* + *_ptr per the two-call protocol. Caller MUST set
# `connector_id` at +48 before calling (the kernel keys the lookup
# off it). Returns 0 on success, negative errno on failure.
fn native_drm_mode_get_connector(fd, req): i64 {
    return syscall(SYS_IOCTL, fd, DRM_IOCTL_MODE_GETCONNECTOR, req);
}

# ================================================================
# drm_mode_modeinfo struct layout (68 bytes, x86_64)
# ================================================================
# Mirror of include/uapi/drm/drm_mode.h:drm_mode_modeinfo. Each
# entry in the modes_ptr array of a populated drm_mode_get_connector
# is one of these. The name field is fixed-width 32 bytes (ASCII +
# NUL padding; not necessarily NUL-terminated if the mode name is
# exactly 32 chars, though radv / kernel never go that long).
#
#   +0:  clock         (u32) — pixel clock in kHz
#   +4:  hdisplay      (u16) — visible H pixels
#   +6:  hsync_start   (u16)
#   +8:  hsync_end     (u16)
#   +10: htotal        (u16)
#   +12: hskew         (u16)
#   +14: vdisplay      (u16) — visible V pixels
#   +16: vsync_start   (u16)
#   +18: vsync_end     (u16)
#   +20: vtotal        (u16)
#   +22: vscan         (u16)
#   +24: vrefresh      (u32) — Hz × 1000 (e.g., 59940 = 59.94 Hz)
#   +28: flags         (u32)
#   +32: type          (u32)
#   +36: name[32]      (char) — DRM_DISPLAY_MODE_LEN = 32
var DRM_MODE_MODEINFO_SIZE        = 68;
var DRM_MODE_MODEINFO_CLOCK       = 0;
var DRM_MODE_MODEINFO_HDISPLAY    = 4;
var DRM_MODE_MODEINFO_HSYNC_START = 6;
var DRM_MODE_MODEINFO_HSYNC_END   = 8;
var DRM_MODE_MODEINFO_HTOTAL      = 10;
var DRM_MODE_MODEINFO_HSKEW       = 12;
var DRM_MODE_MODEINFO_VDISPLAY    = 14;
var DRM_MODE_MODEINFO_VSYNC_START = 16;
var DRM_MODE_MODEINFO_VSYNC_END   = 18;
var DRM_MODE_MODEINFO_VTOTAL      = 20;
var DRM_MODE_MODEINFO_VSCAN       = 22;
var DRM_MODE_MODEINFO_VREFRESH    = 24;
var DRM_MODE_MODEINFO_FLAGS       = 28;
var DRM_MODE_MODEINFO_TYPE        = 32;
var DRM_MODE_MODEINFO_NAME        = 36;
var DRM_MODE_MODEINFO_NAME_LEN    = 32;

# ================================================================
# KmsState struct layout (96 bytes)
# ================================================================
# Owns the full output of two-pass MODE_GETRESOURCES discovery:
# the kernel-reported counts, the four ID arrays (heap-allocated by
# native_kms_init), and the framebuffer extent limits. The fd is
# stashed at +0 so subsequent per-connector / per-encoder ioctls
# don't need to be re-passed it.
#
#   +0:  fd                  (u64) — DRM card-node fd
#   +8:  count_fbs           (u32)
#   +12: count_crtcs         (u32)
#   +16: count_connectors    (u32)
#   +20: count_encoders      (u32)
#   +24: fb_ids              (u64 ptr — heap, count_fbs × u32)
#   +32: crtc_ids            (u64 ptr — heap, count_crtcs × u32)
#   +40: connector_ids       (u64 ptr — heap, count_connectors × u32)
#   +48: encoder_ids         (u64 ptr — heap, count_encoders × u32)
#   +56: min_width           (u32)
#   +60: max_width           (u32)
#   +64: min_height          (u32)
#   +68: max_height          (u32)
#   +72: reserved            (24 bytes — for 7.1(b/c) per-connector
#                              + per-encoder summary tables)
var KMS_STATE_FIELD_FD             = 0;
var KMS_STATE_FIELD_COUNT_FBS      = 8;
var KMS_STATE_FIELD_COUNT_CRTCS    = 12;
var KMS_STATE_FIELD_COUNT_CONN     = 16;
var KMS_STATE_FIELD_COUNT_ENCODERS      = 20;
var KMS_STATE_FIELD_FB_IDS         = 24;
var KMS_STATE_FIELD_CRTC_IDS       = 32;
var KMS_STATE_FIELD_CONN_IDS       = 40;
var KMS_STATE_FIELD_ENC_IDS        = 48;
var KMS_STATE_FIELD_MIN_WIDTH      = 56;
var KMS_STATE_FIELD_MAX_WIDTH      = 60;
var KMS_STATE_FIELD_MIN_HEIGHT     = 64;
var KMS_STATE_FIELD_MAX_HEIGHT     = 68;
var KMS_STATE_STRUCT_SIZE          = 96;

# Two-pass discovery driver. Allocates a 96-byte KmsState, opens DRM
# resources twice (count-only then array-fill), populates the state.
# Caller frees the state with native_kms_release.
#
# Returns the KmsState pointer on success, or 0 on failure (count-
# pass ioctl failed; either fd is not a DRM master node, or the
# kernel doesn't support modesetting on this device).
fn native_kms_init(fd): i64 {
    if (fd <= 0) { return 0; }
    var state = alloc(KMS_STATE_STRUCT_SIZE);
    memset(state, 0, KMS_STATE_STRUCT_SIZE);
    store64(state + KMS_STATE_FIELD_FD, fd);

    # ---- Pass 1: count-only (all *_ptr = 0, count_* = 0) ----
    var req[64];
    memset(&req, 0, DRM_MODE_CARD_RES_SIZE);
    var rc = native_drm_mode_get_resources(fd, &req);
    if (rc != 0) { return 0; }

    var count_fbs   = load32(&req + DRM_MODE_CARD_RES_COUNT_FBS);
    var count_crtcs = load32(&req + DRM_MODE_CARD_RES_COUNT_CRTCS);
    var count_conn  = load32(&req + DRM_MODE_CARD_RES_COUNT_CONN);
    var count_enc   = load32(&req + DRM_MODE_CARD_RES_COUNT_ENC);

    # Stash the framebuffer extent limits (these come back from the
    # count-pass; no need for a fill-pass to read them).
    store32(state + KMS_STATE_FIELD_MIN_WIDTH,
    load32(&req + DRM_MODE_CARD_RES_MIN_WIDTH));
    store32(state + KMS_STATE_FIELD_MAX_WIDTH,
    load32(&req + DRM_MODE_CARD_RES_MAX_WIDTH));
    store32(state + KMS_STATE_FIELD_MIN_HEIGHT,
    load32(&req + DRM_MODE_CARD_RES_MIN_HEIGHT));
    store32(state + KMS_STATE_FIELD_MAX_HEIGHT,
    load32(&req + DRM_MODE_CARD_RES_MAX_HEIGHT));

    # ---- Pass 2: array fill ----
    # Heap-allocate four u32 arrays sized by the pass-1 counts. Skip
    # the alloc + ioctl for any zero-count category (e.g., a
    # freshly-booted card with no FBs yet has count_fbs = 0).
    var fb_ids   = 0;
    var crtc_ids = 0;
    var conn_ids = 0;
    var enc_ids  = 0;

    if (count_fbs > 0)   { fb_ids   = alloc(count_fbs * 4); }
    if (count_crtcs > 0) { crtc_ids = alloc(count_crtcs * 4); }
    if (count_conn > 0)  { conn_ids = alloc(count_conn * 4); }
    if (count_enc > 0)   { enc_ids  = alloc(count_enc * 4); }

    memset(&req, 0, DRM_MODE_CARD_RES_SIZE);
    store64(&req + DRM_MODE_CARD_RES_FB_PTR,    fb_ids);
    store64(&req + DRM_MODE_CARD_RES_CRTC_PTR,  crtc_ids);
    store64(&req + DRM_MODE_CARD_RES_CONN_PTR,  conn_ids);
    store64(&req + DRM_MODE_CARD_RES_ENC_PTR,   enc_ids);
    store32(&req + DRM_MODE_CARD_RES_COUNT_FBS,   count_fbs);
    store32(&req + DRM_MODE_CARD_RES_COUNT_CRTCS, count_crtcs);
    store32(&req + DRM_MODE_CARD_RES_COUNT_CONN,  count_conn);
    store32(&req + DRM_MODE_CARD_RES_COUNT_ENC,   count_enc);

    rc = native_drm_mode_get_resources(fd, &req);
    if (rc != 0) { return 0; }

    # The kernel may report fewer than pass-1 counts if a connector
    # was hot-unplugged between calls. Use the post-fill counts as
    # the source of truth — but defensively clamp against the
    # pre-fill capacity (audit MED-4). The kernel SHOULD never
    # return more than the cap we passed in, but the TOCTOU window
    # between the two ioctls is wide enough that we don't want a
    # future kernel quirk or hot-add race to trick downstream code
    # into reading past the end of the heap arrays we sized off
    # pass-1 counts.
    var actual_fbs   = load32(&req + DRM_MODE_CARD_RES_COUNT_FBS);
    var actual_crtcs = load32(&req + DRM_MODE_CARD_RES_COUNT_CRTCS);
    var actual_conn  = load32(&req + DRM_MODE_CARD_RES_COUNT_CONN);
    var actual_enc   = load32(&req + DRM_MODE_CARD_RES_COUNT_ENC);
    if (actual_fbs   > count_fbs)   { actual_fbs   = count_fbs; }
    if (actual_crtcs > count_crtcs) { actual_crtcs = count_crtcs; }
    if (actual_conn  > count_conn)  { actual_conn  = count_conn; }
    if (actual_enc   > count_enc)   { actual_enc   = count_enc; }
    store32(state + KMS_STATE_FIELD_COUNT_FBS,      actual_fbs);
    store32(state + KMS_STATE_FIELD_COUNT_CRTCS,    actual_crtcs);
    store32(state + KMS_STATE_FIELD_COUNT_CONN,     actual_conn);
    store32(state + KMS_STATE_FIELD_COUNT_ENCODERS, actual_enc);
    store64(state + KMS_STATE_FIELD_FB_IDS,   fb_ids);
    store64(state + KMS_STATE_FIELD_CRTC_IDS, crtc_ids);
    store64(state + KMS_STATE_FIELD_CONN_IDS, conn_ids);
    store64(state + KMS_STATE_FIELD_ENC_IDS,  enc_ids);

    return state;
}

# Release a KmsState. The bump-allocator pattern means the heap
# allocations themselves are not freed (consistent with
# native_compute_dispatch_cached and similar paths) — we just zero
# the struct so subsequent loads of stale ptrs surface as null.
# Returns 0.
fn native_kms_release(state): i64 {
    if (state == 0) { return 0; }
    memset(state, 0, KMS_STATE_STRUCT_SIZE);
    return 0;
}

# ----------------------------------------------------------------
# Field accessors (consistent with native_ctx_* helpers in
# backend_native.cyr — short-name accessors keep call sites readable
# without spreading the field-offset constants through callers).
# ----------------------------------------------------------------
fn kms_state_fd(state): i64 { return load64(state + KMS_STATE_FIELD_FD); }
fn kms_state_count_fbs(state): i64 { return load32(state + KMS_STATE_FIELD_COUNT_FBS); }
fn kms_state_count_crtcs(state): i64 { return load32(state + KMS_STATE_FIELD_COUNT_CRTCS); }
fn kms_state_count_conn(state): i64 { return load32(state + KMS_STATE_FIELD_COUNT_CONN); }
fn kms_state_count_enc(state): i64 { return load32(state + KMS_STATE_FIELD_COUNT_ENCODERS); }
fn kms_state_fb_ids(state): i64 { return load64(state + KMS_STATE_FIELD_FB_IDS); }
fn kms_state_crtc_ids(state): i64 { return load64(state + KMS_STATE_FIELD_CRTC_IDS); }
fn kms_state_conn_ids(state): i64 { return load64(state + KMS_STATE_FIELD_CONN_IDS); }
fn kms_state_enc_ids(state): i64 { return load64(state + KMS_STATE_FIELD_ENC_IDS); }
fn kms_state_min_width(state): i64 { return load32(state + KMS_STATE_FIELD_MIN_WIDTH); }
fn kms_state_max_width(state): i64 { return load32(state + KMS_STATE_FIELD_MAX_WIDTH); }
fn kms_state_min_height(state): i64 { return load32(state + KMS_STATE_FIELD_MIN_HEIGHT); }
fn kms_state_max_height(state): i64 { return load32(state + KMS_STATE_FIELD_MAX_HEIGHT); }

# ================================================================
# v3 Step 7.1(c) — Encoder ioctl + DRM_MODE_ENCODER_* enum
# ================================================================
# drm_mode_get_encoder layout (20 bytes, x86_64):
#   +0:  encoder_id      (u32) — IN: encoder to query; OUT: same
#   +4:  encoder_type    (u32) — OUT: DRM_MODE_ENCODER_*
#   +8:  crtc_id         (u32) — OUT: currently bound CRTC, 0 if free
#   +12: possible_crtcs  (u32) — OUT: bitmask of usable CRTCs
#   +16: possible_clones (u32) — OUT: bitmask of clonable encoders
var DRM_MODE_GET_ENCODER_SIZE       = 20;
var DRM_MODE_GET_ENCODER_ID         = 0;
var DRM_MODE_GET_ENCODER_TYPE       = 4;
var DRM_MODE_GET_ENCODER_CRTC_ID    = 8;
var DRM_MODE_GET_ENCODER_POSS_CRTCS = 12;
var DRM_MODE_GET_ENCODER_POSS_CLONES = 16;

# Encoder-type enum (uapi/drm/drm_mode.h DRM_MODE_ENCODER_*).
# DAC/TMDS/LVDS cover the legacy / desktop / laptop common cases;
# VIRTUAL/DSI/DPMST/DPI cover modern ARM + DP-MST setups.
var DRM_MODE_ENCODER_NONE    = 0;
var DRM_MODE_ENCODER_DAC     = 1;
var DRM_MODE_ENCODER_TMDS    = 2;
var DRM_MODE_ENCODER_LVDS    = 3;
var DRM_MODE_ENCODER_TVDAC   = 4;
var DRM_MODE_ENCODER_VIRTUAL = 5;
var DRM_MODE_ENCODER_DSI     = 6;
var DRM_MODE_ENCODER_DPMST   = 7;
var DRM_MODE_ENCODER_DPI     = 8;

# Low-level GetEncoder ioctl. Caller owns `req` (20 bytes), MUST
# set encoder_id at +0 before calling. Returns 0 on success,
# negative errno on failure.
fn native_drm_mode_get_encoder(fd, req): i64 {
    return syscall(SYS_IOCTL, fd, DRM_IOCTL_MODE_GETENCODER, req);
}

# ================================================================
# Type-name lookup helpers (cstr return)
# ================================================================
# Tables are inline if/elif chains rather than data tables — keeps
# the module pure-Cyrius (no string-table runtime), and keeps the
# call sites simple. The fallback "?" string ensures any new value
# added by a future kernel surfaces visibly in summary output.

fn native_drm_connector_type_name(t): i64 {
    if (t == DRM_MODE_CONNECTOR_Unknown)     { return "Unknown"; }
    if (t == DRM_MODE_CONNECTOR_VGA)         { return "VGA"; }
    if (t == DRM_MODE_CONNECTOR_DVII)        { return "DVI-I"; }
    if (t == DRM_MODE_CONNECTOR_DVID)        { return "DVI-D"; }
    if (t == DRM_MODE_CONNECTOR_DVIA)        { return "DVI-A"; }
    if (t == DRM_MODE_CONNECTOR_DisplayPort) { return "DP"; }
    if (t == DRM_MODE_CONNECTOR_HDMIA)       { return "HDMI-A"; }
    if (t == DRM_MODE_CONNECTOR_HDMIB)       { return "HDMI-B"; }
    if (t == DRM_MODE_CONNECTOR_eDP)         { return "eDP"; }
    if (t == DRM_MODE_CONNECTOR_VIRTUAL)     { return "Virtual"; }
    if (t == DRM_MODE_CONNECTOR_DSI)         { return "DSI"; }
    if (t == DRM_MODE_CONNECTOR_USB)         { return "USB-C"; }
    return "?";
}

fn native_drm_encoder_type_name(t): i64 {
    if (t == DRM_MODE_ENCODER_NONE)    { return "None"; }
    if (t == DRM_MODE_ENCODER_DAC)     { return "DAC"; }
    if (t == DRM_MODE_ENCODER_TMDS)    { return "TMDS"; }
    if (t == DRM_MODE_ENCODER_LVDS)    { return "LVDS"; }
    if (t == DRM_MODE_ENCODER_TVDAC)   { return "TVDAC"; }
    if (t == DRM_MODE_ENCODER_VIRTUAL) { return "Virtual"; }
    if (t == DRM_MODE_ENCODER_DSI)     { return "DSI"; }
    if (t == DRM_MODE_ENCODER_DPMST)   { return "DP-MST"; }
    if (t == DRM_MODE_ENCODER_DPI)     { return "DPI"; }
    return "?";
}

fn native_drm_connection_status_name(c): i64 {
    if (c == DRM_MODE_CONNECTED)         { return "connected"; }
    if (c == DRM_MODE_DISCONNECTED)      { return "disconnected"; }
    if (c == DRM_MODE_UNKNOWNCONNECTION) { return "unknown"; }
    return "?";
}

# ================================================================
# native_kms_summary — topology printer (Step 7.1(c))
# ================================================================
# Walks the connector + encoder ID arrays from a populated KmsState
# (Step 7.1(a)) and queries each via the per-resource ioctls
# (7.1(b)/(c) wrappers). Prints one line per connector and one per
# encoder to stdout. HW-gated (ioctl-driven); CPU tests cover the
# data-structure surface in mabda_v3_phase_d.tcyr.
#
# Output shape (one example line per category):
#   conn 95 eDP-1 connected enc 94
#   enc 94 TMDS crtc 73 poss 0x3
#
# Intentionally compact — this is a developer diagnostic, not a
# user-facing UI. The columns are: id, type-name, status (connectors
# only) / current-CRTC + possible-CRTC mask (encoders only).
#
# Returns 0 on full success, negative errno on the first ioctl that
# fails (subsequent connectors / encoders are skipped). Partial
# progress is printed up to the point of failure — useful when
# debugging which connector is misbehaving.
fn native_kms_summary(state): i64 {
    if (state == 0) { return -1; }
    var fd = kms_state_fd(state);
    if (fd <= 0)    { return -1; }

    var conn_count = kms_state_count_conn(state);
    var conn_ids   = kms_state_conn_ids(state);
    var enc_count  = kms_state_count_enc(state);
    var enc_ids    = kms_state_enc_ids(state);

    syscall(1, 1, "kms summary:\n", 13);

    # ---- Connectors ----
    var i = 0;
    var cbuf[80];
    while (i < conn_count) {
        memset(&cbuf, 0, 80);
        store32(&cbuf + DRM_MODE_GET_CONNECTOR_CONN_ID, load32(conn_ids + i * 4));
        var rc = native_drm_mode_get_connector(fd, &cbuf);
        if (rc != 0) { return rc; }
        var conn_id   = load32(&cbuf + DRM_MODE_GET_CONNECTOR_CONN_ID);
        var conn_type = load32(&cbuf + DRM_MODE_GET_CONNECTOR_CONN_TYPE);
        var type_id   = load32(&cbuf + DRM_MODE_GET_CONNECTOR_CONN_TYPE_ID);
        var connection = load32(&cbuf + DRM_MODE_GET_CONNECTOR_CONNECTION);
        var encoder_id = load32(&cbuf + DRM_MODE_GET_CONNECTOR_ENCODER_ID);

        _kms_summary_print_conn(conn_id, conn_type, type_id, connection, encoder_id);
        i = i + 1;
    }

    # ---- Encoders ----
    var j = 0;
    var ebuf[20];
    while (j < enc_count) {
        memset(&ebuf, 0, 20);
        store32(&ebuf + DRM_MODE_GET_ENCODER_ID, load32(enc_ids + j * 4));
        var rc = native_drm_mode_get_encoder(fd, &ebuf);
        if (rc != 0) { return rc; }
        var enc_id    = load32(&ebuf + DRM_MODE_GET_ENCODER_ID);
        var enc_type  = load32(&ebuf + DRM_MODE_GET_ENCODER_TYPE);
        var crtc_id   = load32(&ebuf + DRM_MODE_GET_ENCODER_CRTC_ID);
        var poss_crtcs = load32(&ebuf + DRM_MODE_GET_ENCODER_POSS_CRTCS);

        _kms_summary_print_enc(enc_id, enc_type, crtc_id, poss_crtcs);
        j = j + 1;
    }

    return 0;
}

# Internal printer — kept in the same module so consumers don't pull
# in fmt helpers transitively. Splitting these out as `_`-prefixed
# helpers keeps the main loop in native_kms_summary readable + lets
# the printer logic evolve without churning the loop.
fn _kms_summary_print_conn(id, ctype, type_id, connection, enc_id): i64 {
    syscall(1, 1, "  conn ", 7);
    _kms_summary_print_u32(id);
    syscall(1, 1, " ", 1);
    var name = native_drm_connector_type_name(ctype);
    syscall(1, 1, name, strlen(name));
    syscall(1, 1, "-", 1);
    _kms_summary_print_u32(type_id);
    syscall(1, 1, " ", 1);
    var status = native_drm_connection_status_name(connection);
    syscall(1, 1, status, strlen(status));
    syscall(1, 1, " enc ", 5);
    _kms_summary_print_u32(enc_id);
    syscall(1, 1, "\n", 1);
    return 0;
}

fn _kms_summary_print_enc(id, etype, crtc_id, poss_crtcs): i64 {
    syscall(1, 1, "  enc ", 6);
    _kms_summary_print_u32(id);
    syscall(1, 1, " ", 1);
    var name = native_drm_encoder_type_name(etype);
    syscall(1, 1, name, strlen(name));
    syscall(1, 1, " crtc ", 6);
    _kms_summary_print_u32(crtc_id);
    syscall(1, 1, " poss 0x", 8);
    _kms_summary_print_hex32(poss_crtcs);
    syscall(1, 1, "\n", 1);
    return 0;
}

# Decimal printer — uses fmt_int_buf from lib/fmt to keep the
# call sites concise. Stack-allocated buffer so we don't churn the
# bump allocator on every printed connector / encoder. The buffer
# is 24 bytes to safely hold a 20-digit i64 (max signed i64 is 19
# digits + sign + null) — fmt_int_buf is i64-typed so a max-magnitude
# input would overflow a 16-byte buffer (audit LOW-2). KMS IDs are
# u32 in practice, but the printer is i64-shaped and we don't want
# a future caller to overflow this without an obvious failure.
fn _kms_summary_print_u32(v): i64 {
    var buf[24];
    memset(&buf, 0, 24);
    var n = fmt_int_buf(v, &buf);
    syscall(1, 1, &buf, n);
    return 0;
}

# 8-digit hex u32 printer for the possible-CRTCs bitmask.
fn _kms_summary_print_hex32(v): i64 {
    var digits = "0123456789ABCDEF";
    var buf[8];
    var i = 0;
    while (i < 8) {
        var nibble = (v / (1 << ((7 - i) * 4))) & 0xF;
        store8(&buf + i, load8(digits + nibble));
        i = i + 1;
    }
    syscall(1, 1, &buf, 8);
    return 0;
}

# ================================================================
# v3 Step 7.2(a) — Per-connector mode enumeration + preferred pick
# ================================================================
# Mode-set (7.2 proper) needs to know which mode to set. The kernel
# returns a modes array per connector via the two-call protocol of
# DRM_IOCTL_MODE_GETCONNECTOR. The flag word at modeinfo+32 carries
# the EDID-derived "preferred" hint — picking a mode marked
# PREFERRED matches what the monitor itself recommends, which is
# what radv / wlroots / kwin all do.
#
# DRM_MODE_TYPE_* enum (uapi/drm/drm_mode.h):
#   BUILTIN  = 0x01  (deprecated; never set on modern kernels)
#   CLOCK_C  = 0x02  (deprecated)
#   CRTC_C   = 0x04  (deprecated)
#   PREFERRED = 0x08  (EDID's preferred mode — the load-bearing flag)
#   DEFAULT  = 0x10  (deprecated)
#   USERDEF  = 0x20  (userspace-added via MODE_ADDMODE)
#   DRIVER   = 0x40  (kernel-derived from EDID; typical mode flag)
#
# A modern monitor's modeinfo.type is typically 0x40 (DRIVER) for
# every mode and 0x48 (DRIVER | PREFERRED) for the EDID's
# preferred resolution.
var DRM_MODE_TYPE_BUILTIN   = 0x01;
var DRM_MODE_TYPE_PREFERRED = 0x08;
var DRM_MODE_TYPE_USERDEF   = 0x20;
var DRM_MODE_TYPE_DRIVER    = 0x40;

# Two-call wrapper for the connector's modes array. Pass 1: count-
# only ioctl with all *_ptr=0 to discover count_modes. Pass 2:
# heap-allocate count_modes × DRM_MODE_MODEINFO_SIZE bytes, refill.
# Returns the heap pointer to the modes array on success (caller
# treats as `drm_mode_modeinfo[count_modes]`); returns 0 on failure.
# The count is written to `count_out` (u32) on success.
#
# The connection-status check is the caller's responsibility — a
# disconnected connector still succeeds at the ioctl, just returns
# count_modes=0 (and possibly some old EDID modes the kernel cached).
# Callers wanting "modes from a live connector" filter on
# DRM_MODE_CONNECTED first via native_drm_mode_get_connector.
fn native_kms_get_connector_modes(fd, conn_id, count_out): i64 {
    if (fd <= 0)      { return 0; }
    if (conn_id == 0) { return 0; }
    if (count_out == 0) { return 0; }

    # ---- Pass 1: count-only ----
    var req[80];
    memset(&req, 0, DRM_MODE_GET_CONNECTOR_SIZE);
    store32(&req + DRM_MODE_GET_CONNECTOR_CONN_ID, conn_id);
    var rc = native_drm_mode_get_connector(fd, &req);
    if (rc != 0) { return 0; }

    var count = load32(&req + DRM_MODE_GET_CONNECTOR_COUNT_MODES);
    if (count == 0) {
        store32(count_out, 0);
        return 0;   # no modes — connector probably disconnected
    }

    # ---- Pass 2: fill modes (skip encoders / props for this fn) ----
    var modes = alloc(count * DRM_MODE_MODEINFO_SIZE);
    memset(&req, 0, DRM_MODE_GET_CONNECTOR_SIZE);
    store32(&req + DRM_MODE_GET_CONNECTOR_CONN_ID,     conn_id);
    store64(&req + DRM_MODE_GET_CONNECTOR_MODES_PTR,   modes);
    store32(&req + DRM_MODE_GET_CONNECTOR_COUNT_MODES, count);
    rc = native_drm_mode_get_connector(fd, &req);
    if (rc != 0) {
        store32(count_out, 0);
        return 0;
    }

    # Kernel may report fewer modes if state changed between calls.
    # Truth is the post-fill count, clamped against the pre-fill
    # capacity (audit MED-4 — same TOCTOU defense as
    # native_kms_init: never expose a count larger than the buffer
    # we sized off pass-1).
    var actual = load32(&req + DRM_MODE_GET_CONNECTOR_COUNT_MODES);
    if (actual > count) { actual = count; }
    store32(count_out, actual);
    return modes;
}

# Pick the index of the first mode with the PREFERRED bit set.
# Returns 0 when no preferred mode is found OR when count is 0
# (caller must check count first — a 0 return from a count=0
# array means "nothing valid").
#
# This matches radv's `radv_get_preferred_mode` shape: trust the
# kernel's EDID-derived flag, fall back to mode[0] (which is
# almost always the same as preferred when set, since the kernel
# emits the preferred mode first).
fn native_kms_pick_preferred_mode(modes_ptr, count): i64 {
    if (modes_ptr == 0) { return 0; }
    if (count == 0)     { return 0; }
    var i = 0;
    while (i < count) {
        var t = load32(modes_ptr + i * DRM_MODE_MODEINFO_SIZE
        + DRM_MODE_MODEINFO_TYPE);
        if ((t & DRM_MODE_TYPE_PREFERRED) != 0) { return i; }
        i = i + 1;
    }
    return 0;
}

# Read mode dimensions out of a modes_ptr[idx] entry. Useful both
# for the diagnostic and for callers that want to size a
# framebuffer to match (Step 7.3). Returns 0 on null / out-of-range.
fn native_kms_mode_hdisplay(modes_ptr, idx): i64 {
    if (modes_ptr == 0) { return 0; }
    return load16(modes_ptr + idx * DRM_MODE_MODEINFO_SIZE
    + DRM_MODE_MODEINFO_HDISPLAY);
}

fn native_kms_mode_vdisplay(modes_ptr, idx): i64 {
    if (modes_ptr == 0) { return 0; }
    return load16(modes_ptr + idx * DRM_MODE_MODEINFO_SIZE
    + DRM_MODE_MODEINFO_VDISPLAY);
}

fn native_kms_mode_vrefresh(modes_ptr, idx): i64 {
    if (modes_ptr == 0) { return 0; }
    return load32(modes_ptr + idx * DRM_MODE_MODEINFO_SIZE
    + DRM_MODE_MODEINFO_VREFRESH);
}

fn native_kms_mode_type(modes_ptr, idx): i64 {
    if (modes_ptr == 0) { return 0; }
    return load32(modes_ptr + idx * DRM_MODE_MODEINFO_SIZE
    + DRM_MODE_MODEINFO_TYPE);
}

# Compute refresh rate in Hz from clock + h/vtotal. The kernel's
# vrefresh field is unreliable on modern kernels (often returned
# as 0); libdrm computes it the same way:
#   Hz = clock_kHz × 1000 / (htotal × vtotal)
# Returns 0 for null modes_ptr or zero divisor.
fn native_kms_mode_refresh_hz(modes_ptr, idx): i64 {
    if (modes_ptr == 0) { return 0; }
    var base   = modes_ptr + idx * DRM_MODE_MODEINFO_SIZE;
    var clock  = load32(base + DRM_MODE_MODEINFO_CLOCK);
    var htotal = load16(base + DRM_MODE_MODEINFO_HTOTAL);
    var vtotal = load16(base + DRM_MODE_MODEINFO_VTOTAL);
    if (htotal == 0) { return 0; }
    if (vtotal == 0) { return 0; }
    return (clock * 1000) / (htotal * vtotal);
}

# ================================================================
# v3 Step 7.3 — KMS framebuffer (ADDFB2 + RMFB)
# ================================================================
# A KMS framebuffer is a kernel-side handle that wraps a GEM BO
# with metadata the display engine needs to scan it out: width /
# height in pixels, pixel format (DRM_FORMAT_*), per-plane row
# pitch, per-plane offset into the BO, and an optional tiling
# modifier. The FB ID returned by ADDFB2 is what
# DRM_IOCTL_MODE_SETCRTC (Step 7.2(b)) takes as input.
#
# AddFB2 vs the legacy AddFB: AddFB2 takes a fourcc pixel_format
# directly + supports up to 4 planes (YUV) + supports modifiers
# (tiling). Single-plane RGB scanout uses planes[0] only and
# modifier=0 (linear).

# DRM_IOCTL_MODE_ADDFB2 — nr 0xB8, RW, sizeof(drm_mode_fb_cmd2) = 100
#   0xC0000000 | (100 << 16) | (0x64 << 8) | 0xB8 == 0xC06464B8
var DRM_IOCTL_MODE_ADDFB2 = 0xC06464B8;

# DRM_IOCTL_MODE_RMFB — nr 0xAF, RW, sizeof(u32) = 4
#   0xC0000000 | (4 << 16) | (0x64 << 8) | 0xAF == 0xC00464AF
# The "request" is just a u32 fb_id by value (write-only from
# userspace to kernel). Same RW-encoding ceremony as ADDFB2.
var DRM_IOCTL_MODE_RMFB = 0xC00464AF;

# DRM_FORMAT_* fourcc codes (uapi/drm/drm_fourcc.h). Each is a
# 4-character ASCII tag stored as a little-endian u32. The naming
# describes the *MSB-first byte order* of a single 32-bit pixel —
# so DRM_FORMAT_XRGB8888 means a 32-bit word where the MSByte is
# 'x' (ignored alpha) and the LSByte is 'B'. In LITTLE-ENDIAN
# memory that pixel reads as `B G R x` (bytes 0..3) — which is
# what's commonly called BGRX8 or BGRA8.
#
# Mapping for mabda's wgpu-parity color formats:
#   wgpu RGBA8_UNORM (memory: R G B A)  ↔  DRM_FORMAT_ABGR8888
#   wgpu BGRA8_UNORM (memory: B G R A)  ↔  DRM_FORMAT_ARGB8888
# v3 Phase D scans out from RGBA8 BOs (matches the render path's
# RT format), so ABGR8888 is the working format. XRGB / XBGR are
# also exposed for opaque scanout where alpha is don't-care.
var DRM_FORMAT_XRGB8888 = 0x34325258;   # 'X' 'R' '2' '4'
var DRM_FORMAT_ARGB8888 = 0x34325241;   # 'A' 'R' '2' '4'
var DRM_FORMAT_XBGR8888 = 0x34324258;   # 'X' 'B' '2' '4'
var DRM_FORMAT_ABGR8888 = 0x34324241;   # 'A' 'B' '2' '4'

# drm_mode_fb_cmd2 layout (100 bytes, x86_64):
#   +0:  fb_id          (u32) — OUT (kernel returns FB ID)
#   +4:  width          (u32) — IN
#   +8:  height         (u32) — IN
#   +12: pixel_format   (u32) — IN (DRM_FORMAT_*)
#   +16: flags          (u32) — IN
#   +20: handles[4]     (u32 × 4 = 16 B) — IN, plane GEM handles
#   +36: pitches[4]     (u32 × 4 = 16 B) — IN, bytes per row per plane
#   +52: offsets[4]     (u32 × 4 = 16 B) — IN, BO byte offset per plane
#   +68: modifier[4]    (u64 × 4 = 32 B) — IN, tiling modifier per plane
var DRM_MODE_FB_CMD2_SIZE      = 100;
var DRM_MODE_FB_CMD2_FB_ID     = 0;
var DRM_MODE_FB_CMD2_WIDTH     = 4;
var DRM_MODE_FB_CMD2_HEIGHT    = 8;
var DRM_MODE_FB_CMD2_FORMAT    = 12;
var DRM_MODE_FB_CMD2_FLAGS     = 16;
var DRM_MODE_FB_CMD2_HANDLES   = 20;
var DRM_MODE_FB_CMD2_PITCHES   = 36;
var DRM_MODE_FB_CMD2_OFFSETS   = 52;
var DRM_MODE_FB_CMD2_MODIFIERS = 68;

# Linear (untiled) tiling modifier — value 0 in uapi/drm/drm_fourcc.h.
# Pre-2018 kernels infer linear from "no MODIFIERS flag set"; modern
# kernels accept an explicit 0 modifier as linear. We expose it
# here for clarity at call sites.
var DRM_FORMAT_MOD_LINEAR = 0;

# Low-level AddFB2 ioctl. Caller owns `req` (100 bytes), MUST fill
# width/height/format/handles/pitches/offsets/modifiers/flags
# before calling. fb_id at +0 is OUT (overwritten on success).
# Returns 0 on success (req+0 holds the new FB ID), negative errno
# on failure.
fn native_drm_mode_add_fb2(fd, req): i64 {
    return syscall(SYS_IOCTL, fd, DRM_IOCTL_MODE_ADDFB2, req);
}

# Low-level RmFB ioctl. The kernel takes a `u32 fb_id` BY VALUE,
# but Linux's ioctl ABI passes args by pointer — so we pass a
# 4-byte buffer holding the FB ID. Returns 0 on success, negative
# errno on failure.
fn native_drm_mode_rm_fb(fd, fb_id_ptr): i64 {
    return syscall(SYS_IOCTL, fd, DRM_IOCTL_MODE_RMFB, fb_id_ptr);
}

# High-level: wrap a GEM BO as a single-plane XRGB8888 framebuffer.
# Returns the FB ID on success (always > 0; the kernel rejects 0
# as a valid FB ID), or 0 on failure. `pitch` is bytes per row —
# usually `width * 4` for tightly-packed XRGB8888, but the
# scanout path may require alignment to a hardware-specific stride
# (handled by the consumer; this fn just forwards what's given).
#
# `bo_handle` MUST come from the same fd as this fn is called on
# (the kernel verifies). Use the card-master fd for both
# native_bo_create_gtt and this call.
fn native_kms_add_fb_xrgb8888(fd, bo_handle, width, height, pitch): i64 {
    if (fd <= 0)        { return 0; }
    if (bo_handle == 0) { return 0; }
    if (width <= 0)     { return 0; }
    if (height <= 0)    { return 0; }
    if (pitch <= 0)     { return 0; }

    var req[100];
    memset(&req, 0, DRM_MODE_FB_CMD2_SIZE);
    store32(&req + DRM_MODE_FB_CMD2_WIDTH,           width);
    store32(&req + DRM_MODE_FB_CMD2_HEIGHT,          height);
    store32(&req + DRM_MODE_FB_CMD2_FORMAT,          DRM_FORMAT_XRGB8888);
    store32(&req + DRM_MODE_FB_CMD2_FLAGS,           0);
    store32(&req + DRM_MODE_FB_CMD2_HANDLES + 0,     bo_handle);
    store32(&req + DRM_MODE_FB_CMD2_PITCHES + 0,     pitch);
    store32(&req + DRM_MODE_FB_CMD2_OFFSETS + 0,     0);
    store64(&req + DRM_MODE_FB_CMD2_MODIFIERS + 0,   DRM_FORMAT_MOD_LINEAR);
    var rc = native_drm_mode_add_fb2(fd, &req);
    if (rc != 0) { return 0; }
    return load32(&req + DRM_MODE_FB_CMD2_FB_ID);
}

# Release a framebuffer ID. fb_id == 0 is a no-op (matches the
# convention native_kms_add_fb_xrgb8888 uses for failure). Returns
# 0 on success, negative errno on failure.
fn native_kms_rm_fb(fd, fb_id): i64 {
    if (fd <= 0)    { return 0; }
    if (fb_id == 0) { return 0; }
    var id_buf[4];
    store32(&id_buf, fb_id);
    return native_drm_mode_rm_fb(fd, &id_buf);
}

# ================================================================
# v3 Step 7.2(b) — SETCRTC primitive
# ================================================================
# `DRM_IOCTL_MODE_SETCRTC` is the ioctl that actually flips the
# display: it binds (CRTC, framebuffer, mode, connector list) all
# at once. Disabling a CRTC is the same ioctl with fb_id=0 +
# mode_valid=0 + count_connectors=0 — the kernel interprets that as
# "stop scanning out from this CRTC" and may power down the
# associated encoder + connector to save power.
#
# Cross-fd note: the kernel verifies that fb_id refers to a
# framebuffer registered on THIS fd. A framebuffer added on the
# master fd is only valid for SETCRTC on the same fd. BO + FB +
# SETCRTC must all be reachable through one master fd — see
# the PRIME bridge (next step) for how a render-fd BO becomes a
# master-fd FB.
#
# Permission note: SETCRTC requires DRM master. On a running
# desktop session the compositor (Hyprland / GNOME / KDE) holds
# master, so this ioctl returns EACCES from a non-master client.
# To exercise it from a userspace client, vt-switch to a tty
# (the previous master drops automatically) or use
# `DRM_IOCTL_SET_MASTER` after the compositor releases.

# DRM_IOCTL_MODE_SETCRTC — nr 0xA2, RW, sizeof(drm_mode_crtc) = 104
#   0xC0000000 | (104 << 16) | (0x64 << 8) | 0xA2 == 0xC06864A2
var DRM_IOCTL_MODE_SETCRTC = 0xC06864A2;

# drm_mode_crtc layout (104 bytes, x86_64). The mode field is a
# drm_mode_modeinfo embedded in-place at +36 — caller can either
# fill it directly or memcpy from a modes array entry returned by
# native_kms_get_connector_modes.
#
#   +0:  set_connectors_ptr  (u64) — IN: ptr to u32[count_connectors]
#   +8:  count_connectors    (u32) — IN: number of connectors to bind
#   +12: crtc_id             (u32) — IN: CRTC to configure
#   +16: fb_id               (u32) — IN: framebuffer to scan out, 0 = blank
#   +20: x                   (u32) — IN: x offset within FB
#   +24: y                   (u32) — IN: y offset within FB
#   +28: gamma_size          (u32) — OUT (not used in v3 setup path)
#   +32: mode_valid          (u32) — IN: 1 = use mode, 0 = disable
#   +36: mode                (drm_mode_modeinfo, 68 B) — IN if mode_valid
var DRM_MODE_CRTC_SIZE             = 104;
var DRM_MODE_CRTC_CONN_PTR         = 0;
var DRM_MODE_CRTC_COUNT_CONN       = 8;
var DRM_MODE_CRTC_CRTC_ID          = 12;
var DRM_MODE_CRTC_FB_ID            = 16;
var DRM_MODE_CRTC_X                = 20;
var DRM_MODE_CRTC_Y                = 24;
var DRM_MODE_CRTC_GAMMA_SIZE       = 28;
var DRM_MODE_CRTC_MODE_VALID       = 32;
var DRM_MODE_CRTC_MODE             = 36;

# Low-level SETCRTC ioctl. Caller owns `req` (104 bytes), MUST fill
# crtc_id + fb_id + connector_ptr/count + mode_valid + mode (or
# zeros for disable). Returns 0 on success, negative errno on
# failure (typically -EACCES for "not master", -EINVAL for "bad
# CRTC / FB / mode combination").
fn native_drm_mode_set_crtc(fd, req): i64 {
    return syscall(SYS_IOCTL, fd, DRM_IOCTL_MODE_SETCRTC, req);
}

# High-level SETCRTC. `mode_ptr` points to a 68-byte
# drm_mode_modeinfo (typically picked from the array returned by
# native_kms_get_connector_modes via native_kms_pick_preferred_mode).
# `conn_ids_ptr` is a u32 array of connector IDs to bind to this
# CRTC; `conn_count` is its length. Scan-out region defaults to
# (0, 0) — the FB's top-left becomes the screen's top-left.
#
# Returns 0 on success, negative errno on failure. Null-safe on
# every pointer arg.
fn native_kms_set_crtc(fd, crtc_id, fb_id, conn_ids_ptr, conn_count, mode_ptr): i64 {
    if (fd <= 0)         { return -1; }
    if (crtc_id == 0)    { return -1; }
    if (fb_id == 0)      { return -1; }
    if (conn_ids_ptr == 0) { return -1; }
    if (conn_count <= 0) { return -1; }
    if (mode_ptr == 0)   { return -1; }

    var req[104];
    memset(&req, 0, DRM_MODE_CRTC_SIZE);
    store64(&req + DRM_MODE_CRTC_CONN_PTR,    conn_ids_ptr);
    store32(&req + DRM_MODE_CRTC_COUNT_CONN,  conn_count);
    store32(&req + DRM_MODE_CRTC_CRTC_ID,     crtc_id);
    store32(&req + DRM_MODE_CRTC_FB_ID,       fb_id);
    store32(&req + DRM_MODE_CRTC_MODE_VALID,  1);
    memcpy(&req + DRM_MODE_CRTC_MODE, mode_ptr, DRM_MODE_MODEINFO_SIZE);
    return native_drm_mode_set_crtc(fd, &req);
}

# Convenience: disable a CRTC. Same ioctl as native_kms_set_crtc
# but with fb_id=0 + mode_valid=0 + connector list empty — the
# kernel interprets the combination as "stop scanout."
# Useful for clean teardown after a present session, and for
# probing CRTC accessibility (a successful disable on an idle
# CRTC proves master + CRTC ID are valid).
fn native_kms_disable_crtc(fd, crtc_id): i64 {
    if (fd <= 0)      { return -1; }
    if (crtc_id == 0) { return -1; }
    var req[104];
    memset(&req, 0, DRM_MODE_CRTC_SIZE);
    store32(&req + DRM_MODE_CRTC_CRTC_ID, crtc_id);
    # All other fields (fb_id, mode_valid, conn ptr/count) stay 0.
    return native_drm_mode_set_crtc(fd, &req);
}

# ================================================================
# v3 Step 7.2(c) — PRIME cross-fd BO bridge
# ================================================================
# DRM PRIME exports a GEM BO from one fd's handle namespace as a
# kernel-level dmabuf fd, which can then be re-imported on another
# fd as a fresh handle. The two ends become independent handles
# pointing at the same underlying memory; closing one does NOT
# affect the other.
#
# Why we need this: KMS ioctls (AddFB2, SETCRTC) live on the master
# fd (`/dev/dri/cardN`). The AMDGPU GEM allocator
# (`native_bo_create_gtt`) typically runs on the render fd
# (`/dev/dri/renderD128`) — that's the convention Mesa / radv
# established for unprivileged GEM access. Bridging the two
# requires PRIME.
#
# Direction matters:
#   render_fd → HANDLE_TO_FD → dmabuf_fd → FD_TO_HANDLE → card_fd
# The transient dmabuf fd is a regular Linux file descriptor; close
# it after the second ioctl. Both render_fd's handle and card_fd's
# handle remain valid independently and need separate GEM_CLOSE
# calls when the consumer is done.
#
# Reference: drivers/gpu/drm/drm_prime.c.

# struct drm_prime_handle (12 bytes, x86_64):
#   +0: handle  (u32) — IN for HANDLE_TO_FD, OUT for FD_TO_HANDLE
#   +4: flags   (u32) — IN: DRM_CLOEXEC | DRM_RDWR (HANDLE_TO_FD only)
#   +8: fd      (s32) — OUT for HANDLE_TO_FD, IN for FD_TO_HANDLE
var DRM_PRIME_HANDLE_SIZE   = 12;
var DRM_PRIME_HANDLE_HANDLE = 0;
var DRM_PRIME_HANDLE_FLAGS  = 4;
var DRM_PRIME_HANDLE_FD     = 8;

# DRM_IOCTL_PRIME_HANDLE_TO_FD — nr 0x2D, RW, sizeof = 12
#   0xC0000000 | (12 << 16) | (0x64 << 8) | 0x2D == 0xC00C642D
var DRM_IOCTL_PRIME_HANDLE_TO_FD = 0xC00C642D;

# DRM_IOCTL_PRIME_FD_TO_HANDLE — nr 0x2E, RW, sizeof = 12
#   0xC0000000 | (12 << 16) | (0x64 << 8) | 0x2E == 0xC00C642E
var DRM_IOCTL_PRIME_FD_TO_HANDLE = 0xC00C642E;

# Flags for HANDLE_TO_FD — these mirror the open(2) flags of the
# resulting dmabuf fd. CLOEXEC is essentially mandatory (otherwise
# fork+exec leaks the handle); RDWR is needed if the importer
# wants write access (always true for KMS scanout BOs).
var DRM_CLOEXEC = 0x80000;     # O_CLOEXEC
var DRM_RDWR    = 0x2;         # O_RDWR

# Low-level HANDLE_TO_FD ioctl. Caller fills handle + flags at
# +0/+4; on success, fd is at +8. Returns 0 on success, negative
# errno on failure.
fn native_drm_prime_handle_to_fd(fd, req): i64 {
    return syscall(SYS_IOCTL, fd, DRM_IOCTL_PRIME_HANDLE_TO_FD, req);
}

# Low-level FD_TO_HANDLE ioctl. Caller fills fd at +8; on success,
# handle is at +0. Returns 0 on success, negative errno on failure.
fn native_drm_prime_fd_to_handle(fd, req): i64 {
    return syscall(SYS_IOCTL, fd, DRM_IOCTL_PRIME_FD_TO_HANDLE, req);
}

# Pick the lowest set bit of a u32 bitmask. Returns 0..31 for the
# bit index, or -1 if no bit is set. Used to find the first
# usable CRTC from an encoder's `possible_crtcs` mask.
fn native_kms_lowest_set_bit(mask): i64 {
    var i = 0;
    while (i < 32) {
        if (((mask / (1 << i)) & 1) == 1) { return i; }
        i = i + 1;
    }
    return -1;
}

# High-level: bridge a BO from `render_fd`'s handle namespace into
# `card_fd`'s. Returns the new card-fd handle on success, or 0 on
# failure. The transient dmabuf fd is closed before return — the
# caller only needs to track the two fd handles.
#
# Caller is responsible for closing both handles when done:
#   native_gem_close(render_fd, render_handle);
#   native_gem_close(card_fd,   card_handle);
fn native_kms_import_bo(card_fd, render_fd, render_handle): i64 {
    if (card_fd <= 0)      { return 0; }
    if (render_fd <= 0)    { return 0; }
    if (render_handle == 0) { return 0; }

    # ---- Step 1: HANDLE_TO_FD on render_fd ----
    var exp_req[12];
    memset(&exp_req, 0, DRM_PRIME_HANDLE_SIZE);
    store32(&exp_req + DRM_PRIME_HANDLE_HANDLE, render_handle);
    store32(&exp_req + DRM_PRIME_HANDLE_FLAGS,  DRM_CLOEXEC | DRM_RDWR);
    var rc = native_drm_prime_handle_to_fd(render_fd, &exp_req);
    if (rc != 0) { return 0; }
    var dmabuf_fd = load32(&exp_req + DRM_PRIME_HANDLE_FD);
    if (dmabuf_fd < 0) { return 0; }

    # ---- Step 2: FD_TO_HANDLE on card_fd ----
    var imp_req[12];
    memset(&imp_req, 0, DRM_PRIME_HANDLE_SIZE);
    store32(&imp_req + DRM_PRIME_HANDLE_FD, dmabuf_fd);
    rc = native_drm_prime_fd_to_handle(card_fd, &imp_req);

    # Close the transient dmabuf fd in BOTH branches — the kernel
    # bumped its refcount when FD_TO_HANDLE succeeded (via the
    # underlying dmabuf object), and on failure we never want to
    # leak the fd anyway.
    sys_close(dmabuf_fd);

    if (rc != 0) { return 0; }
    return load32(&imp_req + DRM_PRIME_HANDLE_HANDLE);
}

# ================================================================
# v3 Step 7.2(d) — End-to-end modeset driver
# ================================================================
# Composes everything from 7.1 + 7.2(a/b/c) + 7.3 into a single
# call: walk the discovered topology, find a connected connector,
# pick its preferred mode, alloc a render-fd BO sized to the mode,
# bridge it via PRIME, AddFB2 it, SETCRTC. The result is a live
# scanout — running the smoke program from a tty makes the screen
# turn red (the FB content) until release.
#
# Failure modes worth knowing about:
#   - SETCRTC returns -EACCES → not master. Run from a tty
#     (Ctrl-Alt-F2 drops the running compositor's master) and
#     systemd-logind will hand master to the new process via the
#     vt-active mechanism.
#   - SETCRTC returns -EINVAL → mode/CRTC/encoder mismatch. The
#     algorithm picks "lowest bit of possible_crtcs", which always
#     yields a valid CRTC for the encoder per kernel guarantees.
#     If we still see EINVAL, suspect mode struct corruption
#     (memcpy from the wrong offset, etc.).
#   - SETCRTC returns -EBUSY → CRTC already in use. Disable the
#     conflicting CRTC first (native_kms_disable_crtc) or pick
#     a different bit from possible_crtcs.

# NativeKmsScanout layout (40 bytes) — bag of resources to track
# for clean teardown after a successful modeset.
#   +0:  conn_id        (u32) — bound connector
#   +4:  crtc_id        (u32) — bound CRTC
#   +8:  fb_id          (u32) — kernel framebuffer ID (master fd)
#   +12: card_handle    (u32) — BO's master-fd handle (PRIME-imported)
#   +16: render_handle  (u32) — BO's render-fd handle (allocator-side)
#   +20: width          (u32) — pixels
#   +24: mapped_addr    (u64) — CPU-visible mmap of the BO bytes
#   +32: height         (u32) — pixels
#   +36: bo_size        (u32) — bytes; for native_bo_release_gtt
var NATIVE_KMS_SCANOUT_SIZE         = 40;
var NATIVE_KMS_SCANOUT_CONN_ID      = 0;
var NATIVE_KMS_SCANOUT_CRTC_ID      = 4;
var NATIVE_KMS_SCANOUT_FB_ID        = 8;
var NATIVE_KMS_SCANOUT_CARD_HANDLE  = 12;
var NATIVE_KMS_SCANOUT_RENDER_HANDLE = 16;
var NATIVE_KMS_SCANOUT_WIDTH        = 20;
var NATIVE_KMS_SCANOUT_MAPPED_ADDR  = 24;
var NATIVE_KMS_SCANOUT_HEIGHT       = 32;
var NATIVE_KMS_SCANOUT_BO_SIZE      = 36;

# Drive the full modeset on the first connected connector found.
# Caller provides:
#   card_fd    — master fd opened on /dev/dri/cardN
#   render_fd  — opened on /dev/dri/renderD128
#   state      — populated KmsState from native_kms_init(card_fd)
#   out        — caller-allocated 40-byte NativeKmsScanout
# On success returns 0 and `out` is populated; on failure returns
# negative and `out` is not guaranteed valid (caller should not
# release).
fn native_kms_modeset_first_connected(card_fd, render_fd, state, out): i64 {
    if (card_fd <= 0)   { return -1; }
    if (render_fd <= 0) { return -1; }
    if (state == 0)     { return -1; }
    if (out == 0)       { return -1; }
    memset(out, 0, NATIVE_KMS_SCANOUT_SIZE);

    var conn_count = kms_state_count_conn(state);
    var conn_ids   = kms_state_conn_ids(state);
    var crtc_count = kms_state_count_crtcs(state);
    var crtc_ids   = kms_state_crtc_ids(state);

    # ---- Step A: walk connectors, find first CONNECTED ----
    var i = 0;
    var conn_id = 0;
    var encoder_id = 0;
    var meta[80];
    while (i < conn_count) {
        var cid = load32(conn_ids + i * 4);
        memset(&meta, 0, DRM_MODE_GET_CONNECTOR_SIZE);
        store32(&meta + DRM_MODE_GET_CONNECTOR_CONN_ID, cid);
        if (native_drm_mode_get_connector(card_fd, &meta) == 0) {
            var status = load32(&meta + DRM_MODE_GET_CONNECTOR_CONNECTION);
            if (status == DRM_MODE_CONNECTED) {
                conn_id = cid;
                encoder_id = load32(&meta + DRM_MODE_GET_CONNECTOR_ENCODER_ID);
                i = conn_count;   # break
            }
        }
        i = i + 1;
    }
    if (conn_id == 0) { return -2; }   # no connected connector

    # ---- Step B: get encoder, pick CRTC from possible_crtcs ----
    # If the connector reports encoder_id == 0 (connected but not
    # currently bound), fall back to the connector's first usable
    # encoder via the encoders_ptr array — Step 7.1(c) coverage.
    # For v2-native simplicity, require an existing encoder_id.
    if (encoder_id == 0) { return -3; }
    var enc_req[20];
    memset(&enc_req, 0, DRM_MODE_GET_ENCODER_SIZE);
    store32(&enc_req + DRM_MODE_GET_ENCODER_ID, encoder_id);
    if (native_drm_mode_get_encoder(card_fd, &enc_req) != 0) { return -4; }
    var possible_crtcs = load32(&enc_req + DRM_MODE_GET_ENCODER_POSS_CRTCS);
    var crtc_idx = native_kms_lowest_set_bit(possible_crtcs);
    if (crtc_idx < 0)            { return -5; }
    if (crtc_idx >= crtc_count)  { return -5; }
    var crtc_id = load32(crtc_ids + crtc_idx * 4);

    # ---- Step C: get connector modes, pick preferred ----
    var modes_count[4];
    store32(&modes_count, 0);
    var modes = native_kms_get_connector_modes(card_fd, conn_id, &modes_count);
    if (modes == 0) { return -6; }
    var n_modes = load32(&modes_count);
    if (n_modes == 0) { return -6; }
    var mode_idx = native_kms_pick_preferred_mode(modes, n_modes);
    var width  = native_kms_mode_hdisplay(modes, mode_idx);
    var height = native_kms_mode_vdisplay(modes, mode_idx);

    # ---- Step D: allocate render-fd BO sized to mode ----
    # Pitch rounded up to 256-byte alignment (AMD scanout requires it
    # on most Vega-era hardware; pre-Vega is more permissive but the
    # alignment never hurts). Audit MED-2: cap dims + guard the
    # pitch/bo_size arithmetic via the shared validator. EDID-fed
    # modes from sane monitors land well inside the 16384/2 GiB caps,
    # but a malicious or corrupted EDID could push us into overflow
    # territory — so validate here, before we allocate.
    var pitch_buf[8];
    var bo_size_buf[8];
    if (_kms_validate_fb_dims(width, height, &pitch_buf, &bo_size_buf) != 0) {
        return -7;
    }
    var pitch   = load64(&pitch_buf);
    var bo_size = load64(&bo_size_buf);
    var bo_buf[16];
    var rc_bo = native_bo_create_gtt(render_fd, bo_size, &bo_buf);
    if (rc_bo != 0) { return -8; }
    var render_handle = load64(&bo_buf + 0);
    var mapped_addr   = load64(&bo_buf + 8);

    # ---- Step E: PRIME-import to card-fd handle namespace ----
    var card_handle = native_kms_import_bo(card_fd, render_fd, render_handle);
    if (card_handle == 0) {
        native_bo_release_gtt(render_fd, render_handle, mapped_addr, bo_size);
        return -9;
    }

    # ---- Step F: AddFB2 ----
    var fb_id = native_kms_add_fb_xrgb8888(card_fd, card_handle,
    width, height, pitch);
    if (fb_id == 0) {
        native_gem_close(card_fd, card_handle);
        native_bo_release_gtt(render_fd, render_handle, mapped_addr, bo_size);
        return -10;
    }

    # ---- Step G: SETCRTC ----
    # Connector list is a single u32 holding `conn_id`. The mode
    # ptr indexes into the modes array we got in Step C — the
    # array sticks around until the modes pointer is freed (which
    # we don't do here; the bump allocator outlives this call).
    var conn_list[4];
    store32(&conn_list, conn_id);
    var mode_ptr = modes + mode_idx * DRM_MODE_MODEINFO_SIZE;
    var rc = native_kms_set_crtc(card_fd, crtc_id, fb_id,
    &conn_list, 1, mode_ptr);
    if (rc != 0) {
        native_kms_rm_fb(card_fd, fb_id);
        native_gem_close(card_fd, card_handle);
        native_bo_release_gtt(render_fd, render_handle, mapped_addr, bo_size);
        return -11;
    }

    # Success — populate the scanout bag.
    store32(out + NATIVE_KMS_SCANOUT_CONN_ID,       conn_id);
    store32(out + NATIVE_KMS_SCANOUT_CRTC_ID,       crtc_id);
    store32(out + NATIVE_KMS_SCANOUT_FB_ID,         fb_id);
    store32(out + NATIVE_KMS_SCANOUT_CARD_HANDLE,   card_handle);
    store32(out + NATIVE_KMS_SCANOUT_RENDER_HANDLE, render_handle);
    store32(out + NATIVE_KMS_SCANOUT_WIDTH,         width);
    store32(out + NATIVE_KMS_SCANOUT_HEIGHT,        height);
    store32(out + NATIVE_KMS_SCANOUT_BO_SIZE,       bo_size);
    store64(out + NATIVE_KMS_SCANOUT_MAPPED_ADDR,   mapped_addr);
    return 0;
}

# Tear down a successful scanout. Disables the CRTC, removes the
# FB, closes both fd handles, unmaps the BO. Idempotent on a
# zeroed scanout struct (each zero check skips its release).
# Returns 0.
fn native_kms_release_scanout(card_fd, render_fd, scanout): i64 {
    if (scanout == 0) { return 0; }
    var crtc_id       = load32(scanout + NATIVE_KMS_SCANOUT_CRTC_ID);
    var fb_id         = load32(scanout + NATIVE_KMS_SCANOUT_FB_ID);
    var card_handle   = load32(scanout + NATIVE_KMS_SCANOUT_CARD_HANDLE);
    var render_handle = load32(scanout + NATIVE_KMS_SCANOUT_RENDER_HANDLE);
    var mapped_addr   = load64(scanout + NATIVE_KMS_SCANOUT_MAPPED_ADDR);
    var bo_size       = load32(scanout + NATIVE_KMS_SCANOUT_BO_SIZE);

    if (card_fd > 0) {
        if (crtc_id != 0)     { native_kms_disable_crtc(card_fd, crtc_id); }
        if (fb_id != 0)       { native_kms_rm_fb(card_fd, fb_id); }
        if (card_handle != 0) { native_gem_close(card_fd, card_handle); }
    }
    if (render_fd > 0) {
        if (render_handle != 0) {
            native_bo_release_gtt(render_fd, render_handle,
            mapped_addr, bo_size);
        }
    }
    memset(scanout, 0, NATIVE_KMS_SCANOUT_SIZE);
    return 0;
}

# ================================================================
# v3 Step 7.4 — Page-flip + event read
# ================================================================
# Page-flip swaps which framebuffer a CRTC scans out from, without
# re-doing the full modeset (which would blank the screen briefly).
# It's the load-bearing primitive for double-buffered present:
# render to FB B while FB A is on screen, then page-flip A→B at
# vblank, then render to A while B scans out, repeat.
#
# Two variants of the flip behavior, controlled by `flags`:
#   DRM_MODE_PAGE_FLIP_EVENT — kernel queues a vblank event; the
#     fd becomes readable, and a 32-byte drm_event_vblank lands in
#     the read queue when the flip actually happens. Used for
#     present-time reporting and for stuttering-detection.
#   DRM_MODE_PAGE_FLIP_ASYNC — flip immediately, don't wait for
#     vblank. Causes tearing; not what consumers want for v3.0
#     present, but useful for testing.
# Default (flags=0) = "synchronous, no event" — kernel still waits
# for vblank but caller doesn't get notified.
#
# Event-read path: after a flip with EVENT flag set, read(2) on
# the drm fd yields a drm_event header (8 B) followed by the
# specific event payload. For vblank events the payload is
# drm_event_vblank (32 B total including the header).

# DRM_IOCTL_MODE_PAGE_FLIP — nr 0xB0, RW, sizeof = 24
#   0xC0000000 | (24 << 16) | (0x64 << 8) | 0xB0 == 0xC01864B0
var DRM_IOCTL_MODE_PAGE_FLIP = 0xC01864B0;

# Page-flip flag constants (uapi/drm/drm_mode.h):
var DRM_MODE_PAGE_FLIP_EVENT = 0x01;
var DRM_MODE_PAGE_FLIP_ASYNC = 0x02;

# drm_mode_crtc_page_flip layout (24 bytes, x86_64):
#   +0:  crtc_id    (u32) — IN
#   +4:  fb_id      (u32) — IN: framebuffer to swap to
#   +8:  flags      (u32) — IN
#   +12: reserved   (u32) — must be 0
#   +16: user_data  (u64) — IN: opaque value returned in the event
var DRM_MODE_PAGE_FLIP_SIZE      = 24;
var DRM_MODE_PAGE_FLIP_CRTC_ID   = 0;
var DRM_MODE_PAGE_FLIP_FB_ID     = 4;
var DRM_MODE_PAGE_FLIP_FLAGS     = 8;
var DRM_MODE_PAGE_FLIP_RESERVED  = 12;
var DRM_MODE_PAGE_FLIP_USER_DATA = 16;

# Low-level page-flip ioctl. Caller fills crtc_id + fb_id + flags
# (+ user_data if EVENT flag set). Returns 0 on success, negative
# errno on failure. Common errors:
#   -EBUSY    — a previous flip is still pending on this CRTC
#               (haven't received the vblank event yet)
#   -EINVAL   — fb dimensions don't match CRTC's current mode
#   -EACCES   — not master (Phase D pre-requisite — see logind
#               note in memory)
fn native_drm_mode_page_flip(fd, req): i64 {
    return syscall(SYS_IOCTL, fd, DRM_IOCTL_MODE_PAGE_FLIP, req);
}

# High-level page-flip. user_data is opaque — the kernel echoes it
# back in the event payload, so callers use it to identify which
# flip the event corresponds to (typically a sequence number).
# Returns 0 on success, negative errno on failure.
fn native_kms_page_flip(fd, crtc_id, fb_id, flags, user_data): i64 {
    if (fd <= 0)      { return -1; }
    if (crtc_id == 0) { return -1; }
    if (fb_id == 0)   { return -1; }
    var req[24];
    memset(&req, 0, DRM_MODE_PAGE_FLIP_SIZE);
    store32(&req + DRM_MODE_PAGE_FLIP_CRTC_ID,   crtc_id);
    store32(&req + DRM_MODE_PAGE_FLIP_FB_ID,     fb_id);
    store32(&req + DRM_MODE_PAGE_FLIP_FLAGS,     flags);
    store64(&req + DRM_MODE_PAGE_FLIP_USER_DATA, user_data);
    return native_drm_mode_page_flip(fd, &req);
}

# ================================================================
# DRM event-read path
# ================================================================
# The kernel queues events on the drm fd; userspace drains them
# via read(2). Each event starts with a drm_event header (8 B)
# describing the event type + total length, followed by event-
# type-specific payload. For page-flip events:
#
#   drm_event (8 B):
#     +0: type    (u32) — DRM_EVENT_VBLANK or DRM_EVENT_FLIP_COMPLETE
#     +4: length  (u32) — total bytes including this header
#
#   drm_event_vblank payload (24 B following the header → 32 B total):
#     +8:  user_data  (u64) — the value passed in PAGE_FLIP_USER_DATA
#     +16: tv_sec     (u32) — flip timestamp seconds
#     +20: tv_usec    (u32) — flip timestamp microseconds
#     +24: sequence   (u32) — vblank sequence number
#     +28: crtc_id    (u32) — which CRTC fired (kernel >= 4.x)

var DRM_EVENT_VBLANK         = 0x01;
var DRM_EVENT_FLIP_COMPLETE  = 0x02;

var DRM_EVENT_HEADER_SIZE    = 8;
var DRM_EVENT_HEADER_TYPE    = 0;
var DRM_EVENT_HEADER_LENGTH  = 4;

var DRM_EVENT_VBLANK_SIZE      = 32;
var DRM_EVENT_VBLANK_USER_DATA = 8;
var DRM_EVENT_VBLANK_TV_SEC    = 16;
var DRM_EVENT_VBLANK_TV_USEC   = 20;
var DRM_EVENT_VBLANK_SEQUENCE  = 24;
var DRM_EVENT_VBLANK_CRTC_ID   = 28;

# Read DRM events from the fd. `buf` should be at least 32 bytes
# for a single drm_event_vblank; a larger buffer can hold multiple
# queued events. Returns the number of bytes read (positive),
# 0 if no events available (only with O_NONBLOCK), or negative
# errno on failure. SYS_READ = 0 on x86_64.
fn native_drm_read_event(fd, buf, n): i64 {
    if (fd <= 0)  { return -1; }
    if (buf == 0) { return -1; }
    if (n <= 0)   { return -1; }
    return syscall(0, fd, buf, n);
}

# Convenience accessors for a freshly-read drm_event_vblank.
fn drm_event_type(buf): i64 { return load32(buf + DRM_EVENT_HEADER_TYPE); }
fn drm_event_length(buf): i64 { return load32(buf + DRM_EVENT_HEADER_LENGTH); }
fn drm_event_vblank_user_data(buf): i64 { return load64(buf + DRM_EVENT_VBLANK_USER_DATA); }
fn drm_event_vblank_sequence(buf): i64 { return load32(buf + DRM_EVENT_VBLANK_SEQUENCE); }
fn drm_event_vblank_crtc_id(buf): i64 { return load32(buf + DRM_EVENT_VBLANK_CRTC_ID); }

# ================================================================
# v3 Step 7.5 — Reusable FB alloc + present primitive
# ================================================================
# Step 7.2(d) bundled BO + PRIME + AddFB2 inside the modeset
# driver. For double-buffered present, callers need the SAME
# sequence repeatable for a second (or third) FB without
# re-doing the modeset. native_kms_alloc_fb extracts it.
#
# native_kms_present is the load-bearing primitive: page-flip
# the bound CRTC to a new FB ID, wait for the flip-complete
# vblank event, return the kernel's vblank sequence number.
# Repeating with two FBs (rendering to whichever isn't currently
# scanning out) is the v3.0 vsync-paced present loop.
#
# Caveat (same as 7.2(d)): page-flip returns -EACCES if the fd
# isn't master. See `project_phase_d_master_logind_blocker`
# memory for workaround paths.

# NativeKmsFb layout (32 bytes) — a self-contained "framebuffer +
# its backing BO" bundle. Returned by native_kms_alloc_fb;
# released by native_kms_release_fb.
#
#   +0:  fb_id          (u32) — kernel framebuffer ID (master fd)
#   +4:  card_handle    (u32) — BO's master-fd handle (PRIME-imported)
#   +8:  render_handle  (u32) — BO's render-fd handle (allocator-side)
#   +12: pitch          (u32) — bytes per row (256-byte aligned)
#   +16: mapped_addr    (u64) — CPU-visible mmap of the BO
#   +24: bo_size        (u32) — total BO bytes (= pitch × height)
#   +28: width          (u32) — mode-bound width (height derived from bo_size/pitch)
var NATIVE_KMS_FB_SIZE         = 32;
var NATIVE_KMS_FB_FB_ID        = 0;
var NATIVE_KMS_FB_CARD_HANDLE  = 4;
var NATIVE_KMS_FB_RENDER_HANDLE = 8;
var NATIVE_KMS_FB_PITCH        = 12;
var NATIVE_KMS_FB_MAPPED_ADDR  = 16;
var NATIVE_KMS_FB_BO_SIZE      = 24;
var NATIVE_KMS_FB_WIDTH        = 28;

# Audit MED-2 — caller-supplied dimension bounds.
#
# Every consumer-facing path that ends up calling AddFB2 (native
# scanout) flows width/height in from outside (modeset picks them
# from EDID, alloc_fb takes them as args). Without bounds, a
# pathological mode or a mistaken caller could push (width × 4)
# into i32-overflow territory or push the backing BO size past the
# kernel's u32 caps on pitches[0] / total FB bytes. The kernel
# would reject the ioctl, but only AFTER we'd done a multi-MiB BO
# allocation we then have to release.
#
# Caps:
#   - 16384 per dim — WebGPU's MAX_TEXTURE_DIMENSION_2D, which is
#     also the practical scanout limit on the AMD HW we target
#     (Vega/RDNA1 max single-pipe).
#   - 0x80000000 (2 GiB) per BO — strictly under both 2^31 (signed
#     i32 wrap point that could trip up future arithmetic) and the
#     kernel's u32 cap on pitches[0] / total FB bytes.
#
# 16384 × 16384 XRGB8888 with 256-aligned pitch = 1 GiB exactly,
# so the 2 GiB BO cap is never reachable from valid (w, h) pairs;
# it's defense-in-depth in case the per-dim caps relax later.
var MABDA_KMS_MAX_FB_DIM       = 16384;
var MABDA_KMS_MAX_FB_BYTES     = 0x80000000;
var MABDA_KMS_PITCH_ALIGN_MASK = 255;

# Validate (width, height) and compute the 256-byte-aligned pitch
# + bo_size. Writes pitch and bo_size into the i64-sized out-params
# on success. Returns 0 on success, -1 on rejection.
fn _kms_validate_fb_dims(width, height, pitch_out, bo_size_out): i64 {
    if (pitch_out == 0)            { return -1; }
    if (bo_size_out == 0)          { return -1; }
    if (width <= 0)                { return -1; }
    if (height <= 0)               { return -1; }
    if (width > MABDA_KMS_MAX_FB_DIM)  { return -1; }
    if (height > MABDA_KMS_MAX_FB_DIM) { return -1; }
    var pitch_raw = width * 4;
    var pitch = ((pitch_raw + MABDA_KMS_PITCH_ALIGN_MASK) / 256) * 256;
    var bo_size = pitch * height;
    if (bo_size > MABDA_KMS_MAX_FB_BYTES) { return -1; }
    store64(pitch_out, pitch);
    store64(bo_size_out, bo_size);
    return 0;
}

# Allocate a render-fd BO sized for `(width × height)` XRGB8888,
# PRIME-import to the master fd, AddFB2 it, and populate `out`.
# Pitch is rounded up to 256-byte alignment (AMD scanout requires;
# matches native_kms_modeset_first_connected). Returns 0 on success
# or a negative step code on failure (matches the modeset driver's
# step-code convention so consumers can map errors uniformly).
fn native_kms_alloc_fb(card_fd, render_fd, width, height, out): i64 {
    if (card_fd <= 0)   { return -1; }
    if (render_fd <= 0) { return -1; }
    if (out == 0)       { return -1; }
    memset(out, 0, NATIVE_KMS_FB_SIZE);

    # Audit MED-2: cap caller-supplied dimensions + guard arithmetic.
    var pitch_buf[8];
    var bo_size_buf[8];
    if (_kms_validate_fb_dims(width, height, &pitch_buf, &bo_size_buf) != 0) {
        return -1;
    }
    var pitch   = load64(&pitch_buf);
    var bo_size = load64(&bo_size_buf);

    var bo_buf[16];
    var rc_bo = native_bo_create_gtt(render_fd, bo_size, &bo_buf);
    if (rc_bo != 0) { return -8; }
    var render_handle = load64(&bo_buf + 0);
    var mapped_addr   = load64(&bo_buf + 8);

    var card_handle = native_kms_import_bo(card_fd, render_fd, render_handle);
    if (card_handle == 0) {
        native_bo_release_gtt(render_fd, render_handle, mapped_addr, bo_size);
        return -9;
    }

    var fb_id = native_kms_add_fb_xrgb8888(card_fd, card_handle,
    width, height, pitch);
    if (fb_id == 0) {
        native_gem_close(card_fd, card_handle);
        native_bo_release_gtt(render_fd, render_handle, mapped_addr, bo_size);
        return -10;
    }

    store32(out + NATIVE_KMS_FB_FB_ID,         fb_id);
    store32(out + NATIVE_KMS_FB_CARD_HANDLE,   card_handle);
    store32(out + NATIVE_KMS_FB_RENDER_HANDLE, render_handle);
    store32(out + NATIVE_KMS_FB_PITCH,         pitch);
    store64(out + NATIVE_KMS_FB_MAPPED_ADDR,   mapped_addr);
    store32(out + NATIVE_KMS_FB_BO_SIZE,       bo_size);
    store32(out + NATIVE_KMS_FB_WIDTH,         width);
    return 0;
}

# Release a NativeKmsFb. Idempotent on a zeroed fb (every release
# call short-circuits on its zero check). Returns 0.
fn native_kms_release_fb(card_fd, render_fd, fb): i64 {
    if (fb == 0) { return 0; }
    var fb_id         = load32(fb + NATIVE_KMS_FB_FB_ID);
    var card_handle   = load32(fb + NATIVE_KMS_FB_CARD_HANDLE);
    var render_handle = load32(fb + NATIVE_KMS_FB_RENDER_HANDLE);
    var mapped_addr   = load64(fb + NATIVE_KMS_FB_MAPPED_ADDR);
    var bo_size       = load32(fb + NATIVE_KMS_FB_BO_SIZE);
    if (card_fd > 0) {
        if (fb_id != 0)       { native_kms_rm_fb(card_fd, fb_id); }
        if (card_handle != 0) { native_gem_close(card_fd, card_handle); }
    }
    if (render_fd > 0) {
        if (render_handle != 0) {
            native_bo_release_gtt(render_fd, render_handle,
            mapped_addr, bo_size);
        }
    }
    memset(fb, 0, NATIVE_KMS_FB_SIZE);
    return 0;
}

# Page-flip a scanout's CRTC to a new FB and block until the
# kernel reports flip-complete. Updates scanout.fb_id to the new
# value on success so subsequent presents target the right CRTC
# state. If `sequence_out` is non-null, writes the kernel's
# vblank sequence number there — useful for present-time
# tracking and stutter detection.
#
# Return codes:
#    0  — flip completed, scanout updated
#   -1  — invalid args
#   <0 — propagated kernel errno from page-flip ioctl OR from
#        the read(2) on the event fd OR `-2` if read returned
#        fewer bytes than a drm_event_vblank OR `-3` if the
#        event we drained wasn't FLIP_COMPLETE (could happen
#        if some other queued event lives in the read queue;
#        v3.0 single-flip path doesn't expect that, but the
#        diagnostic value is worth the rc).
#
# Caveat: this is the simplest possible single-flip + blocking-
# read shape. A real present loop would either (a) use a
# non-blocking read with poll/epoll on the fd, or (b) batch
# multiple events. v3.0 keeps this simple; consumers needing
# more sophisticated event handling can call native_kms_page_flip
# + native_drm_read_event directly.
fn native_kms_present(card_fd, scanout, new_fb_id, sequence_out): i64 {
    if (card_fd <= 0)   { return -1; }
    if (scanout == 0)   { return -1; }
    if (new_fb_id == 0) { return -1; }

    var crtc_id = load32(scanout + NATIVE_KMS_SCANOUT_CRTC_ID);
    if (crtc_id == 0) { return -1; }

    # User_data carries the new FB ID — convenient echo for any
    # caller that wants to verify the event matches the flip.
    var rc = native_kms_page_flip(card_fd, crtc_id, new_fb_id,
    DRM_MODE_PAGE_FLIP_EVENT,
    new_fb_id);
    if (rc != 0) { return rc; }

    # Audit MED-6 (2026-04-30): drain events until FLIP_COMPLETE
    # found. The kernel may queue multiple events per flip
    # (DRM_EVENT_VBLANK + DRM_EVENT_FLIP_COMPLETE on most kernels);
    # the prior single-event read returned -3 on the second present
    # because the stale VBLANK landed at offset 0. Walk every event
    # in each buffer using the header `length` field, then re-read
    # if FLIP_COMPLETE wasn't in this batch. 256-byte read buffer
    # easily holds 8+ events. Cap the outer reads at 16 to prevent
    # any pathological event-spew from spinning the present loop
    # forever (16 * 8 events = 128 events drained before bail-out).
    var buf[256];
    var found = 0;
    var seq = 0;
    var attempts = 0;
    while (found == 0) {
        if (attempts >= 16) { return 0 - 2; }   # too many events drained, bail
        attempts = attempts + 1;
        memset(&buf, 0, 256);
        var n = native_drm_read_event(card_fd, &buf, 256);
        if (n < 0) { return n; }
        if (n < DRM_EVENT_VBLANK_SIZE) { return 0 - 2; }
        # walk events in this read
        var off = 0;
        while (off < n) {
            var ev_len = drm_event_length(&buf + off);
            if (ev_len <= 0) { return 0 - 3; }   # malformed header, can't advance
            if (off + ev_len > n) { return 0 - 3; }   # length past read end
            var ev_type = drm_event_type(&buf + off);
            if (ev_type == DRM_EVENT_FLIP_COMPLETE) {
                seq = drm_event_vblank_sequence(&buf + off);
                found = 1;
                off = n;   # exit inner loop
            }
            if (found == 0) { off = off + ev_len; }
        }
    }

    # Update scanout's bound FB so subsequent operations have the
    # right state.
    store32(scanout + NATIVE_KMS_SCANOUT_FB_ID, new_fb_id);

    if (sequence_out != 0) {
        store32(sequence_out, seq);
    }
    return 0;
}

# --- buffer.cyr ---

# @public — stable API surface (survives the v3.0 backend swap)
# buffer.cyr — GPU buffer management
# Ported from mabda/src/buffer.rs
#
# Buffer creation helpers, readback, and GrowableBuffer.
# All functions use wgpu FFI function table.

# ================================================================
# Buffer creation helpers
# ================================================================

# Create a storage buffer with initial data
fn create_storage_buffer(device, queue, data, size, label): i64 {
    var usage = WGPU_BUFFER_USAGE_STORAGE | WGPU_BUFFER_USAGE_COPY_DST | WGPU_BUFFER_USAGE_COPY_SRC;
    var desc = wgpu_buffer_descriptor(label, usage, size, 0);
    var buf = wgpu_device_create_buffer(device, desc);
    if (buf != 0) {
        wgpu_queue_write_buffer(queue, buf, 0, data, size);
    }
    return buf;
}

# Create an empty storage buffer (for compute output)
fn create_storage_buffer_empty(device, size, label): i64 {
    var usage = WGPU_BUFFER_USAGE_STORAGE | WGPU_BUFFER_USAGE_COPY_DST | WGPU_BUFFER_USAGE_COPY_SRC;
    var desc = wgpu_buffer_descriptor(label, usage, size, 0);
    return wgpu_device_create_buffer(device, desc);
}

# Create a uniform buffer with initial data
fn create_uniform_buffer(device, queue, data, size, label): i64 {
    var usage = WGPU_BUFFER_USAGE_UNIFORM | WGPU_BUFFER_USAGE_COPY_DST;
    var desc = wgpu_buffer_descriptor(label, usage, size, 0);
    var buf = wgpu_device_create_buffer(device, desc);
    if (buf != 0) {
        wgpu_queue_write_buffer(queue, buf, 0, data, size);
    }
    return buf;
}

# Create a staging buffer for CPU readback
fn create_staging_buffer(device, size, label): i64 {
    var usage = WGPU_BUFFER_USAGE_MAP_READ | WGPU_BUFFER_USAGE_COPY_DST;
    var desc = wgpu_buffer_descriptor(label, usage, size, 0);
    return wgpu_device_create_buffer(device, desc);
}

# Create a vertex buffer with initial data
fn create_vertex_buffer(device, queue, data, size, label): i64 {
    var usage = WGPU_BUFFER_USAGE_VERTEX | WGPU_BUFFER_USAGE_COPY_DST;
    var desc = wgpu_buffer_descriptor(label, usage, size, 0);
    var buf = wgpu_device_create_buffer(device, desc);
    if (buf != 0) {
        wgpu_queue_write_buffer(queue, buf, 0, data, size);
    }
    return buf;
}

# Create an index buffer with initial data
fn create_index_buffer(device, queue, data, size, label): i64 {
    var usage = WGPU_BUFFER_USAGE_INDEX | WGPU_BUFFER_USAGE_COPY_DST;
    var desc = wgpu_buffer_descriptor(label, usage, size, 0);
    var buf = wgpu_device_create_buffer(device, desc);
    if (buf != 0) {
        wgpu_queue_write_buffer(queue, buf, 0, data, size);
    }
    return buf;
}

# Create an indirect dispatch buffer
fn create_dispatch_indirect_buffer(device, queue, data, size, label): i64 {
    var usage = WGPU_BUFFER_USAGE_INDIRECT | WGPU_BUFFER_USAGE_COPY_DST;
    var desc = wgpu_buffer_descriptor(label, usage, size, 0);
    var buf = wgpu_device_create_buffer(device, desc);
    if (buf != 0) {
        wgpu_queue_write_buffer(queue, buf, 0, data, size);
    }
    return buf;
}

# ================================================================
# Synchronous buffer readback
# ================================================================

# Default cap: 256 MB. Matches the WebGPU `maxStorageBufferBindingSize`
# default. Caller can use `read_buffer_capped(..., max_bytes)` to override.
var READ_BUFFER_DEFAULT_CAP = 268435456;

# Read buffer contents synchronously, with a 256 MB cap.
# Returns pointer to copied data (heap-allocated) or 0 on failure
# (zero/negative size, size exceeding cap, or size exceeding the
# source buffer's allocated capacity).
fn read_buffer(device, queue, buffer, size): i64 {
    return read_buffer_capped(device, queue, buffer, size, READ_BUFFER_DEFAULT_CAP);
}

# Read buffer with an explicit max-bytes cap. See audit LOW-2.
# Bounds:
#   size > 0
#   size <= max_bytes
#   size <= wgpu_buffer_get_size(buffer)
# Any failure returns 0 without allocating staging or host memory.
fn read_buffer_capped(device, queue, buffer, size, max_bytes): i64 {
    if (size <= 0)         { return 0; }
    if (size > max_bytes)  { return 0; }
    var src_size = wgpu_buffer_get_size(buffer);
    if (size > src_size)   { return 0; }

    # Create staging buffer
    var staging = create_staging_buffer(device, size, "readback_staging");
    if (staging == 0) { return 0; }

    # Copy buffer → staging
    var encoder = wgpu_device_create_command_encoder(device, "readback_enc");
    wgpu_command_encoder_copy_buffer_to_buffer(encoder, buffer, 0, staging, 0, size);
    var cmd_buf = wgpu_command_encoder_finish(encoder, "readback_cmd");
    wgpu_queue_submit_one(queue, cmd_buf);

    # Map and copy
    var status = wgpu_buffer_map_sync(device, staging, WGPU_MAP_MODE_READ, 0, size);
    if (status != WGPU_BUFFER_MAP_ASYNC_STATUS_SUCCESS) {
        wgpu_buffer_release(staging);
        return 0;
    }

    var mapped = wgpu_buffer_get_const_mapped_range(staging, 0, size);
    if (mapped == 0) {
        wgpu_buffer_unmap(staging);
        wgpu_buffer_release(staging);
        return 0;
    }

    # Copy to heap
    var result = alloc(size);
    memcpy(result, mapped, size);

    wgpu_buffer_unmap(staging);
    wgpu_buffer_release(staging);
    return result;
}

# ================================================================
# v3 Step 3c — ctx-aware buffer read (dispatches through backend)
# ================================================================
# Public v3-shape API per docs/proposals/v3-native-api-principles.md:
# every operation that takes a ctx routes through ctx->backend->slot.
# This fn validates the buffer_read slot flow end-to-end.
#
# Reads n bytes starting at off from buf into the caller-allocated
# ptr. Returns 0 on success or a GPU_ERR_* code. Does not allocate.
#
# Coexists with the legacy read_buffer / read_buffer_capped above,
# which take (device, queue, buffer, size) and return an alloc-and-
# fill heap pointer. Those stay for v2.x consumer compatibility and
# retire alongside the v3.x→v5.1 buffer-name shim retirement.

fn gpu_buffer_read(ctx, buf, off, ptr, n): i64 {
    if (ctx == 0) { return GPU_ERR_BUFFER; }
    var slot = backend_get_slot(gpu_ctx_backend(ctx),
    BACKEND_SLOT_BUFFER_READ);
    return fncall5(slot, ctx, buf, off, ptr, n);
}

# Allocate a GPU buffer of `size` bytes with the given usage flags.
# Returns the backend handle (an opaque u64); 0 on failure.
fn gpu_buffer_create(ctx, size, usage): i64 {
    if (ctx == 0) { return 0; }
    var slot = backend_get_slot(gpu_ctx_backend(ctx),
    BACKEND_SLOT_BUFFER_CREATE);
    return fncall3(slot, ctx, size, usage);
}

# Write n bytes from ptr into buf at off. Returns 0 on success.
fn gpu_buffer_write(ctx, buf, off, ptr, n): i64 {
    if (ctx == 0) { return GPU_ERR_BUFFER; }
    var slot = backend_get_slot(gpu_ctx_backend(ctx),
    BACKEND_SLOT_BUFFER_WRITE);
    return fncall5(slot, ctx, buf, off, ptr, n);
}

# Release a GPU buffer obtained from gpu_buffer_create. Returns 0.
fn gpu_buffer_release(ctx, buf): i64 {
    if (ctx == 0) { return 0; }
    var slot = backend_get_slot(gpu_ctx_backend(ctx),
    BACKEND_SLOT_BUFFER_RELEASE);
    return fncall2(slot, ctx, buf);
}

# v3.2 X.5 — copy `bytes` from src_buf to dst_buf on an implicit
# TRANSFER queue (native: the SDMA ring; wgpu: the single device
# queue). Synchronous: blocks until the copy retires, so dst is
# readable on return. Resolves the transfer queue, then routes through
# the buffer_copy backend slot. Returns 0 on success or a GPU_ERR_*
# code (GPU_ERR_NOT_IMPLEMENTED if the active backend has no filler  #skip-lint
# wired yet). See also gpu_queue_transfer_copy for an explicit queue.
fn gpu_buffer_copy(ctx, src_buf, dst_buf, bytes): i64 {
    if (ctx == 0) { return GPU_ERR_BUFFER; }
    # WebGPU's copy_buffer_to_buffer requires a 4-byte-multiple size; the
    # native SDMA path is byte-granular. Reject sub-DWORD sizes uniformly
    # so a portable copy behaves identically on both backends (audit
    # 2026-06-15 HIGH-1) rather than succeeding on native + faulting on wgpu.
    if ((bytes & 3) != 0) { return GPU_ERR_BUFFER; }
    var q = gpu_queue_get(ctx, QUEUE_KIND_TRANSFER);
    if (q == 0) { return GPU_ERR_OTHER; }
    var slot = backend_get_slot(gpu_ctx_backend(ctx),
    BACKEND_SLOT_BUFFER_COPY);
    if (slot == 0) { return GPU_ERR_NOT_IMPLEMENTED; }  #skip-lint
    return fncall5(slot, ctx, q, src_buf, dst_buf, bytes);
}

# ================================================================
# GrowableBuffer — dynamic GPU buffer with generation tracking
# ================================================================
#
# GrowableBuffer struct layout (32 bytes):
#   +0: buffer     (WGPUBuffer handle, 8)
#   +8: capacity   (i64, bytes)
#   +16: generation (i64, incremented on growth — invalidates bind groups)
#   +24: usage      (i64, WGPUBufferUsage flags)

fn growable_buffer_new(device, initial_capacity, usage): i64 {
    var gb = alloc(32);
    var desc = wgpu_buffer_descriptor("growable", usage, initial_capacity, 0);
    var buf = wgpu_device_create_buffer(device, desc);
    store64(gb, buf);
    store64(gb + 8, initial_capacity);
    store64(gb + 16, 0);
    store64(gb + 24, usage);
    return gb;
}

fn growable_buffer_handle(gb): i64 { return load64(gb); }
fn growable_buffer_capacity(gb): i64 { return load64(gb + 8); }
fn growable_buffer_generation(gb): i64 { return load64(gb + 16); }

# Update buffer contents — grows if needed, returns 1 if grown (bind group invalidated)
fn growable_buffer_update(gb, device, queue, data, size): i64 {
    var cap = load64(gb + 8);
    var grew = 0;
    if (size > cap) {
        # Grow to 2x or size, whichever is larger. The `new_cap < cap`
        # check catches signed-i64 overflow when cap approaches the
        # i64 boundary — without it, the doubling wraps to a negative
        # number and `size > new_cap` takes the wrong branch (audit MED-2).
        var new_cap = cap * 2;
        if (new_cap < cap) { new_cap = size; }
        if (size > new_cap) { new_cap = size; }
        # Release old buffer
        var old = load64(gb);
        if (old != 0) { wgpu_buffer_release(old); }
        # Create new
        var usage = load64(gb + 24);
        var desc = wgpu_buffer_descriptor("growable", usage, new_cap, 0);
        var new_buf = wgpu_device_create_buffer(device, desc);
        store64(gb, new_buf);
        store64(gb + 8, new_cap);
        store64(gb + 16, load64(gb + 16) + 1);  # increment generation
        grew = 1;
    }
    wgpu_queue_write_buffer(queue, load64(gb), 0, data, size);
    return grew;
}

# ================================================================
# Compute workgroup helpers (pure math, no GPU)
# ================================================================

# Calculate workgroup count for 1D dispatch
# Returns ceil(total / workgroup_size), or 0 if workgroup_size is 0.
# The 0 guard avoids SIGFPE when a caller passes a mis-configured workgroup
# size pulled from a shader config — see audit MED-1.
fn workgroups_1d(total, workgroup_size): i64 {
    if (workgroup_size == 0) { return 0; }
    return (total + workgroup_size - 1) / workgroup_size;
}

# Calculate workgroup count for 2D dispatch
# Returns (x_groups, y_groups) packed as two i64 at dst; leaves dst zeroed
# on wg_x == 0 or wg_y == 0 (avoids SIGFPE — audit MED-1).
fn workgroups_2d(dst, width, height, wg_x, wg_y): i64 {
    store64(dst, 0);
    store64(dst + 8, 0);
    if (wg_x == 0) { return 0; }
    if (wg_y == 0) { return 0; }
    store64(dst, (width + wg_x - 1) / wg_x);
    store64(dst + 8, (height + wg_y - 1) / wg_y);
    return 0;
}

# Validate dispatch workgroup count against device limits
# Returns 0 if valid, error code if exceeded
fn validate_dispatch(x, y, z, max_per_dim): i64 {
    if (x > max_per_dim) { return GPU_ERR_WORKGROUP_LIMIT; }
    if (y > max_per_dim) { return GPU_ERR_WORKGROUP_LIMIT; }
    if (z > max_per_dim) { return GPU_ERR_WORKGROUP_LIMIT; }
    return 0;
}

# --- typed_buffer.cyr ---

# @public — stable API surface (survives the v3.0 backend swap)
# typed_buffer.cyr — Typed GPU buffer wrappers with runtime alignment checks
# Ported from mabda/src/typed_buffer.rs
#
# Cyrius has no generics; the Rust `UniformBuffer<T>` / `StorageBuffer<T>`
# collapse to runtime-sized wrappers that carry capacity/count information
# alongside the wgpu handle. Alignment validation happens at construction.
#
# For raw byte-level control without the wrapper overhead, use the functions
# in buffer.cyr directly.
#
# UniformBuffer struct layout (16 bytes):
#   +0: handle  (WGPUBuffer, 8)
#   +8: size    (i64, bytes — always a multiple of 16)
#
# StorageBuffer struct layout (32 bytes):
#   +0:  handle        (WGPUBuffer, 8)
#   +8:  capacity      (i64, bytes)
#   +16: count         (i64, element count)
#   +24: element_size  (i64, bytes per element)
#
# ABI note: all functions in this file cap the parameter list at 6 to avoid
# Cyrius's parameter-passing issue when a 7+-arg function also makes wgpu
# fncalls. See feedback_fncall6_wgpu memory for the related fncall6 issue.

# ================================================================
# UniformBuffer
# ================================================================

# Create a uniform buffer initialized with `data`. Returns a GpuResult:
#   Ok(ub_ptr) on success
#   Err(gpu_err(...)) if size is zero or not a multiple of 16
#
# Enforces WebGPU's minUniformBufferOffsetAlignment = 16.
fn uniform_buffer_new(device, queue, data, size, label): i64 {
    if (size == 0) {
        return gpu_err_result_msg(GPU_ERR_BUFFER, "uniform buffer size is zero");
    }
    # size % 16 == 0 via bitwise AND since 16 is a power of two
    if ((size & 15) != 0) {
        return gpu_err_result_msg(GPU_ERR_BUFFER, "uniform buffer size must be multiple of 16");
    }
    var handle = create_uniform_buffer(device, queue, data, size, label);
    if (handle == 0) {
        return gpu_err_result_msg(GPU_ERR_BUFFER, "wgpuDeviceCreateBuffer returned null");
    }
    var ub = alloc(16);
    store64(ub, handle);
    store64(ub + 8, size);
    return gpu_ok(ub);
}

# Write new data to the uniform buffer. Caller must pass the same size as
# was used at creation; writes of a different size are undefined behavior.
fn uniform_buffer_write(queue, ub, data, size): i64 {
    wgpu_queue_write_buffer(queue, load64(ub), 0, data, size);
    return 0;
}

# Accessors
fn uniform_buffer_handle(ub): i64 { return load64(ub); }
fn uniform_buffer_size(ub): i64 { return load64(ub + 8); }

# Release the underlying GPU buffer. The struct itself is bump-allocated
# and collected with the rest of the arena.
fn uniform_buffer_release(ub): i64 {
    var h = load64(ub);
    if (h != 0) { wgpu_buffer_release(h); }
    store64(ub, 0);
    return 0;
}

# ================================================================
# StorageBuffer
# ================================================================

fn _storage_usage(read_only): i64 {
    if (read_only == 0) {
        return WGPU_BUFFER_USAGE_STORAGE | WGPU_BUFFER_USAGE_COPY_DST | WGPU_BUFFER_USAGE_COPY_SRC;
    }
    return WGPU_BUFFER_USAGE_STORAGE | WGPU_BUFFER_USAGE_COPY_DST;
}

# Create a raw storage buffer handle. Does not track count or element size
# — use storage_buffer_wrap if you need metadata on top of this handle.
fn storage_buffer_create(device, capacity, label, read_only): i64 {
    var usage = _storage_usage(read_only);
    var desc = wgpu_buffer_descriptor(label, usage, capacity, 0);
    return wgpu_device_create_buffer(device, desc);
}

# Wrap a raw buffer handle with element-count metadata. The wrapper zero-
# initialises element_size to 1 when count * element_size would overflow
# or exceed capacity — see audit MED-5. Callers that need the unchecked
# byte-oriented path can use storage_buffer_wrap_raw.
fn storage_buffer_wrap(handle, capacity, count, element_size): i64 {
    var sb = alloc(32);
    store64(sb, handle);
    store64(sb + 8, capacity);
    store64(sb + 16, count);
    # Consistency: count * element_size must fit in i64 and not exceed capacity.
    if (element_size <= 0) {
        store64(sb + 24, 1);
    } else {
        var max_count = 0x7FFFFFFFFFFFFFFF / element_size;
        if (count > max_count) {
            store64(sb + 24, 1);
        } else {
            var required = count * element_size;
            if (required > capacity) {
                store64(sb + 24, 1);
            } else {
                store64(sb + 24, element_size);
            }
        }
    }
    return sb;
}

# Unchecked wrap — byte-oriented view on top of an already-validated handle.
# Internal convenience for storage_buffer_new / _empty. Do not expose this as
# a general-purpose entry point; the checked storage_buffer_wrap is preferred.
fn storage_buffer_wrap_raw(handle, capacity, count, element_size): i64 {
    var sb = alloc(32);
    store64(sb, handle);
    store64(sb + 8, capacity);
    store64(sb + 16, count);
    store64(sb + 24, element_size);
    return sb;
}

# Convenience: create a storage buffer initialized with `data`.
# 6 parameters max (Cyrius ABI ceiling — see header comment).
# The caller folds (count × element_size) into `capacity` before calling.
# Element metadata on the returned wrapper is set to a byte-oriented view
# (count = capacity, element_size = 1). Callers who need richer metadata
# should use storage_buffer_create + storage_buffer_wrap directly.
fn storage_buffer_new(device, queue, data, capacity, label, read_only): i64 {
    var handle = storage_buffer_create(device, capacity, label, read_only);
    if (handle != 0) {
        wgpu_queue_write_buffer(queue, handle, 0, data, capacity);
    }
    return storage_buffer_wrap_raw(handle, capacity, capacity, 1);
}

# Convenience: create an empty storage buffer of the given byte capacity.
fn storage_buffer_empty(device, capacity, label, read_only): i64 {
    var handle = storage_buffer_create(device, capacity, label, read_only);
    return storage_buffer_wrap_raw(handle, capacity, capacity, 1);
}

# Write `write_count` elements into the storage buffer. Returns a GpuResult:
#   Ok(0)          on success
#   Err(...)       if write_count > stored count (exceeds capacity)
#   Err(...)       if write_count * element_size would overflow i64 (audit MED-4)
fn storage_buffer_write(queue, sb, data, write_count): i64 {
    var capacity_count = load64(sb + 16);
    if (write_count > capacity_count) {
        return gpu_err_result_msg(GPU_ERR_BUFFER, "storage buffer write exceeds capacity");
    }
    var element_size = load64(sb + 24);
    # Overflow guard: write_count * element_size must fit in i64 positive range.
    # 0x7FFFFFFFFFFFFFFF / element_size is the largest safe write_count for this
    # element_size. Skip when element_size is 0 (nothing to write).
    if (element_size != 0) {
        var max_write = 0x7FFFFFFFFFFFFFFF / element_size;
        if (write_count > max_write) {
            return gpu_err_result_msg(GPU_ERR_BUFFER, "storage buffer write size overflow");
        }
    }
    var write_bytes = write_count * element_size;
    wgpu_queue_write_buffer(queue, load64(sb), 0, data, write_bytes);
    return gpu_ok(0);
}

# Accessors
fn storage_buffer_handle(sb): i64 { return load64(sb); }
fn storage_buffer_capacity(sb): i64 { return load64(sb + 8); }
fn storage_buffer_count(sb): i64 { return load64(sb + 16); }
fn storage_buffer_element_size(sb): i64 { return load64(sb + 24); }

# Release the underlying GPU buffer.
fn storage_buffer_release(sb): i64 {
    var h = load64(sb);
    if (h != 0) { wgpu_buffer_release(h); }
    store64(sb, 0);
    return 0;
}

# --- gpu_timestamps.cyr ---

# @public — stable API surface (survives the v3.0 backend swap)
# gpu_timestamps.cyr — GPU timestamp query profiling
# Ported from mabda/src/profiler.rs :: GpuTimestamps
#
# Wraps wgpu's QuerySet + resolve buffer + read buffer triple to provide
# per-pass GPU timing. The adapter must support `TIMESTAMP_QUERY` (feature
# code 0x9 in WGPUFeatureName).
#
# GpuTimestamps struct layout (56 bytes):
#   +0:  query_set        (WGPUQuerySet handle, 8)
#   +8:  resolve_buffer   (WGPUBuffer handle, 8)
#   +16: read_buffer      (WGPUBuffer handle, 8)
#   +24: max_queries      (i64, query pair count × 2)
#   +32: timestamp_period_bits (i64, f32 bit-pattern — 1.0f by default)
#   +40: _pad             (8)
#   +48: _pad             (8)

# WGPUQueryType constants (webgpu.h)
enum WGPUQueryType {
    WGPU_QUERY_TYPE_OCCLUSION = 1;
    WGPU_QUERY_TYPE_TIMESTAMP = 2;
}

# WGPUFeatureName::TimestampQuery from webgpu.h
var WGPU_FEATURE_TIMESTAMP_QUERY = 9;

# WGPUBufferUsage::QueryResolve (0x200) — must combine with COPY_SRC
var WGPU_BUFFER_USAGE_QUERY_RESOLVE = 0x200;

# ================================================================
# Adapter feature query
# ================================================================

# Returns 1 if the DEVICE has timestamp queries enabled, 0 otherwise.
# Note: wgpu requires TIMESTAMP_QUERY to be explicitly requested when
# creating the device — an adapter supporting the feature is not enough.
# Check the device, not the adapter.
fn gpu_timestamps_supported(device): i64 {
    if (device == 0) { return 0; }
    return wgpu_device_has_feature(device, WGPU_FEATURE_TIMESTAMP_QUERY);
}

# ================================================================
# Allocation
# ================================================================

# Create GPU timestamp queries. Returns a GpuResult:
#   Ok(ts_ptr)   — on success
#   Err(...)     — if the device doesn't support TIMESTAMP_QUERY
#
# max_passes is the number of query PAIRS (begin + end per pass).
# The query set is sized at max_passes * 2.
fn gpu_timestamps_new(device, queue, max_passes): i64 {
    if (gpu_timestamps_supported(device) == 0) {
        return gpu_err_result_msg(GPU_ERR_OTHER, "device lacks TIMESTAMP_QUERY feature");
    }

    var max_queries = max_passes * 2;

    # 1. Create the query set
    var qs_desc = wgpu_query_set_descriptor("gpu_timestamps",
    WGPU_QUERY_TYPE_TIMESTAMP,
    max_queries);
    var qs = wgpu_device_create_query_set(device, qs_desc);
    if (qs == 0) {
        return gpu_err_result_msg(GPU_ERR_OTHER, "wgpuDeviceCreateQuerySet returned null");
    }

    # 2. Resolve buffer: QUERY_RESOLVE | COPY_SRC, 8 bytes per query
    var buffer_size = max_queries * 8;
    var resolve_usage = WGPU_BUFFER_USAGE_QUERY_RESOLVE | WGPU_BUFFER_USAGE_COPY_SRC;
    var resolve_desc = wgpu_buffer_descriptor("timestamp_resolve",
    resolve_usage, buffer_size, 0);
    var resolve_buffer = wgpu_device_create_buffer(device, resolve_desc);
    # Audit 2026-06-14 [MED-5]: a null buffer handle stored into the
    # wrapper would later be deref'd inside wgpu-native by resolve/map.
    # Fail loudly, releasing the resources already acquired.
    if (resolve_buffer == 0) {
        wgpu_query_set_release(qs);
        return gpu_err_result_msg(GPU_ERR_OTHER, "wgpuDeviceCreateBuffer (timestamp_resolve) returned null");
    }

    # 3. Read buffer: COPY_DST | MAP_READ
    var read_usage = WGPU_BUFFER_USAGE_COPY_DST | WGPU_BUFFER_USAGE_MAP_READ;
    var read_desc = wgpu_buffer_descriptor("timestamp_read",
    read_usage, buffer_size, 0);
    var read_buffer = wgpu_device_create_buffer(device, read_desc);
    if (read_buffer == 0) {
        wgpu_buffer_release(resolve_buffer);
        wgpu_query_set_release(qs);
        return gpu_err_result_msg(GPU_ERR_OTHER, "wgpuDeviceCreateBuffer (timestamp_read) returned null");
    }

    # 4. Record the hardware timestamp period
    var period_bits = wgpu_queue_get_timestamp_period_bits(queue);

    # 5. Build the wrapper struct
    var ts = alloc(56);
    store64(ts + 0,  qs);
    store64(ts + 8,  resolve_buffer);
    store64(ts + 16, read_buffer);
    store64(ts + 24, max_queries);
    store64(ts + 32, period_bits);
    store64(ts + 40, 0);
    store64(ts + 48, 0);
    return gpu_ok(ts);
}

# ================================================================
# Accessors
# ================================================================

fn gpu_timestamps_query_set(ts): i64 { return load64(ts + 0); }
fn gpu_timestamps_resolve_buffer(ts): i64 { return load64(ts + 8); }
fn gpu_timestamps_read_buffer(ts): i64 { return load64(ts + 16); }
fn gpu_timestamps_max_queries(ts): i64 { return load64(ts + 24); }
fn gpu_timestamps_max_passes(ts): i64 { return load64(ts + 24) / 2; }
fn gpu_timestamps_period_bits(ts): i64 { return load64(ts + 32); }

# ================================================================
# Resolve + readback
# ================================================================

# Resolve queries into the resolve buffer and copy to the read buffer.
# Call after all passes with timestamp writes are submitted.
#
# query_count is the number of individual query slots to resolve (not pairs).
fn gpu_timestamps_resolve(ts, encoder, query_count): i64 {
    var max = load64(ts + 24);
    var count = query_count;
    if (count > max) { count = max; }
    # Audit [LOW-6]: a negative count would feed count*8 as a huge u64
    # size to wgpu resolve/copy.
    if (count < 0)   { count = 0; }
    var qs      = load64(ts + 0);
    var resolve = load64(ts + 8);
    var read    = load64(ts + 16);
    wgpu_encoder_resolve_query_set(encoder, qs, 0, count, resolve, 0);
    wgpu_command_encoder_copy_buffer_to_buffer(encoder, resolve, 0, read, 0, count * 8);
    return 0;
}

# Map the read buffer synchronously and return a pointer to the raw u64
# timestamp array. Caller must call gpu_timestamps_unmap when done.
#
# Returns 0 on failure. Call AFTER queue_submit and device_poll so the GPU
# has finished writing the timestamps.
fn gpu_timestamps_map(ts, device, query_count): i64 {
    var max = load64(ts + 24);
    var count = query_count;
    if (count > max) { count = max; }
    if (count < 0)   { count = 0; }   # Audit [LOW-6]: see gpu_timestamps_resolve
    var read = load64(ts + 16);
    var status = wgpu_buffer_map_sync(device, read, WGPU_MAP_MODE_READ, 0, count * 8);
    if (status != WGPU_BUFFER_MAP_ASYNC_STATUS_SUCCESS) {
        return 0;
    }
    return wgpu_buffer_get_const_mapped_range(read, 0, count * 8);
}

fn gpu_timestamps_unmap(ts): i64 {
    wgpu_buffer_unmap(load64(ts + 16));
    return 0;
}

# ================================================================
# Release
# ================================================================

fn gpu_timestamps_release(ts): i64 {
    var qs      = load64(ts + 0);
    var resolve = load64(ts + 8);
    var read    = load64(ts + 16);
    if (qs != 0)      { wgpu_query_set_release(qs); }
    if (resolve != 0) { wgpu_buffer_release(resolve); }
    if (read != 0)    { wgpu_buffer_release(read); }
    store64(ts + 0, 0);
    store64(ts + 8, 0);
    store64(ts + 16, 0);
    return 0;
}

# --- compute.cyr ---

# @public — stable API surface (survives the v3.0 backend swap)
# compute.cyr — compute pipeline creation and dispatch
# Ported from mabda/src/compute.rs
#
# ComputePipeline struct layout (24 bytes):
#   +0: pipeline          (WGPUComputePipeline handle, 8)
#   +8: bind_group_layout (WGPUBindGroupLayout handle, 8)
#   +16: pipeline_layout  (WGPUPipelineLayout handle, 8)

# ================================================================
# ComputePipeline creation
# ================================================================

# Create a compute pipeline with default storage buffer bindings.
# buffer 0 = read-write storage, buffers 1..n = read-only storage.
#
# Failure-path cleanup (audit LOW-5): every wgpu handle allocated
# before a failure is released before the function returns 0, so
# repeated failed creation attempts cannot leak GPU memory.
fn compute_pipeline_new(device, wgsl_source, entry_point, storage_count): i64 {
    if (storage_count <= 0) { return 0; }

    # Build bind group layout entries
    var entries = alloc(storage_count * 120);
    var stage = WGPU_SHADER_STAGE_COMPUTE;
    var rw = WGPU_BUFFER_BINDING_TYPE_STORAGE;
    var ro = WGPU_BUFFER_BINDING_TYPE_READ_ONLY_STORAGE;
    for (var i = 0; i < storage_count; i = i + 1) {
        var e = entries + i * 120;
        memset(e, 0, 120);
        if (i == 0) {
            # First buffer: read-write storage
            wgpu_bgl_entry_buffer(e, i, stage, rw, 0, 0);
        } else {
            # Remaining: read-only storage
            wgpu_bgl_entry_buffer(e, i, stage, ro, 0, 0);
        }
    }

    # Create bind group layout
    var bgl_desc = wgpu_bind_group_layout_descriptor("compute_bgl", entries, storage_count);
    var bgl = wgpu_device_create_bind_group_layout(device, bgl_desc);
    if (bgl == 0) { return 0; }

    # Create pipeline layout
    var layouts[8];
    store64(&layouts, bgl);
    var pl_desc = wgpu_pipeline_layout_descriptor("compute_pl", &layouts, 1);
    var pl = wgpu_device_create_pipeline_layout(device, pl_desc);
    if (pl == 0) {
        wgpu_bind_group_layout_release(bgl);
        return 0;
    }

    # Create shader module
    var src = wgpu_shader_source_wgsl(wgsl_source);
    var sm_desc = wgpu_shader_module_descriptor("compute_shader", src);
    var shader = wgpu_device_create_shader_module(device, sm_desc);
    if (shader == 0) {
        wgpu_pipeline_layout_release(pl);
        wgpu_bind_group_layout_release(bgl);
        return 0;
    }

    # Create compute pipeline
    var cp_desc = wgpu_compute_pipeline_descriptor("compute_pipeline", pl, shader, entry_point);
    var pipeline = wgpu_device_create_compute_pipeline(device, cp_desc);

    wgpu_shader_module_release(shader);
    if (pipeline == 0) {
        wgpu_pipeline_layout_release(pl);
        wgpu_bind_group_layout_release(bgl);
        return 0;
    }

    # Build ComputePipeline struct
    var cp = alloc(24);
    store64(cp, pipeline);
    store64(cp + 8, bgl);
    store64(cp + 16, pl);
    return cp;
}

# Accessors
fn compute_pipeline_handle(cp): i64 { return load64(cp); }
fn compute_pipeline_bgl(cp): i64 { return load64(cp + 8); }
fn compute_pipeline_layout(cp): i64 { return load64(cp + 16); }

# ================================================================
# Dispatch helpers
# ================================================================

# WebGPU spec minimum: maxComputeWorkgroupsPerDimension = 65535.
# Dispatches exceeding this are short-circuited (no-op) — matches the
# audit MED-3 zero/negative short-circuit pattern. Audit LOW-3.
var MABDA_MAX_DISPATCH_DIM = 65535;

# Dispatch a compute pipeline with one bind group.
# `dims_xyz` must point to 12 bytes holding three packed u32 workgroup counts
# (x at +0, y at +4, z at +8). Using a pointer keeps this function at 5
# parameters — a 7-parameter signature that internally fncalls into wgpu
# reliably segfaults per `feedback_cyrius_param_ceiling`. See the inline
# `compute_dispatch_xyz` helper below for the scalar form (which splits its
# work through this function).
# Returns 0 on submit; returns 0 silently (no submit) if any dimension
# is <= 0 or exceeds MABDA_MAX_DISPATCH_DIM. See audit LOW-3.
fn compute_dispatch(device, queue, cp, bind_group, dims_xyz): i64 {
    var x = load32(dims_xyz);
    var y = load32(dims_xyz + 4);
    var z = load32(dims_xyz + 8);
    if (x <= 0) { return 0; }
    if (y <= 0) { return 0; }
    if (z <= 0) { return 0; }
    if (validate_dispatch(x, y, z, MABDA_MAX_DISPATCH_DIM) != 0) { return 0; }

    var encoder = wgpu_device_create_command_encoder(device, "compute_enc");

    var pass_desc = wgpu_compute_pass_descriptor("compute_pass");
    var pass = wgpu_command_encoder_begin_compute_pass(encoder, pass_desc);

    wgpu_compute_pass_set_pipeline(pass, compute_pipeline_handle(cp));
    wgpu_compute_pass_set_bind_group(pass, 0, bind_group, 0, 0);
    wgpu_compute_pass_dispatch(pass, x, y, z);
    wgpu_compute_pass_end(pass);

    var cmd_buf = wgpu_command_encoder_finish(encoder, "compute_cmd");
    wgpu_queue_submit_one(queue, cmd_buf);
    return 0;
}

# ================================================================
# PingPongBuffer — iterative compute with source/dest swapping
# ================================================================
#
# PingPongBuffer struct layout (24 bytes):
#   +0: buffer_a (WGPUBuffer, 8)
#   +8: buffer_b (WGPUBuffer, 8)
#   +16: current  (i64, 0=A is source, 1=B is source)

fn ping_pong_new(device, size): i64 {
    var usage = WGPU_BUFFER_USAGE_STORAGE | WGPU_BUFFER_USAGE_COPY_SRC | WGPU_BUFFER_USAGE_COPY_DST;
    var desc_a = wgpu_buffer_descriptor("ping", usage, size, 0);
    var desc_b = wgpu_buffer_descriptor("pong", usage, size, 0);
    var pp = alloc(24);
    store64(pp, wgpu_device_create_buffer(device, desc_a));
    store64(pp + 8, wgpu_device_create_buffer(device, desc_b));
    store64(pp + 16, 0);
    return pp;
}

fn ping_pong_source(pp): i64 {
    if (load64(pp + 16) == 0) { return load64(pp); }
    return load64(pp + 8);
}

fn ping_pong_dest(pp): i64 {
    if (load64(pp + 16) == 0) { return load64(pp + 8); }
    return load64(pp);
}

fn ping_pong_swap(pp): i64 {
    var cur = load64(pp + 16);
    store64(pp + 16, 1 - cur);
    return 0;
}

fn ping_pong_release(pp): i64 {
    wgpu_buffer_release(load64(pp));
    wgpu_buffer_release(load64(pp + 8));
    return 0;
}

# Release a compute pipeline
fn compute_pipeline_release(cp): i64 {
    if (cp == 0) { return 0; }
    wgpu_compute_pipeline_release(compute_pipeline_handle(cp));
    wgpu_bind_group_layout_release(compute_pipeline_bgl(cp));
    wgpu_pipeline_layout_release(compute_pipeline_layout(cp));
    return 0;
}

# ================================================================
# v3 Step 3e — ctx-aware shader-module dispatchers
# ================================================================
# Public v3-shape API per docs/proposals/v3-native-api-principles.md:
# every operation that takes a ctx routes through ctx->backend->slot.
# Coexists with the legacy compute_pipeline_new above (which takes
# WGSL source + builds a full pipeline + bind group layout in one
# step). The dispatchers here expose the lower-level shader-module
# primitive so consumers can stage shader bytes once and reuse them
# across pipelines once Step 3g lands gpu_compute_dispatch.
#
# bytes_ptr semantics are backend-specific:
#   wgpu  — UTF-8 WGSL source, possibly null-terminated
#   AMD   — pre-compiled GFX9 ISA bytes (Step 3g consumer)

# Forwards the bound backend's default source kind: WGSL on wgpu, GFX9 ISA on
# native — byte-for-byte the v3.0 meaning, no call-site churn. SPIR-V uses the
# sibling gpu_shader_module_create_spirv. The slot carries `kind` (v3.2 Phase S).
fn gpu_shader_module_create(ctx, bytes_ptr, n): i64 {
    if (ctx == 0) { return 0; }
    var b = gpu_ctx_backend(ctx);
    var kind = SHADER_SRC_GFX9;
    if (backend_kind(b) == BACKEND_KIND_WGPU) { kind = SHADER_SRC_WGSL; }
    return fncall4(backend_get_slot(b, BACKEND_SLOT_SHADER_MODULE_CREATE),
    ctx, bytes_ptr, n, kind);
}

# @public — create a shader module from a SPIR-V binary (wgpu path). `words_ptr`
# = u32 word stream (magic 0x07230203); `byte_len` = word_count * 4. The wgpu
# instance MUST be built with the ShaderSourceSPIRV feature (deps/wgpu_main.c) —
# otherwise create returns 0 (the fail-loud null; mabda can't detect the missing
# feature before the call). Native returns 0 (SPIR-V→GFX9 lowering is Phase N).
fn gpu_shader_module_create_spirv(ctx, words_ptr, byte_len): i64 {
    if (ctx == 0) { return 0; }
    return fncall4(backend_get_slot(gpu_ctx_backend(ctx),
    BACKEND_SLOT_SHADER_MODULE_CREATE), ctx, words_ptr, byte_len, SHADER_SRC_SPIRV);
}

fn gpu_shader_module_release(ctx, shmod): i64 {
    if (ctx == 0) { return 0; }
    var slot = backend_get_slot(gpu_ctx_backend(ctx),
    BACKEND_SLOT_SHADER_MODULE_RELEASE);
    return fncall2(slot, ctx, shmod);
}

# ================================================================
# v3 Step 3g — ctx-aware compute dispatch (fncall6)
# ================================================================
# Slot signature: (ctx, shmod, x, y, z, bindings_ptr) → 0|err.
# This is the highest-arity slot in the Backend interface and the
# first time mabda exercises Cyrius-to-Cyrius fncall6 through a
# struct slot. fncall6 against extern-C wgpu functions has been
# historically unreliable (per the feedback_fncall6_wgpu memory
# note) — the fix on that side is a struct-packing C shim. The
# Cyrius-side fncall6 (cyrius callee, no extern-C ABI mismatch)
# should work; this dispatcher is the test.
#
# bindings_ptr is a raw byte buffer of (slot, kind, handle)
# triples per the bindless-resources non-negotiable in
# docs/proposals/v3-native-api-principles.md. The format is not
# yet finalized; consumers and slot wrappers can ignore it for
# now (Step 2 wgpu wrapper returns GPU_ERR_OTHER unconditionally).

fn gpu_compute_dispatch(ctx, shmod, x, y, z, bp): i64 {
    if (ctx == 0) { return GPU_ERR_OTHER; }
    # Audit 2026-06-14 [MED-3]: the v3 dispatcher must validate like its v2
    # sibling compute_dispatch — reject non-positive / over-limit workgroup
    # counts before they reach PM4 dispatch construction + CS submit.
    if (x <= 0) { return GPU_ERR_WORKGROUP_LIMIT; }
    if (y <= 0) { return GPU_ERR_WORKGROUP_LIMIT; }
    if (z <= 0) { return GPU_ERR_WORKGROUP_LIMIT; }
    if (validate_dispatch(x, y, z, MABDA_MAX_DISPATCH_DIM) != 0) {
        return GPU_ERR_WORKGROUP_LIMIT;
    }
    var slot = backend_get_slot(gpu_ctx_backend(ctx),
    BACKEND_SLOT_COMPUTE_DISPATCH);
    return fncall6(slot, ctx, shmod, x, y, z, bp);
}

# --- shader_cache.cyr ---

# @public — stable API surface (survives the v3.0 backend swap)
# shader_cache.cyr — hash-based shader module deduplication
# Ported from mabda/src/shader.rs
#
# ShaderCache stores compiled shader modules keyed by a u64 FNV-1a hash
# of their WGSL source code. Prevents recompiling identical shaders.
#
# v2.4.5 migration: switched from the cstr-keyed hashmap (with the
# `_hash_to_heap_key` per-lookup alloc) to `map_u64_*` — the u64 hash
# becomes the hashmap key directly. No allocation on get/has/set-of-
# existing-key. See cyrius v5.5.20 CHANGELOG for the stdlib side.

# FNV-1a hash for shader source deduplication
# FNV-1a hash over an EXPLICIT byte length, with the shader-source KIND folded
# into the seed (v3.2 Phase S.3). Length-explicit because a SPIR-V blob has
# embedded NUL bytes (it's a u32 word stream) — the NUL-terminated scan below
# would stop at the first zero and collide wildly. The kind fold seeds the basis
# with `kind * prime`; SHADER_SRC_WGSL = 0 leaves the basis UNCHANGED, so WGSL
# keys are byte-identical to the legacy hash, while a WGSL string and a SPIR-V
# blob can never share a key.
fn _shader_hash_n(ptr, byte_len, kind): i64 {
    var hash = 14695981039346656037;        # FNV-1a offset basis (u64)
    hash = hash ^ (kind * 1099511628211);   # kind fold (identity for WGSL=0)
    var i = 0;
    while (i < byte_len) {
        hash = hash ^ load8(ptr + i);
        hash = hash * 1099511628211;         # FNV prime
        i = i + 1;
    }
    return hash;
}

# FNV-1a hash for WGSL source dedup (NUL-terminated). Kept for the unchanged
# WGSL cache callers; delegates to _shader_hash_n folded with SHADER_SRC_WGSL,
# so existing keys are byte-stable.
fn _shader_hash(source): i64 {
    return _shader_hash_n(source, strlen(source), SHADER_SRC_WGSL);
}

fn shader_cache_new(): i64 {
    return map_u64_new();
}

# Get a cached shader module or 0 if not cached
fn shader_cache_get(cache, wgsl_source): i64 {
    return map_u64_get(cache, _shader_hash(wgsl_source));
}

# Store a shader module in the cache
fn shader_cache_set(cache, wgsl_source, module): i64 {
    map_u64_set(cache, _shader_hash(wgsl_source), module);
    return 0;
}

# Get or compile: returns cached module or compiles new one
fn shader_cache_get_or_compile(cache, device, wgsl_source, label): i64 {
    var existing = shader_cache_get(cache, wgsl_source);
    if (existing != 0) { return existing; }

    # Compile new shader
    var src = wgpu_shader_source_wgsl(wgsl_source);
    var desc = wgpu_shader_module_descriptor(label, src);
    var module = wgpu_device_create_shader_module(device, desc);

    if (module != 0) {
        shader_cache_set(cache, wgsl_source, module);
    }
    return module;
}

# ================================================================
# v3.2 Phase S.3 — SPIR-V cache peers (kind-folded, length-explicit)
# ================================================================
# `words_ptr` = u32 word stream; `byte_len` = word_count * 4. The hash folds
# SHADER_SRC_SPIRV, so a SPIR-V blob never collides with a WGSL string of the
# same bytes. (wgpu path — SPIR-V→GFX9 native lowering is Phase N.)

fn shader_cache_get_spirv(cache, words_ptr, byte_len): i64 {
    return map_u64_get(cache, _shader_hash_n(words_ptr, byte_len, SHADER_SRC_SPIRV));
}

fn shader_cache_set_spirv(cache, words_ptr, byte_len, module): i64 {
    map_u64_set(cache, _shader_hash_n(words_ptr, byte_len, SHADER_SRC_SPIRV), module);
    return 0;
}

# Get-or-compile a SPIR-V module. Validates the binary (magic/align/bound) before
# building the WGPUShaderSourceSPIRV (codeSize = byte_len/4 WORDS); a malformed
# blob returns 0 without caching. wgpu instance must have the ShaderSourceSPIRV
# feature (else the create nulls — fail-loud).
fn shader_cache_get_or_compile_spirv(cache, device, words_ptr, byte_len, label): i64 {
    # Validate BEFORE hashing/caching — never key the cache on a malformed blob
    # (defense-in-depth; Phase S review 2026-06-16).
    if (_spirv_validate(words_ptr, byte_len) != 0) { return 0; }
    var existing = shader_cache_get_spirv(cache, words_ptr, byte_len);
    if (existing != 0) { return existing; }
    var src = wgpu_shader_source_spirv(words_ptr, byte_len / 4);
    var desc = wgpu_shader_module_descriptor(label, src);
    var module = wgpu_device_create_shader_module(device, desc);
    if (module != 0) {
        shader_cache_set_spirv(cache, words_ptr, byte_len, module);
    }
    return module;
}

# --- pipeline_cache.cyr ---

# @public — stable API surface (survives the v3.0 backend swap)
# pipeline_cache.cyr — hash-based pipeline deduplication
# Ported from mabda/src/pipeline_cache.rs
#
# Caches compute and render pipeline handles keyed by a caller-supplied
# u64 hash. v2.4.5 migrated from cstr-keyed to u64-keyed hashmap — zero
# allocation per lookup; see cyrius v5.5.20 CHANGELOG.

# Audit 2026-06-14 [HIGH-4]: lib/hashmap.cyr reserves two key values
# in-band — MAP_U64_EMPTY (0) and MAP_U64_TOMB (0xFFFFFFFFFFFFFFFF). A
# caller-supplied cache key equal to either is silently dropped (every
# get/has misses), and a stored key of 0 also corrupts the map's
# occupied-count (was_new fires on every overwrite), mis-timing growth.
# These caches are keyed by consumer-folded u64 hashes, so a zero or
# all-ones fold is readily reachable. Remap the two reserved values to
# fixed sentinel-free constants before delegating to map_u64_*. Applied
# symmetrically across set/get/has (shared by bind_group_cache too) so
# round-trips stay consistent. A genuine key colliding with a remap
# target is a 2^-64 event — the same odds as the original sentinel hit,
# and strictly better than the always-broken status quo for keys 0/MAX.
var _CACHE_KEY_REMAP_ZERO = 0x9E3779B97F4A7C15;   # stands in for key 0
var _CACHE_KEY_REMAP_MAX  = 0xC2B2AE3D27D4EB4F;   # stands in for u64::MAX

fn _cache_safe_key(key): i64 {
    if (key == 0)                  { return _CACHE_KEY_REMAP_ZERO; }
    if (key == 0xFFFFFFFFFFFFFFFF) { return _CACHE_KEY_REMAP_MAX; }
    return key;
}

fn pipeline_cache_new(): i64 {
    return map_u64_new();
}

fn pipeline_cache_get(cache, key): i64 {
    return map_u64_get(cache, _cache_safe_key(key));
}

fn pipeline_cache_set(cache, key, pipeline): i64 {
    map_u64_set(cache, _cache_safe_key(key), pipeline);
    return 0;
}

fn pipeline_cache_has(cache, key): i64 {
    return map_u64_has(cache, _cache_safe_key(key));
}

# --- bind_group_cache.cyr ---

# @public — stable API surface (survives the v3.0 backend swap)
# bind_group_cache.cyr — hash-based bind group caching
# Ported from mabda/src/bind_group_cache.rs
#
# Caches bind group handles keyed by a caller-supplied u64 hash.
# v2.4.5 migrated from cstr-keyed to u64-keyed hashmap — zero
# allocation per lookup; see cyrius v5.5.20 CHANGELOG.

fn bind_group_cache_new(): i64 {
    return map_u64_new();
}

# Audit 2026-06-14 [HIGH-4]: route keys through _cache_safe_key (defined
# in pipeline_cache.cyr) so a caller key of 0 or 0xFFFFFFFFFFFFFFFF can't
# collide with map_u64's reserved EMPTY/TOMB sentinels.
fn bind_group_cache_get(cache, key): i64 {
    return map_u64_get(cache, _cache_safe_key(key));
}

fn bind_group_cache_set(cache, key, bind_group): i64 {
    map_u64_set(cache, _cache_safe_key(key), bind_group);
    return 0;
}

fn bind_group_cache_has(cache, key): i64 {
    return map_u64_has(cache, _cache_safe_key(key));
}

# Clear all entries. Old backing store gets GC'd by the bump allocator
# on reset; callers that need in-place clear should use map_u64_clear.
fn bind_group_cache_clear(cache): i64 {
    return map_u64_new();
}

# --- vertex.cyr ---

# @public — stable API surface (survives the v3.0 backend swap)
# vertex.cyr — vertex types and buffer layout descriptors
# Ported from mabda/src/vertex.rs
#
# Canonical vertex types for the AGNOS GPU ecosystem.
# All values stored as f32 bit patterns via store32.
#
# Vertex2D (32 bytes):
#   +0:  position[0] (f32)     shader_location 0
#   +4:  position[1] (f32)
#   +8:  tex_coords[0] (f32)   shader_location 1
#   +12: tex_coords[1] (f32)
#   +16: color[0] (f32)        shader_location 2
#   +20: color[1] (f32)
#   +24: color[2] (f32)
#   +28: color[3] (f32)
#
# Vertex3D (48 bytes):
#   +0:  position[0..3] (3×f32)      shader_location 0
#   +12: normal[0..3] (3×f32)        shader_location 1
#   +24: tex_coords[0..2] (2×f32)    shader_location 2
#   +32: color[0..4] (4×f32)         shader_location 3
#
# SkinnedVertex3D (96 bytes):
#   +0:  position[0..3] (3×f32)      shader_location 0
#   +12: normal[0..3] (3×f32)        shader_location 1
#   +24: tex_coords[0..2] (2×f32)    shader_location 2
#   +32: color[0..4] (4×f32)         shader_location 3
#   +48: joints[0..4] (4×f32)        shader_location 4
#   +64: weights[0..4] (4×f32)       shader_location 5
#   +80: tangent[0..4] (4×f32)       shader_location 6

enum VertexSize {
    VERTEX_2D_SIZE     = 32;
    VERTEX_3D_SIZE     = 48;
    SKINNED_3D_SIZE    = 96;
}

# ================================================================
# Vertex2D — create and write
# ================================================================

# Allocate a Vertex2D and fill with f64 values (converted to f32)
fn vertex2d_new(px, py, tx, ty, cr, cg, cb, ca): i64 {
    var v = alloc(32);
    store32(v, f64_to_f32(px));
    store32(v + 4, f64_to_f32(py));
    store32(v + 8, f64_to_f32(tx));
    store32(v + 12, f64_to_f32(ty));
    store32(v + 16, f64_to_f32(cr));
    store32(v + 20, f64_to_f32(cg));
    store32(v + 24, f64_to_f32(cb));
    store32(v + 28, f64_to_f32(ca));
    return v;
}

# Write a Vertex2D at dst (doesn't allocate, writes 32 bytes)
fn vertex2d_write(dst, px, py, tx, ty, cr, cg, cb, ca): i64 {
    store32(dst, f64_to_f32(px));
    store32(dst + 4, f64_to_f32(py));
    store32(dst + 8, f64_to_f32(tx));
    store32(dst + 12, f64_to_f32(ty));
    store32(dst + 16, f64_to_f32(cr));
    store32(dst + 20, f64_to_f32(cg));
    store32(dst + 24, f64_to_f32(cb));
    store32(dst + 28, f64_to_f32(ca));
    return 0;
}

# ================================================================
# Vertex3D — create and write
# ================================================================

fn vertex3d_new(px, py, pz, nx, ny, nz, tx, ty, cr, cg, cb, ca): i64 {
    var v = alloc(48);
    store32(v, f64_to_f32(px));
    store32(v + 4, f64_to_f32(py));
    store32(v + 8, f64_to_f32(pz));
    store32(v + 12, f64_to_f32(nx));
    store32(v + 16, f64_to_f32(ny));
    store32(v + 20, f64_to_f32(nz));
    store32(v + 24, f64_to_f32(tx));
    store32(v + 28, f64_to_f32(ty));
    store32(v + 32, f64_to_f32(cr));
    store32(v + 36, f64_to_f32(cg));
    store32(v + 40, f64_to_f32(cb));
    store32(v + 44, f64_to_f32(ca));
    return v;
}

# ================================================================
# WGPUVertexFormat constants (for layout descriptors)
# ================================================================

enum WGPUVertexFormat {
    WGPU_VERTEX_FORMAT_FLOAT32X2 = 21;
    WGPU_VERTEX_FORMAT_FLOAT32X3 = 22;
    WGPU_VERTEX_FORMAT_FLOAT32X4 = 23;
}

# ================================================================
# WGPUVertexAttribute layout (24 bytes per attribute)
#   +0:  format (u32)
#   +8:  offset (u64)
#   +16: shaderLocation (u32)
# ================================================================

fn _vertex_attr(dst, format, offset, location): i64 {
    store32(dst, format);
    store64(dst + 8, offset);
    store32(dst + 16, location);
    return 0;
}

# ================================================================
# WGPUVertexBufferLayout (24 bytes)
#   +0:  arrayStride (u64)
#   +8:  stepMode (u32)
#   +16: attributeCount (u64) — wait, check actual layout
# Actually: need to verify from webgpu.h
# For now, provide attribute arrays that can be used with
# the render pipeline builder
# ================================================================

# Build a Vertex2D attribute array (3 attributes × 24 bytes = 72 bytes)
# Returns pointer to attribute array
fn vertex2d_attributes(): i64 {
    var attrs = alloc(72);
    _vertex_attr(attrs, WGPU_VERTEX_FORMAT_FLOAT32X2, 0, 0);       # position
    _vertex_attr(attrs + 24, WGPU_VERTEX_FORMAT_FLOAT32X2, 8, 1);  # tex_coords
    _vertex_attr(attrs + 48, WGPU_VERTEX_FORMAT_FLOAT32X4, 16, 2); # color
    return attrs;
}

# Build a Vertex3D attribute array (4 attributes × 24 bytes = 96 bytes)
fn vertex3d_attributes(): i64 {
    var attrs = alloc(96);
    _vertex_attr(attrs, WGPU_VERTEX_FORMAT_FLOAT32X3, 0, 0);       # position
    _vertex_attr(attrs + 24, WGPU_VERTEX_FORMAT_FLOAT32X3, 12, 1); # normal
    _vertex_attr(attrs + 48, WGPU_VERTEX_FORMAT_FLOAT32X2, 24, 2); # tex_coords
    _vertex_attr(attrs + 72, WGPU_VERTEX_FORMAT_FLOAT32X4, 32, 3); # color
    return attrs;
}

# --- blend.cyr ---

# @public — stable API surface (survives the v3.0 backend swap)
# blend.cyr — blend state presets
# Ported from mabda/src/blend.rs
#
# WGPUBlendState layout (24 bytes):
#   +0:  color (WGPUBlendComponent = 12 bytes)
#   +12: alpha (WGPUBlendComponent = 12 bytes)
#
# WGPUBlendComponent layout (12 bytes):
#   +0:  operation (u32)
#   +4:  srcFactor (u32)
#   +8:  dstFactor (u32)

# WGPUBlendOperation
enum WGPUBlendOp {
    WGPU_BLEND_OP_ADD = 1;
}

# WGPUBlendFactor
enum WGPUBlendFactor {
    WGPU_BLEND_FACTOR_ZERO      = 1;
    WGPU_BLEND_FACTOR_ONE       = 2;
    WGPU_BLEND_FACTOR_SRC       = 3;
    WGPU_BLEND_FACTOR_ONE_MINUS_SRC = 4;
    WGPU_BLEND_FACTOR_SRC_ALPHA = 5;
    WGPU_BLEND_FACTOR_ONE_MINUS_SRC_ALPHA = 6;
    WGPU_BLEND_FACTOR_DST       = 7;
    WGPU_BLEND_FACTOR_ONE_MINUS_DST = 8;
    WGPU_BLEND_FACTOR_DST_ALPHA = 9;
    WGPU_BLEND_FACTOR_ONE_MINUS_DST_ALPHA = 10;
}

# ================================================================
# Blend presets
# ================================================================

enum BlendPreset {
    BLEND_OPAQUE              = 0;
    BLEND_ALPHA_BLEND         = 1;
    BLEND_PREMULTIPLIED_ALPHA = 2;
    BLEND_ADDITIVE            = 3;
    BLEND_MULTIPLY            = 4;
}

fn _blend_component(dst, op, src_factor, dst_factor): i64 {
    store32(dst, op);
    store32(dst + 4, src_factor);
    store32(dst + 8, dst_factor);
    return 0;
}

# Write a blend state (24 bytes) at dst for the given preset
fn blend_state(dst, preset): i64 {
    var add = WGPU_BLEND_OP_ADD;
    var one = WGPU_BLEND_FACTOR_ONE;
    var zero = WGPU_BLEND_FACTOR_ZERO;
    var src_a = WGPU_BLEND_FACTOR_SRC_ALPHA;
    var inv_src_a = WGPU_BLEND_FACTOR_ONE_MINUS_SRC_ALPHA;
    if (preset == BLEND_OPAQUE) {
        # Replace: src=One, dst=Zero
        _blend_component(dst, add, one, zero);
        _blend_component(dst + 12, add, one, zero);
    }
    elif (preset == BLEND_ALPHA_BLEND) {
        # Standard alpha: src=SrcAlpha, dst=OneMinusSrcAlpha
        _blend_component(dst, add, src_a, inv_src_a);
        _blend_component(dst + 12, add, one, inv_src_a);
    }
    elif (preset == BLEND_PREMULTIPLIED_ALPHA) {
        # Premultiplied: src=One, dst=OneMinusSrcAlpha
        _blend_component(dst, add, one, inv_src_a);
        _blend_component(dst + 12, add, one, inv_src_a);
    }
    elif (preset == BLEND_ADDITIVE) {
        # Additive: src=One, dst=One
        _blend_component(dst, add, one, one);
        _blend_component(dst + 12, add, one, one);
    }
    elif (preset == BLEND_MULTIPLY) {
        # Multiply: src=Dst, dst=Zero
        _blend_component(dst, add, WGPU_BLEND_FACTOR_DST, zero);
        _blend_component(dst + 12, add, WGPU_BLEND_FACTOR_DST_ALPHA, zero);
    }
    return 0;
}

# Allocate and return a blend state for the given preset
fn blend_state_new(preset): i64 {
    var bs = alloc(24);
    blend_state(bs, preset);
    return bs;
}

# --- sampler.cyr ---

# @public — stable API surface (survives the v3.0 backend swap)
# sampler.cyr — sampler presets and creation helpers
# Ported from mabda/src/sampler.rs
#
# WGPUSamplerDescriptor layout (56 bytes — from webgpu.h):
#   +0:  nextInChain (8)
#   +8:  label (StringView = 16)
#   +24: addressModeU (u32)
#   +28: addressModeV (u32)
#   +32: addressModeW (u32)
#   +36: magFilter (u32)
#   +40: minFilter (u32)
#   +44: mipmapFilter (u32)
#   +48: lodMinClamp (f32)
#   +52: lodMaxClamp (f32)
#   +56: compare (u32)
#   +60: maxAnisotropy (u16)

# WGPUAddressMode (wgpu-native v29 values)
var WGPU_ADDRESS_MODE_CLAMP_TO_EDGE = 1;
var WGPU_ADDRESS_MODE_REPEAT        = 2;
var WGPU_ADDRESS_MODE_MIRROR_REPEAT = 3;

# WGPUFilterMode (v29)
var WGPU_FILTER_MODE_NEAREST = 1;
var WGPU_FILTER_MODE_LINEAR  = 2;

# WGPUMipmapFilterMode (v29)
var WGPU_MIPMAP_FILTER_NEAREST = 1;
var WGPU_MIPMAP_FILTER_LINEAR  = 2;

# WGPUCompareFunction (v29)
var WGPU_COMPARE_UNDEFINED   = 0;
var WGPU_COMPARE_NEVER       = 1;
var WGPU_COMPARE_LESS        = 2;
var WGPU_COMPARE_EQUAL       = 3;
var WGPU_COMPARE_LESS_EQUAL  = 4;
var WGPU_COMPARE_GREATER     = 5;
var WGPU_COMPARE_NOT_EQUAL   = 6;
var WGPU_COMPARE_GREATER_EQUAL = 7;
var WGPU_COMPARE_ALWAYS      = 8;

# Sampler presets
var SAMPLER_NEAREST     = 0;
var SAMPLER_LINEAR      = 1;
var SAMPLER_ANISOTROPIC = 2;
var SAMPLER_COMPARISON  = 3;

# Build a sampler descriptor at dst (64-byte WGPUSamplerDescriptor)
# WGPU_SAMPLER_DESCRIPTOR_INIT defaults:
#   nextInChain=NULL, label=empty, addressMode=ClampToEdge
#   filters=Nearest, lodMinClamp=0.0, lodMaxClamp=32.0,
#   compare=Undefined, maxAnisotropy=1
fn _sampler_desc_init(dst, label): i64 {
    memset(dst, 0, 64);
    if (label != 0) { wgpu_string_view(dst + 8, label); }
    store32(dst + 24, WGPU_ADDRESS_MODE_CLAMP_TO_EDGE);
    store32(dst + 28, WGPU_ADDRESS_MODE_CLAMP_TO_EDGE);
    store32(dst + 32, WGPU_ADDRESS_MODE_CLAMP_TO_EDGE);
    # lodMaxClamp = 32.0f (default per WGPU_SAMPLER_DESCRIPTOR_INIT)
    store32(dst + 52, 0x42000000);  # 32.0f bit pattern
    # maxAnisotropy = 1 (uint16); anything less triggers a wgpu validation error
    store16(dst + 60, 1);
    return 0;
}

fn sampler_descriptor(preset): i64 {
    var desc = alloc(64);
    if (preset == SAMPLER_NEAREST) {
        _sampler_desc_init(desc, "sampler_nearest");
        store32(desc + 36, WGPU_FILTER_MODE_NEAREST);
        store32(desc + 40, WGPU_FILTER_MODE_NEAREST);
        store32(desc + 44, WGPU_MIPMAP_FILTER_NEAREST);
    }
    elif (preset == SAMPLER_LINEAR) {
        _sampler_desc_init(desc, "sampler_linear");
        store32(desc + 36, WGPU_FILTER_MODE_LINEAR);
        store32(desc + 40, WGPU_FILTER_MODE_LINEAR);
        store32(desc + 44, WGPU_MIPMAP_FILTER_LINEAR);
    }
    elif (preset == SAMPLER_ANISOTROPIC) {
        _sampler_desc_init(desc, "sampler_anisotropic");
        store32(desc + 36, WGPU_FILTER_MODE_LINEAR);
        store32(desc + 40, WGPU_FILTER_MODE_LINEAR);
        store32(desc + 44, WGPU_MIPMAP_FILTER_LINEAR);
        # Override the init's maxAnisotropy=1 with 16× anisotropic filtering.
        store16(desc + 60, 16);
    }
    elif (preset == SAMPLER_COMPARISON) {
        _sampler_desc_init(desc, "sampler_comparison");
        store32(desc + 36, WGPU_FILTER_MODE_LINEAR);
        store32(desc + 40, WGPU_FILTER_MODE_LINEAR);
        store32(desc + 44, WGPU_MIPMAP_FILTER_NEAREST);
        store32(desc + 56, WGPU_COMPARE_LESS_EQUAL);
    }
    return desc;
}

# ================================================================
# v3.2 TS.3 — public sampler intent (both backends)
# ================================================================
# gpu_sampler_create returns a backend-agnostic sampler-intent HANDLE that
# packs the filter + address mode (NATIVE_SAMP_FILTER_* / NATIVE_SAMP_ADDR_*).
# It is NOT a backend object: the actual GFX9 S# (native) / WGPUSampler (wgpu)
# is materialized at gpu_render_pass_bind_texture time from this intent (TS.5),
# so there is no per-sampler backend slot. A non-zero tag in the high bits
# means a (point, clamp) = (0, 0) intent is never mistaken for a 0 failure.
# Returns 0 on null ctx or an out-of-range filter/addr.
var MABDA_SAMPLER_TAG = 0x5A4D0000;   # 'ZM' marker in bits [31:16]

fn gpu_sampler_create(ctx, filter, addr): i64 {
    if (ctx == 0) { return 0; }
    if (filter != NATIVE_SAMP_FILTER_POINT) {
        if (filter != NATIVE_SAMP_FILTER_BILINEAR) { return 0; }
    }
    if (addr != NATIVE_SAMP_ADDR_CLAMP) {
        if (addr != NATIVE_SAMP_ADDR_WRAP) { return 0; }
    }
    return MABDA_SAMPLER_TAG | ((addr & 0xFF) << 8) | (filter & 0xFF);
}

# Unpack a gpu_sampler_create handle (used by the bind_for_sample fillers).
fn gpu_sampler_filter(s): i64 { return s & 0xFF; }
fn gpu_sampler_addr(s): i64 { return (s >> 8) & 0xFF; }
fn gpu_sampler_is_valid(s): i64 {
    if ((s & 0xFFFF0000) == MABDA_SAMPLER_TAG) { return 1; }
    return 0;
}

# v3.2 TS.5 (wgpu sample path) — build a 64-byte WGPUSamplerDescriptor from a
# NATIVE_SAMP_* intent (filter + addr), ready for wgpu_device_create_sampler.
# NEAREST/CLAMP_TO_EDGE is the point/clamp MVP; BILINEAR -> LINEAR, WRAP ->
# REPEAT. mipmapFilter NEAREST, lodMaxClamp 32.0, maxAnisotropy 1 (a 0 trips a
# wgpu validation error). Field offsets pinned vs the layout above.
fn wgpu_sampler_descriptor_from_intent(filter, addr): i64 {
    var d = alloc(64);
    _sampler_desc_init(d, 0);
    var amode = WGPU_ADDRESS_MODE_CLAMP_TO_EDGE;
    if (addr == NATIVE_SAMP_ADDR_WRAP) { amode = WGPU_ADDRESS_MODE_REPEAT; }
    store32(d + 24, amode);   # addressModeU
    store32(d + 28, amode);   # addressModeV
    store32(d + 32, amode);   # addressModeW
    var fmode = WGPU_FILTER_MODE_NEAREST;
    if (filter == NATIVE_SAMP_FILTER_BILINEAR) { fmode = WGPU_FILTER_MODE_LINEAR; }
    store32(d + 36, fmode);   # magFilter
    store32(d + 40, fmode);   # minFilter
    store32(d + 44, WGPU_MIPMAP_FILTER_NEAREST);   # mipmapFilter
    return d;
}

# --- depth.cyr ---

# @public — stable API surface (survives the v3.0 backend swap)
# depth.cyr — depth/stencil texture management
# Ported from mabda/src/depth.rs
#
# DepthTexture struct layout (40 bytes):
#   +0:  texture (WGPUTexture handle, 8)
#   +8:  view    (WGPUTextureView handle, 8)
#   +16: format  (u32 WGPUTextureFormat)
#   +24: width   (i64)
#   +32: height  (i64)

# Depth format constants (wgpu-native v29 values)
var DEPTH_FORMAT_DEPTH32_FLOAT         = 0x30;  # WGPUTextureFormat_Depth32Float
var DEPTH_FORMAT_DEPTH24_PLUS_STENCIL8 = 0x2F;  # WGPUTextureFormat_Depth24PlusStencil8
var DEPTH_DEFAULT_FORMAT               = 0x30;

# Create a depth texture backed by a real WGPUTexture + view.
# Uses the shared `wgpu_texture_descriptor` builder (which matches v29
# WGPUTextureDescriptor offsets byte-for-byte: size@+36 NOT +40) and
# calls `wgpu_device_create_texture` (slot 45 — not create_buffer, which
# was the latent TODO-marked bug before v2.4.4).  #skip-lint
# Returns DepthTexture struct pointer (40 bytes), or 0 on failure.
fn depth_texture_new(device, width, height, format): i64 {
    if (width < 1)  { width = 1; }
    if (height < 1) { height = 1; }
    # usage = RENDER_ATTACHMENT | TEXTURE_BINDING
    var usage = WGPU_TEXTURE_USAGE_RENDER_ATTACHMENT | WGPU_TEXTURE_USAGE_TEXTURE_BINDING;
    var desc = wgpu_texture_descriptor("depth_texture", usage,
    WGPU_TEXTURE_DIMENSION_2D, width, height, format);
    var texture = wgpu_device_create_texture(device, desc);
    if (texture == 0) { return 0; }
    # Default 2D view that matches the texture's format.
    var view_desc = wgpu_texture_view_descriptor(0, format,
    WGPU_TEXTURE_VIEW_DIMENSION_2D);
    var view = wgpu_texture_create_view(texture, view_desc);
    var dt = alloc(40);
    store64(dt, texture);
    store64(dt + 8, view);
    store32(dt + 16, format);
    store64(dt + 24, width);
    store64(dt + 32, height);
    return dt;
}

# Create with default format (Depth32Float)
fn depth_texture_new_default(device, width, height): i64 {
    return depth_texture_new(device, width, height, DEPTH_DEFAULT_FORMAT);
}

# Accessors
fn depth_texture_handle(dt): i64 { return load64(dt); }
fn depth_texture_view(dt): i64 { return load64(dt + 8); }
fn depth_texture_format(dt): i64 { return load32(dt + 16); }
fn depth_texture_width(dt): i64 { return load64(dt + 24); }
fn depth_texture_height(dt): i64 { return load64(dt + 32); }

# WGPUCompareFunction constants
var WGPU_COMPARE_LESS = 2;

# Build a depth/stencil state (for render pipeline integration)
# WGPUDepthStencilState layout (68 bytes):
#   +0:  nextInChain (8)
#   +8:  format (u32)
#   +12: depthWriteEnabled (u32 OptionalBool)
#   +16: depthCompare (u32)
#   +20: stencilFront (StencilFaceState = 16)
#   +36: stencilBack (StencilFaceState = 16)
#   +52: stencilReadMask (u32)
#   +56: stencilWriteMask (u32)
#   +60: depthBias (i32)
#   +64: depthBiasSlopeScale (f32)
#   +68: depthBiasClamp (f32)
fn depth_stencil_state(dst, format): i64 {
    memset(dst, 0, 72);
    store32(dst + 8, format);
    store32(dst + 12, 2);          # depthWriteEnabled = true (OptionalBool_True = 2)
    store32(dst + 16, WGPU_COMPARE_LESS);
    store32(dst + 52, 0xFFFFFFFF); # stencilReadMask
    store32(dst + 56, 0xFFFFFFFF); # stencilWriteMask
    return 0;
}

# --- bind_group.cyr ---

# @public — stable API surface (survives the v3.0 backend swap)
# bind_group.cyr — bind group layout builder
# Ported from mabda/src/bind_group.rs
#
# Fluent builder for WGPUBindGroupLayout creation.
# Uses a vec of WGPUBindGroupLayoutEntry structs (120 bytes each).
#
# BindGroupLayoutBuilder struct layout (8 bytes):
#   +0: entries (vec ptr — vec of entry pointers)

fn bglb_new(): i64 {
    var b = alloc(8);
    store64(b, vec_new());
    return b;
}

fn _bglb_entries(b): i64 { return load64(b); }

# Add a uniform buffer binding
fn bglb_uniform_buffer(b, visibility): i64 {
    var entries = _bglb_entries(b);
    var idx = vec_len(entries);
    var e = alloc(120);
    memset(e, 0, 120);
    wgpu_bgl_entry_buffer(e, idx, visibility, WGPU_BUFFER_BINDING_TYPE_UNIFORM, 0, 0);
    vec_push(entries, e);
    return b;
}

# Add a uniform buffer binding with dynamic offset
fn bglb_uniform_buffer_dynamic(b, visibility): i64 {
    var entries = _bglb_entries(b);
    var idx = vec_len(entries);
    var e = alloc(120);
    memset(e, 0, 120);
    wgpu_bgl_entry_buffer(e, idx, visibility, WGPU_BUFFER_BINDING_TYPE_UNIFORM, 1, 0);
    vec_push(entries, e);
    return b;
}

# Add a storage buffer binding (read-only)
fn bglb_storage_buffer_readonly(b, visibility): i64 {
    var entries = _bglb_entries(b);
    var idx = vec_len(entries);
    var e = alloc(120);
    memset(e, 0, 120);
    wgpu_bgl_entry_buffer(e, idx, visibility, WGPU_BUFFER_BINDING_TYPE_READ_ONLY_STORAGE, 0, 0);
    vec_push(entries, e);
    return b;
}

# Add a storage buffer binding (read-write)
fn bglb_storage_buffer(b, visibility): i64 {
    var entries = _bglb_entries(b);
    var idx = vec_len(entries);
    var e = alloc(120);
    memset(e, 0, 120);
    wgpu_bgl_entry_buffer(e, idx, visibility, WGPU_BUFFER_BINDING_TYPE_STORAGE, 0, 0);
    vec_push(entries, e);
    return b;
}

# Add a 2D texture binding (float, filterable)
# WGPUBindGroupLayoutEntry texture field at +72 (24 bytes):
#   +72: sampleType (u32) — Float=1, UnfilterableFloat=2, Depth=3
#   +76: viewDimension (u32) — D2=2
#   +80: multisampled (u32 bool)
fn bglb_texture_2d(b, visibility): i64 {
    var entries = _bglb_entries(b);
    var idx = vec_len(entries);
    var e = alloc(120);
    memset(e, 0, 120);
    store32(e + 8, idx);
    store64(e + 16, visibility);
    store32(e + 72, 1);   # sampleType = Float (filterable)
    store32(e + 76, 2);   # viewDimension = D2
    vec_push(entries, e);
    return b;
}

# Add a sampler binding (filtering)
# WGPUBindGroupLayoutEntry sampler field at +56 (16 bytes):
#   +56: type (u32) — Filtering=1, NonFiltering=2, Comparison=3
fn bglb_sampler(b, visibility): i64 {
    var entries = _bglb_entries(b);
    var idx = vec_len(entries);
    var e = alloc(120);
    memset(e, 0, 120);
    store32(e + 8, idx);
    store64(e + 16, visibility);
    store32(e + 56, 1);   # type = Filtering
    vec_push(entries, e);
    return b;
}

# Add a comparison sampler binding (for shadow maps)
fn bglb_comparison_sampler(b, visibility): i64 {
    var entries = _bglb_entries(b);
    var idx = vec_len(entries);
    var e = alloc(120);
    memset(e, 0, 120);
    store32(e + 8, idx);
    store64(e + 16, visibility);
    store32(e + 56, 3);   # type = Comparison
    vec_push(entries, e);
    return b;
}

# Build the bind group layout — returns entry array pointer + count
# Caller uses these with wgpu_bind_group_layout_descriptor()
fn bglb_entry_count(b): i64 {
    return vec_len(_bglb_entries(b));
}

# Copy entries into a contiguous array for wgpu (120 bytes each)
fn bglb_build_entries(b): i64 {
    var entries = _bglb_entries(b);
    var count = vec_len(entries);
    if (count == 0) { return 0; }
    var arr = alloc(count * 120);
    for (var i = 0; i < count; i = i + 1) {
        var src = vec_get(entries, i);
        memcpy(arr + i * 120, src, 120);
    }
    return arr;
}

# ================================================================
# v3.2 TS.5 (wgpu sample path) — bind-GROUP descriptor builder
# ================================================================
# Builds a WGPUBindGroupDescriptor for the textured-sample group:
# binding 0 = texture view, binding 1 = sampler. `bgl` is the matching
# bind-group LAYOUT (bglb: texture_2d@0 + sampler@1). Allocates the 48-byte
# descriptor + the 2-entry (56 B each) array; returns the descriptor ptr for
# wgpu_device_create_bind_group. Layouts pinned vs webgpu.h v29:
#   WGPUBindGroupEntry (56 B): nextInChain@0 binding@8 buffer@16 offset@24
#                              size@32 sampler@40 textureView@48
#   WGPUBindGroupDescriptor (48 B): nextInChain@0 label@8(StringView,16)
#                              layout@24 entryCount@32 entries@40
fn wgpu_texture_bind_group_descriptor(bgl, view, sampler): i64 {
    var entries = alloc(112);   # 2 × 56
    memset(entries, 0, 112);
    # entry 0: texture view at binding 0
    store32(entries + 8,  0);          # binding
    store64(entries + 48, view);       # textureView
    # entry 1: sampler at binding 1
    store32(entries + 56 + 8,  1);     # binding
    store64(entries + 56 + 40, sampler);   # sampler
    var desc = alloc(48);
    memset(desc, 0, 48);
    wgpu_string_view_null(desc + 8);   # label (empty)
    store64(desc + 24, bgl);           # layout
    store64(desc + 32, 2);             # entryCount
    store64(desc + 40, entries);       # entries
    return desc;
}

# --- texture.cyr ---

# @public — stable API surface (survives the v3.0 backend swap)
# texture.cyr — texture creation, view, sampler, and caching
# Ported from mabda/src/texture.rs
#
# Texture struct layout (32 bytes):
#   +0:  texture (WGPUTexture handle, 8)
#   +8:  view    (WGPUTextureView handle, 8)
#   +16: sampler (WGPUSampler handle, 8)
#   +24: width × height packed (lower 32 bits = width, upper 32 bits = height)
#
# The last field is for informational purposes — the original 24-byte layout
# lost size information, which makes `texture_from_*` results hard to use.
#
# FFI contract: all creation paths use wgpu_ffi slots 45–51. See
# src/wgpu_descriptors.cyr for the struct builders.

# ================================================================
# Accessors
# ================================================================
fn texture_handle(t): i64 { return load64(t); }
fn texture_view(t): i64 { return load64(t + 8); }
fn texture_sampler(t): i64 { return load64(t + 16); }
fn texture_width(t): i64 { return load32(t + 24); }
fn texture_height(t): i64 { return load32(t + 28); }

# Build a Texture struct from pre-created handles
fn texture_from_handles(tex, view, sampler): i64 {
    var t = alloc(32);
    store64(t + 0,  tex);
    store64(t + 8,  view);
    store64(t + 16, sampler);
    store64(t + 24, 0);
    return t;
}

# Release all handles held by a Texture struct (safe for partial fills)
fn texture_release(t): i64 {
    var tex     = load64(t + 0);
    var view    = load64(t + 8);
    var sampler = load64(t + 16);
    if (view != 0)    { wgpu_texture_view_release(view); }
    if (tex != 0)     { wgpu_texture_release(tex); }
    if (sampler != 0) { wgpu_sampler_release(sampler); }
    store64(t + 0, 0);
    store64(t + 8, 0);
    store64(t + 16, 0);
    return 0;
}

# ================================================================
# Raw creation — create a texture handle without view/sampler
# ================================================================

# MABDA_MAX_TEXTURE_DIM_2D (WebGPU spec minimum maxTextureDimension2D =
# 8192) moved to src/texture_format.cyr at v3.2 T.3 so the block-size math
# there can share the dimension bound; texture.cyr still uses it below.

# Creates a 2D texture with RGBA8_UNORM format and
# TEXTURE_BINDING | COPY_DST usage (the common "upload + sample" case).
# Returns 0 on invalid dimensions (<= 0 or > MABDA_MAX_TEXTURE_DIM_2D).
fn texture_create_rgba8(device, width, height, label): i64 {
    if (width <= 0)  { return 0; }
    if (height <= 0) { return 0; }
    if (validate_dimensions(width, height, MABDA_MAX_TEXTURE_DIM_2D) != 0) { return 0; }
    var usage = WGPU_TEXTURE_USAGE_TEXTURE_BINDING | WGPU_TEXTURE_USAGE_COPY_DST;
    var desc = wgpu_texture_descriptor(label, usage, WGPU_TEXTURE_DIMENSION_2D,
    width, height, WGPU_TEXTURE_FORMAT_RGBA8_UNORM);
    return wgpu_device_create_texture(device, desc);
}

# Creates a 2D RGBA8_UNORM render target — usage is
# RENDER_ATTACHMENT | COPY_SRC | COPY_DST so it can be drawn into,
# read back via copy_texture_to_buffer, and cleared/initialised via
# queue.writeTexture if needed. Returns the WGPUTexture handle, or
# 0 on invalid dimensions. Used by programs/render_e2e.cyr and any
# consumer that renders to an offscreen target. v2.4.3.
fn texture_create_render_target_rgba8(device, width, height, label): i64 {
    if (width <= 0)  { return 0; }
    if (height <= 0) { return 0; }
    if (validate_dimensions(width, height, MABDA_MAX_TEXTURE_DIM_2D) != 0) { return 0; }
    var usage = WGPU_TEXTURE_USAGE_RENDER_ATTACHMENT
    | WGPU_TEXTURE_USAGE_COPY_SRC
    | WGPU_TEXTURE_USAGE_COPY_DST;
    var desc = wgpu_texture_descriptor(label, usage, WGPU_TEXTURE_DIMENSION_2D,
    width, height, WGPU_TEXTURE_FORMAT_RGBA8_UNORM);
    return wgpu_device_create_texture(device, desc);
}

# Create a default 2D TextureView for an RGBA8 texture.
fn texture_view_create_rgba8(texture, label): i64 {
    var desc = wgpu_texture_view_descriptor(label,
    WGPU_TEXTURE_FORMAT_RGBA8_UNORM,
    WGPU_TEXTURE_VIEW_DIMENSION_2D);
    return wgpu_texture_create_view(texture, desc);
}

# ================================================================
# Upload — wraps wgpuQueueWriteTexture
# ================================================================

# Upload a tightly packed RGBA8 buffer into a texture.
#   bytes_per_row = width × 4 (caller can override for aligned uploads)
# Zero-dimension short-circuits the FFI; negative or past-i32 dimensions
# are rejected (WebGPU texture extents are u32). See audit MED-3.
fn texture_upload_rgba8(queue, texture, data, width, height): i64 {
    if (width <= 0) { return 0; }
    if (height <= 0) { return 0; }
    if (width > 0x7FFFFFFF) { return 0; }
    if (height > 0x7FFFFFFF) { return 0; }
    var dest = wgpu_texel_copy_texture_info(texture, 0);
    var layout = wgpu_texel_copy_buffer_layout(0, width * 4, height);
    var size = wgpu_extent_3d(width, height, 1);
    var data_size = width * height * 4;
    wgpu_queue_write_texture(queue, dest, data, data_size, layout, size);
    return 0;
}

# ================================================================
# Convenience: RGBA8 texture + view + upload in one call
# ================================================================
# Caller must supply a tightly packed (width × height × 4) byte buffer.
# Returns a Texture struct with texture + view populated (sampler = 0).
fn texture_from_rgba(device, queue, rgba_ptr, width, height, label): i64 {
    var tex = texture_create_rgba8(device, width, height, label);
    if (tex == 0) { return 0; }
    var view = texture_view_create_rgba8(tex, label);
    texture_upload_rgba8(queue, tex, rgba_ptr, width, height);
    var t = alloc(32);
    store64(t + 0,  tex);
    store64(t + 8,  view);
    store64(t + 16, 0);
    store32(t + 24, width);
    store32(t + 28, height);
    return t;
}

# Clamp an f64 component to the WebGPU-valid colour range [0.0, 1.0].
# Audit LOW-6 — without this, f64 components outside [0,1] truncate
# to wrapping u8 values (1.5 → 382 → 126; -0.5 → -127 → 129).
fn _clamp_unit(v): i64 {
    if (f64_lt(v, F64_0) == 1) { return F64_0; }
    if (f64_gt(v, F64_1) == 1) { return F64_1; }
    return v;
}

# Create a 1×1 solid-color texture from a Color struct.
# Components outside [0.0, 1.0] are clamped before the u8 conversion
# so out-of-range values produce a defined edge-of-gamut pixel rather
# than a wrapped garbage one. Audit LOW-6.
fn texture_from_color(device, queue, color): i64 {
    var rgba[4];
    store8(&rgba,     f64_to(f64_mul(_clamp_unit(color_r(color)), F64_255)));
    store8(&rgba + 1, f64_to(f64_mul(_clamp_unit(color_g(color)), F64_255)));
    store8(&rgba + 2, f64_to(f64_mul(_clamp_unit(color_b(color)), F64_255)));
    store8(&rgba + 3, f64_to(f64_mul(_clamp_unit(color_a(color)), F64_255)));
    return texture_from_rgba(device, queue, &rgba, 1, 1, "solid_color");
}

# ================================================================
# Mip math (pure — no FFI)
# ================================================================

# Compute mip level count for a texture of given dimensions
fn mip_level_count(width, height): i64 {
    var max_dim = width;
    if (height > max_dim) { max_dim = height; }
    if (max_dim == 0) { return 1; }
    # floor(log2(max_dim)) + 1
    var levels = 1;
    var dim = max_dim;
    while (dim > 1) { dim = dim / 2; levels = levels + 1; }
    return levels;
}

# v3.1 [M.1]: dimension of `dim` at mip `level` (level 0 = full size).
# Halve once per level, floor, clamped to a minimum of 1 (the WebGPU /
# GFX9 convention — a 1px dimension stops halving). Shared by both
# backends' mip math.
fn mip_level_dim(dim, level): i64 {
    var d = dim;
    var i = 0;
    while (i < level) {
        d = d / 2;
        if (d < 1) { d = 1; }
        i = i + 1;
    }
    return d;
}

# Validate texture dimensions against device limit
fn validate_dimensions(width, height, max_dim): i64 {
    if (width > max_dim) { return GPU_ERR_TEXTURE_DIMENSION; }
    if (height > max_dim) { return GPU_ERR_TEXTURE_DIMENSION; }
    return 0;
}

# ================================================================
# TextureCache — keyed caching for loaded textures
# ================================================================
# v2.4.5 migrated from cstr-keyed to u64-keyed hashmap — zero allocation
# per lookup; see cyrius v5.5.20 CHANGELOG.

fn texture_cache_new(): i64 {
    return map_u64_new();
}

fn texture_cache_get(cache, key): i64 {
    return map_u64_get(cache, key);
}

fn texture_cache_set(cache, key, texture): i64 {
    map_u64_set(cache, key, texture);
    return 0;
}

fn texture_cache_has(cache, key): i64 {
    return map_u64_has(cache, key);
}

# ================================================================
# v3 Step 5.7 — public ctx-aware texture dispatchers
# ================================================================
# Public v3-shape API per docs/proposals/v3-native-api-principles.md:
# every operation that takes a ctx routes through ctx->backend->slot.
# Coexists with the v2.x texture_create_rgba8 / texture_release /
# etc. above, which retire at v5.1 alongside the wgpu path.
#
# Slot signatures (from docs/proposals/v3-backend-interface.md v1):
#   texture_create_2d_rgba8 (ctx, width, height)        → tex_ptr
#   texture_write           (ctx, tex_ptr, src, n)      → 0|err
#   texture_read            (ctx, tex_ptr, dst, n)      → 0|err
#   texture_release         (ctx, tex_ptr)              → 0
#
# Returns are backend-specific. wgpu wraps a 32-byte
# {handle, view, sampler, width|height} struct; native wraps a
# 32-byte NativeTexture (handle, va, addr, size). Caller treats
# tex_ptr as opaque.

fn gpu_texture_create_2d_rgba8(ctx, width, height): i64 {
    if (ctx == 0) { return 0; }
    # Audit 2026-06-14 [HIGH-1]: the v3 dispatcher must validate like its
    # v2 sibling texture_create_rgba8 — reject non-positive / out-of-bound
    # dims so an unvalidated width*height*4 never reaches the native
    # GEM_CREATE ioctl + mmap. The 8192 cap also bounds the multiply
    # (8192*8192*4 = 268 MiB — no i64 overflow).
    if (width <= 0)  { return 0; }
    if (height <= 0) { return 0; }
    if (validate_dimensions(width, height, MABDA_MAX_TEXTURE_DIM_2D) != 0) {
        return 0;
    }
    var slot = backend_get_slot(gpu_ctx_backend(ctx),
    BACKEND_SLOT_TEXTURE_CREATE_2D_RGBA8);
    return fncall3(slot, ctx, width, height);
}

# v3.2 [T.5]: format-parameterized 2D texture create. `fmt` is a
# MABDA_TEXFMT_* id. Returns an opaque backend tex_ptr, or 0 on invalid
# input. Validates dims (same guards as the rgba8 path) plus that `fmt` is
# a known format id (block_bytes != 0 — the format-supported guard; an
# unknown id is rejected before the FFI). Adapter-FAMILY support (does
# this adapter advertise BC/ETC2/ASTC) is the consumer's check via
# gpu_caps_supports_format; the wgpu backend slot (T.6) also rejects a
# family the adapter lacks. wgpu samples compressed; native stores +
# reads compressed but cannot sample it until Phase TS.
fn gpu_texture_create_2d(ctx, width, height, fmt): i64 {
    if (ctx == 0) { return 0; }
    if (width <= 0)  { return 0; }
    if (height <= 0) { return 0; }
    if (validate_dimensions(width, height, MABDA_MAX_TEXTURE_DIM_2D) != 0) {
        return 0;
    }
    if (mabda_texfmt_block_bytes(fmt) == 0) { return 0; }   # unknown format id
    var slot = backend_get_slot(gpu_ctx_backend(ctx),
    BACKEND_SLOT_TEXTURE_CREATE_2D_FMT);
    return fncall4(slot, ctx, width, height, fmt);
}

# v3.2 TS.3 — create a 2D texture that can be SAMPLED in a fragment shader
# (not just stored). Same validation as gpu_texture_create_2d; routes through
# the sampleable backend slot. On native: a tiled-or-linear BO + a T#/S#
# descriptor BO (TS.5/TS.7). On wgpu: a TEXTURE_BINDING view. Returns an
# opaque tex_ptr, or 0 on invalid dims/format or an unfilled backend slot
# (the slot's fillers land in TS.5, so this returns 0 until then).
fn gpu_texture_create_2d_sampleable(ctx, width, height, fmt): i64 {
    if (ctx == 0) { return 0; }
    if (width <= 0)  { return 0; }
    if (height <= 0) { return 0; }
    if (validate_dimensions(width, height, MABDA_MAX_TEXTURE_DIM_2D) != 0) {
        return 0;
    }
    if (mabda_texfmt_block_bytes(fmt) == 0) { return 0; }   # unknown format id
    var slot = backend_get_slot(gpu_ctx_backend(ctx),
    BACKEND_SLOT_TEXTURE_CREATE_2D_SAMPLEABLE);
    if (slot == 0) { return 0; }
    return fncall4(slot, ctx, width, height, fmt);
}

# v3.1 [M.6]: create a 2D RGBA8 texture with a mip chain. mip_count == 1
# is a single level (same as gpu_texture_create_2d_rgba8); mip_count == 0
# means "full chain" (floor(log2(max(w,h))) + 1). Levels are allocated but
# only level 0 is defined until gpu_texture_generate_mipmaps runs. Returns
# an opaque backend tex_ptr, or 0 on invalid input. Validates dims (same
# guards as the single-level path) plus the mip-count bound.
fn gpu_texture_create_2d_rgba8_mipped(ctx, width, height, mip_count): i64 {
    if (ctx == 0) { return 0; }
    if (width <= 0)  { return 0; }
    if (height <= 0) { return 0; }
    if (validate_dimensions(width, height, MABDA_MAX_TEXTURE_DIM_2D) != 0) {
        return 0;
    }
    var full = mip_level_count(width, height);
    var mc = mip_count;
    if (mc == 0) { mc = full; }       # 0 = full chain
    if (mc < 1) { return 0; }
    if (mc > full) { return 0; }      # can't exceed the natural chain length
    var slot = backend_get_slot(gpu_ctx_backend(ctx),
    BACKEND_SLOT_TEXTURE_CREATE_2D_RGBA8_MIPPED);
    return fncall4(slot, ctx, width, height, mc);
}

# v3.1 [M.6b]: fill mip levels 1..N-1 of `tex` (from gpu_texture_create_2d_rgba8_mipped)
# by GPU 2x2 box-filter downsample. Level 0 must already be written.
# Returns 0 on success or GPU_ERR_*. Native: real (one compute dispatch
# per level). wgpu returns GPU_ERR_NOT_IMPLEMENTED (deferred, see docs/development/roadmap.md)
# until the wgpu compute path lands; impl in _backend_wgpu_texture_generate_mipmaps.
fn gpu_texture_generate_mipmaps(ctx, tex): i64 {
    if (ctx == 0) { return GPU_ERR_OTHER; }
    if (tex == 0) { return GPU_ERR_OTHER; }
    var slot = backend_get_slot(gpu_ctx_backend(ctx),
    BACKEND_SLOT_TEXTURE_GENERATE_MIPMAPS);
    return fncall2(slot, ctx, tex);
}

fn gpu_texture_write(ctx, tex, src, n): i64 {
    if (ctx == 0) { return GPU_ERR_OTHER; }
    var slot = backend_get_slot(gpu_ctx_backend(ctx),
    BACKEND_SLOT_TEXTURE_WRITE);
    return fncall4(slot, ctx, tex, src, n);
}

fn gpu_texture_read(ctx, tex, dst, n): i64 {
    if (ctx == 0) { return GPU_ERR_OTHER; }
    var slot = backend_get_slot(gpu_ctx_backend(ctx),
    BACKEND_SLOT_TEXTURE_READ);
    return fncall4(slot, ctx, tex, dst, n);
}

fn gpu_texture_release(ctx, tex): i64 {
    if (ctx == 0) { return 0; }
    var slot = backend_get_slot(gpu_ctx_backend(ctx),
    BACKEND_SLOT_TEXTURE_RELEASE);
    return fncall2(slot, ctx, tex);
}

# --- render_target.cyr ---

# @public — stable API surface (survives the v3.0 backend swap)
# render_target.cyr — offscreen render target with optional MSAA and depth
# Ported from mabda/src/render_target.rs
#
# RenderTarget struct layout (64 bytes):
#   +0:  texture      (WGPUTexture, 8)
#   +8:  view         (WGPUTextureView, 8)
#   +16: format       (u32 WGPUTextureFormat)
#   +24: width        (i64)
#   +32: height       (i64)
#   +40: sample_count (i64)
#   +48: msaa_view    (WGPUTextureView or 0, 8)
#   +56: depth        (DepthTexture ptr or 0, 8)
# Audit 2026-06-14 [LOW-2]: total is 64 bytes (RENDER_TARGET_SIZE below),
# not 48 — the +48 msaa_view and +56 depth fields extend through byte 63.

var RENDER_TARGET_SIZE = 64;

# Accessors
fn render_target_texture(rt): i64 { return load64(rt); }
fn render_target_view(rt): i64 { return load64(rt + 8); }
fn render_target_format(rt): i64 { return load32(rt + 16); }
fn render_target_width(rt): i64 { return load64(rt + 24); }
fn render_target_height(rt): i64 { return load64(rt + 32); }
fn render_target_sample_count(rt): i64 { return load64(rt + 40); }
fn render_target_msaa_view(rt): i64 { return load64(rt + 48); }
fn render_target_depth(rt): i64 { return load64(rt + 56); }

# Get the view to render into (MSAA view if multisampled, else main view)
fn render_target_render_view(rt): i64 {
    var msaa = render_target_msaa_view(rt);
    if (msaa != 0) { return msaa; }
    return render_target_view(rt);
}

# Get the resolve target (main view if MSAA, else 0)
fn render_target_resolve(rt): i64 {
    var msaa = render_target_msaa_view(rt);
    if (msaa != 0) { return render_target_view(rt); }
    return 0;
}

# Get depth view (or 0)
fn render_target_depth_view(rt): i64 {
    var depth = render_target_depth(rt);
    if (depth == 0) { return 0; }
    return depth_texture_view(depth);
}

# ================================================================
# RenderTargetBuilder
# ================================================================
#
# Builder struct layout (32 bytes):
#   +0:  width (i64)
#   +8:  height (i64)
#   +16: format (u32)
#   +20: sample_count (u32)
#   +24: depth_format (u32, 0 = no depth)

fn rtb_new(width, height): i64 {
    var b = alloc(32);
    memset(b, 0, 32);
    store64(b, width);
    store64(b + 8, height);
    store32(b + 16, WGPU_TEXTURE_FORMAT_RGBA8_UNORM_SRGB);
    store32(b + 20, 1);  # no MSAA by default
    return b;
}

fn rtb_format(b, format): i64 {
    store32(b + 16, format);
    return b;
}

fn rtb_msaa(b, sample_count): i64 {
    store32(b + 20, sample_count);
    return b;
}

fn rtb_depth(b, depth_format): i64 {
    store32(b + 24, depth_format);
    return b;
}

# Build — creates the real GPU texture + view(s) + optional depth attachment.
# Returns a RenderTarget ptr (GPU resources allocated) or 0 on failure.
#
# Single-sampled build: one texture (usage = RENDER_ATTACHMENT | TEXTURE_BINDING
# | COPY_SRC) + default view.
# MSAA build: a resolve-sided 1-sample texture (same usage, stored at `view`)
# PLUS an N-sample MSAA texture (RENDER_ATTACHMENT only — multisampled
# textures cannot carry TEXTURE_BINDING, wgpu rejects that combo) stored at
# `msaa_view`. The render-pass builder points `view` at the render target and
# `resolve_target` at the MSAA view to drive hardware resolve at pass end.
# With depth_format != 0, a matching depth_texture_new is attached at +56.
fn rtb_build(b, device): i64 {
    var width        = load64(b + 0);
    var height       = load64(b + 8);
    var format       = load32(b + 16);
    var sample_count = load32(b + 20);
    var depth_format = load32(b + 24);

    var rt = alloc(RENDER_TARGET_SIZE);
    memset(rt, 0, RENDER_TARGET_SIZE);
    store32(rt + 16, format);
    store64(rt + 24, width);
    store64(rt + 32, height);
    store64(rt + 40, sample_count);

    # --- Main (resolve-side on MSAA) texture — 1 sample ---
    var main_usage = WGPU_TEXTURE_USAGE_RENDER_ATTACHMENT
    | WGPU_TEXTURE_USAGE_TEXTURE_BINDING
    | WGPU_TEXTURE_USAGE_COPY_SRC;
    var main_desc = wgpu_texture_descriptor("render_target", main_usage,
    WGPU_TEXTURE_DIMENSION_2D, width, height, format);
    var main_tex = wgpu_device_create_texture(device, main_desc);
    if (main_tex == 0) { return 0; }
    var main_view_desc = wgpu_texture_view_descriptor(0, format,
    WGPU_TEXTURE_VIEW_DIMENSION_2D);
    var main_view = wgpu_texture_create_view(main_tex, main_view_desc);
    store64(rt + 0, main_tex);
    store64(rt + 8, main_view);

    # --- Optional MSAA texture (N samples, RENDER_ATTACHMENT only) ---
    if (sample_count > 1) {
        var msaa_usage = WGPU_TEXTURE_USAGE_RENDER_ATTACHMENT;
        var msaa_desc = wgpu_texture_descriptor("render_target_msaa",
        msaa_usage, WGPU_TEXTURE_DIMENSION_2D, width, height, format);
        # Override sampleCount @ +56 (wgpu_texture_descriptor bakes in 1).
        store32(msaa_desc + 56, sample_count);
        var msaa_tex = wgpu_device_create_texture(device, msaa_desc);
        if (msaa_tex != 0) {
            var msaa_view = wgpu_texture_create_view(msaa_tex, main_view_desc);
            store64(rt + 48, msaa_view);
        }
    }

    # --- Optional depth attachment ---
    if (depth_format != 0) {
        var depth = depth_texture_new(device, width, height, depth_format);
        store64(rt + 56, depth);
    }
    return rt;
}

# ================================================================
# v3 public dispatchers — Backend-routed render-target API (Step 6.9)
# ================================================================
# These dispatch through ctx->backend->render_target_* slots. They
# coexist with the v2.x rtb_* / render_target_* helpers above; v2.x
# wgpu programs that build their own RenderTarget directly continue
# to work, and new programs can use the dispatcher for backend-
# agnostic code. Returned rt_ptr is opaque (32-byte struct on both
# backends — see docs/proposals/v3-backend-interface.md v2.1).

fn gpu_render_target_create_2d_rgba8(ctx, width, height): i64 {
    if (ctx == 0) { return 0; }
    var b = gpu_ctx_backend(ctx);
    if (b == 0) { return 0; }
    var slot = backend_get_slot(b, BACKEND_SLOT_RENDER_TARGET_CREATE_2D_RGBA8);
    if (slot == 0) { return 0; }
    return fncall3(slot, ctx, width, height);
}

fn gpu_render_target_release(ctx, rt): i64 {
    if (ctx == 0) { return 0; }
    if (rt == 0) { return 0; }
    var b = gpu_ctx_backend(ctx);
    if (b == 0) { return 0; }
    var slot = backend_get_slot(b, BACKEND_SLOT_RENDER_TARGET_RELEASE);
    if (slot == 0) { return 0; }
    return fncall2(slot, ctx, rt);
}

# --- render_pipeline.cyr ---

# @public — stable API surface (survives the v3.0 backend swap)
# render_pipeline.cyr — render pipeline creation and draw commands
# Ported from mabda/src/render_pipeline.rs
#
# The WGPURenderPipelineDescriptor is the most complex struct in the wgpu
# API (168 bytes, verified via offsetof). To keep the Cyrius builder under
# the 6-parameter ceiling, we expose two entry points:
#
#   render_pipeline_create_simple(device, module, color_format)
#     — no vertex buffers, no depth, no MSAA, TriangleList, no cull, no blend
#       Matches what a full-screen triangle / fragment-only effect needs.
#
#   render_pipeline_create_from_config(device, config)
#     — accepts a heap-allocated RenderPipelineConfig struct for anything
#       beyond the simple case. See `rpc_new` / `rpc_*` setters below.
#
# The v29 render pipeline layout:
#   +0:   nextInChain                    (8)
#   +8:   label (StringView)             (16)
#   +24:  layout (WGPUPipelineLayout)    (8)  — null = auto-layout
#   +32:  vertex (WGPUVertexState)      (64)
#   +96:  primitive (WGPUPrimitiveState)(32)
#   +128: depthStencil (ptr, nullable)   (8)
#   +136: multisample (WGPUMultisampleState)(24)
#   +160: fragment (ptr, nullable)       (8)
#
# Primitive topology/cull/frontFace values (wgpu v29):
#   Topology::TriangleList = 4, LineList = 2, PointList = 1
#   FrontFace::CCW = 1
#   CullMode::None = 1, Back = 3, Front = 2

# ================================================================
# RenderPipeline struct + accessors (24 bytes)
# ================================================================
# Layout:
#   +0:  pipeline  (WGPURenderPipeline, 8)
#   +8:  reserved
#   +16: reserved
# We drop the old bind_group_layout array because the simple path uses
# auto-layout; complex cases set their own layout via rpc_layout.

fn render_pipeline_handle(rp): i64 { return load64(rp); }
fn render_pipeline_release(rp): i64 {
    var h = load64(rp);
    if (h != 0) { wgpu_render_pipeline_release(h); }
    store64(rp, 0);
    return 0;
}

# Kept for backward compatibility with the stub API — always returns 0.
fn render_pipeline_bgl(rp, idx): i64 { return 0; }
fn render_pipeline_layout_count(rp): i64 { return 0; }

# ================================================================
# Primitive topology / cull / front-face constants (wgpu v29)
# ================================================================
var WGPU_TOPOLOGY_POINT_LIST     = 1;
var WGPU_TOPOLOGY_LINE_LIST      = 2;
var WGPU_TOPOLOGY_LINE_STRIP     = 3;
var WGPU_TOPOLOGY_TRIANGLE_LIST  = 4;
var WGPU_TOPOLOGY_TRIANGLE_STRIP = 5;

var WGPU_FRONT_FACE_CCW = 1;
var WGPU_FRONT_FACE_CW  = 2;

var WGPU_CULL_MODE_NONE  = 1;
var WGPU_CULL_MODE_FRONT = 2;
var WGPU_CULL_MODE_BACK  = 3;

# WGPUColorWriteMask — bitmask. All = R|G|B|A = 0xF
var WGPU_COLOR_WRITE_MASK_NONE = 0x0;
var WGPU_COLOR_WRITE_MASK_ALL  = 0xF;

# ================================================================
# Internal helpers — descriptor struct initializers
# ================================================================

# Initialize a VertexState (64 bytes) at `dst` with just a module + entry.
# No vertex buffers, no constants. Suitable for full-screen effects.
fn _vertex_state_init(dst, module, entry_cstr): i64 {
    memset(dst, 0, 64);
    store64(dst + 8, module);
    wgpu_string_view(dst + 16, entry_cstr);
    # constantCount=0, constants=NULL, bufferCount=0, buffers=NULL — zeroed
    return 0;
}

# Initialize a PrimitiveState (32 bytes) at `dst`.
fn _primitive_state_init(dst, topology, front_face, cull_mode): i64 {
    memset(dst, 0, 32);
    store32(dst + 8,  topology);
    # stripIndexFormat at +12 stays 0 (Undefined)
    store32(dst + 16, front_face);
    store32(dst + 20, cull_mode);
    # unclippedDepth (WGPUBool at +24) stays 0
    return 0;
}

# Initialize a MultisampleState (24 bytes) at `dst`.
fn _multisample_state_init(dst, sample_count): i64 {
    memset(dst, 0, 24);
    store32(dst + 8,  sample_count);
    store32(dst + 12, 0xFFFFFFFF);  # mask = all bits set
    # alphaToCoverageEnabled at +16 stays 0 (false)
    return 0;
}

# Build a ColorTargetState (32 bytes). writeMask = All by default.
fn _color_target_state_new(format, blend_ptr): i64 {
    var t = alloc(32);
    memset(t, 0, 32);
    store32(t + 8,  format);
    store64(t + 16, blend_ptr);        # 0 = no blend
    store32(t + 24, WGPU_COLOR_WRITE_MASK_ALL);
    return t;
}

# Build a FragmentState (64 bytes) pointing at a single color target.
fn _fragment_state_new(module, entry_cstr, target_ptr): i64 {
    var f = alloc(64);
    memset(f, 0, 64);
    store64(f + 8,  module);
    wgpu_string_view(f + 16, entry_cstr);
    # constantCount=0, constants=NULL stays zeroed
    store64(f + 48, 1);                # targetCount = 1
    # targets is a pointer to an array of ColorTargetState; allocate the
    # 1-element array here so Cyrius owns the backing storage.
    var targets_array = alloc(32);
    memset(targets_array, 0, 32);
    # Copy the color target struct into the array slot
    memcpy(targets_array, target_ptr, 32);
    store64(f + 56, targets_array);
    return f;
}

# ================================================================
# render_pipeline_create_simple — minimal full-screen-style pipeline
# ================================================================
# - auto-layout (no bind groups needed for the simple case)
# - TriangleList, CCW, no cull
# - No depth, no MSAA (sample_count=1)
# - Single color target with write-all mask, no blend
# - Vertex entry = "vs_main", fragment entry = "fs_main"
#
# Returns a RenderPipeline struct (24 bytes) with the handle populated,
# or 0 on failure.
fn render_pipeline_create_simple(device, module, color_format): i64 {
    # 1. Allocate the 168-byte descriptor and zero it
    var desc = alloc(168);
    memset(desc, 0, 168);

    # 2. label (optional — empty)
    wgpu_string_view_null(desc + 8);

    # 3. layout = NULL → auto-layout
    store64(desc + 24, 0);

    # 4. Embedded VertexState at +32
    _vertex_state_init(desc + 32, module, "vs_main");

    # 5. Embedded PrimitiveState at +96
    _primitive_state_init(desc + 96, WGPU_TOPOLOGY_TRIANGLE_LIST,
    WGPU_FRONT_FACE_CCW, WGPU_CULL_MODE_NONE);

    # 6. depthStencil pointer at +128 = NULL (no depth)
    store64(desc + 128, 0);

    # 7. Embedded MultisampleState at +136
    _multisample_state_init(desc + 136, 1);

    # 8. FragmentState pointer at +160
    var color_target = _color_target_state_new(color_format, 0);
    var fragment = _fragment_state_new(module, "fs_main", color_target);
    store64(desc + 160, fragment);

    # 9. Create the pipeline
    var handle = wgpu_device_create_render_pipeline(device, desc);
    if (handle == 0) { return 0; }

    var rp = alloc(24);
    store64(rp, handle);
    store64(rp + 8, 0);
    store64(rp + 16, 0);
    return rp;
}

# ================================================================
# DrawCommand (40 bytes) — unchanged from the stub
# ================================================================

var DRAW_CMD_DRAW             = 0;
var DRAW_CMD_DRAW_INDEXED     = 1;
var DRAW_CMD_INDIRECT         = 2;
var DRAW_CMD_INDEXED_INDIRECT = 3;

fn draw_cmd_draw(vertex_count, instance_count): i64 {
    var cmd = alloc(40);
    store64(cmd, DRAW_CMD_DRAW);
    store64(cmd + 8, vertex_count);
    store64(cmd + 16, instance_count);
    store64(cmd + 24, 0);
    store64(cmd + 32, 0);
    return cmd;
}

fn draw_cmd_draw_indexed(index_count, instance_count, first_index, base_vertex, first_instance): i64 {
    var cmd = alloc(40);
    store64(cmd, DRAW_CMD_DRAW_INDEXED);
    store64(cmd + 8, index_count);
    store64(cmd + 16, instance_count);
    store64(cmd + 24, first_index);
    store64(cmd + 32, base_vertex);
    return cmd;
}

# ================================================================
# Legacy RenderPipelineBuilder — kept for API compatibility
# ================================================================
#
# The old builder API is preserved but `rpb_build` now delegates to
# `render_pipeline_create_simple` internally. Callers that previously
# configured the builder fields (vertex layouts, bind groups, blend)
# will still compile but only the minimal-path fields take effect.
#
# Builder struct layout (80 bytes) — field map unchanged.

# Builder allocation bumped from 80 → 88 bytes in 2.3.0: the label field
# at +76 is 8 bytes wide and used to overflow the last 4 bytes of the
# 80-byte slab. See docs/audit/2026-04-19-audit.md HIGH-2.
fn rpb_new(device, shader_source, vs_entry): i64 {
    var b = alloc(88);
    memset(b, 0, 88);
    store64(b, device);
    store64(b + 8, shader_source);
    store64(b + 16, vs_entry);
    store32(b + 32, WGPU_TEXTURE_FORMAT_BGRA8_UNORM_SRGB);
    store32(b + 52, WGPU_TOPOLOGY_TRIANGLE_LIST);
    store32(b + 56, 1);
    store64(b + 60, vec_new());
    store64(b + 68, vec_new());
    return b;
}

fn rpb_fragment_entry(b, entry): i64 { store64(b + 24, entry); return b; }
fn rpb_color_target(b, format, blend_ptr): i64 {
    store32(b + 32, format);
    store64(b + 36, blend_ptr);
    return b;
}
fn rpb_depth(b, format): i64 { store32(b + 44, format); return b; }
fn rpb_cull_mode(b, mode): i64 { store32(b + 48, mode); return b; }
fn rpb_topology(b, topo): i64 { store32(b + 52, topo); return b; }
fn rpb_multisample(b, count): i64 { store32(b + 56, count); return b; }
fn rpb_label(b, label): i64 { store64(b + 76, label); return b; }

fn rpb_bind_group(b, bgl): i64 {
    vec_push(load64(b + 60), bgl);
    return b;
}

fn rpb_vertex_layout(b, layout_ptr): i64 {
    vec_push(load64(b + 68), layout_ptr);
    return b;
}

# Build — delegates to the simple path. The builder's additional knobs
# (vertex layouts, bind groups, depth, blend) are ignored on this path.
# To use them, construct the descriptor directly via the helpers above.
fn rpb_build(b): i64 {
    var device = load64(b + 0);
    # In the old builder, the caller passed a pre-compiled shader module as
    # `shader_source`. We preserve that — the field is labeled "source" but
    # is expected to hold the module handle in the current API.
    var module = load64(b + 8);
    var format = load32(b + 32);
    return render_pipeline_create_simple(device, module, format);
}

# ================================================================
# v3 public dispatchers — Backend-routed render-pipeline API (Step 6.9)
# ================================================================
# These dispatch through ctx->backend->render_pipeline_* slots. They
# coexist with the v2.x render_pipeline_create_simple / rpb_* path —
# the v2.x path returns a 24-byte struct holding handle+layout+bgl;
# the v3 path returns whatever shape the backend chose (16 bytes on
# wgpu — handle only; native uses pipeline_sh_block + pipeline_ctx_block).
# Slot signatures from docs/proposals/v3-backend-interface.md v2.1.

fn gpu_render_pipeline_create(ctx, vs_mod, fs_mod, color_fmt): i64 {
    if (ctx == 0) { return 0; }
    if (vs_mod == 0) { return 0; }
    if (fs_mod == 0) { return 0; }
    var b = gpu_ctx_backend(ctx);
    if (b == 0) { return 0; }
    var slot = backend_get_slot(b, BACKEND_SLOT_RENDER_PIPELINE_CREATE);
    if (slot == 0) { return 0; }
    return fncall4(slot, ctx, vs_mod, fs_mod, color_fmt);
}

fn gpu_render_pipeline_release(ctx, pipe): i64 {
    if (ctx == 0) { return 0; }
    if (pipe == 0) { return 0; }
    var b = gpu_ctx_backend(ctx);
    if (b == 0) { return 0; }
    var slot = backend_get_slot(b, BACKEND_SLOT_RENDER_PIPELINE_RELEASE);
    if (slot == 0) { return 0; }
    return fncall2(slot, ctx, pipe);
}

# --- render_pass.cyr ---

# @public — stable API surface (survives the v3.0 backend swap)
# render_pass.cyr — render pass builder
# Ported from mabda/src/render_pass.rs
#
# Fluent builder for configuring render pass color and depth attachments.
# Each color attachment is stored in v29-compatible layout (72 bytes, matching
# WGPURenderPassColorAttachment) so the C shim can pass the packed array
# through to wgpu-native without repacking.
#
# RenderPassBuilder struct layout (48 bytes):
#   +0:  label (cstr ptr, 8)
#   +8:  color_attachments (vec of attachment ptrs)
#   +16: depth_view (WGPUTextureView or 0, 8)
#   +24: depth_clear (f32 bit pattern — default 1.0)
#   +28: depth_load_op (u32 — Clear or Load)
#   +32: stencil_clear (u32)
#
# ColorAttachment (72 bytes — matches v29 WGPURenderPassColorAttachment):
#   +0:  nextInChain (8) — always 0
#   +8:  view (WGPUTextureView, 8)
#   +16: depthSlice (u32) + 4 pad
#   +24: resolveTarget (WGPUTextureView or 0, 8)
#   +32: loadOp (u32)
#   +36: storeOp (u32)
#   +40: clearValue (WGPUColor = 32 bytes: r,g,b,a as f64)

var COLOR_ATTACHMENT_SIZE = 72;

fn rpb_pass_new(): i64 {
    var b = alloc(48);
    memset(b, 0, 48);
    store64(b + 8, vec_new());
    # depth_clear = 1.0 as f32
    store32(b + 24, 0x3F800000);
    store32(b + 28, WGPU_LOAD_OP_CLEAR);
    return b;
}

fn rpb_pass_label(b, label): i64 { store64(b, label); return b; }

# Add a color attachment (clear with given color, or load existing)
fn rpb_pass_color(b, view, clear_color): i64 {
    var att = alloc(COLOR_ATTACHMENT_SIZE);
    memset(att, 0, COLOR_ATTACHMENT_SIZE);
    store64(att + 8, view);
    store32(att + 16, 0xFFFFFFFF);  # depthSlice = WGPU_DEPTH_SLICE_UNDEFINED
    if (clear_color != 0) {
        store32(att + 32, WGPU_LOAD_OP_CLEAR);
        store32(att + 36, WGPU_STORE_OP_STORE);
        color_write_f64(clear_color, att + 40);
    } else {
        store32(att + 32, WGPU_LOAD_OP_LOAD);
        store32(att + 36, WGPU_STORE_OP_STORE);
    }
    vec_push(load64(b + 8), att);
    return b;
}

# Add a color attachment with MSAA resolve
fn rpb_pass_color_msaa(b, render_view, resolve_view, clear_color): i64 {
    var att = alloc(COLOR_ATTACHMENT_SIZE);
    memset(att, 0, COLOR_ATTACHMENT_SIZE);
    store64(att + 8, render_view);
    store32(att + 16, 0xFFFFFFFF);
    store64(att + 24, resolve_view);
    if (clear_color != 0) {
        store32(att + 32, WGPU_LOAD_OP_CLEAR);
        store32(att + 36, WGPU_STORE_OP_STORE);
        color_write_f64(clear_color, att + 40);
    } else {
        store32(att + 32, WGPU_LOAD_OP_LOAD);
        store32(att + 36, WGPU_STORE_OP_STORE);
    }
    vec_push(load64(b + 8), att);
    return b;
}

# Set depth attachment
fn rpb_pass_depth(b, depth_view): i64 {
    store64(b + 16, depth_view);
    return b;
}

# Set depth load op (LOAD instead of CLEAR)
fn rpb_pass_depth_load(b): i64 {
    store32(b + 28, WGPU_LOAD_OP_LOAD);
    return b;
}

# Get the color attachment count
fn rpb_pass_color_count(b): i64 {
    return vec_len(load64(b + 8));
}

# Get color attachment array pointer (for WGPURenderPassDescriptor)
fn rpb_pass_color_array(b): i64 {
    var attachments = load64(b + 8);
    var count = vec_len(attachments);
    if (count == 0) { return 0; }
    # Build contiguous array
    var arr = alloc(count * COLOR_ATTACHMENT_SIZE);
    for (var i = 0; i < count; i = i + 1) {
        var src = vec_get(attachments, i);
        memcpy(arr + i * COLOR_ATTACHMENT_SIZE, src, COLOR_ATTACHMENT_SIZE);
    }
    return arr;
}

# Open a wgpu render pass against `encoder` from the configured builder `b`.
# Allocates a WgpuBeginPassArgs (40 bytes) that the C shim consumes — the
# packed color-attachment array is v29-layout-compatible and flows straight
# through. Returns the WGPURenderPassEncoder handle (0 if encoder is null or
# no color attachments are configured — wgpu rejects empty descriptors).
#
# WgpuBeginPassArgs layout (40 bytes, mirrors deps/wgpu_main.c):
#   +0:  color_attachments      (ptr)
#   +8:  color_attachment_count (u64)
#   +16: depth_stencil          (ptr or 0)
#   +24: timestamp_writes       (ptr or 0)
#   +32: label                  (cstr or 0)
fn rpb_pass_begin(encoder, b): i64 {
    if (encoder == 0) { return 0; }
    var count = rpb_pass_color_count(b);
    if (count == 0) { return 0; }
    var arr = rpb_pass_color_array(b);
    var args = alloc(40);
    memset(args, 0, 40);
    store64(args + 0,  arr);
    store64(args + 8,  count);
    # depth_stencil + timestamp_writes left NULL — out of scope here (see docs/development/roadmap.md)
    # (depth attachment storage in the builder is retained for v2.5 usage;
    # the dispatcher will grow a depth-stencil pack when the render graph
    # consumes it).
    store64(args + 32, load64(b));  # label
    return wgpu_command_encoder_begin_render_pass(encoder, args);
}

# ================================================================
# v3 public dispatchers — Backend-routed render-pass API (Step 6.9)
# ================================================================
# These dispatch through ctx->backend->render_pass_* slots. They
# coexist with the v2.x rpb_pass_* builder path. The v2 slot
# interface clears on every pass-begin (load_op = preserve is a
# v2.1 expansion); for the v2.x preserve case use rpb_pass_color
# with clear_color = 0 instead. clear_color_ptr is a 32-byte f64
# RGBA block (mabda Color shape — same as WGPUColor in webgpu.h v29).
# Slot signatures from docs/proposals/v3-backend-interface.md v2.1.

fn gpu_render_pass_begin(ctx, rt, clear_color_ptr): i64 {
    if (ctx == 0) { return 0; }
    if (rt == 0) { return 0; }
    if (clear_color_ptr == 0) { return 0; }
    var b = gpu_ctx_backend(ctx);
    if (b == 0) { return 0; }
    var slot = backend_get_slot(b, BACKEND_SLOT_RENDER_PASS_BEGIN);
    if (slot == 0) { return 0; }
    return fncall3(slot, ctx, rt, clear_color_ptr);
}

fn gpu_render_pass_draw(ctx, pass, pipe, vertex_count, instance_count): i64 {
    if (ctx == 0)  { return GPU_ERR_OTHER; }
    if (pass == 0) { return GPU_ERR_OTHER; }
    if (pipe == 0) { return GPU_ERR_OTHER; }
    var b = gpu_ctx_backend(ctx);
    if (b == 0)    { return GPU_ERR_OTHER; }
    var slot = backend_get_slot(b, BACKEND_SLOT_RENDER_PASS_DRAW);
    if (slot == 0) { return GPU_ERR_OTHER; }
    return fncall5(slot, ctx, pass, pipe, vertex_count, instance_count);
}

fn gpu_render_pass_end(ctx, pass): i64 {
    if (ctx == 0) { return 0; }
    if (pass == 0) { return 0; }
    var b = gpu_ctx_backend(ctx);
    if (b == 0) { return 0; }
    var slot = backend_get_slot(b, BACKEND_SLOT_RENDER_PASS_END);
    if (slot == 0) { return 0; }
    return fncall2(slot, ctx, pass);
}

# v3.2 TS.3 — bind a sampleable texture + sampler into a render pass so the
# bound pipeline's FS samples it. `tex` is from gpu_texture_create_2d_sampleable,
# `sampler` from gpu_sampler_create. Routes through the bind_for_sample slot:
# native stashes the bound tex on the pass (NATIVE_PASS_FIELD_BOUND_TEX) so the
# next draw emits the PS USER_DATA SET_SH_REG (descriptor VA) + adds the surface
# BO to residency; wgpu builds the bind group. Returns 0|GPU_ERR_*.
fn gpu_render_pass_bind_texture(ctx, pass, tex, sampler): i64 {
    if (ctx == 0)  { return GPU_ERR_OTHER; }
    if (pass == 0) { return GPU_ERR_OTHER; }
    if (tex == 0)  { return GPU_ERR_TEXTURE; }
    var b = gpu_ctx_backend(ctx);
    if (b == 0)    { return GPU_ERR_OTHER; }
    var slot = backend_get_slot(b, BACKEND_SLOT_TEXTURE_BIND_FOR_SAMPLE);
    if (slot == 0) { return GPU_ERR_NOT_IMPLEMENTED; }  #skip-lint
    return fncall4(slot, ctx, pass, tex, sampler);
}

# --- queue.cyr ---

# @public — multi-queue coordination (v3.1 Phase Q)
# queue.cyr — logical GPU queue abstraction dispatched through the
# ctx->backend queue slots.
#
# A "logical queue" is a handle the caller asks for by kind
# (GRAPHICS / COMPUTE / TRANSFER) and then targets work onto. The two
# backends realize the abstraction very differently:
#
#   native (AMD): each kind maps to a real hardware ring —
#       GRAPHICS -> GFX ring, COMPUTE -> COMPUTE ring. TRANSFER shares
#       the COMPUTE ring in 3.1.1; the SDMA COPY_LINEAR path is HW-proven
#       (Q.5, programs/native_sdma_copy_e2e.cyr) but the TRANSFER->SDMA
#       flip lands with the public buffer-copy op in 3.1.2. Each logical
#       Queue carries a *persistent* timeline
#       syncobj so cross-ring ordering (gpu_queue_barrier, Q.4) is a
#       WAIT-in / SIGNAL-out on the queue's monotonic timeline point,
#       and genuine GFX/COMPUTE overlap is possible.
#
#   wgpu: WebGPU exposes a single device queue. All three logical
#       queues alias that one WGPUQueue (Q.2); there is NO real
#       overlap. gpu_queue_barrier degrades to a submit-ordering pin
#       and gpu_queue_wait_idle to a device poll. This is the
#       documented wgpu limitation, mirroring how wgpu compute is a
#       stub today — consumers that need true multi-queue use the
#       native backend.
#
# Q.1 lands the layout only: the Queue struct, the kind constants, the
# ctx-side queue table, and the public dispatchers (null-slot-guarded
# so they are safe to call before the fillers exist). The wgpu fillers
# + the backend_is_complete() walk over the queue range land in Q.2;
# the native fillers + timeline accounting in Q.3.
#
# Proposal: docs/proposals/v3.1-multiqueue.md.

# ================================================================
# Queue-kind constants
# ================================================================
# Stable ABI — callers pass these to gpu_queue_get(). Values are the
# native ring-preference order (GFX first). QUEUE_KIND_COUNT bounds
# the ctx-side queue table and validates caller input.
var QUEUE_KIND_GRAPHICS = 0;
var QUEUE_KIND_COMPUTE  = 1;
var QUEUE_KIND_TRANSFER = 2;
var QUEUE_KIND_COUNT    = 3;

# ================================================================
# Queue struct layout (32 bytes)
# ================================================================
#   +0:  kind             QUEUE_KIND_* (invariant per queue)
#   +8:  ring_handle      native: AMDGPU_HW_IP_* ring id for the kind.
#                         wgpu  : the aliased WGPUQueue handle.
#   +16: timeline_syncobj native: persistent timeline syncobj handle
#                         (created once in Q.3, replaces the ephemeral
#                         per-dispatch syncobj on the queue-targeted
#                         path). wgpu: 0 (ordering is submit-order).
#   +24: timeline_point   monotonic u64 — last point signalled on this
#                         queue's timeline. Bumped per queue-targeted
#                         submit (Q.3); read by gpu_queue_barrier (Q.4).
#   +32: pending_wait_syncobj  Q.4 — a cross-ring dependency recorded by
#                         gpu_queue_barrier on the CONSUMER queue. The
#                         consumer's NEXT queue-targeted submit adds an
#                         in-CS TIMELINE_WAIT on (this syncobj, point),
#                         then clears both. 0 = no pending dependency.
#   +40: pending_wait_point    Q.4 — the producer timeline point this
#                         queue's next submit must wait for.
var QUEUE_OFF_KIND         = 0;
var QUEUE_OFF_RING         = 8;
var QUEUE_OFF_SYNCOBJ      = 16;
var QUEUE_OFF_POINT        = 24;
var QUEUE_OFF_PEND_SYNCOBJ = 32;
var QUEUE_OFF_PEND_POINT   = 40;
var QUEUE_STRUCT_SIZE      = 48;

# Allocate a zero-initialized Queue of the given kind. ring_handle,
# timeline_syncobj, and timeline_point stay zero until the backend
# filler binds them (Q.2 / Q.3).
fn queue_new(kind): i64 {
    var q = alloc(QUEUE_STRUCT_SIZE);
    memset(q, 0, QUEUE_STRUCT_SIZE);
    store64(q + QUEUE_OFF_KIND, kind);
    return q;
}

fn queue_kind(q): i64 {
    if (q == 0) { return -1; }
    return load64(q + QUEUE_OFF_KIND);
}
fn queue_ring(q): i64 {
    if (q == 0) { return 0; }
    return load64(q + QUEUE_OFF_RING);
}
fn queue_syncobj(q): i64 {
    if (q == 0) { return 0; }
    return load64(q + QUEUE_OFF_SYNCOBJ);
}
fn queue_point(q): i64 {
    if (q == 0) { return 0; }
    return load64(q + QUEUE_OFF_POINT);
}

fn queue_set_ring(q, ring): i64 {
    if (q == 0) { return -1; }
    store64(q + QUEUE_OFF_RING, ring);
    return 0;
}
fn queue_set_syncobj(q, syncobj): i64 {
    if (q == 0) { return -1; }
    store64(q + QUEUE_OFF_SYNCOBJ, syncobj);
    return 0;
}
fn queue_set_point(q, point): i64 {
    if (q == 0) { return -1; }
    store64(q + QUEUE_OFF_POINT, point);
    return 0;
}
# Increment and return the queue's timeline point. The native submit
# path (Q.3) calls this to get the next SIGNAL value for a dispatch.
fn queue_bump_point(q): i64 {
    if (q == 0) { return -1; }
    var p = load64(q + QUEUE_OFF_POINT) + 1;
    store64(q + QUEUE_OFF_POINT, p);
    return p;
}

# Pending cross-ring wait dependency (Q.4). gpu_queue_barrier records
# (producer syncobj, producer point) on the CONSUMER queue; the
# consumer's next queue-targeted submit reads these, adds an in-CS
# TIMELINE_WAIT, and clears them. syncobj == 0 means "no pending wait".
fn queue_pending_wait_syncobj(q): i64 {
    if (q == 0) { return 0; }
    return load64(q + QUEUE_OFF_PEND_SYNCOBJ);
}
fn queue_pending_wait_point(q): i64 {
    if (q == 0) { return 0; }
    return load64(q + QUEUE_OFF_PEND_POINT);
}
fn queue_set_pending_wait(q, syncobj, point): i64 {
    if (q == 0) { return -1; }
    store64(q + QUEUE_OFF_PEND_SYNCOBJ, syncobj);
    store64(q + QUEUE_OFF_PEND_POINT, point);
    return 0;
}
fn queue_clear_pending_wait(q): i64 {
    if (q == 0) { return -1; }
    store64(q + QUEUE_OFF_PEND_SYNCOBJ, 0);
    store64(q + QUEUE_OFF_PEND_POINT, 0);
    return 0;
}

# ================================================================
# ctx-side queue table
# ================================================================
# One Queue* per kind plus a "current queue" stash, living OUTSIDE the
# +0..+24 dual-interpretation region (context.cyr documents the byte
# layout). The table is backend-agnostic: both backends populate it
# lazily through the queue_get slot, then read it back for dispatch
# routing (Q.3) and barriers (Q.4).
var CTX_OFF_QUEUE_GRAPHICS = 128;
var CTX_OFF_QUEUE_COMPUTE  = 136;
var CTX_OFF_QUEUE_TRANSFER = 144;
var CTX_OFF_QUEUE_CURRENT  = 152;

# Map a queue kind to its ctx table byte offset; -1 on bad kind.
fn _ctx_queue_table_off(kind): i64 {
    if (kind == QUEUE_KIND_GRAPHICS) { return CTX_OFF_QUEUE_GRAPHICS; }
    if (kind == QUEUE_KIND_COMPUTE)  { return CTX_OFF_QUEUE_COMPUTE; }
    if (kind == QUEUE_KIND_TRANSFER) { return CTX_OFF_QUEUE_TRANSFER; }
    return -1;
}

# Read the cached Queue* for a kind (0 if not yet created or bad kind).  #skip-lint
fn gpu_ctx_queue_slot(ctx, kind): i64 {
    if (ctx == 0) { return 0; }
    var off = _ctx_queue_table_off(kind);
    if (off < 0) { return 0; }
    return load64(ctx + off);
}
# Cache a Queue* for a kind on the ctx. Used by the queue_get fillers.
fn gpu_ctx_set_queue_slot(ctx, kind, q): i64 {
    if (ctx == 0) { return -1; }
    var off = _ctx_queue_table_off(kind);
    if (off < 0) { return -1; }
    store64(ctx + off, q);
    return 0;
}
# The "current queue" stash — which logical queue the next
# queue-targeted dispatch submits onto. Zero means "backend default
# ring" (the legacy single-ring path, preserving v3.0 behaviour).
fn gpu_ctx_current_queue(ctx): i64 {
    if (ctx == 0) { return 0; }
    return load64(ctx + CTX_OFF_QUEUE_CURRENT);
}
fn gpu_ctx_set_current_queue(ctx, q): i64 {
    if (ctx == 0) { return -1; }
    store64(ctx + CTX_OFF_QUEUE_CURRENT, q);
    return 0;
}

# ================================================================
# Public queue API — dispatch through ctx->backend queue slots
# ================================================================
# The slots are filled in Q.2 (wgpu) / Q.3 (native). Until then — and
# as defense-in-depth afterward — every dispatcher null-guards the slot
# and returns a fail-loud value rather than fncall'ing a zero pointer.

# Acquire the logical queue for `kind`. Returns a Queue* (opaque to
# the caller), or 0 on invalid input / unfilled backend. Idempotent:
# the backend caches one Queue per kind on the ctx and returns it.
fn gpu_queue_get(ctx, kind): i64 {
    if (ctx == 0) { return 0; }
    if (kind < 0) { return 0; }
    if (kind >= QUEUE_KIND_COUNT) { return 0; }
    var slot = backend_get_slot(gpu_ctx_backend(ctx), BACKEND_SLOT_QUEUE_GET);
    if (slot == 0) { return 0; }
    return fncall2(slot, ctx, kind);
}

# Order work on dst_queue after work already submitted on src_queue.
# native: cross-ring timeline WAIT-in / SIGNAL-out (Q.4). wgpu: submit
# ordering pin (no real overlap). Returns 0|GPU_ERR_*.
fn gpu_queue_barrier(ctx, src_queue, dst_queue): i64 {
    if (ctx == 0) { return GPU_ERR_OTHER; }
    if (src_queue == 0) { return GPU_ERR_OTHER; }
    if (dst_queue == 0) { return GPU_ERR_OTHER; }
    var slot = backend_get_slot(gpu_ctx_backend(ctx), BACKEND_SLOT_QUEUE_BARRIER);
    if (slot == 0) { return GPU_ERR_NOT_IMPLEMENTED; }  #skip-lint
    return fncall3(slot, ctx, src_queue, dst_queue);
}

# Block until all work submitted on `queue` has retired. native:
# syncobj wait on the queue's current timeline point. wgpu: device
# poll. Returns 0|GPU_ERR_*.
fn gpu_queue_wait_idle(ctx, queue): i64 {
    if (ctx == 0) { return GPU_ERR_OTHER; }
    if (queue == 0) { return GPU_ERR_OTHER; }
    var slot = backend_get_slot(gpu_ctx_backend(ctx), BACKEND_SLOT_QUEUE_WAIT_IDLE);
    if (slot == 0) { return GPU_ERR_NOT_IMPLEMENTED; }  #skip-lint
    return fncall2(slot, ctx, queue);
}

# v3.2 X.5 — copy `bytes` from src_buf to dst_buf on an explicit
# logical queue (caller chooses the ring; native requires a TRANSFER/
# DMA queue — the ring check lives in the native driver). Synchronous.
# Routes through the buffer_copy backend slot. Returns 0|GPU_ERR_*
# (GPU_ERR_NOT_IMPLEMENTED if the active backend has no filler wired).  #skip-lint
# gpu_buffer_copy is the implicit-queue convenience wrapper over this.
fn gpu_queue_transfer_copy(ctx, queue, src_buf, dst_buf, bytes): i64 {
    if (ctx == 0)   { return GPU_ERR_OTHER; }
    if (queue == 0) { return GPU_ERR_OTHER; }
    # 4-byte-multiple size — same uniform contract as gpu_buffer_copy
    # (audit 2026-06-15 HIGH-1: wgpu requires it, native is byte-granular).
    if ((bytes & 3) != 0) { return GPU_ERR_BUFFER; }
    var slot = backend_get_slot(gpu_ctx_backend(ctx), BACKEND_SLOT_BUFFER_COPY);
    if (slot == 0) { return GPU_ERR_NOT_IMPLEMENTED; }  #skip-lint
    return fncall5(slot, ctx, queue, src_buf, dst_buf, bytes);
}

# --- render_graph.cyr ---

# @public — stable API surface (survives the v3.0 backend swap)
# render_graph.cyr — DAG pass orchestration
#
# First feature module of the v2.5.x line. Builds a directed acyclic
# graph of GPU passes (compute / render / copy) over a shared set of
# transient resources, topo-sorts the graph, and executes every pass
# into a SINGLE wgpu command encoder with ONE queue submit at the end.
#
# The module owns ORDERING. Synchronization and layout transitions are
# handled by wgpu-native; in v3.0 when we swap in a native backend,
# only the dispatch implementation underneath changes — the public
# builder API stays intact.
#
# Design notes:
# - Every struct is heap-allocated and stores field offsets in its
#   header comment. Vector fields are `vec_new` instances (8-byte
#   pointers to heap-owned growable vecs).
# - Kahn's algorithm for toposort. In-edges are inferred from the
#   reads/writes declarations on each node: if node A writes resource
#   R and node B reads R, B depends on A.
# - Transient resources (buffers / textures the graph owns for one
#   submission) are allocated at `rg_build` time and freed at
#   `rg_release`. Alias pass is scaffolded but OFF by default — alias
#   mode shares backing storage between transients with disjoint
#   lifetimes (follow-up work when a consumer asks; see docs/development/roadmap.md).
#
# Struct layouts:
#
# RenderGraph (48 bytes — grew 40→48 at v3.2.13 R.3, append-only):
#   +0:  nodes         (vec ptr, 8)   — vec of Node*
#   +8:  transients    (vec ptr, 8)   — vec of TransientResource*
#   +16: built_flag    (i64)          — 0 before rg_build, 1 after
#   +24: aliasing_flag (i64)          — 0 off (default), 1 on
#   +32: label         (cstr, 8)
#   +40: schedule      (ptr, 8)       — Schedule* (per-queue batches +
#                                       cross-queue fence edges), 0 before
#                                       rg_schedule. See the scheduler block.
#
# Node (80 bytes — grew 72→80 at v3.2.13 R.1, append-only):
#   +0:  kind            (i64 — NODE_* enum)
#   +8:  payload         (ptr, 8 — per-kind struct)
#   +16: reads           (vec ptr, 8 — i64 res_ids)
#   +24: writes          (vec ptr, 8 — i64 res_ids)
#   +32: label           (cstr, 8)
#   +40: in_degree       (i64 — toposort scratch)
#   +48: sort_idx        (i64 — index after rg_build; -1 if unsorted)
#   +56: queue_kind      (i64 — QUEUE_KIND_* affinity; reuses 8 of the
#                         old reserved-16 tail. Default per node kind:
#                         compute→QUEUE_KIND_COMPUTE, render/copy→
#                         QUEUE_KIND_GRAPHICS — the v3.0 "default queue
#                         per op kind" rule. rg_node_queue overrides it.)
#   +64: batch_idx       (i64 — scheduler scratch: which per-queue batch
#                         this node lands in; -1 before rg_schedule. R.3.)
#
# ComputePayload (32 bytes):
#   +0:  pipeline    (WGPUComputePipeline struct ptr from compute.cyr)
#   +8:  bind_group  (WGPUBindGroup handle)
#   +16: dim_x       (u32)
#   +20: dim_y       (u32)
#   +24: dim_z       (u32)
#   +28: pad (4)
#
# RenderPayload (24 bytes):
#   +0:  pass_builder (RenderPassBuilder*)
#   +8:  pipeline     (WGPURenderPipeline handle or 0 for clear-only)
#   +16: draw_verts   (i64 — 0 = clear-only, else vertex_count)
#
# CopyBufBufPayload (40 bytes):
#   +0:  src          (WGPUBuffer)
#   +8:  src_off      (u64)
#   +16: dst          (WGPUBuffer)
#   +24: dst_off      (u64)
#   +32: size         (u64)
#
# CopyTexBufPayload (72 bytes — matches WgpuCopyTexToBufArgs in
# deps/wgpu_main.c, so we can pass the payload pointer directly to
# the FFI):
#   +0:  src_texture        (WGPUTexture)
#   +8:  src_mip_level      (u32)
#   +12: src_origin_x       (u32)
#   +16: src_origin_y       (u32)
#   +20: src_origin_z       (u32)
#   +24: aspect             (u32)
#   +28: pad (4)
#   +32: dst_buffer         (WGPUBuffer)
#   +40: dst_offset         (u64)
#   +48: dst_bytes_per_row  (u32)
#   +52: dst_rows_per_image (u32)
#   +56: copy_w             (u32)
#   +60: copy_h             (u32)
#   +64: copy_depth         (u32)
#   +68: pad (4)
#
# TransientResource (72 bytes, grew from 56 at v3 for aliasing planner):
#   +0:  kind         (i64 — RES_BUFFER or RES_TEXTURE)
#   +8:  handle       (WGPUBuffer or WGPUTexture — populated by rg_build)
#   +16: view         (WGPUTextureView for textures, 0 for buffers — populated by rg_build)
#   +24: size_w       (u64 — buffer size, or texture width)
#   +32: height       (u64 — 0 for buffer, texture height)
#   +40: format_usage (u64 — format << 32 | usage_flags)
#   +48: first_use    (i64 — node sort_idx of first user, -1 before scan)
#   +56: last_use     (i64 — node sort_idx of last user, -1 before scan)
#   +64: offset       (i64 — byte offset into the aliased block, set by planner)

var NODE_COMPUTE       = 1;
var NODE_RENDER        = 2;
var NODE_COPY_BUF_BUF  = 3;
var NODE_COPY_TEX_BUF  = 4;

var RES_BUFFER  = 1;
var RES_TEXTURE = 2;

# ================================================================
# Graph construction
# ================================================================

fn rg_new(): i64 {
    var g = alloc(48);
    memset(g, 0, 48);
    store64(g + 0,  vec_new());
    store64(g + 8,  vec_new());
    return g;
}

fn rg_label(g, label): i64 { store64(g + 32, label); return g; }
fn rg_aliasing(g, on): i64 { store64(g + 24, on); return g; }

fn rg_node_count(g): i64 { return vec_len(load64(g + 0)); }
fn rg_transient_count(g): i64 { return vec_len(load64(g + 8)); }
fn rg_is_built(g): i64 { return load64(g + 16); }

# Add a compute node. `dims_xyz` is a 12-byte packed (x, y, z) u32 triple.
# Returns the node_id (0-indexed); callers pass this to rg_node_reads /
# rg_node_writes to declare resource dependencies.
fn rg_add_compute(g, pipeline, bind_group, dims_xyz, label): i64 {
    var node = _rg_node_new(NODE_COMPUTE, label);
    var pl = alloc(32);
    memset(pl, 0, 32);
    store64(pl + 0,  pipeline);
    store64(pl + 8,  bind_group);
    store32(pl + 16, load32(dims_xyz + 0));
    store32(pl + 20, load32(dims_xyz + 4));
    store32(pl + 24, load32(dims_xyz + 8));
    store64(node + 8, pl);
    return _rg_append_node(g, node);
}

# Add a render node. `pass_builder` is the RenderPassBuilder that drives
# the pass (see src/render_pass.cyr). `pipeline` is optional; pass 0 for
# a clear-only pass. `draw_verts` is the vertex count to submit (0 for
# clear-only).
fn rg_add_render(g, pass_builder, pipeline, draw_verts, label): i64 {
    var node = _rg_node_new(NODE_RENDER, label);
    var pl = alloc(24);
    memset(pl, 0, 24);
    store64(pl + 0,  pass_builder);
    store64(pl + 8,  pipeline);
    store64(pl + 16, draw_verts);
    store64(node + 8, pl);
    return _rg_append_node(g, node);
}

# Add a buffer→buffer copy node.
fn rg_add_copy_buf_buf(g, src, src_off, dst, dst_off, size): i64 {
    var node = _rg_node_new(NODE_COPY_BUF_BUF, 0);
    var pl = alloc(40);
    store64(pl + 0,  src);
    store64(pl + 8,  src_off);
    store64(pl + 16, dst);
    store64(pl + 24, dst_off);
    store64(pl + 32, size);
    store64(node + 8, pl);
    return _rg_append_node(g, node);
}

# Add a texture→buffer copy node. `args` points to a 72-byte buffer
# matching WgpuCopyTexToBufArgs from deps/wgpu_main.c — see the header
# comment at the top of this file for the layout.
fn rg_add_copy_tex_buf(g, args): i64 {
    var node = _rg_node_new(NODE_COPY_TEX_BUF, 0);
    var pl = alloc(72);
    memcpy(pl, args, 72);
    store64(node + 8, pl);
    return _rg_append_node(g, node);
}

# Declare that `node_id` reads `res_id` during execution. Used for
# toposort edge inference (if any earlier node WROTE this resource,
# the current node depends on it).
fn rg_node_reads(g, node_id, res_id): i64 {
    if (node_id < 0) { return 0; }
    if (node_id >= rg_node_count(g)) { return 0; }
    var node = vec_get(load64(g + 0), node_id);
    vec_push(load64(node + 16), res_id);
    return 0;
}

fn rg_node_writes(g, node_id, res_id): i64 {
    if (node_id < 0) { return 0; }
    if (node_id >= rg_node_count(g)) { return 0; }
    var node = vec_get(load64(g + 0), node_id);
    vec_push(load64(node + 24), res_id);
    return 0;
}

# Declare the queue a node runs on (v3.2.13 R.1). `kind` is a
# QUEUE_KIND_* value (GRAPHICS / COMPUTE / TRANSFER). Omitting this call
# keeps the per-kind default (compute→COMPUTE, render/copy→GRAPHICS),
# which reproduces v2.5 ordering. Must be called before rg_build. On the
# wgpu backend affinity is informational (one device queue); on native
# it routes the node to the matching HW ring (consumed by the R.2/R.3
# scheduler). Returns 0 on success, 1 on a bad node_id or kind.
fn rg_node_queue(g, node_id, kind): i64 {
    if (node_id < 0) { return 1; }
    if (node_id >= rg_node_count(g)) { return 1; }
    if (kind < 0) { return 1; }
    if (kind >= QUEUE_KIND_COUNT) { return 1; }
    var node = vec_get(load64(g + 0), node_id);
    store64(node + 56, kind);
    return 0;
}

# Accessor: the queue affinity assigned to a node (QUEUE_KIND_*).
# Returns -1 on a bad node_id.
fn rg_node_queue_get(g, node_id): i64 {
    if (node_id < 0) { return 0 - 1; }
    if (node_id >= rg_node_count(g)) { return 0 - 1; }
    return load64(vec_get(load64(g + 0), node_id) + 56);
}

# Transient resources — the graph owns them between rg_build and
# rg_release. Size/format/usage are recorded here; actual GPU
# creation happens inside rg_build.

fn rg_add_transient_buffer(g, size, usage, label): i64 {
    var r = alloc(72);
    memset(r, 0, 72);
    store64(r + 0,  RES_BUFFER);
    store64(r + 24, size);
    store64(r + 40, usage);
    store64(r + 48, 0 - 1);
    store64(r + 56, 0 - 1);
    # label stashed in handle slot until rg_build replaces it
    store64(r + 8,  label);
    var res_id = vec_len(load64(g + 8));
    vec_push(load64(g + 8), r);
    return res_id;
}

fn rg_add_transient_texture(g, width, height, format, usage, label): i64 {
    var r = alloc(72);
    memset(r, 0, 72);
    store64(r + 0,  RES_TEXTURE);
    store64(r + 24, width);
    store64(r + 32, height);
    # Pack (format << 32) | usage so both fit in one field.
    store64(r + 40, (format * 0x100000000) | usage);
    store64(r + 48, 0 - 1);
    store64(r + 56, 0 - 1);
    store64(r + 8,  label);
    var res_id = vec_len(load64(g + 8));
    vec_push(load64(g + 8), r);
    return res_id;
}

# Accessor: post-build, returns the allocated handle for a transient.
fn rg_transient_handle(g, res_id): i64 {
    if (res_id < 0) { return 0; }
    if (res_id >= rg_transient_count(g)) { return 0; }
    return load64(vec_get(load64(g + 8), res_id) + 8);
}

# Accessor: post-build, returns the texture view for a transient
# texture (0 for buffers).
fn rg_transient_view(g, res_id): i64 {
    if (res_id < 0) { return 0; }
    if (res_id >= rg_transient_count(g)) { return 0; }
    return load64(vec_get(load64(g + 8), res_id) + 16);
}

# ================================================================
# Build — toposort + allocate transients
# ================================================================
# Kahn's algorithm: compute in-degree per node, repeatedly drain
# nodes with zero remaining in-degree, decrement their successors,
# repeat. Cycle is signalled by drain length < node count — we
# return 1 (error); callers should treat that like `is_err_result`.
#
# After toposort, transient resources are walked in sorted order to
# allocate their GPU-backed handles. Alias pass is reserved (flag is
# checked but does nothing until a consumer asks for aliasing).

fn rg_build(g, device): i64 {
    if (rg_is_built(g) == 1) { return 0; }

    var nodes = load64(g + 0);
    var n = vec_len(nodes);
    if (n == 0) {
        store64(g + 16, 1);
        return 0;
    }

    # --- Reset per-node in_degree + sort_idx ---
    var i = 0;
    while (i < n) {
        var node = vec_get(nodes, i);
        store64(node + 40, 0);
        store64(node + 48, 0 - 1);
        i = i + 1;
    }

    # --- Build in-degree. For every ordered pair (writer, reader)
    #     where writer precedes reader only in insertion order,
    #     we count the edge. We scan O(n^2) which is fine for the
    #     graph sizes consumers will build (dozens of nodes).
    var writer_i = 0;
    while (writer_i < n) {
        var writer = vec_get(nodes, writer_i);
        var writes = load64(writer + 24);
        var wcount = vec_len(writes);
        var wi = 0;
        while (wi < wcount) {
            var res = vec_get(writes, wi);
            var reader_i = 0;
            while (reader_i < n) {
                if (reader_i != writer_i) {
                    var reader = vec_get(nodes, reader_i);
                    var reads = load64(reader + 16);
                    var rcount = vec_len(reads);
                    var ri = 0;
                    while (ri < rcount) {
                        if (vec_get(reads, ri) == res) {
                            # Edge writer → reader. Only count once
                            # per edge: if this is the first read
                            # of this resource by this reader from
                            # this writer, increment.
                            if (writer_i < reader_i) {
                                store64(reader + 40,
                                load64(reader + 40) + 1);
                            }
                        }
                        ri = ri + 1;
                    }
                }
                reader_i = reader_i + 1;
            }
            wi = wi + 1;
        }
        writer_i = writer_i + 1;
    }

    # --- Kahn's: process nodes with in_degree == 0, decrement
    #     successors as they are drained. Sorted order is stored
    #     in a fresh vec appended to the graph (we reuse the
    #     existing nodes vec after clearing it — no, we'd lose
    #     the node pointers. Use a side vec instead, then swap.)
    var sorted = vec_new();
    var queue = vec_new();
    i = 0;
    while (i < n) {
        var node = vec_get(nodes, i);
        if (load64(node + 40) == 0) {
            vec_push(queue, i);
        }
        i = i + 1;
    }

    var qi = 0;
    while (qi < vec_len(queue)) {
        var cur_i = vec_get(queue, qi);
        var cur = vec_get(nodes, cur_i);
        store64(cur + 48, vec_len(sorted));
        vec_push(sorted, cur);

        # Decrement in-degree of successors. A successor is any
        # later-inserted node that reads a resource this one writes.
        var writes = load64(cur + 24);
        var wc = vec_len(writes);
        var wi2 = 0;
        while (wi2 < wc) {
            var rr = vec_get(writes, wi2);
            var si = cur_i + 1;
            while (si < n) {
                var succ = vec_get(nodes, si);
                var succ_reads = load64(succ + 16);
                var sc = vec_len(succ_reads);
                var ci = 0;
                while (ci < sc) {
                    if (vec_get(succ_reads, ci) == rr) {
                        var old = load64(succ + 40);
                        store64(succ + 40, old - 1);
                        if (old - 1 == 0) {
                            vec_push(queue, si);
                        }
                    }
                    ci = ci + 1;
                }
                si = si + 1;
            }
            wi2 = wi2 + 1;
        }
        qi = qi + 1;
    }

    # Cycle detection: if sorted length < node count, there's a cycle.
    if (vec_len(sorted) < n) {
        return 1;
    }

    # Install the sorted order back into the nodes vec by value copy
    # (the vec stores pointers; we overwrite in place with vec_set).
    var k = 0;
    while (k < n) {
        vec_set(nodes, k, vec_get(sorted, k));
        k = k + 1;
    }

    # --- Scan transient lifetimes: for every node in sorted order,
    #     for every resource in its reads+writes, update that
    #     transient's first_use = min(first_use, sort_idx) and
    #     last_use  = max(last_use, sort_idx). Transients that are
    #     never read or written stay at (first_use, last_use) = (-1, -1)
    #     and the planner treats them as dead.
    var transients = load64(g + 8);
    var t = vec_len(transients);
    var ni = 0;
    while (ni < n) {
        var node = vec_get(nodes, ni);
        var sort_idx = load64(node + 48);
        # Reads
        var reads_vec = load64(node + 16);
        var rcount = vec_len(reads_vec);
        var ri = 0;
        while (ri < rcount) {
            var res_id = vec_get(reads_vec, ri);
            if (res_id >= 0) {
                if (res_id < t) {
                    var r = vec_get(transients, res_id);
                    var fu = load64(r + 48);
                    if (fu == 0 - 1) { store64(r + 48, sort_idx); }
                    if (fu != 0 - 1) { if (sort_idx < fu) { store64(r + 48, sort_idx); } }
                    var lu = load64(r + 56);
                    if (lu == 0 - 1) { store64(r + 56, sort_idx); }
                    if (lu != 0 - 1) { if (sort_idx > lu) { store64(r + 56, sort_idx); } }
                }
            }
            ri = ri + 1;
        }
        # Writes — same update logic
        var writes_vec = load64(node + 24);
        var wcount = vec_len(writes_vec);
        var wi = 0;
        while (wi < wcount) {
            var res_id = vec_get(writes_vec, wi);
            if (res_id >= 0) {
                if (res_id < t) {
                    var r = vec_get(transients, res_id);
                    var fu = load64(r + 48);
                    if (fu == 0 - 1) { store64(r + 48, sort_idx); }
                    if (fu != 0 - 1) { if (sort_idx < fu) { store64(r + 48, sort_idx); } }
                    var lu = load64(r + 56);
                    if (lu == 0 - 1) { store64(r + 56, sort_idx); }
                    if (lu != 0 - 1) { if (sort_idx > lu) { store64(r + 56, sort_idx); } }
                }
            }
            wi = wi + 1;
        }
        ni = ni + 1;
    }

    # --- Allocate GPU resources per transient. The aliasing planner
    #     (rg_plan_aliasing_stats) can diagnose the memory the graph
    #     *would* save under full aliasing; actually applying aliasing
    #     to GPU memory lands in v3 Phase B (native backend). Today
    #     each transient gets its own wgpu handle regardless of the
    #     aliasing_flag value.
    var ti = 0;
    while (ti < t) {
        var r = vec_get(transients, ti);
        _rg_alloc_transient(r, device);
        ti = ti + 1;
    }

    store64(g + 16, 1);
    return 0;
}

# ================================================================
# Aliasing planner — v3 Phase A
# ================================================================
# Computes how much backing memory the transient set would occupy
# under optimal aliasing (disjoint-lifetime transients sharing a
# backing slot). Pure analysis; does not mutate the graph's GPU
# allocation. Phase B's native backend will call this during rg_build
# when rg_aliasing(g, 1) is set and place transients at the computed
# offsets inside a single BO.
#
# Algorithm: greedy interval coloring, per kind (buffers cannot alias
# textures and vice versa at the memory-type level). For each
# transient in first_use order, find the slot whose current occupant's
# last_use < this transient's first_use AND whose size >= this
# transient's size; reuse the tightest-fit match or open a new slot.
#
# Writes the chosen byte offset into each transient's `offset` field
# (byte 64). Stores the output stats at `out`:
#   +0:  slot_count    (i64) — total number of backing slots
#   +8:  naive_bytes   (i64) — sum of all transient sizes (no aliasing)
#   +16: aliased_bytes (i64) — block size under optimal aliasing
# Transients with first_use == -1 (never used) are skipped.
# Returns 0 on success.
#
# Byte size per kind: buffers use size_w directly; textures use
# width * height * 4 as a portable RGBA8 proxy. Format-aware sizing
# lands with Phase B's texture-format byte-width table.
#
# Alignment: 256 bytes, matches typical GPU storage-buffer binding
# alignment. Both naive and aliased totals respect it, so the reclaim
# ratio is apples-to-apples.
var _RG_PLAN_ALIGN = 256;

fn _rg_plan_transient_bytes(r): i64 {
    var kind = load64(r + 0);
    if (kind == RES_BUFFER) {
        return load64(r + 24);
    }
    # Texture: width * height * 4 (RGBA8 proxy).
    var w = load64(r + 24);
    var h = load64(r + 32);
    if (h == 0) { h = 1; }
    return w * h * 4;
}

fn _rg_plan_align_up(n, align): i64 {
    var rem = n % align;
    if (rem == 0) { return n; }
    return n + (align - rem);
}

# Per-kind planner. Call once with kind=RES_BUFFER then once with
# kind=RES_TEXTURE, summing results. Slots are tracked in two
# parallel vecs:
#   slot_offset (i64)
#   slot_size   (i64)
#   slot_until  (i64 — last_use of the current occupant; -1 = free)
fn _rg_plan_kind(g, kind, start_offset, out_slot_count): i64 {
    var transients = load64(g + 8);
    var t = vec_len(transients);
    if (t == 0) { store64(out_slot_count, 0); return start_offset; }

    # Collect live transients of this kind (first_use != -1).
    var live = vec_new();
    var ti = 0;
    while (ti < t) {
        var r = vec_get(transients, ti);
        if (load64(r + 0) == kind) {
            if (load64(r + 48) != 0 - 1) { vec_push(live, r); }
        }
        ti = ti + 1;
    }

    # Selection sort by first_use ascending. O(n²) but n is small
    # (typically dozens); good enough to land Phase A.
    var n_live = vec_len(live);
    var i = 0;
    while (i < n_live) {
        var min_j = i;
        var j = i + 1;
        while (j < n_live) {
            if (load64(vec_get(live, j) + 48) < load64(vec_get(live, min_j) + 48)) {
                min_j = j;
            }
            j = j + 1;
        }
        if (min_j != i) {
            var tmp = vec_get(live, i);
            vec_set(live, i, vec_get(live, min_j));
            vec_set(live, min_j, tmp);
        }
        i = i + 1;
    }

    # Greedy interval coloring: walk transients in first_use order,
    # reuse a slot whose occupant's last_use < this.first_use and
    # whose size >= this.size (tightest-fit), else open a new slot.
    var slot_offsets = vec_new();
    var slot_sizes   = vec_new();
    var slot_until   = vec_new();
    var cursor = start_offset;

    var si = 0;
    while (si < n_live) {
        var r2 = vec_get(live, si);
        var fu2 = load64(r2 + 48);
        var lu2 = load64(r2 + 56);
        var sz2 = _rg_plan_align_up(_rg_plan_transient_bytes(r2), _RG_PLAN_ALIGN);

        var best = 0 - 1;
        var best_size = 0 - 1;
        var k = 0;
        while (k < vec_len(slot_offsets)) {
            var u = vec_get(slot_until, k);
            if (u < fu2) {
                var slot_sz = vec_get(slot_sizes, k);
                if (slot_sz >= sz2) {
                    if (best == 0 - 1) { best = k; best_size = slot_sz; }
                    if (best != 0 - 1) {
                        if (slot_sz < best_size) { best = k; best_size = slot_sz; }
                    }
                }
            }
            k = k + 1;
        }

        if (best == 0 - 1) {
            store64(r2 + 64, cursor);
            vec_push(slot_offsets, cursor);
            vec_push(slot_sizes, sz2);
            vec_push(slot_until, lu2);
            cursor = cursor + sz2;
        } else {
            store64(r2 + 64, vec_get(slot_offsets, best));
            vec_set(slot_until, best, lu2);
        }
        si = si + 1;
    }

    store64(out_slot_count, vec_len(slot_offsets));
    return cursor;
}

# Public planner query. `out` must point to 24 bytes:
#   +0:  slot_count    (i64)
#   +8:  naive_bytes   (i64) — sum of all live transient sizes, aligned
#   +16: aliased_bytes (i64) — total block size under aliasing
# Sets each live transient's offset field as a side effect.
# Returns 0 on success, 1 if the graph is not yet built.   #skip-lint
fn rg_plan_aliasing_stats(g, out): i64 {
    if (rg_is_built(g) == 0) { return 1; }
    store64(out + 0, 0);
    store64(out + 8, 0);
    store64(out + 16, 0);

    # Naive bytes: sum of every live transient's aligned size.
    var transients = load64(g + 8);
    var t = vec_len(transients);
    var naive = 0;
    var ti = 0;
    while (ti < t) {
        var r = vec_get(transients, ti);
        if (load64(r + 48) != 0 - 1) {
            naive = naive + _rg_plan_align_up(_rg_plan_transient_bytes(r), _RG_PLAN_ALIGN);
        }
        ti = ti + 1;
    }

    # Per-kind planning. Offsets are disjoint across kinds (buffers
    # get [0, buf_end); textures start at buf_end). This is conservative
    # — real hardware might allow mixed allocations but requires
    # bufferImageGranularity handling that lives in Phase B.
    var buf_slots = alloc(8);
    store64(buf_slots, 0);
    var buf_end = _rg_plan_kind(g, RES_BUFFER, 0, buf_slots);

    var tex_slots = alloc(8);
    store64(tex_slots, 0);
    var tex_end = _rg_plan_kind(g, RES_TEXTURE, buf_end, tex_slots);

    store64(out + 0, load64(buf_slots) + load64(tex_slots));
    store64(out + 8, naive);
    store64(out + 16, tex_end);
    return 0;
}

# Accessor: byte offset assigned by the planner for a transient.
# Returns -1 if the graph isn't built or the planner hasn't run.
fn rg_transient_offset(g, res_id): i64 {
    if (res_id < 0) { return 0 - 1; }
    if (res_id >= rg_transient_count(g)) { return 0 - 1; }
    return load64(vec_get(load64(g + 8), res_id) + 64);
}

# Accessor: sort_idx of a transient's first user (-1 if unused).
fn rg_transient_first_use(g, res_id): i64 {
    if (res_id < 0) { return 0 - 1; }
    if (res_id >= rg_transient_count(g)) { return 0 - 1; }
    return load64(vec_get(load64(g + 8), res_id) + 48);
}

# Accessor: sort_idx of a transient's last user (-1 if unused).
fn rg_transient_last_use(g, res_id): i64 {
    if (res_id < 0) { return 0 - 1; }
    if (res_id >= rg_transient_count(g)) { return 0 - 1; }
    return load64(vec_get(load64(g + 8), res_id) + 56);
}

# ================================================================
# Scheduler — v3.2.13 Phase R (R.2 + R.3): the pass between rg_build
# and the multi-queue executor.
# ================================================================
# rg_schedule walks the (already topo-sorted) nodes and produces a
# Schedule: the per-queue node batches (R.3) and the cross-queue fence
# edges (R.2). It is pure graph math over the in-memory model — no FFI,
# no HW — so every step is CPU-assertable.
#
# Submission-order note (important for the R.4 native executor): the
# executor submits nodes in GLOBAL sort_idx order (the nodes vec order
# after rg_build), NOT batch-by-batch. Walking global sort_idx order is
# the toposort guarantee that every producer is submitted before its
# consumer — which the per-batch "ascending min-sort_idx" order in the
# proposal does NOT guarantee (an independent early node sharing a queue
# with a late consumer would submit the consumer's batch before a
# producer on another queue). The batches here exist for per-queue
# grouping (which queues to gpu_queue_get / gpu_queue_wait_idle) and the
# R.3 "submit batching" deliverable; the fence edges carry the real
# cross-queue ordering. (Deviation from the proposal's step 3, recorded
# in docs/development/3-2-punchlist.md Phase R.)
#
# Schedule (24 bytes):
#   +0:  batches    (vec ptr) — vec of Batch*, in ascending min-sort_idx
#                               order (= first-seen order, since nodes are
#                               walked in sort_idx order).
#   +8:  fences     (vec ptr) — vec of FenceEdge* (cross-queue edges).
#   +16: node_count (i64)     — total nodes scheduled (sanity / tests).
var SCHED_OFF_BATCHES   = 0;
var SCHED_OFF_FENCES    = 8;
var SCHED_OFF_NODECOUNT = 16;
var SCHED_SIZE          = 24;

# Batch (24 bytes):
#   +0:  queue_kind (i64 — QUEUE_KIND_*)
#   +8:  nodes      (vec ptr — Node*, in sort_idx order within the queue)
#   +16: min_sort   (i64 — smallest sort_idx in the batch; submit-order key)
var BATCH_OFF_QUEUE   = 0;
var BATCH_OFF_NODES   = 8;
var BATCH_OFF_MINSORT = 16;
var BATCH_SIZE        = 24;

# FenceEdge (32 bytes) — a writer→reader dependency whose endpoints sit
# on different queues. The R.4 executor turns each into a
# gpu_queue_barrier(producer_queue → consumer_queue) recorded before the
# consumer node's submit.
#   +0:  producer_queue (i64 — QUEUE_KIND_*)
#   +8:  producer_node  (i64 — producer sort_idx)
#   +16: consumer_queue (i64 — QUEUE_KIND_*)
#   +24: consumer_node  (i64 — consumer sort_idx)
var FENCE_OFF_PQ = 0;
var FENCE_OFF_PN = 8;
var FENCE_OFF_CQ = 16;
var FENCE_OFF_CN = 24;
var FENCE_SIZE   = 32;

var RG_OFF_SCHEDULE = 40;

# Find the index of the batch for `qk` in `batches`, or -1 if none.
fn _rg_batch_index_for(batches, qk): i64 {
    var k = 0;
    while (k < vec_len(batches)) {
        if (load64(vec_get(batches, k) + BATCH_OFF_QUEUE) == qk) { return k; }
        k = k + 1;
    }
    return 0 - 1;
}

# Does any resource in `writes` also appear in `reads`? (a writer→reader
# dependency between two nodes). 1 = yes, 0 = no.
fn _rg_nodes_share_dep(writes, reads): i64 {
    var wc = vec_len(writes);
    var rc = vec_len(reads);
    var wi = 0;
    while (wi < wc) {
        var res = vec_get(writes, wi);
        var ri = 0;
        while (ri < rc) {
            if (vec_get(reads, ri) == res) { return 1; }
            ri = ri + 1;
        }
        wi = wi + 1;
    }
    return 0;
}

# Has a fence edge for this (producer_node, consumer_node) pair already
# been recorded? (dedup — two shared resources between the same pair are
# one cross-queue dependency). 1 = exists, 0 = new.
fn _rg_fence_exists(fences, pn, cn): i64 {
    var k = 0;
    while (k < vec_len(fences)) {
        var fe = vec_get(fences, k);
        if (load64(fe + FENCE_OFF_PN) == pn) {
            if (load64(fe + FENCE_OFF_CN) == cn) { return 1; }
        }
        k = k + 1;
    }
    return 0;
}

# Build the Schedule. Requires rg_build first (returns 1 if unbuilt).
# Idempotent: a second call short-circuits to success. # @public
fn rg_schedule(g): i64 {
    if (rg_is_built(g) == 0) { return 1; }
    if (load64(g + RG_OFF_SCHEDULE) != 0) { return 0; }

    var nodes = load64(g + 0);
    var n = vec_len(nodes);

    var sched = alloc(SCHED_SIZE);
    memset(sched, 0, SCHED_SIZE);
    var batches = vec_new();
    var fences  = vec_new();
    store64(sched + SCHED_OFF_BATCHES, batches);
    store64(sched + SCHED_OFF_FENCES, fences);
    store64(sched + SCHED_OFF_NODECOUNT, n);

    # --- R.3: per-queue batch assignment. Nodes are in sort_idx order in
    #     the vec after rg_build, so first-seen order of each queue kind is
    #     its minimum sort_idx → batches come out in ascending min-sort.
    var i = 0;
    while (i < n) {
        var node = vec_get(nodes, i);
        var qk = load64(node + 56);
        var bidx = _rg_batch_index_for(batches, qk);
        if (bidx == 0 - 1) {
            var b = alloc(BATCH_SIZE);
            memset(b, 0, BATCH_SIZE);
            store64(b + BATCH_OFF_QUEUE, qk);
            store64(b + BATCH_OFF_NODES, vec_new());
            store64(b + BATCH_OFF_MINSORT, load64(node + 48));
            bidx = vec_len(batches);
            vec_push(batches, b);
        }
        var batch = vec_get(batches, bidx);
        vec_push(load64(batch + BATCH_OFF_NODES), node);
        store64(node + 64, bidx);
        i = i + 1;
    }

    # --- R.2: cross-queue edge classification. Re-scan writer→reader
    #     dependencies (same inference rg_build uses). A reader always
    #     follows its writer in sort_idx order, so we only look forward.
    #     Same-queue edges are satisfied by submit order; cross-queue
    #     edges become fence edges (deduped per producer/consumer pair).
    var writer_i = 0;
    while (writer_i < n) {
        var writer = vec_get(nodes, writer_i);
        var wq = load64(writer + 56);
        var writes = load64(writer + 24);
        var reader_i = writer_i + 1;
        while (reader_i < n) {
            var reader = vec_get(nodes, reader_i);
            var rq = load64(reader + 56);
            if (wq != rq) {
                if (_rg_nodes_share_dep(writes, load64(reader + 16)) == 1) {
                    if (_rg_fence_exists(fences, writer_i, reader_i) == 0) {
                        var fe = alloc(FENCE_SIZE);
                        store64(fe + FENCE_OFF_PQ, wq);
                        store64(fe + FENCE_OFF_PN, writer_i);
                        store64(fe + FENCE_OFF_CQ, rq);
                        store64(fe + FENCE_OFF_CN, reader_i);
                        vec_push(fences, fe);
                    }
                }
            }
            reader_i = reader_i + 1;
        }
        writer_i = writer_i + 1;
    }

    store64(g + RG_OFF_SCHEDULE, sched);
    return 0;
}

# 1 if rg_schedule has run on this graph, else 0.
fn rg_is_scheduled(g): i64 {
    if (load64(g + RG_OFF_SCHEDULE) == 0) { return 0; }
    return 1;
}

# --- Schedule accessors (post-rg_schedule). All return 0 / -1 on a bad
#     index or an unscheduled graph rather than dereferencing null. ---

fn _rg_sched(g): i64 { return load64(g + RG_OFF_SCHEDULE); }

# Number of per-queue batches (distinct queues used by the graph).
fn rg_schedule_batch_count(g): i64 {
    var s = _rg_sched(g);
    if (s == 0) { return 0; }
    return vec_len(load64(s + SCHED_OFF_BATCHES));
}

fn _rg_batch_at(g, bi): i64 {
    var s = _rg_sched(g);
    if (s == 0) { return 0; }
    var batches = load64(s + SCHED_OFF_BATCHES);
    if (bi < 0) { return 0; }
    if (bi >= vec_len(batches)) { return 0; }
    return vec_get(batches, bi);
}

# Queue kind of batch `bi` (-1 on bad index / unscheduled).
fn rg_schedule_batch_queue(g, bi): i64 {
    var b = _rg_batch_at(g, bi);
    if (b == 0) { return 0 - 1; }
    return load64(b + BATCH_OFF_QUEUE);
}

# Node count in batch `bi` (0 on bad index).
fn rg_schedule_batch_node_count(g, bi): i64 {
    var b = _rg_batch_at(g, bi);
    if (b == 0) { return 0; }
    return vec_len(load64(b + BATCH_OFF_NODES));
}

# Minimum sort_idx in batch `bi` — the submit-order key (-1 on bad index).
fn rg_schedule_batch_min_sort(g, bi): i64 {
    var b = _rg_batch_at(g, bi);
    if (b == 0) { return 0 - 1; }
    return load64(b + BATCH_OFF_MINSORT);
}

# Number of cross-queue fence edges.
fn rg_schedule_fence_count(g): i64 {
    var s = _rg_sched(g);
    if (s == 0) { return 0; }
    return vec_len(load64(s + SCHED_OFF_FENCES));
}

fn _rg_fence_at(g, fi): i64 {
    var s = _rg_sched(g);
    if (s == 0) { return 0; }
    var fences = load64(s + SCHED_OFF_FENCES);
    if (fi < 0) { return 0; }
    if (fi >= vec_len(fences)) { return 0; }
    return vec_get(fences, fi);
}

fn rg_schedule_fence_producer_queue(g, fi): i64 {
    var f = _rg_fence_at(g, fi);
    if (f == 0) { return 0 - 1; }
    return load64(f + FENCE_OFF_PQ);
}
fn rg_schedule_fence_producer_node(g, fi): i64 {
    var f = _rg_fence_at(g, fi);
    if (f == 0) { return 0 - 1; }
    return load64(f + FENCE_OFF_PN);
}
fn rg_schedule_fence_consumer_queue(g, fi): i64 {
    var f = _rg_fence_at(g, fi);
    if (f == 0) { return 0 - 1; }
    return load64(f + FENCE_OFF_CQ);
}
fn rg_schedule_fence_consumer_node(g, fi): i64 {
    var f = _rg_fence_at(g, fi);
    if (f == 0) { return 0 - 1; }
    return load64(f + FENCE_OFF_CN);
}

# The batch index a node landed in (-1 before rg_schedule or bad id).
fn rg_node_batch_idx(g, node_id): i64 {
    if (node_id < 0) { return 0 - 1; }
    if (node_id >= rg_node_count(g)) { return 0 - 1; }
    return load64(vec_get(load64(g + 0), node_id) + 64);
}

# ================================================================
# Execute — encode every node into one command encoder, submit once.
# ================================================================

fn rg_execute(g, device, queue): i64 {
    if (rg_is_built(g) == 0) { return 1; }
    # Refuse null device/queue rather than letting fncallN dereference
    # an uninitialized fn-table slot. CPU-only tests exercise the error
    # path via this guard.
    if (device == 0) { return 1; }
    if (queue == 0)  { return 1; }
    var nodes = load64(g + 0);
    var n = vec_len(nodes);
    if (n == 0) { return 0; }

    var label = load64(g + 32);
    var enc_label = label;
    if (enc_label == 0) { enc_label = "render_graph_enc"; }
    var encoder = wgpu_device_create_command_encoder(device, enc_label);
    if (encoder == 0) { return 1; }

    var i = 0;
    while (i < n) {
        var node = vec_get(nodes, i);
        var kind = load64(node + 0);
        if (kind == NODE_COMPUTE) {
            _rg_encode_compute(encoder, node);
        } else {
            if (kind == NODE_RENDER) {
                _rg_encode_render(encoder, node);
            } else {
                if (kind == NODE_COPY_BUF_BUF) {
                    _rg_encode_copy_buf_buf(encoder, node);
                } else {
                    if (kind == NODE_COPY_TEX_BUF) {
                        _rg_encode_copy_tex_buf(encoder, node);
                    }
                }
            }
        }
        i = i + 1;
    }

    var cmd_label = label;
    if (cmd_label == 0) { cmd_label = "render_graph_cmd"; }
    var cmd = wgpu_command_encoder_finish(encoder, cmd_label);
    if (cmd == 0) { return 1; }
    wgpu_queue_submit_one(queue, cmd);
    return 0;
}

# ================================================================
# Execute (multi-queue aware) — v3.2.13–14 Phase R.
# ================================================================
# rg_execute_mq(g, ctx) is the ctx-taking, queue-aware executor. It runs
# rg_schedule (R.2/R.3) then routes by backend: native AMD takes the real
# multi-queue executor (_rg_execute_native_mq — per-ring timeline submits +
# cross-ring fence edges, R.4–R.6); wgpu (one device queue) stays on the v2.5
# single-encoder/single-submit path, serialized-equivalent with the identical
# command stream (affinity honored as ordering only). Returns 0 on success,
# non-zero on error (GPU_ERR_* on native, 1 on wgpu). # @public
#
# Dispatch one node natively, reinterpreting its byte-polymorphic payload as
# native objects — the same backend-boundary polymorphism gpu_shader_module_create
# uses (wgpu reads WGSL bytes, native reads GFX9 ISA). The node's queue is
# already stashed as current, so each backend dispatch slot routes through its
# timeline (async) path onto that ring. Returns 0|GPU_ERR_*.
fn _rg_native_dispatch_node(ctx, node): i64 {
    var kind = load64(node + 0);
    var pl = load64(node + 8);
    if (kind == NODE_COMPUTE) {
        # ComputePayload natively: +0 shader module, +8 buffer-pair, +16/20/24 dims.
        return gpu_compute_dispatch(ctx, load64(pl + 0),
        load32(pl + 16), load32(pl + 20), load32(pl + 24), load64(pl + 8));
    }
    if (kind == NODE_RENDER) {
        # RenderPayload natively: +0 NativePass, +8 NativeRenderPipeline, +16
        # draw_verts. The render_pass_draw slot is queue-aware (R.6), so with a
        # current queue stashed it routes through native_render_dispatch_timeline.
        var slot = backend_get_slot(gpu_ctx_backend(ctx), BACKEND_SLOT_RENDER_PASS_DRAW);
        if (slot == 0) { return GPU_ERR_NOT_IMPLEMENTED; }   #skip-lint
        return fncall5(slot, ctx, load64(pl + 0), load64(pl + 8), load64(pl + 16), 1);
    }
    if (kind == NODE_COPY_BUF_BUF) {
        # CopyBufBufPayload natively: +0 src NativeBuf, +16 dst NativeBuf, +32
        # size. The native whole-buffer copy slot has no offset args, so a
        # non-zero src/dst offset fails loud rather than silently mis-copying.
        # The copy node must be TRANSFER-affined (the SDMA ring); a GFX/COMPUTE
        # queue is rejected inside the buffer_copy slot (GPU_ERR_TRANSFER).
        if (load64(pl + 8) != 0)  { return GPU_ERR_BUFFER; }
        if (load64(pl + 24) != 0) { return GPU_ERR_BUFFER; }
        return gpu_queue_transfer_copy(ctx, gpu_ctx_current_queue(ctx),
        load64(pl + 0), load64(pl + 16), load64(pl + 32));
    }
    # NODE_COPY_TEX_BUF has no native MQ-graph path yet — fail loud (tracked in
    # docs/development/3-2-punchlist.md Phase R), never silent-wrong.
    return GPU_ERR_NOT_IMPLEMENTED;   #skip-lint
}

# v3.2.14 R.6 — native multi-queue executor. Consumes the Schedule (R.2/R.3):
# acquires the logical queue per used kind, walks nodes in GLOBAL sort_idx
# order (the toposort guarantee that every producer submits before its
# consumer — see the rg_schedule submission-order note), inserts a
# gpu_queue_barrier for each incoming cross-queue fence edge before the
# consumer's dispatch (in-CS timeline wait, no CPU stall), stashes the node's
# queue as current so the native dispatch slots take their timeline paths,
# advances the IB staging slice per node (R.5; no shared-IB clobber), and
# finally gpu_queue_wait_idle's every used queue so results are readable on
# return (the v2.5 completion contract). Returns 0|GPU_ERR_*.
fn _rg_execute_native_mq(g, ctx): i64 {
    var nodes = load64(g + 0);
    var n = vec_len(nodes);
    if (n == 0) { return 0; }
    rg_schedule(g);                  # idempotent; safe if called directly
    native_ctx_ib_reset_slots(ctx);  # deterministic per-execution start

    var sched = _rg_sched(g);
    var batches = load64(sched + SCHED_OFF_BATCHES);
    var nb = vec_len(batches);
    var fences = load64(sched + SCHED_OFF_FENCES);
    var nf = vec_len(fences);

    # Acquire (idempotently) the logical queue for every batch's kind.
    var bi = 0;
    while (bi < nb) {
        if (gpu_queue_get(ctx, load64(vec_get(batches, bi) + BATCH_OFF_QUEUE)) == 0) {
            return GPU_ERR_OTHER;
        }
        bi = bi + 1;
    }

    var rc = 0;
    var i = 0;
    while (i < n) {
        var node = vec_get(nodes, i);   # vec is in sort_idx order, so i == sort_idx
        var q = gpu_queue_get(ctx, load64(node + 56));

        # Cross-queue barriers for every fence edge feeding this consumer node.
        var fi = 0;
        while (fi < nf) {
            var fe = vec_get(fences, fi);
            if (load64(fe + FENCE_OFF_CN) == i) {
                gpu_queue_barrier(ctx, gpu_queue_get(ctx, load64(fe + FENCE_OFF_PQ)), q);
            }
            fi = fi + 1;
        }

        gpu_ctx_set_current_queue(ctx, q);
        var dr = _rg_native_dispatch_node(ctx, node);
        if (dr != 0) { rc = dr; }
        native_ctx_ib_advance(ctx);     # next node stages into a fresh IB slice
        i = i + 1;
    }

    # Clear the stash and retire every used queue before returning.
    gpu_ctx_set_current_queue(ctx, 0);
    bi = 0;
    while (bi < nb) {
        var wr = gpu_queue_wait_idle(ctx,
        gpu_queue_get(ctx, load64(vec_get(batches, bi) + BATCH_OFF_QUEUE)));
        if (wr != 0) { rc = wr; }
        bi = bi + 1;
    }
    return rc;
}

fn rg_execute_mq(g, ctx): i64 {
    if (ctx == 0) { return 1; }
    if (rg_is_built(g) == 0) { return 1; }
    # Run the scheduler pass (R.2/R.3) — idempotent; produces the per-queue
    # batches + cross-queue fence edges both executors read.
    rg_schedule(g);
    # Native AMD gets the real multi-queue executor (per-ring timeline submits
    # + cross-ring fence edges, R.6). wgpu has one device queue, so it stays on
    # the v2.5 single-encoder/single-submit path — serialized-equivalent, the
    # identical command stream (the affinity is honored as ordering only). A
    # null backend ptr (or any non-AMD kind) falls through to the wgpu path
    # rather than dereferencing it.
    var b = gpu_ctx_backend(ctx);
    if (b != 0) {
        if (backend_kind(b) == BACKEND_KIND_AMD) {
            return _rg_execute_native_mq(g, ctx);
        }
    }
    return rg_execute(g, gpu_ctx_device(ctx), gpu_ctx_queue(ctx));
}

# ================================================================
# Teardown
# ================================================================

fn rg_release(g): i64 {
    if (g == 0) { return 0; }
    var transients = load64(g + 8);
    var t = vec_len(transients);
    var ti = 0;
    while (ti < t) {
        var r = vec_get(transients, ti);
        var view = load64(r + 16);
        if (view != 0) { wgpu_texture_view_release(view); }
        var handle = load64(r + 8);
        var kind = load64(r + 0);
        if (handle != 0) {
            if (kind == RES_BUFFER)  { wgpu_buffer_release(handle); }
            if (kind == RES_TEXTURE) { wgpu_texture_release(handle); }
        }
        ti = ti + 1;
    }
    # Node payloads and vecs are bump-allocated; the arena reset
    # reclaims them en masse. Nothing else to free per-node.
    return 0;
}

# ================================================================
# Internals
# ================================================================

fn _rg_node_new(kind, label): i64 {
    var node = alloc(80);
    memset(node, 0, 80);
    store64(node + 0,  kind);
    store64(node + 16, vec_new());
    store64(node + 24, vec_new());
    store64(node + 32, label);
    store64(node + 48, 0 - 1);
    # Default queue affinity per node kind (R.1): compute runs on the
    # COMPUTE ring, render/copy on GRAPHICS. rg_node_queue overrides this.
    var qk = QUEUE_KIND_GRAPHICS;
    if (kind == NODE_COMPUTE) { qk = QUEUE_KIND_COMPUTE; }
    store64(node + 56, qk);
    store64(node + 64, 0 - 1);
    return node;
}

fn _rg_append_node(g, node): i64 {
    var nodes = load64(g + 0);
    var id = vec_len(nodes);
    vec_push(nodes, node);
    return id;
}

fn _rg_alloc_transient(r, device): i64 {
    # Tests and CPU-only consumers can build a graph with a null device;
    # we skip allocation in that case so rg_build is side-effect-free on
    # the GPU side. Real executions pass a live device.
    if (device == 0) { return 0; }
    var kind = load64(r + 0);
    var label = load64(r + 8);
    if (kind == RES_BUFFER) {
        var size = load64(r + 24);
        var usage = load64(r + 40) & 0xFFFFFFFF;
        var desc = wgpu_buffer_descriptor(label, usage, size, 0);
        var buf = wgpu_device_create_buffer(device, desc);
        store64(r + 8,  buf);
        store64(r + 16, 0);
        return 0;
    }
    if (kind == RES_TEXTURE) {
        var width  = load64(r + 24);
        var height = load64(r + 32);
        var packed = load64(r + 40);
        var format = packed / 0x100000000;
        var usage  = packed & 0xFFFFFFFF;
        var desc = wgpu_texture_descriptor(label, usage,
        WGPU_TEXTURE_DIMENSION_2D, width, height, format);
        var tex = wgpu_device_create_texture(device, desc);
        store64(r + 8, tex);
        if (tex != 0) {
            var view_desc = wgpu_texture_view_descriptor(0, format,
            WGPU_TEXTURE_VIEW_DIMENSION_2D);
            var view = wgpu_texture_create_view(tex, view_desc);
            store64(r + 16, view);
        }
        return 0;
    }
    return 0;
}

fn _rg_encode_compute(encoder, node): i64 {
    var pl = load64(node + 8);
    var pipeline   = load64(pl + 0);
    var bind_group = load64(pl + 8);
    var x = load32(pl + 16);
    var y = load32(pl + 20);
    var z = load32(pl + 24);
    if (x <= 0) { return 0; }
    if (y <= 0) { return 0; }
    if (z <= 0) { return 0; }

    var pass_desc = wgpu_compute_pass_descriptor(load64(node + 32));
    var pass = wgpu_command_encoder_begin_compute_pass(encoder, pass_desc);
    wgpu_compute_pass_set_pipeline(pass, compute_pipeline_handle(pipeline));
    wgpu_compute_pass_set_bind_group(pass, 0, bind_group, 0, 0);
    wgpu_compute_pass_dispatch(pass, x, y, z);
    wgpu_compute_pass_end(pass);
    return 0;
}

fn _rg_encode_render(encoder, node): i64 {
    var pl = load64(node + 8);
    var pb         = load64(pl + 0);
    var pipeline   = load64(pl + 8);
    var draw_verts = load64(pl + 16);

    var pass = rpb_pass_begin(encoder, pb);
    if (pass == 0) { return 0; }
    if (pipeline != 0) {
        wgpu_render_pass_encoder_set_pipeline(pass, pipeline);
        if (draw_verts > 0) {
            wgpu_render_pass_encoder_draw(pass, draw_verts, 1, 0, 0);
        }
    }
    wgpu_render_pass_encoder_end(pass);
    wgpu_render_pass_encoder_release(pass);
    return 0;
}

fn _rg_encode_copy_buf_buf(encoder, node): i64 {
    var pl = load64(node + 8);
    wgpu_command_encoder_copy_buffer_to_buffer(encoder,
    load64(pl + 0),  load64(pl + 8),
    load64(pl + 16), load64(pl + 24),
    load64(pl + 32));
    return 0;
}

fn _rg_encode_copy_tex_buf(encoder, node): i64 {
    var pl = load64(node + 8);
    wgpu_command_encoder_copy_texture_to_buffer(encoder, pl);
    return 0;
}

# --- surface.cyr ---

# @public — stable API surface (survives the v3.0 backend swap)
# surface.cyr — window surface lifecycle management
# Ported from mabda/src/surface.rs
#
# mabda is headless — creating a WGPUSurface requires a platform-specific
# handle (X11 window, Wayland surface, HWND, NSView, etc). Consumers like
# soorat provide the handle; this module owns everything that happens
# after creation: configure, acquire-frame, present, release.
#
# SurfaceState struct layout (48 bytes):
#   +0:  surface          (WGPUSurface handle, 8)
#   +8:  device           (WGPUDevice handle, 8) — needed for reconfigure
#   +16: format           (u32 WGPUTextureFormat)
#   +24: width            (i64)
#   +32: height           (i64)
#   +40: present_mode     (u32)

# ================================================================
# Present mode preferences (wgpu-native v29 values)
# ================================================================
var PRESENT_VSYNC     = 0;
var PRESENT_NO_VSYNC  = 1;
var PRESENT_IMMEDIATE = 2;
var PRESENT_MAILBOX   = 3;

# WGPUPresentMode — v29 values
var WGPU_PRESENT_MODE_FIFO         = 1;
var WGPU_PRESENT_MODE_FIFO_RELAXED = 2;
var WGPU_PRESENT_MODE_IMMEDIATE    = 3;
var WGPU_PRESENT_MODE_MAILBOX      = 4;

# WGPUSurfaceGetCurrentTextureStatus — v29 values
var WGPU_SURFACE_STATUS_SUCCESS_OPTIMAL    = 1;
var WGPU_SURFACE_STATUS_SUCCESS_SUBOPTIMAL = 2;
var WGPU_SURFACE_STATUS_TIMEOUT            = 3;

fn present_mode_to_wgpu(pref): i64 {
    if (pref == PRESENT_VSYNC)     { return WGPU_PRESENT_MODE_FIFO; }
    if (pref == PRESENT_NO_VSYNC)  { return WGPU_PRESENT_MODE_FIFO_RELAXED; }
    if (pref == PRESENT_IMMEDIATE) { return WGPU_PRESENT_MODE_IMMEDIATE; }
    if (pref == PRESENT_MAILBOX)   { return WGPU_PRESENT_MODE_MAILBOX; }
    return WGPU_PRESENT_MODE_FIFO;
}

# ================================================================
# SurfaceState accessors
# ================================================================
fn surface_state_handle(ss): i64 { return load64(ss + 0); }
fn surface_state_device(ss): i64 { return load64(ss + 8); }
fn surface_state_format(ss): i64 { return load32(ss + 16); }
fn surface_state_width(ss): i64 { return load64(ss + 24); }
fn surface_state_height(ss): i64 { return load64(ss + 32); }
fn surface_state_present(ss): i64 { return load32(ss + 40); }

# ================================================================
# SurfaceState construction — called by the consumer after they obtain
# a WGPUSurface handle from their windowing library.
# ================================================================
fn surface_state_new(surface, device, format, width, height, present_pref): i64 {
    # Audit 2026-06-14 [LOW-3]: reject non-positive dimensions before they
    # truncate to a huge u32 surface extent at the wgpu boundary. Matches
    # the v3 gpu_surface_configure_wgpu guard.
    if (width <= 0)  { return 0; }
    if (height <= 0) { return 0; }
    var ss = alloc(48);
    store64(ss + 0,  surface);
    store64(ss + 8,  device);
    store32(ss + 16, format);
    store64(ss + 24, width);
    store64(ss + 32, height);
    store32(ss + 40, present_mode_to_wgpu(present_pref));
    _surface_state_configure(ss);
    return ss;
}

# Internal: build a SurfaceConfiguration and call wgpuSurfaceConfigure.
# Used by surface_state_new and surface_state_resize.
fn _surface_state_configure(ss): i64 {
    var usage = WGPU_TEXTURE_USAGE_RENDER_ATTACHMENT;
    var cfg = wgpu_surface_configuration(surface_state_device(ss),
    surface_state_format(ss),
    surface_state_width(ss),
    surface_state_height(ss),
    usage,
    surface_state_present(ss));
    wgpu_surface_configure(surface_state_handle(ss), cfg);
    return 0;
}

# ================================================================
# Resize — reconfigure the surface with new dimensions
# ================================================================
fn surface_state_resize(ss, width, height): i64 {
    if (width <= 0) { return 0; }    # Audit [LOW-3]: was == 0; negatives
    if (height <= 0) { return 0; }   # truncated to a huge u32 extent.
    store64(ss + 24, width);
    store64(ss + 32, height);
    _surface_state_configure(ss);
    return 0;
}

# ================================================================
# Frame acquisition — wraps wgpuSurfaceGetCurrentTexture
# ================================================================
# Returns a GpuResult:
#   Ok(texture_handle) — success (optimal or suboptimal)
#   Err(...)           — timeout, outdated, lost, etc.
#
# wgpuSurfaceGetCurrentTexture writes into a WGPUSurfaceTexture struct
# (24 bytes): +0 nextInChain, +8 texture, +16 status.
fn surface_state_acquire(ss): i64 {
    var out = alloc(24);
    memset(out, 0, 24);
    wgpu_surface_get_current_texture(surface_state_handle(ss), out);
    var status = load32(out + 16);
    var texture = load64(out + 8);
    if (status == WGPU_SURFACE_STATUS_SUCCESS_OPTIMAL) { return gpu_ok(texture); }
    if (status == WGPU_SURFACE_STATUS_SUCCESS_SUBOPTIMAL) { return gpu_ok(texture); }
    if (status == WGPU_SURFACE_STATUS_TIMEOUT) {
        return gpu_err_result_msg(GPU_ERR_SURFACE_TIMEOUT, "surface texture acquire timed out");
    }
    return gpu_err_result_msg(GPU_ERR_SURFACE_LOST, "surface texture acquire failed");
}

# ================================================================
# Present + release
# ================================================================
# Renamed from `surface_state_present` in 2.3.0 — the old name collided
# with the `present_mode` accessor above (`load32(ss + 40)`) and Cyrius
# silently kept only the second definition, breaking `_surface_state_configure`.
# See docs/audit/2026-04-19-audit.md HIGH-1.
fn surface_state_submit_present(ss): i64 {
    wgpu_surface_present(surface_state_handle(ss));
    return 0;
}

fn surface_state_release(ss): i64 {
    var h = load64(ss + 0);
    if (h != 0) { wgpu_surface_release(h); }
    store64(ss + 0, 0);
    return 0;
}

# ================================================================
# Size helper (unchanged from pre-FFI version)
# ================================================================
fn surface_state_size(ss, dst): i64 {
    store64(dst + 0, surface_state_width(ss));
    store64(dst + 8, surface_state_height(ss));
    return 0;
}

# --- surface_v3.cyr ---

# @public — v3 surface API (Step 7.7)
# surface_v3.cyr — public dispatchers for the v3 surface
# abstraction. Sits ABOVE the v2 `src/surface.cyr` lifecycle (which
# stays in tree as the wgpu-side mechanism the wgpu wrappers
# delegate to) and BELOW the consumer's window/master-fd code.
#
# Six public fns total:
#   - 3 backend-specific configure entries:
#       gpu_surface_configure_wgpu          (wgpu, full)
#       gpu_surface_configure_native_kiosk  (native, full)
#       gpu_surface_configure_native_logind (native, stub → samvada 0.4.1)
#   - 3 generic per-frame ops:
#       gpu_surface_acquire
#       gpu_surface_present
#       gpu_surface_release
#
# Configure entries stash backend-specific resources (WGPUSurface
# handle or DRM master card_fd) on the GpuContext via
# `gpu_ctx_set_*` accessors, then dispatch through
# `ctx->backend->surface_configure` slot. The slot impl reads the
# stash back from ctx and runs backend-appropriate setup.
#
# Per-frame ops are backend-agnostic — they route directly through
# the slot table without any backend-specific input.
#
# Design + tradeoffs are documented in
# `docs/proposals/v3-surface-api-design.md`.

# ================================================================
# Backend-specific configure entries
# ================================================================

# Wgpu: caller pre-creates a WGPUSurface from their window using
# wgpu_instance_create_surface (or whatever windowing-library
# binding they're using). mabda doesn't touch windows; it just
# wraps the resulting surface handle with format / size / present
# config and returns an opaque surface ptr.
#
# Returns the surface_ptr on success, 0 on failure (typically:
# null ctx, zero dimensions, no backend, surface_state_new
# returning null).
fn gpu_surface_configure_wgpu(ctx, wgpu_surface, width, height): i64 {
    if (ctx == 0)          { return 0; }
    if (wgpu_surface == 0) { return 0; }
    if (width <= 0)        { return 0; }
    if (height <= 0)       { return 0; }
    var b = gpu_ctx_backend(ctx);
    if (b == 0) { return 0; }
    var slot = backend_get_slot(b, BACKEND_SLOT_SURFACE_CONFIGURE);
    if (slot == 0) { return 0; }
    gpu_ctx_set_wgpu_surface_handle(ctx, wgpu_surface);
    return fncall3(slot, ctx, width, height);
}

# Native (TTY/kiosk): caller has already opened /dev/dri/cardN and
# called DRM_IOCTL_SET_MASTER on it. This entry stashes the fd on
# ctx and runs the full modeset through the backend slot, which
# does discovery → mode-pick → BO alloc → PRIME bridge → AddFB2
# → SETCRTC → second-FB alloc.
#
# Returns the surface_ptr on success, 0 on failure. The card_fd
# remains the caller's responsibility — release_scanout / rm_fb /
# gem_close run on `release`, but the master fd close + drop_master
# stay with the caller.
fn gpu_surface_configure_native_kiosk(ctx, card_fd, width, height): i64 {
    if (ctx == 0)     { return 0; }
    if (card_fd <= 0) { return 0; }
    if (width <= 0)   { return 0; }
    if (height <= 0)  { return 0; }
    var b = gpu_ctx_backend(ctx);
    if (b == 0) { return 0; }
    var slot = backend_get_slot(b, BACKEND_SLOT_SURFACE_CONFIGURE);
    if (slot == 0) { return 0; }
    gpu_ctx_set_native_card_fd(ctx, card_fd);
    return fncall3(slot, ctx, width, height);
}

# Native (logind): asks systemd-logind via dbus TakeDevice() to
# delegate DRM master from the caller's session. As of v3.0 the
# `samvada` package (`[deps.samvada]` >= 0.4.1) provides the
# implementation; this dispatcher composes:
#   1. samvada_session_take_device(major, minor) on each candidate
#      card (minors 0..1 — most systems have AMD on card0 or card1;
#      multi-GPU disambiguation is a v3.x extension).
#   2. First card that returns a positive fd → stash via
#      gpu_ctx_set_native_card_fd + dispatch through the slot.
#
# Pre-condition: samvada must already be initialized. Consumer
# programs link `samvada/deps/samvada_main.c` alongside mabda's
# `wgpu_main.c`; the C side calls `samvada_main(table)` during
# init which populates samvada's static fn-table reference. If
# samvada isn't initialized, take_device returns -22 (EINVAL)
# and this dispatcher falls through to "logind path unavailable"
# (returns 0 — consumer can fall back to _native_kiosk).
#
# DRM major is 226 on Linux (drivers/gpu/drm/drm_drv.c); minors
# 0..15 cover card0..card15 (primary nodes). Render nodes start
# at minor 128 and aren't relevant here — TakeDevice operates on
# the master/primary node.
var _DRM_MAJOR = 226;

fn gpu_surface_configure_native_logind(ctx, width, height): i64 {
    if (ctx == 0)    { return 0; }
    if (width <= 0)  { return 0; }
    if (height <= 0) { return 0; }

    # Try minors 0 + 1 — covers the typical AMD-on-card0 and
    # AMD-on-card1 setups (split-GPU machines often have integrated
    # on card0 and discrete on card1, or vice versa). Multi-card
    # disambiguation is v3.x scope.
    var minor = 0;
    var fd = samvada_session_take_device(_DRM_MAJOR, 0);
    if (fd < 0) {
        minor = 1;
        fd = samvada_session_take_device(_DRM_MAJOR, 1);
    }
    if (fd < 0) { return 0; }   # samvada uninit'd OR no card available

    # Audit HIGH-2 (2026-04-30): every failure path between here and
    # the slot dispatch must release the fd back to logind + close.
    # Otherwise the consumer's fallback "try logind, then kiosk" loop
    # accumulates leaked master fds (RLIMIT_NOFILE pressure + DRM
    # master held until process exit).
    var b = gpu_ctx_backend(ctx);
    if (b == 0) {
        samvada_session_release_device(_DRM_MAJOR, minor);
        sys_close(fd);
        return 0;
    }
    var slot = backend_get_slot(b, BACKEND_SLOT_SURFACE_CONFIGURE);
    if (slot == 0) {
        samvada_session_release_device(_DRM_MAJOR, minor);
        sys_close(fd);
        return 0;
    }
    gpu_ctx_set_native_card_fd(ctx, fd);
    var surf = fncall3(slot, ctx, width, height);
    if (surf == 0) {
        # Slot's own failure path (discovery / modeset / FB alloc).
        # Return master to logind, close the fd, scrub the ctx stash.
        samvada_session_release_device(_DRM_MAJOR, minor);
        sys_close(fd);
        gpu_ctx_set_native_card_fd(ctx, 0);
    }
    # Audit 2026-06-14 [HIGH-2 NEW]: on success mabda still OWNS this
    # logind-acquired master fd — the consumer never sees it (it lives
    # only in the surface). Record provenance so gpu_surface_release gives
    # master back to logind + closes the fd; without this the fd and DRM
    # master leak for the process lifetime. Native-only: marking writes
    # into the NativeSurface tail, so guard on the backend kind (this path
    # is always native in practice, but never corrupt a wgpu surface_state).
    if (surf != 0) {
        if (backend_kind(b) == BACKEND_KIND_AMD) {
            native_surface_mark_master_owned(surf, minor);
        }
    }
    return surf;
}

# ================================================================
# Generic per-frame ops (backend-agnostic)
# ================================================================

# Returns a backend-specific buffer pointer the caller renders
# into. wgpu: a WGPUTexture handle. native: a NativeKmsFb pointer
# (consumer reads `mapped_addr` field for CPU-direct access).
# Returns 0 on failure (typically: null inputs, slot rejected,
# stale surface).
fn gpu_surface_acquire(ctx, surface): i64 {
    if (ctx == 0)     { return 0; }
    if (surface == 0) { return 0; }
    var b = gpu_ctx_backend(ctx);
    if (b == 0) { return 0; }
    var slot = backend_get_slot(b, BACKEND_SLOT_SURFACE_ACQUIRE);
    if (slot == 0) { return 0; }
    return fncall2(slot, ctx, surface);
}

# Submit the back-buffer for display. wgpu: queue submit + the
# library's swapchain present semantics. native: page-flip the
# CRTC, block on vblank event, swap front/back. Returns 0 on
# success, GPU_ERR_* on failure.
fn gpu_surface_present(ctx, surface): i64 {
    if (ctx == 0)     { return GPU_ERR_OTHER; }
    if (surface == 0) { return GPU_ERR_OTHER; }
    var b = gpu_ctx_backend(ctx);
    if (b == 0) { return GPU_ERR_OTHER; }
    var slot = backend_get_slot(b, BACKEND_SLOT_SURFACE_PRESENT);
    if (slot == 0) { return GPU_ERR_OTHER; }
    return fncall2(slot, ctx, surface);
}

# Release the surface and any backend-owned resources (FBs, CRTC
# disable, BO close). Does NOT close consumer-supplied fds (master
# card_fd, wgpu surface handle); those stay with the caller.
fn gpu_surface_release(ctx, surface): i64 {
    if (ctx == 0)     { return 0; }
    if (surface == 0) { return 0; }
    var b = gpu_ctx_backend(ctx);
    if (b == 0) { return 0; }
    var slot = backend_get_slot(b, BACKEND_SLOT_SURFACE_RELEASE);
    if (slot == 0) { return 0; }
    var rc = fncall2(slot, ctx, surface);
    # Audit LOW-6 (2026-04-30): zero the ctx stash so a subsequent
    # configure that fails before stashing doesn't see stale fd / handle.
    gpu_ctx_set_wgpu_surface_handle(ctx, 0);
    gpu_ctx_set_native_card_fd(ctx, 0);
    return rc;
}

# --- instancing.cyr ---

# @public — stable API surface (survives the v3.0 backend swap)
# instancing.cyr — per-instance transform and color data
# Ported from mabda/src/instancing.rs
#
# InstanceData (80 bytes):
#   +0:  model[0..16]  (16 × f32 = 64 bytes, column-major 4x4 matrix)
#   +64: color[0..4]   (4 × f32 = 16 bytes, RGBA tint)
#
# Shader locations: 7-10 (model matrix columns), 11 (color tint)

var INSTANCE_DATA_SIZE = 80;

# Write an identity InstanceData at dst (80 bytes)
fn instance_data_identity(dst): i64 {
    memset(dst, 0, 80);
    # Identity matrix: 1.0 on diagonal (column-major)
    # [0]=1, [5]=1, [10]=1, [15]=1  (column-major indices)
    var f32_one = f64_to_f32(F64_1);
    store32(dst, f32_one);        # model[0] = 1.0
    store32(dst + 20, f32_one);   # model[5] = 1.0
    store32(dst + 40, f32_one);   # model[10] = 1.0
    store32(dst + 60, f32_one);   # model[15] = 1.0
    # color = white (1,1,1,1)
    store32(dst + 64, f32_one);
    store32(dst + 68, f32_one);
    store32(dst + 72, f32_one);
    store32(dst + 76, f32_one);
    return 0;
}

# Create an InstanceData with identity matrix + white color
fn instance_data_new(): i64 {
    var d = alloc(80);
    instance_data_identity(d);
    return d;
}

# Create an InstanceData from a translation (x, y, z are f64)
fn instance_data_from_translation(x, y, z): i64 {
    var d = alloc(80);
    instance_data_identity(d);
    # Translation in column 3: model[12]=x, model[13]=y, model[14]=z
    store32(d + 48, f64_to_f32(x));  # model[12]
    store32(d + 52, f64_to_f32(y));  # model[13]
    store32(d + 56, f64_to_f32(z));  # model[14]
    return d;
}

# Set translation on existing InstanceData
fn instance_data_set_translation(d, x, y, z): i64 {
    store32(d + 48, f64_to_f32(x));
    store32(d + 52, f64_to_f32(y));
    store32(d + 56, f64_to_f32(z));
    return 0;
}

# Set color tint on existing InstanceData (rgba as f64)
fn instance_data_set_color(d, r, g, b, a): i64 {
    store32(d + 64, f64_to_f32(r));
    store32(d + 68, f64_to_f32(g));
    store32(d + 72, f64_to_f32(b));
    store32(d + 76, f64_to_f32(a));
    return 0;
}

# Build vertex attribute layout for InstanceData (5 attributes × 24 bytes = 120 bytes)
# Shader locations 7-11
fn instance_data_attributes(): i64 {
    var attrs = alloc(120);
    # model matrix: 4 × Float32x4 at locations 7-10
    _vertex_attr(attrs, WGPU_VERTEX_FORMAT_FLOAT32X4, 0, 7);
    _vertex_attr(attrs + 24, WGPU_VERTEX_FORMAT_FLOAT32X4, 16, 8);
    _vertex_attr(attrs + 48, WGPU_VERTEX_FORMAT_FLOAT32X4, 32, 9);
    _vertex_attr(attrs + 72, WGPU_VERTEX_FORMAT_FLOAT32X4, 48, 10);
    # color tint: Float32x4 at location 11
    _vertex_attr(attrs + 96, WGPU_VERTEX_FORMAT_FLOAT32X4, 64, 11);
    return attrs;
}

# ================================================================
# InstanceBuffer — dynamic GPU buffer for instance data
# ================================================================
#
# InstanceBuffer struct layout (24 bytes):
#   +0: buffer   (WGPUBuffer handle, 8)
#   +8: count    (i64, current instance count)
#   +16: capacity (i64, allocated capacity in instances)

fn instance_buffer_new(capacity): i64 {
    var ib = alloc(24);
    store64(ib, 0);           # buffer handle (set on first update)
    store64(ib + 8, 0);       # count
    store64(ib + 16, capacity);
    return ib;
}

fn instance_buffer_handle(ib): i64 { return load64(ib); }
fn instance_buffer_count(ib): i64 { return load64(ib + 8); }
fn instance_buffer_capacity(ib): i64 { return load64(ib + 16); }

