# Display subclasses (class 0x03)
# ---------------------------------------------------------------------------

enum PciDisplaySubclass {
    PCI_SUB_DISPLAY_VGA = 0;
    PCI_SUB_DISPLAY_XGA = 1;
    PCI_SUB_DISPLAY_3D = 2;
}

# ---------------------------------------------------------------------------
# Network subclasses (class 0x02)
# ---------------------------------------------------------------------------

enum PciNetworkSubclass {
    PCI_SUB_NETWORK_ETHERNET = 0;
    PCI_SUB_NETWORK_TOKEN_RING = 1;
    PCI_SUB_NETWORK_FDDI = 2;
    PCI_SUB_NETWORK_ATM = 3;
    PCI_SUB_NETWORK_ISDN = 4;
    PCI_SUB_NETWORK_WORLDFIP = 5;
    PCI_SUB_NETWORK_PICMG = 6;
    PCI_SUB_NETWORK_INFINIBAND = 7;
}

# ---------------------------------------------------------------------------
# Serial bus subclasses (class 0x0C) — host controllers
# ---------------------------------------------------------------------------

enum PciSerialBusSubclass {
    PCI_SUB_SERIAL_FIREWIRE = 0;
    PCI_SUB_SERIAL_ACCESS = 1;
    PCI_SUB_SERIAL_SSA = 2;
    PCI_SUB_SERIAL_USB = 3;
    PCI_SUB_SERIAL_FIBRE_CHANNEL = 4;
    PCI_SUB_SERIAL_SMBUS = 5;
    PCI_SUB_SERIAL_INFINIBAND = 6;
    PCI_SUB_SERIAL_IPMI = 7;
    PCI_SUB_SERIAL_SERCOS = 8;
    PCI_SUB_SERIAL_CANBUS = 9;
}

# ---------------------------------------------------------------------------
# pci_class_to_device_type — map (class, subclass) → yukti DeviceClass
#
# This is the primary kernel-use-case lookup: given a PCI config-space
# class/subclass pair, what kind of yukti device is it? Returns a
# DeviceClass value from src/core.cyr.
# ---------------------------------------------------------------------------

pub fn pci_class_to_device_type(class_code, subclass) {
    if (class_code == PCI_CLASS_STORAGE) {
        # NVMe and most storage controllers map to internal block
        return DC_BLOCK_INTERNAL;
    }
    if (class_code == PCI_CLASS_NETWORK) {
        return DC_NETWORK;
    }
    if (class_code == PCI_CLASS_DISPLAY) {
        return DC_GPU;
    }
    if (class_code == PCI_CLASS_SERIAL_BUS) {
        # USB host controllers — device_class will be refined downstream
        # when actual USB devices attach. For the host-controller itself,
        # surface it as unknown so the enumerator doesn't mistake it for
        # a storage device.
        if (subclass == PCI_SUB_SERIAL_USB) { return DC_UNKNOWN; }
        return DC_UNKNOWN;
    }
    return DC_UNKNOWN;
}

# ---------------------------------------------------------------------------
# Vendor IDs — common silicon vendors.
# List intentionally small; only vendors the AGNOS kernel is likely
# to encounter during boot on mainstream x86/ARM hardware.
# ---------------------------------------------------------------------------

enum PciVendor {
    PCI_VENDOR_INTEL = 0x8086;
    PCI_VENDOR_AMD = 0x1022;
    PCI_VENDOR_NVIDIA = 0x10DE;
    PCI_VENDOR_REALTEK = 0x10EC;
    PCI_VENDOR_BROADCOM = 0x14E4;
    PCI_VENDOR_QUALCOMM = 0x17CB;
    PCI_VENDOR_APPLE = 0x106B;
    PCI_VENDOR_SAMSUNG = 0x144D;
    PCI_VENDOR_MELLANOX = 0x15B3;
    PCI_VENDOR_MARVELL = 0x11AB;
    PCI_VENDOR_ATI = 0x1002;   # AMD GPUs still show up here
    PCI_VENDOR_VMWARE = 0x15AD;
    PCI_VENDOR_REDHAT = 0x1AF4; # virtio
    PCI_VENDOR_IBM = 0x1014;
    PCI_VENDOR_VIA = 0x1106;
    PCI_VENDOR_ASMEDIA = 0x1B21;
    PCI_VENDOR_STMICRO = 0x104A;
    PCI_VENDOR_MICRON = 0x1344;
    PCI_VENDOR_WESTERN_DIGITAL = 0x1B96;
    PCI_VENDOR_SEAGATE = 0x1BB1;
}

pub fn pci_vendor_name(vendor_id) {
    if (vendor_id == PCI_VENDOR_INTEL) { return "Intel"; }
    if (vendor_id == PCI_VENDOR_AMD) { return "AMD"; }
    if (vendor_id == PCI_VENDOR_NVIDIA) { return "NVIDIA"; }
    if (vendor_id == PCI_VENDOR_REALTEK) { return "Realtek"; }
    if (vendor_id == PCI_VENDOR_BROADCOM) { return "Broadcom"; }
    if (vendor_id == PCI_VENDOR_QUALCOMM) { return "Qualcomm"; }
    if (vendor_id == PCI_VENDOR_APPLE) { return "Apple"; }
    if (vendor_id == PCI_VENDOR_SAMSUNG) { return "Samsung"; }
    if (vendor_id == PCI_VENDOR_MELLANOX) { return "Mellanox"; }
    if (vendor_id == PCI_VENDOR_MARVELL) { return "Marvell"; }
    if (vendor_id == PCI_VENDOR_ATI) { return "ATI/AMD"; }
    if (vendor_id == PCI_VENDOR_VMWARE) { return "VMware"; }
    if (vendor_id == PCI_VENDOR_REDHAT) { return "Red Hat (virtio)"; }
    if (vendor_id == PCI_VENDOR_IBM) { return "IBM"; }
    if (vendor_id == PCI_VENDOR_VIA) { return "VIA"; }
    if (vendor_id == PCI_VENDOR_ASMEDIA) { return "ASMedia"; }
    if (vendor_id == PCI_VENDOR_STMICRO) { return "STMicroelectronics"; }
    if (vendor_id == PCI_VENDOR_MICRON) { return "Micron"; }
    if (vendor_id == PCI_VENDOR_WESTERN_DIGITAL) { return "Western Digital"; }
    if (vendor_id == PCI_VENDOR_SEAGATE) { return "Seagate"; }
    return "unknown";
}

# ---------------------------------------------------------------------------
# pci_device_name — (vendor_id, device_id) → human name
#
# Stub for now: no per-device table. Extend when a kernel consumer
# actually needs device-level granularity beyond vendor+class.
# Returns the vendor name as a best-effort fallback.
# ---------------------------------------------------------------------------

pub fn pci_device_name(vendor_id, device_id) {
    return pci_vendor_name(vendor_id);
}

# ---------------------------------------------------------------------------
# Convenience: is this a storage controller class worth probing?
# ---------------------------------------------------------------------------

pub fn pci_is_storage(class_code) {
    return class_code == PCI_CLASS_STORAGE;
}

pub fn pci_is_nvme(class_code, subclass) {
    if (class_code != PCI_CLASS_STORAGE) { return 0; }
    if (subclass != PCI_SUB_STORAGE_NVM) { return 0; }
    return 1;
}

pub fn pci_is_sata(class_code, subclass) {
    if (class_code != PCI_CLASS_STORAGE) { return 0; }
    if (subclass != PCI_SUB_STORAGE_SATA) { return 0; }
    return 1;
}

pub fn pci_is_gpu(class_code) {
    return class_code == PCI_CLASS_DISPLAY;
}

pub fn pci_is_network(class_code) {
    return class_code == PCI_CLASS_NETWORK;
}

# --- device.cyr ---

# yukti/device.cyr — Userland constructors, queries, and serializers
#
# This module is the Linux-userland counterpart to src/core.cyr.
# Everything here either allocates (alloc / str_builder / str_from),
# makes a syscall, or touches /sys — none of which are safe in the
# AGNOS kernel import path.
#
# The kernel-safe half (enums, struct layouts, accessors, pure
# predicates) lives in src/core.cyr and is imported first.

# ---------------------------------------------------------------------------
# DeviceId — wraps a Str. Allocates.
# ---------------------------------------------------------------------------

pub fn device_id_new(s) {
    var id = alloc(8);
    store64(id, s);
    return id;
}

pub fn device_id_new_cstr(cstr) {
    return device_id_new(str_from(cstr));
}

pub fn device_id_str(id) {
    return load64(id);
}

pub fn device_id_eq(a, b) {
    return str_eq(device_id_str(a), device_id_str(b));
}

# ---------------------------------------------------------------------------
# DeviceInfo constructor — allocates the 168-byte struct.
# Field layout + accessors are in src/core.cyr.
# ---------------------------------------------------------------------------

pub fn device_info_new(id, dev_path, class) {
    # Bump-allocated: benchmark showed fl_alloc regresses this hot
    # path by ~30% without matching fl_free callsites to amortize
    # the per-alloc overhead. DeviceInfo objects are long-lived
    # (enumerate → cache → listener dispatch) so pooling doesn't
    # win here. Keep the 168-byte struct on the bump arena.
    var info = alloc(DI_SIZE);
    store64(info + DI_ID, id);
    store64(info + DI_DEV_PATH, dev_path);
    store64(info + DI_SYS_PATH, 0);
    store64(info + DI_CLASS, class);
    store64(info + DI_STATE, DS_READY);
    store64(info + DI_LABEL, 0);
    store64(info + DI_VENDOR, 0);
    store64(info + DI_MODEL, 0);
    store64(info + DI_SERIAL, 0);
    store64(info + DI_FS_TYPE, 0);
    store64(info + DI_MOUNT_POINT, 0);
    store64(info + DI_SIZE_BYTES, 0);
    store64(info + DI_CAPS, 0);
    store64(info + DI_DETECTED_AT, 0);
    store64(info + DI_UID, 0);
    store64(info + DI_GID, 0);
    store64(info + DI_MODE, 0);
    store64(info + DI_USB_VID, 0 - 1);
    store64(info + DI_USB_PID, 0 - 1);
    store64(info + DI_PART_TABLE, 0);
    store64(info + DI_PROPERTIES, 0);
    return info;
}

# device_info_free is a no-op for now — DeviceInfo is bump-allocated
# (see comment in device_info_new). Kept in the API for symmetry
# with device_event_free / udev_event_free and to let consumers
# declare intent; removes the call-site churn if we later switch
# back to fl_alloc under a specialized short-lived workload.
pub fn device_info_free(info) {
    return 0;
}

# ---------------------------------------------------------------------------
# Size display — uses str_builder, so userland.
# ---------------------------------------------------------------------------

pub fn device_info_size_display(info, sb) {
    var bytes = di_size_bytes(info);
    if (bytes == 0) {
        str_builder_add_cstr(sb, "unknown");
        return 0;
    }

    if (bytes < 1024) {
        str_builder_add_int(sb, bytes);
        str_builder_add_cstr(sb, " B");
        return 0;
    }

    if (bytes < 1048576) {
        var kb = bytes / 1024;
        var kb_frac = ((bytes % 1024) * 10) / 1024;
        str_builder_add_int(sb, kb);
        str_builder_add_cstr(sb, ".");
        str_builder_add_int(sb, kb_frac);
        str_builder_add_cstr(sb, " KB");
        return 0;
    }

    if (bytes < 1073741824) {
        var mb = bytes / 1048576;
        var mb_frac = ((bytes % 1048576) * 10) / 1048576;
        str_builder_add_int(sb, mb);
        str_builder_add_cstr(sb, ".");
        str_builder_add_int(sb, mb_frac);
        str_builder_add_cstr(sb, " MB");
        return 0;
    }

    if (bytes < 1099511627776) {
        var gb = bytes / 1073741824;
        var gb_frac = ((bytes % 1073741824) * 10) / 1073741824;
        str_builder_add_int(sb, gb);
        str_builder_add_cstr(sb, ".");
        str_builder_add_int(sb, gb_frac);
        str_builder_add_cstr(sb, " GB");
        return 0;
    }

    var tb = bytes / 1099511627776;
    var tb_frac = ((bytes % 1099511627776) * 10) / 1099511627776;
    str_builder_add_int(sb, tb);
    str_builder_add_cstr(sb, ".");
    str_builder_add_int(sb, tb_frac);
    str_builder_add_cstr(sb, " TB");
    return 0;
}

# ---------------------------------------------------------------------------
# DeviceHealth constructor — allocates.
# ---------------------------------------------------------------------------

pub fn device_health_new() {
    var h = alloc(DH_SIZE);
    store64(h, 0 - 1);
    store64(h + DH_TEMP, 0);
    store64(h + DH_SCHEDULER, 0);
    return h;
}

# ---------------------------------------------------------------------------
# query_permissions — stat a device node for uid/gid/mode (SYS_STAT=4).
# stat struct layout: st_dev(8), st_ino(8), st_nlink(8), st_mode(4),
#   st_uid(4), st_gid(4), ...
# ---------------------------------------------------------------------------

pub fn query_permissions(dev_path_cstr) {
    var buf[144];
    var r = sys_stat(dev_path_cstr, &buf);
    if (r < 0) { return 0; }

    var mode = load32(&buf + 24);
    var uid = load32(&buf + 28);
    var gid = load32(&buf + 32);

    var perms = alloc(24);
    store64(perms, uid);
    store64(perms + 8, gid);
    store64(perms + 16, mode);
    return perms;
}

pub fn perms_uid(p) { return load64(p); }
pub fn perms_gid(p) { return load64(p + 8); }
pub fn perms_mode(p) { return load64(p + 16); }

# ---------------------------------------------------------------------------
# query_device_health — read sysfs attributes for a block device.
# ---------------------------------------------------------------------------

pub fn query_device_health(dev_name) {
    var health = device_health_new();

    var sb = str_builder_new();
    str_builder_add_cstr(sb, "/sys/block/");
    str_builder_add_str(sb, dev_name);
    str_builder_add_cstr(sb, "/queue/rotational");
    var rot_path = str_builder_build(sb);

    var rot_buf[64];
    var rot_n = file_read_all(str_cstr(rot_path), &rot_buf, 64);
    var rot_data = 0;
    if (rot_n > 0) { rot_data = &rot_buf; }
    if (rot_data != 0) {
        var rot_s = str_from_buf(rot_data, rot_n);
        var rot_trimmed = str_trim(rot_s);
        if (str_eq_cstr(rot_trimmed, "1")) {
            store64(health, 1);
        } elif (str_eq_cstr(rot_trimmed, "0")) {
            store64(health, 0);
        }
    }

    var sb2 = str_builder_new();
    str_builder_add_cstr(sb2, "/sys/block/");
    str_builder_add_str(sb2, dev_name);
    str_builder_add_cstr(sb2, "/queue/scheduler");
    var sched_path = str_builder_build(sb2);

    var sched_buf[256];
    var sched_n = file_read_all(str_cstr(sched_path), &sched_buf, 256);
    var sched_data = 0;
    if (sched_n > 0) { sched_data = &sched_buf; }
    if (sched_data != 0) {
        var sched_s = str_from_buf(sched_data, sched_n);
        store64(health + DH_SCHEDULER, str_trim(sched_s));
    }

    return health;
}

# ---------------------------------------------------------------------------
# DeviceInfo JSON serialization — uses str_builder.
# ---------------------------------------------------------------------------

pub fn device_info_to_json(info, sb) {
    str_builder_add_cstr(sb, "{\"id\":\"");
    str_builder_add_str(sb, device_id_str(di_id(info)));
    str_builder_add_cstr(sb, "\",\"dev_path\":\"");
    str_builder_add_str(sb, di_dev_path(info));
    str_builder_add_cstr(sb, "\",\"class\":\"");
    str_builder_add_cstr(sb, device_class_to_str(di_class(info)));
    str_builder_add_cstr(sb, "\",\"state\":\"");
    str_builder_add_cstr(sb, device_state_to_str(di_state(info)));
    str_builder_add_cstr(sb, "\",\"size_bytes\":");
    str_builder_add_int(sb, di_size_bytes(info));

    var label = di_label(info);
    if (label != 0) {
        str_builder_add_cstr(sb, ",\"label\":\"");
        str_builder_add_str(sb, label);
        str_builder_add_cstr(sb, "\"");
    }

    var vendor = di_vendor(info);
    if (vendor != 0) {
        str_builder_add_cstr(sb, ",\"vendor\":\"");
        str_builder_add_str(sb, vendor);
        str_builder_add_cstr(sb, "\"");
    }

    var model = di_model(info);
    if (model != 0) {
        str_builder_add_cstr(sb, ",\"model\":\"");
        str_builder_add_str(sb, model);
        str_builder_add_cstr(sb, "\"");
    }

    var mp = di_mount_point(info);
    if (mp != 0) {
        str_builder_add_cstr(sb, ",\"mount_point\":\"");
        str_builder_add_str(sb, mp);
        str_builder_add_cstr(sb, "\"");
    }

    str_builder_add_cstr(sb, ",\"capabilities\":");
    str_builder_add_int(sb, di_caps(info));

    str_builder_add_cstr(sb, "}");
    return 0;
}

# --- event.cyr ---

# yukti/event.cyr — Device events: attach, detach, media change, mount/unmount
#
# DeviceEvent, DeviceEventKind, EventCollector (for testing),
# and listener callback pattern.

# ---------------------------------------------------------------------------
# DeviceEventKind enum — 6 variants
# ---------------------------------------------------------------------------

enum DeviceEventKind {
    EK_ATTACHED = 0;
    EK_DETACHED = 1;
    EK_MEDIA_CHANGED = 2;
    EK_MOUNTED = 3;
    EK_UNMOUNTED = 4;
    EK_ERROR = 5;
}

pub fn event_kind_to_str(kind) {
    if (kind == EK_ATTACHED) { return "attached"; }
    if (kind == EK_DETACHED) { return "detached"; }
    if (kind == EK_MEDIA_CHANGED) { return "media-changed"; }
    if (kind == EK_MOUNTED) { return "mounted"; }
    if (kind == EK_UNMOUNTED) { return "unmounted"; }
    if (kind == EK_ERROR) { return "error"; }
    return "unknown";
}

# ---------------------------------------------------------------------------
# DeviceEvent struct
# Layout: 56 bytes
#   0: device_id (DeviceId ptr)
#   8: device_class (DeviceClass enum value)
#  16: kind (DeviceEventKind enum value)
#  24: dev_path (Str)
#  32: timestamp (i64 — epoch seconds)
#  40: extra (Str — mount_point for Mounted, message for Error, 0 otherwise)
#  48: device_info (DeviceInfo ptr, 0 for detach)
# ---------------------------------------------------------------------------

enum DeviceEventField {
    DE_DEVICE_ID = 0;
    DE_DEVICE_CLASS = 8;
    DE_KIND = 16;
    DE_DEV_PATH = 24;
    DE_TIMESTAMP = 32;
    DE_EXTRA = 40;
    DE_DEVICE_INFO = 48;
    DE_SIZE = 56;
}

pub fn device_event_new(device_id, device_class, kind, dev_path) {
    # Freelist-backed so transient events from the hotplug dispatch
    # loop can be reclaimed via device_event_free(). See 2.1.0
    # performance roadmap entry.
    var e = fl_alloc(DE_SIZE);
    store64(e + DE_DEVICE_ID, device_id);
    store64(e + DE_DEVICE_CLASS, device_class);
    store64(e + DE_KIND, kind);
    store64(e + DE_DEV_PATH, dev_path);
    # Timestamp: epoch seconds via stdlib chrono (cross-platform). Was a `var`
    # syscall(228,0,&ts) that did NOT route on macOS/Windows (the reroute needs a
    # literal number) — cyrius issue 2026-06-16-var-syscall-number-defeats-macho-pe-reroute.
    store64(e + DE_TIMESTAMP, clock_epoch_secs());
    store64(e + DE_EXTRA, 0);
    store64(e + DE_DEVICE_INFO, 0);
    return e;
}

pub fn device_event_free(e) {
    if (e == 0) { return 0; }
    fl_free(e);
    return 0;
}

# Accessors
pub fn de_device_id(e) { return load64(e + DE_DEVICE_ID); }
pub fn de_device_class(e) { return load64(e + DE_DEVICE_CLASS); }
pub fn de_kind(e) { return load64(e + DE_KIND); }
pub fn de_dev_path(e) { return load64(e + DE_DEV_PATH); }
pub fn de_timestamp(e) { return load64(e + DE_TIMESTAMP); }
pub fn de_extra(e) { return load64(e + DE_EXTRA); }
pub fn de_device_info(e) { return load64(e + DE_DEVICE_INFO); }

# Setters
pub fn de_set_extra(e, v) { store64(e + DE_EXTRA, v); return 0; }
pub fn de_set_device_info(e, v) { store64(e + DE_DEVICE_INFO, v); return 0; }

# Attach device info snapshot to event
pub fn device_event_with_info(e, info) {
    de_set_device_info(e, info);
    return e;
}

# Predicate methods
pub fn device_event_is_attach(e) {
    return de_kind(e) == EK_ATTACHED;
}

pub fn device_event_is_detach(e) {
    return de_kind(e) == EK_DETACHED;
}

pub fn device_event_is_removable(e) {
    var class = de_device_class(e);
    if (class == DC_USB_STORAGE) { return 1; }
    if (class == DC_OPTICAL) { return 1; }
    if (class == DC_SD_CARD) { return 1; }
    return 0;
}

# Format event kind with extra data for display
pub fn device_event_kind_display(e, sb) {
    var kind = de_kind(e);
    if (kind == EK_MOUNTED) {
        str_builder_add_cstr(sb, "mounted:");
        var extra = de_extra(e);
        if (extra != 0) {
            str_builder_add_str(sb, extra);
        }
        return 0;
    }
    if (kind == EK_ERROR) {
        str_builder_add_cstr(sb, "error:");
        var extra = de_extra(e);
        if (extra != 0) {
            str_builder_add_str(sb, extra);
        }
        return 0;
    }
    str_builder_add_cstr(sb, event_kind_to_str(kind));
    return 0;
}

# ---------------------------------------------------------------------------
# EventCollector — vec-backed event collector for testing
# Layout: 8 bytes — pointer to vec
# ---------------------------------------------------------------------------

pub fn event_collector_new() {
    var c = alloc(8);
    store64(c, vec_new());
    return c;
}

pub fn event_collector_push(c, event) {
    vec_push(load64(c), event);
    return 0;
}

pub fn event_collector_count(c) {
    return vec_len(load64(c));
}

pub fn event_collector_get(c, i) {
    return vec_get(load64(c), i);
}

pub fn event_collector_clear(c) {
    var v = load64(c);
    # Reset vec length to 0
    store64(v + 8, 0);
    return 0;
}

# ---------------------------------------------------------------------------
# Listener dispatch — function pointer callbacks
#
# Listeners are stored as function pointers in a vec.
# Each listener is called as fncall1(fn_ptr, event).
# Filter support: a listener can be paired with a filter function
# that returns 1 to accept, 0 to skip.
#
# Listener entry: 16 bytes [fn_ptr, filter_fn_ptr (0 = accept all)]
# ---------------------------------------------------------------------------

pub fn listener_entry_new(fn_ptr, filter_fn) {
    var entry = alloc(16);
    store64(entry, fn_ptr);
    store64(entry + 8, filter_fn);
    return entry;
}

pub fn dispatch_event_to_listeners(listeners_vec, event) {
    var len = vec_len(listeners_vec);
    for (var i = 0; i < len; i = i + 1) {
        var entry = vec_get(listeners_vec, i);
        var filter_fn = load64(entry + 8);

        # Check filter if present
        if (filter_fn != 0) {
            var accepted = fncall1(filter_fn, event);
            if (accepted == 0) {
                continue;
            }
        }

        # Dispatch event
        var handler = load64(entry);
        fncall1(handler, event);
    }
    return 0;
}

# --- storage.cyr ---

# yukti/storage.cyr — USB/block device storage operations
#
# Mount, unmount, eject, filesystem detection, /proc/mounts parsing.
# All syscalls direct — no libc dependency.

# ---------------------------------------------------------------------------
# Filesystem enum — 17 known types + unknown
# ---------------------------------------------------------------------------

enum Filesystem {
    FS_EXT4 = 0;
    FS_BTRFS = 1;
    FS_XFS = 2;
    FS_VFAT = 3;
    FS_NTFS = 4;
    FS_EXFAT = 5;
    FS_ISO9660 = 6;
    FS_UDF = 7;
    FS_HFSPLUS = 8;
    FS_SWAP = 9;
    FS_LUKS = 10;
    FS_F2FS = 11;
    FS_EROFS = 12;
    FS_TMPFS = 13;
    FS_CIFS = 14;
    FS_NFS = 15;
    FS_UNKNOWN = 16;
}

pub fn filesystem_to_str(fs) {
    if (fs == FS_EXT4) { return "ext4"; }
    if (fs == FS_BTRFS) { return "btrfs"; }
    if (fs == FS_XFS) { return "xfs"; }
    if (fs == FS_VFAT) { return "vfat"; }
    if (fs == FS_NTFS) { return "ntfs"; }
    if (fs == FS_EXFAT) { return "exfat"; }
    if (fs == FS_ISO9660) { return "iso9660"; }
    if (fs == FS_UDF) { return "udf"; }
    if (fs == FS_HFSPLUS) { return "hfs+"; }
    if (fs == FS_SWAP) { return "swap"; }
    if (fs == FS_LUKS) { return "luks"; }
    if (fs == FS_F2FS) { return "f2fs"; }
    if (fs == FS_EROFS) { return "erofs"; }
    if (fs == FS_TMPFS) { return "tmpfs"; }
    if (fs == FS_CIFS) { return "cifs"; }
    if (fs == FS_NFS) { return "nfs"; }
    return "unknown";
}

# Case-insensitive string comparison helper
fn _str_eq_ci(a, b): i64 {
    var a_len = strlen(a);
    var b_len = strlen(b);
    if (a_len != b_len) { return 0; }
    for (var i = 0; i < a_len; i = i + 1) {
        var ca = load8(a + i);
        var cb = load8(b + i);
        # Lowercase: if A-Z (65-90), add 32
        if (ca >= 65) { if (ca <= 90) { ca = ca + 32; } }
        if (cb >= 65) { if (cb <= 90) { cb = cb + 32; } }
        if (ca != cb) { return 0; }
    }
    return 1;
}

# Parse filesystem type from string (case-insensitive, zero-alloc for known types)
pub fn filesystem_from_str(s) {
    if (_str_eq_ci(s, "ext4")) { return FS_EXT4; }
    if (_str_eq_ci(s, "btrfs")) { return FS_BTRFS; }
    if (_str_eq_ci(s, "xfs")) { return FS_XFS; }
    if (_str_eq_ci(s, "vfat")) { return FS_VFAT; }
    if (_str_eq_ci(s, "fat32")) { return FS_VFAT; }
    if (_str_eq_ci(s, "fat16")) { return FS_VFAT; }
    if (_str_eq_ci(s, "ntfs")) { return FS_NTFS; }
    if (_str_eq_ci(s, "exfat")) { return FS_EXFAT; }
    if (_str_eq_ci(s, "iso9660")) { return FS_ISO9660; }
    if (_str_eq_ci(s, "udf")) { return FS_UDF; }
    if (_str_eq_ci(s, "hfsplus")) { return FS_HFSPLUS; }
    if (_str_eq_ci(s, "hfs+")) { return FS_HFSPLUS; }
    if (_str_eq_ci(s, "swap")) { return FS_SWAP; }
    if (_str_eq_ci(s, "crypto_luks")) { return FS_LUKS; }
    if (_str_eq_ci(s, "luks")) { return FS_LUKS; }
    if (_str_eq_ci(s, "f2fs")) { return FS_F2FS; }
    if (_str_eq_ci(s, "erofs")) { return FS_EROFS; }
    if (_str_eq_ci(s, "tmpfs")) { return FS_TMPFS; }
    if (_str_eq_ci(s, "cifs")) { return FS_CIFS; }
    if (_str_eq_ci(s, "nfs")) { return FS_NFS; }
    if (_str_eq_ci(s, "nfs4")) { return FS_NFS; }
    return FS_UNKNOWN;
}

pub fn filesystem_is_writable(fs) {
    if (fs == FS_EXT4) { return 1; }
    if (fs == FS_BTRFS) { return 1; }
    if (fs == FS_XFS) { return 1; }
    if (fs == FS_VFAT) { return 1; }
    if (fs == FS_NTFS) { return 1; }
    if (fs == FS_EXFAT) { return 1; }
    if (fs == FS_HFSPLUS) { return 1; }
    if (fs == FS_F2FS) { return 1; }
    if (fs == FS_TMPFS) { return 1; }
    if (fs == FS_CIFS) { return 1; }
    if (fs == FS_NFS) { return 1; }
    return 0;
}

pub fn filesystem_is_optical(fs) {
    if (fs == FS_ISO9660) { return 1; }
    if (fs == FS_UDF) { return 1; }
    return 0;
}

# ---------------------------------------------------------------------------
# FilesystemUsage struct
# Layout: 32 bytes
#   0: total_bytes
#   8: used_bytes
#  16: available_bytes
#  24: usage_percent_x100 (integer, e.g. 4523 = 45.23%)
# ---------------------------------------------------------------------------

pub fn filesystem_usage(mount_point_cstr) {
    # SYS_STATFS = 137
    # struct statfs is 120 bytes on x86_64
    var buf[120];
    var r = syscall(SYS_STATFS, mount_point_cstr, &buf);
    if (r < 0) {
        var sb = str_builder_new();
        str_builder_add_cstr(sb, "statfs failed: errno ");
        str_builder_add_int(sb, 0 - r);
        return err_io(str_builder_build(sb));
    }

    # statfs layout (x86_64):
    #  0: f_type (8)
    #  8: f_bsize (8)
    # 16: f_blocks (8)
    # 24: f_bfree (8)
    # 32: f_bavail (8)
    # 40: f_files (8)  ... etc

    var bsize = load64(&buf + 8);
    var blocks = load64(&buf + 16);
    var bfree = load64(&buf + 24);
    var bavail = load64(&buf + 32);

    var total_bytes = blocks * bsize;
    var free_bytes = bfree * bsize;
    var available_bytes = bavail * bsize;
    var used_bytes = total_bytes - free_bytes;

    var usage_pct_x100 = 0;
    if (total_bytes > 0) {
        usage_pct_x100 = (used_bytes * 10000) / total_bytes;
    }

    var usage = alloc(32);
    store64(usage, total_bytes);
    store64(usage + 8, used_bytes);
    store64(usage + 16, available_bytes);
    store64(usage + 24, usage_pct_x100);
    return Ok(usage);
}

# ---------------------------------------------------------------------------
# MountOptions struct
# Layout: 32 bytes
#   0: mount_point (Str, 0 = auto)
#   8: read_only (0/1)
#  16: options (Str — comma-separated, e.g. "nosuid,nodev")
#  24: fs_type (Str, 0 = auto-detect)
# ---------------------------------------------------------------------------

pub fn mount_options_new() {
    var opts = alloc(32);
    store64(opts, 0);
    store64(opts + 8, 0);
    store64(opts + 16, str_from("nosuid,nodev"));
    store64(opts + 24, 0);
    return opts;
}

pub fn mount_options_set_point(opts, mp) { store64(opts, mp); return opts; }
pub fn mount_options_set_ro(opts, ro) { store64(opts + 8, ro); return opts; }
pub fn mount_options_set_fs(opts, fs) { store64(opts + 24, fs); return opts; }

# ---------------------------------------------------------------------------
# MountResult struct
# Layout: 40 bytes
#   0: device_id (DeviceId ptr)
#   8: dev_path (Str)
#  16: mount_point (Str)
#  24: fs_type (Filesystem enum)
#  32: read_only (0/1)
# ---------------------------------------------------------------------------

pub fn mount_result_new(device_id, dev_path, mount_point, fs_type, read_only) {
    var r = alloc(40);
    store64(r, device_id);
    store64(r + 8, dev_path);
    store64(r + 16, mount_point);
    store64(r + 24, fs_type);
    store64(r + 32, read_only);
    return r;
}

pub fn mr_device_id(r) { return load64(r); }
pub fn mr_dev_path(r) { return load64(r + 8); }
pub fn mr_mount_point(r) { return load64(r + 16); }
pub fn mr_fs_type(r) { return load64(r + 24); }
pub fn mr_read_only(r) { return load64(r + 32); }

# ---------------------------------------------------------------------------
# Forbidden system mount points
# ---------------------------------------------------------------------------

# Check that path starts with prefix + ('/' or '\0').
# Examples: _starts_with_dir("/etc/foo", "/etc") == 1
#           _starts_with_dir("/etcetera", "/etc") == 0
fn _starts_with_dir(path_cstr, prefix): i64 {
    var plen = strlen(prefix);
    var i = 0;
    while (i < plen) {
        if (load8(path_cstr + i) != load8(prefix + i)) { return 0; }
        i = i + 1;
    }
    var next = load8(path_cstr + plen);
    if (next == 0) { return 1; }
    if (next == 47) { return 1; }
    return 0;
}

# Reject paths that contain `..` as a path component, or `//` (double
# slash — our string compare below treats these as distinct from the
# canonical form, so tighten the input requirement).
fn _path_has_traversal(path_cstr): i64 {
    var len = strlen(path_cstr);
    if (len == 0) { return 1; }
    var i = 0;
    while (i < len) {
        var c = load8(path_cstr + i);
        # Reject empty components (double slash) except a leading "/"
        if (c == 47) {
            if (i > 0) {
                if (load8(path_cstr + i - 1) == 47) { return 1; }
            }
        }
        # Reject ".." component: "/../" or trailing "/.."
        if (c == 46) {
            if (load8(path_cstr + i + 1) == 46) {
                var prev = 47;
                if (i > 0) { prev = load8(path_cstr + i - 1); }
                var nxt = load8(path_cstr + i + 2);
                if (prev == 47) {
                    if (nxt == 47) { return 1; }
                    if (nxt == 0) { return 1; }
                }
            }
        }
        i = i + 1;
    }
    return 0;
}

fn _is_forbidden_mount(path_cstr): i64 {
    # Root is a literal match only — no prefix rule can apply to "/".
    if (streq(path_cstr, "/")) { return 1; }
    # Protected system directories — block the dir itself AND anything
    # under it (addresses audit finding MED-1).
    if (_starts_with_dir(path_cstr, "/bin"))    { return 1; }
    if (_starts_with_dir(path_cstr, "/sbin"))   { return 1; }
    if (_starts_with_dir(path_cstr, "/lib"))    { return 1; }
    if (_starts_with_dir(path_cstr, "/lib64"))  { return 1; }
    if (_starts_with_dir(path_cstr, "/usr"))    { return 1; }
    if (_starts_with_dir(path_cstr, "/etc"))    { return 1; }
    if (_starts_with_dir(path_cstr, "/boot"))   { return 1; }
    if (_starts_with_dir(path_cstr, "/sys"))    { return 1; }
    if (_starts_with_dir(path_cstr, "/proc"))   { return 1; }
    if (_starts_with_dir(path_cstr, "/dev"))    { return 1; }
    if (_starts_with_dir(path_cstr, "/root"))   { return 1; }
    if (_starts_with_dir(path_cstr, "/var"))    { return 1; }
    if (_starts_with_dir(path_cstr, "/home"))   { return 1; }
    if (_starts_with_dir(path_cstr, "/srv"))    { return 1; }
    if (_starts_with_dir(path_cstr, "/opt"))    { return 1; }
    return 0;
}

# ---------------------------------------------------------------------------
# Octal unescape for /proc/mounts paths
# The kernel encodes spaces as \040, tabs as \011, etc.
# ---------------------------------------------------------------------------

pub fn unescape_mount_path(s, s_len) {
    var sb = str_builder_new();
    var i = 0;
    while (i < s_len) {
        var c = load8(s + i);
        if (c == 92) {
            # backslash — check for octal escape
            if (i + 3 < s_len) {
                var d1 = load8(s + i + 1);
                var d2 = load8(s + i + 2);
                var d3 = load8(s + i + 3);
                if (d1 >= 48) { if (d1 <= 55) {
                        if (d2 >= 48) { if (d2 <= 55) {
                                if (d3 >= 48) { if (d3 <= 55) {
                                        var val = (d1 - 48) * 64 + (d2 - 48) * 8 + (d3 - 48);
                                        str_builder_add_byte(sb, val);
                                        i = i + 4;
                                        continue;
                                    } } } } } }
            }
        }
        str_builder_add_byte(sb, c);
        i = i + 1;
    }
    return str_builder_build(sb);
}

# ---------------------------------------------------------------------------
# find_mount_in — parse mount table to find device mount point
# ---------------------------------------------------------------------------

pub fn find_mount_in(dev_path_cstr, mount_table) {
    var lines = str_split(mount_table, 10);
    var nlines = vec_len(lines);

    for (var i = 0; i < nlines; i = i + 1) {
        var line = vec_get(lines, i);
        var trimmed = str_trim(line);
        if (str_len(trimmed) == 0) { continue; }
        if (load8(str_data(trimmed)) == 35) { continue; }

        # Split line by spaces: device mountpoint fstype options dump pass
        var fields = str_split(trimmed, 32);
        if (vec_len(fields) < 2) { continue; }

        var device_field = vec_get(fields, 0);
        var mount_field = vec_get(fields, 1);

        var device_unesc = unescape_mount_path(str_data(device_field), str_len(device_field));
        var mount_unesc = unescape_mount_path(str_data(mount_field), str_len(mount_field));

        if (str_eq_cstr(device_unesc, dev_path_cstr)) {
            return mount_unesc;
        }
    }
    return 0;
}

# ---------------------------------------------------------------------------
# find_mount_point — read /proc/mounts and find device
# ---------------------------------------------------------------------------

pub fn find_mount_point(dev_path_cstr) {
    # /proc/mounts can exceed 8 KB on container / btrfs / snap-heavy
    # systems — a fixed stack buffer silently truncated the tail and
    # caused false-negative mount lookups (audit finding MED-3).
    # Read in 4 KB chunks until EOF and assemble via str_builder.
    # Syscalls inlined: open=2, read=0, close=3. O_RDONLY=0.
    var fd = sys_open("/proc/mounts", 0, 0);
    if (fd < 0) { return 0; }
    var sb = str_builder_new();
    var chunk[4096];
    var total = 0;
    var going = 1;
    while (going == 1) {
        var n = sys_read(fd, &chunk, 4096);
        if (n < 0) { going = 0; }
        elif (n == 0) { going = 0; }
        else {
            # Cap total at 1 MB to bound memory under a hostile /proc/mounts
            if (total + n > 1048576) {
                going = 0;
            } else {
                var i = 0;
                while (i < n) {
                    str_builder_add_byte(sb, load8(&chunk + i));
                    i = i + 1;
                }
                total = total + n;
            }
        }
    }
    sys_close(fd);
    if (total == 0) { return 0; }
    return find_mount_in(dev_path_cstr, str_builder_build(sb));
}

# ---------------------------------------------------------------------------
# default_mount_point — generate safe mount path
# ---------------------------------------------------------------------------

pub fn default_mount_point(info) {
    var label = di_label(info);
    var name = label;
    if (name == 0) {
        name = device_id_str(di_id(info));
    }

    # Sanitize: replace non-alphanumeric with underscore. Cap at
    # 64 chars so pathological USB labels can't bloat the mount path
    # (audit finding LOW-4). Many filesystems allow up to 255 bytes;
    # /run/media/<64> is plenty for humans and keeps PATH_MAX wiggle
    # room for downstream consumers that concat file names.
    var src = str_data(name);
    var slen = str_len(name);
    if (slen > 64) { slen = 64; }
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "/run/media/");
    for (var i = 0; i < slen; i = i + 1) {
        var c = load8(src + i);
        if (c >= 48) { if (c <= 57) { str_builder_add_byte(sb, c); continue; } }
        if (c >= 65) { if (c <= 90) { str_builder_add_byte(sb, c); continue; } }
        if (c >= 97) { if (c <= 122) { str_builder_add_byte(sb, c); continue; } }
        if (c == 45) { str_builder_add_byte(sb, c); continue; }
        if (c == 95) { str_builder_add_byte(sb, c); continue; }
        str_builder_add_byte(sb, 95);
    }
    return str_builder_build(sb);
}

# ---------------------------------------------------------------------------
# is_mounted — check if device is mounted via /proc/mounts
# ---------------------------------------------------------------------------

pub fn is_mounted(dev_path_cstr) {
    var mp = find_mount_point(dev_path_cstr);
    return mp != 0;
}

# ---------------------------------------------------------------------------
# validate_mount_point — check safety
# ---------------------------------------------------------------------------

pub fn validate_mount_point(path_cstr) {
    # Must be absolute
    if (load8(path_cstr) != 47) {
        var sb = str_builder_new();
        str_builder_add_cstr(sb, "mount point must be absolute: ");
        str_builder_add_cstr(sb, path_cstr);
        return err_mount_failed(str_from(""), str_builder_build(sb));
    }

    # Reject `..` components and `//` — path must already be in
    # canonical form. Callers must pre-resolve symlinks or pass
    # a simple absolute path. Prevents the _is_forbidden_mount
    # blacklist below from being bypassed by "/mnt/../etc".
    if (_path_has_traversal(path_cstr)) {
        var sb = str_builder_new();
        str_builder_add_cstr(sb, "mount point contains traversal ('..' or '//'): ");
        str_builder_add_cstr(sb, path_cstr);
        return err_mount_failed(str_from(""), str_builder_build(sb));
    }

    # Must not be forbidden
    if (_is_forbidden_mount(path_cstr)) {
        var sb = str_builder_new();
        str_builder_add_cstr(sb, "cannot mount on system directory: ");
        str_builder_add_cstr(sb, path_cstr);
        return err_mount_failed(str_from(""), str_builder_build(sb));
    }

    return Ok(0);
}

# ---------------------------------------------------------------------------
# parse_mount_flags — convert option strings to mount syscall flags
# ---------------------------------------------------------------------------

enum MountFlag {
    MS_RDONLY = 1;
    MS_NOSUID = 2;
    MS_NODEV = 4;
    MS_NOEXEC = 8;
}

fn _parse_mount_flags(options_str, read_only): i64 {
    var flags = 0;
    if (read_only) { flags = flags | MS_RDONLY; }

    if (options_str == 0) { return flags; }

    var parts = str_split(options_str, 44);
    var n = vec_len(parts);
    for (var i = 0; i < n; i = i + 1) {
        var opt = vec_get(parts, i);
        var opt_trimmed = str_trim(opt);
        if (str_eq_cstr(opt_trimmed, "nosuid")) { flags = flags | MS_NOSUID; }
        if (str_eq_cstr(opt_trimmed, "nodev")) { flags = flags | MS_NODEV; }
        if (str_eq_cstr(opt_trimmed, "noexec")) { flags = flags | MS_NOEXEC; }
    }
    return flags;
}

# ---------------------------------------------------------------------------
# Filesystem types to try when auto-detecting
# ---------------------------------------------------------------------------

fn _get_auto_fs_type(idx): i64 {
    if (idx == 0) { return "ext4"; }
    if (idx == 1) { return "vfat"; }
    if (idx == 2) { return "ntfs"; }
    if (idx == 3) { return "iso9660"; }
    if (idx == 4) { return "udf"; }
    if (idx == 5) { return "exfat"; }
    if (idx == 6) { return "btrfs"; }
    if (idx == 7) { return "xfs"; }
    if (idx == 8) { return "f2fs"; }
    if (idx == 9) { return "erofs"; }
    return 0;
}

enum AutoFs {
    AUTO_FS_COUNT = 10;
}

# ---------------------------------------------------------------------------
# mount — mount a device via SYS_MOUNT (165)
# ---------------------------------------------------------------------------

pub fn storage_mount(dev_path_cstr, options) {
    # Check if already mounted
    var existing = find_mount_point(dev_path_cstr);
    if (existing != 0) {
        return err_already_mounted(str_from(dev_path_cstr), existing);
    }

    # Determine mount point
    var mp_str = load64(options);
    var mount_cstr = 0;
    if (mp_str != 0) {
        mount_cstr = str_cstr(mp_str);
    } else {
        # Auto-generate: /run/media/<dev_name>
        var dev_s = str_from(dev_path_cstr);
        # Find last / to get device name
        var idx = str_last_index_of(dev_s, "/");
        var dev_name = dev_s;
        if (idx >= 0) {
            dev_name = str_substr(dev_s, idx + 1, str_len(dev_s));
        }
        var sb = str_builder_new();
        str_builder_add_cstr(sb, "/run/media/");
        str_builder_add_str(sb, dev_name);
        var mp = str_builder_build(sb);
        mount_cstr = str_cstr(mp);
    }

    # Validate mount point
    var val_r = validate_mount_point(mount_cstr);
    if (is_ok(val_r) == 0) { return val_r; }

    sakshi_span_enter("mount", 5);

    # Create mount point directory: SYS_MKDIR = 83, mode 0755.
    sys_mkdir(mount_cstr, 493);

    # TOCTOU guard (audit finding MED-2, CVE-2026-27456 class):
    # between validate_mount_point and mount(2) an attacker with write
    # access to the mount parent could symlink the target at /etc or
    # similar. lstat via newfstatat(AT_SYMLINK_NOFOLLOW) refuses to
    # follow the final component — if it's a symlink we abort.
    #   newfstatat = 262, AT_FDCWD = -100, AT_SYMLINK_NOFOLLOW = 256
    #   struct stat: st_mode is u32 at offset 24
    #   S_IFMT = 0xF000, S_IFLNK = 0xA000, S_IFDIR = 0x4000
    var stbuf[144];
    var st_rc = syscall(SYS_NEWFSTATAT, 0 - 100, mount_cstr, &stbuf, 256);
    if (st_rc < 0) {
        sakshi_span_exit();
        return err_mount_failed(str_from(dev_path_cstr),
        str_from("mount target stat failed"));
    }
    var mode = load32(&stbuf + 24);
    var fmt = mode & 61440;   # 0xF000
    if (fmt == 40960) {       # 0xA000 — symlink
        sakshi_span_exit();
        return err_mount_failed(str_from(dev_path_cstr),
        str_from("mount target is a symlink (TOCTOU guard)"));
    }
    if (fmt != 16384) {       # 0x4000 — directory
        sakshi_span_exit();
        return err_mount_failed(str_from(dev_path_cstr),
        str_from("mount target is not a directory"));
    }

    var read_only = load64(options + 8);
    var opts_str = load64(options + 16);
    var flags = _parse_mount_flags(opts_str, read_only);

    var fs_type_str = load64(options + 24);

    if (fs_type_str != 0) {
        # Explicit filesystem type
        var fs_cstr = str_cstr(fs_type_str);
        var r = sys_mount(dev_path_cstr, mount_cstr, fs_cstr, flags, 0);
        if (r < 0) {
            var errno = 0 - r;
            return map_errno_to_err(errno, "mount", str_from(dev_path_cstr));
        }
        sakshi_span_exit();
        var dev_id = device_id_new_cstr(dev_path_cstr);
        return Ok(mount_result_new(dev_id, str_from(dev_path_cstr), str_from(mount_cstr),
        filesystem_from_str(fs_cstr), read_only));
    }

    # Auto-detect filesystem type
    var last_errno = 0;
    for (var i = 0; i < AUTO_FS_COUNT; i = i + 1) {
        var fs_try = _get_auto_fs_type(i);
        if (fs_try == 0) { break; }
        var r = sys_mount(dev_path_cstr, mount_cstr, fs_try, flags, 0);
        if (r == 0) {
            sakshi_span_exit();
            var dev_id = device_id_new_cstr(dev_path_cstr);
            return Ok(mount_result_new(dev_id, str_from(dev_path_cstr), str_from(mount_cstr),
            filesystem_from_str(fs_try), read_only));
        }
        last_errno = 0 - r;
    }

    return map_errno_to_err(last_errno, "mount", str_from(dev_path_cstr));
}

# ---------------------------------------------------------------------------
# unmount — unmount via SYS_UMOUNT2 (166)
# ---------------------------------------------------------------------------

pub fn storage_unmount(mount_point_cstr) {
    sakshi_span_enter("unmount", 7);

    # SYS_UMOUNT2 = 166, flags = 0
    var r = sys_umount2(mount_point_cstr, 0);
    if (r < 0) {
        var errno = 0 - r;
        sakshi_span_exit();
        if (errno == 1) {
            return err_permission_denied(str_from("unmount"), str_from(mount_point_cstr));
        }
        if (errno == 13) {
            return err_permission_denied(str_from("unmount"), str_from(mount_point_cstr));
        }
        if (errno == 16) { return err_device_busy(str_from(mount_point_cstr)); }
        var sb = str_builder_new();
        str_builder_add_cstr(sb, "umount failed: errno ");
        str_builder_add_int(sb, errno);
        return err_unmount_failed(str_from(mount_point_cstr), str_builder_build(sb));
    }

    sakshi_span_exit();

    # Clean up mount directory if under /run/media/
    # SYS_RMDIR = 84
    var mp_s = str_from(mount_point_cstr);
    if (str_starts_with(mp_s, "/run/media/")) {
        sys_rmdir(mount_point_cstr);
    }

    return Ok(0);
}

# ---------------------------------------------------------------------------
# eject — eject device (CDROMEJECT ioctl or sysfs delete)
# ---------------------------------------------------------------------------

enum EjectConst {
    CDROMEJECT_IOCTL = 0x5309;
    O_RDONLY = 0;
    O_NONBLOCK = 2048;
}

pub fn storage_eject(dev_path_cstr) {
    sakshi_span_enter("eject", 5);

    # Unmount first if mounted
    var mp = find_mount_point(dev_path_cstr);
    if (mp != 0) {
        var um_r = storage_unmount(str_cstr(mp));
        if (is_ok(um_r) == 0) { return um_r; }
    }

    # Get device name from path
    var dev_s = str_from(dev_path_cstr);
    var idx = str_last_index_of(dev_s, "/");
    var dev_name = dev_s;
    if (idx >= 0) {
        dev_name = str_substr(dev_s, idx + 1, str_len(dev_s));
    }

    # Check if optical drive (starts with "sr")
    if (str_starts_with(dev_name, "sr")) {
        # Optical: open device and CDROMEJECT ioctl
        var fd = sys_open(dev_path_cstr, O_RDONLY | O_NONBLOCK, 0);
        if (fd < 0) {
            return err_eject_failed(dev_s, str_from("failed to open device"));
        }
        var r = syscall(SYS_IOCTL, fd, CDROMEJECT_IOCTL, 0);
        sys_close(fd);
        if (r < 0) {
            return err_eject_failed(dev_s, str_from("CDROMEJECT ioctl failed"));
        }
    } else {
        # USB/block: strip partition suffix to get base device name
        var base_name = dev_name;
        # For nvme/mmcblk: strip p<digits> suffix
        if (str_contains_cstr(dev_name, "nvme")) {
            var p_idx = str_last_index_of(dev_name, "p");
            if (p_idx > 0) {
                base_name = str_substr(dev_name, 0, p_idx);
            }
        } elif (str_contains_cstr(dev_name, "mmcblk")) {
            var p_idx = str_last_index_of(dev_name, "p");
            if (p_idx > 0) {
                base_name = str_substr(dev_name, 0, p_idx);
            }
        } else {
            # sdb1 -> sdb: strip trailing digits
            var name_data = str_data(dev_name);
            var name_len = str_len(dev_name);
            var end = name_len;
            while (end > 0) {
                var c = load8(name_data + end - 1);
                if (c < 48) { break; }
                if (c > 57) { break; }
                end = end - 1;
            }
            if (end > 0) {
                base_name = str_substr(dev_name, 0, end);
            }
        }

        # Strict allowlist for base_name before building the sysfs path:
        # [a-zA-Z0-9_-]+, length 1..32. Sysfs legitimately uses
        # symlinks under /sys/block/, so O_NOFOLLOW on the full path
        # would break the common case — we validate the untrusted
        # component instead (audit finding LOW-1).
        var bn_data = str_data(base_name);
        var bn_len = str_len(base_name);
        if (bn_len == 0) {
            return err_eject_failed(dev_s, str_from("empty device name"));
        }
        if (bn_len > 32) {
            return err_eject_failed(dev_s, str_from("device name too long"));
        }
        var bn_ok = 1;
        for (var ci = 0; ci < bn_len; ci = ci + 1) {
            var bc = load8(bn_data + ci);
            var good = 0;
            if (bc >= 48) { if (bc <= 57) { good = 1; } }    # 0-9
            if (bc >= 65) { if (bc <= 90) { good = 1; } }    # A-Z
            if (bc >= 97) { if (bc <= 122) { good = 1; } }   # a-z
            if (bc == 45) { good = 1; }                      # -
            if (bc == 95) { good = 1; }                      # _
            if (good == 0) { bn_ok = 0; }
        }
        if (bn_ok == 0) {
            return err_eject_failed(dev_s, str_from("invalid device name chars"));
        }

        # Write "1" to /sys/block/<base>/device/delete
        var sb = str_builder_new();
        str_builder_add_cstr(sb, "/sys/block/");
        str_builder_add_str(sb, base_name);
        str_builder_add_cstr(sb, "/device/delete");
        var delete_path = str_builder_build(sb);

        var fd = sys_open(str_cstr(delete_path), 1, 0);
        if (fd < 0) {
            return err_eject_failed(dev_s, str_from("failed to open sysfs delete"));
        }
        sys_write(fd, "1", 1);
        sys_close(fd);
    }

    sakshi_span_exit();
    return Ok(0);
}

# --- optical.cyr ---

# yukti/optical.cyr — Optical drive operations
#
# Disc type detection, tray control, TOC reading.
# All hardware ops via direct syscalls/ioctls.

# ---------------------------------------------------------------------------
# DiscType enum — 10 variants
# ---------------------------------------------------------------------------

enum DiscType {
    DT_CD_AUDIO = 0;
    DT_CD_DATA = 1;
    DT_CD_MIXED = 2;
    DT_DVD_ROM = 3;
    DT_DVD_WRITABLE = 4;
    DT_DVD_VIDEO = 5;
    DT_BLURAY = 6;
    DT_BLURAY_VIDEO = 7;
    DT_BLANK = 8;
    DT_UNKNOWN = 9;
    # Capacity / layout variants (2.1.0 — optical enhancements).
    # Match the Rust crate's DVD±R DL and dual-sided classes so
    # downstream consumers can distinguish a 4.7 GB SL disc from an
    # 8.5 GB DL or a 9.4 GB DS on the same drive.
    DT_DVD_WRITABLE_DL = 10;
    DT_DVD_ROM_DL = 11;
    DT_DVD_DUAL_SIDED = 12;
    DT_BLURAY_DL = 13;
    DT_BLURAY_XL = 14;
}

pub fn disc_type_to_str(dt) {
    if (dt == DT_CD_AUDIO) { return "CD-DA (Audio)"; }
    if (dt == DT_CD_DATA) { return "CD-ROM (Data)"; }
    if (dt == DT_CD_MIXED) { return "CD (Mixed Mode)"; }
    if (dt == DT_DVD_ROM) { return "DVD-ROM"; }
    if (dt == DT_DVD_WRITABLE) { return "DVD-R/RW"; }
    if (dt == DT_DVD_VIDEO) { return "DVD Video"; }
    if (dt == DT_BLURAY) { return "Blu-ray"; }
    if (dt == DT_BLURAY_VIDEO) { return "Blu-ray Video"; }
    if (dt == DT_BLANK) { return "Blank"; }
    if (dt == DT_DVD_WRITABLE_DL) { return "DVD±R DL (Dual Layer)"; }
    if (dt == DT_DVD_ROM_DL) { return "DVD-ROM DL"; }
    if (dt == DT_DVD_DUAL_SIDED) { return "DVD Dual-Sided"; }
    if (dt == DT_BLURAY_DL) { return "Blu-ray DL (Dual Layer, 50GB)"; }
    if (dt == DT_BLURAY_XL) { return "Blu-ray XL (Triple/Quad Layer)"; }
    return "Unknown";
}

pub fn disc_type_has_audio(dt) {
    if (dt == DT_CD_AUDIO) { return 1; }
    if (dt == DT_CD_MIXED) { return 1; }
    return 0;
}

pub fn disc_type_has_data(dt) {
    if (dt == DT_CD_DATA) { return 1; }
    if (dt == DT_CD_MIXED) { return 1; }
    if (dt == DT_DVD_ROM) { return 1; }
    if (dt == DT_DVD_WRITABLE) { return 1; }
    if (dt == DT_DVD_VIDEO) { return 1; }
    if (dt == DT_BLURAY) { return 1; }
    if (dt == DT_BLURAY_VIDEO) { return 1; }
    if (dt == DT_DVD_WRITABLE_DL) { return 1; }
    if (dt == DT_DVD_ROM_DL) { return 1; }
    if (dt == DT_DVD_DUAL_SIDED) { return 1; }
    if (dt == DT_BLURAY_DL) { return 1; }
    if (dt == DT_BLURAY_XL) { return 1; }
    return 0;
}

pub fn disc_type_is_writable(dt) {
    if (dt == DT_DVD_WRITABLE) { return 1; }
    if (dt == DT_DVD_WRITABLE_DL) { return 1; }
    if (dt == DT_BLANK) { return 1; }
    return 0;
}

# Nominal sector capacity for a disc type (for size estimation when
# the drive hasn't reported actual geometry yet). Returns sectors of
# 2048 bytes; callers multiply by SECTOR_SIZE for bytes.
#   CD-ROM ~700 MB  →  333 K sectors
#   DVD SL ~4.7 GB  →  2.29 M sectors
#   DVD DL ~8.5 GB  →  4.15 M sectors
#   BD SL  ~25 GB   → 12.2 M sectors
#   BD DL  ~50 GB   → 24.4 M sectors
#   BD XL  ~100 GB  → 48.8 M sectors
pub fn disc_type_nominal_sectors(dt) {
    if (dt == DT_CD_AUDIO) { return 333000; }
    if (dt == DT_CD_DATA) { return 333000; }
    if (dt == DT_CD_MIXED) { return 333000; }
    if (dt == DT_DVD_ROM) { return 2295104; }
    if (dt == DT_DVD_WRITABLE) { return 2295104; }
    if (dt == DT_DVD_VIDEO) { return 2295104; }
    if (dt == DT_DVD_WRITABLE_DL) { return 4148608; }
    if (dt == DT_DVD_ROM_DL) { return 4148608; }
    if (dt == DT_DVD_DUAL_SIDED) { return 4590208; }
    if (dt == DT_BLURAY) { return 12219392; }
    if (dt == DT_BLURAY_VIDEO) { return 12219392; }
    if (dt == DT_BLURAY_DL) { return 24438784; }
    if (dt == DT_BLURAY_XL) { return 48877568; }
    return 0;
}

# ---------------------------------------------------------------------------
# TrayState enum
# ---------------------------------------------------------------------------

enum TrayState {
    TS_OPEN = 0;
    TS_CLOSED = 1;
    TS_UNKNOWN = 2;
}

pub fn tray_state_to_str(ts) {
    if (ts == TS_OPEN) { return "open"; }
    if (ts == TS_CLOSED) { return "closed"; }
    return "unknown";
}

# ---------------------------------------------------------------------------
# TrackType enum
# ---------------------------------------------------------------------------

enum TrackType {
    TT_AUDIO = 0;
    TT_DATA = 1;
    TT_UNKNOWN = 2;
}

# ---------------------------------------------------------------------------
# ioctl constants
# ---------------------------------------------------------------------------

enum OpticalIoctl {
    IOCTL_CDROMEJECT = 0x5309;
    IOCTL_CDROMCLOSETRAY = 0x5319;
    IOCTL_CDROM_DRIVE_STATUS = 0x5326;
    IOCTL_CDROMREADTOCHDR = 0x5305;
    IOCTL_CDROMREADTOCENTRY = 0x5306;
    IOCTL_CDROMREADAUDIO = 0x530E;
    CDROM_LBA = 0x01;
    CDROM_LEADOUT = 0xAA;
    CDS_NO_DISC = 1;
    CDS_TRAY_OPEN = 2;
    CDS_DRIVE_NOT_READY = 3;
    CDS_DISC_OK = 4;
    ENOMEDIUM = 123;
    # Red Book CD-DA constants
    CDDA_FRAME_SIZE = 2352;         # bytes per audio sector
    CDDA_MAX_FRAMES_PER_READ = 75;  # 1 s of audio at 75 fps
}

# ---------------------------------------------------------------------------
# TocEntry struct
# Layout: 40 bytes
#   0: number (track number, 1-based)
#   8: track_type (TrackType)
#  16: start_lba
#  24: length_sectors
#  32: duration_secs_x100 (integer, e.g. 18050 = 180.50s)
# ---------------------------------------------------------------------------

pub fn toc_entry_new(number, track_type, start_lba, length_sectors, duration_x100) {
    var e = alloc(40);
    store64(e, number);
    store64(e + 8, track_type);
    store64(e + 16, start_lba);
    store64(e + 24, length_sectors);
    store64(e + 32, duration_x100);
    return e;
}

pub fn te_number(e) { return load64(e); }
pub fn te_track_type(e) { return load64(e + 8); }
pub fn te_start_lba(e) { return load64(e + 16); }
pub fn te_length_sectors(e) { return load64(e + 24); }
pub fn te_duration_x100(e) { return load64(e + 32); }

# ---------------------------------------------------------------------------
# DiscToc struct
# Layout: 24 bytes
#   0: disc_type (DiscType)
#   8: tracks (vec of TocEntry ptrs)
#  16: total_size_bytes
# ---------------------------------------------------------------------------

pub fn disc_toc_new(disc_type, tracks_vec, total_size) {
    var t = alloc(24);
    store64(t, disc_type);
    store64(t + 8, tracks_vec);
    store64(t + 16, total_size);
    return t;
}

pub fn toc_disc_type(t) { return load64(t); }
pub fn toc_tracks(t) { return load64(t + 8); }
pub fn toc_total_size(t) { return load64(t + 16); }

pub fn toc_audio_track_count(toc) {
    var tracks = toc_tracks(toc);
    var count = 0;
    var n = vec_len(tracks);
    for (var i = 0; i < n; i = i + 1) {
        var entry = vec_get(tracks, i);
        if (te_track_type(entry) == TT_AUDIO) { count = count + 1; }
    }
    return count;
}

pub fn toc_data_track_count(toc) {
    var tracks = toc_tracks(toc);
    var count = 0;
    var n = vec_len(tracks);
    for (var i = 0; i < n; i = i + 1) {
        var entry = vec_get(tracks, i);
        if (te_track_type(entry) == TT_DATA) { count = count + 1; }
    }
    return count;
}

# Total audio duration in centiseconds (x100)
pub fn toc_total_audio_duration_x100(toc) {
    var tracks = toc_tracks(toc);
    var total = 0;
    var n = vec_len(tracks);
    for (var i = 0; i < n; i = i + 1) {
        var entry = vec_get(tracks, i);
        if (te_track_type(entry) == TT_AUDIO) {
            total = total + te_duration_x100(entry);
        }
    }
    return total;
}

# ---------------------------------------------------------------------------
# Helper: open optical device with O_RDONLY | O_NONBLOCK
# ---------------------------------------------------------------------------

fn _open_optical_device(dev_path_cstr): i64 {
    var fd = sys_open(dev_path_cstr, O_RDONLY | O_NONBLOCK, 0);
    if (fd < 0) {
        var errno = 0 - fd;
        if (errno == 13) {
            return err_permission_denied(str_from("open"), str_from(dev_path_cstr));
        }
        if (errno == 1) {
            return err_permission_denied(str_from("open"), str_from(dev_path_cstr));
        }
        if (errno == ENOMEDIUM) { return err_no_media(str_from(dev_path_cstr)); }
        return err_io(str_from(dev_path_cstr));
    }
    return Ok(fd);
}

# ---------------------------------------------------------------------------
# open_tray — eject/open optical drive tray
# ---------------------------------------------------------------------------

pub fn open_tray(dev_path_cstr) {
    sakshi_span_enter("open_tray", 9);
    var fd_r = _open_optical_device(dev_path_cstr);
    if (is_ok(fd_r) == 0) { return fd_r; }
    var fd = payload(fd_r);

    var ret = syscall(SYS_IOCTL, fd, IOCTL_CDROMEJECT, 0);
    sys_close(fd);

    if (ret < 0) {
        sakshi_span_exit();
        return err_tray_failed(str_from("eject ioctl failed"));
    }

    sakshi_span_exit();
    return Ok(0);
}

# ---------------------------------------------------------------------------
# close_tray — close optical drive tray
# ---------------------------------------------------------------------------

pub fn close_tray(dev_path_cstr) {
    sakshi_span_enter("close_tray", 10);
    var fd_r = _open_optical_device(dev_path_cstr);
    if (is_ok(fd_r) == 0) { return fd_r; }
    var fd = payload(fd_r);

    var ret = syscall(SYS_IOCTL, fd, IOCTL_CDROMCLOSETRAY, 0);
    sys_close(fd);

    if (ret < 0) {
        sakshi_span_exit();
        return err_tray_failed(str_from("close tray ioctl failed"));
    }

    sakshi_span_exit();
    return Ok(0);
}

# ---------------------------------------------------------------------------
# drive_status — query tray state
# ---------------------------------------------------------------------------

pub fn drive_status(dev_path_cstr) {
    var fd_r = _open_optical_device(dev_path_cstr);
    if (is_ok(fd_r) == 0) { return fd_r; }
    var fd = payload(fd_r);

    var ret = syscall(SYS_IOCTL, fd, IOCTL_CDROM_DRIVE_STATUS, 0);
    sys_close(fd);

    if (ret < 0) {
        return err_tray_failed(str_from("drive status ioctl failed"));
    }

    if (ret == CDS_TRAY_OPEN) { return Ok(TS_OPEN); }
    if (ret == CDS_DISC_OK) { return Ok(TS_CLOSED); }
    if (ret == CDS_NO_DISC) { return Ok(TS_CLOSED); }
    if (ret == CDS_DRIVE_NOT_READY) { return Ok(TS_CLOSED); }
    return Ok(TS_UNKNOWN);
}

# ---------------------------------------------------------------------------
# read_toc — read CD table of contents via ioctls
# ---------------------------------------------------------------------------

pub fn read_toc(dev_path_cstr) {
    sakshi_span_enter("read_toc", 8);
    var fd_r = _open_optical_device(dev_path_cstr);
    if (is_ok(fd_r) == 0) { return fd_r; }
    var fd = payload(fd_r);

    # Read TOC header: struct cdrom_tochdr { u8 first, u8 last }
    var hdr[2];
    store8(&hdr, 0);
    store8(&hdr + 1, 0);
    var ret = syscall(SYS_IOCTL, fd, IOCTL_CDROMREADTOCHDR, &hdr);
    if (ret < 0) {
        sys_close(fd);
        return err_tray_failed(str_from("read TOC header failed"));
    }

    var first = load8(&hdr);
    var last = load8(&hdr + 1);

    # Read LBA for each track plus lead-out (0xAA)
    # struct cdrom_tocentry: { u8 track, u8 adr_ctrl, u8 format, union addr(4+pad), u8 datamode }
    # For LBA format: addr is i32 at offset 4 (after 3 bytes of track/adr_ctrl/format, padded)
    # Actual struct layout on x86_64:
    #   0: track (u8)
    #   1: adr_ctrl (u8)
    #   2: format (u8)
    #   3: padding (1 byte)
    #   4: addr union (4 bytes for LBA i32)
    #   8: datamode (u8)
    #   total: ~12 bytes, padded to alignment

    var lba_vec = vec_new();
    var ctrl_vec = vec_new();

    var track_num = first;
    while (track_num <= last) {
        var entry[16];
        store8(&entry, track_num);
        store8(&entry + 1, 0);
        store8(&entry + 2, CDROM_LBA);
        store32(&entry + 4, 0);
        store8(&entry + 8, 0);

        ret = syscall(SYS_IOCTL, fd, IOCTL_CDROMREADTOCENTRY, &entry);
        if (ret < 0) {
            sys_close(fd);
            return err_tray_failed(str_from("read TOC entry failed"));
        }

        var lba = load32(&entry + 4);
        var adr_ctrl = load8(&entry + 1);
        vec_push(lba_vec, lba);
        vec_push(ctrl_vec, adr_ctrl);

        track_num = track_num + 1;
    }

    # Read lead-out entry
    var leadout[16];
    store8(&leadout, CDROM_LEADOUT);
    store8(&leadout + 1, 0);
    store8(&leadout + 2, CDROM_LBA);
    store32(&leadout + 4, 0);
    store8(&leadout + 8, 0);
    ret = syscall(SYS_IOCTL, fd, IOCTL_CDROMREADTOCENTRY, &leadout);
    if (ret < 0) {
        sys_close(fd);
        return err_tray_failed(str_from("read lead-out failed"));
    }
    var leadout_lba = load32(&leadout + 4);
    vec_push(lba_vec, leadout_lba);

    sys_close(fd);

    # Build track entries
    var tracks = vec_new();
    var has_audio = 0;
    var has_data = 0;
    var num_tracks = vec_len(lba_vec) - 1;

    # Largest plausible track length. A full Red Book CD holds ~333k
    # sectors (~74 min at 75 frames/sec). Triple-layer BD holds
    # ~50 M sectors. 128 M sectors (256 GB) is comfortably beyond the
    # largest real disc — bigger values imply a crafted TOC.
    # Clamp instead of trusting the drive (audit finding LOW-2).
    for (var i = 0; i < num_tracks; i = i + 1) {
        var start_lba = vec_get(lba_vec, i);
        var next_lba = vec_get(lba_vec, i + 1);
        var length = next_lba - start_lba;
        if (length < 0) { length = 0; }
        if (length > 134217728) { length = 134217728; }   # 128M-sector cap

        var adr_ctrl = vec_get(ctrl_vec, i);
        var is_data_track = (adr_ctrl & 4) != 0;

        var tt = TT_AUDIO;
        var duration_x100 = 0;
        if (is_data_track) {
            tt = TT_DATA;
            has_data = 1;
        } else {
            has_audio = 1;
            # Audio: 75 frames/sec -> duration = length / 75
            # x100 for centiseconds: length * 100 / 75 = length * 4 / 3
            # length bounded above, so this multiply stays in i64.
            duration_x100 = (length * 100) / 75;
        }

        var entry = toc_entry_new(first + i, tt, start_lba, length, duration_x100);
        vec_push(tracks, entry);
    }

    # Total size: lead-out LBA * 2048. Clamp lead-out the same way
    # before multiplying so `total_size` stays sane on crafted discs.
    if (leadout_lba < 0) { leadout_lba = 0; }
    if (leadout_lba > 134217728) { leadout_lba = 134217728; }
    var total_size = leadout_lba * 2048;

    # Classify disc type
    var dt = classify_toc_tracks(has_audio, has_data);

    sakshi_span_exit();

    return Ok(disc_toc_new(dt, tracks, total_size));
}

# ---------------------------------------------------------------------------
# read_audio_sectors — raw CD-DA sector rip (CDROMREADAUDIO ioctl)
#
# Reads `nframes` consecutive Red Book audio sectors starting at
# `start_lba` into `buf`. Each sector is 2352 bytes. Caller must
# size `buf` to at least `nframes * 2352` bytes.
#
# The kernel enforces a per-call cap of 75 frames (one second) to
# keep single-ioctl latency bounded. We enforce the same cap here
# and return the count actually requested — callers that want a
# whole audio track loop with the LBA from `toc_entry_start_lba`.
#
# struct cdrom_read_audio (x86_64 layout, 24 bytes with padding):
#    0..3  union addr (lba i32)
#    4     addr_format u8 (CDROM_LBA = 1)
#    5..7  padding
#    8..11 nframes i32
#   12..15 padding (pointer alignment)
#   16..23 buf u64 (user pointer)
# ---------------------------------------------------------------------------

pub fn read_audio_sectors(dev_path_cstr, start_lba, nframes, buf, buflen) {
    if (nframes <= 0) { return err_tray_failed(str_from("nframes must be > 0")); }
    if (nframes > CDDA_MAX_FRAMES_PER_READ) { nframes = CDDA_MAX_FRAMES_PER_READ; }
    var need = nframes * CDDA_FRAME_SIZE;
    if (buflen < need) {
        return err_tray_failed(str_from("read_audio_sectors: buf too small"));
    }

    sakshi_span_enter("read_audio", 10);
    var fd_r = _open_optical_device(dev_path_cstr);
    if (is_ok(fd_r) == 0) {
        sakshi_span_exit();
        return fd_r;
    }
    var fd = payload(fd_r);

    var req[24];
    # Zero the struct before populating — stray bits in padding
    # are passed to the kernel and have historically been an
    # info-disclosure surface in ioctl drivers.
    for (var zi = 0; zi < 24; zi = zi + 1) { store8(&req + zi, 0); }
    store32(&req + 0, start_lba);
    store8(&req + 4, CDROM_LBA);
    store32(&req + 8, nframes);
    store64(&req + 16, buf);

    var rc = syscall(SYS_IOCTL, fd, IOCTL_CDROMREADAUDIO, &req);
    sys_close(fd);
    if (rc < 0) {
        sakshi_span_exit();
        return err_tray_failed(str_from("CDROMREADAUDIO ioctl failed"));
    }
    sakshi_span_exit();
    return Ok(need);
}

# Convenience: read the whole audio track described by a TocEntry
# into `buf`. Returns Ok(bytes_read) or Err. Loops the single-ioctl
# cap internally — a 4-minute track is ~18000 sectors ≈ 240 calls.
pub fn read_audio_track(dev_path_cstr, entry, buf, buflen) {
    if (te_track_type(entry) != TT_AUDIO) {
        return err_tray_failed(str_from("read_audio_track: not an audio track"));
    }
    var lba = te_start_lba(entry);
    var remaining = te_length_sectors(entry);
    if (remaining <= 0) { return Ok(0); }
    var total_bytes = remaining * CDDA_FRAME_SIZE;
    if (buflen < total_bytes) {
        return err_tray_failed(str_from("read_audio_track: buf too small"));
    }
    var written = 0;
    var off = 0;
    while (remaining > 0) {
        var batch = remaining;
        if (batch > CDDA_MAX_FRAMES_PER_READ) { batch = CDDA_MAX_FRAMES_PER_READ; }
        var batch_bytes = batch * CDDA_FRAME_SIZE;
        var r = read_audio_sectors(dev_path_cstr, lba, batch, buf + off, buflen - off);
        if (is_ok(r) == 0) { return r; }
        written = written + payload(r);
        off = off + batch_bytes;
        lba = lba + batch;
        remaining = remaining - batch;
    }
    return Ok(written);
}

# ---------------------------------------------------------------------------
# classify_toc_tracks — determine disc type from track content
# ---------------------------------------------------------------------------

pub fn classify_toc_tracks(has_audio, has_data) {
    if (has_audio != 0) {
        if (has_data != 0) { return DT_CD_MIXED; }
        return DT_CD_AUDIO;
    }
    if (has_data != 0) { return DT_CD_DATA; }
    return DT_UNKNOWN;
}

# ---------------------------------------------------------------------------
# detect_disc_type — from media type string + track info
# Zero-alloc case-insensitive matching
# ---------------------------------------------------------------------------

pub fn detect_disc_type(media_type_cstr, has_audio, has_data) {
    if (_str_eq_ci(media_type_cstr, "cd")) {
        return classify_toc_tracks(has_audio, has_data);
    }
    if (_str_eq_ci(media_type_cstr, "cd-rom")) {
        return classify_toc_tracks(has_audio, has_data);
    }
    if (_str_eq_ci(media_type_cstr, "dvd")) { return DT_DVD_ROM; }
    if (_str_eq_ci(media_type_cstr, "dvd-rom")) { return DT_DVD_ROM; }
    # Dual-layer + dual-sided DVDs (2.1.0).
    if (_str_eq_ci(media_type_cstr, "dvd-r-dl")) { return DT_DVD_WRITABLE_DL; }
    if (_str_eq_ci(media_type_cstr, "dvd+r-dl")) { return DT_DVD_WRITABLE_DL; }
    if (_str_eq_ci(media_type_cstr, "dvd-r_dl")) { return DT_DVD_WRITABLE_DL; }
    if (_str_eq_ci(media_type_cstr, "dvd+r_dl")) { return DT_DVD_WRITABLE_DL; }
    if (_str_eq_ci(media_type_cstr, "dvd-rom-dl")) { return DT_DVD_ROM_DL; }
    if (_str_eq_ci(media_type_cstr, "dvd-rom_dl")) { return DT_DVD_ROM_DL; }
    if (_str_eq_ci(media_type_cstr, "dvd-ds")) { return DT_DVD_DUAL_SIDED; }
    if (_str_eq_ci(media_type_cstr, "dvd-dual-sided")) { return DT_DVD_DUAL_SIDED; }
    if (_str_eq_ci(media_type_cstr, "dvd-r")) { return DT_DVD_WRITABLE; }
    if (_str_eq_ci(media_type_cstr, "dvd-rw")) { return DT_DVD_WRITABLE; }
    if (_str_eq_ci(media_type_cstr, "dvd+r")) { return DT_DVD_WRITABLE; }
    if (_str_eq_ci(media_type_cstr, "dvd+rw")) { return DT_DVD_WRITABLE; }
    if (_str_eq_ci(media_type_cstr, "dvd-video")) { return DT_DVD_VIDEO; }
    if (_str_eq_ci(media_type_cstr, "bd")) { return DT_BLURAY; }
    if (_str_eq_ci(media_type_cstr, "blu-ray")) { return DT_BLURAY; }
    if (_str_eq_ci(media_type_cstr, "bd-rom")) { return DT_BLURAY; }
    if (_str_eq_ci(media_type_cstr, "bd-video")) { return DT_BLURAY_VIDEO; }
    # Blu-ray capacity variants.
    if (_str_eq_ci(media_type_cstr, "bd-dl")) { return DT_BLURAY_DL; }
    if (_str_eq_ci(media_type_cstr, "bd-r-dl")) { return DT_BLURAY_DL; }
    if (_str_eq_ci(media_type_cstr, "bdxl")) { return DT_BLURAY_XL; }
    if (_str_eq_ci(media_type_cstr, "bd-xl")) { return DT_BLURAY_XL; }
    if (_str_eq_ci(media_type_cstr, "blank")) { return DT_BLANK; }
    if (_str_eq_ci(media_type_cstr, "no_disc")) { return DT_BLANK; }
    return DT_UNKNOWN;
}

# ---------------------------------------------------------------------------
# is_dvd_video — check if mount point contains VIDEO_TS directory
# ---------------------------------------------------------------------------

pub fn is_dvd_video(mount_point_cstr) {
    var sb1 = str_builder_new();
    str_builder_add_cstr(sb1, mount_point_cstr);
    str_builder_add_cstr(sb1, "/VIDEO_TS");
    if (is_dir(str_builder_build(sb1))) { return 1; }

    var sb2 = str_builder_new();
    str_builder_add_cstr(sb2, mount_point_cstr);
    str_builder_add_cstr(sb2, "/video_ts");
    if (is_dir(str_builder_build(sb2))) { return 1; }

    return 0;
}

# --- udev.cyr ---

# yukti/udev.cyr — udev integration: device enumeration and hotplug monitoring
#
# Reads from /sys/, monitors udev events via netlink socket.
# UdevEvent, device classification, sysfs enumeration, uevent parsing.

# ---------------------------------------------------------------------------
# UdevEvent struct
# Layout: 48 bytes
#   0: action (Str — "add", "remove", "change")
#   8: sys_path (Str)
#  16: dev_path (Str, 0 if none)
#  24: subsystem (Str)
#  32: dev_type (Str, 0 if none)
#  40: properties (hashmap ptr)
# ---------------------------------------------------------------------------

enum UdevEventField {
    UE_ACTION = 0;
    UE_SYS_PATH = 8;
    UE_DEV_PATH = 16;
    UE_SUBSYSTEM = 24;
    UE_DEV_TYPE = 32;
    UE_PROPERTIES = 40;
    UE_SIZE = 48;
}

pub fn udev_event_new(action, sys_path, dev_path, subsystem, dev_type, props) {
    # Freelist-backed — udev monitor churns these per hotplug event.
    var e = fl_alloc(UE_SIZE);
    store64(e + UE_ACTION, action);
    store64(e + UE_SYS_PATH, sys_path);
    store64(e + UE_DEV_PATH, dev_path);
    store64(e + UE_SUBSYSTEM, subsystem);
    store64(e + UE_DEV_TYPE, dev_type);
    store64(e + UE_PROPERTIES, props);
    return e;
}

pub fn udev_event_free(e) {
    if (e == 0) { return 0; }
    fl_free(e);
    return 0;
}

pub fn ue_action(e) { return load64(e + UE_ACTION); }
pub fn ue_sys_path(e) { return load64(e + UE_SYS_PATH); }
pub fn ue_dev_path(e) { return load64(e + UE_DEV_PATH); }
pub fn ue_subsystem(e) { return load64(e + UE_SUBSYSTEM); }
pub fn ue_dev_type(e) { return load64(e + UE_DEV_TYPE); }
pub fn ue_properties(e) { return load64(e + UE_PROPERTIES); }

pub fn udev_event_is_add(e) {
    return str_eq_cstr(ue_action(e), "add");
}

pub fn udev_event_is_remove(e) {
    return str_eq_cstr(ue_action(e), "remove");
}

pub fn udev_event_is_change(e) {
    return str_eq_cstr(ue_action(e), "change");
}

pub fn udev_event_property(e, key_cstr) {
    var props = ue_properties(e);
    if (props == 0) { return 0; }
    return map_get(props, key_cstr);
}

# ---------------------------------------------------------------------------
# classify_device — determine DeviceClass from udev properties
# ---------------------------------------------------------------------------

pub fn classify_device(event) {
    var bus = udev_event_property(event, "ID_BUS");
    if (bus == 0) { bus = str_from(""); }

    var dev_type = ue_dev_type(event);
    if (dev_type == 0) { dev_type = str_from(""); }

    var subsystem = ue_subsystem(event);

    # USB storage
    if (str_eq_cstr(bus, "usb")) {
        if (str_eq_cstr(dev_type, "disk")) { return DC_USB_STORAGE; }
        if (str_eq_cstr(dev_type, "partition")) { return DC_USB_STORAGE; }
    }

    # Optical drive
    if (str_eq_cstr(subsystem, "block")) {
        var cdrom = udev_event_property(event, "ID_CDROM");
        if (cdrom != 0) { return DC_OPTICAL; }
    }

    # SD card
    if (str_eq_cstr(bus, "mmc")) { return DC_SD_CARD; }
    var flash_sd = udev_event_property(event, "ID_DRIVE_FLASH_SD");
    if (flash_sd != 0) { return DC_SD_CARD; }

    # Block device subtypes
    if (str_eq_cstr(subsystem, "block")) {
        var sys_path = ue_sys_path(event);
        if (str_contains_cstr(sys_path, "/dm-")) { return DC_DEVICE_MAPPER; }
        if (str_contains_cstr(sys_path, "/loop")) { return DC_LOOP; }
        if (str_eq_cstr(dev_type, "disk")) { return DC_BLOCK_INTERNAL; }
        if (str_eq_cstr(dev_type, "partition")) { return DC_BLOCK_INTERNAL; }
    }

    # Audio devices (2.2.1: SUBSYSTEM=sound, filtered to PCM endpoints).
    # The kernel emits separate events for control nodes / sequencer /
    # timer under the same subsystem; we only care about pcmC<n>D<m>{p|c}
    # for vani's adapter. The /pcmC substring check is the cheap form
    # of the full filename grammar (see audio.cyr's _audio_parse_pcm_name
    # for the strict version used by the enumerator).
    if (str_eq_cstr(subsystem, "sound")) {
        var sound_dev_path = ue_dev_path(event);
        if (sound_dev_path != 0) {
            if (str_contains_cstr(sound_dev_path, "/pcmC")) { return DC_AUDIO; }
        }
    }

    return DC_UNKNOWN;
}

# ---------------------------------------------------------------------------
# extract_capabilities — build capability bitflags from udev properties
# ---------------------------------------------------------------------------

pub fn extract_capabilities(event, class) {
    var caps = CAP_READ;

    # Writable unless read-only
    var ro = udev_event_property(event, "ID_FS_READONLY");
    if (ro != 0) {
        if (str_eq_cstr(ro, "1") == 0) {
            caps = caps | CAP_WRITE;
        }
    } else {
        caps = caps | CAP_WRITE;
    }

    # Removable
    var usb_drv = udev_event_property(event, "ID_USB_DRIVER");
    var udisks_rem = udev_event_property(event, "UDISKS_REMOVABLE");
    var removable = 0;
    if (usb_drv != 0) { removable = 1; }
    if (udisks_rem != 0) {
        if (str_eq_cstr(udisks_rem, "1")) { removable = 1; }
    }
    if (class == DC_USB_STORAGE) { removable = 1; }
    if (class == DC_OPTICAL) { removable = 1; }
    if (class == DC_SD_CARD) { removable = 1; }

    if (removable) {
        caps = caps | CAP_REMOVABLE | CAP_HOTPLUG | CAP_EJECT;
    }

    # Optical-specific
    if (class == DC_OPTICAL) {
        caps = caps | CAP_MEDIA_CHANGE | CAP_TRAY_CONTROL;
        var cd_rw = udev_event_property(event, "ID_CDROM_CD_RW");
        var dvd_rw = udev_event_property(event, "ID_CDROM_DVD_RW");
        if (cd_rw != 0) { caps = caps | CAP_BURN; }
        if (dvd_rw != 0) { caps = caps | CAP_BURN; }
    }

    # SSD TRIM
    var trim = udev_event_property(event, "ID_ATA_FEATURE_SET_TRIM");
    if (trim != 0) { caps = caps | CAP_TRIM; }

    return caps;
}

# Classify and extract capabilities in one call
pub fn classify_and_extract(event) {
    var class = classify_device(event);
    var caps = extract_capabilities(event, class);
    # Return packed: class in low bits, caps shifted
    # Actually, we return two values via a small struct
    var result = alloc(16);
    store64(result, class);
    store64(result + 8, caps);
    return result;
}

# ---------------------------------------------------------------------------
# device_info_from_udev — build DeviceInfo from a UdevEvent
# ---------------------------------------------------------------------------

pub fn device_info_from_udev(event) {
    var dev_path = ue_dev_path(event);
    if (dev_path == 0) {
        return err_udev(str_from("no dev_path in event"));
    }

    var ce = classify_and_extract(event);
    var class = load64(ce);
    var caps = load64(ce + 8);

    # Build device ID: "subsystem:devname"
    var subsys = ue_subsystem(event);
    # Get filename from dev_path
    var dev_name = dev_path;
    var slash_idx = str_last_index_of(dev_path, "/");
    if (slash_idx >= 0) {
        dev_name = str_substr(dev_path, slash_idx + 1, str_len(dev_path));
    }

    var sb = str_builder_new();
    str_builder_add_str(sb, subsys);
    str_builder_add_cstr(sb, ":");
    str_builder_add_str(sb, dev_name);
    var id_str = str_builder_build(sb);
    var id = device_id_new(id_str);

    var info = device_info_new(id, dev_path, class);
    di_set_sys_path(info, ue_sys_path(event));
    di_set_caps(info, caps);

    # Extract known properties
    var vendor = udev_event_property(event, "ID_VENDOR");
    if (vendor != 0) { di_set_vendor(info, vendor); }

    var model = udev_event_property(event, "ID_MODEL");
    if (model != 0) { di_set_model(info, model); }

    var serial = udev_event_property(event, "ID_SERIAL_SHORT");
    if (serial != 0) { di_set_serial(info, serial); }

    var label = udev_event_property(event, "ID_FS_LABEL");
    if (label == 0) { label = udev_event_property(event, "ID_FS_LABEL_ENC"); }
    if (label != 0) { di_set_label(info, label); }

    var fs_type = udev_event_property(event, "ID_FS_TYPE");
    if (fs_type != 0) { di_set_fs_type(info, fs_type); }

    # Size from partition entry size (sectors * 512)
    var size_str = udev_event_property(event, "ID_PART_ENTRY_SIZE");
    if (size_str != 0) {
        var sectors = str_to_int(size_str);
        if (sectors > 0) {
            di_set_size_bytes(info, sectors * 512);
        }
    }

    # USB vendor/product IDs (hex)
    var vid_str = udev_event_property(event, "ID_VENDOR_ID");
    if (vid_str != 0) {
        var vid = str_to_hex(vid_str);
        di_set_usb_vid(info, vid);
    }

    var pid_str = udev_event_property(event, "ID_MODEL_ID");
    if (pid_str != 0) {
        var pid = str_to_hex(pid_str);
        di_set_usb_pid(info, pid);
    }

    # Partition table type
    var pt = udev_event_property(event, "ID_PART_TABLE_TYPE");
    if (pt != 0) { di_set_part_table(info, pt); }

    di_set_properties(info, ue_properties(event));

    return Ok(info);
}

# Note: str_to_hex() and str_to_int() are provided by lib/str.cyr

# ---------------------------------------------------------------------------
# read_sysfs_attr — read a single sysfs attribute file, trimmed
# ---------------------------------------------------------------------------

fn _read_sysfs_attr(base_path, attr_cstr): i64 {
    var sb = str_builder_new();
    str_builder_add_str(sb, base_path);
    str_builder_add_cstr(sb, "/");
    str_builder_add_cstr(sb, attr_cstr);
    var path = str_builder_build(sb);

    var attr_buf[256];
    var attr_n = file_read_all(str_cstr(path), &attr_buf, 256);
    if (attr_n <= 0) { return 0; }
    return str_trim(str_from_buf(&attr_buf, attr_n));
}

# ---------------------------------------------------------------------------
# enumerate_block_devices — list /sys/block/ entries
# ---------------------------------------------------------------------------

pub fn enumerate_block_devices(sysfs_root) {
    var sb = str_builder_new();
    str_builder_add_str(sb, sysfs_root);
    str_builder_add_cstr(sb, "/block");
    var block_dir = str_builder_build(sb);

    var entries = dir_list(block_dir);
    if (entries == 0) { return vec_new(); }
    return entries;
}

# ---------------------------------------------------------------------------
# build_device_info_from_sysfs — construct DeviceInfo from sysfs attributes
# ---------------------------------------------------------------------------

fn _build_device_info_from_sysfs(sys_path, dev_name, dev_type_cstr): i64 {
    var props = map_new();

    # Read standard sysfs attributes
    var vendor = _read_sysfs_attr(sys_path, "device/vendor");
    if (vendor != 0) { map_set(props, "ID_VENDOR", vendor); }

    var model = _read_sysfs_attr(sys_path, "device/model");
    if (model != 0) { map_set(props, "ID_MODEL", model); }

    var serial = _read_sysfs_attr(sys_path, "device/serial");
    if (serial != 0) { map_set(props, "ID_SERIAL_SHORT", serial); }

    var removable = _read_sysfs_attr(sys_path, "removable");
    if (removable != 0) {
        if (str_eq_cstr(removable, "1")) {
            map_set(props, "UDISKS_REMOVABLE", str_from("1"));
        }
    }

    var ro = _read_sysfs_attr(sys_path, "ro");
    if (ro != 0) {
        if (str_eq_cstr(ro, "1")) {
            map_set(props, "ID_FS_READONLY", str_from("1"));
        }
    }

    var size_str = _read_sysfs_attr(sys_path, "size");
    if (size_str != 0) {
        map_set(props, "ID_PART_ENTRY_SIZE", size_str);
    }

    # USB IDs
    var vid = _read_sysfs_attr(sys_path, "device/idVendor");
    if (vid != 0) { map_set(props, "ID_VENDOR_ID", vid); }

    var pid = _read_sysfs_attr(sys_path, "device/idProduct");
    if (pid != 0) { map_set(props, "ID_MODEL_ID", pid); }

    # Build dev_path: /dev/<dev_name>
    var dp_sb = str_builder_new();
    str_builder_add_cstr(dp_sb, "/dev/");
    str_builder_add_str(dp_sb, dev_name);
    var dev_path = str_builder_build(dp_sb);

    # Create synthetic UdevEvent
    var event = udev_event_new(
    str_from("add"),
    sys_path,
    dev_path,
    str_from("block"),
    str_from(dev_type_cstr),
    props
    );

    var info_r = device_info_from_udev(event);
    if (is_ok(info_r) == 0) { return 0; }
    var info = payload(info_r);

    # Query device node permissions
    var perms = query_permissions(str_cstr(dev_path));
    if (perms != 0) {
        di_set_uid(info, perms_uid(perms));
        di_set_gid(info, perms_gid(perms));
        di_set_mode(info, perms_mode(perms));
    }

    # Check mount status
    var mp = find_mount_point(str_cstr(dev_path));
    if (mp != 0) {
        di_set_mount_point(info, mp);
        di_set_state(info, DS_MOUNTED);
    }

    return info;
}

# ---------------------------------------------------------------------------
# enumerate_devices — enumerate all block devices under sysfs_root
# ---------------------------------------------------------------------------

pub fn enumerate_devices(sysfs_root) {
    var sb = str_builder_new();
    str_builder_add_str(sb, sysfs_root);
    str_builder_add_cstr(sb, "/block");
    var block_dir = str_builder_build(sb);

    var entries = dir_list(block_dir);
    if (entries == 0) {
        return err_udev(str_from("failed to read /sys/block"));
    }

    var devices = vec_new();
    var n = vec_len(entries);

    for (var i = 0; i < n; i = i + 1) {
        var dev_name = vec_get(entries, i);
        # Skip . and ..
        if (str_eq_cstr(dev_name, ".")) { continue; }
        if (str_eq_cstr(dev_name, "..")) { continue; }

        var path_sb = str_builder_new();
        str_builder_add_str(path_sb, block_dir);
        str_builder_add_cstr(path_sb, "/");
        str_builder_add_str(path_sb, dev_name);
        var sys_path = str_builder_build(path_sb);

        var info = _build_device_info_from_sysfs(sys_path, dev_name, "disk");
        if (info != 0) {
            vec_push(devices, info);
        }

        # Enumerate partitions: subdirectories starting with dev_name
        var sub_entries = dir_list(sys_path);
        if (sub_entries != 0) {
            var nsub = vec_len(sub_entries);
            for (var j = 0; j < nsub; j = j + 1) {
                var part_name = vec_get(sub_entries, j);
                if (str_starts_with(part_name, str_cstr(dev_name)) == 0) { continue; }
                if (str_len(part_name) <= str_len(dev_name)) { continue; }

                # Check if partition file exists
                var pp_sb = str_builder_new();
                str_builder_add_str(pp_sb, sys_path);
                str_builder_add_cstr(pp_sb, "/");
                str_builder_add_str(pp_sb, part_name);
                var part_path = str_builder_build(pp_sb);

                var chk_sb = str_builder_new();
                str_builder_add_str(chk_sb, part_path);
                str_builder_add_cstr(chk_sb, "/partition");
                var part_file = str_builder_build(chk_sb);

                if (file_exists(str_cstr(part_file))) {
                    var part_info = _build_device_info_from_sysfs(
                    part_path, part_name, "partition");
                    if (part_info != 0) {
                        vec_push(devices, part_info);
                    }
                }
            }
        }
    }

    sakshi_info("enumeration complete", 20);
    return Ok(devices);
}

# ---------------------------------------------------------------------------
# parse_uevent — parse raw kernel uevent message (null-separated key=value)
# ---------------------------------------------------------------------------

pub fn parse_uevent(buf, len) {
    if (len == 0) { return 0; }

    var action = str_from("");
    var devpath = str_from("");
    var subsystem = str_from("");
    var devtype = 0;
    var props = map_new();

    # Split on null bytes
    var start = 0;
    var first_part = 1;

    for (var i = 0; i <= len; i = i + 1) {
        var is_end = 0;
        if (i == len) { is_end = 1; }
        if (is_end == 0) {
            if (load8(buf + i) == 0) { is_end = 1; }
        }

        if (is_end) {
            var part_len = i - start;
            if (part_len > 0) {
                var part = str_from_buf(buf + start, part_len);

                if (first_part) {
                    # Check for action@devpath header
                    var at_idx = str_index_of(part, 64);
                    if (at_idx >= 0) {
                        action = str_substr(part, 0, at_idx);
                        devpath = str_substr(part, at_idx + 1, str_len(part));
                        first_part = 0;
                        start = i + 1;
                        continue;
                    }
                    first_part = 0;
                }

                # Parse KEY=VALUE
                var eq_idx = str_index_of(part, 61);
                if (eq_idx >= 0) {
                    var key = str_substr(part, 0, eq_idx);
                    var val = str_substr(part, eq_idx + 1, str_len(part));

                    if (str_eq_cstr(key, "ACTION")) { action = val; }
                    elif (str_eq_cstr(key, "DEVPATH")) { devpath = val; }
                    elif (str_eq_cstr(key, "SUBSYSTEM")) { subsystem = val; }
                    elif (str_eq_cstr(key, "DEVTYPE")) { devtype = val; }
                    else { map_set(props, str_cstr(key), val); }
                }
            }
            start = i + 1;
        }
    }

    # Observability (audit finding LOW-5): log malformed uevents
    # instead of silently returning 0. A burst of these during an
    # incident is a signal worth chasing — forged messages, kernel
    # emitting partial events under OOM, etc.
    if (str_len(action) == 0) {
        sakshi_warn("uevent: empty ACTION", 20);
        return 0;
    }
    if (str_len(devpath) == 0) {
        sakshi_warn("uevent: empty DEVPATH", 21);
        return 0;
    }

    # Derive dev_path from DEVNAME property
    var dev_path = 0;
    var devname = map_get(props, "DEVNAME");
    if (devname != 0) {
        if (load8(str_data(devname)) == 47) {
            dev_path = devname;
        } else {
            var sb = str_builder_new();
            str_builder_add_cstr(sb, "/dev/");
            str_builder_add_str(sb, devname);
            dev_path = str_builder_build(sb);
        }
    }

    # Build sys_path: /sys<devpath>
    var sp_sb = str_builder_new();
    str_builder_add_cstr(sp_sb, "/sys");
    str_builder_add_str(sp_sb, devpath);
    var sys_path = str_builder_build(sp_sb);

    return udev_event_new(action, sys_path, dev_path, subsystem, devtype, props);
}

# ---------------------------------------------------------------------------
# udev_event_to_device_event — convert UdevEvent to DeviceEvent
# ---------------------------------------------------------------------------

pub fn udev_event_to_device_event(uevent) {
    var action = ue_action(uevent);
    var kind = 0 - 1;

    if (str_eq_cstr(action, "add")) { kind = EK_ATTACHED; }
    elif (str_eq_cstr(action, "remove")) { kind = EK_DETACHED; }
    elif (str_eq_cstr(action, "change")) { kind = EK_MEDIA_CHANGED; }
    else { return 0; }

    var dev_path = ue_dev_path(uevent);
    if (dev_path == 0) { return 0; }

    var ce = classify_and_extract(uevent);
    var class = load64(ce);

    # Build device ID
    var subsys = ue_subsystem(uevent);
    var dev_name = dev_path;
    var slash_idx = str_last_index_of(dev_path, "/");
    if (slash_idx >= 0) {
        dev_name = str_substr(dev_path, slash_idx + 1, str_len(dev_path));
    }

    var sb = str_builder_new();
    str_builder_add_str(sb, subsys);
    str_builder_add_cstr(sb, ":");
    str_builder_add_str(sb, dev_name);
    var id = device_id_new(str_builder_build(sb));

    var event = device_event_new(id, class, kind, dev_path);

    # Attach info for non-remove events
    if (udev_event_is_remove(uevent) == 0) {
        var info_r = device_info_from_udev(uevent);
        if (is_ok(info_r)) {
            de_set_device_info(event, payload(info_r));
        }
    }

    return event;
}

# ---------------------------------------------------------------------------
# UdevMonitor — netlink-based udev monitor
# Layout: 24 bytes
#   0: socket_fd
#   8: running (0/1)
#  16: filter (vec of DeviceClass values, 0 = no filter)
# ---------------------------------------------------------------------------

enum NetlinkConst {
    AF_NETLINK = 16;
    SOCK_DGRAM = 2;
    SOCK_CLOEXEC = 524288;
    NETLINK_KOBJECT_UEVENT = 15;
    SOL_SOCKET = 1;
    SO_RCVBUF = 8;
    RECV_BUF_SIZE = 262144;
}
# Syscall numbers for socket/bind/setsockopt/recvfrom/ppoll come from
# src/syscalls.cyr (arch-conditional; was hardcoded x86_64 here pre-2.1.4).

pub fn udev_monitor_new() {
    return udev_monitor_with_filter(0);
}

pub fn udev_monitor_with_filter(filter_vec) {
    # Create netlink socket
    var fd = syscall(SYS_SOCKET, AF_NETLINK, SOCK_DGRAM | SOCK_CLOEXEC, NETLINK_KOBJECT_UEVENT);
    if (fd < 0) {
        var sb = str_builder_new();
        str_builder_add_cstr(sb, "socket() failed: errno ");
        str_builder_add_int(sb, 0 - fd);
        return err_udev_socket(str_builder_build(sb));
    }

    # Bind to multicast group 1
    # struct sockaddr_nl: { u16 family, u16 pad, u32 pid, u32 groups }
    var addr[12];
    store16(&addr, AF_NETLINK);
    store16(&addr + 2, 0);
    store32(&addr + 4, 0);
    store32(&addr + 8, 1);

    var rc = syscall(SYS_BIND, fd, &addr, 12);
    if (rc < 0) {
        sys_close(fd);
        return err_udev_socket(str_from("bind() failed"));
    }

    # Set receive buffer size
    var bufsize[4];
    store32(&bufsize, RECV_BUF_SIZE);
    syscall(SYS_SETSOCKOPT, fd, SOL_SOCKET, SO_RCVBUF, &bufsize, 4);

    var mon = alloc(24);
    store64(mon, fd);
    store64(mon + 8, 1);
    store64(mon + 16, filter_vec);

    sakshi_info("udev monitor created", 20);
    return Ok(mon);
}

pub fn udev_monitor_poll(mon, timeout_ms) {
    var fd = load64(mon);

    # struct pollfd: { int fd, short events, short revents }
    var pfd[8];
    store32(&pfd, fd);
    store16(&pfd + 4, 1);
    store16(&pfd + 6, 0);

    # ppoll(2) instead of poll(2) — aarch64's syscall table has no
    # SYS_POLL, only SYS_PPOLL. ppoll takes a timespec* (not int ms)
    # and an extra (sigmask, sigsetsize) pair. We drive both arches
    # through ppoll uniformly via SYS_PPOLL (defined in src/syscalls.cyr).
    var ts[16];
    store64(&ts, timeout_ms / 1000);
    store64(&ts + 8, (timeout_ms - (timeout_ms / 1000) * 1000) * 1000000);
    var ret = syscall(SYS_PPOLL, &pfd, 1, &ts, 0, 8);
    if (ret < 0) {
        return err_udev_socket(str_from("ppoll() failed"));
    }
    if (ret == 0) { return Ok(0); }

    # Receive data. Provide src_addr + addrlen so we can verify the
    # sender is the kernel (nl_pid == 0) — defense-in-depth against
    # CVE-2009-1185-class uevent spoofing (audit finding MED-4).
    #   struct sockaddr_nl { u16 family, u16 pad, u32 pid, u32 groups }
    var buf[8192];
    var src_addr[12];
    var src_len[1];
    store32(&src_len, 12);
    var n = syscall(SYS_RECVFROM, fd, &buf, 8192, 0, &src_addr, &src_len);
    if (n <= 0) { return Ok(0); }

    # Reject non-kernel senders — the kernel always sends with pid=0.
    # Unprivileged user processes with CAP_NET_ADMIN could otherwise
    # inject forged uevents into our monitor.
    var src_pid = load32(&src_addr + 4);
    if (src_pid != 0) { return Ok(0); }

    var uevent = parse_uevent(&buf, n);
    return Ok(uevent);
}

pub fn udev_monitor_stop(mon) {
    store64(mon + 8, 0);
    sakshi_info("udev monitor stopping", 21);
    return 0;
}

pub fn udev_monitor_close(mon) {
    udev_monitor_stop(mon);
    var fd = load64(mon);
    sys_close(fd);
    return 0;
}

pub fn udev_monitor_is_running(mon) {
    return load64(mon + 8);
}

# Run event loop dispatching to a listener function pointer
pub fn udev_monitor_run(mon, listener_fn) {
    sakshi_span_enter("udev_monitor", 12);
    while (udev_monitor_is_running(mon)) {
        var r = udev_monitor_poll(mon, 500);
        if (is_ok(r) == 0) { continue; }
        var uevent = payload(r);
        if (uevent == 0) { continue; }

        var dev_event = udev_event_to_device_event(uevent);
        if (dev_event == 0) { continue; }

        # Check monitor-level filter
        var filter = load64(mon + 16);
        if (filter != 0) {
            var class = de_device_class(dev_event);
            var found = 0;
            var flen = vec_len(filter);
            for (var i = 0; i < flen; i = i + 1) {
                if (vec_get(filter, i) == class) { found = 1; break; }
            }
            if (found == 0) { continue; }
        }

        fncall1(listener_fn, dev_event);
    }
    return Ok(0);
}

# --- linux.cyr ---

# yukti/linux.cyr — Linux device manager
#
# Ties together udev, storage, and optical modules.
# Concrete implementation providing device enumeration, lookup,
# mount/eject operations, and hotplug monitoring.

# ---------------------------------------------------------------------------
# LinuxDeviceManager struct
# Layout: 40 bytes
#   0: sysfs_root (Str)
#   8: devices (hashmap — DeviceId string → DeviceInfo ptr)
#  16: listeners (vec of listener entries)
#  24: monitor (UdevMonitor ptr, 0 if not running)
#  32: monitor_thread (thread id, 0 if not running)
# ---------------------------------------------------------------------------

enum LinuxDMField {
    LDM_SYSFS_ROOT = 0;
    LDM_DEVICES = 8;
    LDM_LISTENERS = 16;
    LDM_MONITOR = 24;
    LDM_MONITOR_THREAD = 32;
    LDM_SIZE = 40;
}

pub fn linux_dm_new() {
    return linux_dm_with_root(str_from("/sys"));
}

pub fn linux_dm_with_root(root) {
    var mgr = alloc(LDM_SIZE);
    store64(mgr + LDM_SYSFS_ROOT, root);
    store64(mgr + LDM_DEVICES, map_new());
    store64(mgr + LDM_LISTENERS, vec_new());
    store64(mgr + LDM_MONITOR, 0);
    store64(mgr + LDM_MONITOR_THREAD, 0);
    return mgr;
}

pub fn ldm_sysfs_root(mgr) { return load64(mgr + LDM_SYSFS_ROOT); }

# ---------------------------------------------------------------------------
# Listener management
# ---------------------------------------------------------------------------

pub fn linux_dm_add_listener(mgr, handler_fn, filter_fn) {
    var entry = listener_entry_new(handler_fn, filter_fn);
    var listeners = load64(mgr + LDM_LISTENERS);
    vec_push(listeners, entry);
    return 0;
}

pub fn linux_dm_dispatch_event(mgr, event) {
    var listeners = load64(mgr + LDM_LISTENERS);
    dispatch_event_to_listeners(listeners, event);
    return 0;
}

# ---------------------------------------------------------------------------
# Device enumeration (Device trait: enumerate)
# ---------------------------------------------------------------------------

pub fn linux_dm_enumerate(mgr) {
    var root = ldm_sysfs_root(mgr);
    sakshi_span_enter("enumerate", 9);

    var r = enumerate_devices(root);
    if (is_ok(r) == 0) { return r; }

    var devices = payload(r);
    var cache = load64(mgr + LDM_DEVICES);

    # Clear and repopulate cache
    # (hashmap doesn't have a clear, so we create a new one)
    var new_cache = map_new();
    var n = vec_len(devices);
    for (var i = 0; i < n; i = i + 1) {
        var info = vec_get(devices, i);
        var id_str = device_id_str(di_id(info));
        map_set(new_cache, str_cstr(id_str), info);
    }
    store64(mgr + LDM_DEVICES, new_cache);

    sakshi_span_exit();
    return Ok(devices);
}

# ---------------------------------------------------------------------------
# Device lookup (Device trait: get)
# ---------------------------------------------------------------------------

pub fn linux_dm_get(mgr, device_id) {
    var cache = load64(mgr + LDM_DEVICES);
    var id_str = device_id_str(device_id);
    var info = map_get(cache, str_cstr(id_str));
    return Ok(info);
}

# ---------------------------------------------------------------------------
# Device refresh (Device trait: refresh)
# ---------------------------------------------------------------------------

pub fn linux_dm_refresh(mgr, device_id) {
    var r = linux_dm_enumerate(mgr);
    if (is_ok(r) == 0) { return r; }

    var devices = payload(r);
    var n = vec_len(devices);
    for (var i = 0; i < n; i = i + 1) {
        var info = vec_get(devices, i);
        if (device_id_eq(di_id(info), device_id)) {
            return Ok(info);
        }
    }

    return err_device_not_found(device_id_str(device_id));
}

# ---------------------------------------------------------------------------
# Mount a device by ID
# ---------------------------------------------------------------------------

pub fn linux_dm_mount(mgr, device_id, options) {
    # Look up device
    var get_r = linux_dm_get(mgr, device_id);
    if (is_ok(get_r) == 0) { return get_r; }
    var info = payload(get_r);
    if (info == 0) {
        return err_device_not_found(device_id_str(device_id));
    }

    var dev_path = di_dev_path(info);
    var result = storage_mount(str_cstr(dev_path), options);
    if (is_ok(result) == 0) { return result; }

    var mr = payload(result);

    # Update cached state
    di_set_state(info, DS_MOUNTED);
    di_set_mount_point(info, mr_mount_point(mr));

    return Ok(mr);
}

# ---------------------------------------------------------------------------
# Unmount a device by ID
# ---------------------------------------------------------------------------

pub fn linux_dm_unmount(mgr, device_id) {
    var get_r = linux_dm_get(mgr, device_id);
    if (is_ok(get_r) == 0) { return get_r; }
    var info = payload(get_r);
    if (info == 0) {
        return err_device_not_found(device_id_str(device_id));
    }

    var mp = di_mount_point(info);
    if (mp == 0) {
        return err_unmount_failed(di_dev_path(info), str_from("device is not mounted"));
    }

    var r = storage_unmount(str_cstr(mp));
    if (is_ok(r) == 0) { return r; }

    # Update cached state
    di_set_state(info, DS_READY);
    di_set_mount_point(info, 0);

    return Ok(0);
}

# ---------------------------------------------------------------------------
# Eject a device by ID
# ---------------------------------------------------------------------------

pub fn linux_dm_eject(mgr, device_id) {
    var get_r = linux_dm_get(mgr, device_id);
    if (is_ok(get_r) == 0) { return get_r; }
    var info = payload(get_r);
    if (info == 0) {
        return err_device_not_found(device_id_str(device_id));
    }

    var dev_path = di_dev_path(info);
    var r = storage_eject(str_cstr(dev_path));
    if (is_ok(r) == 0) { return r; }

    # Update cached state
    di_set_state(info, DS_EJECTING);

    return Ok(0);
}

# ---------------------------------------------------------------------------
# Start udev hotplug monitor
# ---------------------------------------------------------------------------

pub fn linux_dm_start_monitor(mgr) {
    var existing = load64(mgr + LDM_MONITOR);
    if (existing != 0) {
        return err_udev(str_from("monitor already running"));
    }

    sakshi_info("starting udev hotplug monitor", 31);
    var r = udev_monitor_new();
    if (is_ok(r) == 0) { return r; }

    var mon = payload(r);
    store64(mgr + LDM_MONITOR, mon);

    return Ok(mon);
}

# ---------------------------------------------------------------------------
# Stop udev monitor
# ---------------------------------------------------------------------------

pub fn linux_dm_stop_monitor(mgr) {
    var mon = load64(mgr + LDM_MONITOR);
    if (mon != 0) {
        udev_monitor_close(mon);
        store64(mgr + LDM_MONITOR, 0);
    }
    sakshi_info("udev monitor stopped", 20);
    return 0;
}

# --- udev_rules.cyr ---

# yukti/udev_rules.cyr — Udev rule management
#
# Create, validate, render, and install udev rules.
# Standalone implementation (no agnosys dependency).

# ---------------------------------------------------------------------------
# UdevRule struct
# Layout: 24 bytes
#   0: name (Str — rule file name without .rules extension)
#   8: match_attrs (vec of pairs — each pair is [key Str, value Str])
#  16: actions (vec of pairs — each pair is [key Str, value Str])
# ---------------------------------------------------------------------------

pub fn udev_rule_new(name, match_attrs, actions) {
    var r = alloc(24);
    store64(r, name);
    store64(r + 8, match_attrs);
    store64(r + 16, actions);
    return r;
}

pub fn ur_name(r) { return load64(r); }
pub fn ur_match_attrs(r) { return load64(r + 8); }
pub fn ur_actions(r) { return load64(r + 16); }

# A pair is 16 bytes: [key Str, value Str]
pub fn pair_new(key, value) {
    var p = alloc(16);
    store64(p, key);
    store64(p + 8, value);
    return p;
}

pub fn pair_key(p) { return load64(p); }
pub fn pair_value(p) { return load64(p + 8); }

# ---------------------------------------------------------------------------
# UdevDeviceInfo struct (from udevadm query)
# Layout: 48 bytes
# ---------------------------------------------------------------------------

pub fn udev_device_info_new(syspath, devpath, subsystem, devtype, driver, devnode) {
    var info = alloc(48);
    store64(info, syspath);
    store64(info + 8, devpath);
    store64(info + 16, subsystem);
    store64(info + 24, devtype);
    store64(info + 32, driver);
    store64(info + 40, devnode);
    return info;
}

pub fn udi_syspath(i) { return load64(i); }
pub fn udi_devpath(i) { return load64(i + 8); }
pub fn udi_subsystem(i) { return load64(i + 16); }
pub fn udi_devtype(i) { return load64(i + 24); }
pub fn udi_driver(i) { return load64(i + 32); }
pub fn udi_devnode(i) { return load64(i + 40); }

# ---------------------------------------------------------------------------
# render_rule — render udev rule to .rules file format
# ---------------------------------------------------------------------------

pub fn render_rule(rule) {
    var sb = str_builder_new();

    # Match conditions: KEY=="VALUE"
    var matches = ur_match_attrs(rule);
    var nm = vec_len(matches);
    for (var i = 0; i < nm; i = i + 1) {
        if (i > 0) { str_builder_add_cstr(sb, ", "); }
        var p = vec_get(matches, i);
        str_builder_add_str(sb, pair_key(p));
        str_builder_add_cstr(sb, "==\"");
        str_builder_add_str(sb, pair_value(p));
        str_builder_add_cstr(sb, "\"");
    }

    # Actions: KEY="VALUE"
    var actions = ur_actions(rule);
    var na = vec_len(actions);
    for (var i = 0; i < na; i = i + 1) {
        if (nm > 0) { str_builder_add_cstr(sb, ", "); }
        elif (i > 0) { str_builder_add_cstr(sb, ", "); }
        var p = vec_get(actions, i);
        str_builder_add_str(sb, pair_key(p));
        str_builder_add_cstr(sb, "=\"");
        str_builder_add_str(sb, pair_value(p));
        str_builder_add_cstr(sb, "\"");
    }

    return str_builder_build(sb);
}

# ---------------------------------------------------------------------------
# validate_rule — check rule for correctness
# ---------------------------------------------------------------------------

pub fn validate_rule(rule) {
    var name = ur_name(rule);
    if (str_len(name) == 0) {
        return err_udev(str_from("rule name cannot be empty"));
    }

    var matches = ur_match_attrs(rule);
    if (vec_len(matches) == 0) {
        return err_udev(str_from("rule must have at least one match"));
    }

    var actions = ur_actions(rule);
    if (vec_len(actions) == 0) {
        return err_udev(str_from("rule must have at least one action"));
    }

    return Ok(0);
}

# ---------------------------------------------------------------------------
# write_rule — write rule file to rules directory
# ---------------------------------------------------------------------------

pub fn write_rule(rule, rules_dir_cstr) {
    var val_r = validate_rule(rule);
    if (is_ok(val_r) == 0) { return val_r; }

    var rendered = render_rule(rule);

    # Build path: rules_dir/name.rules
    var sb = str_builder_new();
    str_builder_add_cstr(sb, rules_dir_cstr);
    str_builder_add_cstr(sb, "/");
    str_builder_add_str(sb, ur_name(rule));
    str_builder_add_cstr(sb, ".rules");
    var path = str_builder_build(sb);
    var path_cstr = str_cstr(path);

    # Write file: open + write + close
    var fd = sys_open(path_cstr, 577, 420);
    if (fd < 0) {
        var esb = str_builder_new();
        str_builder_add_cstr(esb, "failed to write rule: ");
        str_builder_add_str(esb, path);
        return err_udev(str_builder_build(esb));
    }

    var data = str_cstr(rendered);
    sys_write(fd, data, strlen(data));
    sys_write(fd, "\n", 1);
    sys_close(fd);

    return Ok(path);
}

# ---------------------------------------------------------------------------
# remove_rule — delete rule file
# ---------------------------------------------------------------------------

pub fn remove_rule(name, rules_dir_cstr) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, rules_dir_cstr);
    str_builder_add_cstr(sb, "/");
    str_builder_add_str(sb, name);
    str_builder_add_cstr(sb, ".rules");
    var path = str_builder_build(sb);

    # SYS_UNLINK = 87
    var r = sys_unlink(str_cstr(path));
    if (r < 0) {
        var esb = str_builder_new();
        str_builder_add_cstr(esb, "failed to remove rule: ");
        str_builder_add_str(esb, path);
        return err_udev(str_builder_build(esb));
    }
    return Ok(0);
}

# ---------------------------------------------------------------------------
# udevadm wrappers
#
# All of these use exec_vec / exec_capture with an absolute path and
# one argv element per token. Never concatenate arguments into a
# single string — sys_execve doesn't tokenize, and it doesn't do PATH
# lookup (audit finding MED-5). UDEVADM_PATH falls back to the
# historical /sbin location for busybox-ish distros.
# ---------------------------------------------------------------------------

fn _udevadm_path(): i64 { return "/usr/bin/udevadm"; }

# Reject sysfs paths that aren't under /sys/ — defense-in-depth
# against argv shenanigans if a caller ever hands us something
# attacker-controlled.
fn _is_sysfs_path(p): i64 {
    if (p == 0) { return 0; }
    if (load8(p + 0) != 47) { return 0; }      # '/'
    if (load8(p + 1) != 115) { return 0; }     # 's'
    if (load8(p + 2) != 121) { return 0; }     # 'y'
    if (load8(p + 3) != 115) { return 0; }     # 's'
    if (load8(p + 4) != 47) { return 0; }      # '/'
    return 1;
}

# ---------------------------------------------------------------------------
# reload_rules — udevadm control --reload-rules
# ---------------------------------------------------------------------------

pub fn reload_rules() {
    var args = vec_new();
    vec_push(args, _udevadm_path());
    vec_push(args, "control");
    vec_push(args, "--reload-rules");
    var rc = exec_vec(args);
    if (rc != 0) {
        return err_udev(str_from("failed to reload rules"));
    }
    return Ok(0);
}

# ---------------------------------------------------------------------------
# trigger_device — udevadm trigger --action=change <syspath>
# ---------------------------------------------------------------------------

pub fn trigger_device(syspath_cstr) {
    if (_is_sysfs_path(syspath_cstr) == 0) {
        return err_udev(str_from("trigger_device: path must be under /sys/"));
    }
    var args = vec_new();
    vec_push(args, _udevadm_path());
    vec_push(args, "trigger");
    vec_push(args, "--action=change");
    vec_push(args, syspath_cstr);
    var rc = exec_vec(args);
    if (rc != 0) {
        return err_udev(str_from("failed to trigger device"));
    }
    return Ok(0);
}

# ---------------------------------------------------------------------------
# query_device — udevadm info --query=property --path=<syspath>
# ---------------------------------------------------------------------------

pub fn query_device(syspath_cstr) {
    if (_is_sysfs_path(syspath_cstr) == 0) {
        return err_udev(str_from("query_device: path must be under /sys/"));
    }
    var buf[4096];
    var args = vec_new();
    vec_push(args, _udevadm_path());
    vec_push(args, "info");
    vec_push(args, "--query=property");
    # --path takes the sysfs path as a separate argument.
    vec_push(args, "--path");
    vec_push(args, syspath_cstr);
    var n = exec_capture(args, &buf, 4096);
    if (n <= 0) {
        return err_udev(str_from("device query failed"));
    }

    # Parse output into UdevDeviceInfo
    var output = str_from_buf(&buf, n);
    var info = udev_device_info_new(
    str_from(syspath_cstr),
    str_from(""),
    str_from(""),
    0, 0, 0
    );

    # Parse KEY=VALUE lines
    var lines = str_split(output, 10);
    var nlines = vec_len(lines);
    for (var i = 0; i < nlines; i = i + 1) {
        var line = str_trim(vec_get(lines, i));
        var eq = str_index_of(line, 61);
        if (eq < 0) { continue; }
        var key = str_substr(line, 0, eq);
        var val = str_substr(line, eq + 1, str_len(line));

        if (str_eq_cstr(key, "DEVPATH")) { store64(info + 8, val); }
        elif (str_eq_cstr(key, "SUBSYSTEM")) { store64(info + 16, val); }
        elif (str_eq_cstr(key, "DEVTYPE")) { store64(info + 24, val); }
        elif (str_eq_cstr(key, "DRIVER")) { store64(info + 32, val); }
        elif (str_eq_cstr(key, "DEVNAME")) { store64(info + 40, val); }
    }

    return Ok(info);
}

# ---------------------------------------------------------------------------
# list_devices — enumerate devices (optionally filtered by subsystem)
# ---------------------------------------------------------------------------

pub fn list_devices(subsystem) {
    var buf[8192];
    var args = vec_new();
    vec_push(args, _udevadm_path());
    vec_push(args, "info");
    vec_push(args, "--export-db");
    var n = exec_capture(args, &buf, 8192);
    if (n <= 0) { return vec_new(); }

    # Parse output: device blocks separated by blank lines
    var output = str_from_buf(&buf, n);
    var devices = vec_new();
    var lines = str_split(output, 10);
    var nlines = vec_len(lines);

    var cur_syspath = 0;
    var cur_devpath = str_from("");
    var cur_subsystem = str_from("");
    var cur_devtype = 0;
    var cur_driver = 0;
    var cur_devnode = 0;

    for (var i = 0; i < nlines; i = i + 1) {
        var line = str_trim(vec_get(lines, i));
        if (str_len(line) == 0) {
            # End of block
            if (cur_syspath != 0) {
                # Filter by subsystem if provided
                var include = 1;
                if (subsystem != 0) {
                    if (str_eq(cur_subsystem, subsystem) == 0) {
                        include = 0;
                    }
                }
                if (include) {
                    var di = udev_device_info_new(cur_syspath, cur_devpath, cur_subsystem,
                    cur_devtype, cur_driver, cur_devnode);
                    vec_push(devices, di);
                }
            }
            cur_syspath = 0;
            cur_devpath = str_from("");
            cur_subsystem = str_from("");
            cur_devtype = 0;
            cur_driver = 0;
            cur_devnode = 0;
            continue;
        }

        # Parse P: (syspath), E: (property)
        if (str_starts_with(line, "P: ")) {
            cur_syspath = str_substr(line, 3, str_len(line));
        } elif (str_starts_with(line, "E: ")) {
            var kv = str_substr(line, 3, str_len(line));
            var eq = str_index_of(kv, 61);
            if (eq >= 0) {
                var key = str_substr(kv, 0, eq);
                var val = str_substr(kv, eq + 1, str_len(kv));
                if (str_eq_cstr(key, "DEVPATH")) { cur_devpath = val; }
                elif (str_eq_cstr(key, "SUBSYSTEM")) { cur_subsystem = val; }
                elif (str_eq_cstr(key, "DEVTYPE")) { cur_devtype = val; }
                elif (str_eq_cstr(key, "DRIVER")) { cur_driver = val; }
                elif (str_eq_cstr(key, "DEVNAME")) { cur_devnode = val; }
            }
        }
    }

    return devices;
}

# --- partition.cyr ---

# yukti/partition.cyr — Partition table reading (MBR and GPT)
#
# Reads partition tables directly from block device files.
# Supports MBR (Master Boot Record) and GPT (GUID Partition Table).
# EFI System Partition detection and boot flag queries.

# ---------------------------------------------------------------------------
# Constants
# ---------------------------------------------------------------------------

enum PartConst {
    SECTOR_SIZE = 512;
    MBR_SIG_OFFSET = 510;
    MBR_SIG_LO = 0x55;
    MBR_SIG_HI = 0xAA;
    MBR_PART_OFFSET = 446;
    MBR_PART_ENTRY_SIZE = 16;
    MBR_MAX_PARTS = 4;
    GPT_HEADER_LBA = 1;
    GPT_ENTRY_SIZE = 128;
    GPT_MAX_ENTRIES = 128;
}

# MBR partition type IDs
enum MbrType {
    MBR_TYPE_EMPTY = 0x00;
    MBR_TYPE_FAT12 = 0x01;
    MBR_TYPE_FAT16_SMALL = 0x04;
    MBR_TYPE_EXTENDED = 0x05;
    MBR_TYPE_FAT16 = 0x06;
    MBR_TYPE_NTFS = 0x07;
    MBR_TYPE_FAT32 = 0x0B;
    MBR_TYPE_FAT32_LBA = 0x0C;
    MBR_TYPE_FAT16_LBA = 0x0E;
    MBR_TYPE_EXTENDED_LBA = 0x0F;
    MBR_TYPE_LINUX_SWAP = 0x82;
    MBR_TYPE_LINUX = 0x83;
    MBR_TYPE_LINUX_LVM = 0x8E;
    MBR_TYPE_EFI = 0xEF;
    MBR_TYPE_GPT_PROTECTIVE = 0xEE;
}

# Partition table type
enum PartTableType {
    PT_NONE = 0;
    PT_MBR = 1;
    PT_GPT = 2;
}

# ---------------------------------------------------------------------------
# PartitionEntry struct — unified for MBR and GPT
# Layout: 80 bytes
#   0: index (partition number, 0-based)
#   8: type_id (MBR type byte, or 0 for GPT)
#  16: start_lba (u64)
#  24: size_sectors (u64)
#  32: size_bytes (u64)
#  40: bootable (0/1 — MBR boot flag or GPT legacy BIOS attr)
#  48: name (Str, from GPT name field, or type description for MBR)
#  56: type_guid_hi (upper 8 bytes of GPT type GUID, 0 for MBR)
#  64: type_guid_lo (lower 8 bytes of GPT type GUID, 0 for MBR)
#  72: is_efi (0/1 — EFI System Partition)
# ---------------------------------------------------------------------------

enum PartEntryField {
    PE_INDEX = 0;
    PE_TYPE_ID = 8;
    PE_START_LBA = 16;
    PE_SIZE_SECTORS = 24;
    PE_SIZE_BYTES = 32;
    PE_BOOTABLE = 40;
    PE_NAME = 48;
    PE_TYPE_GUID_HI = 56;
    PE_TYPE_GUID_LO = 64;
    PE_IS_EFI = 72;
    PE_SIZE = 80;
}

pub fn partition_entry_new() {
    var pe = alloc(PE_SIZE);
    store64(pe + PE_INDEX, 0);
    store64(pe + PE_TYPE_ID, 0);
    store64(pe + PE_START_LBA, 0);
    store64(pe + PE_SIZE_SECTORS, 0);
    store64(pe + PE_SIZE_BYTES, 0);
    store64(pe + PE_BOOTABLE, 0);
    store64(pe + PE_NAME, 0);
    store64(pe + PE_TYPE_GUID_HI, 0);
    store64(pe + PE_TYPE_GUID_LO, 0);
    store64(pe + PE_IS_EFI, 0);
    return pe;
}

# Partition entry accessors
pub fn pe_index(pe) { return load64(pe + PE_INDEX); }         # Partition number (0-based)
pub fn pe_type_id(pe) { return load64(pe + PE_TYPE_ID); }     # MBR type byte (0 for GPT)
pub fn pe_start_lba(pe) { return load64(pe + PE_START_LBA); } # Starting LBA
pub fn pe_size_sectors(pe) { return load64(pe + PE_SIZE_SECTORS); } # Size in 512-byte sectors
pub fn pe_size_bytes(pe) { return load64(pe + PE_SIZE_BYTES); }    # Size in bytes
pub fn pe_bootable(pe) { return load64(pe + PE_BOOTABLE); }   # 1 if bootable
pub fn pe_name(pe) { return load64(pe + PE_NAME); }           # Str: GPT name or MBR type desc
pub fn pe_is_efi(pe) { return load64(pe + PE_IS_EFI); }       # 1 if EFI System Partition

# ---------------------------------------------------------------------------
# PartitionTable struct — result of reading a partition table
# Layout: 24 bytes
#   0: table_type (PT_MBR, PT_GPT, PT_NONE)
#   8: entries (vec of PartitionEntry ptrs)
#  16: disk_guid (Str, GPT only, 0 for MBR)
# ---------------------------------------------------------------------------

pub fn partition_table_new(table_type, entries, disk_guid) {
    var pt = alloc(24);
    store64(pt, table_type);
    store64(pt + 8, entries);
    store64(pt + 16, disk_guid);
    return pt;
}

# Partition table accessors
pub fn pt_type(pt) { return load64(pt); }          # PT_MBR, PT_GPT, or PT_NONE
pub fn pt_entries(pt) { return load64(pt + 8); }   # Vec of PartitionEntry ptrs
pub fn pt_disk_guid(pt) { return load64(pt + 16); } # Str: GPT disk GUID (0 for MBR)

pub fn pt_type_to_str(t) {
    if (t == PT_MBR) { return "mbr"; }
    if (t == PT_GPT) { return "gpt"; }
    return "none";
}

# ---------------------------------------------------------------------------
# MBR type ID to human-readable string
# ---------------------------------------------------------------------------

pub fn mbr_type_to_str(type_id) {
    if (type_id == MBR_TYPE_EMPTY) { return "Empty"; }
    if (type_id == MBR_TYPE_FAT12) { return "FAT12"; }
    if (type_id == MBR_TYPE_FAT16_SMALL) { return "FAT16 <32M"; }
    if (type_id == MBR_TYPE_EXTENDED) { return "Extended"; }
    if (type_id == MBR_TYPE_FAT16) { return "FAT16"; }
    if (type_id == MBR_TYPE_NTFS) { return "NTFS/exFAT"; }
    if (type_id == MBR_TYPE_FAT32) { return "FAT32"; }
    if (type_id == MBR_TYPE_FAT32_LBA) { return "FAT32 LBA"; }
    if (type_id == MBR_TYPE_FAT16_LBA) { return "FAT16 LBA"; }
    if (type_id == MBR_TYPE_EXTENDED_LBA) { return "Extended LBA"; }
    if (type_id == MBR_TYPE_LINUX_SWAP) { return "Linux swap"; }
    if (type_id == MBR_TYPE_LINUX) { return "Linux"; }
    if (type_id == MBR_TYPE_LINUX_LVM) { return "Linux LVM"; }
    if (type_id == MBR_TYPE_EFI) { return "EFI System"; }
    if (type_id == MBR_TYPE_GPT_PROTECTIVE) { return "GPT Protective"; }
    return "Unknown";
}

# ---------------------------------------------------------------------------
# Read 512 bytes from a block device at a given LBA
# ---------------------------------------------------------------------------

fn _read_sector(fd, lba, buf): i64 {
    # lseek to lba * 512: SYS_LSEEK = 8, SEEK_SET = 0
    var offset = lba * SECTOR_SIZE;
    var r = syscall(SYS_LSEEK, fd, offset, 0);
    if (r < 0) { return r; }
    # read 512 bytes
    return sys_read(fd, buf, SECTOR_SIZE);
}

# Read N bytes at an exact byte offset
fn _read_at(fd, byte_offset, buf, count): i64 {
    var r = syscall(SYS_LSEEK, fd, byte_offset, 0);
    if (r < 0) { return r; }
    return sys_read(fd, buf, count);
}

# ---------------------------------------------------------------------------
# Parse MBR partition table from sector 0 buffer
# ---------------------------------------------------------------------------

fn _parse_mbr_entries(buf): i64 {
    var entries = vec_new();

    for (var i = 0; i < MBR_MAX_PARTS; i = i + 1) {
        var offset = MBR_PART_OFFSET + i * MBR_PART_ENTRY_SIZE;

        # MBR partition entry layout (16 bytes):
        #  0: status (0x80=bootable, 0x00=inactive)
        #  1-3: CHS first sector
        #  4: type ID
        #  5-7: CHS last sector
        #  8-11: LBA start (little-endian u32)
        # 12-15: sector count (little-endian u32)

        var type_id = load8(buf + offset + 4);
        if (type_id == MBR_TYPE_EMPTY) { continue; }

        var status = load8(buf + offset);
        var lba_start = load8(buf + offset + 8) |
        (load8(buf + offset + 9) << 8) |
        (load8(buf + offset + 10) << 16) |
        (load8(buf + offset + 11) << 24);
        var sector_count = load8(buf + offset + 12) |
        (load8(buf + offset + 13) << 8) |
        (load8(buf + offset + 14) << 16) |
        (load8(buf + offset + 15) << 24);

        var pe = partition_entry_new();
        store64(pe + PE_INDEX, i);
        store64(pe + PE_TYPE_ID, type_id);
        store64(pe + PE_START_LBA, lba_start);
        store64(pe + PE_SIZE_SECTORS, sector_count);
        store64(pe + PE_SIZE_BYTES, sector_count * SECTOR_SIZE);
        if (status == 0x80) { store64(pe + PE_BOOTABLE, 1); }
        store64(pe + PE_NAME, str_from(mbr_type_to_str(type_id)));
        if (type_id == MBR_TYPE_EFI) { store64(pe + PE_IS_EFI, 1); }

        vec_push(entries, pe);
    }

    return entries;
}

# ---------------------------------------------------------------------------
# GPT GUID helpers
# ---------------------------------------------------------------------------

# Format a 16-byte GUID buffer as string (xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx)
fn _format_guid(buf): i64 {
    var sb = str_builder_new();
    # GUID is stored in mixed-endian: first 3 fields are little-endian
    # Bytes: 0-3 (LE u32), 4-5 (LE u16), 6-7 (LE u16), 8-9 (BE), 10-15 (BE)

    # Field 1: bytes 3,2,1,0
    _hex2(sb, load8(buf + 3)); _hex2(sb, load8(buf + 2));
    _hex2(sb, load8(buf + 1)); _hex2(sb, load8(buf + 0));
    str_builder_add_byte(sb, 45);
    # Field 2: bytes 5,4
    _hex2(sb, load8(buf + 5)); _hex2(sb, load8(buf + 4));
    str_builder_add_byte(sb, 45);
    # Field 3: bytes 7,6
    _hex2(sb, load8(buf + 7)); _hex2(sb, load8(buf + 6));
    str_builder_add_byte(sb, 45);
    # Field 4: bytes 8,9
    _hex2(sb, load8(buf + 8)); _hex2(sb, load8(buf + 9));
    str_builder_add_byte(sb, 45);
    # Field 5: bytes 10-15
    _hex2(sb, load8(buf + 10)); _hex2(sb, load8(buf + 11));
    _hex2(sb, load8(buf + 12)); _hex2(sb, load8(buf + 13));
    _hex2(sb, load8(buf + 14)); _hex2(sb, load8(buf + 15));

    return str_builder_build(sb);
}

fn _hex2(sb, byte): i64 {
    var hi = (byte >> 4) & 0x0F;
    var lo = byte & 0x0F;
    if (hi < 10) { str_builder_add_byte(sb, 48 + hi); }
    else { str_builder_add_byte(sb, 97 + hi - 10); }
    if (lo < 10) { str_builder_add_byte(sb, 48 + lo); }
    else { str_builder_add_byte(sb, 97 + lo - 10); }
    return 0;
}

# Known GPT type GUIDs (stored as the first 4 bytes LE for quick comparison)
# EFI System: C12A7328-F81F-11D2-BA4B-00A0C93EC93B
# Linux filesystem: 0FC63DAF-8483-4772-8E79-3D69D8477DE4
# Linux swap: 0657FD6D-A4AB-43C4-84E5-0933C84B4F4F
# Microsoft Basic Data: EBD0A0A2-B9E5-4433-87C0-68B6B72699C7

fn _is_efi_type_guid(guid_buf): i64 {
    # Check first 4 bytes (LE): C12A7328 -> bytes: 28 73 2A C1
    if (load8(guid_buf) == 0x28) {
        if (load8(guid_buf + 1) == 0x73) {
            if (load8(guid_buf + 2) == 0x2A) {
                if (load8(guid_buf + 3) == 0xC1) {
                    return 1;
                }
            }
        }
    }
    return 0;
}

fn _is_linux_type_guid(guid_buf): i64 {
    # 0FC63DAF -> bytes: AF 3D C6 0F
    if (load8(guid_buf) == 0xAF) {
        if (load8(guid_buf + 1) == 0x3D) {
            if (load8(guid_buf + 2) == 0xC6) {
                if (load8(guid_buf + 3) == 0x0F) { return 1; }
            }
        }
    }
    return 0;
}

fn _is_linux_swap_guid(guid_buf): i64 {
    # 0657FD6D -> bytes: 6D FD 57 06
    if (load8(guid_buf) == 0x6D) {
        if (load8(guid_buf + 1) == 0xFD) {
            if (load8(guid_buf + 2) == 0x57) {
                if (load8(guid_buf + 3) == 0x06) { return 1; }
            }
        }
    }
    return 0;
}

fn _is_msdata_type_guid(guid_buf): i64 {
    # EBD0A0A2 -> bytes: A2 A0 D0 EB
    if (load8(guid_buf) == 0xA2) {
        if (load8(guid_buf + 1) == 0xA0) {
            if (load8(guid_buf + 2) == 0xD0) {
                if (load8(guid_buf + 3) == 0xEB) { return 1; }
            }
        }
    }
    return 0;
}

fn _gpt_type_guid_to_str(guid_buf): i64 {
    if (_is_efi_type_guid(guid_buf)) { return "EFI System"; }
    if (_is_linux_type_guid(guid_buf)) { return "Linux filesystem"; }
    if (_is_linux_swap_guid(guid_buf)) { return "Linux swap"; }
    if (_is_msdata_type_guid(guid_buf)) { return "Microsoft Basic Data"; }
    return _format_guid(guid_buf);
}

# Check if GUID is all zeros (unused entry)
fn _is_zero_guid(buf): i64 {
    for (var i = 0; i < 16; i = i + 1) {
        if (load8(buf + i) != 0) { return 0; }
    }
    return 1;
}

# ---------------------------------------------------------------------------
# Parse GPT name field — 72 bytes of UTF-16LE, extract ASCII
# ---------------------------------------------------------------------------

fn _parse_gpt_name(buf): i64 {
    var sb = str_builder_new();
    for (var i = 0; i < 36; i = i + 1) {
        var lo = load8(buf + i * 2);
        var hi = load8(buf + i * 2 + 1);
        if (lo == 0) { if (hi == 0) { break; } }
        # ASCII range only
        if (hi == 0) {
            if (lo >= 32) { if (lo < 127) { str_builder_add_byte(sb, lo); } }
        }
    }
    return str_builder_build(sb);
}

# ---------------------------------------------------------------------------
# Parse GPT partition entries
# ---------------------------------------------------------------------------

fn _parse_gpt_entries(fd, entry_start_lba, num_entries, entry_size): i64 {
    var entries = vec_new();
    var buf[128];
    var byte_offset = entry_start_lba * SECTOR_SIZE;

    for (var i = 0; i < num_entries; i = i + 1) {
        var n = _read_at(fd, byte_offset + i * entry_size, &buf, entry_size);
        if (n < entry_size) { break; }

        # GPT partition entry layout (128 bytes):
        #  0-15: Partition type GUID (16 bytes)
        # 16-31: Unique partition GUID (16 bytes)
        # 32-39: Starting LBA (u64 LE)
        # 40-47: Ending LBA (u64 LE)
        # 48-55: Attributes (u64)
        # 56-127: Name (72 bytes, UTF-16LE)

        # Skip empty entries (zero type GUID)
        if (_is_zero_guid(&buf)) { continue; }

        var start_lba = load64(&buf + 32);
        var end_lba = load64(&buf + 40);
        var attrs = load64(&buf + 48);
        var sector_count = end_lba - start_lba + 1;

        var pe = partition_entry_new();
        store64(pe + PE_INDEX, i);
        store64(pe + PE_TYPE_ID, 0);
        store64(pe + PE_START_LBA, start_lba);
        store64(pe + PE_SIZE_SECTORS, sector_count);
        store64(pe + PE_SIZE_BYTES, sector_count * SECTOR_SIZE);

        # GPT legacy BIOS bootable: attribute bit 2
        store64(pe + PE_BOOTABLE, (attrs >> 2) & 1);

        # Name
        var name = _parse_gpt_name(&buf + 56);
        if (str_len(name) == 0) {
            name = str_from(_gpt_type_guid_to_str(&buf));
        }
        store64(pe + PE_NAME, name);

        # Type GUID
        store64(pe + PE_TYPE_GUID_HI, load64(&buf));
        store64(pe + PE_TYPE_GUID_LO, load64(&buf + 8));

        # EFI detection
        store64(pe + PE_IS_EFI, _is_efi_type_guid(&buf));

        vec_push(entries, pe);
    }

    return entries;
}

# ---------------------------------------------------------------------------
# read_partition_table — main entry point
# Opens a block device and reads its partition table (MBR or GPT)
# ---------------------------------------------------------------------------

pub fn read_partition_table(dev_path_cstr) {
    sakshi_span_enter("read_pt", 7);

    var fd = sys_open(dev_path_cstr, O_RDONLY, 0);
    if (fd < 0) {
        sakshi_span_exit();
        return err_io(str_from(dev_path_cstr));
    }

    # Read sector 0 (MBR / protective MBR)
    var sector0[512];
    var n = _read_sector(fd, 0, &sector0);
    if (n < SECTOR_SIZE) {
        sys_close(fd);
        sakshi_span_exit();
        return err_io(str_from("failed to read sector 0"));
    }

    # Validate MBR signature
    if (load8(&sector0 + MBR_SIG_OFFSET) != MBR_SIG_LO) {
        sys_close(fd);
        sakshi_span_exit();
        return Ok(partition_table_new(PT_NONE, vec_new(), 0));
    }
    if (load8(&sector0 + MBR_SIG_OFFSET + 1) != MBR_SIG_HI) {
        sys_close(fd);
        sakshi_span_exit();
        return Ok(partition_table_new(PT_NONE, vec_new(), 0));
    }

    # Check if this is a GPT protective MBR
    var mbr_type0 = load8(&sector0 + MBR_PART_OFFSET + 4);
    if (mbr_type0 == MBR_TYPE_GPT_PROTECTIVE) {
        # Read GPT header at LBA 1
        var gpt_hdr[512];
        n = _read_sector(fd, GPT_HEADER_LBA, &gpt_hdr);
        if (n < SECTOR_SIZE) {
            sys_close(fd);
            sakshi_span_exit();
            return err_io(str_from("failed to read GPT header"));
        }

        # GPT header layout:
        #  0-7: Signature "EFI PART" (45 46 49 20 50 41 52 54)
        #  8-11: Revision (usually 00 00 01 00)
        # 12-15: Header size (usually 92)
        # 16-19: CRC32 of header
        # 20-23: Reserved
        # 24-31: My LBA
        # 32-39: Alternate LBA
        # 40-47: First usable LBA
        # 48-55: Last usable LBA
        # 56-71: Disk GUID (16 bytes)
        # 72-79: Partition entry start LBA
        # 80-83: Number of partition entries
        # 84-87: Size of partition entry
        # 88-91: CRC32 of partition entries

        # Validate signature: "EFI PART"
        if (load8(&gpt_hdr) != 0x45) {
            sys_close(fd);
            sakshi_span_exit();
            return err_parse(str_from("invalid GPT signature"));
        }
        if (load8(&gpt_hdr + 1) != 0x46) {
            sys_close(fd);
            sakshi_span_exit();
            return err_parse(str_from("invalid GPT signature"));
        }

        var entry_start_lba = load64(&gpt_hdr + 72);
        var num_entries = load32(&gpt_hdr + 80);
        var entry_size = load32(&gpt_hdr + 84);
        # GPT spec permits entry_size multiples of 128, but every real-world
        # producer writes exactly 128 and our stack buffer in
        # _parse_gpt_entries is sized for 128. A crafted disk with
        # entry_size > 128 would overflow that buffer (see
        # docs/audit/2026-04-19-audit.md finding HIGH-2) — reject instead.
        if (entry_size != GPT_ENTRY_SIZE) {
            sys_close(fd);
            sakshi_span_exit();
            return err_parse(str_from("GPT entry_size must be 128"));
        }
        if (num_entries > GPT_MAX_ENTRIES) { num_entries = GPT_MAX_ENTRIES; }

        # Disk GUID
        var disk_guid = _format_guid(&gpt_hdr + 56);

        var entries = _parse_gpt_entries(fd, entry_start_lba, num_entries, entry_size);

        sys_close(fd);
        sakshi_span_exit();
        return Ok(partition_table_new(PT_GPT, entries, disk_guid));
    }

    # Plain MBR
    var entries = _parse_mbr_entries(&sector0);
    sys_close(fd);
    sakshi_span_exit();
    return Ok(partition_table_new(PT_MBR, entries, 0));
}

# ---------------------------------------------------------------------------
# Convenience queries
# ---------------------------------------------------------------------------

# Find the EFI System Partition in a partition table
pub fn find_efi_partition(pt) {
    var entries = pt_entries(pt);
    var n = vec_len(entries);
    for (var i = 0; i < n; i = i + 1) {
        var pe = vec_get(entries, i);
        if (pe_is_efi(pe)) { return pe; }
    }
    return 0;
}

# Find all bootable partitions
pub fn find_bootable_partitions(pt) {
    var result = vec_new();
    var entries = pt_entries(pt);
    var n = vec_len(entries);
    for (var i = 0; i < n; i = i + 1) {
        var pe = vec_get(entries, i);
        if (pe_bootable(pe)) { vec_push(result, pe); }
    }
    return result;
}

# Get partition count (non-empty entries)
pub fn partition_count(pt) {
    return vec_len(pt_entries(pt));
}

# Check if a disk has an EFI System Partition
pub fn has_efi_partition(pt) {
    return find_efi_partition(pt) != 0;
}

# Read partition table from sysfs device name (e.g. "sda", "nvme0n1")
pub fn read_partition_table_by_name(dev_name) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "/dev/");
    str_builder_add_str(sb, dev_name);
    return read_partition_table(str_cstr(str_builder_build(sb)));
}

# --- device_db.cyr ---

# yukti/device_db.cyr — Device database persistence via patra
#
# Tracks device history, mount preferences, and metadata.
# Stores in a local .patra database file.
#
# Tables:
#   devices       — known devices (by serial/vendor+model)
#   mount_history — mount/unmount events with timestamps
#   preferences   — per-device mount preferences (mount point, read-only, fs type)

# ---------------------------------------------------------------------------
# SQL string-literal escape
#
# patra 1.1.1 has no prepared-statement API, so every string
# interpolated into SQL must be escaped here. Malicious USB descriptor
# fields (ID_SERIAL, vendor, model) can otherwise break out of the
# surrounding quotes — see docs/audit/2026-04-19-audit.md finding
# HIGH-1.
#
# Rules (kept strict — err toward dropping metacharacters):
#   '  -> ''           (standard SQL single-quote escape)
#   \0 -> dropped      (terminates cstr; never belongs in a row value)
#   \n -> dropped      (no multi-line SQL values; defense-in-depth)
# ---------------------------------------------------------------------------

fn _sql_escape_str(s): i64 {
    if (s == 0) { return str_from(""); }
    var n = str_len(s);
    var src = str_data(s);
    var sb = str_builder_new();
    for (var i = 0; i < n; i = i + 1) {
        var c = load8(src + i);
        if (c == 0) { continue; }
        if (c == 10) { continue; }
        str_builder_add_byte(sb, c);
        if (c == 39) { str_builder_add_byte(sb, c); }   # '' escape
    }
    return str_builder_build(sb);
}

pub fn _sql_escape_str_pub(s) { return _sql_escape_str(s); }

# ---------------------------------------------------------------------------
# Database lifecycle
# ---------------------------------------------------------------------------

var _yukti_db = 0;

pub fn device_db_open(path) {
    sakshi_span_enter("db_open", 7);
    patra_init();
    _yukti_db = patra_open(path);
    if (_yukti_db == 0) {
        sakshi_span_exit();
        return err_io(str_from("failed to open device database"));
    }

    # Create tables if they don't exist
    var s1 = "CREATE TABLE devices (serial STR, vendor STR, ";
    var s2 = "model STR, class INT, first_seen INT, ";
    var s3 = "last_seen INT, mount_count INT)";
    var sb0 = str_builder_new();
    str_builder_add_cstr(sb0, s1);
    str_builder_add_cstr(sb0, s2);
    str_builder_add_cstr(sb0, s3);
    patra_exec(_yukti_db, str_cstr(str_builder_build(sb0)));

    var h1 = "CREATE TABLE mount_history (serial STR, ";
    var h2 = "dev_path STR, mount_point STR, ";
    var h3 = "fs_type STR, timestamp INT, action INT)";
    var sb1 = str_builder_new();
    str_builder_add_cstr(sb1, h1);
    str_builder_add_cstr(sb1, h2);
    str_builder_add_cstr(sb1, h3);
    patra_exec(_yukti_db, str_cstr(str_builder_build(sb1)));

    var p1 = "CREATE TABLE preferences (serial STR, ";
    var p2 = "mount_point STR, read_only INT, ";
    var p3 = "fs_type STR, auto_mount INT)";
    var sb2 = str_builder_new();
    str_builder_add_cstr(sb2, p1);
    str_builder_add_cstr(sb2, p2);
    str_builder_add_cstr(sb2, p3);
    patra_exec(_yukti_db, str_cstr(str_builder_build(sb2)));

    # 2.2.1: audio_devices table — one row per (hw_id, direction)
    # pair. Keyed by hw_id so re-plugging the same USB DAC bumps
    # last_seen rather than creating a new row. friendly_name and
    # driver get refreshed on every record_audio_seen call so the
    # most recently observed display string wins.
    var a1 = "CREATE TABLE audio_devices (hw_id STR, ";
    var a2 = "friendly_name STR, driver STR, ";
    var a3 = "direction INT, card INT, device INT, ";
    var a4 = "first_seen INT, last_seen INT)";
    var sb3 = str_builder_new();
    str_builder_add_cstr(sb3, a1);
    str_builder_add_cstr(sb3, a2);
    str_builder_add_cstr(sb3, a3);
    str_builder_add_cstr(sb3, a4);
    patra_exec(_yukti_db, str_cstr(str_builder_build(sb3)));

    sakshi_span_exit();
    return Ok(_yukti_db);
}

pub fn device_db_close() {
    if (_yukti_db != 0) {
        patra_close(_yukti_db);
        _yukti_db = 0;
    }
    return 0;
}

pub fn device_db_handle() {
    return _yukti_db;
}

# ---------------------------------------------------------------------------
# Device key — serial if available, else vendor:model
# ---------------------------------------------------------------------------

fn _device_key(info): i64 {
    var serial = di_serial(info);
    if (serial != 0) {
        if (str_len(serial) > 0) {
            return serial;
        }
    }
    # Fallback: vendor:model
    var vendor = di_vendor(info);
    var model = di_model(info);
    if (vendor == 0) { vendor = str_from("unknown"); }
    if (model == 0) { model = str_from("unknown"); }
    var sb = str_builder_new();
    str_builder_add_str(sb, vendor);
    str_builder_add_cstr(sb, ":");
    str_builder_add_str(sb, model);
    return str_builder_build(sb);
}

# ---------------------------------------------------------------------------
# Record device seen — upsert into devices table
# ---------------------------------------------------------------------------

pub fn device_db_record_seen(info) {
    if (_yukti_db == 0) { return 0; }

    var key = _device_key(info);
    var key_cstr = str_cstr(key);
    var vendor = di_vendor(info);
    var model = di_model(info);
    var class = di_class(info);

    # Get current timestamp
    var now = clock_epoch_secs();   # epoch secs (chrono; cross-platform — see src/syscalls.cyr)

    # Check if device exists
    var key_esc = _sql_escape_str(key);
    var sql_sb = str_builder_new();
    str_builder_add_cstr(sql_sb, "SELECT mount_count FROM devices WHERE serial = '");
    str_builder_add_str(sql_sb, key_esc);
    str_builder_add_cstr(sql_sb, "'");
    var sql = str_builder_build(sql_sb);

    var rs = patra_query(_yukti_db, str_cstr(sql));
    if (rs != 0) {
        if (patra_result_count(rs) > 0) {
            # Update existing — bump last_seen and mount_count
            var count = patra_result_get_int(rs, 0, 0);
            patra_result_free(rs);

            var upd_sb = str_builder_new();
            str_builder_add_cstr(upd_sb, "UPDATE devices SET last_seen = ");
            str_builder_add_int(upd_sb, now);
            str_builder_add_cstr(upd_sb, " WHERE serial = '");
            str_builder_add_str(upd_sb, key_esc);
            str_builder_add_cstr(upd_sb, "'");
            patra_exec(_yukti_db, str_cstr(str_builder_build(upd_sb)));
            return 0;
        }
        patra_result_free(rs);
    }

    # Insert new device
    var vendor_esc = _sql_escape_str(vendor);
    var model_esc = _sql_escape_str(model);
    var ins_sb = str_builder_new();
    str_builder_add_cstr(ins_sb, "INSERT INTO devices VALUES ('");
    str_builder_add_str(ins_sb, key_esc);
    str_builder_add_cstr(ins_sb, "', '");
    str_builder_add_str(ins_sb, vendor_esc);
    str_builder_add_cstr(ins_sb, "', '");
    str_builder_add_str(ins_sb, model_esc);
    str_builder_add_cstr(ins_sb, "', ");
    str_builder_add_int(ins_sb, class);
    str_builder_add_cstr(ins_sb, ", ");
    str_builder_add_int(ins_sb, now);
    str_builder_add_cstr(ins_sb, ", ");
    str_builder_add_int(ins_sb, now);
    str_builder_add_cstr(ins_sb, ", 0)");
    patra_exec(_yukti_db, str_cstr(str_builder_build(ins_sb)));

    return 0;
}

# ---------------------------------------------------------------------------
# Record mount/unmount event
# ---------------------------------------------------------------------------

enum MountAction {
    ACTION_MOUNT = 1;
    ACTION_UNMOUNT = 2;
    ACTION_EJECT = 3;
}

pub fn device_db_record_mount(info, mount_point, fs_type_str, action) {
    if (_yukti_db == 0) { return 0; }

    var key = _device_key(info);
    var dev_path = di_dev_path(info);

    var now = clock_epoch_secs();   # epoch secs (chrono; cross-platform — see src/syscalls.cyr)

    var key_esc = _sql_escape_str(key);
    var dev_path_esc = _sql_escape_str(dev_path);
    var mount_point_esc = _sql_escape_str(mount_point);
    var fs_type_esc = _sql_escape_str(fs_type_str);
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "INSERT INTO mount_history VALUES ('");
    str_builder_add_str(sb, key_esc);
    str_builder_add_cstr(sb, "', '");
    str_builder_add_str(sb, dev_path_esc);
    str_builder_add_cstr(sb, "', '");
    str_builder_add_str(sb, mount_point_esc);
    str_builder_add_cstr(sb, "', '");
    str_builder_add_str(sb, fs_type_esc);
    str_builder_add_cstr(sb, "', ");
    str_builder_add_int(sb, now);
    str_builder_add_cstr(sb, ", ");
    str_builder_add_int(sb, action);
    str_builder_add_cstr(sb, ")");
    patra_exec(_yukti_db, str_cstr(str_builder_build(sb)));

    # Update mount_count in devices table
    if (action == ACTION_MOUNT) {
        var upd_sb = str_builder_new();
        str_builder_add_cstr(upd_sb, "UPDATE devices SET ");
        str_builder_add_cstr(upd_sb, "mount_count = mount_count + 1, last_seen = ");
        str_builder_add_int(upd_sb, now);
        str_builder_add_cstr(upd_sb, " WHERE serial = '");
        str_builder_add_str(upd_sb, key_esc);
        str_builder_add_cstr(upd_sb, "'");
        patra_exec(_yukti_db, str_cstr(str_builder_build(upd_sb)));
    }

    return 0;
}

# ---------------------------------------------------------------------------
# Preferences — per-device mount configuration
# ---------------------------------------------------------------------------

pub fn device_db_set_preference(serial, mount_point, read_only, fs_type, auto_mount) {
    if (_yukti_db == 0) { return 0; }

    # Delete existing preference
    var serial_esc = _sql_escape_str(serial);
    var mount_point_esc = _sql_escape_str(mount_point);
    var fs_type_esc = _sql_escape_str(fs_type);
    var del_sb = str_builder_new();
    str_builder_add_cstr(del_sb, "DELETE FROM preferences WHERE serial = '");
    str_builder_add_str(del_sb, serial_esc);
    str_builder_add_cstr(del_sb, "'");
    patra_exec(_yukti_db, str_cstr(str_builder_build(del_sb)));

    # Insert new preference
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "INSERT INTO preferences VALUES ('");
    str_builder_add_str(sb, serial_esc);
    str_builder_add_cstr(sb, "', '");
    str_builder_add_str(sb, mount_point_esc);
    str_builder_add_cstr(sb, "', ");
    str_builder_add_int(sb, read_only);
    str_builder_add_cstr(sb, ", '");
    str_builder_add_str(sb, fs_type_esc);
    str_builder_add_cstr(sb, "', ");
    str_builder_add_int(sb, auto_mount);
    str_builder_add_cstr(sb, ")");
    patra_exec(_yukti_db, str_cstr(str_builder_build(sb)));

    return 0;
}

# Get preference for a device. Returns alloc'd struct or 0.
# Layout: 32 bytes [mount_point Str, read_only i64, fs_type Str, auto_mount i64]
pub fn device_db_get_preference(serial) {
    if (_yukti_db == 0) { return 0; }

    var serial_esc = _sql_escape_str(serial);
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "SELECT mount_point, read_only, ");
    str_builder_add_cstr(sb, "fs_type, auto_mount ");
    str_builder_add_cstr(sb, "FROM preferences WHERE serial = '");
    str_builder_add_str(sb, serial_esc);
    str_builder_add_cstr(sb, "'");

    var rs = patra_query(_yukti_db, str_cstr(str_builder_build(sb)));
    if (rs == 0) { return 0; }
    if (patra_result_count(rs) == 0) {
        patra_result_free(rs);
        return 0;
    }

    var pref = alloc(32);
    var mp_raw = patra_result_get_str(rs, 0, 0);
    if (mp_raw != 0) {
        if (load8(mp_raw) != 0) {
            store64(pref, str_from(mp_raw));
        } else {
            store64(pref, 0);
        }
    } else {
        store64(pref, 0);
    }
    store64(pref + 8, patra_result_get_int(rs, 0, 1));
    var fs_raw = patra_result_get_str(rs, 0, 2);
    if (fs_raw != 0) {
        if (load8(fs_raw) != 0) {
            store64(pref + 16, str_from(fs_raw));
        } else {
            store64(pref + 16, 0);
        }
    } else {
        store64(pref + 16, 0);
    }
    store64(pref + 24, patra_result_get_int(rs, 0, 3));
    patra_result_free(rs);
    return pref;
}

# Preference accessors
pub fn pref_mount_point(p) { return load64(p); }     # Str: preferred mount point (0 = auto)
pub fn pref_read_only(p) { return load64(p + 8); }   # 0/1
pub fn pref_fs_type(p) { return load64(p + 16); }    # Str: filesystem type (0 = auto)
pub fn pref_auto_mount(p) { return load64(p + 24); } # 0/1: auto-mount on plug

# ---------------------------------------------------------------------------
# Queries — device history
# ---------------------------------------------------------------------------

# Get mount count for a device
pub fn device_db_mount_count(serial) {
    if (_yukti_db == 0) { return 0; }

    var serial_esc = _sql_escape_str(serial);
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "SELECT mount_count FROM devices WHERE serial = '");
    str_builder_add_str(sb, serial_esc);
    str_builder_add_cstr(sb, "'");

    var rs = patra_query(_yukti_db, str_cstr(str_builder_build(sb)));
    if (rs == 0) { return 0; }
    if (patra_result_count(rs) == 0) {
        patra_result_free(rs);
        return 0;
    }
    var count = patra_result_get_int(rs, 0, 0);
    patra_result_free(rs);
    return count;
}

# Get total known device count
pub fn device_db_device_count() {
    if (_yukti_db == 0) { return 0; }
    var rs = patra_query(_yukti_db, "SELECT COUNT(*) FROM devices");
    if (rs == 0) { return 0; }
    var count = patra_result_get_int(rs, 0, 0);
    patra_result_free(rs);
    return count;
}

# Check if a device has been seen before
pub fn device_db_is_known(serial) {
    if (_yukti_db == 0) { return 0; }

    var serial_esc = _sql_escape_str(serial);
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "SELECT serial FROM devices WHERE serial = '");
    str_builder_add_str(sb, serial_esc);
    str_builder_add_cstr(sb, "'");

    var rs = patra_query(_yukti_db, str_cstr(str_builder_build(sb)));
    if (rs == 0) { return 0; }
    var known = patra_result_count(rs) > 0;
    patra_result_free(rs);
    return known;
}

# ---------------------------------------------------------------------------
# Audio device persistence (2.2.1)
#
# Records an AudioDeviceInfo into the audio_devices table, keyed by
# hw_id. UPSERT semantics — first call inserts with first_seen =
# last_seen = now; subsequent calls bump last_seen and refresh the
# friendly_name + driver fields (the most recently observed
# display string wins, e.g. if the kernel renames a card on
# firmware update).
#
# hw_id stability matters here. yukti_audio_hw_id() anchors on PCI
# BDF for built-in HDA / discrete sound / GPU HDMI and on
# vendor:product:serial for USB. Re-plugging the same USB DAC
# carries history forward; adding a PCIe sound card and reordering
# ALSA card numbers does NOT corrupt history (the "card2_dev0_p"
# fallback path is documented as transient — consumers should not
# rely on it for long-term identity).
# ---------------------------------------------------------------------------

pub fn device_db_record_audio_seen(audio_info) {
    if (_yukti_db == 0) { return 0; }
    if (audio_info == 0) { return 0; }

    var hw_id = yukti_audio_hw_id(audio_info);
    if (hw_id == 0) { return 0; }
    var hw_esc = _sql_escape_str(hw_id);

    var name = yukti_audio_name(audio_info);
    if (name == 0) { name = str_from(""); }
    var driver = yukti_audio_driver(audio_info);
    if (driver == 0) { driver = str_from(""); }
    var name_esc = _sql_escape_str(name);
    var driver_esc = _sql_escape_str(driver);

    var direction = yukti_audio_direction(audio_info);
    var card = yukti_audio_card(audio_info);
    var device = yukti_audio_device(audio_info);

    var now = clock_epoch_secs();   # epoch secs (chrono; cross-platform — see src/syscalls.cyr)

    # Lookup
    var qsb = str_builder_new();
    str_builder_add_cstr(qsb, "SELECT first_seen FROM audio_devices WHERE hw_id = '");
    str_builder_add_str(qsb, hw_esc);
    str_builder_add_cstr(qsb, "'");
    var rs = patra_query(_yukti_db, str_cstr(str_builder_build(qsb)));
    if (rs != 0) {
        if (patra_result_count(rs) > 0) {
            patra_result_free(rs);
            # Update — bump last_seen + refresh display fields
            var usb = str_builder_new();
            str_builder_add_cstr(usb, "UPDATE audio_devices SET last_seen = ");
            str_builder_add_int(usb, now);
            str_builder_add_cstr(usb, ", friendly_name = '");
            str_builder_add_str(usb, name_esc);
            str_builder_add_cstr(usb, "', driver = '");
            str_builder_add_str(usb, driver_esc);
            str_builder_add_cstr(usb, "', card = ");
            str_builder_add_int(usb, card);
            str_builder_add_cstr(usb, ", device = ");
            str_builder_add_int(usb, device);
            str_builder_add_cstr(usb, " WHERE hw_id = '");
            str_builder_add_str(usb, hw_esc);
            str_builder_add_cstr(usb, "'");
            patra_exec(_yukti_db, str_cstr(str_builder_build(usb)));
            return 0;
        }
        patra_result_free(rs);
    }

    # Insert
    var isb = str_builder_new();
    str_builder_add_cstr(isb, "INSERT INTO audio_devices VALUES ('");
    str_builder_add_str(isb, hw_esc);
    str_builder_add_cstr(isb, "', '");
    str_builder_add_str(isb, name_esc);
    str_builder_add_cstr(isb, "', '");
    str_builder_add_str(isb, driver_esc);
    str_builder_add_cstr(isb, "', ");
    str_builder_add_int(isb, direction);
    str_builder_add_cstr(isb, ", ");
    str_builder_add_int(isb, card);
    str_builder_add_cstr(isb, ", ");
    str_builder_add_int(isb, device);
    str_builder_add_cstr(isb, ", ");
    str_builder_add_int(isb, now);
    str_builder_add_cstr(isb, ", ");
    str_builder_add_int(isb, now);
    str_builder_add_cstr(isb, ")");
    patra_exec(_yukti_db, str_cstr(str_builder_build(isb)));
    return 0;
}

# Total number of audio devices ever seen.
pub fn device_db_audio_count() {
    if (_yukti_db == 0) { return 0; }
    var rs = patra_query(_yukti_db, "SELECT COUNT(*) FROM audio_devices");
    if (rs == 0) { return 0; }
    var count = patra_result_get_int(rs, 0, 0);
    patra_result_free(rs);
    return count;
}

# Check whether an audio device with the given hw_id has been seen
# before. Returns 1 / 0.
pub fn device_db_audio_known(hw_id) {
    if (_yukti_db == 0) { return 0; }
    if (hw_id == 0) { return 0; }
    var hw_esc = _sql_escape_str(hw_id);
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "SELECT hw_id FROM audio_devices WHERE hw_id = '");
    str_builder_add_str(sb, hw_esc);
    str_builder_add_cstr(sb, "'");
    var rs = patra_query(_yukti_db, str_cstr(str_builder_build(sb)));
    if (rs == 0) { return 0; }
    var known = patra_result_count(rs) > 0;
    patra_result_free(rs);
    return known;
}

# Return last_seen timestamp for an audio device's hw_id, or 0 if
# never seen. Useful for "show me devices I haven't plugged in for
# a while" diagnostics.
pub fn device_db_audio_last_seen(hw_id) {
    if (_yukti_db == 0) { return 0; }
    if (hw_id == 0) { return 0; }
    var hw_esc = _sql_escape_str(hw_id);
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "SELECT last_seen FROM audio_devices WHERE hw_id = '");
    str_builder_add_str(sb, hw_esc);
    str_builder_add_cstr(sb, "'");
    var rs = patra_query(_yukti_db, str_cstr(str_builder_build(sb)));
    if (rs == 0) { return 0; }
    if (patra_result_count(rs) == 0) {
        patra_result_free(rs);
        return 0;
    }
    var ts = patra_result_get_int(rs, 0, 0);
    patra_result_free(rs);
    return ts;
}

# --- network.cyr ---

# yukti/network.cyr — Network filesystem mount helpers
#
# SMB/CIFS and NFS mount support via mount syscall.
# Share detection via /proc/mounts and simple probing.

# ---------------------------------------------------------------------------
# Network filesystem types
# ---------------------------------------------------------------------------

enum NetFsType {
    NET_FS_SMB = 0;
    NET_FS_NFS = 1;
    NET_FS_NFS4 = 2;
}

pub fn net_fs_to_str(nfs) {
    if (nfs == NET_FS_SMB) { return "cifs"; }
    if (nfs == NET_FS_NFS) { return "nfs"; }
    if (nfs == NET_FS_NFS4) { return "nfs4"; }
    return "unknown";
}

pub fn net_fs_to_kernel_type(nfs) {
    if (nfs == NET_FS_SMB) { return "cifs"; }
    if (nfs == NET_FS_NFS) { return "nfs"; }
    if (nfs == NET_FS_NFS4) { return "nfs4"; }
    return "nfs";
}

# ---------------------------------------------------------------------------
# NetworkShare struct — describes a remote share
# Layout: 48 bytes
#   0: host (Str — IP or hostname)
#   8: path (Str — remote path, e.g. /exports/data)
#  16: fs_type (NetFsType)
#  24: port (i64, 0 = default: 445 for SMB, 2049 for NFS)
#  32: username (Str, 0 if none)
#  40: password (Str, 0 if none)
# ---------------------------------------------------------------------------

enum NetShareField {
    NS_HOST = 0;
    NS_PATH = 8;
    NS_FS_TYPE = 16;
    NS_PORT = 24;
    NS_USERNAME = 32;
    NS_PASSWORD = 40;
    NS_SIZE = 48;
}

pub fn network_share_new(host, path, fs_type) {
    var ns = alloc(NS_SIZE);
    store64(ns + NS_HOST, host);
    store64(ns + NS_PATH, path);
    store64(ns + NS_FS_TYPE, fs_type);
    store64(ns + NS_PORT, 0);
    store64(ns + NS_USERNAME, 0);
    store64(ns + NS_PASSWORD, 0);
    return ns;
}

# NetworkShare accessors
pub fn ns_host(ns) { return load64(ns + NS_HOST); }       # Str: IP or hostname
pub fn ns_path(ns) { return load64(ns + NS_PATH); }       # Str: remote path
pub fn ns_fs_type(ns) { return load64(ns + NS_FS_TYPE); } # NetFsType enum
pub fn ns_port(ns) { return load64(ns + NS_PORT); }       # Port (0 = default)
pub fn ns_username(ns) { return load64(ns + NS_USERNAME); } # Str or 0
pub fn ns_password(ns) { return load64(ns + NS_PASSWORD); } # Str or 0

# NetworkShare setters (builder pattern — returns ns)
pub fn ns_set_port(ns, port) { store64(ns + NS_PORT, port); return ns; }
pub fn ns_set_username(ns, user) { store64(ns + NS_USERNAME, user); return ns; }
pub fn ns_set_password(ns, pass) { store64(ns + NS_PASSWORD, pass); return ns; }

# Default port for filesystem type
pub fn ns_default_port(fs_type) {
    if (fs_type == NET_FS_SMB) { return 445; }
    if (fs_type == NET_FS_NFS) { return 2049; }
    if (fs_type == NET_FS_NFS4) { return 2049; }
    return 0;
}

# ---------------------------------------------------------------------------
# Build mount source string
# SMB: //host/path
# NFS: host:/path
# ---------------------------------------------------------------------------

pub fn network_mount_source(share) {
    var sb = str_builder_new();
    var fs = ns_fs_type(share);

    if (fs == NET_FS_SMB) {
        str_builder_add_cstr(sb, "//");
        str_builder_add_str(sb, ns_host(share));
        var path = ns_path(share);
        if (load8(str_data(path)) != 47) {
            str_builder_add_cstr(sb, "/");
        }
        str_builder_add_str(sb, path);
    } else {
        # NFS: host:/path
        str_builder_add_str(sb, ns_host(share));
        str_builder_add_cstr(sb, ":");
        str_builder_add_str(sb, ns_path(share));
    }

    return str_builder_build(sb);
}

# ---------------------------------------------------------------------------
# Build mount data options string for SMB/NFS
# ---------------------------------------------------------------------------

fn _build_smb_options(share): i64 {
    var sb = str_builder_new();

    var user = ns_username(share);
    if (user != 0) {
        str_builder_add_cstr(sb, "username=");
        str_builder_add_str(sb, user);
        var pass = ns_password(share);
        if (pass != 0) {
            str_builder_add_cstr(sb, ",password=");
            str_builder_add_str(sb, pass);
        }
    } else {
        str_builder_add_cstr(sb, "guest");
    }

    var port = ns_port(share);
    if (port != 0) {
        if (port != 445) {
            str_builder_add_cstr(sb, ",port=");
            str_builder_add_int(sb, port);
        }
    }

    return str_builder_build(sb);
}

fn _build_nfs_options(share): i64 {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "nolock");

    var port = ns_port(share);
    if (port != 0) {
        if (port != 2049) {
            str_builder_add_cstr(sb, ",port=");
            str_builder_add_int(sb, port);
        }
    }

    return str_builder_build(sb);
}

# ---------------------------------------------------------------------------
# Mount a network share
# ---------------------------------------------------------------------------

pub fn network_mount(share, mount_point_cstr) {
    sakshi_span_enter("net_mount", 9);

    var source = network_mount_source(share);
    var source_cstr = str_cstr(source);
    var fs_type = ns_fs_type(share);
    var kernel_type = net_fs_to_kernel_type(fs_type);

    # Validate mount point
    var val_r = validate_mount_point(mount_point_cstr);
    if (is_ok(val_r) == 0) {
        sakshi_span_exit();
        return val_r;
    }

    # Create mount point directory
    sys_mkdir(mount_point_cstr, 493);

    # Build options
    var options = 0;
    if (fs_type == NET_FS_SMB) {
        options = _build_smb_options(share);
    } else {
        options = _build_nfs_options(share);
    }
    var options_cstr = str_cstr(options);

    # Mount syscall: mount(source, target, fstype, flags, data)
    # MS_NOSUID=2 | MS_NODEV=4 = 6
    var flags = 6;
    var r = sys_mount(source_cstr, mount_point_cstr, kernel_type, flags, options_cstr);

    if (r < 0) {
        var errno = 0 - r;
        sakshi_span_exit();
        return map_errno_to_err(errno, "network mount", source);
    }

    sakshi_span_exit();

    # Build a DeviceInfo for the network mount
    var id = device_id_new(source);
    var info = device_info_new(id, source, DC_NETWORK);
    di_set_state(info, DS_MOUNTED);
    di_set_mount_point(info, str_from(mount_point_cstr));
    if (fs_type == NET_FS_SMB) {
        di_set_fs_type(info, str_from("cifs"));
    } elif (fs_type == NET_FS_NFS4) {
        di_set_fs_type(info, str_from("nfs4"));
    } else {
        di_set_fs_type(info, str_from("nfs"));
    }

    var mr = mount_result_new(id, source, str_from(mount_point_cstr),
    filesystem_from_str(kernel_type), 0);
    return Ok(mr);
}

# ---------------------------------------------------------------------------
# Unmount a network share (delegates to storage_unmount)
# ---------------------------------------------------------------------------

pub fn network_unmount(mount_point_cstr) {
    return storage_unmount(mount_point_cstr);
}

# ---------------------------------------------------------------------------
# Detect mounted network shares from /proc/mounts
# Returns vec of NetworkShare structs for currently mounted shares
# ---------------------------------------------------------------------------

pub fn network_list_mounted() {
    var readbuf[8192];
    var nbytes = file_read_all("/proc/mounts", &readbuf, 8192);
    if (nbytes <= 0) { return vec_new(); }

    var table = str_from_buf(&readbuf, nbytes);
    var lines = str_split(table, 10);
    var shares = vec_new();
    var nlines = vec_len(lines);

    for (var i = 0; i < nlines; i = i + 1) {
        var line = str_trim(vec_get(lines, i));
        if (str_len(line) == 0) { continue; }

        var fields = str_split(line, 32);
        if (vec_len(fields) < 3) { continue; }

        var device = vec_get(fields, 0);
        var mountpoint = vec_get(fields, 1);
        var fstype = vec_get(fields, 2);

        # Check for network filesystem types
        var fs = 0 - 1;
        if (str_eq_cstr(fstype, "cifs")) { fs = NET_FS_SMB; }
        elif (str_eq_cstr(fstype, "nfs")) { fs = NET_FS_NFS; }
        elif (str_eq_cstr(fstype, "nfs4")) { fs = NET_FS_NFS4; }

        if (fs >= 0) {
            # Parse source: //host/path (SMB) or host:/path (NFS)
            var host = str_from("");
            var path = str_from("");

            if (fs == NET_FS_SMB) {
                # //host/share → strip //, split on first /
                if (str_starts_with(device, "//")) {
                    var rest = str_substr(device, 2, str_len(device));
                    var slash = str_index_of(rest, 47);
                    if (slash >= 0) {
                        host = str_substr(rest, 0, slash);
                        path = str_substr(rest, slash, str_len(rest));
                    } else {
                        host = rest;
                    }
                }
            } else {
                # host:/path → split on :
                var colon = str_index_of(device, 58);
                if (colon >= 0) {
                    host = str_substr(device, 0, colon);
                    path = str_substr(device, colon + 1, str_len(device));
                }
            }

            var share = network_share_new(host, path, fs);
            vec_push(shares, share);
        }
    }

    return shares;
}

# ---------------------------------------------------------------------------
# Probe if a host is reachable on a given port (simple TCP connect test)
# Returns 1 if reachable, 0 if not. Timeout ~2 seconds.
# ---------------------------------------------------------------------------

pub fn network_probe_host(host_cstr, port) {
    # Create TCP socket
    var fd = syscall(SYS_SOCKET, 2, 1, 0);
    if (fd < 0) { return 0; }

    # Build sockaddr_in
    var addr[16];
    store16(&addr, 2);

    # Port in network byte order (big-endian)
    store8(&addr + 2, (port >> 8) & 0xFF);
    store8(&addr + 3, port & 0xFF);

    # Parse IP from dotted notation (simple — 4 octets)
    var ip = 0;
    var octet = 0;
    var shift = 0;
    var hi = 0;
    while (load8(host_cstr + hi) != 0) {
        var c = load8(host_cstr + hi);
        if (c == 46) {
            ip = ip | (octet << shift);
            shift = shift + 8;
            octet = 0;
        } else {
            if (c >= 48) { if (c <= 57) { octet = octet * 10 + (c - 48); } }
        }
        hi = hi + 1;
    }
    ip = ip | (octet << shift);
    store32(&addr + 4, ip);

    # Non-blocking connect would be better, but simple blocking test works
    var r = syscall(SYS_CONNECT, fd, &addr, 16);
    sys_close(fd);

    if (r == 0) { return 1; }
    return 0;
}

# ---------------------------------------------------------------------------
# Probe common network share ports
# ---------------------------------------------------------------------------

pub fn network_probe_smb(host_cstr) {
    return network_probe_host(host_cstr, 445);
}

pub fn network_probe_nfs(host_cstr) {
    return network_probe_host(host_cstr, 2049);
}

# --- gpu.cyr ---

# yukti/gpu.cyr — GPU device discovery via sysfs
#
# Enumerates GPU devices from /sys/class/drm/ and provides
# vendor/device/driver identification for GPU capability detection.
#
# GpuInfo struct layout (64 bytes):
#   +0:  card_name   (Str — e.g. "card0")
#   +8:  dev_path    (Str — e.g. "/dev/dri/card0")
#   +16: sys_path    (Str — e.g. "/sys/class/drm/card0")
#   +24: vendor_id   (i64 — PCI vendor, e.g. 0x1002 = AMD)
#   +32: device_id   (i64 — PCI device ID)
#   +40: driver      (Str — e.g. "amdgpu", "i915", "nvidia")
#   +48: pci_slot    (Str — e.g. "0000:04:00.0")
#   +56: render_node (Str — e.g. "/dev/dri/renderD128", 0 if none)

# ---------------------------------------------------------------------------
# Known GPU vendor IDs
# ---------------------------------------------------------------------------

enum GpuVendor {
    GPU_VENDOR_AMD    = 0x1002;
    GPU_VENDOR_INTEL  = 0x8086;
    GPU_VENDOR_NVIDIA = 0x10DE;
    GPU_VENDOR_VIRTIO = 0x1AF4;
}

# gpu_vendor_name(vendor_id) → human-readable vendor name
pub fn gpu_vendor_name(vid) {
    if (vid == GPU_VENDOR_AMD)    { return "AMD"; }
    if (vid == GPU_VENDOR_INTEL)  { return "Intel"; }
    if (vid == GPU_VENDOR_NVIDIA) { return "NVIDIA"; }
    if (vid == GPU_VENDOR_VIRTIO) { return "VirtIO"; }
    return "Unknown";
}

# ---------------------------------------------------------------------------
# GpuInfo accessors
# ---------------------------------------------------------------------------

pub fn gpu_info_card_name(g)   { return load64(g); }
pub fn gpu_info_dev_path(g)    { return load64(g + 8); }
pub fn gpu_info_sys_path(g)    { return load64(g + 16); }
pub fn gpu_info_vendor_id(g)   { return load64(g + 24); }
pub fn gpu_info_device_id(g)   { return load64(g + 32); }
pub fn gpu_info_driver(g)      { return load64(g + 40); }
pub fn gpu_info_pci_slot(g)    { return load64(g + 48); }
pub fn gpu_info_render_node(g) { return load64(g + 56); }

# ---------------------------------------------------------------------------
# Parse hex value from sysfs file content (e.g. "0x1002\n" → 0x1002)
# ---------------------------------------------------------------------------

fn _parse_hex_attr(s): i64 {
    if (s == 0) { return 0; }
    var cstr = str_cstr(s);
    var i = 0;
    # Skip "0x" prefix if present
    if (load8(cstr) == 0x30) {
        if (load8(cstr + 1) == 0x78) { i = 2; }
        elif (load8(cstr + 1) == 0x58) { i = 2; }
    }
    var val = 0;
    var c = load8(cstr + i);
    while (c != 0) {
        if (c == 10) { c = 0; }
        elif (c == 13) { c = 0; }
        elif (c >= 0x30) {
            if (c <= 0x39) {
                val = val * 16 + (c - 0x30);
            }
            elif (c >= 0x61) {
                if (c <= 0x66) { val = val * 16 + (c - 0x61 + 10); }
            }
            elif (c >= 0x41) {
                if (c <= 0x46) { val = val * 16 + (c - 0x41 + 10); }
            }
        }
        if (c != 0) { i = i + 1; c = load8(cstr + i); }
    }
    return val;
}

# ---------------------------------------------------------------------------
# Parse uevent key=value for a specific key
# ---------------------------------------------------------------------------

fn _parse_uevent_key(uevent_str, key_cstr): i64 {
    if (uevent_str == 0) { return 0; }
    var text = str_cstr(uevent_str);
    var text_len = str_len(uevent_str);
    var key_len = strlen(key_cstr);
    # Walk each line. Pre-2.1.4 the inner line-end loop set
    # `line_end = text_len` as a "break" sentinel and the post-loop
    # fixup never fired (line_end == text_len, not >), so line_end
    # ended up past the newline and `vlen = line_end - vstart`
    # captured the entire remaining buffer rather than just the
    # value. gpu_info_driver / gpu_info_pci_slot consumers got the
    # whole uevent stream from DRIVER= onward — silently broken.
    # Fixed loop uses a done flag and stops AT the newline.
    var i = 0;
    while (i < text_len) {
        # Find end of current line
        var line_end = i;
        var le_done = 0;
        while (le_done == 0) {
            if (line_end >= text_len) { le_done = 1; }
            elif (load8(text + line_end) == 10) { le_done = 1; }
            else { line_end = line_end + 1; }
        }
        var line_len = line_end - i;
        # Check if line starts with key=
        if (line_len > key_len) {
            var eq = 1;
            for (var k = 0; k < key_len; k = k + 1) {
                if (load8(text + i + k) != load8(key_cstr + k)) { eq = 0; }
            }
            if (eq == 1) {
                if (load8(text + i + key_len) == 0x3D) {
                    var vstart = i + key_len + 1;
                    var vlen = line_end - vstart;
                    if (vlen > 0) {
                        return str_from_buf(text + vstart, vlen);
                    }
                }
            }
        }
        # Advance past newline
        i = line_end;
        if (i < text_len) { i = i + 1; }
    }
    return 0;
}

# ---------------------------------------------------------------------------
# enumerate_gpus — discover GPU devices from /sys/class/drm/
# ---------------------------------------------------------------------------
# Returns a vec of GpuInfo pointers.
# Only includes primary card devices (card0, card1, ...), not outputs or render nodes.

pub fn enumerate_gpus() {
    return enumerate_gpus_sysfs(str_from("/sys"));
}

pub fn enumerate_gpus_sysfs(sysfs_root) {
    var results = vec_new();

    var sb = str_builder_new();
    str_builder_add_str(sb, sysfs_root);
    str_builder_add_cstr(sb, "/class/drm");
    var drm_dir = str_builder_build(sb);

    var entries = dir_list(drm_dir);
    if (entries == 0) { return results; }

    var count = vec_len(entries);
    for (var i = 0; i < count; i = i + 1) {
        var name = vec_get(entries, i);  # Str from dir_list

        # Only match "card[0-9]" (skip card0-DP-1, renderD128, version)
        var name_cstr = str_cstr(name);
        if (load8(name_cstr) != 0x63) { continue; }     # 'c'
        if (load8(name_cstr + 1) != 0x61) { continue; }  # 'a'
        if (load8(name_cstr + 2) != 0x72) { continue; }  # 'r'
        if (load8(name_cstr + 3) != 0x64) { continue; }  # 'd'
        var digit = load8(name_cstr + 4);
        if (digit < 0x30) { continue; }
        if (digit > 0x39) { continue; }
        # Ensure no more chars after digit(s) — reject "card0-DP-1"
        var j = 5;
        var valid = 1;
        while (load8(name_cstr + j) != 0) {
            var ch = load8(name_cstr + j);
            if (ch < 0x30) { valid = 0; j = 100; }
            elif (ch > 0x39) { valid = 0; j = 100; }
            j = j + 1;
        }
        if (valid == 0) { continue; }

        # Build paths
        sb = str_builder_new();
        str_builder_add_str(sb, drm_dir);
        str_builder_add_cstr(sb, "/");
        str_builder_add_str(sb, name);
        var sys_path = str_builder_build(sb);

        sb = str_builder_new();
        str_builder_add_cstr(sb, "/dev/dri/");
        str_builder_add_str(sb, name);
        var dev_path = str_builder_build(sb);

        # Read sysfs attributes
        var vendor_str = _read_sysfs_attr(sys_path, "device/vendor");
        var device_str = _read_sysfs_attr(sys_path, "device/device");
        var vendor_id = _parse_hex_attr(vendor_str);
        var device_id = _parse_hex_attr(device_str);

        # Read uevent for driver and PCI slot
        var uevent = _read_sysfs_attr(sys_path, "device/uevent");
        var driver = 0;
        var pci_slot = 0;
        if (uevent != 0) {
            driver = _parse_uevent_key(uevent, "DRIVER");
            pci_slot = _parse_uevent_key(uevent, "PCI_SLOT_NAME");
        }

        # Find matching render node (renderD128 for card0, renderD129 for card1, etc.)
        var card_num = digit - 0x30;
        var render_num = 128 + card_num;
        var rnbuf[24];
        var rnlen = fmt_int_buf(render_num, &rnbuf);
        store8(&rnbuf + rnlen, 0);  # null-terminate
        sb = str_builder_new();
        str_builder_add_cstr(sb, "/dev/dri/renderD");
        str_builder_add_cstr(sb, &rnbuf);
        var render_node = str_builder_build(sb);

        # Build GpuInfo
        var g = alloc(64);
        store64(g, name);
        store64(g + 8, dev_path);
        store64(g + 16, sys_path);
        store64(g + 24, vendor_id);
        store64(g + 32, device_id);
        store64(g + 40, driver);
        store64(g + 48, pci_slot);
        store64(g + 56, render_node);

        vec_push(results, g);
    }
    return results;
}

# ---------------------------------------------------------------------------
# gpu_count — quick check for how many GPUs are available
# ---------------------------------------------------------------------------

pub fn gpu_count() {
    var gpus = enumerate_gpus();
    return vec_len(gpus);
}

# ---------------------------------------------------------------------------
# gpu_info_report — format a GpuInfo as a human-readable string
# ---------------------------------------------------------------------------

pub fn gpu_info_report(g) {
    var sb = str_builder_new();
    var vid = gpu_info_vendor_id(g);
    str_builder_add_cstr(sb, gpu_vendor_name(vid));
    var driver = gpu_info_driver(g);
    if (driver != 0) {
        str_builder_add_cstr(sb, " (");
        str_builder_add_str(sb, driver);
        str_builder_add_cstr(sb, ")");
    }
    str_builder_add_cstr(sb, " @ ");
    var slot = gpu_info_pci_slot(g);
    if (slot != 0) {
        str_builder_add_str(sb, slot);
    } else {
        str_builder_add_str(sb, gpu_info_card_name(g));
    }
    return str_builder_build(sb);
}

# --- audio.cyr ---

# yukti/audio.cyr — Audio device discovery via /dev/snd/ + /proc/asound/
#
# Enumerates ALSA PCM devices (playback + capture) with stable
# identifiers across hotplug. Surfaces the descriptor shape that
# vani's `vani_open_yukti(desc, direction)` consumes — vani
# 0.3.x's typed-yukti-adapter (#8) and multi-device routing (#9)
# block on this landing.
#
# Domain split: yukti reports presence + identity only. Capability
# queries (rate / format / channel range) live on the vani side
# via `SNDRV_PCM_IOCTL_HW_REFINE` — we tell consumers *what* devices
# exist; vani opens the kernel handle and asks the kernel *how*.
#
# AudioDeviceInfo struct layout (72 bytes):
#   +0:  card        (i64 — ALSA card number, 0..99)
#   +8:  device      (i64 — ALSA device number on that card, 0..99)
#  +16:  subdevice   (i64 — ALSA subdevice; 0 for the common case)
#  +24:  direction   (i64 — YUKTI_AUDIO_PLAYBACK = 0 / _CAPTURE = 1;
#                     matches vani's VaniDirection 1:1 so the adapter
#                     is a copy, not a translation)
#  +32:  name        (Str — friendly name from
#                     /proc/asound/card{N}/pcm{D}{p|c}/info)
#  +40:  driver      (Str — kernel driver from /proc/asound/cards
#                     line 1 — e.g. "HDA-Intel", "USB-Audio")
#  +48:  hw_id       (Str — stable identifier across hotplug)
#  +56:  dev_path    (Str — /dev/snd/pcmC{N}D{M}{p|c})
#  +64:  sys_path    (Str — /sys/class/sound/card{N})
#
# `hw_id` construction (anchors NEVER on the ALSA card index, since
# adding a PCIe sound card reorders cards and breaks device_db
# history):
#   - PCI device (built-in HDA, discrete sound card, GPU HDMI):
#       PCI BDF from card{N}/device/uevent's PCI_SLOT_NAME — e.g.
#       "pci:0000:04:00.1:dev0:p". Stable across reboots and ALSA
#       reorderings.
#   - USB device (USB DAC, USB headset):
#       "usb:VID:PID:SERIAL:dev{M}:{p|c}" using idVendor / idProduct
#       / serial files in card{N}/device/. Falls back to the
#       PRODUCT= uevent triple when serial is missing.
#   - Anything else (loopback, bluetooth, virtual):
#       "card{N}_dev{M}_{p|c}" — last-resort fallback. Not stable
#       across reboots; consumers that care should treat this as
#       a transient identity.

# ---------------------------------------------------------------------------
# Direction constants
#
# Bit-for-bit identical to vani's VaniDirection so a yukti
# AudioDeviceInfo*'s direction can be passed straight into
# vani_open_yukti(desc, direction) without a translation table.
# ---------------------------------------------------------------------------

enum AudioDirection {
    YUKTI_AUDIO_PLAYBACK = 0;
    YUKTI_AUDIO_CAPTURE = 1;
}

# ---------------------------------------------------------------------------
# AudioDeviceInfo offset constants
# ---------------------------------------------------------------------------

enum AudioInfoOff {
    AI_CARD = 0;
    AI_DEVICE = 8;
    AI_SUBDEVICE = 16;
    AI_DIRECTION = 24;
    AI_NAME = 32;
    AI_DRIVER = 40;
    AI_HW_ID = 48;
    AI_DEV_PATH = 56;
    AI_SYS_PATH = 64;
    AI_SIZE = 72;
}

# ---------------------------------------------------------------------------
# Vani descriptor adapter API — typed accessors
#
# Stable shape. vani 0.3.x's vani_open_yukti(desc, direction) routes
# descriptors to audio_open_playback / audio_open_capture against
# this surface.
# ---------------------------------------------------------------------------

pub fn yukti_audio_card(d)        { return load64(d + AI_CARD); }
pub fn yukti_audio_device(d)      { return load64(d + AI_DEVICE); }
pub fn yukti_audio_subdevice(d)   { return load64(d + AI_SUBDEVICE); }
pub fn yukti_audio_direction(d)   { return load64(d + AI_DIRECTION); }
pub fn yukti_audio_name(d)        { return load64(d + AI_NAME); }
pub fn yukti_audio_driver(d)      { return load64(d + AI_DRIVER); }
pub fn yukti_audio_hw_id(d)       { return load64(d + AI_HW_ID); }
pub fn yukti_audio_dev_path(d)    { return load64(d + AI_DEV_PATH); }
pub fn yukti_audio_sys_path(d)    { return load64(d + AI_SYS_PATH); }

# ---------------------------------------------------------------------------
# Constructor
# ---------------------------------------------------------------------------

fn _audio_info_new(card, device, subdevice, direction, name, driver,
hw_id, dev_path, sys_path): i64 {
    var d = alloc(AI_SIZE);
    store64(d + AI_CARD, card);
    store64(d + AI_DEVICE, device);
    store64(d + AI_SUBDEVICE, subdevice);
    store64(d + AI_DIRECTION, direction);
    store64(d + AI_NAME, name);
    store64(d + AI_DRIVER, driver);
    store64(d + AI_HW_ID, hw_id);
    store64(d + AI_DEV_PATH, dev_path);
    store64(d + AI_SYS_PATH, sys_path);
    return d;
}

# ---------------------------------------------------------------------------
# Filename parser: pcmC{N}D{M}{p|c} → (card, device, direction)
#
# Returns: encoded i64 — bits [0..7] direction, [8..15] device,
# [16..23] card, or -1 on parse failure. The bit-pack avoids vec
# allocation in the hot enumeration loop; callers unpack inline.
# ---------------------------------------------------------------------------

fn _audio_parse_pcm_name(name_cstr): i64 {
    # Must start with "pcmC"
    if (load8(name_cstr) != 0x70) { return 0 - 1; }       # 'p'
    if (load8(name_cstr + 1) != 0x63) { return 0 - 1; }   # 'c'
    if (load8(name_cstr + 2) != 0x6D) { return 0 - 1; }   # 'm'
    if (load8(name_cstr + 3) != 0x43) { return 0 - 1; }   # 'C'

    # Card number: digits at offset 4.. (CLAUDE.md: avoid `break` in
    # var-heavy loops; use a done flag).
    var i = 4;
    var card = 0;
    var card_digits = 0;
    var done = 0;
    while (done == 0) {
        var c = load8(name_cstr + i);
        if (c >= 0x30) {
            if (c <= 0x39) {
                card = card * 10 + (c - 0x30);
                card_digits = card_digits + 1;
                i = i + 1;
            } else { done = 1; }
        } else { done = 1; }
        if (card_digits >= 3) { done = 1; }
    }
    if (card_digits == 0) { return 0 - 1; }

    # Must be 'D'
    if (load8(name_cstr + i) != 0x44) { return 0 - 1; }   # 'D'
    i = i + 1;

    # Device number: digits
    var device = 0;
    var dev_digits = 0;
    done = 0;
    while (done == 0) {
        var c = load8(name_cstr + i);
        if (c >= 0x30) {
            if (c <= 0x39) {
                device = device * 10 + (c - 0x30);
                dev_digits = dev_digits + 1;
                i = i + 1;
            } else { done = 1; }
        } else { done = 1; }
        if (dev_digits >= 3) { done = 1; }
    }
    if (dev_digits == 0) { return 0 - 1; }

    # Direction: 'p' or 'c'
    var dir_byte = load8(name_cstr + i);
    var direction = 0;
    if (dir_byte == 0x70) { direction = 0; }              # 'p' = playback
    elif (dir_byte == 0x63) { direction = 1; }            # 'c' = capture
    else { return 0 - 1; }

    # Trailing must be NUL
    if (load8(name_cstr + i + 1) != 0) { return 0 - 1; }

    return (card * 65536) + (device * 256) + direction;
}

# Bit-unpack helpers for _audio_parse_pcm_name's return value.
fn _audio_parsed_card(packed): i64 { return (packed / 65536) % 256; }
fn _audio_parsed_device(packed): i64 { return (packed / 256) % 256; }
fn _audio_parsed_direction(packed): i64 { return packed % 256; }

# ---------------------------------------------------------------------------
# Driver lookup from /proc/asound/cards
#
# Format (per card, 2 lines):
#   N [SHORTNAME      ]: DRIVER - LONGNAME
#                        LOCATION_OR_INFO
#
# Returns a vec where index = card number, value = Str of the driver
# name (e.g. "HDA-Intel"). Indices for missing cards have value 0.
# ---------------------------------------------------------------------------

fn _audio_load_drivers(): i64 {
    var drivers = vec_new();
    var buf = alloc(8192);
    var fd = sys_open("/proc/asound/cards", 0, 0);
    if (fd < 0) { return drivers; }
    var n = sys_read(fd, buf, 8192);
    sys_close(fd);
    if (n <= 0) { return drivers; }

    # Parse line by line — expect even-numbered lines to start with
    # " N [...]: DRIVER - ..." where N is the card index. Odd-numbered
    # lines are continuation (location info) and ignored here.
    var content = str_from_buf(buf, n);
    var lines = str_split(content, 10);
    var nlines = vec_len(lines);
    for (var li = 0; li < nlines; li = li + 1) {
        var line = vec_get(lines, li);
        var llen = str_len(line);
        if (llen < 5) { continue; }
        var ld = str_data(line);

        # Skip leading spaces (use done-flag to keep position accurate)
        var p = 0;
        var skip_done = 0;
        while (skip_done == 0) {
            if (p >= llen) { skip_done = 1; }
            elif (load8(ld + p) != 0x20) { skip_done = 1; }
            else { p = p + 1; }
        }
        if (p >= llen) { continue; }

        # Card index — leading digits
        var idx = 0;
        var idx_digits = 0;
        var idx_done = 0;
        while (idx_done == 0) {
            if (p >= llen) { idx_done = 1; }
            else {
                var ch = load8(ld + p);
                if (ch >= 0x30) {
                    if (ch <= 0x39) {
                        idx = idx * 10 + (ch - 0x30);
                        idx_digits = idx_digits + 1;
                        p = p + 1;
                    } else { idx_done = 1; }
                } else { idx_done = 1; }
            }
        }
        if (idx_digits == 0) { continue; }

        # Find ']: ' — driver starts after that
        var rb = str_index_of_cstr(line, "]: ");
        if (rb < 0) { continue; }
        var dstart = rb + 3;
        # Driver ends at ' - '
        var dash = _audio_str_index_from(line, " - ", dstart);
        if (dash < 0) { dash = llen; }
        var driver = str_substr(line, dstart, dash);

        # Pad drivers vec to idx with 0 entries
        while (vec_len(drivers) <= idx) { vec_push(drivers, 0); }
        # Replace at idx by rebuilding (vec has no set-by-index)
        var rebuilt = vec_new();
        for (var i = 0; i < vec_len(drivers); i = i + 1) {
            if (i == idx) { vec_push(rebuilt, driver); }
            else { vec_push(rebuilt, vec_get(drivers, i)); }
        }
        drivers = rebuilt;
    }
    return drivers;
}

# Helper: find substring in a Str starting from `start`.
# Stdlib provides `str_index_of_cstr(s, needle)` (lib/str.cyr:358) but
# not a from-offset variant — define one privately here.
fn _audio_str_index_from(s, needle_cstr, start): i64 {
    var slen = str_len(s);
    var nlen = strlen(needle_cstr);
    if (nlen > slen - start) { return 0 - 1; }
    var sd = str_data(s);
    for (var i = start; i <= slen - nlen; i = i + 1) {
        var hit = 1;
        for (var j = 0; j < nlen; j = j + 1) {
            if (load8(sd + i + j) != load8(needle_cstr + j)) { hit = 0; }
        }
        if (hit == 1) { return i; }
    }
    return 0 - 1;
}

# ---------------------------------------------------------------------------
# Friendly name lookup from /proc/asound/card{N}/pcm{D}{p|c}/info
#
# Returns the value of the `name:` line as a Str, or 0 if the file
# can't be read.
# ---------------------------------------------------------------------------

fn _audio_read_pcm_name(card, device, direction): i64 {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "/proc/asound/card");
    str_builder_add_int(sb, card);
    str_builder_add_cstr(sb, "/pcm");
    str_builder_add_int(sb, device);
    if (direction == 0) { str_builder_add_cstr(sb, "p"); }
    else { str_builder_add_cstr(sb, "c"); }
    str_builder_add_cstr(sb, "/info");
    var path = str_builder_build(sb);

    var buf = alloc(2048);
    var fd = sys_open(str_cstr(path), 0, 0);
    if (fd < 0) { return 0; }
    var n = sys_read(fd, buf, 2048);
    sys_close(fd);
    if (n <= 0) { return 0; }

    # Walk lines — find one starting "name: "
    var content = str_from_buf(buf, n);
    var lines = str_split(content, 10);
    var nlines = vec_len(lines);
    for (var i = 0; i < nlines; i = i + 1) {
        var line = vec_get(lines, i);
        if (str_starts_with_cstr(line, "name: ") == 0) { continue; }
        return str_substr(line, 6, str_len(line));
    }
    return 0;
}

# Helper: test if Str starts with cstr.
fn str_starts_with_cstr(s, prefix_cstr): i64 {
    var nlen = strlen(prefix_cstr);
    if (nlen > str_len(s)) { return 0; }
    var sd = str_data(s);
    for (var i = 0; i < nlen; i = i + 1) {
        if (load8(sd + i) != load8(prefix_cstr + i)) { return 0; }
    }
    return 1;
}

# ---------------------------------------------------------------------------
# hw_id construction
#
# Reads /sys/class/sound/card{N}/device/uevent + a few sibling files
# to produce a stable identifier. See module header for the strategy.
# ---------------------------------------------------------------------------

fn _audio_compute_hw_id(card, device, direction): i64 {
    # Build sys_path
    var sysb = str_builder_new();
    str_builder_add_cstr(sysb, "/sys/class/sound/card");
    str_builder_add_int(sysb, card);
    str_builder_add_cstr(sysb, "/device");
    var device_dir = str_builder_build(sysb);

    # Read uevent
    var uevent = _read_sysfs_attr(device_dir, "uevent");
    var dir_suffix = "p";
    if (direction == 1) { dir_suffix = "c"; }

    if (uevent != 0) {
        # PCI: PCI_SLOT_NAME=BBBB:bb:dd.f
        var pci_slot = _parse_uevent_key(uevent, "PCI_SLOT_NAME");
        if (pci_slot != 0) {
            var sb = str_builder_new();
            str_builder_add_cstr(sb, "pci:");
            str_builder_add_str(sb, pci_slot);
            str_builder_add_cstr(sb, ":dev");
            str_builder_add_int(sb, device);
            str_builder_add_cstr(sb, ":");
            str_builder_add_cstr(sb, dir_suffix);
            return str_builder_build(sb);
        }

        # USB: PRODUCT=VID/PID/BCD (typical encoding from kernel uevent)
        var product = _parse_uevent_key(uevent, "PRODUCT");
        if (product != 0) {
            # Optional serial
            var serial = _read_sysfs_attr(device_dir, "../serial");
            var sb = str_builder_new();
            str_builder_add_cstr(sb, "usb:");
            str_builder_add_str(sb, product);
            if (serial != 0) {
                str_builder_add_cstr(sb, ":");
                str_builder_add_str(sb, serial);
            }
            str_builder_add_cstr(sb, ":dev");
            str_builder_add_int(sb, device);
            str_builder_add_cstr(sb, ":");
            str_builder_add_cstr(sb, dir_suffix);
            return str_builder_build(sb);
        }
    }

    # Fallback: card-position-based — NOT stable across hotplug
    # reordering, but better than 0. Consumers reading device_db
    # against this hw_id should treat the entry as transient.
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "card");
    str_builder_add_int(sb, card);
    str_builder_add_cstr(sb, "_dev");
    str_builder_add_int(sb, device);
    str_builder_add_cstr(sb, "_");
    str_builder_add_cstr(sb, dir_suffix);
    return str_builder_build(sb);
}

# ---------------------------------------------------------------------------
# yukti_audio_devices — top-level enumerator
#
# Returns a vec of AudioDeviceInfo pointers. Each /dev/snd/pcmC*D*[pc]
# entry produces one descriptor. Order matches readdir order (caller
# should not rely on stability across kernel versions).
# ---------------------------------------------------------------------------

pub fn yukti_audio_devices() {
    var results = vec_new();

    var entries = dir_list(str_from("/dev/snd"));
    if (entries == 0) { return results; }

    var drivers = _audio_load_drivers();

    var count = vec_len(entries);
    for (var i = 0; i < count; i = i + 1) {
        var name_str = vec_get(entries, i);
        var name_cstr = str_cstr(name_str);

        var packed = _audio_parse_pcm_name(name_cstr);
        if (packed < 0) { continue; }

        var card = _audio_parsed_card(packed);
        var device = _audio_parsed_device(packed);
        var direction = _audio_parsed_direction(packed);

        # dev_path
        var dpb = str_builder_new();
        str_builder_add_cstr(dpb, "/dev/snd/");
        str_builder_add_str(dpb, name_str);
        var dev_path = str_builder_build(dpb);

        # sys_path
        var spb = str_builder_new();
        str_builder_add_cstr(spb, "/sys/class/sound/card");
        str_builder_add_int(spb, card);
        var sys_path = str_builder_build(spb);

        # Driver lookup
        var driver = 0;
        if (card < vec_len(drivers)) {
            driver = vec_get(drivers, card);
        }

        # Friendly name + hw_id
        var pretty_name = _audio_read_pcm_name(card, device, direction);
        var hw_id = _audio_compute_hw_id(card, device, direction);

        var info = _audio_info_new(card, device, 0, direction,
        pretty_name, driver, hw_id, dev_path, sys_path);
        vec_push(results, info);
    }

    return results;
}

# ---------------------------------------------------------------------------
# yukti_audio_devices_for_direction(dir) — filter to playback or capture
# ---------------------------------------------------------------------------

pub fn yukti_audio_devices_for_direction(direction) {
    var all = yukti_audio_devices();
    var filtered = vec_new();
    for (var i = 0; i < vec_len(all); i = i + 1) {
        var d = vec_get(all, i);
        if (yukti_audio_direction(d) == direction) { vec_push(filtered, d); }
    }
    return filtered;
}

# ---------------------------------------------------------------------------
# yukti_audio_devices_for_card(card) — filter by ALSA card index
# ---------------------------------------------------------------------------

pub fn yukti_audio_devices_for_card(card) {
    var all = yukti_audio_devices();
    var filtered = vec_new();
    for (var i = 0; i < vec_len(all); i = i + 1) {
        var d = vec_get(all, i);
        if (yukti_audio_card(d) == card) { vec_push(filtered, d); }
    }
    return filtered;
}

# ---------------------------------------------------------------------------
# yukti_audio_count() — convenience: total number of PCM endpoints
# ---------------------------------------------------------------------------

pub fn yukti_audio_count() {
    return vec_len(yukti_audio_devices());
}
