# --- csv.cyr ---

# csv.cyr — RFC 4180 CSV parser and writer
# Usage: include "lib/csv.cyr"
# Requires: alloc.cyr, string.cyr, vec.cyr, str.cyr

# Parse a CSV line into a vec of field strings (C strings).
# Handles quoted fields, escaped quotes (""), and commas within quotes.
fn bayan_csv_parse_line(line): i64 {
    var fields = vec_new();
    var len = strlen(line);
    var pos = 0;
    while (pos < len) {
        var field = alloc(1024);
        var fi = 0;
        if (pos < len) {
            if (load8(line + pos) == 34) {
                # Quoted field
                pos = pos + 1;
                var qgo = 1;
                while (qgo == 1) {
                    if (pos >= len) { qgo = 0; }
                    elif (load8(line + pos) == 34) {
                        if (pos + 1 < len) {
                            if (load8(line + pos + 1) == 34) {
                                # Escaped quote
                                store8(field + fi, 34); fi = fi + 1;
                                pos = pos + 2;
                            } else { pos = pos + 1; qgo = 0; }
                        } else { pos = pos + 1; qgo = 0; }
                    } else {
                        store8(field + fi, load8(line + pos));
                        fi = fi + 1; pos = pos + 1;
                    }
                }
                # Skip comma after closing quote
                if (pos < len) { if (load8(line + pos) == 44) { pos = pos + 1; } }
            } else {
                # Unquoted field — read until comma or end
                while (pos < len) {
                    var c = load8(line + pos);
                    if (c == 44) { pos = pos + 1; break; }
                    store8(field + fi, c);
                    fi = fi + 1; pos = pos + 1;
                }
            }
        }
        store8(field + fi, 0);
        vec_push(fields, field);
    }
    return fields;
}

# Escape a field for CSV output (quote if needed)
fn bayan_csv_escape(field): i64 {
    var len = strlen(field);
    var needs_quote = 0;
    var i = 0;
    while (i < len) {
        var c = load8(field + i);
        if (c == 44) { needs_quote = 1; }
        if (c == 34) { needs_quote = 1; }
        if (c == 10) { needs_quote = 1; }
        i = i + 1;
    }
    if (needs_quote == 0) { return field; }
    # Quote and escape internal quotes
    var out = alloc(len * 2 + 3);
    var oi = 0;
    store8(out + oi, 34); oi = oi + 1;
    i = 0;
    while (i < len) {
        var c = load8(field + i);
        if (c == 34) { store8(out + oi, 34); oi = oi + 1; }
        store8(out + oi, c); oi = oi + 1;
        i = i + 1;
    }
    store8(out + oi, 34); oi = oi + 1;
    store8(out + oi, 0);
    return out;
}

# Write a vec of fields as a CSV line (returns null-terminated string)
fn bayan_csv_write_line(fields): i64 {
    var buf = alloc(4096);
    var pos = 0;
    var i = 0;
    while (i < vec_len(fields)) {
        if (i > 0) { store8(buf + pos, 44); pos = pos + 1; }
        var escaped = bayan_csv_escape(vec_get(fields, i));
        var elen = strlen(escaped);
        memcpy(buf + pos, escaped, elen);
        pos = pos + elen;
        i = i + 1;
    }
    store8(buf + pos, 10); pos = pos + 1;
    store8(buf + pos, 0);
    return buf;
}

# --- u128.cyr ---

# lib/u128.cyr — 128-bit unsigned integer helpers
#
# A u128 is a 16-byte slot: low 8 bytes at ptr+0, high 8 bytes at ptr+8.
# Declared with `var x: u128 = 0;` (v4.8.0).
# These helpers cover construction, copy, part-access, equality,
# arithmetic, shifts, comparisons, and divmod.
#
# Convention: functions take pointers (returned by `&x`), never values,
# because the cyrius ABI currently passes / returns scalars in a single
# register.

# Set both limbs at `dst` to (lo, hi). Both args are u64 treated as
# unsigned.
fn bayan_u128_set(dst, lo, hi): i64 {
    store64(dst, lo);
    store64(dst + 8, hi);
    return 0;
}

# Zero-extend a u64 to a u128 at `dst`.
fn bayan_u128_from_u64(dst, lo): i64 {
    store64(dst, lo);
    store64(dst + 8, 0);
    return 0;
}

# Copy 16 bytes `src` → `dst`. Source and destination must not overlap.
fn bayan_u128_copy(dst, src): i64 {
    store64(dst, load64(src));
    store64(dst + 8, load64(src + 8));
    return 0;
}

# Low 64-bit limb of a u128 at `ptr`.
fn bayan_u128_lo(ptr): i64 { return load64(ptr); }
# High 64-bit limb of a u128 at `ptr`.
fn bayan_u128_hi(ptr): i64 { return load64(ptr + 8); }

# Equality — byte-identical both limbs.
#pure
fn bayan_u128_eq(a, b): i64 {
    if (load64(a) != load64(b)) { return 0; }
    if (load64(a + 8) != load64(b + 8)) { return 0; }
    return 1;
}

# Zero-test.
#pure
fn bayan_u128_is_zero(ptr): i64 {
    if (load64(ptr) != 0) { return 0; }
    if (load64(ptr + 8) != 0) { return 0; }
    return 1;
}

# -------- Arithmetic --------
#
# Carry / borrow detection without an unsigned primitive: split each
# 64-bit limb into two 32-bit halves, add/subtract in pieces (cyrius's
# i64 arith has more than enough headroom), propagate the carry bit
# from bit 32 of each partial result. Shifts here are on values whose
# high bit (63) is zero, so signed and logical `>>` coincide.

# dst = a + b  (u128 wraps at 2^128)
fn bayan_u128_add(dst, a, b): i64 {
    var a_lo = load64(a);
    var a_hi = load64(a + 8);
    var b_lo = load64(b);
    var b_hi = load64(b + 8);
    var a_lolo = a_lo & 0xFFFFFFFF;
    var a_lohi = (a_lo >> 32) & 0xFFFFFFFF;
    var b_lolo = b_lo & 0xFFFFFFFF;
    var b_lohi = (b_lo >> 32) & 0xFFFFFFFF;
    var s_lolo = a_lolo + b_lolo;
    var s_lohi = a_lohi + b_lohi + (s_lolo >> 32);
    var new_lo = (s_lolo & 0xFFFFFFFF) | ((s_lohi & 0xFFFFFFFF) << 32);
    var carry = s_lohi >> 32;
    var new_hi = a_hi + b_hi + carry;
    store64(dst, new_lo);
    store64(dst + 8, new_hi);
    return 0;
}

# dst = a - b  (u128 wraps at 2^128, so 0 - 1 = 2^128 - 1)
fn bayan_u128_sub(dst, a, b): i64 {
    var a_lo = load64(a);
    var a_hi = load64(a + 8);
    var b_lo = load64(b);
    var b_hi = load64(b + 8);
    var a_lolo = a_lo & 0xFFFFFFFF;
    var a_lohi = (a_lo >> 32) & 0xFFFFFFFF;
    var b_lolo = b_lo & 0xFFFFFFFF;
    var b_lohi = (b_lo >> 32) & 0xFFFFFFFF;
    var d_lolo = a_lolo - b_lolo;
    var borrow_lo = 0;
    if (d_lolo < 0) { d_lolo = d_lolo + 0x100000000; borrow_lo = 1; }
    var d_lohi = a_lohi - b_lohi - borrow_lo;
    var borrow_hi = 0;
    if (d_lohi < 0) { d_lohi = d_lohi + 0x100000000; borrow_hi = 1; }
    var new_lo = (d_lolo & 0xFFFFFFFF) | ((d_lohi & 0xFFFFFFFF) << 32);
    var new_hi = a_hi - b_hi - borrow_hi;
    store64(dst, new_lo);
    store64(dst + 8, new_hi);
    return 0;
}

# `dst += src` — wraps at 2^128.
fn bayan_u128_addeq(dst, src): i64 { return bayan_u128_add(dst, dst, src); }
# `dst -= src` — wraps at 2^128.
fn bayan_u128_subeq(dst, src): i64 { return bayan_u128_sub(dst, dst, src); }

# dst = a * b  (u128 wraps at 2^128)
#
# Standard schoolbook: a = a_lo + a_hi*2^64, b likewise.
# a * b (mod 2^128) = a_lo*b_lo  +  (a_hi*b_lo + a_lo*b_hi)*2^64
# (the a_hi*b_hi*2^128 term wraps to 0).
# Cross terms contribute to the HIGH limb only — we take their low 64
# bits via natural i64 wrap.
# For the full 128-bit product of a_lo*b_lo we split each 64-bit limb
# into two 32-bit halves and accumulate per 32-bit chunk with carry.
fn bayan_u128_mul(dst, a, b): i64 {
    var a_lo = load64(a);
    var a_hi = load64(a + 8);
    var b_lo = load64(b);
    var b_hi = load64(b + 8);

    var a_ll = a_lo & 0xFFFFFFFF;
    var a_lh = (a_lo >> 32) & 0xFFFFFFFF;
    var b_ll = b_lo & 0xFFFFFFFF;
    var b_lh = (b_lo >> 32) & 0xFFFFFFFF;

    # Four 32x32 partial products (each fits in 64 bits; masking with
    # 0xFFFFFFFF after `>> 32` discards any sign-extension bits).
    var p0 = a_ll * b_ll;
    var p1 = a_ll * b_lh;
    var p2 = a_lh * b_ll;
    var p3 = a_lh * b_lh;

    var chunk0 = p0 & 0xFFFFFFFF;
    var sum1 = ((p0 >> 32) & 0xFFFFFFFF) + (p1 & 0xFFFFFFFF) + (p2 & 0xFFFFFFFF);
    var chunk1 = sum1 & 0xFFFFFFFF;
    var carry1 = (sum1 >> 32) & 0xFFFFFFFF;

    var sum2 = ((p1 >> 32) & 0xFFFFFFFF) + ((p2 >> 32) & 0xFFFFFFFF) + (p3 & 0xFFFFFFFF) + carry1;
    var chunk2 = sum2 & 0xFFFFFFFF;
    var carry2 = (sum2 >> 32) & 0xFFFFFFFF;

    var chunk3 = (((p3 >> 32) & 0xFFFFFFFF) + carry2) & 0xFFFFFFFF;

    var new_lo = chunk0 | (chunk1 << 32);
    var lolo_hi = chunk2 | (chunk3 << 32);

    # Cross terms (low 64 bits of each — natural wrap).
    var mid = a_hi * b_lo + a_lo * b_hi;
    var new_hi = lolo_hi + mid;

    store64(dst, new_lo);
    store64(dst + 8, new_hi);
    return 0;
}

# `dst *= src` — wraps at 2^128.
fn bayan_u128_muleq(dst, src): i64 { return bayan_u128_mul(dst, dst, src); }

# -------- Shifts & bitwise --------
#
# Cyrius `>>` sign-extends (arithmetic). For unsigned semantics we
# strip the sign bit after a 1-bit shift, then finish the rest:
#   (x >> 1) & 0x7FFFFFFFFFFFFFFF   →   bit 63 now 0
#   >> (n-1)                         →   safe to arithmetic-shift
# Defined for 0 <= n < 64. Caller handles n == 0 (return x unchanged)
# and n >= 64 (whole-limb shift paths).
fn _u128_lshr64(x, n): i64 {
    if (n == 0) { return x; }
    return ((x >> 1) & 0x7FFFFFFFFFFFFFFF) >> (n - 1);
}

# dst = src << n  (u128 wraps at 2^128; n >= 128 yields 0)
fn bayan_u128_shl(dst, src, n): i64 {
    var lo = load64(src);
    var hi = load64(src + 8);
    if (n == 0) {
        store64(dst, lo);
        store64(dst + 8, hi);
        return 0;
    }
    if (n >= 128) {
        store64(dst, 0);
        store64(dst + 8, 0);
        return 0;
    }
    if (n >= 64) {
        store64(dst, 0);
        store64(dst + 8, lo << (n - 64));
        return 0;
    }
    # 0 < n < 64: spill top n bits of lo into bottom n bits of hi.
    var new_lo = lo << n;
    var spill = _u128_lshr64(lo, 64 - n);
    var new_hi = (hi << n) | spill;
    store64(dst, new_lo);
    store64(dst + 8, new_hi);
    return 0;
}

# dst = src >> n  (logical right — always fills with 0)
fn bayan_u128_shr(dst, src, n): i64 {
    var lo = load64(src);
    var hi = load64(src + 8);
    if (n == 0) {
        store64(dst, lo);
        store64(dst + 8, hi);
        return 0;
    }
    if (n >= 128) {
        store64(dst, 0);
        store64(dst + 8, 0);
        return 0;
    }
    if (n >= 64) {
        store64(dst, _u128_lshr64(hi, n - 64));
        store64(dst + 8, 0);
        return 0;
    }
    # 0 < n < 64: bottom n bits of hi spill into top n bits of lo.
    var new_lo = _u128_lshr64(lo, n) | (hi << (64 - n));
    var new_hi = _u128_lshr64(hi, n);
    store64(dst, new_lo);
    store64(dst + 8, new_hi);
    return 0;
}

# dst = a & b — per-limb bitwise AND.
fn bayan_u128_and(dst, a, b): i64 {
    store64(dst, load64(a) & load64(b));
    store64(dst + 8, load64(a + 8) & load64(b + 8));
    return 0;
}

# dst = a | b — per-limb bitwise OR.
fn bayan_u128_or(dst, a, b): i64 {
    store64(dst, load64(a) | load64(b));
    store64(dst + 8, load64(a + 8) | load64(b + 8));
    return 0;
}

# dst = a ^ b — per-limb bitwise XOR.
fn bayan_u128_xor(dst, a, b): i64 {
    store64(dst, load64(a) ^ load64(b));
    store64(dst + 8, load64(a + 8) ^ load64(b + 8));
    return 0;
}

# dst = ~src — per-limb bitwise NOT.
fn bayan_u128_not(dst, src): i64 {
    store64(dst, ~load64(src));
    store64(dst + 8, ~load64(src + 8));
    return 0;
}

# `dst <<= n`.
fn bayan_u128_shleq(dst, n): i64 { return bayan_u128_shl(dst, dst, n); }
# `dst >>= n` (logical right).
fn bayan_u128_shreq(dst, n): i64 { return bayan_u128_shr(dst, dst, n); }
# `dst &= src`.
fn bayan_u128_andeq(dst, src): i64 { return bayan_u128_and(dst, dst, src); }
# `dst |= src`.
fn bayan_u128_oreq(dst, src): i64 { return bayan_u128_or(dst, dst, src); }
# `dst ^= src`.
fn bayan_u128_xoreq(dst, src): i64 { return bayan_u128_xor(dst, dst, src); }

# -------- Unsigned comparisons + divmod --------
#
# Cyrius native `<` / `>` / `>=` are signed. For u64 pieces we need
# an unsigned interpretation (bit 63 is a real value bit, not a
# sign flag).

# Unsigned a > b on 64-bit limbs.
fn _u64_ugt(a, b): i64 {
    if (a >= 0) {
        if (b >= 0) { if (a > b) { return 1; } return 0; }
        return 0;           # a non-negative, b "negative" (bit 63 set) → b larger
    }
    if (b >= 0) { return 1; }   # a "negative" (huge unsigned), b non-negative
    if (a > b) { return 1; }     # both "negative" — signed order matches unsigned here
    return 0;
}

# Unsigned a >= b on 64-bit limbs.
fn _u64_uge(a, b): i64 {
    if (a == b) { return 1; }
    return _u64_ugt(a, b);
}

# u128 unsigned comparisons. `a` / `b` are pointers to u128 slots.
fn bayan_u128_ugt(a, b): i64 {
    var a_hi = load64(a + 8);
    var b_hi = load64(b + 8);
    if (a_hi != b_hi) { return _u64_ugt(a_hi, b_hi); }
    return _u64_ugt(load64(a), load64(b));
}

# Unsigned a >= b on u128 pointers.
fn bayan_u128_uge(a, b): i64 {
    var a_hi = load64(a + 8);
    var b_hi = load64(b + 8);
    if (a_hi != b_hi) { return _u64_ugt(a_hi, b_hi); }
    return _u64_uge(load64(a), load64(b));
}

# Unsigned a < b on u128 pointers.
fn bayan_u128_ult(a, b): i64 { return bayan_u128_ugt(b, a); }
# Unsigned a <= b on u128 pointers.
fn bayan_u128_ule(a, b): i64 { return bayan_u128_uge(b, a); }

# Unsigned two-limb subtract helper — writes (a - b) into (*out_lo,
# *out_hi) with natural mod-2^128 wrap. Shared between divmod and
# anything else that needs scalar-limb borrow propagation.
# (Kept local to the file; public callers use bayan_u128_sub.)

# (qdst, rdst) = (a / b, a % b)  — shift-subtract long division.
# On b == 0, writes "u128: division by zero" to stderr and exits 1.
# Algorithm:
#   q = 0, r = 0
#   for i in 127..0:
#       r = (r << 1) | bit_i(a)
#       if r >= b: r -= b; q |= (1 << i)
fn bayan_u128_divmod(qdst, rdst, a, b): i64 {
    if (bayan_u128_is_zero(b) == 1) {
        syscall(SYS_WRITE, 2, "u128: division by zero\n", 23);
        syscall(SYS_EXIT, 1);
    }
    var a_lo = load64(a);
    var a_hi = load64(a + 8);
    var b_lo = load64(b);
    var b_hi = load64(b + 8);
    # Hardware fast-path when the divisor fits in 64 bits
    # bits. Covers every `(u64 * u64) % u64` pipeline — Miller-Rabin,
    # Pollard rho, RSA, `random::shuffle`, hashing. The slow path
    # below burns 128 shift-subtract iterations even when the top
    # half of b is zero; this path takes two hardware `div`
    # instructions instead, trading O(128) on the critical path for
    # O(1). Abaco's ntheory::mod_mul gets ~40× on the hot loop.
    #
    # Two hardware `div` steps back-to-back, both inside one asm
    # block so both divisions run UNSIGNED (Cyrius's `/` operator
    # lowers to `idiv` — signed — which would mis-compute whenever
    # an operand has its top bit set, mulmod's common case):
    #   step 1:  rax = a_hi, rdx = 0
    #            div b_lo           ; rax = q_hi, rdx = r1
    #   step 2:  rax = a_lo, rdx = r1 (carried from step 1)
    #            div b_lo           ; rax = q_lo, rdx = r_final
    # When a_hi == 0, step 1 returns q_hi=0, r1=0 and step 2 falls
    # through to straight 64-bit a_lo/b_lo — so this same block
    # handles both a_hi==0 and a_hi!=0 correctly. r1 < b_lo by the
    # definition of the first remainder, so step 2 never trips #DE.
    if (b_hi == 0) {
        var q_hi_fast = 0;
        var q_lo_fast = 0;
        var r_final   = 0;
        # Local layout after this point (flat fn index order):
        #   qdst(0), rdst(1), a(2), b(3),
        #   a_lo(4), a_hi(5), b_lo(6), b_hi(7),
        #   q_hi_fast(8), q_lo_fast(9), r_final(10)
        # disp8 = -(idx+1)*8.
        asm {
            0x48; 0x8B; 0x45; 0xD0;   # mov rax, [rbp-48]   ; a_hi
            0x48; 0x31; 0xD2;         # xor rdx, rdx        ; zero-ext
            0x48; 0xF7; 0x75; 0xC8;   # div qword [rbp-56]  ; / b_lo
            0x48; 0x89; 0x45; 0xB8;   # mov [rbp-72], rax   ; q_hi_fast
            0x48; 0x8B; 0x45; 0xD8;   # mov rax, [rbp-40]   ; a_lo
            0x48; 0xF7; 0x75; 0xC8;   # div qword [rbp-56]  ; rdx:rax/b_lo
            0x48; 0x89; 0x45; 0xB0;   # mov [rbp-80], rax   ; q_lo_fast
            0x48; 0x89; 0x55; 0xA8;   # mov [rbp-88], rdx   ; r_final
        }
        store64(qdst,     q_lo_fast);
        store64(qdst + 8, q_hi_fast);
        store64(rdst,     r_final);
        store64(rdst + 8, 0);
        return 0;
    }
    var q_lo = 0;
    var q_hi = 0;
    var r_lo = 0;
    var r_hi = 0;
    var i = 127;
    while (i >= 0) {
        # r <<= 1 (128-bit) — top bit of r_lo spills into r_hi
        var spill = _u128_lshr64(r_lo, 63) & 1;
        r_hi = (r_hi << 1) | spill;
        r_lo = r_lo << 1;
        # Bring bit i of `a` into r's LSB.
        var bit = 0;
        if (i >= 64) { bit = _u128_lshr64(a_hi, i - 64) & 1; }
        else { bit = _u128_lshr64(a_lo, i) & 1; }
        r_lo = r_lo | bit;
        # Compare r >= b (unsigned 128-bit).
        var ge = 0;
        if (r_hi != b_hi) { ge = _u64_ugt(r_hi, b_hi); }
        else { ge = _u64_uge(r_lo, b_lo); }
        if (ge == 1) {
            # r -= b
            var borrow = 0;
            if (_u64_ugt(b_lo, r_lo) == 1) { borrow = 1; }
            r_lo = r_lo - b_lo;
            r_hi = r_hi - b_hi - borrow;
            # q |= (1 << i)
            if (i >= 64) { q_hi = q_hi | (1 << (i - 64)); }
            else { q_lo = q_lo | (1 << i); }
        }
        i = i - 1;
    }
    store64(qdst, q_lo);
    store64(qdst + 8, q_hi);
    store64(rdst, r_lo);
    store64(rdst + 8, r_hi);
    return 0;
}

# Convenience: quotient only / remainder only. Uses a module-level
# scratch u128 for the discarded half.
var _u128_discard: u128 = 0;

# dst = a / b (quotient only). Division by zero exits 1.
fn bayan_u128_div(dst, a, b): i64 {
    return bayan_u128_divmod(dst, &_u128_discard, a, b);
}
# dst = a % b (remainder only). Division by zero exits 1.
fn bayan_u128_mod(dst, a, b): i64 {
    return bayan_u128_divmod(&_u128_discard, dst, a, b);
}

# `dst /= src`.
fn bayan_u128_diveq(dst, src): i64 { return bayan_u128_div(dst, dst, src); }
# `dst %= src`.
fn bayan_u128_modeq(dst, src): i64 { return bayan_u128_mod(dst, dst, src); }

# ================================================================
# u64 MODULAR ARITHMETIC
# ================================================================
# Two ergonomic helpers built on top of the `bayan_u128_mul + bayan_u128_mod`
# pipeline, whose fast-path now uses hardware `div` when
# the modulus fits in 64 bits. Purpose is abaco's ntheory::mod_mul
# / mod_pow call shape — and every RSA / primality / cryptographic-
# hash consumer that used to hand-roll a double-and-add loop. The
# helpers keep the u128 machinery hidden from the caller.
#
# Preconditions (caller-enforced; no runtime checks):
#   bayan_u64_mulmod(a, b, m): m > 0. a and b may be >= m (they're
#     reduced internally via the mod), but for abaco's Miller-
#     Rabin style workloads a, b < m is the common case.
#   bayan_u64_powmod(base, exp, m): m > 0. On m == 1, returns 0 without
#     touching the fast path.
#
# `bayan_u64_mulmod` stack scratch: two u128 locals (product + modulus
# envelope). The abaco bench in benches/bench_mulmod.bcyr shows
# the concrete win versus a pure-Cyrius double-and-add reference.

# Return (a * b) mod m, all u64. Collapses to three hardware
# instructions: `mul b ; div m ; mov result, rdx` — no u128
# intermediate, no shift-subtract loop, no Cyrius-level function
# calls inside the hot path.
#
# Preconditions (caller-enforced; a violation trips #DE at the
# `div`):
#   - m > 0
#   - a < m AND b < m   (so the 128-bit product / m fits in u64)
# Miller-Rabin, Pollard rho, RSA, and every other modular-arith
# consumer naturally reduces its operands below the modulus, so
# this precondition is free in practice. Callers working with
# unreduced inputs should pre-reduce via `a % m` (Cyrius's `%`
# is signed, so only safe while m < 2^63) or fall back to the
# u128 pipeline.
fn bayan_u64_mulmod(a, b, m): i64 {
    var result = 0;
    # Locals: a(0)=[rbp-8], b(1)=[rbp-16], m(2)=[rbp-24],
    #         result(3)=[rbp-32].
    asm {
        0x48; 0x8B; 0x45; 0xF8;   # mov rax, [rbp-8]    ; a
        0x48; 0xF7; 0x65; 0xF0;   # mul qword [rbp-16]  ; rdx:rax = a*b
        0x48; 0xF7; 0x75; 0xE8;   # div qword [rbp-24]  ; rax=quot rdx=rem
        0x48; 0x89; 0x55; 0xE0;   # mov [rbp-32], rdx   ; result = rem
    }
    return result;
}

# Return base^exp mod m, all u64. Square-and-multiply via
# bayan_u64_mulmod on every step, so the inner loop cost is two hardware
# `div` instructions per iteration instead of a 128-iter shift-
# subtract. Loop count is exactly the bit-length of `exp`.
fn bayan_u64_powmod(base, exp, m): i64 {
    if (m == 1) { return 0; }
    var result = 1;
    base = base % m;
    while (exp > 0) {
        if ((exp & 1) == 1) {
            result = bayan_u64_mulmod(result, base, m);
        }
        exp = exp >> 1;
        if (exp > 0) {
            base = bayan_u64_mulmod(base, base, m);
        }
    }
    return result;
}

# --- bigint.cyr ---

# bigint.cyr — 256-bit unsigned integer arithmetic
# Usage: include "lib/bigint.cyr"
# Requires: alloc.cyr, string.cyr
#
# Representation: 4 × 64-bit limbs in little-endian order
# u256 = { limb[0] (low), limb[1], limb[2], limb[3] (high) }
# Each limb treated as unsigned via masking.
#
# Core operations: add, sub, mul, mod, compare, shift
# For Ed25519/secp256k1 curve arithmetic.

# ================================================================
# Limb access (32 bytes = 4 × 8)
# ================================================================

var U256_SIZE = 32;

# Create a zero u256
fn bayan_u256_zero(): i64 {
    var r = alloc(32);
    store64(r, 0);
    store64(r + 8, 0);
    store64(r + 16, 0);
    store64(r + 24, 0);
    return r;
}

# Create u256 from a single 64-bit value
fn bayan_u256_from(val): i64 {
    var r = alloc(32);
    store64(r, val);
    store64(r + 8, 0);
    store64(r + 16, 0);
    store64(r + 24, 0);
    return r;
}

# Copy u256
fn bayan_u256_copy(dst, src): i64 {
    store64(dst, load64(src));
    store64(dst + 8, load64(src + 8));
    store64(dst + 16, load64(src + 16));
    store64(dst + 24, load64(src + 24));
    return 0;
}

# Clone u256 (allocates new)
fn bayan_u256_clone(a): i64 {
    var r = alloc(32);
    bayan_u256_copy(r, a);
    return r;
}

# Get/set individual limbs
fn bayan_u256_limb(a, i): i64 { return load64(a + i * 8); }
# Set limb i of u256 to value v
fn bayan_u256_set_limb(a, i, v): i64 { store64(a + i * 8, v); return 0; }

# Check if zero
fn bayan_u256_is_zero(a): i64 {
    if (load64(a) != 0) { return 0; }
    if (load64(a + 8) != 0) { return 0; }
    if (load64(a + 16) != 0) { return 0; }
    if (load64(a + 24) != 0) { return 0; }
    return 1;
}

# ================================================================
# Comparison (unsigned)
# ================================================================

# Compare a vs b: returns 1 if a > b, -1 if a < b, 0 if equal
fn bayan_u256_cmp(a, b): i64 {
    # Compare from high limb to low
    var i = 3;
    while (i >= 0) {
        var al = load64(a + i * 8);
        var bl = load64(b + i * 8);
        # Unsigned comparison via XOR high bit trick
        var ax = al ^ (1 << 63);
        var bx = bl ^ (1 << 63);
        if (ax > bx) { return 1; }
        if (ax < bx) { return 0 - 1; }
        i = i - 1;
    }
    return 0;
}

# Equality check
fn bayan_u256_eq(a, b): i64 {
    if (load64(a) != load64(b)) { return 0; }
    if (load64(a + 8) != load64(b + 8)) { return 0; }
    if (load64(a + 16) != load64(b + 16)) { return 0; }
    if (load64(a + 24) != load64(b + 24)) { return 0; }
    return 1;
}

# ================================================================
# Addition / Subtraction with carry
# ================================================================

# Add two 64-bit values, return {sum, carry}
# Uses the fact that if a + b < a, carry occurred (unsigned overflow)
fn _add64(a, b): i64 {
    var sum = a + b;
    # Unsigned carry detection: if sum < a (treating as unsigned)
    var carry = 0;
    var sa = a ^ (1 << 63);
    var ss = sum ^ (1 << 63);
    if (ss < sa) { carry = 1; }
    # Edge case: if b was added to get exactly 0 (full wrap)
    if (sum == 0) { if (a != 0) { carry = 1; } }
    return carry;
}

# Add single limb pair, return carry
fn _add_limb(r_off, r, a, b, carry_in): i64 {
    var al = load64(a + r_off);
    var bl = load64(b + r_off);
    var s1 = al + bl;
    var c1 = _add64(al, bl);
    var s2 = s1 + carry_in;
    var c2 = 0;
    if (carry_in > 0) {
        if (s2 == 0) { c2 = 1; }
        else { var sx = s2 ^ (1 << 63); var s1x = s1 ^ (1 << 63); if (sx < s1x) { c2 = 1; } }
    }
    store64(r + r_off, s2);
    return c1 + c2;
}

# r = a + b (mod 2^256). Returns carry (0 or 1).
fn bayan_u256_add(r, a, b): i64 {
    var c = _add_limb(0, r, a, b, 0);
    c = _add_limb(8, r, a, b, c);
    c = _add_limb(16, r, a, b, c);
    c = _add_limb(24, r, a, b, c);
    return c;
}

# r = a - b (mod 2^256). Returns borrow (0 or 1).
# Subtract single limb pair, return borrow
fn _sub_limb(r_off, r, a, b, borrow_in): i64 {
    var al = load64(a + r_off);
    var bl = load64(b + r_off);
    var new_borrow = 0;
    if (borrow_in > 0) {
        if (bl == (0 - 1)) {
            new_borrow = 1;
            store64(r + r_off, al);
        } else {
            var bl2 = bl + 1;
            var ax = al ^ (1 << 63);
            var bx = bl2 ^ (1 << 63);
            if (bx > ax) { new_borrow = 1; }
            store64(r + r_off, al - bl2);
        }
    } else {
        var ax = al ^ (1 << 63);
        var bx = bl ^ (1 << 63);
        if (bx > ax) { new_borrow = 1; }
        store64(r + r_off, al - bl);
    }
    return new_borrow;
}

# r = a - b (mod 2^256). Returns borrow (0 or 1).
fn bayan_u256_sub(r, a, b): i64 {
    var c = _sub_limb(0, r, a, b, 0);
    c = _sub_limb(8, r, a, b, c);
    c = _sub_limb(16, r, a, b, c);
    c = _sub_limb(24, r, a, b, c);
    return c;
}

# ================================================================
# Multiplication (64×64→128 via 32-bit halves)
# ================================================================

# Multiply two 64-bit values, store 128-bit result in {lo, hi}
# Split each into 32-bit halves: a = aH*2^32 + aL, b = bH*2^32 + bL
# a*b = aH*bH*2^64 + (aH*bL + aL*bH)*2^32 + aL*bL
fn _mul64(a, b, out_lo, out_hi): i64 {
    var mask32 = 0xFFFFFFFF;
    var aL = a & mask32;
    var aH = (a >> 32) & mask32;
    var bL = b & mask32;
    var bH = (b >> 32) & mask32;
    # Partial products (each fits in 64 bits since 32×32 = 64)
    var ll = aL * bL;
    var lh = aL * bH;
    var hl = aH * bL;
    var hh = aH * bH;
    # Combine: lo = ll + (lh + hl) << 32, hi = hh + carries
    var mid = lh + hl;
    # Carry from lh + hl overflow
    var mid_carry = 0;
    if ((mid ^ (1 << 63)) < (lh ^ (1 << 63))) { mid_carry = 1; }
    var lo = ll + (mid << 32);
    var lo_carry = 0;
    if ((lo ^ (1 << 63)) < (ll ^ (1 << 63))) { lo_carry = 1; }
    var hi = hh + (mid >> 32) + (mid_carry << 32) + lo_carry;
    store64(out_lo, lo);
    store64(out_hi, hi);
    return 0;
}

# r = a * b (mod 2^256). Truncates to 256 bits.
fn bayan_u256_mul(r, a, b): i64 {
    # Schoolbook multiplication: 4×4 limbs
    var tmp[64];  # 8 limbs temp (512 bits)
    memset(&tmp, 0, 64);
    var i = 0;
    while (i < 4) {
        var carry = 0;
        var j = 0;
        while (j < 4) {
            if (i + j < 4) {
                var lo[8];
                var hi[8];
                _mul64(load64(a + i * 8), load64(b + j * 8), &lo, &hi);
                var cur = load64(&tmp + (i + j) * 8) + load64(&lo) + carry;
                # Detect carry
                carry = load64(&hi);
                var prev = load64(&tmp + (i + j) * 8);
                if ((cur ^ (1 << 63)) < (prev ^ (1 << 63))) { carry = carry + 1; }
                store64(&tmp + (i + j) * 8, cur);
            }
            j = j + 1;
        }
        i = i + 1;
    }
    # Copy low 4 limbs to result
    store64(r, load64(&tmp));
    store64(r + 8, load64(&tmp + 8));
    store64(r + 16, load64(&tmp + 16));
    store64(r + 24, load64(&tmp + 24));
    return 0;
}

# ================================================================
# Shift operations
# ================================================================

# Left shift by 1 bit
fn bayan_u256_shl1(r, a): i64 {
    var carry = 0;
    var i = 0;
    while (i < 4) {
        var v = load64(a + i * 8);
        store64(r + i * 8, (v << 1) | carry);
        carry = (v >> 63) & 1;
        i = i + 1;
    }
    return carry;
}

# Right shift by 1 bit
fn bayan_u256_shr1(r, a): i64 {
    var carry = 0;
    var i = 3;
    while (i >= 0) {
        var v = load64(a + i * 8);
        store64(r + i * 8, (v >> 1) | (carry << 63));
        carry = v & 1;
        i = i - 1;
    }
    return 0;
}

# ================================================================
# Modular reduction: r = a mod p
# ================================================================

# r = a mod p (simple repeated subtraction for small quotients,
# or shift-subtract for general case)
fn bayan_u256_mod(r, a, p): i64 {
    bayan_u256_copy(r, a);
    while (bayan_u256_cmp(r, p) >= 0) {
        bayan_u256_sub(r, r, p);
    }
    return 0;
}

# r = (a + b) mod p. Precondition: a, b < p (so a + b < 2p → one reduce
# suffices). Honors bayan_u256_add's carry-out — without it, when a + b ≥ 2^256
# the truncated r tests < p and the needed subtract is skipped, leaving r
# short by 2^256 − p (wrong for moduli near 2^256, e.g. the P-256 group
# order; Curve25519 callers with p < 2^255 never overflow). Mirrors
# bayan_u256_submod's borrow handling. See CHANGELOG [6.0.36].
fn bayan_u256_addmod(r, a, b, p): i64 {
    var carry = bayan_u256_add(r, a, b);
    if (carry > 0) {
        bayan_u256_sub(r, r, p);              # overflowed 2^256 → reduce once
    } else {
        if (bayan_u256_cmp(r, p) >= 0) { bayan_u256_sub(r, r, p); }
    }
    return 0;
}

# r = (a - b) mod p (handles underflow by adding p)
fn bayan_u256_submod(r, a, b, p): i64 {
    var borrow = bayan_u256_sub(r, a, b);
    if (borrow > 0) { bayan_u256_add(r, r, p); }
    return 0;
}

# r = (a * b) mod p
fn bayan_u256_mulmod(r, a, b, p): i64 {
    bayan_u256_mul(r, a, b);
    bayan_u256_mod(r, r, p);
    return 0;
}

# ================================================================
# Hex conversion
# ================================================================

# Format u256 as 64-char hex string (big-endian, no prefix)
fn bayan_u256_to_hex(a): i64 {
    var hex = "0123456789abcdef";
    var buf = alloc(65);
    var bi = 0;
    var i = 3;
    while (i >= 0) {
        var v = load64(a + i * 8);
        var j = 15;
        while (j >= 0) {
            store8(buf + bi, load8(hex + ((v >> (j * 4)) & 0xF)));
            bi = bi + 1;
            j = j - 1;
        }
        i = i - 1;
    }
    store8(buf + 64, 0);
    return buf;
}

# Parse hex string to u256 (big-endian, up to 64 chars)
fn bayan_u256_from_hex(s): i64 {
    var r = bayan_u256_zero();
    var len = strlen(s);
    if (len > 64) { len = 64; }
    var i = 0;
    while (i < len) {
        # Shift left by 4 bits
        var carry = 0;
        var li = 0;
        while (li < 4) {
            var v = load64(r + li * 8);
            store64(r + li * 8, (v << 4) | carry);
            carry = (v >> 60) & 0xF;
            li = li + 1;
        }
        # Add hex digit
        var c = load8(s + i);
        var d = 0;
        if (c >= 48) { if (c <= 57) { d = c - 48; } }
        if (c >= 97) { if (c <= 102) { d = c - 87; } }
        if (c >= 65) { if (c <= 70) { d = c - 55; } }
        store64(r, load64(r) | d);
        i = i + 1;
    }
    return r;
}

# --- toml.cyr ---

# toml.cyr — TOML parser for vidya content format
# Usage: include "lib/toml.cyr"
# Requires: string.cyr, alloc.cyr, str.cyr, vec.cyr, fmt.cyr, fs.cyr
#
# Parses TOML files with:
#   key = "value"          (string values)
#   key = '''multi-line''' (triple-quoted strings)
#   [[section]]            (arrays of tables)
#   # comments
#
# Each table is a vec of key-value pairs (like json.cyr).
# bayan_toml_parse returns a vec of { section_name, pairs_vec } entries.

# v5.8.30 — Result-returning *_r variant for the file-loading
# parser (`bayan_toml_parse_file_r`). Bare `bayan_toml_parse(src)` keeps its
# best-effort vec return — no clean -1 surface to migrate.

# v5.8.30 — TomlError variants. Mirrors the JsonError shape:
# `TomlIoErr` for any IoError raised while reading the source
# file; `TomlParseErr` reserved for a future slot when the
# parser tracks structural errors instead of best-effort
# recovery; `TomlOther` is the catch-all. Variant-name prefix
# `Toml` to keep these distinct from `Io*` / `Json*` variants
# in the global enum-variant namespace.
enum TomlError {
    TomlIoErr;
    TomlParseErr;
    TomlOther;
}

# TOML entry: { section: Str, pairs: vec of {key: Str, value: Str} }

# v5.8.36 — Allocator-as-first-arg variant of bayan_toml_section_new.
# Allocates the 16-byte section header via `a`. Returns 0 on OOM.
fn bayan_toml_section_new_a(a, name, pairs): i64 {
    var s = alloc_via(a, 16);
    if (s == 0) { return 0; }
    store64(s, name);
    store64(s + 8, pairs);
    return s;
}

# Create a TOML section entry. v5.8.36 wrapper.
fn bayan_toml_section_new(name, pairs): i64 {
    return bayan_toml_section_new_a(default_alloc(), name, pairs);
}

# Get section name from a TOML section entry
fn bayan_toml_section_name(s) : i64 { return load64(s); }
# Get pairs vec from a TOML section entry
fn bayan_toml_section_pairs(s) : i64 { return load64(s + 8); }

# v5.8.36 — Allocator-as-first-arg variant of bayan_toml_pair_new.
# Allocates the 16-byte pair via `a`. Returns 0 on OOM.
fn bayan_toml_pair_new_a(a, key, value): i64 {
    var p = alloc_via(a, 16);
    if (p == 0) { return 0; }
    store64(p, key);
    store64(p + 8, value);
    return p;
}

# Create a TOML key-value pair. v5.8.36 wrapper.
fn bayan_toml_pair_new(key, value): i64 {
    return bayan_toml_pair_new_a(default_alloc(), key, value);
}

# Get key from a TOML pair
fn bayan_toml_pair_key(p) : i64 { return load64(p); }
# Get value from a TOML pair
fn bayan_toml_pair_value(p) : i64 { return load64(p + 8); }

# Skip whitespace in buffer, return new position
fn _toml_skip_ws(buf, pos, end): i64 {
    while (pos < end) {
        var c = load8(buf + pos);
        if (c != 32 && c != 9) { return pos; }
        pos = pos + 1;
    }
    return pos;
}

# Parse a single-line quoted string: "value" — returns Str, advances pos
fn _toml_parse_str(buf, pos, end): i64 {
    # Skip opening quote
    pos = pos + 1;
    var start = pos;
    while (pos < end) {
        var c = load8(buf + pos);
        if (c == 34) {
            # Closing quote
            var s = str_new(buf + start, pos - start);
            store64(s + 8, pos - start);
            return s;
        }
        if (c == 92) { pos = pos + 1; }
        pos = pos + 1;
    }
    return str_from("");
}

# Get the end position after a single-line string parse
fn _toml_str_end(buf, pos, end): i64 {
    pos = pos + 1;
    while (pos < end) {
        var c = load8(buf + pos);
        if (c == 34) { return pos + 1; }
        if (c == 92) { pos = pos + 1; }
        pos = pos + 1;
    }
    return pos;
}

# Parse a triple-quoted string: '''...''' — returns Str
fn _toml_parse_multiline(buf, pos, end): i64 {
    # Skip opening '''
    pos = pos + 3;
    # Skip optional newline after opening '''
    if (pos < end && load8(buf + pos) == 10) { pos = pos + 1; }
    var start = pos;
    while (pos + 2 < end) {
        if (load8(buf + pos) == 39 && load8(buf + pos + 1) == 39 && load8(buf + pos + 2) == 39) {
            # Found closing '''
            # Trim trailing newline if present
            var slen = pos - start;
            if (slen > 0 && load8(buf + start + slen - 1) == 10) { slen = slen - 1; }
            return str_new(buf + start, slen);
        }
        pos = pos + 1;
    }
    return str_new(buf + start, end - start);
}

# Get end position after triple-quoted string
fn _toml_multiline_end(buf, pos, end): i64 {
    pos = pos + 3;
    if (pos < end && load8(buf + pos) == 10) { pos = pos + 1; }
    while (pos + 2 < end) {
        if (load8(buf + pos) == 39 && load8(buf + pos + 1) == 39 && load8(buf + pos + 2) == 39) {
            return pos + 3;
        }
        pos = pos + 1;
    }
    return end;
}

# Parse a TOML file into a vec of sections.
# Each section has a name (from [[name]]) and a pairs vec.
# Top-level key=value pairs go into a section named "".
fn bayan_toml_parse(src): i64 {
    var sections = vec_new();
    var data = str_data(src);
    var slen = str_len(src);
    var pos = 0;
    var cur_name = str_from("");
    var cur_pairs = vec_new();

    while (pos < slen) {
        var c = load8(data + pos);

        # Skip blank lines and whitespace
        if (c == 10 || c == 13) { pos = pos + 1; }
        elif (c == 32 || c == 9) { pos = pos + 1; }

        # Comment line
        elif (c == 35) {
            while (pos < slen && load8(data + pos) != 10) { pos = pos + 1; }
        }

        # Array of tables: [[name]]
        elif (c == 91 && pos + 1 < slen && load8(data + pos + 1) == 91) {
            # Save current section if it has pairs
            if (vec_len(cur_pairs) > 0) {
                vec_push(sections, bayan_toml_section_new(cur_name, cur_pairs));
            }
            pos = pos + 2;
            var nstart = pos;
            while (pos < slen && load8(data + pos) != 93) { pos = pos + 1; }
            cur_name = str_new(data + nstart, pos - nstart);
            if (pos < slen && load8(data + pos) == 93) { pos = pos + 1; }
            if (pos < slen && load8(data + pos) == 93) { pos = pos + 1; }
            cur_pairs = vec_new();
            # Skip to end of line
            while (pos < slen && load8(data + pos) != 10) { pos = pos + 1; }
        }

        # Table header: [section]  (single bracket — v6.0.62). The [[name]]
        # array-of-tables case is checked above, so a bare `[` reaches here
        # only as a single-bracket table header. One closing `]`, not two.
        elif (c == 91) {
            # Save current section if it has pairs
            if (vec_len(cur_pairs) > 0) {
                vec_push(sections, bayan_toml_section_new(cur_name, cur_pairs));
            }
            pos = pos + 1;
            var sbstart = pos;
            while (pos < slen && load8(data + pos) != 93) { pos = pos + 1; }
            cur_name = str_new(data + sbstart, pos - sbstart);
            if (pos < slen && load8(data + pos) == 93) { pos = pos + 1; }
            cur_pairs = vec_new();
            # Skip to end of line
            while (pos < slen && load8(data + pos) != 10) { pos = pos + 1; }
        }

        # Key = value
        else {
            # Read key (until = or whitespace)
            var kstart = pos;
            while (pos < slen) {
                var kc = load8(data + pos);
                if (kc == 61 || kc == 32 || kc == 9 || kc == 10) { break; }
                pos = pos + 1;
            }
            var key = str_new(data + kstart, pos - kstart);

            # Skip to =
            pos = _toml_skip_ws(data, pos, slen);
            if (pos < slen && load8(data + pos) == 61) {
                pos = pos + 1;
                pos = _toml_skip_ws(data, pos, slen);

                # Parse value
                var value = str_from("");
                if (pos < slen) {
                    var vc = load8(data + pos);
                    # Triple-quoted string '''...'''
                    var is_tri = vc == 39 && pos + 2 < slen;
                    if (is_tri == 1) { is_tri = load8(data + pos + 1) == 39; }
                    if (is_tri == 1) { is_tri = load8(data + pos + 2) == 39; }
                    if (is_tri == 1) {
                        value = _toml_parse_multiline(data, pos, slen);
                        pos = _toml_multiline_end(data, pos, slen);
                    }
                    # Double-quoted string "..."
                    elif (vc == 34) {
                        value = _toml_parse_str(data, pos, slen);
                        pos = _toml_str_end(data, pos, slen);
                    }
                    # Array "[ ... ]" — may span multiple lines (v5.4.17).
                    # Walk forward tracking quote state and bracket depth so
                    # `\n` inside the array body doesn't terminate the value.
                    # Nested arrays bump depth defensively; quoted `]` inside
                    # a string doesn't close the outer bracket.
                    elif (vc == 91) {
                        var astart = pos;
                        var depth = 1;
                        var in_quote = 0;
                        pos = pos + 1;
                        while (pos < slen && depth > 0) {
                            var ch = load8(data + pos);
                            if (in_quote == 1) {
                                if (ch == 34) { in_quote = 0; }
                            } else {
                                if (ch == 34) { in_quote = 1; }
                                elif (ch == 91) { depth = depth + 1; }
                                elif (ch == 93) { depth = depth - 1; }
                            }
                            pos = pos + 1;
                        }
                        value = str_new(data + astart, pos - astart);
                    }
                    # Unquoted value (number, boolean, etc) — read to end of line
                    else {
                        var vstart = pos;
                        while (pos < slen && load8(data + pos) != 10) { pos = pos + 1; }
                        # Trim trailing whitespace
                        var vend = pos;
                        while (vend > vstart && load8(data + vend - 1) == 32) { vend = vend - 1; }
                        value = str_new(data + vstart, vend - vstart);
                    }
                }
                vec_push(cur_pairs, bayan_toml_pair_new(key, value));
            }
            # Skip to end of line
            while (pos < slen && load8(data + pos) != 10) { pos = pos + 1; }
        }
    }
    # Save last section
    if (vec_len(cur_pairs) > 0) {
        vec_push(sections, bayan_toml_section_new(cur_name, cur_pairs));
    }
    return sections;
}

# Parse a TOML file from disk. Reads up to 256KB.
# v5.11.61: heap-alloc the read buffer instead of declaring it on-fn-scope.
# The previous `var buf[262144]` landed 256 KB in every consumer's `.bss`
# regardless of whether this fn was ever called (DCE drops the fn body but
# the static survives). Mirrors `bayan_toml_parse_file_r` (v5.8.30, already
# heap-allocs). See CHANGELOG [5.11.61].
fn bayan_toml_parse_file(path): i64 {
    var buf = alloc(262144);
    var n = file_read_all(path, buf, 262144);
    if (n <= 0) { return vec_new(); }
    return bayan_toml_parse(str_new(buf, n));
}

# v5.8.30 — Result variant of bayan_toml_parse_file. Surfaces underlying
# I/O errors as Err(TomlIoErr) instead of silently converting to an
# empty vec (the back-compat behavior of `bayan_toml_parse_file`).
fn bayan_toml_parse_file_r(path) : Result {
    var fd_r = file_open_r(path, 0, 0);
    if (is_err_result(fd_r) == 1) { return Err(TomlIoErr); }
    var fd = load64(fd_r + 8);
    var buf = alloc(262144);
    var total = 0;
    var rgo = 1;
    while (rgo == 1) {
        var rd_r = file_read_r(fd, buf + total, 262144 - total);
        if (is_err_result(rd_r) == 1) { sys_close(fd); return Err(TomlIoErr); }
        var n = load64(rd_r + 8);
        if (n <= 0) { rgo = 0; }
        else {
            total = total + n;
            if (total >= 262144) { rgo = 0; }
        }
    }
    sys_close(fd);
    if (total == 0) { return Err(TomlIoErr); }
    return Ok(bayan_toml_parse(str_new(buf, total)));
}

# Get value for a key from a pairs vec. Returns Str or 0 if not found.
# Get value by key. Key can be a cstring (e.g. "name") or a Str.
fn bayan_toml_get(pairs, key): i64 {
    var i = 0;
    var len = vec_len(pairs);
    while (i < len) {
        var p = vec_get(pairs, i);
        if (str_eq_cstr(bayan_toml_pair_key(p), key) == 1) {
            return bayan_toml_pair_value(p);
        }
        i = i + 1;
    }
    return 0;
}

# Get all sections with a given name (for [[entries]] etc.)
fn bayan_toml_get_sections(sections, name): i64 {
    var result = vec_new();
    var i = 0;
    var len = vec_len(sections);
    while (i < len) {
        var s = vec_get(sections, i);
        if (str_eq_cstr(bayan_toml_section_name(s), name) == 1) {
            vec_push(result, s);
        }
        i = i + 1;
    }
    return result;
}

# --- cyml.cyr ---

# cyml.cyr — CYML parser (TOML header + markdown body)
# Usage: include "lib/cyml.cyr"
# Requires: string.cyr, alloc.cyr
#
# CYML is TOML above `---`, markdown below.
# Single-entry: one header, one body.
# Multi-entry: file-level TOML, then [[entries]] with per-entry header+body.
# Parser returns zero-copy pointers into the input buffer.

# v5.8.30 — Result-returning *_r variant for the file-loading
# parser (`bayan_cyml_parse_file_r`). Bare `bayan_cyml_parse(data, len)` keeps
# its current shape — it can't really fail (always returns a doc
# with entry_count >= 0), so no Result variant is needed for it.

# v5.8.30 — CymlError variants. Same shape as Json/TomlError:
# `CymlIoErr` for any IoError raised while reading the source
# file; `CymlOther` is the catch-all. Variant-name prefix `Cyml`
# to keep these out of the `Io*` / `Json*` / `Toml*` namespace.
enum CymlError {
    CymlIoErr;
    CymlOther;
}

# v5.8.36 — Allocator-as-first-arg variant of bayan_cyml_entry_new.
# Allocates the 32-byte entry header via `a`. Returns 0 on OOM.
fn bayan_cyml_entry_new_a(a, hp, hl, bp, bl): i64 {
    var e = alloc_via(a, 32);
    if (e == 0) { return 0; }
    store64(e, hp);
    store64(e + 8, hl);
    store64(e + 16, bp);
    store64(e + 24, bl);
    return e;
}

# CymlEntry: { header_ptr, header_len, body_ptr, body_len }
# 32 bytes per entry. v5.8.36 wrapper.
fn bayan_cyml_entry_new(hp, hl, bp, bl): i64 {
    return bayan_cyml_entry_new_a(default_alloc(), hp, hl, bp, bl);
}

# Get TOML header pointer from a CymlEntry
fn bayan_cyml_entry_header(e) : i64 { return load64(e); }
# Get TOML header byte length from a CymlEntry
fn bayan_cyml_entry_header_len(e) : i64 { return load64(e + 8); }
# Get markdown body pointer from a CymlEntry
fn bayan_cyml_entry_body(e) : i64 { return load64(e + 16); }
# Get markdown body byte length from a CymlEntry
fn bayan_cyml_entry_body_len(e) : i64 { return load64(e + 24); }

# v5.8.36 — Allocator-as-first-arg variant of bayan_cyml_doc_new.
# Allocates the 32-byte doc struct via `a`. Returns 0 on OOM.
fn bayan_cyml_doc_new_a(a): i64 {
    var d = alloc_via(a, 32);
    if (d == 0) { return 0; }
    store64(d, 0);
    store64(d + 8, 0);
    store64(d + 16, 0);
    store64(d + 24, 0);
    return d;
}

# CymlDoc: { file_header_ptr, file_header_len, entries_ptr, entry_count }
# 32 bytes. v5.8.36 wrapper.
fn bayan_cyml_doc_new(): i64 {
    return bayan_cyml_doc_new_a(default_alloc());
}

# Get file-level TOML header pointer from a CymlDoc
fn bayan_cyml_doc_header(d) : i64 { return load64(d); }
# Get file-level TOML header byte length from a CymlDoc
fn bayan_cyml_doc_header_len(d) : i64 { return load64(d + 8); }
# Get entries array pointer from a CymlDoc
fn bayan_cyml_doc_entries(d) : i64 { return load64(d + 16); }
# Get number of entries in a CymlDoc
fn bayan_cyml_doc_entry_count(d) : i64 { return load64(d + 24); }

# Get entry N from a doc (returns CymlEntry pointer)
fn bayan_cyml_doc_entry(d, n): i64 {
    return load64(load64(d + 16) + n * 8);
}

# Check if data[pos..] starts with "\n---\n" (or "---\n" at pos==0)
fn _cyml_is_delim(data, len, pos): i64 {
    if (pos == 0) {
        if (pos + 4 <= len) {
            if (load8(data) == 45 && load8(data+1) == 45 && load8(data+2) == 45 && load8(data+3) == 10) {
                return 1;
            }
        }
        return 0;
    }
    if (pos + 5 > len) { return 0; }
    if (load8(data + pos) != 10) { return 0; }
    if (load8(data + pos + 1) != 45) { return 0; }
    if (load8(data + pos + 2) != 45) { return 0; }
    if (load8(data + pos + 3) != 45) { return 0; }
    if (load8(data + pos + 4) != 10) { return 0; }
    return 1;
}

# Check if data[pos..] starts with "\n[[entries]]\n" (or "[[entries]]\n" at pos==0)
fn _cyml_is_entries(data, len, pos): i64 {
    # "[[entries]]" = 11 chars + newline before and after
    if (pos == 0) {
        if (len < 12) { return 0; }
        if (load8(data) != 91) { return 0; }       # [
        if (load8(data+1) != 91) { return 0; }     # [
        if (load8(data+2) != 101) { return 0; }    # e
        if (load8(data+3) != 110) { return 0; }    # n
        if (load8(data+4) != 116) { return 0; }    # t
        if (load8(data+5) != 114) { return 0; }    # r
        if (load8(data+6) != 105) { return 0; }    # i
        if (load8(data+7) != 101) { return 0; }    # e
        if (load8(data+8) != 115) { return 0; }    # s
        if (load8(data+9) != 93) { return 0; }     # ]
        if (load8(data+10) != 93) { return 0; }    # ]
        if (load8(data+11) != 10) { return 0; }    # \n
        return 1;
    }
    if (pos + 13 > len) { return 0; }
    if (load8(data+pos) != 10) { return 0; }       # \n
    if (load8(data+pos+1) != 91) { return 0; }     # [
    if (load8(data+pos+2) != 91) { return 0; }     # [
    if (load8(data+pos+3) != 101) { return 0; }    # e
    if (load8(data+pos+4) != 110) { return 0; }    # n
    if (load8(data+pos+5) != 116) { return 0; }    # t
    if (load8(data+pos+6) != 114) { return 0; }    # r
    if (load8(data+pos+7) != 105) { return 0; }    # i
    if (load8(data+pos+8) != 101) { return 0; }    # e
    if (load8(data+pos+9) != 115) { return 0; }    # s
    if (load8(data+pos+10) != 93) { return 0; }    # ]
    if (load8(data+pos+11) != 93) { return 0; }    # ]
    if (load8(data+pos+12) != 10) { return 0; }    # \n
    return 1;
}

# Trim leading/trailing whitespace from a (ptr, len) pair.
# Returns new length (ptr adjusted in-place via out params).
fn _cyml_trim(ptr, len, out_ptr, out_len): i64 {
    var s = 0;
    while (s < len) {
        var c = load8(ptr + s);
        if (c == 32 || c == 10 || c == 13 || c == 9) {
            s = s + 1;
        } else { break; }
    }
    var e = len;
    while (e > s) {
        var c = load8(ptr + e - 1);
        if (c == 32 || c == 10 || c == 13 || c == 9) {
            e = e - 1;
        } else { break; }
    }
    store64(out_ptr, ptr + s);
    store64(out_len, e - s);
    return 0;
}

# Parse a CYML buffer. Returns a CymlDoc pointer.
# data = pointer to buffer, len = byte length.
fn bayan_cyml_parse(data, len): i64 {
    var doc = bayan_cyml_doc_new();
    # Collect entry positions: up to 256 entries
    # 256 eight-byte slots = 2048 BYTES. A function-local `var X[N]` is N
    # BYTES (not N i64 slots), so this MUST be [2048] to hold the 256 entries
    # the `entry_count >= 256` cap (below) permits. [256] was a 1792-byte OOB
    # stack write from untrusted CYML (8-byte stride × 256). See CHANGELOG [6.0.79].
    var entry_starts[2048];  # byte offsets of [[entries]] markers (256 × 8B)
    var entry_count = 0;

    # Scan for [[entries]] markers
    var i = 0;
    while (i < len) {
        if (_cyml_is_entries(data, len, i) == 1) {
            store64(&entry_starts + entry_count * 8, i);
            entry_count = entry_count + 1;
            if (entry_count >= 256) { i = len; }
            else {
                if (i == 0) { i = 12; }
                else { i = i + 13; }
            }
        } else {
            i = i + 1;
        }
    }

    if (entry_count == 0) {
        # Single-entry file: find --- delimiter
        var delim_pos = 0 - 1;
        var di = 0;
        while (di < len) {
            if (_cyml_is_delim(data, len, di) == 1) {
                delim_pos = di;
                di = len;
            } else {
                di = di + 1;
            }
        }
        if (delim_pos < 0) {
            # No delimiter — entire file is header, no body
            store64(doc, data);
            store64(doc + 8, len);
            store64(doc + 24, 0);
            return doc;
        }
        # Header = data[0..delim_pos], body = data[delim_pos+4/5..end]
        var hp = 0; var hl = 0; var bp = 0; var bl = 0;
        _cyml_trim(data, delim_pos, &hp, &hl);
        var body_start = delim_pos + 4;
        if (delim_pos > 0) { body_start = delim_pos + 5; }
        _cyml_trim(data + body_start, len - body_start, &bp, &bl);

        store64(doc, hp);
        store64(doc + 8, hl);
        # Single entry stored as entries[0]
        var entries = alloc(8);
        store64(entries, bayan_cyml_entry_new(hp, hl, bp, bl));
        store64(doc + 16, entries);
        store64(doc + 24, 1);
        return doc;
    }

    # Multi-entry file
    # File header = data[0..first_entry_start]
    var first_entry = load64(&entry_starts);
    if (first_entry > 0) {
        var fhp = 0; var fhl = 0;
        _cyml_trim(data, first_entry, &fhp, &fhl);
        store64(doc, fhp);
        store64(doc + 8, fhl);
    }

    var entries = alloc(entry_count * 8);
    var ei = 0;
    while (ei < entry_count) {
        var estart = load64(&entry_starts + ei * 8);
        var eend = len;
        if (ei + 1 < entry_count) { eend = load64(&entry_starts + (ei + 1) * 8); }

        # Entry header starts after "[[entries]]\n"
        var hdr_start = estart + 12;
        if (estart > 0) { hdr_start = estart + 13; }

        # Find --- within this entry
        var edelim = 0 - 1;
        var edi = hdr_start;
        while (edi < eend) {
            if (_cyml_is_delim(data, eend, edi) == 1) {
                edelim = edi;
                edi = eend;
            } else {
                edi = edi + 1;
            }
        }

        if (edelim < 0) {
            # No body — entry is header only
            var ehp = 0; var ehl = 0;
            _cyml_trim(data + hdr_start, eend - hdr_start, &ehp, &ehl);
            store64(entries + ei * 8, bayan_cyml_entry_new(ehp, ehl, 0, 0));
        } else {
            var ehp = 0; var ehl = 0; var ebp = 0; var ebl = 0;
            _cyml_trim(data + hdr_start, edelim - hdr_start, &ehp, &ehl);
            var ebody_start = edelim + 5;
            _cyml_trim(data + ebody_start, eend - ebody_start, &ebp, &ebl);
            store64(entries + ei * 8, bayan_cyml_entry_new(ehp, ehl, ebp, ebl));
        }
        ei = ei + 1;
    }

    store64(doc + 16, entries);
    store64(doc + 24, entry_count);
    return doc;
}

# ================================================================
# Value expansion — resolve ${file:PATH} and ${env:NAME} references
# ================================================================
# ${file:VERSION} → reads file "VERSION", trims whitespace
# ${env:HOME}     → reads environment variable HOME
# Plain strings without ${...} returned as-is.

fn _cyml_read_file_trimmed(path): i64 {
    var buf[4096];
    var fd = syscall(2, path, 0, 0);
    if (fd < 0) { return 0; }
    var n = syscall(0, fd, &buf, 4095);
    syscall(3, fd);
    if (n <= 0) { return 0; }
    # Trim trailing whitespace/newlines
    while (n > 0) {
        var c = load8(&buf + n - 1);
        if (c == 10 || c == 13 || c == 32 || c == 9) { n = n - 1; }
        else { break; }
    }
    var out = alloc(n + 1);
    memcpy(out, &buf, n);
    store8(out + n, 0);
    return out;
}

fn _cyml_read_env(name, name_len): i64 {
    var ebuf[8192];
    var fd = syscall(2, "/proc/self/environ", 0, 0);
    if (fd < 0) { return 0; }
    var n = syscall(0, fd, &ebuf, 8191);
    syscall(3, fd);
    if (n <= 0) { return 0; }
    store8(&ebuf + n, 0);
    var pos = 0;
    while (pos < n) {
        var end = pos;
        while (end < n && load8(&ebuf + end) != 0) { end = end + 1; }
        # Check if this entry starts with name=
        if (end - pos > name_len) {
            if (load8(&ebuf + pos + name_len) == 61) {
                var matched = 1;
                var k = 0;
                while (k < name_len) {
                    if (load8(&ebuf + pos + k) != load8(name + k)) { matched = 0; break; }
                    k = k + 1;
                }
                if (matched == 1) {
                    var vstart = pos + name_len + 1;
                    var vlen = end - vstart;
                    var out = alloc(vlen + 1);
                    memcpy(out, &ebuf + vstart, vlen);
                    store8(out + vlen, 0);
                    return out;
                }
            }
        }
        pos = end + 1;
    }
    return 0;
}

# Expand ${file:PATH} and ${env:NAME} in a value string.
# Returns expanded cstring (allocated). Returns input unchanged if no expansion.
fn bayan_cyml_expand_value(val): i64 {
    if (val == 0) { return 0; }
    var len = strlen(val);
    if (len < 4) { return val; }
    # Scan for ${
    var i = 0;
    while (i < len - 1) {
        if (load8(val + i) == 36 && load8(val + i + 1) == 123) {
            # Found ${ — find closing }
            var start = i + 2;
            var end = start;
            while (end < len && load8(val + end) != 125) { end = end + 1; }
            if (end >= len) { return val; }
            # Extract reference: file:PATH or env:NAME
            if (end - start > 5 && memeq(val + start, "file:", 5) == 1) {
                # ${file:PATH}
                var plen = end - start - 5;
                var path = alloc(plen + 1);
                memcpy(path, val + start + 5, plen);
                store8(path + plen, 0);
                var expanded = _cyml_read_file_trimmed(path);
                if (expanded != 0) { return expanded; }
                return val;
            }
            if (end - start > 4 && memeq(val + start, "env:", 4) == 1) {
                # ${env:NAME}
                var nlen = end - start - 4;
                var expanded = _cyml_read_env(val + start + 4, nlen);
                if (expanded != 0) { return expanded; }
                return val;
            }
            return val;
        }
        i = i + 1;
    }
    return val;
}

# Convenience: split a single-entry CYML buffer into header + body.
# Returns 1 on success, 0 if no delimiter found.
fn bayan_cyml_split(data, len, out_hdr, out_hdr_len, out_body, out_body_len): i64 {
    var i = 0;
    while (i < len) {
        if (_cyml_is_delim(data, len, i) == 1) {
            _cyml_trim(data, i, out_hdr, out_hdr_len);
            var body_start = i + 4;
            if (i > 0) { body_start = i + 5; }
            _cyml_trim(data + body_start, len - body_start, out_body, out_body_len);
            return 1;
        }
        i = i + 1;
    }
    return 0;
}

# v5.8.30 — Result variant of file-loading parser. Reads the file
# via file_open_r / file_read_r, wraps any IoError as Err(CymlIoErr).
# Buffer cap matches the conservative 256KB used elsewhere; vidya's
# largest current .cyml entries fit comfortably.
fn bayan_cyml_parse_file_r(path): i64 {
    var fd_r = file_open_r(path, 0, 0);
    if (is_err_result(fd_r) == 1) { return Err(CymlIoErr); }
    var fd = load64(fd_r + 8);
    var buf = alloc(262144);
    var total = 0;
    var rgo = 1;
    while (rgo == 1) {
        var rd_r = file_read_r(fd, buf + total, 262144 - total);
        if (is_err_result(rd_r) == 1) { sys_close(fd); return Err(CymlIoErr); }
        var n = load64(rd_r + 8);
        if (n <= 0) { rgo = 0; }
        else {
            total = total + n;
            if (total >= 262144) { rgo = 0; }
        }
    }
    sys_close(fd);
    if (total == 0) { return Err(CymlIoErr); }
    return Ok(bayan_cyml_parse(buf, total));
}

# --- json.cyr ---

# json.cyr — minimal JSON parser and builder
# Usage: include "lib/json.cyr"
# Requires: string.cyr, alloc.cyr, str.cyr, vec.cyr, fmt.cyr, io.cyr
# Internally includes: fnptr.cyr (for streaming-parser fncallN dispatch)
#
# Parses flat JSON objects into key-value pairs.
# Values are stored as strings (callers convert with str_to_int etc).

# v5.8.30: Result-returning *_r variants for the file-loading
# parsers (`bayan_json_parse_file_r`). Bare `bayan_json_parse(src)` keeps its
# best-effort vec return — no clean -1 surface to migrate.

# v5.8.30 — JsonError variants. `JsonIoErr` covers any underlying
# IoError raised while reading the source file; `JsonParseErr` is
# reserved for a future slot when the parser tracks structural
# errors instead of best-effort recovery; `JsonOther` is the
# catch-all. Keep variant-name prefix `Json` to avoid colliding
# with IoError's `Io*` variants in the global enum-variant
# namespace.
enum JsonError {
    JsonIoErr;
    JsonParseErr;
    JsonOther;
}

# JSON value: { key: Str, value: Str }
var JSON_PAIR_SIZE = 16;

# v5.8.36 — Allocator-as-first-arg variant of bayan_json_pair_new.
# Allocates the 16-byte pair via `a`. Returns 0 on OOM.
fn bayan_json_pair_new_a(a, key, value): i64 {
    var p = alloc_via(a, JSON_PAIR_SIZE);
    if (p == 0) { return 0; }
    store64(p, key);
    store64(p + 8, value);
    return p;
}

# Create a new key-value pair for JSON storage. v5.8.36 wrapper.
fn bayan_json_pair_new(key, value): i64 {
    return bayan_json_pair_new_a(default_alloc(), key, value);
}

# Return the key Str from a JSON pair
fn bayan_json_key(p): i64 { return load64(p); }
# Return the value Str from a JSON pair
fn bayan_json_value(p): i64 { return load64(p + 8); }

# Parse a JSON object string into a vec of key-value pairs.
# Handles: {"key": "value", "key2": "value2", "num": 42}
# Returns vec of json_pair pointers.
fn bayan_json_parse(src): i64 {
    var pairs = vec_new();
    var data = str_data(src);
    var slen = str_len(src);
    var ji = 0;
    # Skip to opening brace
    while (ji < slen) {
        if (load8(data + ji) == 123) { ji = ji + 1; break; }
        ji = ji + 1;
    }
    # Parse key-value pairs
    var key = 0;
    var val = 0;
    while (ji < slen) {
        var c = load8(data + ji);
        # Skip whitespace and commas
        if (c == 32) { ji = ji + 1; }
        elif (c == 10) { ji = ji + 1; }
        elif (c == 13) { ji = ji + 1; }
        elif (c == 9) { ji = ji + 1; }
        elif (c == 44) { ji = ji + 1; }
        elif (c == 125) { break; }
        elif (c == 34) {
            # Parse quoted string
            ji = ji + 1;
            var qs = ji;
            while (ji < slen) {
                if (load8(data + ji) == 34) { break; }
                ji = ji + 1;
            }
            var qstr = str_new(data + qs, ji - qs);
            ji = ji + 1;
            # Is this a key or value?
            if (key == 0) {
                key = qstr;
                # Skip to colon
                while (ji < slen) {
                    if (load8(data + ji) == 58) { ji = ji + 1; break; }
                    ji = ji + 1;
                }
            } else {
                val = qstr;
                vec_push(pairs, bayan_json_pair_new(key, val));
                key = 0;
                val = 0;
            }
        } else {
            # Non-string value (number, true, false, null)
            # Note: historical — chained if/break inside while was broken
            # pre-3.2.6 (upstream report from argonaut, fixed long since);
            # keep the flag + || form below anyway — it's clear enough.
            if (key != 0) {
                var vs = ji;
                var done = 0;
                while (ji < slen && done == 0) {
                    var vc = load8(data + ji);
                    if (vc == 44 || vc == 125 || vc == 32 || vc == 10) {
                        done = 1;
                    } else {
                        ji = ji + 1;
                    }
                }
                val = str_new(data + vs, ji - vs);
                vec_push(pairs, bayan_json_pair_new(key, val));
                key = 0;
                val = 0;
            } else {
                ji = ji + 1;
            }
        }
    }
    return pairs;
}

# Find value by key in parsed JSON. Returns Str or 0 if not found.
fn bayan_json_get(pairs, key): i64 {
    if (pairs == 0) { return 0; }
    if (key == 0) { return 0; }
    var len = vec_len(pairs);
    var gi = 0;
    while (gi < len) {
        var p = vec_get(pairs, gi);
        if (str_eq(bayan_json_key(p), key) == 1) {
            return bayan_json_value(p);
        }
        gi = gi + 1;
    }
    return 0;
}

# Get value as integer (0 if not found or not numeric)
fn bayan_json_get_int(pairs, key): i64 {
    var v = bayan_json_get(pairs, key);
    if (v == 0) { return 0; }
    return str_to_int(v);
}

# Build a JSON object from a vec of key-value pairs
fn bayan_json_build(pairs): i64 {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{");
    var len = vec_len(pairs);
    var bi = 0;
    while (bi < len) {
        if (bi > 0) { str_builder_add_cstr(sb, ", "); }
        var p = vec_get(pairs, bi);
        str_builder_add_cstr(sb, "\"");
        str_builder_add(sb, bayan_json_key(p));
        str_builder_add_cstr(sb, "\": \"");
        str_builder_add(sb, bayan_json_value(p));
        str_builder_add_cstr(sb, "\"");
        bi = bi + 1;
    }
    str_builder_add_cstr(sb, "}");
    return str_builder_build(sb);
}

# Parse a JSON file
fn bayan_json_parse_file(path): i64 {
    var buf = alloc(16384);
    var n = file_read_all(path, buf, 16384);
    if (n <= 0) { return vec_new(); }
    return bayan_json_parse(str_new(buf, n));
}

# v5.8.30 — Result variant of bayan_json_parse_file. Open + read are
# pushed through file_open_r / file_read_r so an underlying
# IoError surfaces as Err(JsonIoErr) instead of being silently
# converted to an empty vec (the back-compat behavior of
# `bayan_json_parse_file`).
fn bayan_json_parse_file_r(path): i64 {
    var fd_r = file_open_r(path, 0, 0);
    if (is_err_result(fd_r) == 1) { return Err(JsonIoErr); }
    var fd = load64(fd_r + 8);
    var buf = alloc(16384);
    var total = 0;
    var rgo = 1;
    while (rgo == 1) {
        var rd_r = file_read_r(fd, buf + total, 16384 - total);
        if (is_err_result(rd_r) == 1) { sys_close(fd); return Err(JsonIoErr); }
        var n = load64(rd_r + 8);
        if (n <= 0) { rgo = 0; }
        else {
            total = total + n;
            if (total >= 16384) { rgo = 0; }
        }
    }
    sys_close(fd);
    if (total == 0) { return Err(JsonIoErr); }
    return Ok(bayan_json_parse(str_new(buf, total)));
}

# ======================================================================
# JSON ENGINE (v5.7.20) — Tagged-value tree with full nesting + escapes
# ======================================================================
#
# Stdlib baseline. RPC-grade scope (custom serializers, binary
# extensions, etc.) is owned by sandhi (lib/sandhi.cyr).
#
# Backward compat: the flat key-value API at the top of this file
# (bayan_json_parse, bayan_json_get, bayan_json_get_int, bayan_json_pair_new, bayan_json_key,
# bayan_json_value, bayan_json_build, bayan_json_parse_file) is preserved unchanged.
# Existing kybernet / argonaut / libro callers stay green.
#
# The new engine below uses a `json_v_*` prefix and a tagged 24-byte
# heap value:
#
#   +0   tag      u64    JTAG_NULL / BOOL / INT / FLOAT / STR / ARR / OBJ
#   +8   payload  u64    i64 / f64 bits / Str ptr / vec ptr
#   +16  reserved u64    0 (future: source span for raw access)
#
# Vec contents:
#   ARR: vec<json_v*> — element values in declaration order
#   OBJ: vec<json_v_pair*> — { key: Str, value: json_v* } pairs in order
#
# Strings (STR tag and OBJ keys) are decoded — \" \\ \/ \b \f \n \r \t
# \uXXXX (UTF-8 encoded) are all resolved at parse time. The Str ptr
# holds the decoded byte sequence, not the source-text bytes.
#
# Numbers: parsed as INT if the source has no `.` `e` `E`; else FLOAT.
# Float parsing handles scientific notation `3.14e10` / `1.5E-3`.
#
# Errors: parse failures set _json_err_msg (cstr) and _json_err_pos
# (input byte offset). bayan_json_v_parse* returns 0 on error.

var JTAG_NULL  = 0;
var JTAG_BOOL  = 1;
var JTAG_INT   = 2;
var JTAG_FLOAT = 3;
var JTAG_STR   = 4;
var JTAG_ARR   = 5;
var JTAG_OBJ   = 6;

var JV_SIZE = 24;

# Last-error reporting (single-threaded; one parse at a time).
var _json_err_msg = 0;
var _json_err_pos = 0;

# Return the last parse error message (cstr) — set on bayan_json_v_parse* failure.
fn bayan_json_last_error(): i64 {
    if (_json_err_msg == 0) { return ""; }
    return _json_err_msg;
}

# Return the last parse error byte offset — set on bayan_json_v_parse* failure.
fn bayan_json_last_error_pos(): i64 { return _json_err_pos; }

# === Constructors ===

# v5.8.36 — Allocator-as-first-arg internal jv-cell allocator.
# Returns 0 on OOM (caller must check). Used by every json_v_*_new_a
# constructor below.
fn _jv_alloc_a(a, tag): i64 {
    var v = alloc_via(a, JV_SIZE);
    if (v == 0) { return 0; }
    store64(v, tag);
    store64(v + 8, 0);
    store64(v + 16, 0);
    return v;
}

# Internal jv-cell allocator (back-compat wrapper).
fn _jv_alloc(tag): i64 { return _jv_alloc_a(default_alloc(), tag); }

# v5.8.36 — Allocator-as-first-arg variant of bayan_json_v_null.
fn bayan_json_v_null_a(a): i64 { return _jv_alloc_a(a, JTAG_NULL); }

# Create a new JTAG_NULL value. v5.8.36 wrapper.
fn bayan_json_v_null(): i64 { return _jv_alloc(JTAG_NULL); }

# v5.8.36 — Allocator-as-first-arg variant of bayan_json_v_bool_new.
fn bayan_json_v_bool_new_a(a, b): i64 {
    var v = _jv_alloc_a(a, JTAG_BOOL);
    if (v == 0) { return 0; }
    if (b == 0) { store64(v + 8, 0); }
    else        { store64(v + 8, 1); }
    return v;
}

# Create a new JTAG_BOOL value (b is 0 or 1). v5.8.36 wrapper.
fn bayan_json_v_bool_new(b): i64 {
    return bayan_json_v_bool_new_a(default_alloc(), b);
}

# v5.8.36 — Allocator-as-first-arg variant of bayan_json_v_int_new.
fn bayan_json_v_int_new_a(a, n): i64 {
    var v = _jv_alloc_a(a, JTAG_INT);
    if (v == 0) { return 0; }
    store64(v + 8, n);
    return v;
}

# Create a new JTAG_INT value (n is i64). v5.8.36 wrapper.
fn bayan_json_v_int_new(n): i64 {
    return bayan_json_v_int_new_a(default_alloc(), n);
}

# v5.8.36 — Allocator-as-first-arg variant of bayan_json_v_float_new.
fn bayan_json_v_float_new_a(a, f): i64 {
    var v = _jv_alloc_a(a, JTAG_FLOAT);
    if (v == 0) { return 0; }
    store64(v + 8, f);
    return v;
}

# Create a new JTAG_FLOAT value (f is f64 bit pattern). v5.8.36 wrapper.
fn bayan_json_v_float_new(f): i64 {
    return bayan_json_v_float_new_a(default_alloc(), f);
}

# v5.8.36 — Allocator-as-first-arg variant of bayan_json_v_str_new.
fn bayan_json_v_str_new_a(a, s): i64 {
    var v = _jv_alloc_a(a, JTAG_STR);
    if (v == 0) { return 0; }
    store64(v + 8, s);
    return v;
}

# Create a new JTAG_STR value (s is a Str ptr). v5.8.36 wrapper.
fn bayan_json_v_str_new(s): i64 {
    return bayan_json_v_str_new_a(default_alloc(), s);
}

# v5.8.36 — Allocator-as-first-arg variant of bayan_json_v_arr_new.
# Allocates BOTH the jv-cell AND the inner vec via `a`.
fn bayan_json_v_arr_new_a(a): i64 {
    var v = _jv_alloc_a(a, JTAG_ARR);
    if (v == 0) { return 0; }
    var inner = vec_new_a(a);
    if (inner == 0) { return 0; }
    store64(v + 8, inner);
    return v;
}

# Create an empty JTAG_ARR value. v5.8.36 wrapper. Append via
# bayan_json_v_arr_push (use bayan_json_v_arr_push_a if you need the same
# allocator threaded through grows).
fn bayan_json_v_arr_new(): i64 {
    return bayan_json_v_arr_new_a(default_alloc());
}

# v5.8.36 — Allocator-as-first-arg variant of bayan_json_v_obj_new.
# Allocates BOTH the jv-cell AND the inner pairs vec via `a`.
fn bayan_json_v_obj_new_a(a): i64 {
    var v = _jv_alloc_a(a, JTAG_OBJ);
    if (v == 0) { return 0; }
    var inner = vec_new_a(a);
    if (inner == 0) { return 0; }
    store64(v + 8, inner);
    return v;
}

# Create an empty JTAG_OBJ value. v5.8.36 wrapper.
fn bayan_json_v_obj_new(): i64 {
    return bayan_json_v_obj_new_a(default_alloc());
}

# v5.8.36 — Allocator-as-first-arg variant of _jv_pair_new.
fn _jv_pair_new_a(a, key, val): i64 {
    var p = alloc_via(a, 16);
    if (p == 0) { return 0; }
    store64(p, key);
    store64(p + 8, val);
    return p;
}

# A pair is a 16-byte heap struct: { key: Str @ +0, value: json_v* @ +8 }.
# v5.8.36 wrapper.
fn _jv_pair_new(key, val): i64 {
    return _jv_pair_new_a(default_alloc(), key, val);
}

# v5.8.36 — Allocator-as-first-arg variant of bayan_json_v_arr_push.
# Routes any vec-grow through `a`. Returns -1 on grow OOM
# (vs. back-compat which aborts via vec_push).
fn bayan_json_v_arr_push_a(a, arr, val): i64 {
    if (arr == 0) { return 0 - 1; }
    if (load64(arr) != JTAG_ARR) { return 0 - 1; }
    return vec_push_a(a, load64(arr + 8), val);
}

# Append a value to an array. No-op if arr is not JTAG_ARR.
# v5.8.36 wrapper.
fn bayan_json_v_arr_push(arr, val): i64 {
    if (arr == 0) { return 0; }
    if (load64(arr) != JTAG_ARR) { return 0; }
    vec_push(load64(arr + 8), val);
    return 0;
}

# Append a key/value pair to an object. No-op if obj is not JTAG_OBJ.
fn bayan_json_v_obj_set(obj, key, val): i64 {
    if (obj == 0) { return 0; }
    if (load64(obj) != JTAG_OBJ) { return 0; }
    vec_push(load64(obj + 8), _jv_pair_new(key, val));
    return 0;
}

# === Tag predicates ===

# Return the value tag (JTAG_NULL/BOOL/INT/FLOAT/STR/ARR/OBJ), or -1 if v is 0.
fn bayan_json_v_tag(v): i64 {
    if (v == 0) { return 0 - 1; }
    return load64(v);
}

# Tag predicates — return 1 if v has the given tag, else 0. All return 0 on null v.
fn bayan_json_v_is_null(v): i64 { if (v == 0) { return 0; } if (load64(v) == JTAG_NULL)  { return 1; } return 0; }
# True if v is a JTAG_BOOL value.
fn bayan_json_v_is_bool(v): i64 { if (v == 0) { return 0; } if (load64(v) == JTAG_BOOL)  { return 1; } return 0; }
# True if v is a JTAG_INT value.
fn bayan_json_v_is_int(v): i64 { if (v == 0) { return 0; } if (load64(v) == JTAG_INT)   { return 1; } return 0; }
# True if v is a JTAG_FLOAT value.
fn bayan_json_v_is_float(v): i64 { if (v == 0) { return 0; } if (load64(v) == JTAG_FLOAT) { return 1; } return 0; }
# True if v is a JTAG_STR value.
fn bayan_json_v_is_str(v): i64 { if (v == 0) { return 0; } if (load64(v) == JTAG_STR)   { return 1; } return 0; }
# True if v is a JTAG_ARR value.
fn bayan_json_v_is_arr(v): i64 { if (v == 0) { return 0; } if (load64(v) == JTAG_ARR)   { return 1; } return 0; }
# True if v is a JTAG_OBJ value.
fn bayan_json_v_is_obj(v): i64 { if (v == 0) { return 0; } if (load64(v) == JTAG_OBJ)   { return 1; } return 0; }

# === Value accessors (INT/FLOAT coercion) ===

# Return v as i64 (0 or 1) if v is JTAG_BOOL, else 0.
fn bayan_json_v_bool(v): i64 {
    if (v == 0) { return 0; }
    if (load64(v) != JTAG_BOOL) { return 0; }
    return load64(v + 8);
}

# Return v as i64 — coerces JTAG_FLOAT via f64_to. Returns 0 on other tags.
fn bayan_json_v_int(v): i64 {
    if (v == 0) { return 0; }
    var t = load64(v);
    if (t == JTAG_INT) { return load64(v + 8); }
    if (t == JTAG_FLOAT) { return f64_to(load64(v + 8)); }
    return 0;
}

# Return v as f64 bit pattern — coerces JTAG_INT via f64_from. Returns f64_from(0) on other tags.
fn bayan_json_v_float(v): i64 {
    if (v == 0) { return 0; }
    var t = load64(v);
    if (t == JTAG_FLOAT) { return load64(v + 8); }
    if (t == JTAG_INT)   { return f64_from(load64(v + 8)); }
    return f64_from(0);
}

# Return v as Str ptr if v is JTAG_STR, else 0.
fn bayan_json_v_str(v): i64 {
    if (v == 0) { return 0; }
    if (load64(v) != JTAG_STR) { return 0; }
    return load64(v + 8);
}

# === Container accessors ===

# Return array length, or 0 if v is not JTAG_ARR.
fn bayan_json_v_arr_len(v): i64 {
    if (v == 0) { return 0; }
    if (load64(v) != JTAG_ARR) { return 0; }
    return vec_len(load64(v + 8));
}

# Return array element at index i (json_v* or 0 if out of range / wrong tag).
fn bayan_json_v_arr_get(v, i): i64 {
    if (v == 0) { return 0; }
    if (load64(v) != JTAG_ARR) { return 0; }
    var arr = load64(v + 8);
    if (i < 0) { return 0; }
    if (i >= vec_len(arr)) { return 0; }
    return vec_get(arr, i);
}

# Return object pair count, or 0 if v is not JTAG_OBJ.
fn bayan_json_v_obj_len(v): i64 {
    if (v == 0) { return 0; }
    if (load64(v) != JTAG_OBJ) { return 0; }
    return vec_len(load64(v + 8));
}

# Return the n-th object key (Str ptr or 0 if out of range / wrong tag).
fn bayan_json_v_obj_key(v, i): i64 {
    if (v == 0) { return 0; }
    if (load64(v) != JTAG_OBJ) { return 0; }
    var pairs = load64(v + 8);
    if (i < 0) { return 0; }
    if (i >= vec_len(pairs)) { return 0; }
    return load64(vec_get(pairs, i));
}

# Return the n-th object value (json_v* or 0 if out of range / wrong tag).
fn bayan_json_v_obj_val(v, i): i64 {
    if (v == 0) { return 0; }
    if (load64(v) != JTAG_OBJ) { return 0; }
    var pairs = load64(v + 8);
    if (i < 0) { return 0; }
    if (i >= vec_len(pairs)) { return 0; }
    return load64(vec_get(pairs, i) + 8);
}

# bayan_json_v_obj_get — lookup by C-string key. Returns json_v* or 0.
fn bayan_json_v_obj_get(v, key): i64 {
    if (v == 0) { return 0; }
    if (load64(v) != JTAG_OBJ) { return 0; }
    var pairs = load64(v + 8);
    var n = vec_len(pairs);
    var klen = strlen(key);
    var i = 0;
    while (i < n) {
        var p = vec_get(pairs, i);
        var ks = load64(p);
        if (str_len(ks) == klen) {
            if (memeq(str_data(ks), key, klen) == 1) {
                return load64(p + 8);
            }
        }
        i = i + 1;
    }
    return 0;
}

# === Parser state (single-threaded) ===
var _jp_buf = 0;
var _jp_len = 0;
var _jp_pos = 0;

fn _jp_set_err(msg): i64 {
    _json_err_msg = msg;
    _json_err_pos = _jp_pos;
    return 0;
}

# Skip whitespace (space, tab, LF, CR).
fn _jp_skip_ws(): i64 {
    while (_jp_pos < _jp_len) {
        var c = load8(_jp_buf + _jp_pos);
        if (c == 32 || c == 9 || c == 10 || c == 13) { _jp_pos = _jp_pos + 1; }
        else { return 0; }
    }
    return 0;
}

# Decode a hex digit (returns -1 if not a hex digit).
fn _jp_hex(c): i64 {
    if (c >= 48) { if (c <= 57)  { return c - 48; } }
    if (c >= 97) { if (c <= 102) { return c - 87; } }
    if (c >= 65) { if (c <= 70)  { return c - 55; } }
    return 0 - 1;
}

# Encode codepoint cp as UTF-8 into dst; return bytes written (1..4).
# Caller handles surrogate pairs before calling.
fn _jp_emit_utf8(dst, cp): i64 {
    if (cp < 128)    { store8(dst, cp); return 1; }
    if (cp < 2048)   {
        store8(dst, 192 | (cp >> 6));
        store8(dst + 1, 128 | (cp & 63));
        return 2;
    }
    if (cp < 65536)  {
        store8(dst, 224 | (cp >> 12));
        store8(dst + 1, 128 | ((cp >> 6) & 63));
        store8(dst + 2, 128 | (cp & 63));
        return 3;
    }
    store8(dst, 240 | (cp >> 18));
    store8(dst + 1, 128 | ((cp >> 12) & 63));
    store8(dst + 2, 128 | ((cp >> 6) & 63));
    store8(dst + 3, 128 | (cp & 63));
    return 4;
}

# Parse a JSON string starting at the opening quote. Returns Str* or 0.
# On entry, _jp_pos points at the `"`. On success, _jp_pos points just
# past the closing `"`.
fn _jp_parse_string(): i64 {
    if (_jp_pos >= _jp_len) { _jp_set_err("unexpected EOF in string"); return 0; }
    if (load8(_jp_buf + _jp_pos) != 34) { _jp_set_err("expected string"); return 0; }
    _jp_pos = _jp_pos + 1;
    # Worst case: every escape decoded to fewer bytes. Allocate input-len buf.
    var cap = _jp_len - _jp_pos + 1;
    var out = alloc(cap + 4);
    var oi = 0;
    while (1 == 1) {
        if (_jp_pos >= _jp_len) { _jp_set_err("unterminated string"); return 0; }
        var c = load8(_jp_buf + _jp_pos);
        if (c == 34) { _jp_pos = _jp_pos + 1; store8(out + oi, 0); return str_new(out, oi); }
        if (c == 92) {
            # Escape sequence
            _jp_pos = _jp_pos + 1;
            if (_jp_pos >= _jp_len) { _jp_set_err("unterminated escape"); return 0; }
            var e = load8(_jp_buf + _jp_pos);
            _jp_pos = _jp_pos + 1;
            if      (e == 34)  { store8(out + oi,  34); oi = oi + 1; }
            elif    (e == 92)  { store8(out + oi,  92); oi = oi + 1; }
            elif    (e == 47)  { store8(out + oi,  47); oi = oi + 1; }
            elif    (e == 98)  { store8(out + oi,   8); oi = oi + 1; }
            elif    (e == 102) { store8(out + oi,  12); oi = oi + 1; }
            elif    (e == 110) { store8(out + oi,  10); oi = oi + 1; }
            elif    (e == 114) { store8(out + oi,  13); oi = oi + 1; }
            elif    (e == 116) { store8(out + oi,   9); oi = oi + 1; }
            elif    (e == 117) {
                if (_jp_pos + 3 >= _jp_len) { _jp_set_err("\\u needs 4 hex digits"); return 0; }
                var d0 = _jp_hex(load8(_jp_buf + _jp_pos));
                var d1 = _jp_hex(load8(_jp_buf + _jp_pos + 1));
                var d2 = _jp_hex(load8(_jp_buf + _jp_pos + 2));
                var d3 = _jp_hex(load8(_jp_buf + _jp_pos + 3));
                if (d0 < 0 || d1 < 0 || d2 < 0 || d3 < 0) { _jp_set_err("\\u: bad hex digit"); return 0; }
                _jp_pos = _jp_pos + 4;
                var cp = (d0 << 12) | (d1 << 8) | (d2 << 4) | d3;
                # Surrogate pair handling
                if (cp >= 0xD800 && cp <= 0xDBFF) {
                    # High surrogate — expect low surrogate next
                    if (_jp_pos + 5 >= _jp_len) { _jp_set_err("incomplete surrogate pair"); return 0; }
                    if (load8(_jp_buf + _jp_pos) != 92 || load8(_jp_buf + _jp_pos + 1) != 117) {
                        _jp_set_err("expected low surrogate after high");
                        return 0;
                    }
                    _jp_pos = _jp_pos + 2;
                    var l0 = _jp_hex(load8(_jp_buf + _jp_pos));
                    var l1 = _jp_hex(load8(_jp_buf + _jp_pos + 1));
                    var l2 = _jp_hex(load8(_jp_buf + _jp_pos + 2));
                    var l3 = _jp_hex(load8(_jp_buf + _jp_pos + 3));
                    if (l0 < 0 || l1 < 0 || l2 < 0 || l3 < 0) { _jp_set_err("low surrogate: bad hex"); return 0; }
                    _jp_pos = _jp_pos + 4;
                    var lo = (l0 << 12) | (l1 << 8) | (l2 << 4) | l3;
                    if (lo < 0xDC00 || lo > 0xDFFF) { _jp_set_err("invalid low surrogate"); return 0; }
                    cp = 0x10000 + ((cp - 0xD800) << 10) + (lo - 0xDC00);
                }
                elif (cp >= 0xDC00 && cp <= 0xDFFF) {
                    _jp_set_err("unexpected low surrogate");
                    return 0;
                }
                oi = oi + _jp_emit_utf8(out + oi, cp);
            }
            else { _jp_set_err("unknown escape sequence"); return 0; }
        }
        else {
            # Ordinary byte
            store8(out + oi, c);
            oi = oi + 1;
            _jp_pos = _jp_pos + 1;
        }
    }
    return 0;
}

# Parse a number. Returns json_v* (INT or FLOAT) or 0.
fn _jp_parse_number(): i64 {
    var start = _jp_pos;
    var is_float = 0;
    # Optional minus
    if (_jp_pos < _jp_len && load8(_jp_buf + _jp_pos) == 45) { _jp_pos = _jp_pos + 1; }
    # Integer part
    while (_jp_pos < _jp_len) {
        var c = load8(_jp_buf + _jp_pos);
        if (c >= 48 && c <= 57) { _jp_pos = _jp_pos + 1; }
        else { break; }
    }
    # Fraction
    if (_jp_pos < _jp_len && load8(_jp_buf + _jp_pos) == 46) {
        is_float = 1;
        _jp_pos = _jp_pos + 1;
        while (_jp_pos < _jp_len) {
            var c2 = load8(_jp_buf + _jp_pos);
            if (c2 >= 48 && c2 <= 57) { _jp_pos = _jp_pos + 1; }
            else { break; }
        }
    }
    # Exponent
    if (_jp_pos < _jp_len) {
        var ec = load8(_jp_buf + _jp_pos);
        if (ec == 101 || ec == 69) {
            is_float = 1;
            _jp_pos = _jp_pos + 1;
            if (_jp_pos < _jp_len) {
                var sg = load8(_jp_buf + _jp_pos);
                if (sg == 43 || sg == 45) { _jp_pos = _jp_pos + 1; }
            }
            while (_jp_pos < _jp_len) {
                var c3 = load8(_jp_buf + _jp_pos);
                if (c3 >= 48 && c3 <= 57) { _jp_pos = _jp_pos + 1; }
                else { break; }
            }
        }
    }
    if (_jp_pos == start) { _jp_set_err("expected number"); return 0; }
    if (is_float == 1) {
        var fbits = _jp_atof(_jp_buf + start, _jp_pos - start);
        return bayan_json_v_float_new(fbits);
    }
    var iv = _jp_atoi(_jp_buf + start, _jp_pos - start);
    return bayan_json_v_int_new(iv);
}

# Parse a signed integer from buf[0..len). Returns i64.
fn _jp_atoi(buf, len): i64 {
    var i = 0;
    var sign = 1;
    if (len > 0 && load8(buf) == 45) { sign = 0 - 1; i = 1; }
    var n = 0;
    while (i < len) {
        n = n * 10 + (load8(buf + i) - 48);
        i = i + 1;
    }
    return sign * n;
}

# Parse a float from buf[0..len). Returns f64 bit pattern.
# Handles signed mantissa, optional fraction, optional signed exponent.
fn _jp_atof(buf, len): i64 {
    var i = 0;
    var sign = 1;
    if (len > 0 && load8(buf) == 45) { sign = 0 - 1; i = 1; }
    elif (len > 0 && load8(buf) == 43) { i = 1; }
    var int_part = f64_from(0);
    while (i < len) {
        var c = load8(buf + i);
        if (c < 48 || c > 57) { break; }
        int_part = f64_add(f64_mul(int_part, f64_from(10)), f64_from(c - 48));
        i = i + 1;
    }
    var frac_part = f64_from(0);
    var frac_div  = f64_from(1);
    if (i < len && load8(buf + i) == 46) {
        i = i + 1;
        while (i < len) {
            var c2 = load8(buf + i);
            if (c2 < 48 || c2 > 57) { break; }
            frac_part = f64_add(f64_mul(frac_part, f64_from(10)), f64_from(c2 - 48));
            frac_div  = f64_mul(frac_div, f64_from(10));
            i = i + 1;
        }
    }
    var val = f64_add(int_part, f64_div(frac_part, frac_div));
    if (i < len) {
        var ec = load8(buf + i);
        if (ec == 101 || ec == 69) {
            i = i + 1;
            var esign = 1;
            if (i < len && load8(buf + i) == 43) { i = i + 1; }
            elif (i < len && load8(buf + i) == 45) { esign = 0 - 1; i = i + 1; }
            var exp = 0;
            while (i < len) {
                var c3 = load8(buf + i);
                if (c3 < 48 || c3 > 57) { break; }
                exp = exp * 10 + (c3 - 48);
                i = i + 1;
            }
            var ei = 0;
            while (ei < exp) {
                if (esign > 0) { val = f64_mul(val, f64_from(10)); }
                else           { val = f64_div(val, f64_from(10)); }
                ei = ei + 1;
            }
        }
    }
    if (sign < 0) { val = f64_sub(f64_from(0), val); }
    return val;
}

# === Main parse entry ===

# Recursive value parser. Returns json_v* or 0.
fn _jp_parse_value(): i64 {
    _jp_skip_ws();
    if (_jp_pos >= _jp_len) { _jp_set_err("unexpected EOF"); return 0; }
    var c = load8(_jp_buf + _jp_pos);
    if (c == 123) { return _jp_parse_object(); }
    if (c == 91)  { return _jp_parse_array(); }
    if (c == 34)  {
        var s = _jp_parse_string();
        if (s == 0) { return 0; }
        return bayan_json_v_str_new(s);
    }
    if (c == 116) {
        if (_jp_pos + 3 < _jp_len && memeq(_jp_buf + _jp_pos + 1, "rue", 3) == 1) {
            _jp_pos = _jp_pos + 4;
            return bayan_json_v_bool_new(1);
        }
        _jp_set_err("expected 'true'"); return 0;
    }
    if (c == 102) {
        if (_jp_pos + 4 < _jp_len && memeq(_jp_buf + _jp_pos + 1, "alse", 4) == 1) {
            _jp_pos = _jp_pos + 5;
            return bayan_json_v_bool_new(0);
        }
        _jp_set_err("expected 'false'"); return 0;
    }
    if (c == 110) {
        if (_jp_pos + 3 < _jp_len && memeq(_jp_buf + _jp_pos + 1, "ull", 3) == 1) {
            _jp_pos = _jp_pos + 4;
            return bayan_json_v_null();
        }
        _jp_set_err("expected 'null'"); return 0;
    }
    if (c == 45 || (c >= 48 && c <= 57)) {
        return _jp_parse_number();
    }
    _jp_set_err("unexpected character");
    return 0;
}

fn _jp_parse_array(): i64 {
    if (load8(_jp_buf + _jp_pos) != 91) { _jp_set_err("expected '['"); return 0; }
    _jp_pos = _jp_pos + 1;
    var arr = bayan_json_v_arr_new();
    _jp_skip_ws();
    if (_jp_pos < _jp_len && load8(_jp_buf + _jp_pos) == 93) {
        _jp_pos = _jp_pos + 1;
        return arr;
    }
    while (1 == 1) {
        var v = _jp_parse_value();
        if (v == 0) { return 0; }
        bayan_json_v_arr_push(arr, v);
        _jp_skip_ws();
        if (_jp_pos >= _jp_len) { _jp_set_err("unterminated array"); return 0; }
        var c = load8(_jp_buf + _jp_pos);
        if (c == 44) { _jp_pos = _jp_pos + 1; _jp_skip_ws(); }
        elif (c == 93) { _jp_pos = _jp_pos + 1; return arr; }
        else { _jp_set_err("expected ',' or ']'"); return 0; }
    }
    return 0;
}

fn _jp_parse_object(): i64 {
    if (load8(_jp_buf + _jp_pos) != 123) { _jp_set_err("expected '{'"); return 0; }
    _jp_pos = _jp_pos + 1;
    var obj = bayan_json_v_obj_new();
    _jp_skip_ws();
    if (_jp_pos < _jp_len && load8(_jp_buf + _jp_pos) == 125) {
        _jp_pos = _jp_pos + 1;
        return obj;
    }
    while (1 == 1) {
        _jp_skip_ws();
        var k = _jp_parse_string();
        if (k == 0) { return 0; }
        _jp_skip_ws();
        if (_jp_pos >= _jp_len) { _jp_set_err("unterminated object"); return 0; }
        if (load8(_jp_buf + _jp_pos) != 58) { _jp_set_err("expected ':' after key"); return 0; }
        _jp_pos = _jp_pos + 1;
        _jp_skip_ws();
        var val = _jp_parse_value();
        if (val == 0) { return 0; }
        bayan_json_v_obj_set(obj, k, val);
        _jp_skip_ws();
        if (_jp_pos >= _jp_len) { _jp_set_err("unterminated object"); return 0; }
        var c = load8(_jp_buf + _jp_pos);
        if (c == 44) { _jp_pos = _jp_pos + 1; }
        elif (c == 125) { _jp_pos = _jp_pos + 1; return obj; }
        else { _jp_set_err("expected ',' or '}'"); return 0; }
    }
    return 0;
}

# Public parse entry — Str. Returns json_v* or 0.
fn bayan_json_v_parse(src): i64 {
    if (src == 0) { _json_err_msg = "null source"; _json_err_pos = 0; return 0; }
    return bayan_json_v_parse_str(str_data(src), str_len(src));
}

# Public parse entry — explicit cstr+len.
fn bayan_json_v_parse_str(buf, len): i64 {
    _jp_buf = buf;
    _jp_len = len;
    _jp_pos = 0;
    _json_err_msg = 0;
    _json_err_pos = 0;
    var v = _jp_parse_value();
    if (v == 0) { return 0; }
    _jp_skip_ws();
    if (_jp_pos != _jp_len) {
        _json_err_msg = "trailing content after JSON value";
        _json_err_pos = _jp_pos;
        return 0;
    }
    return v;
}

# === Serializer ===

# Append a JSON-escaped string into sb, including the surrounding quotes.
fn _jb_append_string(sb, s): i64 {
    str_builder_add_cstr(sb, "\"");
    var data = str_data(s);
    var slen = str_len(s);
    var i = 0;
    while (i < slen) {
        var c = load8(data + i);
        if      (c == 34) { str_builder_add_cstr(sb, "\\\""); }
        elif    (c == 92) { str_builder_add_cstr(sb, "\\\\"); }
        elif    (c ==  8) { str_builder_add_cstr(sb, "\\b"); }
        elif    (c == 12) { str_builder_add_cstr(sb, "\\f"); }
        elif    (c == 10) { str_builder_add_cstr(sb, "\\n"); }
        elif    (c == 13) { str_builder_add_cstr(sb, "\\r"); }
        elif    (c ==  9) { str_builder_add_cstr(sb, "\\t"); }
        elif    (c < 32) {
            # Control char — emit \u00XX
            str_builder_add_cstr(sb, "\\u00");
            var hi = c >> 4;
            var lo = c & 15;
            var hb[3];
            if (hi < 10) { store8(&hb, 48 + hi); } else { store8(&hb, 87 + hi); }
            if (lo < 10) { store8(&hb + 1, 48 + lo); } else { store8(&hb + 1, 87 + lo); }
            store8(&hb + 2, 0);
            str_builder_add_cstr(sb, &hb);
        }
        else {
            var bb[2];
            store8(&bb, c);
            store8(&bb + 1, 0);
            str_builder_add_cstr(sb, &bb);
        }
        i = i + 1;
    }
    str_builder_add_cstr(sb, "\"");
    return 0;
}

# Emit '\n' followed by (indent * level) spaces. Pretty-mode helper.
fn _jb_emit_indent(sb, indent, level): i64 {
    str_builder_add_byte(sb, 10);
    var total = indent * level;
    var i = 0;
    while (i < total) {
        str_builder_add_byte(sb, 32);
        i = i + 1;
    }
    return 0;
}

# Unified compact + pretty walker. `indent` param drives mode:
# 0 = compact (":" separator), >0 = pretty (newlines, ": ").
# `if n > 0` guards empty-container case for both modes.
# See CHANGELOG [5.7.47].
fn _jb_walk(sb, v, indent, level): i64 {
    if (v == 0) { str_builder_add_cstr(sb, "null"); return 0; }
    var t = load64(v);
    if      (t == JTAG_NULL)  { str_builder_add_cstr(sb, "null"); }
    elif    (t == JTAG_BOOL)  {
        if (load64(v + 8) == 0) { str_builder_add_cstr(sb, "false"); }
        else                    { str_builder_add_cstr(sb, "true");  }
    }
    elif    (t == JTAG_INT)   {
        var nb[24];
        var nl = fmt_int_buf(load64(v + 8), &nb);
        store8(&nb + nl, 0);
        str_builder_add_cstr(sb, &nb);
    }
    elif    (t == JTAG_FLOAT) {
        var fb[64];
        var fl = fmt_float_buf(load64(v + 8), &fb, 6);
        store8(&fb + fl, 0);
        str_builder_add_cstr(sb, &fb);
    }
    elif    (t == JTAG_STR)   { _jb_append_string(sb, load64(v + 8)); }
    elif    (t == JTAG_ARR)   {
        str_builder_add_cstr(sb, "[");
        var arr = load64(v + 8);
        var n = vec_len(arr);
        if (n > 0) {
            var i = 0;
            while (i < n) {
                if (i > 0) { str_builder_add_cstr(sb, ","); }
                if (indent > 0) { _jb_emit_indent(sb, indent, level + 1); }
                _jb_walk(sb, vec_get(arr, i), indent, level + 1);
                i = i + 1;
            }
            if (indent > 0) { _jb_emit_indent(sb, indent, level); }
        }
        str_builder_add_cstr(sb, "]");
    }
    elif    (t == JTAG_OBJ)   {
        str_builder_add_cstr(sb, "{");
        var pairs = load64(v + 8);
        var pn = vec_len(pairs);
        if (pn > 0) {
            var pi = 0;
            while (pi < pn) {
                if (pi > 0) { str_builder_add_cstr(sb, ","); }
                if (indent > 0) { _jb_emit_indent(sb, indent, level + 1); }
                var p = vec_get(pairs, pi);
                _jb_append_string(sb, load64(p));
                if (indent > 0) { str_builder_add_cstr(sb, ": "); }
                else            { str_builder_add_cstr(sb, ":");  }
                _jb_walk(sb, load64(p + 8), indent, level + 1);
                pi = pi + 1;
            }
            if (indent > 0) { _jb_emit_indent(sb, indent, level); }
        }
        str_builder_add_cstr(sb, "}");
    }
    else {
        str_builder_add_cstr(sb, "null");
    }
    return 0;
}

# bayan_json_v_build — serialize a tagged value tree to a Str (compact).
fn bayan_json_v_build(v): i64 {
    var sb = str_builder_new();
    _jb_walk(sb, v, 0, 0);
    return str_builder_build(sb);
}

# bayan_json_v_build_pretty — serialize a tagged value tree with newlines + indent.
# `indent` is the spaces per level; `indent <= 0` falls back to compact.
fn bayan_json_v_build_pretty(v, indent): i64 {
    if (indent <= 0) { return bayan_json_v_build(v); }
    var sb = str_builder_new();
    _jb_walk(sb, v, indent, 0);
    return str_builder_build(sb);
}

# ======================================================================
# STREAMING PARSER (v5.7.41) — event-driven, no tree allocation
# ======================================================================
#
# For multi-MB JSON inputs that don't fit the tagged-tree memory model.
# Caller allocates a handler struct, fills in the callbacks they care
# about (others stay 0 = no-op), and the driver fires events as it walks.
#
# Handler layout (96 bytes):
#   +0   ctx              user pointer (1st arg to every callback)
#   +8   on_object_start  fnptr or 0  fncall1(ctx)
#   +16  on_object_end    fnptr or 0  fncall1(ctx)
#   +24  on_array_start   fnptr or 0  fncall1(ctx)
#   +32  on_array_end     fnptr or 0  fncall1(ctx)
#   +40  on_key           fnptr or 0  fncall2(ctx, key_str)
#   +48  on_string        fnptr or 0  fncall2(ctx, value_str)
#   +56  on_int           fnptr or 0  fncall2(ctx, value_i64)
#   +64  on_float         fnptr or 0  fncall2(ctx, value_f64_bits)
#   +72  on_bool          fnptr or 0  fncall2(ctx, value_0_or_1)
#   +80  on_null          fnptr or 0  fncall1(ctx)
#   +88  on_error         fnptr or 0  fncall3(ctx, msg_cstr, pos)
#
# Lex state shared with the tree parser (_jp_buf / _jp_len / _jp_pos +
# _json_err_msg / _json_err_pos), so existing helpers _jp_skip_ws,
# _jp_parse_string, _jp_atoi, _jp_atof, _jp_set_err are reused as-is.
# This keeps the streaming surface ~210 LOC instead of ~400.

var JS_EV_OBJECT_START = 0;
var JS_EV_OBJECT_END   = 1;
var JS_EV_ARRAY_START  = 2;
var JS_EV_ARRAY_END    = 3;
var JS_EV_KEY          = 4;
var JS_EV_STRING       = 5;
var JS_EV_INT          = 6;
var JS_EV_FLOAT        = 7;
var JS_EV_BOOL         = 8;
var JS_EV_NULL         = 9;
var JS_EV_ERROR        = 10;
var JS_EV_COUNT        = 11;

var _JS_HANDLER_SIZE = 96;

# Allocate a handler with all callback slots 0 (no-op). `ctx` is the
# user pointer threaded through every callback as its first argument.
fn bayan_json_stream_handler_new(ctx): i64 {
    var h = alloc(_JS_HANDLER_SIZE);
    var i = 0;
    while (i < _JS_HANDLER_SIZE) { store64(h + i, 0); i = i + 8; }
    store64(h, ctx);
    return h;
}

# Bind callback `fp` to event `event_id`. Returns 0 on success, -1 on
# bad event_id. Pass fp=0 to clear an event.
fn bayan_json_stream_on(h, event_id, fp): i64 {
    if (event_id < 0 || event_id >= JS_EV_COUNT) { return 0 - 1; }
    store64(h + 8 + event_id * 8, fp);
    return 0;
}

fn _js_ctx(h): i64 { return load64(h); }
fn _js_cb(h, event_id): i64 { return load64(h + 8 + event_id * 8); }

# Set last-error globals + fire on_error if registered.
fn _js_emit_error(h, msg): i64 {
    _json_err_msg = msg;
    _json_err_pos = _jp_pos;
    var fp = _js_cb(h, JS_EV_ERROR);
    if (fp != 0) { fncall3(fp, _js_ctx(h), msg, _jp_pos); }
    return 0;
}

# Relay a _jp_set_err-set error through to on_error (for paths that
# call _jp_parse_string and get a 0 back — error globals are already
# populated, just need to forward).
fn _js_relay_err(h): i64 {
    var fp = _js_cb(h, JS_EV_ERROR);
    if (fp != 0) { fncall3(fp, _js_ctx(h), _json_err_msg, _json_err_pos); }
    return 0;
}

# Number parser — mirrors _jp_parse_number's lex but emits via
# callback instead of allocating json_v*. Returns 0 on success, -1 on
# error.
fn _js_parse_number(h): i64 {
    var start = _jp_pos;
    var is_float = 0;
    if (_jp_pos < _jp_len && load8(_jp_buf + _jp_pos) == 45) { _jp_pos = _jp_pos + 1; }
    while (_jp_pos < _jp_len) {
        var c = load8(_jp_buf + _jp_pos);
        if (c >= 48 && c <= 57) { _jp_pos = _jp_pos + 1; }
        else { break; }
    }
    if (_jp_pos < _jp_len && load8(_jp_buf + _jp_pos) == 46) {
        is_float = 1;
        _jp_pos = _jp_pos + 1;
        while (_jp_pos < _jp_len) {
            var c2 = load8(_jp_buf + _jp_pos);
            if (c2 >= 48 && c2 <= 57) { _jp_pos = _jp_pos + 1; }
            else { break; }
        }
    }
    if (_jp_pos < _jp_len) {
        var ec = load8(_jp_buf + _jp_pos);
        if (ec == 101 || ec == 69) {
            is_float = 1;
            _jp_pos = _jp_pos + 1;
            if (_jp_pos < _jp_len) {
                var sg = load8(_jp_buf + _jp_pos);
                if (sg == 43 || sg == 45) { _jp_pos = _jp_pos + 1; }
            }
            while (_jp_pos < _jp_len) {
                var c3 = load8(_jp_buf + _jp_pos);
                if (c3 >= 48 && c3 <= 57) { _jp_pos = _jp_pos + 1; }
                else { break; }
            }
        }
    }
    if (_jp_pos == start) { _js_emit_error(h, "expected number"); return 0 - 1; }
    if (is_float == 1) {
        var fbits = _jp_atof(_jp_buf + start, _jp_pos - start);
        var fp_f = _js_cb(h, JS_EV_FLOAT);
        if (fp_f != 0) { fncall2(fp_f, _js_ctx(h), fbits); }
    } else {
        var iv = _jp_atoi(_jp_buf + start, _jp_pos - start);
        var fp_i = _js_cb(h, JS_EV_INT);
        if (fp_i != 0) { fncall2(fp_i, _js_ctx(h), iv); }
    }
    return 0;
}

fn _js_parse_array(h): i64 {
    if (load8(_jp_buf + _jp_pos) != 91) { _js_emit_error(h, "expected '['"); return 0 - 1; }
    _jp_pos = _jp_pos + 1;
    var fp_s = _js_cb(h, JS_EV_ARRAY_START);
    if (fp_s != 0) { fncall1(fp_s, _js_ctx(h)); }
    _jp_skip_ws();
    if (_jp_pos < _jp_len && load8(_jp_buf + _jp_pos) == 93) {
        _jp_pos = _jp_pos + 1;
        var fp_e = _js_cb(h, JS_EV_ARRAY_END);
        if (fp_e != 0) { fncall1(fp_e, _js_ctx(h)); }
        return 0;
    }
    while (1 == 1) {
        if (_js_parse_value(h) != 0) { return 0 - 1; }
        _jp_skip_ws();
        if (_jp_pos >= _jp_len) { _js_emit_error(h, "unterminated array"); return 0 - 1; }
        var c = load8(_jp_buf + _jp_pos);
        if (c == 44) { _jp_pos = _jp_pos + 1; _jp_skip_ws(); }
        elif (c == 93) {
            _jp_pos = _jp_pos + 1;
            var fp_e2 = _js_cb(h, JS_EV_ARRAY_END);
            if (fp_e2 != 0) { fncall1(fp_e2, _js_ctx(h)); }
            return 0;
        } else { _js_emit_error(h, "expected ',' or ']'"); return 0 - 1; }
    }
    return 0;
}

fn _js_parse_object(h): i64 {
    if (load8(_jp_buf + _jp_pos) != 123) { _js_emit_error(h, "expected '{'"); return 0 - 1; }
    _jp_pos = _jp_pos + 1;
    var fp_s = _js_cb(h, JS_EV_OBJECT_START);
    if (fp_s != 0) { fncall1(fp_s, _js_ctx(h)); }
    _jp_skip_ws();
    if (_jp_pos < _jp_len && load8(_jp_buf + _jp_pos) == 125) {
        _jp_pos = _jp_pos + 1;
        var fp_e = _js_cb(h, JS_EV_OBJECT_END);
        if (fp_e != 0) { fncall1(fp_e, _js_ctx(h)); }
        return 0;
    }
    while (1 == 1) {
        _jp_skip_ws();
        var k = _jp_parse_string();
        if (k == 0) { _js_relay_err(h); return 0 - 1; }
        var fp_k = _js_cb(h, JS_EV_KEY);
        if (fp_k != 0) { fncall2(fp_k, _js_ctx(h), k); }
        _jp_skip_ws();
        if (_jp_pos >= _jp_len) { _js_emit_error(h, "unterminated object"); return 0 - 1; }
        if (load8(_jp_buf + _jp_pos) != 58) { _js_emit_error(h, "expected ':' after key"); return 0 - 1; }
        _jp_pos = _jp_pos + 1;
        if (_js_parse_value(h) != 0) { return 0 - 1; }
        _jp_skip_ws();
        if (_jp_pos >= _jp_len) { _js_emit_error(h, "unterminated object"); return 0 - 1; }
        var c = load8(_jp_buf + _jp_pos);
        if (c == 44) { _jp_pos = _jp_pos + 1; }
        elif (c == 125) {
            _jp_pos = _jp_pos + 1;
            var fp_e2 = _js_cb(h, JS_EV_OBJECT_END);
            if (fp_e2 != 0) { fncall1(fp_e2, _js_ctx(h)); }
            return 0;
        } else { _js_emit_error(h, "expected ',' or '}'"); return 0 - 1; }
    }
    return 0;
}

fn _js_parse_value(h): i64 {
    _jp_skip_ws();
    if (_jp_pos >= _jp_len) { _js_emit_error(h, "unexpected EOF"); return 0 - 1; }
    var c = load8(_jp_buf + _jp_pos);
    if (c == 123) { return _js_parse_object(h); }
    if (c == 91)  { return _js_parse_array(h); }
    if (c == 34)  {
        var s = _jp_parse_string();
        if (s == 0) { _js_relay_err(h); return 0 - 1; }
        var fp_s = _js_cb(h, JS_EV_STRING);
        if (fp_s != 0) { fncall2(fp_s, _js_ctx(h), s); }
        return 0;
    }
    if (c == 116) {
        if (_jp_pos + 3 < _jp_len && memeq(_jp_buf + _jp_pos + 1, "rue", 3) == 1) {
            _jp_pos = _jp_pos + 4;
            var fp_b = _js_cb(h, JS_EV_BOOL);
            if (fp_b != 0) { fncall2(fp_b, _js_ctx(h), 1); }
            return 0;
        }
        _js_emit_error(h, "expected 'true'");
        return 0 - 1;
    }
    if (c == 102) {
        if (_jp_pos + 4 < _jp_len && memeq(_jp_buf + _jp_pos + 1, "alse", 4) == 1) {
            _jp_pos = _jp_pos + 5;
            var fp_b = _js_cb(h, JS_EV_BOOL);
            if (fp_b != 0) { fncall2(fp_b, _js_ctx(h), 0); }
            return 0;
        }
        _js_emit_error(h, "expected 'false'");
        return 0 - 1;
    }
    if (c == 110) {
        if (_jp_pos + 3 < _jp_len && memeq(_jp_buf + _jp_pos + 1, "ull", 3) == 1) {
            _jp_pos = _jp_pos + 4;
            var fp_n = _js_cb(h, JS_EV_NULL);
            if (fp_n != 0) { fncall1(fp_n, _js_ctx(h)); }
            return 0;
        }
        _js_emit_error(h, "expected 'null'");
        return 0 - 1;
    }
    if (c == 45 || (c >= 48 && c <= 57)) {
        return _js_parse_number(h);
    }
    _js_emit_error(h, "unexpected character");
    return 0 - 1;
}

# Public stream-parse entry — explicit cstr+len+handler. Returns 0 on
# success, -1 on error. After error, callers can read bayan_json_last_error()
# and bayan_json_last_error_pos(); the JS_EV_ERROR callback (if registered)
# already fired.
fn bayan_json_stream_parse(buf, len, h): i64 {
    _jp_buf = buf;
    _jp_len = len;
    _jp_pos = 0;
    _json_err_msg = 0;
    _json_err_pos = 0;
    if (_js_parse_value(h) != 0) { return 0 - 1; }
    _jp_skip_ws();
    if (_jp_pos != _jp_len) {
        _js_emit_error(h, "trailing content after JSON value");
        return 0 - 1;
    }
    return 0;
}

# Convenience: stream-parse from a Str.
fn bayan_json_stream_parse_str(src, h): i64 {
    if (src == 0) { _json_err_msg = "null source"; _json_err_pos = 0; return 0 - 1; }
    return bayan_json_stream_parse(str_data(src), str_len(src), h);
}

# ======================================================================
# JSON POINTER (v5.7.42, RFC 6901)
# ======================================================================
#
# Walk the tagged tree by slash-separated path. Returns the referenced
# json_v* or 0 (not found / invalid pointer / can't descend into scalar).
#
# Empty pointer ""           → whole document
# "/foo"                     → root["foo"]
# "/foo/0/bar"               → root["foo"][0]["bar"]
# "/" (just slash)           → root[""] (empty-string key)
# "/a/"                      → a[""] (trailing-slash empty token)
#
# Tokens are unescaped per RFC 6901 §3: "~1" → "/", "~0" → "~". The
# left-to-right single-pass unescape below is equivalent to the spec's
# two-pass "~1 then ~0" order — only "~0" and "~1" are valid escapes,
# so any other "~X" is an error and returns 0.
#
# Array tokens must match `0|[1-9][0-9]*` per RFC 6901 §4. The "-"
# (next-element) token is append-only and has no read meaning, so
# it returns 0.

# Look up (buf, len) as a key in OBJ value `v`. Length-explicit so
# tokens with interior NUL bytes (theoretical via `\u0000`) still match.
fn _jp_obj_lookup(v, buf, len): i64 {
    if (load64(v) != JTAG_OBJ) { return 0; }
    var pairs = load64(v + 8);
    var n = vec_len(pairs);
    var i = 0;
    while (i < n) {
        var p = vec_get(pairs, i);
        var ks = load64(p);
        if (str_len(ks) == len) {
            if (memeq(str_data(ks), buf, len) == 1) {
                return load64(p + 8);
            }
        }
        i = i + 1;
    }
    return 0;
}

# Parse (buf, len) as a strict array index per RFC 6901 §4. Returns
# index >= 0, or -1 on invalid (leading zero, non-digit, empty,
# the "-" next-element token, etc.).
fn _jp_parse_idx(buf, len): i64 {
    if (len == 0) { return 0 - 1; }
    var c0 = load8(buf);
    if (c0 == 48) { if (len == 1) { return 0; } return 0 - 1; }
    if (c0 < 49 || c0 > 57) { return 0 - 1; }
    var n = c0 - 48;
    var i = 1;
    while (i < len) {
        var c = load8(buf + i);
        if (c < 48 || c > 57) { return 0 - 1; }
        n = n * 10 + (c - 48);
        i = i + 1;
    }
    return n;
}

# Unescape one reference token from (src, src_len) into a freshly
# allocated buffer. Layout: u64 length prefix at offset 0, decoded
# bytes from offset 8, NUL byte at offset 8+len. Returns the alloc
# pointer, or 0 on bad escape (lone "~" or "~X" where X != 0/1).
fn _jp_token_unescape(src, src_len): i64 {
    var out = alloc(src_len + 8 + 1);
    var oi = 0;
    var i = 0;
    while (i < src_len) {
        var c = load8(src + i);
        if (c == 126) {
            i = i + 1;
            if (i >= src_len) { return 0; }
            var e = load8(src + i);
            if      (e == 48) { store8(out + 8 + oi, 126); oi = oi + 1; }
            elif    (e == 49) { store8(out + 8 + oi,  47); oi = oi + 1; }
            else { return 0; }
            i = i + 1;
        } else {
            store8(out + 8 + oi, c);
            oi = oi + 1;
            i = i + 1;
        }
    }
    store8(out + 8 + oi, 0);
    store64(out, oi);
    return out;
}

# Public entry — explicit buf+len pointer string.
fn bayan_json_v_pointer_cstr(v, ptr, plen): i64 {
    if (v == 0) { return 0; }
    if (plen == 0) { return v; }
    if (load8(ptr) != 47) { return 0; }   # must start with '/'
    var pos = 1;
    var cur = v;
    while (pos <= plen) {
        var start = pos;
        while (pos < plen) {
            if (load8(ptr + pos) == 47) { break; }
            pos = pos + 1;
        }
        var tok_len = pos - start;
        var ub = _jp_token_unescape(ptr + start, tok_len);
        if (ub == 0) { return 0; }
        var ulen = load64(ub);
        var ubuf = ub + 8;
        if (cur == 0) { return 0; }
        var t = load64(cur);
        if (t == JTAG_OBJ) {
            cur = _jp_obj_lookup(cur, ubuf, ulen);
        } elif (t == JTAG_ARR) {
            var idx = _jp_parse_idx(ubuf, ulen);
            if (idx < 0) { return 0; }
            cur = bayan_json_v_arr_get(cur, idx);
        } else {
            return 0;
        }
        if (cur == 0) { return 0; }
        if (pos == plen) { return cur; }
        pos = pos + 1;
    }
    return cur;
}

# Convenience: pointer as a Str.
fn bayan_json_v_pointer(v, ptr): i64 {
    if (ptr == 0) { return v; }
    return bayan_json_v_pointer_cstr(v, str_data(ptr), str_len(ptr));
}

# --- _compat.cyr ---

# bayan back-compat aliases (v6.1.25 carve).
# Forwards the legacy cyrius-stdlib names (json_* / toml_* / u256_* / ...)
# to the canonical bayan_* API. Deprecated — for the downstream
# migration window only; will be removed once consumers re-pin.
# See CHANGELOG [bayan 1.0.0] / cyrius [6.1.25].

fn json_pair_new_a(a, key, value): i64 { return bayan_json_pair_new_a(a, key, value); }
fn json_pair_new(key, value): i64 { return bayan_json_pair_new(key, value); }
fn json_key(p): i64 { return bayan_json_key(p); }
fn json_value(p): i64 { return bayan_json_value(p); }
