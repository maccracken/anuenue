fn aentry_set_result(e, v)              { store64(e + 48, v); return 0; }
fn aentry_set_details(e, v: Str)        { store64(e + 56, v); return 0; }
fn aentry_set_user_id(e, v: Str)        { store64(e + 64, v); return 0; }
fn aentry_set_source_ip(e, v: Str)      { store64(e + 72, v); return 0; }
fn aentry_set_target_resource(e, v: Str){ store64(e + 80, v); return 0; }
