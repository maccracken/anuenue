# --- mcp.cyr ---

# sandhi/rpc/mcp — MCP-over-HTTP transport dialect.
#
# MCP (Model Context Protocol) wire format is JSON-RPC 2.0 over HTTP
# POST. sandhi owns the transport: envelope construction, request-ID
# counter, error extraction. **Protocol semantics — tool discovery,
# prompt schemas, sampling responses — stay in bote + t-ron** per
# ADR 0001. Consumers of this module get "sent a JSON-RPC call; got
# a response"; the payload-shape negotiation is above sandhi's layer.
#
# Reference: https://modelcontextprotocol.io/specification/basic/transports#http

# ================================================================
# Request-ID counter — one per process. JSON-RPC 2.0 requires a
# unique ID per outstanding request; for the HTTP-one-shot case
# (sync request/response), monotonic counter is sufficient.
# ================================================================

var _sandhi_mcp_next_id = 1;

fn _sandhi_mcp_alloc_id(): i64 {
    var id = _sandhi_mcp_next_id;
    _sandhi_mcp_next_id = _sandhi_mcp_next_id + 1;
    return id;
}

# ================================================================
# Envelope build — JSON-RPC 2.0 request.
# ================================================================
#
# Shape:  {"jsonrpc":"2.0","id":N,"method":"<name>","params":{...}}
# `params_json` is a pre-built cstr including braces (or 0 for none).
# Return value: wire-ready request body (cstr).

fn _sandhi_mcp_build_request_a(a, method, params_json): i64 {
    var id = _sandhi_mcp_alloc_id();
    var o = sandhi_json_obj_new_a(a);
    # 1.2.6 OOM guard. Returning 0 here is propagated through the
    # callers (sandhi_rpc_mcp_call_a etc.) — they pass the (possibly
    # 0) build result as `body_json` to `sandhi_rpc_call_a`, which
    # already null-checks and sends bodyless on 0.
    if (o == 0) { return 0; }
    sandhi_json_add_string_a(a, o, "jsonrpc", "2.0");
    sandhi_json_add_int_a(a, o, "id", id);
    sandhi_json_add_string_a(a, o, "method", method);
    if (params_json != 0) {
        sandhi_json_add_raw_a(a, o, "params", params_json);
    }
    return sandhi_json_build_a(a, o);
}

fn _sandhi_mcp_build_request(method, params_json): i64 {
    return _sandhi_mcp_build_request_a(default_alloc(), method, params_json);
}

# ================================================================
# Call — POST the envelope, return rpc-response.
# ================================================================

# sandhi_rpc_mcp_call(endpoint_url, method_name, params_json)
#   - endpoint_url: full URL of the MCP endpoint (e.g.
#     "http://daimon.local:9000/mcp")
#   - method_name: JSON-RPC method name ("tools/list", "resources/read", …)
#   - params_json: cstr of pre-built params object (including braces),
#     or 0 if the method takes no params.
#
# Returns an rpc-response struct. sandhi_rpc_ok(r) == 1 on success.
# The response body is the full JSON-RPC response — caller navigates
# `result.<field>` or `error.<field>` per protocol spec.
fn sandhi_rpc_mcp_call_a(a, endpoint_url, method_name, params_json): i64 {
    var body = _sandhi_mcp_build_request_a(a, method_name, params_json);
    return sandhi_rpc_call_a(a, endpoint_url, "POST", body, SANDHI_RPC_DIALECT_JSONRPC);
}

fn sandhi_rpc_mcp_call(endpoint_url, method_name, params_json): i64 {
    return sandhi_rpc_mcp_call_a(default_alloc(), endpoint_url, method_name, params_json);
}

# Variant accepting caller-supplied headers (auth tokens etc.).
fn sandhi_rpc_mcp_call_with_headers_a(a, endpoint_url, method_name, params_json, user_headers): i64 {
    var body = _sandhi_mcp_build_request_a(a, method_name, params_json);
    return sandhi_rpc_call_with_headers_a(a, endpoint_url, "POST", body, user_headers, SANDHI_RPC_DIALECT_JSONRPC);
}

fn sandhi_rpc_mcp_call_with_headers(endpoint_url, method_name, params_json, user_headers): i64 {
    return sandhi_rpc_mcp_call_with_headers_a(default_alloc(), endpoint_url, method_name, params_json, user_headers);
}

# ================================================================
# Response helpers — transport-level only.
# ================================================================

# Extract the `result` value as a raw JSON cstr (may be an object).
# Returns 0 if the response didn't contain a result (e.g. was an error).
# Callers doing protocol-level work (bote / t-ron) re-parse this into
# the typed shape they want.
fn sandhi_rpc_mcp_result_raw_a(a, resp): i64 {
    var body = sandhi_rpc_body(resp);
    if (body == 0) { return 0; }
    return sandhi_json_get_string_a(a, body, "result");
}

fn sandhi_rpc_mcp_result_raw(resp): i64 {
    return sandhi_rpc_mcp_result_raw_a(default_alloc(), resp);
}

# Extract the JSON-RPC error code. Returns 0 on success (no error).
# (A legitimate error code of 0 is not defined by JSON-RPC 2.0 —
# standard codes are -32600/-32601/-32602/-32603/-32700 plus
# -32000..-32099 for implementation-defined.)
fn sandhi_rpc_mcp_error_code(resp): i64 {
    var body = sandhi_rpc_body(resp);
    if (body == 0) { return 0; }
    return sandhi_json_get_int(body, "error.code");
}

# Extract the JSON-RPC error message. Returns 0 if no error envelope.
fn sandhi_rpc_mcp_error_message_a(a, resp): i64 {
    var body = sandhi_rpc_body(resp);
    if (body == 0) { return 0; }
    return sandhi_json_get_string_a(a, body, "error.message");
}

fn sandhi_rpc_mcp_error_message(resp): i64 {
    return sandhi_rpc_mcp_error_message_a(default_alloc(), resp);
}

# ================================================================
# Streaming — SSE-wrapped JSON-RPC notifications
# ================================================================
#
# Some MCP servers expose long-lived endpoints that stream
# JSON-RPC notifications (tools/progress updates, resource change
# events) as Server-Sent Events. `sandhi_rpc_mcp_stream` sends the
# initial request and drives the SSE-feeding callback loop until
# the callback stops it or the stream closes.
#
# Callback signature: fn cb(ctx, sse_event) -> int (1 = continue, 0 = stop).
# The callback receives `sandhi_sse_event` structs; `sandhi_sse_event_data(e)`
# is the raw JSON payload the server pushed.

fn sandhi_rpc_mcp_stream_a(a, endpoint_url, method_name, params_json, cb, ctx): i64 {
    var body = _sandhi_mcp_build_request_a(a, method_name, params_json);
    # 1.2.6 OOM guard. `strlen(0)` would walk past 0; if the JSON
    # build OOM'd, bail. `sandhi_http_stream_a` returns a stream-
    # result struct so we mirror its err shape via the helper that
    # `_sandhi_stream_result_a` exposes (or 0 fallback if even that
    # OOMs in the same allocator).
    if (body == 0) { return _sandhi_stream_result_a(a, 0, 0, SANDHI_ERR_INTERNAL, 0); }
    var body_len = strlen(body);
    var headers = sandhi_headers_new_a(a);
    if (headers == 0) { return _sandhi_stream_result_a(a, 0, 0, SANDHI_ERR_INTERNAL, 0); }
    sandhi_headers_set_a(a, headers, "Content-Type", "application/json");
    sandhi_headers_set_a(a, headers, "Accept", "text/event-stream");
    return sandhi_http_stream_a(a, endpoint_url, "POST", headers, body, body_len, cb, ctx);
}

fn sandhi_rpc_mcp_stream(endpoint_url, method_name, params_json, cb, ctx): i64 {
    return sandhi_rpc_mcp_stream_a(default_alloc(), endpoint_url, method_name, params_json, cb, ctx);
}


# --- mod.cyr ---

# sandhi/rpc — JSON-RPC dialect index.
#
# Composes:
#   rpc/json     — nested JSON build + dotted-path extract
#   rpc/dispatch — JSON-over-HTTP transport + dialect-aware error envelopes
#
# Dialects (one file each per CLAUDE.md "one dialect per file"):
#   rpc/webdriver — W3C WebDriver wire (Firefox, WebKit via geckodriver)
#   rpc/appium    — Appium UiAutomator2 / XCUITest extensions on top of WebDriver
#   rpc/mcp       — MCP-over-HTTP transport; protocol semantics stay in bote/t-ron per ADR 0001
#
# Adding a new dialect is a new file + a cyrius.cyml entry; don't grow
# an existing dialect file.


# --- service.cyr ---

# sandhi/discovery/service — types shared across resolvers.
#
# A `service` names an endpoint inside an AGNOS deployment. Any
# resolver that claims to resolve returns one of these (or 0 on miss).
#
# Struct layout (32 bytes):
#   +0   name  (cstr — logical service name, may be 0 for unnamed)
#   +8   host  (cstr — hostname OR dotted-quad IP; non-0)
#   +16  port  (int — 1..65535)
#   +24  ipv4  (int — pre-resolved address in sock_connect format, or 0
#               if the caller should resolve the host themselves)

enum SandhiServiceOff {
    SANDHI_SERVICE_OFF_NAME = 0;
    SANDHI_SERVICE_OFF_HOST = 8;
    SANDHI_SERVICE_OFF_PORT = 16;
    SANDHI_SERVICE_OFF_IPV4 = 24;
}

var SANDHI_SERVICE_STRUCT_SIZE = 32;

# Allocate a service struct from `a`. Returns 0 on OOM.
fn sandhi_service_new_a(a, name, host, port, ipv4): i64 {
    var s = alloc_via(a, SANDHI_SERVICE_STRUCT_SIZE);
    if (s == 0) { return 0; }
    store64(s + SANDHI_SERVICE_OFF_NAME, name);
    store64(s + SANDHI_SERVICE_OFF_HOST, host);
    store64(s + SANDHI_SERVICE_OFF_PORT, port);
    store64(s + SANDHI_SERVICE_OFF_IPV4, ipv4);
    return s;
}

fn sandhi_service_new(name, host, port, ipv4): i64 {
    return sandhi_service_new_a(default_alloc(), name, host, port, ipv4);
}

fn sandhi_service_name(s): i64 { return load64(s + SANDHI_SERVICE_OFF_NAME); }
fn sandhi_service_host(s): i64 { return load64(s + SANDHI_SERVICE_OFF_HOST); }
fn sandhi_service_port(s): i64 { return load64(s + SANDHI_SERVICE_OFF_PORT); }
fn sandhi_service_ipv4(s): i64 { return load64(s + SANDHI_SERVICE_OFF_IPV4); }

# ================================================================
# Resolver — a function pointer + opaque context.
# ================================================================
#
# Contract: `lookup_fn(ctx, name)` returns an alloc'd sandhi_service or 0 on miss.
# Resolvers MUST NOT abort on network failure — return 0 so the chain
# can try the next backend.
#
# Struct layout (16 bytes):
#   +0   lookup_fn  (fn pointer, matches fncall2 signature: (ctx, name))
#   +8   ctx        (ptr, resolver-specific)

enum SandhiResolverOff {
    SANDHI_RESOLVER_OFF_FN  = 0;
    SANDHI_RESOLVER_OFF_CTX = 8;
}

var SANDHI_RESOLVER_STRUCT_SIZE = 16;

# Allocate a resolver wrapper from `a`. Returns 0 on OOM.
fn sandhi_resolver_new_a(a, lookup_fn, ctx): i64 {
    var r = alloc_via(a, SANDHI_RESOLVER_STRUCT_SIZE);
    if (r == 0) { return 0; }
    store64(r + SANDHI_RESOLVER_OFF_FN, lookup_fn);
    store64(r + SANDHI_RESOLVER_OFF_CTX, ctx);
    return r;
}

fn sandhi_resolver_new(lookup_fn, ctx): i64 {
    return sandhi_resolver_new_a(default_alloc(), lookup_fn, ctx);
}

fn sandhi_resolver_fn(r): i64 { return load64(r + SANDHI_RESOLVER_OFF_FN); }
fn sandhi_resolver_ctx(r): i64 { return load64(r + SANDHI_RESOLVER_OFF_CTX); }

# Invoke a resolver directly. Chain + consumers use this shape.
fn sandhi_resolver_lookup(r, name): i64 {
    if (r == 0) { return 0; }
    var fp = sandhi_resolver_fn(r);
    if (fp == 0) { return 0; }
    return fncall2(fp, sandhi_resolver_ctx(r), name);
}


# --- chain.cyr ---

# sandhi/discovery/chain — fallback sequence of resolvers.
#
# A chain holds an ordered list of resolvers. On resolve, it asks
# each in turn and returns the first non-null service. No resolver
# is load-bearing — if daimon is down, the chain falls through to
# the next backend (mDNS, static config, …) without the caller
# having to notice.
#
# Usage:
#   var c = sandhi_discovery_chain_new();
#   sandhi_discovery_chain_add(c, sandhi_discovery_daimon_resolver("http://127.0.0.1:9000"));
#   sandhi_discovery_chain_add(c, sandhi_discovery_local_resolver());
#   var svc = sandhi_discovery_chain_resolve(c, "yantra-worker");

# Chain is just a vec of resolver pointers. Kept as a typed alias so
# the API documents intent rather than leaking "vec".
fn sandhi_discovery_chain_new(): i64 {
    return vec_new();
}

# Append a resolver. Resolvers run in insertion order on lookup.
fn sandhi_discovery_chain_add(chain, resolver): i64 {
    if (chain == 0 || resolver == 0) { return 0; }
    vec_push(chain, resolver);
    return 0;
}

# Count of resolvers in the chain. Handy for diagnostics.
fn sandhi_discovery_chain_count(chain): i64 {
    if (chain == 0) { return 0; }
    return vec_len(chain);
}

# Resolve `name` by trying each resolver. Returns the first non-null
# service, or 0 if every resolver misses.
fn sandhi_discovery_chain_resolve(chain, name): i64 {
    if (chain == 0 || name == 0) { return 0; }
    var n = vec_len(chain);
    var i = 0;
    while (i < n) {
        var r = vec_get(chain, i);
        var svc = sandhi_resolver_lookup(r, name);
        if (svc != 0) { return svc; }
        i = i + 1;
    }
    return 0;
}

# Wrap a chain as a resolver itself, so one chain can nest another.
# The caller passes the chain as ctx; the adapter calls chain_resolve.
fn _sandhi_discovery_chain_adapter(ctx, name): i64 {
    return sandhi_discovery_chain_resolve(ctx, name);
}

fn sandhi_discovery_chain_as_resolver(chain): i64 {
    return sandhi_resolver_new(&_sandhi_discovery_chain_adapter, chain);
}


# --- daimon.cyr ---

# sandhi/discovery/daimon — resolver backed by the daimon service registry.
#
# Daimon is AGNOS's local agent orchestrator; when a sandhi consumer
# runs alongside daimon, daimon knows which services are alive and
# where they live. This resolver speaks a minimal HTTP contract
# against daimon's registry endpoint; daimon implements it.
#
# Contract (this file is the reference):
#
#   GET  {base}/services/{name}
#       200 → {"host":"...","port":N}  (service found)
#       404 → miss
#       any other response → miss (safe fail-open so chain falls through)
#
#   POST {base}/services/{name}  body: {"host":"...","port":N}
#       2xx → registered
#       non-2xx → caller should surface as SANDHI_ERR_DISCOVERY
#
#   DELETE {base}/services/{name}
#       2xx → deregistered
#       non-2xx → see above
#
# Base URL is whatever daimon is listening on — typically
# "http://127.0.0.1:9000" for a local daimon. Chain-resolver users
# can make daimon one backend among many; daimon outages fall through.

# Context struct (24 bytes):
#   +0   base_url  (cstr)
#   +8   reserved  (kept 0 for now — future: auth token, timeouts)
#   +16  alloc     (Allocator handed to the resolver-fn-pointer
#                   callback; the (ctx, name) shape can't take an
#                   extra arg, so the allocator rides on the ctx)
enum SandhiDaimonCtxOff {
    SANDHI_DAIMON_CTX_OFF_BASE  = 0;
    SANDHI_DAIMON_CTX_OFF_RES   = 8;
    SANDHI_DAIMON_CTX_OFF_ALLOC = 16;
}

var SANDHI_DAIMON_CTX_SIZE = 24;

# Build a daimon resolver context backed by `a`. Returns 0 on OOM.
fn _sandhi_discovery_daimon_ctx_new_a(a, base_url): i64 {
    var c = alloc_via(a, SANDHI_DAIMON_CTX_SIZE);
    if (c == 0) { return 0; }
    store64(c + SANDHI_DAIMON_CTX_OFF_BASE, base_url);
    store64(c + SANDHI_DAIMON_CTX_OFF_RES, 0);
    store64(c + SANDHI_DAIMON_CTX_OFF_ALLOC, a);
    return c;
}

fn _sandhi_discovery_daimon_ctx_new(base_url): i64 {
    return _sandhi_discovery_daimon_ctx_new_a(default_alloc(), base_url);
}

# Build "{base}/services/{name}" with trailing-slash normalization,
# allocating the trimmed copy from `a`. The str_builder used to
# concatenate the final URL still goes through the global bump
# (str_builder lacks `_a` variants in the pinned stdlib); only the
# trim-copy and the final cstr land in `a`.
fn _sandhi_daimon_url_a(a, base, name): i64 {
    var sb = str_builder_new();
    var blen = strlen(base);
    if (blen > 0 && load8(base + blen - 1) == 47) {
        # Trim trailing slash.
        var trimmed = alloc_via(a, blen);
        if (trimmed == 0) { return 0; }
        memcpy(trimmed, base, blen - 1);
        store8(trimmed + blen - 1, 0);
        str_builder_add_cstr(sb, trimmed);
    } else {
        str_builder_add_cstr(sb, base);
    }
    str_builder_add_cstr(sb, "/services/");
    str_builder_add_cstr(sb, name);
    return str_data(str_builder_build(sb));
}

fn _sandhi_daimon_url(base, name): i64 {
    return _sandhi_daimon_url_a(default_alloc(), base, name);
}

# The resolver callback. Matches fn(ctx, name) → *service. The
# allocator stored on ctx (slot +16, 0 = process default) drives
# every alloc on the resolved-service path.
fn _sandhi_daimon_lookup(ctx, name): i64 {
    if (ctx == 0 || name == 0) { return 0; }
    var base = load64(ctx + SANDHI_DAIMON_CTX_OFF_BASE);
    if (base == 0) { return 0; }
    var a = load64(ctx + SANDHI_DAIMON_CTX_OFF_ALLOC);
    if (a == 0) { a = default_alloc(); }
    var url = _sandhi_daimon_url_a(a, base, name);
    if (url == 0) { return 0; }
    var resp = sandhi_http_get(url, 0);
    # Any non-2xx or transport error → miss (fall-through for chain).
    if (sandhi_http_err_kind(resp) != SANDHI_OK) { return 0; }
    var status = sandhi_http_status(resp);
    if (status < 200 || status >= 300) { return 0; }
    var body = sandhi_http_body(resp);
    if (body == 0) { return 0; }
    return _sandhi_daimon_parse_service_a(a, body, name);
}

# Parse daimon's {"host":"...","port":N} response into a service
# allocated from `a`. Returns 0 on missing fields, malformed input,
# or OOM.
fn _sandhi_daimon_parse_service_a(a, body, name): i64 {
    var host = sandhi_json_get_string(body, "host");
    if (host == 0) { return 0; }
    var port = sandhi_json_get_int(body, "port");
    if (port <= 0) { return 0; }
    if (port > 65535) { return 0; }
    # Daimon might also include a pre-resolved "address" field.
    var ipv4 = 0;
    var addr_str = sandhi_json_get_string(body, "address");
    if (addr_str != 0) {
        var av4 = sandhi_net_parse_ipv4(addr_str);
        if (av4 != 0 - 1) { ipv4 = av4; }
    }
    # Dup the caller-passed name so the service is self-contained.
    var name_copy = 0;
    if (name != 0) {
        var nlen = strlen(name);
        name_copy = alloc_via(a, nlen + 1);
        if (name_copy == 0) { return 0; }
        memcpy(name_copy, name, nlen);
        store8(name_copy + nlen, 0);
    }
    return sandhi_service_new_a(a, name_copy, host, port, ipv4);
}

fn _sandhi_daimon_parse_service(body, name): i64 {
    return _sandhi_daimon_parse_service_a(default_alloc(), body, name);
}

# Build a resolver for the given daimon base URL, owned by `a`.
# Returns 0 on OOM.
fn sandhi_discovery_daimon_resolver_a(a, base_url): i64 {
    if (base_url == 0) { return 0; }
    var ctx = _sandhi_discovery_daimon_ctx_new_a(a, base_url);
    if (ctx == 0) { return 0; }
    return sandhi_resolver_new_a(a, &_sandhi_daimon_lookup, ctx);
}

fn sandhi_discovery_daimon_resolver(base_url): i64 {
    return sandhi_discovery_daimon_resolver_a(default_alloc(), base_url);
}


# --- local.cyr ---

# sandhi/discovery/local — mDNS / link-local resolver (RFC 6762).
#
# Real implementation: builds a unicast-response (QU) A-record query
# for `<name>.local`, sends it to the IPv4 mDNS multicast group
# 224.0.0.251:5353 over UDP, recvs the first response, parses out
# the A record, returns a sandhi_service. Bounded by SO_RCVTIMEO so
# a missing responder doesn't hang the chain.
#
# Wire shape:
#   - Query name: `<name>.local` (one label appended if `name` doesn't
#     already end in `.local`).
#   - QTYPE=A (1), QCLASS = IN with the QU (top) bit set = 0x8001 so
#     responders unicast the answer to our source port. Using QU
#     means we don't need IP_ADD_MEMBERSHIP — the response arrives on
#     the same fd we sent from, no multicast listen required.
#   - TTL: kernel default for IP_MULTICAST_TTL on Linux is 1, which is
#     exactly what RFC 6762 calls for (link-local only). No setsockopt
#     needed.
#
# Reference: RFC 6762 (Multicast DNS), RFC 6763 (DNS-Based Service
# Discovery — out of scope here; this resolver answers names, not
# services-by-type).

# 224.0.0.251 packed as a network-byte-order uint32 in
# little-endian-host repr (matches sock_connect's expectations:
# bytes 224, 0, 0, 251 across the int).
var _SANDHI_MDNS_GROUP = 0;
var _SANDHI_MDNS_PORT  = 5353;
var _SANDHI_MDNS_TIMEOUT_MS = 500;

# Build a `<name>.local` cstr in `a`. If `name` already ends in
# `.local` (case-insensitive), the input is dup'd into `a`; otherwise
# the suffix is appended. Returns 0 on OOM.
fn _sandhi_local_qname_a(a, name): i64 {
    var nlen = strlen(name);
    var has_suffix = 0;
    if (nlen >= 6) {
        var s = name + nlen - 6;
        var c0 = load8(s + 0);
        var c1 = load8(s + 1);
        var c2 = load8(s + 2);
        var c3 = load8(s + 3);
        var c4 = load8(s + 4);
        var c5 = load8(s + 5);
        if (c0 == 46) {  # '.'
            if ((c1 == 108 || c1 == 76) && (c2 == 111 || c2 == 79)
            && (c3 == 99 || c3 == 67) && (c4 == 97 || c4 == 65)
            && (c5 == 108 || c5 == 76)) {
                has_suffix = 1;
            }
        }
    }
    if (has_suffix == 1) {
        var dup = alloc_via(a, nlen + 1);
        if (dup == 0) { return 0; }
        memcpy(dup, name, nlen);
        store8(dup + nlen, 0);
        return dup;
    }
    var out = alloc_via(a, nlen + 7);
    if (out == 0) { return 0; }
    memcpy(out, name, nlen);
    store8(out + nlen + 0, 46);   # '.'
    store8(out + nlen + 1, 108);  # 'l'
    store8(out + nlen + 2, 111);  # 'o'
    store8(out + nlen + 3, 99);   # 'c'
    store8(out + nlen + 4, 97);   # 'a'
    store8(out + nlen + 5, 108);  # 'l'
    store8(out + nlen + 6, 0);
    return out;
}

fn _sandhi_local_qname(name): i64 {
    return _sandhi_local_qname_a(default_alloc(), name);
}

# Build the mDNS query packet. Same wire format as the unicast DNS
# resolver in net/resolve.cyr but with QCLASS = 0x8001 (IN | QU bit
# per RFC 6762 §5.4 — request unicast response).
fn _sandhi_local_build_query(id, qname, out): i64 {
    store8(out + 0, (id >> 8) & 0xFF);
    store8(out + 1, id & 0xFF);
    store8(out + 2, 0x00);  # mDNS queries: QR=0, Opcode=0, AA=0, TC=0, RD=0
    store8(out + 3, 0x00);
    store8(out + 4, 0x00); store8(out + 5, 0x01);  # QDCOUNT = 1
    store8(out + 6, 0x00); store8(out + 7, 0x00);  # ANCOUNT
    store8(out + 8, 0x00); store8(out + 9, 0x00);  # NSCOUNT
    store8(out + 10, 0x00); store8(out + 11, 0x00); # ARCOUNT

    var qname_len = _sandhi_resolve_encode_labels(qname, out + 12);
    if (qname_len < 0) { return 0 - 1; }
    var qi = 12 + qname_len;
    store8(out + qi + 0, 0x00); store8(out + qi + 1, 0x01);  # QTYPE = A
    store8(out + qi + 2, 0x80); store8(out + qi + 3, 0x01);  # QCLASS = IN | QU
    return qi + 4;
}

# Local resolver context (8 bytes):
#   +0  alloc  (Allocator handle the lookup callback uses; 0 → default)
# Carried so the resolver-fn-pointer `(ctx, name)` shape can pull an
# Allocator without growing the callback signature — same approach as
# daimon's ctx struct.
var _SANDHI_LOCAL_CTX_SIZE = 8;

fn _sandhi_discovery_local_ctx_new_a(a): i64 {
    var c = alloc_via(a, _SANDHI_LOCAL_CTX_SIZE);
    if (c == 0) { return 0; }
    store64(c, a);
    return c;
}

# Issue an mDNS query, allocating the qname / qbuf / rbuf scratch into
# `a`. Returns the resolved IPv4 address or 0 on any failure / OOM.
fn _sandhi_local_query_a(a, name): i64 {
    if (name == 0) { return 0; }
    if (_SANDHI_MDNS_GROUP == 0) {
        _SANDHI_MDNS_GROUP = 224 | (0 << 8) | (0 << 16) | (251 << 24);
    }

    var qname = _sandhi_local_qname_a(a, name);
    if (qname == 0) { return 0; }
    var txid = _sandhi_resolve_random_u16();
    var qbuf = alloc_via(a, _SANDHI_RESOLVE_BUF_SIZE);
    if (qbuf == 0) { return 0; }
    var qlen = _sandhi_local_build_query(txid, qname, qbuf);
    if (qlen < 0) { return 0; }

    var fd_r = udp_socket();
    if (is_err_result(fd_r) == 1) { return 0; }
    var fd = payload(fd_r);

    # Bound the recv — link-local; if no responder shows up in 500 ms
    # we treat it as a miss so the chain falls through.
    _sandhi_conn_set_timeout_ms(fd, _SANDHI_MDNS_TIMEOUT_MS, _SANDHI_SO_RCVTIMEO);

    var cr = sock_connect(fd, _SANDHI_MDNS_GROUP, _SANDHI_MDNS_PORT);
    if (is_err_result(cr) == 1) { sock_close(fd); return 0; }
    var sr = sock_send(fd, qbuf, qlen);
    if (is_err_result(sr) == 1) { sock_close(fd); return 0; }

    var rbuf = alloc_via(a, _SANDHI_RESOLVE_BUF_SIZE);
    if (rbuf == 0) { sock_close(fd); return 0; }
    var rr = sock_recv(fd, rbuf, _SANDHI_RESOLVE_BUF_SIZE);
    sock_close(fd);
    if (is_err_result(rr) == 1) { return 0; }
    var rlen = payload(rr);
    if (rlen <= 0) { return 0; }

    var ip = _sandhi_resolve_parse_response(rbuf, rlen, txid);
    if (ip == 0 - 1) { return 0; }
    return ip;
}

fn _sandhi_local_query(name): i64 {
    return _sandhi_local_query_a(default_alloc(), name);
}

# Resolver callback. Reads the Allocator from ctx (0 → default) and
# threads it through the query + service-build path.
fn _sandhi_local_lookup(ctx, name): i64 {
    if (name == 0) { return 0; }
    var a = default_alloc();
    if (ctx != 0) {
        var stored = load64(ctx);
        if (stored != 0) { a = stored; }
    }
    var ip = _sandhi_local_query_a(a, name);
    if (ip == 0) { return 0; }
    var qname = _sandhi_local_qname_a(a, name);
    if (qname == 0) { return 0; }
    return sandhi_service_new_a(a, name, qname, 0, ip);
}

# Build the mDNS resolver backed by `a`. Both the resolver wrapper and
# its ctx are allocated from `a`; the lookup callback also routes its
# transient + service-struct allocations through `a`. Returns 0 on OOM.
fn sandhi_discovery_local_resolver_a(a): i64 {
    var ctx = _sandhi_discovery_local_ctx_new_a(a);
    if (ctx == 0) { return 0; }
    return sandhi_resolver_new_a(a, &_sandhi_local_lookup, ctx);
}

fn sandhi_discovery_local_resolver(): i64 {
    return sandhi_discovery_local_resolver_a(default_alloc());
}

# 1 — wired since 0.9.3. Always available on Linux (multicast UDP is
# kernel-side; no extra deps). Returns 0 only if a future port lacks
# multicast UDP support.
fn sandhi_discovery_local_available(): i64 {
    return 1;
}


# --- register.cyr ---

# sandhi/discovery/register — publish / withdraw services via daimon.
#
# Pairs with discovery/daimon.cyr. Uses the same REST contract:
#   POST   {base}/services/{name}   body: {"host":"...","port":N}
#   DELETE {base}/services/{name}
#
# mDNS publishing (a continuous-responder loop) is not in M4 scope —
# see discovery/local.cyr for the rationale. Register/deregister
# against daimon is the primary path for AGNOS services.

# Register a service with the daimon registry. `base_url` is daimon's
# listening endpoint (e.g. "http://127.0.0.1:9000"). `host` + `port`
# are the published location of the service being registered.
#
# Returns SANDHI_OK on success, or one of:
#   SANDHI_ERR_CONNECT    — daimon unreachable
#   SANDHI_ERR_REMOTE     — daimon answered but refused (non-2xx)
#   SANDHI_ERR_INTERNAL   — malformed input
fn sandhi_discovery_register(base_url, name, host, port): i64 {
    if (base_url == 0 || name == 0 || host == 0) { return SANDHI_ERR_INTERNAL; }
    if (port <= 0 || port > 65535) { return SANDHI_ERR_INTERNAL; }

    var url = _sandhi_daimon_url(base_url, name);
    var body_obj = sandhi_json_obj_new();
    sandhi_json_add_string(body_obj, "host", host);
    sandhi_json_add_int(body_obj, "port", port);
    var body = sandhi_json_build(body_obj);
    var body_len = strlen(body);

    var headers = sandhi_headers_new();
    sandhi_headers_set(headers, "Content-Type", "application/json");

    var resp = sandhi_http_post(url, headers, body, body_len);
    var ek = sandhi_http_err_kind(resp);
    if (ek != SANDHI_OK) { return ek; }
    var status = sandhi_http_status(resp);
    if (status < 200 || status >= 300) { return SANDHI_ERR_REMOTE; }
    return SANDHI_OK;
}

# Withdraw a previously-registered service.
fn sandhi_discovery_deregister(base_url, name): i64 {
    if (base_url == 0 || name == 0) { return SANDHI_ERR_INTERNAL; }
    var url = _sandhi_daimon_url(base_url, name);
    var resp = sandhi_http_delete(url, 0);
    var ek = sandhi_http_err_kind(resp);
    if (ek != SANDHI_OK) { return ek; }
    var status = sandhi_http_status(resp);
    if (status < 200 || status >= 300) { return SANDHI_ERR_REMOTE; }
    return SANDHI_OK;
}


# --- mod.cyr ---

# sandhi/discovery — service discovery index.
#
# Composes:
#   discovery/service   — service struct + resolver (fn-ptr + ctx) shape
#   discovery/chain     — fallback sequence of resolvers
#   discovery/daimon    — HTTP-backed resolver against daimon's registry
#   discovery/local     — mDNS resolver (RFC 6762 link-local query against 224.0.0.251:5353)
#   discovery/register  — publish/withdraw against daimon
#
# Typical consumer shape:
#   var c = sandhi_discovery_chain_new();
#   sandhi_discovery_chain_add(c, sandhi_discovery_daimon_resolver("http://127.0.0.1:9000"));
#   sandhi_discovery_chain_add(c, sandhi_discovery_local_resolver());
#   var svc = sandhi_discovery_chain_resolve(c, "yantra-worker");
#   if (svc != 0) {
#       # svc_host(svc) / svc_port(svc) / svc_ipv4(svc)
#   }
#
# No resolver in the chain is load-bearing — a missing daimon falls
# through to the next backend silently.


# --- mod.cyr ---

# sandhi/server — HTTP server surface.
#
# Lift-and-shift landing site for lib/http_server.cyr per M1 of the
# sandhi roadmap. Content below is the verbatim stdlib file as of the
# 5.6.22 toolchain pin; no behavior change, structural move only.
# Routing, middleware, and auth primitives layer on top in later
# milestones — ADR 0001 is strict about staying lift-first-then-enhance.
#
# During the migration window, stdlib lib/http_server.cyr is expected
# to alias these symbols so existing consumers keep building; the alias
# retires at fold-into-stdlib (M6).
#
# Requires: alloc.cyr, string.cyr, fmt.cyr, str.cyr, net.cyr,
# tagged.cyr, syscalls.cyr (all pulled in via stdlib deps).

# ================================================================
# Status codes
# ================================================================
var HTTP_OK                  = 200;
var HTTP_NO_CONTENT          = 204;
var HTTP_MOVED_PERMANENTLY   = 301;
var HTTP_FOUND               = 302;
var HTTP_NOT_MODIFIED        = 304;
var HTTP_BAD_REQUEST         = 400;
var HTTP_UNAUTHORIZED        = 401;
var HTTP_FORBIDDEN           = 403;
var HTTP_NOT_FOUND           = 404;
var HTTP_METHOD_NOT_ALLOWED  = 405;
var HTTP_REQUEST_TIMEOUT     = 408;
var HTTP_PAYLOAD_TOO_LARGE   = 413;
var HTTP_INTERNAL            = 500;
var HTTP_NOT_IMPLEMENTED     = 501;
var HTTP_SERVICE_UNAVAILABLE = 503;

# ================================================================
# Internal byte-search + ASCII helpers
# ================================================================

# Find the first occurrence of `needle[0..nlen]` in `haystack[0..hlen]`.
# Returns the offset, or 0 - 1 if not found.
fn _hsv_find(haystack, hlen, needle, nlen): i64 {
    if (nlen == 0) { return 0; }
    if (nlen > hlen) { return 0 - 1; }
    var i = 0;
    while (i <= hlen - nlen) {
        if (memeq(haystack + i, needle, nlen) == 1) { return i; }
        i = i + 1;
    }
    return 0 - 1;
}

fn _hsv_to_lower(c): i64 {
    if (c >= 65) { if (c <= 90) { return c + 32; } }
    return c;
}

fn _hsv_iceq(a, b, n): i64 {
    var i = 0;
    while (i < n) {
        if (_hsv_to_lower(load8(a + i)) != _hsv_to_lower(load8(b + i))) { return 0; }
        i = i + 1;
    }
    return 1;
}

fn _hsv_next_nl(buf, start, end): i64 {
    var i = start;
    while (i < end) {
        if (load8(buf + i) == 10) { return i; }
        i = i + 1;
    }
    return end;
}

# ================================================================
# Request parsing — read-only on the buffer, only allocates returned cstrs
# ================================================================

# Method from the request line — "GET", "POST", etc. Returns "" on malformed.
# Extract the request method into `a`. Returns "" on malformed; 0 on
# OOM (caller can distinguish by null-checking; "" is non-zero).
fn sandhi_server_get_method_a(a, buf, blen): i64 {
    var sp = _hsv_find(buf, blen, " ", 1);
    if (sp < 0) { return ""; }
    var out = alloc_via(a, sp + 1);
    if (out == 0) { return 0; }
    memcpy(out, buf, sp);
    store8(out + sp, 0);
    return out;
}

fn sandhi_server_get_method(buf, blen): i64 {
    return sandhi_server_get_method_a(default_alloc(), buf, blen);
}

fn sandhi_server_get_path_a(a, buf, blen): i64 {
    var sp1 = _hsv_find(buf, blen, " ", 1);
    if (sp1 < 0) { return ""; }
    var sp2 = _hsv_find(buf + sp1 + 1, blen - sp1 - 1, " ", 1);
    if (sp2 < 0) { return ""; }
    var out = alloc_via(a, sp2 + 1);
    if (out == 0) { return 0; }
    memcpy(out, buf + sp1 + 1, sp2);
    store8(out + sp2, 0);
    return out;
}

fn sandhi_server_get_path(buf, blen): i64 {
    return sandhi_server_get_path_a(default_alloc(), buf, blen);
}

# Offset of the body start (after \r\n\r\n) — 0 - 1 if no headers terminator.
fn sandhi_server_body_offset(buf, blen): i64 {
    var off = _hsv_find(buf, blen, "\r\n\r\n", 4);
    if (off < 0) { return 0 - 1; }
    return off + 4;
}

# Case-insensitive header lookup. Returns the value cstr (trimmed of leading
# SP and trailing CR), or 0 if the header is absent.
fn sandhi_server_find_header_a(a, buf, blen, name): i64 {
    var nlen = strlen(name);
    var headers_end = _hsv_find(buf, blen, "\r\n\r\n", 4);
    if (headers_end < 0) { headers_end = blen; }
    var line_start = _hsv_next_nl(buf, 0, headers_end);
    if (line_start >= headers_end) { return 0; }
    line_start = line_start + 1;
    while (line_start < headers_end) {
        var line_end = _hsv_next_nl(buf, line_start, headers_end);
        if (line_start + nlen + 1 <= line_end
        && _hsv_iceq(buf + line_start, name, nlen) == 1
        && load8(buf + line_start + nlen) == 58) {
            var vs = line_start + nlen + 1;
            while (vs < line_end && load8(buf + vs) == 32) { vs = vs + 1; }
            var ve = line_end;
            if (ve > vs && load8(buf + ve - 1) == 13) { ve = ve - 1; }
            var vlen = ve - vs;
            var out = alloc_via(a, vlen + 1);
            if (out == 0) { return 0; }
            memcpy(out, buf + vs, vlen);
            store8(out + vlen, 0);
            return out;
        }
        line_start = line_end + 1;
    }
    return 0;
}

fn sandhi_server_find_header(buf, blen, name): i64 {
    return sandhi_server_find_header_a(default_alloc(), buf, blen, name);
}

# Content-Length value — 0 if header absent or malformed.
#
# 0.9.1 P1 — strict per RFC 7230 §3.3.2: pure decimal digits (with
# optional leading/trailing whitespace) only. Previously skipped
# non-digits silently, so "10, 20" parsed as 1020 — CL.CL smuggling.
# Returns 0 on any malformed value (including non-digit characters
# embedded in the number); the existing accept loop reads body up
# to the parsed length so 0 means "no body" which is a safe fail
# closed for malformed input.
fn sandhi_server_content_length(buf, blen): i64 {
    var v = sandhi_server_find_header(buf, blen, "Content-Length");
    if (v == 0) { return 0; }
    var i = 0;
    while (load8(v + i) == 32 || load8(v + i) == 9) { i = i + 1; }
    if (load8(v + i) == 0) { return 0; }
    var n = 0;
    var seen_digit = 0;
    while (load8(v + i) >= 48 && load8(v + i) <= 57) {
        n = n * 10 + (load8(v + i) - 48);
        seen_digit = 1;
        i = i + 1;
    }
    if (seen_digit == 0) { return 0; }
    while (load8(v + i) == 32 || load8(v + i) == 9) { i = i + 1; }
    if (load8(v + i) != 0) { return 0; }
    return n;
}

# 0.9.1 P1 — count occurrences of a given header name in the
# request. Used to detect Host.Host / CL.CL / TE.TE duplicate
# conditions that are malformed per RFC 7230. Case-insensitive
# match. We don't have to be perfect about line boundaries here
# because sandhi_server_find_header / `_hsv_find` already understand the
# request format — we just iterate all body offsets and use them.
fn _sandhi_server_count_header_occurrences(buf, blen, name): i64 {
    var count = 0;
    var pos = 0;
    var name_len = strlen(name);
    var line_start = 0;
    while (line_start < blen) {
        # Find end of line.
        var line_end = line_start;
        while (line_end < blen && load8(buf + line_end) != 10) { line_end = line_end + 1; }
        if (line_end == line_start) { return count; }  # blank line ends headers
        if (line_end == line_start + 1 && load8(buf + line_start) == 13) {
            return count;
        }
        # Compare line prefix against `name:` (case-insensitive).
        if (line_end > line_start + name_len) {
            if (_hsv_iceq(buf + line_start, name, name_len) == 1) {
                if (load8(buf + line_start + name_len) == 58) {
                    count = count + 1;
                }
            }
        }
        line_start = line_end + 1;
    }
    return count;
}

# 0.9.1 P1 — 1 if the request has multiple Host / Content-Length /
# Transfer-Encoding headers (CL.CL / Host.Host / TE.TE smuggling
# vector per RFC 7230 §3.3.2 + §5.4). Server replies 400 on truthy
# rather than dispatching to the handler.
fn sandhi_server_request_has_dup_smuggling_header(buf, blen): i64 {
    if (_sandhi_server_count_header_occurrences(buf, blen, "Host") > 1)              { return 1; }
    if (_sandhi_server_count_header_occurrences(buf, blen, "Content-Length") > 1)    { return 1; }
    if (_sandhi_server_count_header_occurrences(buf, blen, "Transfer-Encoding") > 1) { return 1; }
    return 0;
}

# 0.9.0 P0 #2 — 1 if the request carries both `Content-Length` AND
# `Transfer-Encoding: chunked`, which is malformed per RFC 7230
# §3.3.3 and the canonical CL.TE smuggling vector. The accept-loop
# in `sandhi_server_run_opts` checks this and replies 400 before
# handing the request to the user's handler.
fn sandhi_server_request_has_cl_te_conflict(buf, blen): i64 {
    if (sandhi_server_find_header(buf, blen, "Content-Length") == 0) { return 0; }
    var te = sandhi_server_find_header(buf, blen, "Transfer-Encoding");
    if (te == 0) { return 0; }
    # Tolerant case-insensitive substring match for "chunked".
    var i = 0;
    while (load8(te + i) != 0) {
        var c0 = load8(te + i);
        if (c0 >= 65 && c0 <= 90) { c0 = c0 + 32; }
        if (c0 == 99) {
            var j = 1;
            var matched = 1;
            var want = "hunked";
            while (matched == 1 && j < 7) {
                var ch = load8(te + i + j);
                if (ch >= 65 && ch <= 90) { ch = ch + 32; }
                if (ch != load8(want + j - 1)) { matched = 0; }
                j = j + 1;
            }
            if (matched == 1) { return 1; }
        }
        i = i + 1;
    }
    return 0;
}

# ================================================================
# Path + query helpers
# ================================================================

# "/foo?bar=baz" → "/foo". Returns the input unchanged if there's no '?'.
fn sandhi_server_path_only_a(a, path): i64 {
    if (path == 0) { return path; }
    var i = 0;
    while (load8(path + i) != 0) {
        if (load8(path + i) == 63) {
            var out = alloc_via(a, i + 1);
            if (out == 0) { return 0; }
            memcpy(out, path, i);
            store8(out + i, 0);
            return out;
        }
        i = i + 1;
    }
    return path;
}

fn sandhi_server_path_only(path): i64 {
    return sandhi_server_path_only_a(default_alloc(), path);
}

fn sandhi_server_url_decode_a(a, s): i64 {
    if (s == 0) { return ""; }
    var slen = strlen(s);
    var out = alloc_via(a, slen + 1);
    if (out == 0) { return 0; }
    var si = 0;
    var oi = 0;
    while (si < slen) {
        var c = load8(s + si);
        if (c == 37 && si + 2 < slen) {
            var h1 = load8(s + si + 1);
            var h2 = load8(s + si + 2);
            var v1 = 0;
            var v2 = 0;
            if (h1 >= 48 && h1 <= 57) { v1 = h1 - 48; }
            elif (h1 >= 65 && h1 <= 70) { v1 = h1 - 55; }
            elif (h1 >= 97 && h1 <= 102) { v1 = h1 - 87; }
            if (h2 >= 48 && h2 <= 57) { v2 = h2 - 48; }
            elif (h2 >= 65 && h2 <= 70) { v2 = h2 - 55; }
            elif (h2 >= 97 && h2 <= 102) { v2 = h2 - 87; }
            store8(out + oi, v1 * 16 + v2);
            si = si + 3;
        } elif (c == 43) {
            store8(out + oi, 32);
            si = si + 1;
        } else {
            store8(out + oi, c);
            si = si + 1;
        }
        oi = oi + 1;
    }
    store8(out + oi, 0);
    return out;
}

fn sandhi_server_url_decode(s): i64 {
    return sandhi_server_url_decode_a(default_alloc(), s);
}

# Query parameter value, percent-decoded. 0 if not found.
# Example: sandhi_server_get_param("/a?foo=1&bar=hello%20world", "bar") → "hello world"
fn sandhi_server_get_param_a(a, path, name): i64 {
    if (path == 0) { return 0; }
    var plen = strlen(path);
    var qmark = 0 - 1;
    var pi = 0;
    while (pi < plen) {
        if (load8(path + pi) == 63) { qmark = pi + 1; pi = plen; }
        pi = pi + 1;
    }
    if (qmark < 0) { return 0; }
    var nlen = strlen(name);
    pi = qmark;
    while (pi < plen) {
        if (pi + nlen + 1 <= plen
        && memeq(path + pi, name, nlen) == 1
        && load8(path + pi + nlen) == 61) {
            var vs = pi + nlen + 1;
            var ve = vs;
            while (ve < plen && load8(path + ve) != 38) { ve = ve + 1; }
            var raw = alloc_via(a, ve - vs + 1);
            if (raw == 0) { return 0; }
            memcpy(raw, path + vs, ve - vs);
            store8(raw + ve - vs, 0);
            return sandhi_server_url_decode_a(a, raw);
        }
        while (pi < plen && load8(path + pi) != 38) { pi = pi + 1; }
        pi = pi + 1;
    }
    return 0;
}

fn sandhi_server_get_param(path, name): i64 {
    return sandhi_server_get_param_a(default_alloc(), path, name);
}

fn sandhi_server_path_segment_a(a, path, n): i64 {
    if (path == 0) { return 0; }
    var path_only = sandhi_server_path_only_a(a, path);
    var plen = strlen(path_only);
    var seg = 0;
    var ss = 0;
    var pi = 0;
    if (pi < plen && load8(path_only + pi) == 47) { pi = pi + 1; ss = pi; }
    while (pi <= plen) {
        var c = 0;
        if (pi < plen) { c = load8(path_only + pi); }
        if (c == 47 || c == 0) {
            if (seg == n) {
                var slen = pi - ss;
                var out = alloc_via(a, slen + 1);
                if (out == 0) { return 0; }
                memcpy(out, path_only + ss, slen);
                store8(out + slen, 0);
                return out;
            }
            seg = seg + 1;
            ss = pi + 1;
        }
        pi = pi + 1;
    }
    return 0;
}

fn sandhi_server_path_segment(path, n): i64 {
    return sandhi_server_path_segment_a(default_alloc(), path, n);
}

# ================================================================
# Response builders
# ================================================================

# Minimal status response with Content-Length: 0.
# e.g. sandhi_server_send_status(cfd, HTTP_NOT_FOUND, "Not Found");
# 1.2.7 Batch G: each `_send_*` gains an `_a` variant that threads
# `a` through `str_builder_*_a`. Bare versions stay as back-compat
# wrappers passing `default_alloc()`. Return shape: `_a` returns 0
# on success, `-1` on OOM (str_builder_new_a returned 0). Bare
# versions return whatever `_a` returns — under default_alloc that's
# always 0 in practice. Closes the SIGSEGV-on-OOM gap that mirrored
# the 1.2.6 RPC dialect findings.
fn sandhi_server_send_status_a(a, cfd, code, msg): i64 {
    var sb = str_builder_new_a(a);
    if (sb == 0) { return 0 - 1; }
    str_builder_add_cstr_a(a, sb, "HTTP/1.1 ");
    str_builder_add_int_a(a, sb, code);
    str_builder_add_cstr_a(a, sb, " ");
    str_builder_add_cstr_a(a, sb, msg);
    str_builder_add_cstr_a(a, sb, "\r\nContent-Length: 0\r\nConnection: close\r\n\r\n");
    var s = str_data(str_builder_build_a(a, sb));
    sock_send(cfd, s, strlen(s));
    return 0;
}

fn sandhi_server_send_status(cfd, code, msg): i64 {
    return sandhi_server_send_status_a(default_alloc(), cfd, code, msg);
}

# Full response. extra_headers is a cstr (each line CRLF-terminated) or 0.
# e.g. sandhi_server_send_response(cfd, 200, "OK", "application/json", body, len, 0);
fn sandhi_server_send_response_a(a, cfd, code, msg, content_type, body, body_len, extra_headers): i64 {
    var sb = str_builder_new_a(a);
    if (sb == 0) { return 0 - 1; }
    str_builder_add_cstr_a(a, sb, "HTTP/1.1 ");
    str_builder_add_int_a(a, sb, code);
    str_builder_add_cstr_a(a, sb, " ");
    str_builder_add_cstr_a(a, sb, msg);
    str_builder_add_cstr_a(a, sb, "\r\nContent-Type: ");
    str_builder_add_cstr_a(a, sb, content_type);
    str_builder_add_cstr_a(a, sb, "\r\nContent-Length: ");
    str_builder_add_int_a(a, sb, body_len);
    str_builder_add_cstr_a(a, sb, "\r\n");
    if (extra_headers != 0) { str_builder_add_cstr_a(a, sb, extra_headers); }
    str_builder_add_cstr_a(a, sb, "Connection: close\r\n\r\n");
    var head = str_data(str_builder_build_a(a, sb));
    sock_send(cfd, head, strlen(head));
    if (body_len > 0) { sock_send(cfd, body, body_len); }
    return 0;
}

fn sandhi_server_send_response(cfd, code, msg, content_type, body, body_len, extra_headers): i64 {
    return sandhi_server_send_response_a(default_alloc(), cfd, code, msg,
    content_type, body, body_len, extra_headers);
}

# 204 No Content with optional extra headers (CRLF-terminated cstr or 0).
fn sandhi_server_send_204_a(a, cfd, extra_headers): i64 {
    var sb = str_builder_new_a(a);
    if (sb == 0) { return 0 - 1; }
    str_builder_add_cstr_a(a, sb, "HTTP/1.1 204 No Content\r\n");
    if (extra_headers != 0) { str_builder_add_cstr_a(a, sb, extra_headers); }
    str_builder_add_cstr_a(a, sb, "Content-Length: 0\r\nConnection: close\r\n\r\n");
    var s = str_data(str_builder_build_a(a, sb));
    sock_send(cfd, s, strlen(s));
    return 0;
}

fn sandhi_server_send_204(cfd, extra_headers): i64 {
    return sandhi_server_send_204_a(default_alloc(), cfd, extra_headers);
}

# ================================================================
# Chunked / streaming responses (Transfer-Encoding: chunked)
# ================================================================
# Use this for SSE, large bodies, or any long-running response.
# Sequence:
#   sandhi_server_send_chunked_start(cfd, 200, "text/event-stream", 0);
#   sandhi_server_send_chunk(cfd, "data: hello\n\n", 13);
#   sandhi_server_send_chunk(cfd, "data: world\n\n", 13);
#   sandhi_server_send_chunked_end(cfd);

# Begin a chunked / SSE response. Sends the HTTP/1.1 status line plus
# Transfer-Encoding: chunked. Follow with repeated sandhi_server_send_chunk calls
# and finish with sandhi_server_send_chunked_end. extra_headers is a cstr of
# CRLF-terminated header lines or 0.
fn sandhi_server_send_chunked_start_a(a, cfd, code, content_type, extra_headers): i64 {
    var sb = str_builder_new_a(a);
    if (sb == 0) { return 0 - 1; }
    str_builder_add_cstr_a(a, sb, "HTTP/1.1 ");
    str_builder_add_int_a(a, sb, code);
    str_builder_add_cstr_a(a, sb, " OK\r\nContent-Type: ");
    str_builder_add_cstr_a(a, sb, content_type);
    str_builder_add_cstr_a(a, sb, "\r\nTransfer-Encoding: chunked\r\n");
    if (extra_headers != 0) { str_builder_add_cstr_a(a, sb, extra_headers); }
    str_builder_add_cstr_a(a, sb, "Connection: close\r\n\r\n");
    var head = str_data(str_builder_build_a(a, sb));
    sock_send(cfd, head, strlen(head));
    return 0;
}

fn sandhi_server_send_chunked_start(cfd, code, content_type, extra_headers): i64 {
    return sandhi_server_send_chunked_start_a(default_alloc(), cfd, code, content_type, extra_headers);
}

# Send one chunk of a chunked-transfer response. Emits the chunk-length
# as lowercase hex followed by CRLF, then `len` bytes of `data`, then
# another CRLF. Use between sandhi_server_send_chunked_start and sandhi_server_send_chunked_end.
fn sandhi_server_send_chunk(cfd, data, len): i64 {
    var hexbuf[32];
    var hi = 0;
    var n = len;
    if (n == 0) { store8(&hexbuf, 48); hi = 1; }
    else {
        var tmp[32];
        var ti = 0;
        while (n > 0) {
            var d = n & 15;
            if (d < 10) { store8(&tmp + ti, 48 + d); }
            else { store8(&tmp + ti, 87 + d); }
            n = n >> 4;
            ti = ti + 1;
        }
        var ri = ti;
        while (ri > 0) {
            ri = ri - 1;
            store8(&hexbuf + hi, load8(&tmp + ri));
            hi = hi + 1;
        }
    }
    store8(&hexbuf + hi, 13);
    store8(&hexbuf + hi + 1, 10);
    sock_send(cfd, &hexbuf, hi + 2);
    if (len > 0) { sock_send(cfd, data, len); }
    sock_send(cfd, "\r\n", 2);
    return 0;
}

# Terminate a chunked-transfer response. Sends the zero-length chunk
# that tells the client the body is complete ("0\r\n\r\n").
fn sandhi_server_send_chunked_end(cfd): i64 {
    sock_send(cfd, "0\r\n\r\n", 5);
    return 0;
}

# ================================================================
# Request reading — Content-Length aware
# ================================================================

# Read a complete HTTP request from cfd into buf (up to max bytes). Reads
# until either:
#   - the request body is fully received (per Content-Length), OR
#   - cfd is closed by the peer, OR
#   - max bytes have been read.
# Returns the total bytes read (or 0 - 1 on socket error). Always
# null-terminates buf at the returned length.
fn sandhi_server_recv_request(cfd, buf, max): i64 {
    var have = 0;
    var need_body = 0 - 1;

    while (have < max) {
        var r = sock_recv(cfd, buf + have, max - have);
        if (is_err_result(r) == 1) { return 0 - 1; }
        var n = payload(r);
        if (n <= 0) {
            store8(buf + have, 0);
            return have;
        }
        have = have + n;

        if (need_body == 0 - 1) {
            store8(buf + have, 0);
            var bo = sandhi_server_body_offset(buf, have);
            if (bo >= 0) {
                var clen = sandhi_server_content_length(buf, have);
                need_body = bo + clen;
            }
        }
        if (need_body != 0 - 1 && have >= need_body) {
            store8(buf + have, 0);
            return have;
        }
    }
    store8(buf + have, 0);
    return have;
}

# ================================================================
# Server lifecycle — bind, listen, accept-loop
# ================================================================

# Per-process request buffer (lazily allocated, reused across connections).
var _hsv_req_buf = 0;
var HSV_REQ_BUF_SIZE = 65536;

# ================================================================
# Server options (added 0.7.2)
# ================================================================
#
# Struct layout (16 bytes):
#   +0   idle_ms    (int: per-connection recv timeout; 0 = blocking.
#                    Default 30000 = 30 s; matches Go `net/http.Server.
#                    IdleTimeout`. Slowloris guard — a peer that sends
#                    a partial request then stalls gets dropped.)
#   +8   max_conns  (int: reserved for 0.8.0+. Server today is single-
#                    threaded accept/serve; honoring this requires a
#                    thread-pool or epoll-based accept model, which is
#                    bigger than 0.7.2 budget. Getter/setter exist
#                    so the option survey-surface stays stable across
#                    0.7.2 → 0.8.0.)

enum SandhiServerOptOff {
    SANDHI_SERVER_OPT_OFF_IDLE_MS   = 0;
    SANDHI_SERVER_OPT_OFF_MAX_CONNS = 8;
}

var SANDHI_SERVER_OPT_STRUCT_SIZE = 16;
var SANDHI_SERVER_DEFAULT_IDLE_MS = 30000;
var SANDHI_SERVER_DEFAULT_MAX_CONNS = 128;

fn sandhi_server_options_new_a(a): i64 {
    var o = alloc_via(a, SANDHI_SERVER_OPT_STRUCT_SIZE);
    if (o == 0) { return 0; }
    store64(o + SANDHI_SERVER_OPT_OFF_IDLE_MS, SANDHI_SERVER_DEFAULT_IDLE_MS);
    store64(o + SANDHI_SERVER_OPT_OFF_MAX_CONNS, SANDHI_SERVER_DEFAULT_MAX_CONNS);
    return o;
}

fn sandhi_server_options_new(): i64 {
    return sandhi_server_options_new_a(default_alloc());
}

fn sandhi_server_options_idle_ms(opts, ms): i64 {
    store64(opts + SANDHI_SERVER_OPT_OFF_IDLE_MS, ms);
    return 0;
}

fn sandhi_server_options_max_conns(opts, n): i64 {
    store64(opts + SANDHI_SERVER_OPT_OFF_MAX_CONNS, n);
    return 0;
}

fn sandhi_server_options_get_idle_ms(opts): i64 {
    if (opts == 0) { return SANDHI_SERVER_DEFAULT_IDLE_MS; }
    return load64(opts + SANDHI_SERVER_OPT_OFF_IDLE_MS);
}

fn sandhi_server_options_get_max_conns(opts): i64 {
    if (opts == 0) { return SANDHI_SERVER_DEFAULT_MAX_CONNS; }
    return load64(opts + SANDHI_SERVER_OPT_OFF_MAX_CONNS);
}

# Bind addr:port, listen, accept-loop. For each connection:
#   read full request → call handler_fp(ctx, cfd, buf, bytes) → close cfd.
#
# `addr` is a network-order IPv4 (use INADDR_ANY() for 0.0.0.0,
# INADDR_LOOPBACK() for 127.0.0.1). `handler_fp` must have the signature:
#   fn handler(ctx, cfd, req_buf, req_len) → 0
#
# Returns 1 on bind/listen failure; never returns on success (loops forever).
fn sandhi_server_run(addr, port, handler_fp, ctx): i64 {
    return sandhi_server_run_opts(addr, port, handler_fp, ctx, 0);
}

# Opts-aware variant. Applies SO_RCVTIMEO on each accepted connection
# to bound slow/idle peers (slowloris guard). max_conns is accepted
# but not honored today — server stays single-threaded until 0.8.0.
fn sandhi_server_run_opts(addr, port, handler_fp, ctx, opts): i64 {
    # _hsv_req_buf is a process-wide singleton shared across every
    # accepted connection — it must outlive any per-request arena, so
    # always allocate from the global bump.
    if (_hsv_req_buf == 0) { _hsv_req_buf = alloc_via(default_alloc(), HSV_REQ_BUF_SIZE); }

    var idle_ms = sandhi_server_options_get_idle_ms(opts);

    var sfd_r = tcp_socket();
    if (is_err_result(sfd_r) == 1) { return 1; }
    var sfd = payload(sfd_r);
    sock_reuse(sfd);

    var br = sock_bind(sfd, addr, port);
    if (is_err_result(br) == 1) { return 1; }

    var lr = sock_listen(sfd, 16);
    if (is_err_result(lr) == 1) { return 1; }

    while (1 == 1) {
        var cr = sock_accept(sfd);
        if (is_err_result(cr) == 0) {
            var cfd = payload(cr);
            # Apply per-connection idle timeout (slowloris guard).
            # _sandhi_conn_set_timeout_ms is sandhi/http/conn.cyr's
            # setsockopt helper — works on any socket fd, not just
            # client-side ones.
            if (idle_ms > 0) {
                _sandhi_conn_set_timeout_ms(cfd, idle_ms, _SANDHI_SO_RCVTIMEO);
            }
            var n = sandhi_server_recv_request(cfd, _hsv_req_buf, HSV_REQ_BUF_SIZE - 1);
            if (n > 0) {
                # 0.9.0 P0 #2 — reject CL+TE coexistence with 400
                # (smuggling vector, RFC 7230 §3.3.3).
                # 0.9.1 P1 — also reject Host.Host / CL.CL / TE.TE
                # duplicates (smuggling vector, RFC 7230 §3.3.2 + §5.4).
                if (sandhi_server_request_has_cl_te_conflict(_hsv_req_buf, n) == 1) {
                    sandhi_server_send_status(cfd, 400, "Bad Request");
                } elif (sandhi_server_request_has_dup_smuggling_header(_hsv_req_buf, n) == 1) {
                    sandhi_server_send_status(cfd, 400, "Bad Request");
                } else {
                    fncall4(handler_fp, ctx, cfd, _hsv_req_buf, n);
                }
            }
            sock_close(cfd);
        }
    }
    return 0;
}

# ================================================================
# sandhi-scoped identity
# ================================================================
# Kept so downstream can probe the migrated-module version. Retires
# when fold-into-stdlib lands; consumers should prefer sandhi_version().

# --- main.cyr ---

# sandhi — public API / library root.
#
# This file declares the top-level surface that consumers include
# via `lib/sandhi.cyr` (once folded into Cyrius stdlib) or
# `dist/sandhi.cyr` (the distributed bundle pre-fold).
#
# No top-level `main()` / `syscall(60)` — sandhi is a LIBRARY.
# `programs/smoke.cyr` is the compile-link proof target.
#
# Per ADR 0001: sandhi composes stdlib primitives (http.cyr, ws.cyr,
# tls.cyr, json.cyr, net.cyr) into full-featured client patterns +
# service discovery. It does NOT reimplement the primitives.
# Scaffolded 2026-04-24.

# --- Public surface ---------------------------------------------------------
# Each sub-module exposes a small, documented verb set:
#   sandhi::http            — HTTP/1.1 + HTTP/2 client. Full method
#                             surface (GET/POST/PUT/DELETE/PATCH/HEAD),
#                             custom headers, HTTPS via tls, opt-in
#                             bounded redirect following, full timeout
#                             matrix (connect/read/write/total),
#                             retry-with-backoff for idempotent
#                             methods. Auto-selection between h2 and
#                             1.1 via `sandhi_http_request_auto`.
#   sandhi::http::pool      — per-route connection pool. Backs
#                             HTTP/1.1 keep-alive + HTTP/2 stream
#                             multiplex from the same struct (ADR
#                             0003). Opt-in via `sandhi_http_options_pool`.
#   sandhi::http::h2        — full HTTP/2 protocol stack: frames
#                             (RFC 7540 §6), HPACK header compression
#                             with Huffman decode (RFC 7541), per-call
#                             reentrant connection lifecycle.
#                             `sandhi_h2_request` is the manual entry
#                             point; auto-selection wires it through
#                             the pool.
#   sandhi::http::stream    — streaming HTTP + WHATWG SSE parser +
#                             incremental chunked decode + callback-per-
#                             event dispatch.
#   sandhi::rpc             — JSON-RPC dialects (W3C WebDriver wire,
#                             Appium extensions, MCP-over-HTTP + SSE).
#                             Transport only per ADR 0001 — protocol
#                             semantics live in bote / t-ron.
#   sandhi::discovery       — service discovery: daimon-registered
#                             lookup, chain-fallback composition,
#                             mDNS resolver (RFC 6762 link-local A
#                             query against 224.0.0.251:5353).
#   sandhi::tls_policy      — cert pinning (SPKI, constant-time
#                             compare), mTLS, custom trust store,
#                             policy composition, ALPN advertise list.
#                             Runtime enforcement wired since 0.9.3
#                             (libssl/libcrypto symbols resolved via
#                             stdlib `tls_dlsym`); fail-closed when a
#                             policy demands enforcement that isn't
#                             wired.
#   sandhi::server          — HTTP/1.1 server. Canonical names are
#                             `sandhi_server_*` (post-0.9.2 rename);
#                             `http_*` aliases retained as transitional
#                             wrappers, retire at the v5.7.0 fold.
#                             Built-in 400-on-smuggling guards (CL+TE,
#                             dup Host/CL/TE).

# `SANDHI_VERSION` is declared in `src/version_str.cyr`, which is
# auto-generated from the top-level `VERSION` file via
# `scripts/version-bump.sh` (mirrors the cyrius pattern in
# `cyrius/src/version_str.cyr`). VERSION is the only place a
# developer edits the version string; the bump script regenerates
# version_str.cyr in lockstep and CI fails the build if they drift.
fn sandhi_version(): i64 {
    return SANDHI_VERSION;
}
